      *    *===========================================================*
      *    * Determinazione numero pagine che compongono la testata    *
      *    *-----------------------------------------------------------*
       dmp-tes-reg-000.
      *              *-------------------------------------------------*
      *              * La testata e' composta di nr. 3 pagine          *
      *              *-------------------------------------------------*
           move      3                    to   w-cnt-sts-imp-mpt      .
       dmp-tes-reg-999.
           exit.

      *    *===========================================================*
      *    * Determinazione si/no pagina w-cnt-sts-imp-npt da trattare *
      *    *-----------------------------------------------------------*
       snp-tes-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-sts-imp-snp      .
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del numero pagina        *
      *              *-------------------------------------------------*
           go to     snp-tes-reg-100
                     snp-tes-reg-200
                     snp-tes-reg-300
                     depending            on   w-cnt-sts-imp-npt      .
           go to     snp-tes-reg-999.
       snp-tes-reg-100.
      *              *-------------------------------------------------*
      *              * Pagina 1 : sempre accettata                     *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-sts-imp-snp      .
           go to     snp-tes-reg-999.
       snp-tes-reg-200.
      *              *-------------------------------------------------*
      *              * Pagina 2 : da accettare solo se il documento    *
      *              *            interessa la fatturazione            *
      *              *-------------------------------------------------*
           if        w-tes-int-ftr        =    01
                     move  "#"            to   w-cnt-sts-imp-snp      .
           go to     snp-tes-reg-999.
       snp-tes-reg-300.
      *              *-------------------------------------------------*
      *              * Pagina 3 : da accettare solo se il documento    *
      *              *            interessa la fatturazione            *
      *              *-------------------------------------------------*
           if        w-tes-int-ftr        =    01
                     move  "#"            to   w-cnt-sts-imp-snp      .
           go to     snp-tes-reg-999.
       snp-tes-reg-999.
           exit.

      *    *===========================================================*
      *    * Accettazione testata registrazione                        *
      *    *-----------------------------------------------------------*
       acc-tes-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione tipo uscita                     *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-tes      .
      *              *-------------------------------------------------*
      *              * Normalizzazione function-key                    *
      *              *-------------------------------------------------*
           move      spaces               to   v-key                  .
      *              *-------------------------------------------------*
      *              * Tipo impostazione : testata                     *
      *              *-------------------------------------------------*
           move      "T"                  to   w-cnt-mfu-tip-imp      .
      *              *-------------------------------------------------*
      *              * Accettazioni                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del numero pagina    *
      *                  *---------------------------------------------*
           go to     acc-tes-reg-100
                     acc-tes-reg-200
                     acc-tes-reg-300
                     depending            on   w-cnt-sts-imp-npt      .
           go to     acc-tes-reg-999.
       acc-tes-reg-100.
      *                  *---------------------------------------------*
      *                  * Normalizzazione func-key di impostazione    *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Tipo archivio                               *
      *                  *---------------------------------------------*
           perform   acc-tip-arc-000      thru acc-tip-arc-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
       acc-tes-reg-110.
      *                  *---------------------------------------------*
      *                  * Codice archivio                             *
      *                  *---------------------------------------------*
           perform   acc-cod-arc-000      thru acc-cod-arc-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-100.
       acc-tes-reg-120.
      *                  *---------------------------------------------*
      *                  * Codice dipendenza                           *
      *                  *---------------------------------------------*
           perform   acc-dpz-arc-000      thru acc-dpz-arc-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-110.
       acc-tes-reg-130.
      *                  *---------------------------------------------*
      *                  * Data documento del fornitore                *
      *                  *---------------------------------------------*
           perform   acc-dat-doc-000      thru acc-dat-doc-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-120.
       acc-tes-reg-140.
      *                  *---------------------------------------------*
      *                  * Numero documento del fornitore              *
      *                  *---------------------------------------------*
           perform   acc-num-doc-000      thru acc-num-doc-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-130.
       acc-tes-reg-150.
      *                  *---------------------------------------------*
      *                  * Si/no documento da verificare               *
      *                  *---------------------------------------------*
           perform   acc-snx-dav-000      thru acc-snx-dav-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-140.
      *                  *---------------------------------------------*
      *                  * Se Next Screen o Tab in corso               *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     move  "+"            to   w-cnt-tus-acc-tes
                     go to acc-tes-reg-999.
      *                  *---------------------------------------------*
      *                  * Presa visione per pagina 1                  *
      *                  *---------------------------------------------*
           perform   acc-pre-vpg-000      thru acc-pre-vpg-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-tes      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-150.
      *                  *---------------------------------------------*
      *                  * Fine Pagina                                 *
      *                  *---------------------------------------------*
           move      "+"                  to   w-cnt-tus-acc-tes      .
           go to     acc-tes-reg-999.
       acc-tes-reg-200.
      *                  *---------------------------------------------*
      *                  * Inoltro pagamenti                           *
      *                  *---------------------------------------------*
           perform   acc-inl-pgt-000      thru acc-inl-pgt-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     move  "-"            to   w-cnt-tus-acc-tes
                     go to acc-tes-reg-999.
       acc-tes-reg-210.
      *                  *---------------------------------------------*
      *                  * Sigla valuta per fatturazione               *
      *                  *---------------------------------------------*
           perform   acc-sgl-vpf-000      thru acc-sgl-vpf-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-200.
       acc-tes-reg-212.
      *                  *---------------------------------------------*
      *                  * Coefficiente di cambio                      *
      *                  *---------------------------------------------*
           perform   acc-cdc-vpf-000      thru acc-cdc-vpf-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-210.
       acc-tes-reg-215.
      *                  *---------------------------------------------*
      *                  * Assoggettamento iva                         *
      *                  *---------------------------------------------*
           perform   acc-ass-iva-000      thru acc-ass-iva-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-212.
       acc-tes-reg-220.
      *                  *---------------------------------------------*
      *                  * Contropartita acquisti                      *
      *                  *---------------------------------------------*
           perform   acc-ctp-acq-000      thru acc-ctp-acq-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-215.
      *                  *---------------------------------------------*
      *                  * Se Next Screen o Tab in corso               *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     move  "+"            to   w-cnt-tus-acc-tes
                     go to acc-tes-reg-999.
      *                  *---------------------------------------------*
      *                  * Presa visione per pagina 2                  *
      *                  *---------------------------------------------*
           perform   acc-pre-vpg-000      thru acc-pre-vpg-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-tes      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-220.
      *                  *---------------------------------------------*
      *                  * Fine Pagina                                 *
      *                  *---------------------------------------------*
           move      "+"                  to   w-cnt-tus-acc-tes      .
           go to     acc-tes-reg-999.
       acc-tes-reg-300.
      *                  *---------------------------------------------*
      *                  * Codice forma di pagamento                   *
      *                  *---------------------------------------------*
           perform   acc-cod-fop-000      thru acc-cod-fop-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     move  "-"            to   w-cnt-tus-acc-tes
                     go to acc-tes-reg-999.
       acc-tes-reg-305.
      *                  *---------------------------------------------*
      *                  * Codice nostra banca di appoggio             *
      *                  *---------------------------------------------*
           perform   acc-nos-ban-000      thru acc-nos-ban-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-300.
       acc-tes-reg-310.
      *                  *---------------------------------------------*
      *                  * Codice ABI banca di appoggio per bonifici   *
      *                  *---------------------------------------------*
           perform   acc-cod-abi-000      thru acc-cod-abi-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-300.
       acc-tes-reg-315.
      *                  *---------------------------------------------*
      *                  * Codice CAB sportello banca di appoggio per  *
      *                  * bonifici                                    *
      *                  *---------------------------------------------*
           perform   acc-cod-cab-000      thru acc-cod-cab-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-310.
       acc-tes-reg-320.
      *                  *---------------------------------------------*
      *                  * Conto corrente di appoggio per bonifici     *
      *                  *---------------------------------------------*
           perform   acc-ccc-app-000      thru acc-ccc-app-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-315.
       acc-tes-reg-325.
      *                  *---------------------------------------------*
      *                  * Conto corrente postale                      *
      *                  *---------------------------------------------*
           perform   acc-ccp-app-000      thru acc-ccp-app-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-320.
       acc-tes-reg-330.
      *                  *---------------------------------------------*
      *                  * Tipo addebito spese incasso                 *
      *                  *---------------------------------------------*
           perform   acc-add-spi-000      thru acc-add-spi-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-325.
       acc-tes-reg-335.
      *                  *---------------------------------------------*
      *                  * Tipo addebito spese bollo                   *
      *                  *---------------------------------------------*
           perform   acc-add-spb-000      thru acc-add-spb-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-330.
       acc-tes-reg-340.
      *                  *---------------------------------------------*
      *                  * Data scadenza manuale pagamento             *
      *                  *---------------------------------------------*
           perform   acc-pag-dsm-000      thru acc-pag-dsm-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-335.
       acc-tes-reg-345.
      *                  *---------------------------------------------*
      *                  * Ammontare quota a forfait pagamento         *
      *                  *---------------------------------------------*
           perform   acc-pag-qaf-000      thru acc-pag-qaf-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-340.
       acc-tes-reg-350.
      *                  *---------------------------------------------*
      *                  * Ammontare acconto                           *
      *                  *---------------------------------------------*
           perform   acc-pag-act-000      thru acc-pag-act-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-345.
      *                  *---------------------------------------------*
      *                  * Se Next Screen o Tab in corso               *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     move  "+"            to   w-cnt-tus-acc-tes
                     go to acc-tes-reg-999.
      *                  *---------------------------------------------*
      *                  * Presa visione per pagina 3                  *
      *                  *---------------------------------------------*
           perform   acc-pre-vpg-000      thru acc-pre-vpg-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-tes      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-350.
      *                  *---------------------------------------------*
      *                  * Fine Pagina                                 *
      *                  *---------------------------------------------*
           move      "+"                  to   w-cnt-tus-acc-tes      .
           go to     acc-tes-reg-999.
       acc-tes-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione testata registrazione                     *
      *    *-----------------------------------------------------------*
       vis-tes-reg-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del numero pagina        *
      *              *-------------------------------------------------*
           go to     vis-tes-reg-100
                     vis-tes-reg-200
                     vis-tes-reg-300
                     depending            on   w-cnt-sts-imp-npt      .
           go to     vis-tes-reg-999.
       vis-tes-reg-100.
      *              *-------------------------------------------------*
      *              * Tipo archivio                                   *
      *              *-------------------------------------------------*
           perform   vis-tip-arc-000      thru vis-tip-arc-999        .
      *              *-------------------------------------------------*
      *              * Codice archivio                                 *
      *              *-------------------------------------------------*
           perform   vis-cod-arc-000      thru vis-cod-arc-999        .
           perform   vis-cod-arc-des-000  thru vis-cod-arc-des-999    .
      *              *-------------------------------------------------*
      *              * Codice dipendenza archivio                      *
      *              *-------------------------------------------------*
           perform   vis-dpz-arc-000      thru vis-dpz-arc-999        .
           perform   vis-dpz-arc-des-000  thru vis-dpz-arc-des-999    .
      *              *-------------------------------------------------*
      *              * Data documento del fornitore                    *
      *              *-------------------------------------------------*
           perform   vis-dat-doc-000      thru vis-dat-doc-999        .
      *              *-------------------------------------------------*
      *              * Numero documento del fornitore                  *
      *              *-------------------------------------------------*
           perform   vis-num-doc-000      thru vis-num-doc-999        .
      *              *-------------------------------------------------*
      *              * Protocollo di magazzino                         *
      *              *-------------------------------------------------*
           perform   vis-prt-mag-000      thru vis-prt-mag-999        .
      *              *-------------------------------------------------*
      *              * Protocollo di magazzino 2                       *
      *              *-------------------------------------------------*
           perform   vis-pr2-mag-000      thru vis-pr2-mag-999        .
      *              *-------------------------------------------------*
      *              * Si/no documento da verificare                   *
      *              *-------------------------------------------------*
           perform   vis-snx-dav-000      thru vis-snx-dav-999        .
      *              *-------------------------------------------------*
      *              * Distinta di verifica                            *
      *              *-------------------------------------------------*
           perform   vis-dst-bfe-000      thru vis-dst-bfe-999        .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     vis-tes-reg-999.
       vis-tes-reg-200.
      *              *-------------------------------------------------*
      *              * Inoltro pagamenti                               *
      *              *-------------------------------------------------*
           perform   vis-inl-pgt-000      thru vis-inl-pgt-999        .
      *              *-------------------------------------------------*
      *              * Sigla valuta per fatturazione                   *
      *              *-------------------------------------------------*
           perform   vis-sgl-vpf-000      thru vis-sgl-vpf-999        .
           perform   vis-sgl-vpf-des-000  thru vis-sgl-vpf-des-999    .
      *              *-------------------------------------------------*
      *              * Coefficiente di cambio                          *
      *              *-------------------------------------------------*
           perform   vis-cdc-vpf-000      thru vis-cdc-vpf-999        .
      *              *-------------------------------------------------*
      *              * Assoggettamento iva                             *
      *              *-------------------------------------------------*
           perform   vis-ass-iva-000      thru vis-ass-iva-999        .
           perform   vis-ass-iva-des-000  thru vis-ass-iva-des-999    .
      *              *-------------------------------------------------*
      *              * Contropartita acquisti                          *
      *              *-------------------------------------------------*
           perform   vis-ctp-acq-000      thru vis-ctp-acq-999        .
           perform   vis-ctp-acq-des-000  thru vis-ctp-acq-des-999    .
           go to     vis-tes-reg-999.
       vis-tes-reg-300.
      *              *-------------------------------------------------*
      *              * Codice forma di pagamento                       *
      *              *-------------------------------------------------*
           perform   vis-cod-fop-000      thru vis-cod-fop-999        .
           perform   vis-des-fop-000      thru vis-des-fop-999        .
      *              *-------------------------------------------------*
      *              * Percentuale sconto pagamento                    *
      *              *-------------------------------------------------*
           perform   vis-scp-aap-000      thru vis-scp-aap-999        .
      *              *-------------------------------------------------*
      *              * Codice nostra banca di appoggio                 *
      *              *-------------------------------------------------*
           perform   vis-nos-ban-000      thru vis-nos-ban-999        .
           perform   vis-nos-ban-des-000  thru vis-nos-ban-des-999    .
      *              *-------------------------------------------------*
      *              * Codice ABI banca di appoggio per bonifici       *
      *              *-------------------------------------------------*
           perform   vis-cod-abi-000      thru vis-cod-abi-999        .
           perform   vis-den-abi-000      thru vis-den-abi-999        .
      *              *-------------------------------------------------*
      *              * Codice CAB sportello banca di appoggio          *
      *              *-------------------------------------------------*
           perform   vis-cod-cab-000      thru vis-cod-cab-999        .
           perform   vis-den-cab-000      thru vis-den-cab-999        .
      *              *-------------------------------------------------*
      *              * Conto corrente di appoggio per bonifici         *
      *              *-------------------------------------------------*
           perform   vis-ccc-app-000      thru vis-ccc-app-999        .
      *              *-------------------------------------------------*
      *              * Conto corrente postale                          *
      *              *-------------------------------------------------*
           perform   vis-ccp-app-000      thru vis-ccp-app-999        .
      *              *-------------------------------------------------*
      *              * Tipo addebito spese incasso                     *
      *              *-------------------------------------------------*
           perform   vis-add-spi-000      thru vis-add-spi-999        .
           perform   vis-des-spi-000      thru vis-des-spi-999        .
      *              *-------------------------------------------------*
      *              * Tipo addebito spese bollo                       *
      *              *-------------------------------------------------*
           perform   vis-add-spb-000      thru vis-add-spb-999        .
           perform   vis-des-spb-000      thru vis-des-spb-999        .
      *              *-------------------------------------------------*
      *              * Data scadenza manuale pagamento                 *
      *              *-------------------------------------------------*
           perform   vis-pag-dsm-000      thru vis-pag-dsm-999        .
      *              *-------------------------------------------------*
      *              * Ammontare quota a forfait pagamento             *
      *              *-------------------------------------------------*
           perform   vis-pag-qaf-000      thru vis-pag-qaf-999        .
      *              *-------------------------------------------------*
      *              * Ammontare acconto                               *
      *              *-------------------------------------------------*
           perform   vis-pag-act-000      thru vis-pag-act-999        .
           go to     vis-tes-reg-999.
       vis-tes-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts testata                           *
      *    *-----------------------------------------------------------*
       pmt-tes-reg-000.
      *              *-------------------------------------------------*
      *              * Erase linee impegnate dalla testata a seconda   *
      *              * del numero pagina                               *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           if        w-cnt-sts-imp-npt    =    1
                     move 07              to   v-lin
           else      move 04              to   v-lin                  .
           move      21                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del numero pagina        *
      *              *-------------------------------------------------*
           go to     pmt-tes-reg-100
                     pmt-tes-reg-200
                     pmt-tes-reg-300
                     depending            on   w-cnt-sts-imp-npt      .
           go to     pmt-tes-reg-999.
       pmt-tes-reg-100.
      *              *-------------------------------------------------*
      *              * Tipo archivio                                   *
      *              *-------------------------------------------------*
           perform   pmt-tip-arc-000      thru pmt-tip-arc-999        .
      *              *-------------------------------------------------*
      *              * Partita iva cliente o fornitore                 *
      *              *-------------------------------------------------*
           perform   pmt-piv-cof-000      thru pmt-piv-cof-999        .
      *              *-------------------------------------------------*
      *              * Codice dipendenza                               *
      *              *-------------------------------------------------*
           perform   pmt-dpz-arc-000      thru pmt-dpz-arc-999        .
      *              *-------------------------------------------------*
      *              * Data documento del fornitore                    *
      *              *-------------------------------------------------*
           perform   pmt-dat-doc-000      thru pmt-dat-doc-999        .
      *              *-------------------------------------------------*
