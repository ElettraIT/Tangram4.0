      *    *===========================================================*
      *    * Accettazione campo chiave : Tipo bilancio                 *
      *    *-----------------------------------------------------------*
       acc-tip-bil-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-tip-bil        to   w-sav-tip-bil          .
       acc-tip-bil-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-ztb-ope      .
           move      w-tes-tip-bil        to   w-cod-cod-ztb-cod      .
           move      04                   to   w-cod-cod-ztb-lin      .
           move      25                   to   w-cod-cod-ztb-pos      .
           move      spaces               to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   cod-cod-ztb-cll-000  thru cod-cod-ztb-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-ztb-foi-000  thru cod-cod-ztb-foi-999    .
       acc-tip-bil-110.
           perform   cod-cod-ztb-cll-000  thru cod-cod-ztb-cll-999    .
           if        w-cod-cod-ztb-ope    =    "F+"
                     go to acc-tip-bil-115.
           if        w-cod-cod-ztb-ope    =    "AC"
                     go to acc-tip-bil-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-tip-bil-115.
           perform   cod-cod-ztb-foi-000  thru cod-cod-ztb-foi-999    .
           go to     acc-tip-bil-110.
       acc-tip-bil-120.
           move      w-cod-cod-ztb-cod    to   v-alf                  .
       acc-tip-bil-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-tip-bil-999.
       acc-tip-bil-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-tip-bil          .
       acc-tip-bil-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [ztb]                      *
      *                  *---------------------------------------------*
           move      w-tes-tip-bil        to   w-let-arc-ztb-cod      .
           perform   let-arc-ztb-000      thru let-arc-ztb-999        .
           move      w-let-arc-ztb-des    to   w-tes-tip-bil-des      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-tip-bil-des-000  thru vis-tip-bil-des-999    .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-ztb-flg    not  = spaces
                     go to acc-tip-bil-100.
       acc-tip-bil-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-tip-bil        =    w-sav-tip-bil
                     go to acc-tip-bil-800.
      *                  *---------------------------------------------*
      *                  * Normalizzazione voci di bilancio            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Livello 1                               *
      *                      *-----------------------------------------*
           if        w-tes-vdb-lv1        not  = zero
                     move  zero           to   w-tes-vdb-lv1
                     move  spaces         to   w-tes-vdb-lv1-mne
                     move  spaces         to   w-tes-vdb-lv1-des
                     move  zero           to   w-tes-vdb-lv1-tcb
                     move  spaces         to   w-tes-vdb-lv1-isg
                     perform vis-vdb-lv1-000
