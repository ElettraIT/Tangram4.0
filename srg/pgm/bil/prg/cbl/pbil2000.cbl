       vis-tip-ope-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-tip-vdb (1)    not  = 03
                     go to vis-tip-ope-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-ope-lun    to   v-car                  .
           move      w-exp-tip-ope-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      19                   to   v-lin                  .
           move      20                   to   v-pos                  .
           move      w-exp-tip-ope-tbl    to   v-txt                  .
           if        w-rig-tip-ope (1)    =    "+"
                     move  01             to   v-num
           else if   w-rig-tip-ope (1)    =    "-"
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tip-ope-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice voce di risultato             *
      *    *-----------------------------------------------------------*
       acc-vrs-lvx-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione contatore da 1..5              *
      *              *-------------------------------------------------*
           move      1                    to   w-acc-vrs-lvx-ctr      .
       acc-vrs-lvx-050.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-tip-vdb (1)    not  = 03
                     go to acc-vrs-lvx-999.
      *                  *---------------------------------------------*
      *                  * Test se indice da accettare                 *
      *                  *---------------------------------------------*
           if        w-acc-vrs-lvx-ctr    =    1
                     go to acc-vrs-lvx-060.
           subtract  1                    from w-acc-vrs-lvx-ctr
                                        giving w-acc-vrs-lvx-inx      .
           if        w-rig-vrs-lvx
                    (1, w-acc-vrs-lvx-inx)
                                          =    zero
                     go to acc-vrs-lvx-999.
           if        w-rig-vrs-lvx-tcb
                    (1, w-acc-vrs-lvx-inx)    not  = 01
                     go to acc-vrs-lvx-999.
       acc-vrs-lvx-060.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-vrs-lvx
                    (1, w-acc-vrs-lvx-ctr)
                                          to   w-sav-vrs-lvx          .
       acc-vrs-lvx-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-vdb-ope      .
           move      w-tes-tip-bil        to   w-cod-mne-vdb-tpb      .
           move      w-acc-vrs-lvx-ctr    to   w-cod-mne-vdb-liv      .
           move      w-rig-vrs-lvx (1, 1) to   w-cod-mne-vdb-lv1      .
           move      w-rig-vrs-lvx (1, 2) to   w-cod-mne-vdb-lv2      .
           move      w-rig-vrs-lvx (1, 3) to   w-cod-mne-vdb-lv3      .
           move      w-rig-vrs-lvx (1, 4) to   w-cod-mne-vdb-lv4      .
           move      w-rig-vrs-lvx (1, 5) to   w-cod-mne-vdb-lv5      .
           move      w-rig-vrs-lvx (1, 6) to   w-cod-mne-vdb-lv6      .
           move      20                   to   w-cod-mne-vdb-lin      .
           if        w-acc-vrs-lvx-ctr    =    1
                     move  20             to   w-cod-mne-vdb-pos
           else if   w-acc-vrs-lvx-ctr    =    2
                     move  26             to   w-cod-mne-vdb-pos
           else if   w-acc-vrs-lvx-ctr    =    3
                     move  32             to   w-cod-mne-vdb-pos
           else if   w-acc-vrs-lvx-ctr    =    4
                     move  38             to   w-cod-mne-vdb-pos
           else if   w-acc-vrs-lvx-ctr    =    5
                     move  44             to   w-cod-mne-vdb-pos
           else if   w-acc-vrs-lvx-ctr    =    6
                     move  50             to   w-cod-mne-vdb-pos      .
           move      21                   to   w-cod-mne-vdb-dln      .
           move      20                   to   w-cod-mne-vdb-dps      .
           move      "B<"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cod-mne-vdb-cll-000  thru cod-mne-vdb-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-vdb-foi-000  thru cod-mne-vdb-foi-999    .
       acc-vrs-lvx-110.
           perform   cod-mne-vdb-cll-000  thru cod-mne-vdb-cll-999    .
           if        w-cod-mne-vdb-ope    =    "F+"
                     go to acc-vrs-lvx-115.
           if        w-cod-mne-vdb-ope    =    "AC"
                     go to acc-vrs-lvx-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-vrs-lvx-115.
           perform   cod-mne-vdb-foi-000  thru cod-mne-vdb-foi-999    .
           go to     acc-vrs-lvx-110.
       acc-vrs-lvx-120.
           move      w-cod-mne-vdb-lvx    to   v-num                  .
       acc-vrs-lvx-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-vrs-lvx-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-vrs-lvx-999.
       acc-vrs-lvx-200.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-vrs-lvx
                                              (1, w-acc-vrs-lvx-ctr)  .
       acc-vrs-lvx-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
           if        w-rig-vrs-lvx
                    (1, w-acc-vrs-lvx-ctr)
                                          not  = zero
                     go to acc-vrs-lvx-450.
      *                  *---------------------------------------------*
      *                  * Normalizzazione descrizione                 *
      *                  *---------------------------------------------*
           move      spaces               to   w-rig-vrs-lvx-des
                                              (1, w-acc-vrs-lvx-ctr)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-vrs-lvx-des-000  thru vis-vrs-lvx-des-999    .
      *                  *---------------------------------------------*
      *                  * Se livello 1 : ammesso solo se UP           *
      *                  *---------------------------------------------*
           if        w-acc-vrs-lvx-ctr    =    1
                     if    v-key          =    "UP  "
                           go to acc-vrs-lvx-600
                     else  go to acc-vrs-lvx-100.
      *                  *---------------------------------------------*
      *                  * Altrimenti : nessun ulteriore controllo     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * A dipendenze dall'impostazione          *
      *                      *-----------------------------------------*
           go to     acc-vrs-lvx-600.
       acc-vrs-lvx-450.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [vbt]                      *
      *                  *---------------------------------------------*
           move      w-tes-tip-bil        to   w-let-arc-vbt-tpb      .
           if        w-acc-vrs-lvx-ctr    =    1
                     move  w-rig-vrs-lvx (1, 1)
                                          to   w-let-arc-vbt-vb1
                     move  zero           to   w-let-arc-vbt-vb2
                     move  zero           to   w-let-arc-vbt-vb3
                     move  zero           to   w-let-arc-vbt-vb4
                     move  zero           to   w-let-arc-vbt-vb5
                     move  zero           to   w-let-arc-vbt-vb6
           else if   w-acc-vrs-lvx-ctr    =    2
                     move  w-rig-vrs-lvx (1, 1)
                                          to   w-let-arc-vbt-vb1
                     move  w-rig-vrs-lvx (1, 2)
                                          to   w-let-arc-vbt-vb2
                     move  zero           to   w-let-arc-vbt-vb3
                     move  zero           to   w-let-arc-vbt-vb4
                     move  zero           to   w-let-arc-vbt-vb5
                     move  zero           to   w-let-arc-vbt-vb6
           else if   w-acc-vrs-lvx-ctr    =    3
                     move  w-rig-vrs-lvx (1, 1)
                                          to   w-let-arc-vbt-vb1
                     move  w-rig-vrs-lvx (1, 2)
                                          to   w-let-arc-vbt-vb2
                     move  w-rig-vrs-lvx (1, 3)
                                          to   w-let-arc-vbt-vb3
                     move  zero           to   w-let-arc-vbt-vb4
                     move  zero           to   w-let-arc-vbt-vb5
                     move  zero           to   w-let-arc-vbt-vb6
           else if   w-acc-vrs-lvx-ctr    =    4
                     move  w-rig-vrs-lvx (1, 1)
                                          to   w-let-arc-vbt-vb1
                     move  w-rig-vrs-lvx (1, 2)
                                          to   w-let-arc-vbt-vb2
                     move  w-rig-vrs-lvx (1, 3)
                                          to   w-let-arc-vbt-vb3
                     move  w-rig-vrs-lvx (1, 4)
                                          to   w-let-arc-vbt-vb4
                     move  zero           to   w-let-arc-vbt-vb5
                     move  zero           to   w-let-arc-vbt-vb6
           else if   w-acc-vrs-lvx-ctr    =    5
                     move  w-rig-vrs-lvx (1, 1)
                                          to   w-let-arc-vbt-vb1
                     move  w-rig-vrs-lvx (1, 2)
                                          to   w-let-arc-vbt-vb2
                     move  w-rig-vrs-lvx (1, 3)
                                          to   w-let-arc-vbt-vb3
                     move  w-rig-vrs-lvx (1, 4)
                                          to   w-let-arc-vbt-vb4
                     move  w-rig-vrs-lvx (1, 5)
                                          to   w-let-arc-vbt-vb5
                     move  zero           to   w-let-arc-vbt-vb6
           else if   w-acc-vrs-lvx-ctr    =    6
                     move  w-rig-vrs-lvx (1, 1)
                                          to   w-let-arc-vbt-vb1
                     move  w-rig-vrs-lvx (1, 2)
                                          to   w-let-arc-vbt-vb2
                     move  w-rig-vrs-lvx (1, 3)
                                          to   w-let-arc-vbt-vb3
                     move  w-rig-vrs-lvx (1, 4)
                                          to   w-let-arc-vbt-vb4
                     move  w-rig-vrs-lvx (1, 5)
                                          to   w-let-arc-vbt-vb5
                     move  w-rig-vrs-lvx (1, 6)
                                          to   w-let-arc-vbt-vb6      .
           perform   let-arc-vbt-000      thru let-arc-vbt-999        .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione descrizione                 *
      *                  *---------------------------------------------*
           move      w-let-arc-vbt-des    to   w-rig-vrs-lvx-des
                                              (1, w-acc-vrs-lvx-ctr)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-vrs-lvx-des-000  thru vis-vrs-lvx-des-999    .
      *                  *---------------------------------------------*
      *                  * Se lettura errata : reimpostazione          *
      *                  *---------------------------------------------*
           if        w-let-arc-vbt-flg    not  = spaces
                     go to acc-vrs-lvx-100.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione dati voce di bilancio       *
      *                  *---------------------------------------------*
           move      w-let-arc-vbt-mne    to   w-rig-vrs-lvx-mne
                                              (1, w-acc-vrs-lvx-ctr)  .
           move      w-let-arc-vbt-tcb    to   w-rig-vrs-lvx-tcb
                                              (1, w-acc-vrs-lvx-ctr)  .
       acc-vrs-lvx-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-vrs-lvx
                    (1, w-acc-vrs-lvx-ctr) =    w-sav-vrs-lvx
                     go to acc-vrs-lvx-700.
      *                  *---------------------------------------------*
      *                  * Normalizzazione codici rimanenti            *
      *                  *---------------------------------------------*
           move      w-acc-vrs-lvx-ctr    to   w-acc-vrs-lvx-inx      .
       acc-vrs-lvx-620.
           add       1                    to   w-acc-vrs-lvx-inx      .
           if        w-acc-vrs-lvx-inx    >    6
                     go to acc-vrs-lvx-640.
           if        w-rig-vrs-lvx
                    (1, w-acc-vrs-lvx-inx)
                                          not  = zero
                     move  zero           to   w-rig-vrs-lvx
                                              (1, w-acc-vrs-lvx-inx)
                     move  spaces         to   w-rig-vrs-lvx-mne
                                              (1, w-acc-vrs-lvx-inx)
                     move  spaces         to   w-rig-vrs-lvx-des
                                              (1, w-acc-vrs-lvx-inx)
                     move  zero           to   w-rig-vrs-lvx-tcb
                                              (1, w-acc-vrs-lvx-inx)  .
           go to     acc-vrs-lvx-620.
       acc-vrs-lvx-640.
      *                  *---------------------------------------------*
      *                  * Visualizzazione codice voce di bilancio     *
      *                  *---------------------------------------------*
           perform   vis-vrs-lvx-000      thru vis-vrs-lvx-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione voce di bilan-  *
      *                  * cio                                         *
      *                  *---------------------------------------------*
           perform   vis-vrs-lvx-des-000  thru vis-vrs-lvx-des-999    .
       acc-vrs-lvx-700.
      *              *-------------------------------------------------*
      *              * Test su function-key impostata                  *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-vrs-lvx-720
           else if   v-key                =    "DOWN" or
                     v-key                =    spaces
                     go to acc-vrs-lvx-740.
       acc-vrs-lvx-720.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           subtract  1                    from w-acc-vrs-lvx-ctr      .
           if        w-acc-vrs-lvx-ctr    =    zero
                     go to acc-vrs-lvx-999.
           go to     acc-vrs-lvx-050.
       acc-vrs-lvx-740.
      *              *-------------------------------------------------*
      *              * Se Down o Return                                *
      *              *-------------------------------------------------*
           add       1                    to   w-acc-vrs-lvx-ctr      .
           if        w-acc-vrs-lvx-ctr    >    6
                     go to acc-vrs-lvx-999.
           go to     acc-vrs-lvx-050.
       acc-vrs-lvx-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-vrs-lvx-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-vrs-lvx-100.
       acc-vrs-lvx-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice voce di risultato          *
      *    *-----------------------------------------------------------*
       vis-vrs-lvx-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-tip-vdb (1)    not  = 03
                     go to vis-vrs-lvx-999.
       vis-vrs-lvx-100.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-vis-vrs-lvx-ctr      .
       vis-vrs-lvx-120.
           add       1                    to   w-vis-vrs-lvx-ctr      .
           if        w-vis-vrs-lvx-ctr    >    6
                     go to vis-vrs-lvx-999.
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "B<"                 to   v-edm                  .
           move      20                   to   v-lin                  .
           if        w-vis-vrs-lvx-ctr    =    1
                     move  20             to   v-pos
           else if   w-vis-vrs-lvx-ctr    =    2
                     move  26             to   v-pos
           else if   w-vis-vrs-lvx-ctr    =    3
                     move  32             to   v-pos
           else if   w-vis-vrs-lvx-ctr    =    4
                     move  38             to   v-pos
           else if   w-vis-vrs-lvx-ctr    =    5
                     move  44             to   v-pos
           else if   w-vis-vrs-lvx-ctr    =    6
                     move  50             to   v-pos                  .
           move      w-rig-vrs-lvx
                    (1, w-vis-vrs-lvx-ctr)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     vis-vrs-lvx-120.
       vis-vrs-lvx-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Descrizione voce di risultato     *
      *    *-----------------------------------------------------------*
       vis-vrs-lvx-des-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-tip-vdb (1)    not  = 03
                     go to vis-vrs-lvx-des-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      50                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      20                   to   v-pos                  .
           if        w-rig-vrs-lvx (1, 6) not  = zero
                     move  w-rig-vrs-lvx-des (1, 6)
                                          to   v-alf
           else if   w-rig-vrs-lvx (1, 5) not  = zero
                     move  w-rig-vrs-lvx-des (1, 5)
                                          to   v-alf
           else if   w-rig-vrs-lvx (1, 4) not  = zero
                     move  w-rig-vrs-lvx-des (1, 4)
                                          to   v-alf
           else if   w-rig-vrs-lvx (1, 3) not  = zero
                     move  w-rig-vrs-lvx-des (1, 3)
                                          to   v-alf
           else if   w-rig-vrs-lvx (1, 2) not  = zero
                     move  w-rig-vrs-lvx-des (1, 2)
                                          to   v-alf
           else if   w-rig-vrs-lvx (1, 1) not  = zero
                     move  w-rig-vrs-lvx-des (1, 1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-vrs-lvx-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice sottoconto                    *
      *    *-----------------------------------------------------------*
       acc-cod-stc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-tip-vdb (1)    not  = 02 and
                     w-tes-tip-vdb (1)    not  = 04
                     go to acc-cod-stc-999.
       acc-cod-stc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-pdc-ope      .
           move      w-prs-liv-pdc        to   w-cod-mne-pdc-liv      .
           move      w-rig-cod-stc (1)    to   w-cod-mne-pdc-cod      .
           move      20                   to   w-cod-mne-pdc-lin      .
           move      20                   to   w-cod-mne-pdc-pos      .
           move      21                   to   w-cod-mne-pdc-dln      .
           move      20                   to   w-cod-mne-pdc-dps      .
           move      "B<"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
       acc-cod-stc-110.
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           if        w-cod-mne-pdc-ope    =    "F+"
                     go to acc-cod-stc-115.
           if        w-cod-mne-pdc-ope    =    "AC"
                     go to acc-cod-stc-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-stc-115.
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
           go to     acc-cod-stc-110.
       acc-cod-stc-120.
           move      w-cod-mne-pdc-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cod-stc-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cod-stc-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-cod-stc (1)      .
       acc-cod-stc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [pdc]                      *
      *                  *---------------------------------------------*
           move      w-rig-cod-stc (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-cod-stc-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-cod-stc-des-000  thru vis-cod-stc-des-999    .
      *                  *---------------------------------------------*
      *                  * Se lettura errata : reimpostazione          *
      *                  *---------------------------------------------*
           if        w-let-arc-pdc-flg    not  = spaces
                     go to acc-cod-stc-100.
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-rig-cod-stc (1)    not  = zero
                     go to acc-cod-stc-600.
           if        v-key                =    "UP  "
                     go to acc-cod-stc-600
           else      go to acc-cod-stc-100.
       acc-cod-stc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-stc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cod-stc-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-cod-stc-100.
       acc-cod-stc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice sottoconto                 *
      *    *-----------------------------------------------------------*
       vis-cod-stc-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-tip-vdb (1)    not  = 02 and
                     w-tes-tip-vdb (1)    not  = 04
                     go to vis-cod-stc-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing con appoggio a sinistra             *
      *                  *---------------------------------------------*
           move      w-prs-liv-pdc        to   w-edt-cod-pdc-liv      .
           move      w-rig-cod-stc (1)    to   w-edt-cod-pdc-cod      .
           move      "B"                  to   w-edt-cod-pdc-edm      .
           perform   edt-pdc-asx-000      thru edt-pdc-asx-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      20                   to   v-pos                  .
           move      w-edt-cod-pdc-edt    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-stc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Descrizione sottoconto            *
      *    *-----------------------------------------------------------*
       vis-cod-stc-des-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-tip-vdb (1)    not  = 02 and
                     w-tes-tip-vdb (1)    not  = 04
                     go to vis-cod-stc-des-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      20                   to   v-pos                  .
           move      w-rig-cod-stc-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-stc-des-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazione tasto Do campi chiave           *
      *    *-----------------------------------------------------------*
       cnt-tdo-key-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-key-flg      .
       cnt-tdo-key-100.
      *              *-------------------------------------------------*
      *              * Test su tipo bilancio                           *
      *              *-------------------------------------------------*
           if        w-tes-tip-bil        not  = spaces
                     go to cnt-tdo-key-200.
           move      "Manca il tipo di bilancio                         
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-key-900.
       cnt-tdo-key-200.
      *              *-------------------------------------------------*
      *              * Controllo su voci di bilancio                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su voce di livello 1                   *
      *                  *---------------------------------------------*
           if        w-tes-vdb-lv1        not  = zero
                     go to cnt-tdo-key-210.
           move      "Manca il numero voce di bilancio di livello 1     
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-key-900.
       cnt-tdo-key-210.
      *                  *---------------------------------------------*
      *                  * Test su voce di livello 2                   *
      *                  *---------------------------------------------*
           if        w-tes-vdb-lv1-tcb    not  = 01
                     go to cnt-tdo-key-260.
           if        w-tes-flg-ins        not  = spaces
                     go to cnt-tdo-key-260.
           if        w-tes-vdb-lv2        not  = zero
                     go to cnt-tdo-key-220.
           move      "Manca il numero voce di bilancio di livello 2     
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-key-900.
       cnt-tdo-key-220.
      *                  *---------------------------------------------*
      *                  * Test su voce di livello 3                   *
      *                  *---------------------------------------------*
           if        w-tes-vdb-lv2-tcb    not  = 01
                     go to cnt-tdo-key-260.
           if        w-tes-flg-ins        not  = spaces
                     go to cnt-tdo-key-260.
           if        w-tes-vdb-lv3        not  = zero
                     go to cnt-tdo-key-230.
