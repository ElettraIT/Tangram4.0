                    (w-tvb-ctr-sec)       to   w-tvb-val-2pr
                                              (w-tvb-ctr-ele)         .
           go to     det-tbl-vdb-570.
       det-tbl-vdb-564.
      *                              *---------------------------------*
      *                              * Se tipo operazione : Sottrazio- *
      *                              * ne                              *
      *                              *---------------------------------*
           subtract  w-tvb-val-1pr
                    (w-tvb-ctr-sec)       from w-tvb-val-1pr
                                              (w-tvb-ctr-ele)         .
           subtract  w-tvb-val-2pr
                    (w-tvb-ctr-sec)       from w-tvb-val-2pr
                                              (w-tvb-ctr-ele)         .
           go to     det-tbl-vdb-570.
       det-tbl-vdb-570.
      *                          *-------------------------------------*
      *                          * Riciclo su lettura sequenziale re-  *
      *                          * cord [vbr]                          *
      *                          *-------------------------------------*
           go to     det-tbl-vdb-540.
       det-tbl-vdb-580.
      *                  *---------------------------------------------*
      *                  * Eventuale inversione del segno              *
      *                  *---------------------------------------------*
           if        w-tvb-snx-isg
                    (w-tvb-ctr-ele)       =    "S"
                     multiply -1          by   w-tvb-val-1pr
                                              (w-tvb-ctr-ele)
                     multiply -1          by   w-tvb-val-2pr
                                              (w-tvb-ctr-ele)         .
      *                  *---------------------------------------------*
      *                  * Riciclo su scansione principale tabella     *
      *                  *---------------------------------------------*
           go to     det-tbl-vdb-520.
       det-tbl-vdb-600.
      *              *-------------------------------------------------*
      *              * Ricalcolo valori voci ulteriormente suddivise   *
      *              * tenendo conto anche delle voci di risultato     *
      *              *-------------------------------------------------*
           move      zero                 to   w-tvb-ctr-ele          .
       det-tbl-vdb-620.
           add       1                    to   w-tvb-ctr-ele          .
           if        w-tvb-ctr-ele        >    w-tvb-num-ele
                     go to det-tbl-vdb-700.
      *                  *---------------------------------------------*
      *                  * Se tipo voce di bilancio non ulteriormente  *
      *                  * suddivisa : riciclo                         *
      *                  *---------------------------------------------*
           if        w-tvb-tip-vdb
                    (w-tvb-ctr-ele)       not  = 01
                     go to det-tbl-vdb-620.
      *                  *---------------------------------------------*
      *                  * Determinazione numero livello voce in esame *
      *                  *---------------------------------------------*
           if        w-tvb-vdb-lv6
                    (w-tvb-ctr-ele)       not  = zero
                     move  6              to   w-tvb-liv-vis
           else if   w-tvb-vdb-lv5
                    (w-tvb-ctr-ele)       not  = zero
                     move  5              to   w-tvb-liv-vis
           else if   w-tvb-vdb-lv4
                    (w-tvb-ctr-ele)       not  = zero
                     move  4              to   w-tvb-liv-vis
           else if   w-tvb-vdb-lv3
                    (w-tvb-ctr-ele)       not  = zero
                     move  3              to   w-tvb-liv-vis
           else if   w-tvb-vdb-lv2
                    (w-tvb-ctr-ele)       not  = zero
                     move  2              to   w-tvb-liv-vis
           else      move  1              to   w-tvb-liv-vis          .
      *                  *---------------------------------------------*
      *                  * Riazzeramento valori voce                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-tvb-val-1pr
                                              (w-tvb-ctr-ele)         .
           move      zero                 to   w-tvb-val-2pr
                                              (w-tvb-ctr-ele)         .
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione secondaria della tabella *
      *                  * a partire dalla voce in esame               *
      *                  *---------------------------------------------*
           move      w-tvb-ctr-ele        to   w-tvb-ctr-sec          .
       det-tbl-vdb-640.
           add       1                    to   w-tvb-ctr-sec          .
      *                      *-----------------------------------------*
      *                      * Se oltre il numero elementi memorizza-  *
      *                      * ti : riciclo su scansione principale    *
      *                      *-----------------------------------------*
           if        w-tvb-ctr-sec        >    w-tvb-num-ele
                     go to det-tbl-vdb-620.
      *                      *-----------------------------------------*
      *                      * Test se la voce appartiene a quella in  *
      *                      * esame, se no : riciclo su scansione     *
      *                      * principale                              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Deviazione in funzione del numero   *
      *                          * di livello della voce in esame      *
      *                          *-------------------------------------*
           go to     det-tbl-vdb-641
                     det-tbl-vdb-642
                     det-tbl-vdb-643
                     det-tbl-vdb-644
                     det-tbl-vdb-645
                     depending on         w-tvb-liv-vis               .
       det-tbl-vdb-641.
      *                          *-------------------------------------*
      *                          * Se livello 1                        *
      *                          *-------------------------------------*
           if        w-tvb-vdb-lv1
                    (w-tvb-ctr-sec)       not  = w-tvb-vdb-lv1
                                                (w-tvb-ctr-ele)
                     go to det-tbl-vdb-620.
           go to     det-tbl-vdb-660.
       det-tbl-vdb-642.
      *                          *-------------------------------------*
      *                          * Se livello 2                        *
      *                          *-------------------------------------*
           if        w-tvb-vdb-lv1
                    (w-tvb-ctr-sec)       not  = w-tvb-vdb-lv1
                                                (w-tvb-ctr-ele) or
                     w-tvb-vdb-lv2
                    (w-tvb-ctr-sec)       not  = w-tvb-vdb-lv2
                                                (w-tvb-ctr-ele)
                     go to det-tbl-vdb-620.
           go to     det-tbl-vdb-660.
       det-tbl-vdb-643.
      *                          *-------------------------------------*
      *                          * Se livello 3                        *
      *                          *-------------------------------------*
           if        w-tvb-vdb-lv1
                    (w-tvb-ctr-sec)       not  = w-tvb-vdb-lv1
                                                (w-tvb-ctr-ele) or
                     w-tvb-vdb-lv2
                    (w-tvb-ctr-sec)       not  = w-tvb-vdb-lv2
                                                (w-tvb-ctr-ele) or
                     w-tvb-vdb-lv3
                    (w-tvb-ctr-sec)       not  = w-tvb-vdb-lv3
                                                (w-tvb-ctr-ele)
                     go to det-tbl-vdb-620.
           go to     det-tbl-vdb-660.
       det-tbl-vdb-644.
      *                          *-------------------------------------*
      *                          * Se livello 4                        *
      *                          *-------------------------------------*
           if        w-tvb-vdb-lv1
                    (w-tvb-ctr-sec)       not  = w-tvb-vdb-lv1
                                                (w-tvb-ctr-ele) or
                     w-tvb-vdb-lv2
                    (w-tvb-ctr-sec)       not  = w-tvb-vdb-lv2
                                                (w-tvb-ctr-ele) or
                     w-tvb-vdb-lv3
                    (w-tvb-ctr-sec)       not  = w-tvb-vdb-lv3
                                                (w-tvb-ctr-ele) or
                     w-tvb-vdb-lv4
                    (w-tvb-ctr-sec)       not  = w-tvb-vdb-lv4
                                                (w-tvb-ctr-ele)
                     go to det-tbl-vdb-620.
           go to     det-tbl-vdb-660.
       det-tbl-vdb-645.
      *                          *-------------------------------------*
      *                          * Se livello 5                        *
      *                          *-------------------------------------*
           if        w-tvb-vdb-lv1
                    (w-tvb-ctr-sec)       not  = w-tvb-vdb-lv1
                                                (w-tvb-ctr-ele) or
                     w-tvb-vdb-lv2
                    (w-tvb-ctr-sec)       not  = w-tvb-vdb-lv2
                                                (w-tvb-ctr-ele) or
                     w-tvb-vdb-lv3
                    (w-tvb-ctr-sec)       not  = w-tvb-vdb-lv3
                                                (w-tvb-ctr-ele) or
                     w-tvb-vdb-lv4
                    (w-tvb-ctr-sec)       not  = w-tvb-vdb-lv4
                                                (w-tvb-ctr-ele) or
                     w-tvb-vdb-lv5
                    (w-tvb-ctr-sec)       not  = w-tvb-vdb-lv5
                                                (w-tvb-ctr-ele)
                     go to det-tbl-vdb-620.
           go to     det-tbl-vdb-660.
       det-tbl-vdb-660.
      *                      *-----------------------------------------*
      *                      * Se voce non di ultimo livello o di ri-  *
      *                      * sultato : riciclo su scansione seconda- *
      *                      * ria                                     *
      *                      *-----------------------------------------*
           if        w-tvb-tip-vdb
                    (w-tvb-ctr-sec)       not  = 02 and
                     w-tvb-tip-vdb
                    (w-tvb-ctr-sec)       not  = 03
                     go to det-tbl-vdb-640.
      *                      *-----------------------------------------*
      *                      * Aggiornamento valori voce in esame      *
      *                      *-----------------------------------------*
           add       w-tvb-val-1pr
                    (w-tvb-ctr-sec)       to   w-tvb-val-1pr
                                              (w-tvb-ctr-ele)         .
           add       w-tvb-val-2pr
                    (w-tvb-ctr-sec)       to   w-tvb-val-2pr
                                              (w-tvb-ctr-ele)         .
      *                      *-----------------------------------------*
      *                      * Riciclo su scansione secondaria tabella *
      *                      *-----------------------------------------*
           go to     det-tbl-vdb-640.
       det-tbl-vdb-700.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-tbl-vdb-999.
       det-tbl-vdb-999.
           exit.

