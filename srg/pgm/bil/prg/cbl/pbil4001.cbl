      *    * Ciclo Report Program : Inizio 2. livello di rottura       *
      *    *-----------------------------------------------------------*
       prn-ini-lr2-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
       prn-ini-lr2-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Fine 2. livello di rottura         *
      *    *-----------------------------------------------------------*
       prn-fin-lr2-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
       prn-fin-lr2-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Inizio 1. livello di rottura       *
      *    *-----------------------------------------------------------*
       prn-ini-lr1-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
       prn-ini-lr1-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Fine 1. livello di rottura         *
      *    *-----------------------------------------------------------*
       prn-fin-lr1-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
       prn-fin-lr1-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Livello di dettaglio               *
      *    *-----------------------------------------------------------*
       prn-liv-det-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
      *              *-------------------------------------------------*
      *              * Determinazione livello voce di bilancio attuale *
      *              *-------------------------------------------------*
           if        rf-vbt-vdb-lv6       not  = zero
                     move  6              to   w-lvx-liv-vba
           else if   rf-vbt-vdb-lv5       not  = zero
                     move  5              to   w-lvx-liv-vba
           else if   rf-vbt-vdb-lv4       not  = zero
                     move  4              to   w-lvx-liv-vba
           else if   rf-vbt-vdb-lv3       not  = zero
                     move  3              to   w-lvx-liv-vba
           else if   rf-vbt-vdb-lv2       not  = zero
                     move  2              to   w-lvx-liv-vba
           else      move  1              to   w-lvx-liv-vba          .
      *              *-------------------------------------------------*
      *              * Controllo che le singole voci di bilancio cor-  *
      *              * rispondano con quelle memorizzate per il livel- *
      *              * lo, se no si ignora la voce                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se il livello attuale e' zero, non si ese-  *
      *                  * gue il controllo                            *
      *                  *---------------------------------------------*
           if        w-lvx-liv-att        =    zero
                     go to prn-liv-det-080.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del livello attuale    *
      *                  *---------------------------------------------*
           go to     prn-liv-det-010
                     prn-liv-det-020
                     prn-liv-det-030
                     prn-liv-det-040
                     prn-liv-det-050
                     prn-liv-det-060
                     depending            on   w-lvx-liv-vba          .
       prn-liv-det-010.
      *                  *---------------------------------------------*
      *                  * Livello attuale : 1                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Nessun test                             *
      *                      *-----------------------------------------*
           go to     prn-liv-det-080.
       prn-liv-det-020.
      *                  *---------------------------------------------*
      *                  * Livello attuale : 2                         *
      *                  *---------------------------------------------*
           if        rf-vbt-vdb-lv1       not  = w-lvx-vdb-lv1
                     go to prn-liv-det-999.
           go to     prn-liv-det-080.
       prn-liv-det-030.
      *                  *---------------------------------------------*
      *                  * Livello attuale : 3                         *
      *                  *---------------------------------------------*
           if        rf-vbt-vdb-lv1       not  = w-lvx-vdb-lv1 or
                     rf-vbt-vdb-lv2       not  = w-lvx-vdb-lv2
                     go to prn-liv-det-999.
           go to     prn-liv-det-080.
       prn-liv-det-040.
      *                  *---------------------------------------------*
      *                  * Livello attuale : 4                         *
      *                  *---------------------------------------------*
           if        rf-vbt-vdb-lv1       not  = w-lvx-vdb-lv1 or
                     rf-vbt-vdb-lv2       not  = w-lvx-vdb-lv2 or
                     rf-vbt-vdb-lv3       not  = w-lvx-vdb-lv3
                     go to prn-liv-det-999.
           go to     prn-liv-det-080.
       prn-liv-det-050.
      *                  *---------------------------------------------*
      *                  * Livello attuale : 5                         *
      *                  *---------------------------------------------*
           if        rf-vbt-vdb-lv1       not  = w-lvx-vdb-lv1 or
                     rf-vbt-vdb-lv2       not  = w-lvx-vdb-lv2 or
                     rf-vbt-vdb-lv3       not  = w-lvx-vdb-lv3 or
                     rf-vbt-vdb-lv4       not  = w-lvx-vdb-lv4
                     go to prn-liv-det-999.
           go to     prn-liv-det-080.
       prn-liv-det-060.
      *                  *---------------------------------------------*
      *                  * Livello attuale : 6                         *
      *                  *---------------------------------------------*
           if        rf-vbt-vdb-lv1       not  = w-lvx-vdb-lv1 or
                     rf-vbt-vdb-lv2       not  = w-lvx-vdb-lv2 or
                     rf-vbt-vdb-lv3       not  = w-lvx-vdb-lv3 or
                     rf-vbt-vdb-lv4       not  = w-lvx-vdb-lv4 or
                     rf-vbt-vdb-lv5       not  = w-lvx-vdb-lv5
                     go to prn-liv-det-999.
           go to     prn-liv-det-080.
       prn-liv-det-080.
      *              *-------------------------------------------------*
      *              * Confronto con numero livello attuale            *
      *              *-------------------------------------------------*
           if        w-lvx-liv-vba        >    w-lvx-liv-att
                     go to prn-liv-det-100
           else if   w-lvx-liv-vba        =    w-lvx-liv-att
                     go to prn-liv-det-200
           else if   w-lvx-liv-vba        <    w-lvx-liv-att
                     go to prn-liv-det-300.
       prn-liv-det-100.
      *              *-------------------------------------------------*
      *              * Se livello voce di bilancio attuale maggiore    *
      *              * del numero livello attuale                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Aggiornamento livello attuale               *
      *                  *---------------------------------------------*
           move      w-lvx-liv-vba        to    w-lvx-liv-att         .
      *                  *---------------------------------------------*
      *                  * Memorizzazione dati per il livello attuale  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Inizializzazione contatore elementi per *
      *                      * il livello                              *
      *                      *-----------------------------------------*
           move      zero                 to   w-lvx-ctr-ele
                                              (w-lvx-liv-att)         .
      *                      *-----------------------------------------*
      *                      * Codici voci di bilancio                 *
      *                      *-----------------------------------------*
           move      rf-vbt-vdb-lv1       to   w-lvx-vdb-lv1          .
           move      rf-vbt-vdb-lv2       to   w-lvx-vdb-lv2          .
           move      rf-vbt-vdb-lv3       to   w-lvx-vdb-lv3          .
           move      rf-vbt-vdb-lv4       to   w-lvx-vdb-lv4          .
           move      rf-vbt-vdb-lv5       to   w-lvx-vdb-lv5          .
           move      rf-vbt-vdb-lv6       to   w-lvx-vdb-lv6          .
      *                      *-----------------------------------------*
      *                      * Altri dati                              *
      *                      *-----------------------------------------*
           move      rf-vbt-snx-tot       to   w-lvx-snx-tot
                                              (w-lvx-liv-att)         .
           move      rf-vbt-dic-tot       to   w-lvx-dic-tot
                                              (w-lvx-liv-att)         .
           move      w-tvb-val-1pr
                    (w-tvb-ctr-ele)       to   w-lvx-val-1pr
                                              (w-lvx-liv-att)         .
           move      w-tvb-val-2pr
                    (w-tvb-ctr-ele)       to   w-lvx-val-2pr
                                              (w-lvx-liv-att)         .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     prn-liv-det-500.
       prn-liv-det-200.
      *              *-------------------------------------------------*
      *              * Se livello voce di bilancio attuale uguale al   *
      *              * numero livello attuale                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Come per livello voce di bilancio attuale   *
      *                  * maggiore del numero livello attuale         *
      *                  *---------------------------------------------*
           go to     prn-liv-det-100.
       prn-liv-det-300.
      *              *-------------------------------------------------*
      *              * Se livello voce di bilancio attuale minore del  *
      *              * numero livello attuale                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ciclo di stampa totali dei livelli da quel- *
      *                  * lo precedente l'attuale fino a quello della *
      *                  * voce di bilancio                            *
      *                  *---------------------------------------------*
           move      w-lvx-liv-att        to    w-lvx-wrk-liv         .
       prn-liv-det-320.
           subtract  1                    from  w-lvx-wrk-liv         .
           if        w-lvx-wrk-liv        <     w-lvx-liv-vba
                     go to prn-liv-det-340.
      *                      *-----------------------------------------*
      *                      * Richiamo routine di stampa totale voce  *
      *                      *-----------------------------------------*
           move      w-lvx-wrk-liv        to    w-stp-tot-vdb-liv     .
           perform   stp-tot-vdb-000      thru stp-tot-vdb-999        .
      *                      *-----------------------------------------*
      *                      * Riazzeramento dei contatori elementi    *
      *                      *-----------------------------------------*
           move      zero                 to   w-lvx-ctr-ele
                                              (w-lvx-wrk-liv)         .
      *                      *-----------------------------------------*
      *                      * Riciclo                                 *
      *                      *-----------------------------------------*
           go to     prn-liv-det-320.
       prn-liv-det-340.
      *                  *---------------------------------------------*
      *                  * Continuazione come per incremento numero    *
      *                  * livello                                     *
      *                  *---------------------------------------------*
           go to     prn-liv-det-200.
       prn-liv-det-500.
      *              *-------------------------------------------------*
      *              * Incremento contatore elementi per il livello    *
      *              *  precedente                                     *
      *              *-------------------------------------------------*
           move      w-lvx-liv-att        to   w-lvx-wrk-liv          .
           subtract  1                    from w-lvx-wrk-liv          .
           if        w-lvx-wrk-liv        =    zero
                     go to prn-liv-det-600.
           if        w-lvx-ctr-ele
                    (w-lvx-wrk-liv)       <    99999
                     add   1              to   w-lvx-ctr-ele
                                              (w-lvx-wrk-liv)         .
       prn-liv-det-600.
      *              *-------------------------------------------------*
      *              * Stampa intestazione voce di bilancio            *
      *              *-------------------------------------------------*
           perform   stp-int-vdb-000      thru stp-int-vdb-999        .
       prn-liv-det-999.
           exit.

      *    *===========================================================*
      *    * Intestazione foglio                                       *
      *    *-----------------------------------------------------------*
       int-pag-sta-000.
      *              *-------------------------------------------------*
      *              * Preparazione parametri intestazione standard    *
      *              *-------------------------------------------------*
           move      rr-tip-bil-des
                                          to   w-cnt-tit-des-tit      .
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-cnt-tit-dat-stp      .
           move      p-pag                to   w-cnt-tit-num-pag      .
           add       1                    to   w-cnt-tit-num-pag      .
      *              *-------------------------------------------------*
      *              * Intestazione standard                           *
      *              *-------------------------------------------------*
           perform   int-pag-std-000      thru int-pag-std-999        .
      *                  *---------------------------------------------*
      *                  * Se uscita per interruzione forzata          *
      *                  *---------------------------------------------*
           if        w-cnt-prn-flg-int    not  = spaces
                     go to  int-pag-sta-999.
      *              *-------------------------------------------------*
      *              * Fincatura per 1. periodo                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing data 1. periodo                     *
      *                  *---------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "D"                  to   p-tip                  .
           move      "<"                  to   p-edm                  .
           move      rr-dat-1pr           to   p-dat                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Stampa                                      *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      20                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      077                  to   p-pos                  .
           move      spaces               to   p-alf                  .
           string    "----- "
                                delimited by   size
                     p-edt
                                delimited by   spaces
                     " -----"
                                delimited by   size
                                          into p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Fincatura per 2. periodo                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da eseguire                         *
      *                  *---------------------------------------------*
           if        rr-dat-2pr           =    zero
                     go to int-pag-sta-100.
      *                  *---------------------------------------------*
      *                  * Editing data 2. periodo                     *
      *                  *---------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "D"                  to   p-tip                  .
           move      "<"                  to   p-edm                  .
           move      rr-dat-2pr           to   p-dat                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Stampa                                      *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      20                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      101                  to   p-pos                  .
           move      spaces               to   p-alf                  .
           string    "----- "
                                delimited by   size
                     p-edt
                                delimited by   spaces
                     " -----"
                                delimited by   size
                                          into p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-pag-sta-100.
      *              *-------------------------------------------------*
      *              * Interlinea                                      *
      *              *-------------------------------------------------*
           move      "VP"                 to   p-ope                  .
           add       2
                     p-lnr              giving p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-pag-sta-999.
           exit.

      *    *===========================================================*
      *    * Stampa intestazione classificatore di bilancio            *
      *    *-----------------------------------------------------------*
       stp-int-vdb-000.
      *              *-------------------------------------------------*
      *              * Stampa spazio di separazione da voce precedente *
      *              *-------------------------------------------------*
           if        rf-vbt-spz-sep       =    01
                     go to stp-int-vdb-010
           else if   rf-vbt-spz-sep       =    02
                     go to stp-int-vdb-020
           else if   rf-vbt-spz-sep       =    03
                     go to stp-int-vdb-030
           else if   rf-vbt-spz-sep       =    04
                     go to stp-int-vdb-040
           else if   rf-vbt-spz-sep       =    09
                     go to stp-int-vdb-090.
       stp-int-vdb-010.
      *                  *---------------------------------------------*
      *                  * Spazio da lasciare : Nessuno spazio         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se righe residue sufficienti       *
      *                      *-----------------------------------------*
           if        p-res                >    1
                     go to stp-int-vdb-012.
      *                      *-----------------------------------------*
      *                      * Reintestazione                          *
      *                      *-----------------------------------------*
           perform   int-pag-sta-000      thru int-pag-sta-999        .
           if        w-cnt-prn-flg-int    not  = spaces
                     go to stp-int-vdb-999.
       stp-int-vdb-012.
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     stp-int-vdb-100.
       stp-int-vdb-020.
      *                  *---------------------------------------------*
      *                  * Spazio da lasciare : Un'interlinea          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se righe residue sufficienti       *
      *                      *-----------------------------------------*
           if        p-res                >    2
                     go to stp-int-vdb-022.
      *                      *-----------------------------------------*
      *                      * Reintestazione                          *
      *                      *-----------------------------------------*
           perform   int-pag-sta-000      thru int-pag-sta-999        .
           if        w-cnt-prn-flg-int    not  = spaces
                     go to stp-int-vdb-999.
       stp-int-vdb-022.
      *                      *-----------------------------------------*
      *                      * Una interlinea subordinata              *
      *                      *-----------------------------------------*
           move      "VS"                 to   p-ope                  .
           add       2
                     p-lnr              giving p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     stp-int-vdb-100.
       stp-int-vdb-030.
      *                  *---------------------------------------------*
      *                  * Spazio da lasciare : Due interlinee         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se righe residue sufficienti       *
      *                      *-----------------------------------------*
           if        p-res                >    3
                     go to stp-int-vdb-032.
      *                      *-----------------------------------------*
      *                      * Reintestazione                          *
      *                      *-----------------------------------------*
           perform   int-pag-sta-000      thru int-pag-sta-999        .
           if        w-cnt-prn-flg-int    not  = spaces
                     go to stp-int-vdb-999.
       stp-int-vdb-032.
      *                      *-----------------------------------------*
      *                      * Due interlinee subordinate              *
      *                      *-----------------------------------------*
           move      "VS"                 to   p-ope                  .
           add       3
                     p-lnr              giving p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     stp-int-vdb-100.
       stp-int-vdb-040.
      *                  *---------------------------------------------*
      *                  * Spazio da lasciare : Tre interlinee         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se righe residue sufficienti       *
      *                      *-----------------------------------------*
           if        p-res                >    4
                     go to stp-int-vdb-042.
      *                      *-----------------------------------------*
      *                      * Reintestazione                          *
      *                      *-----------------------------------------*
           perform   int-pag-sta-000      thru int-pag-sta-999        .
           if        w-cnt-prn-flg-int    not  = spaces
                     go to stp-int-vdb-999.
       stp-int-vdb-042.
      *                      *-----------------------------------------*
      *                      * Tre interlinee subordinate              *
      *                      *-----------------------------------------*
           move      "VS"                 to   p-ope                  .
           add       4
                     p-lnr              giving p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     stp-int-vdb-100.
       stp-int-vdb-090.
      *                  *---------------------------------------------*
      *                  * Spazio da lasciare : Salto pagina           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Reintestazione                          *
      *                      *-----------------------------------------*
           perform   int-pag-sta-000      thru int-pag-sta-999        .
           if        w-cnt-prn-flg-int    not  = spaces
                     go to stp-int-vdb-999.
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     stp-int-vdb-100.
       stp-int-vdb-100.
      *              *-------------------------------------------------*
      *              * Stampa prima riga descrizione voce di bilancio  *
      *              * ed eventuali valori                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se righe residue sufficienti           *
      *                  *---------------------------------------------*
           if        p-res                >    1
                     go to stp-int-vdb-120.
      *                  *---------------------------------------------*
      *                  * Reintestazione                              *
      *                  *---------------------------------------------*
           perform   int-pag-sta-000      thru int-pag-sta-999        .
           if        w-cnt-prn-flg-int    not  = spaces
                     go to stp-int-vdb-999.
       stp-int-vdb-120.
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Stampa prima riga descrizione               *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      50                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      rf-vbt-rde-vdb (1)   to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Stampa valori                               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo voce di *
      *                      * bilancio                                *
      *                      *-----------------------------------------*
           if        rf-vbt-tip-vdb       =    01
                     go to stp-int-vdb-130
           else if   rf-vbt-tip-vdb       =    02
                     go to stp-int-vdb-140
           else if   rf-vbt-tip-vdb       =    03
                     go to stp-int-vdb-150
           else if   rf-vbt-tip-vdb       =    04
                     go to stp-int-vdb-160.
       stp-int-vdb-130.
      *                      *-----------------------------------------*
      *                      * Tipo voce : Ulteriormente suddiviso     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Nessuna stampa                      *
      *                          *-------------------------------------*
           go to     stp-int-vdb-200.
       stp-int-vdb-140.
      *                      *-----------------------------------------*
      *                      * Tipo voce : Di ultimo livello           *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * 1. periodo                          *
      *                          *-------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           move      13                   to   p-car                  .
           move      c-dec                to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      "GB"                 to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      078                  to   p-pos                  .
           move      w-tvb-val-1pr
                    (w-tvb-ctr-ele)       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * 2. periodo                          *
      *                          *-------------------------------------*
           if        rr-dat-2pr           =    zero
                     go to stp-int-vdb-142.
           move      "PF"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           move      13                   to   p-car                  .
           move      c-dec                to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      "GB"                 to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      102                  to   p-pos                  .
           move      w-tvb-val-2pr
                    (w-tvb-ctr-ele)       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-int-vdb-142.
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     stp-int-vdb-200.
