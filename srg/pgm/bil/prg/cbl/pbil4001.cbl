      *    *===========================================================*
      *    * Determinazione tabella voci di bilancio                   *
      *    *-----------------------------------------------------------*
       det-tbl-vdb-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-tbl-vdb-flg      .
       det-tbl-vdb-100.
      *              *-------------------------------------------------*
      *              * Caricamento elementi in tabella                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizializzazione numero elementi in tabella *
      *                  *---------------------------------------------*
           move      zero                 to   w-tvb-num-ele          .
      *                  *---------------------------------------------*
      *                  * Start su file [vbt]                         *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CODVDB    "         to   f-key                  .
           move      rr-tip-bil           to   rf-vbt-tip-bil         .
           move      zero                 to   rf-vbt-vdb-lv1         .
           move      zero                 to   rf-vbt-vdb-lv2         .
           move      zero                 to   rf-vbt-vdb-lv3         .
           move      zero                 to   rf-vbt-vdb-lv4         .
           move      zero                 to   rf-vbt-vdb-lv5         .
           move      zero                 to   rf-vbt-vdb-lv6         .
           move      "pgm/bil/fls/ioc/obj/iofvbt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vbt                 .
      *                      *-----------------------------------------*
      *                      * Test su esito operazione                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-tbl-vdb-200.
       det-tbl-vdb-120.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale record [vbt]            *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bil/fls/ioc/obj/iofvbt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vbt                 .
      *                      *-----------------------------------------*
      *                      * Test se 'At end'                        *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-tbl-vdb-200.
      *                      *-----------------------------------------*
      *                      * Test sul massimo                        *
      *                      *-----------------------------------------*
           if        rf-vbt-tip-bil       not  = rr-tip-bil
                     go to det-tbl-vdb-200.
      *                      *-----------------------------------------*
      *                      * Selezione sul record                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione numero livello voce  *
      *                          * letta                               *
      *                          *-------------------------------------*
           if        rf-vbt-vdb-lv6       not  = zero
                     move  6              to   w-tvb-liv-vis
           else if   rf-vbt-vdb-lv5       not  = zero
                     move  5              to   w-tvb-liv-vis
           else if   rf-vbt-vdb-lv4       not  = zero
                     move  4              to   w-tvb-liv-vis
           else if   rf-vbt-vdb-lv3       not  = zero
                     move  3              to   w-tvb-liv-vis
           else if   rf-vbt-vdb-lv2       not  = zero
                     move  2              to   w-tvb-liv-vis
           else      move  1              to   w-tvb-liv-vis          .
       det-tbl-vdb-130.
      *                          *-------------------------------------*
      *                          * Controllo che i codici della voce   *
      *                          * letta siano compatibili con quelli  *
      *                          * attuali                             *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Deviazione in funzione del li-  *
      *                              * vello voce letta                *
      *                              *---------------------------------*
           go to     det-tbl-vdb-131
                     det-tbl-vdb-132
                     det-tbl-vdb-133
                     det-tbl-vdb-134
                     det-tbl-vdb-135
                     det-tbl-vdb-136
                     depending            on   w-tvb-liv-vis          .
       det-tbl-vdb-131.
      *                              *---------------------------------*
      *                              * Livello voce letta : 1          *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Oltre                       *
      *                                  *-----------------------------*
           go to     det-tbl-vdb-138.
       det-tbl-vdb-132.
      *                          *-------------------------------------*
      *                          * Livello voce letta : 2              *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Test                            *
      *                              *---------------------------------*
           if        rf-vbt-vdb-lv1       not  = w-tvb-sav-lv1
                     go to det-tbl-vdb-120.
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     det-tbl-vdb-138.
       det-tbl-vdb-133.
      *                          *-------------------------------------*
      *                          * Livello voce letta : 3              *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Test                            *
      *                              *---------------------------------*
           if        rf-vbt-vdb-lv1       not  = w-tvb-sav-lv1 or
                     rf-vbt-vdb-lv2       not  = w-tvb-sav-lv2
                     go to det-tbl-vdb-120.
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     det-tbl-vdb-138.
       det-tbl-vdb-134.
      *                          *-------------------------------------*
      *                          * Livello voce letta : 4              *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Test                            *
      *                              *---------------------------------*
           if        rf-vbt-vdb-lv1       not  = w-tvb-sav-lv1 or
                     rf-vbt-vdb-lv2       not  = w-tvb-sav-lv2 or
                     rf-vbt-vdb-lv3       not  = w-tvb-sav-lv3
                     go to det-tbl-vdb-120.
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     det-tbl-vdb-138.
       det-tbl-vdb-135.
      *                          *-------------------------------------*
      *                          * Livello voce letta : 5              *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Test                            *
      *                              *---------------------------------*
           if        rf-vbt-vdb-lv1       not  = w-tvb-sav-lv1 or
                     rf-vbt-vdb-lv2       not  = w-tvb-sav-lv2 or
                     rf-vbt-vdb-lv3       not  = w-tvb-sav-lv3 or
                     rf-vbt-vdb-lv4       not  = w-tvb-sav-lv4
                     go to det-tbl-vdb-120.
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     det-tbl-vdb-138.
       det-tbl-vdb-136.
      *                          *-------------------------------------*
      *                          * Livello voce letta : 6              *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Test                            *
      *                              *---------------------------------*
           if        rf-vbt-vdb-lv1       not  = w-tvb-sav-lv1 or
                     rf-vbt-vdb-lv2       not  = w-tvb-sav-lv2 or
                     rf-vbt-vdb-lv3       not  = w-tvb-sav-lv3 or
                     rf-vbt-vdb-lv4       not  = w-tvb-sav-lv4 or
                     rf-vbt-vdb-lv5       not  = w-tvb-sav-lv5
                     go to det-tbl-vdb-120.
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     det-tbl-vdb-138.
       det-tbl-vdb-138.
      *                          *-------------------------------------*
      *                          * Aggiornamento area salvataggio co-  *
      *                          * dici voci di bilancio attuali       *
      *                          *-------------------------------------*
           move      rf-vbt-vdb-lv1       to   w-tvb-sav-lv1          .
           move      rf-vbt-vdb-lv2       to   w-tvb-sav-lv2          .
           move      rf-vbt-vdb-lv3       to   w-tvb-sav-lv3          .
           move      rf-vbt-vdb-lv4       to   w-tvb-sav-lv4          .
           move      rf-vbt-vdb-lv5       to   w-tvb-sav-lv5          .
           move      rf-vbt-vdb-lv6       to   w-tvb-sav-lv6          .
       det-tbl-vdb-140.
      *                      *-----------------------------------------*
      *                      * Fine selezione sul record               *
      *                      *-----------------------------------------*
       det-tbl-vdb-150.
      *                  *---------------------------------------------*
      *                  * Incremento numero elementi in tabella       *
      *                  *---------------------------------------------*
           if        w-tvb-num-ele        <    w-tvb-max-ele
                     add   1              to   w-tvb-num-ele
                     go to det-tbl-vdb-160.
      *                      *-----------------------------------------*
      *                      * Se oltre il massimo previsto            *
      *                      *-----------------------------------------*
