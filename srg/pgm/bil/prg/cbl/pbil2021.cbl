      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Start su archivio [vbt]                         *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CODVDB    "         to   f-key                  .
           move      rr-cod-tpb           to   rf-vbt-tip-bil         .
           move      zero                 to   rf-vbt-vdb-lv1         .
           move      zero                 to   rf-vbt-vdb-lv2         .
           move      zero                 to   rf-vbt-vdb-lv3         .
           move      zero                 to   rf-vbt-vdb-lv4         .
           move      zero                 to   rf-vbt-vdb-lv5         .
           move      zero                 to   rf-vbt-vdb-lv6         .
           move      "pgm/bil/fls/ioc/obj/iofvbt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vbt                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale archivio [vbt]              *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bil/fls/ioc/obj/iofvbt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vbt                 .
      *                  *---------------------------------------------*
      *                  * Se fine file : uscita                       *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Test max su codice tipo bilancio                *
      *              *-------------------------------------------------*
           if        rf-vbt-tip-bil       not  = rr-cod-tpb
                     go to stp-srt-inp-999.
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su Si/no solo voci con anomalie        *
      *                  *---------------------------------------------*
           if        rr-snx-anm           not  = "S"
                     go to stp-srt-inp-600.
      *                  *---------------------------------------------*
      *                  * Test sul tipo voce in corso di trattamento  *
      *                  *---------------------------------------------*
           if        rf-vbt-tip-vdb       =    01
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione delle righe              *
      *                  *---------------------------------------------*
           move      zero                 to   w-prn-srt-inp-ctr      .
      *                  *---------------------------------------------*
      *                  * Start su archivio [vbr]                     *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CODVDB    "         to   f-key                  .
           move      rf-vbt-tip-bil       to   rf-vbr-tip-bil         .
           move      rf-vbt-vdb-lv1       to   rf-vbr-vdb-lv1         .
           move      rf-vbt-vdb-lv2       to   rf-vbr-vdb-lv2         .
           move      rf-vbt-vdb-lv3       to   rf-vbr-vdb-lv3         .
           move      rf-vbt-vdb-lv4       to   rf-vbr-vdb-lv4         .
           move      rf-vbt-vdb-lv5       to   rf-vbr-vdb-lv5         .
           move      rf-vbt-vdb-lv6       to   rf-vbr-vdb-lv6         .
           move      zero                 to   rf-vbr-num-prg         .
           move      "pgm/bil/fls/ioc/obj/iofvbr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vbr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se non trovate righe per la voce in     *
      *                      * corso di trattamento : uscita per voce  *
      *                      * con anomalie                            *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-600.
       stp-srt-inp-440.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale archivio [vbr]          *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bil/fls/ioc/obj/iofvbr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vbr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura sequenziale           *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-500.
       stp-srt-inp-460.
      *                  *---------------------------------------------*
      *                  * Test sul massimo                            *
      *                  *---------------------------------------------*
           if        rf-vbr-tip-bil       not  = rf-vbt-tip-bil or
                     rf-vbr-vdb-lv1       not  = rf-vbt-vdb-lv1 or
                     rf-vbr-vdb-lv2       not  = rf-vbt-vdb-lv2 or
                     rf-vbr-vdb-lv3       not  = rf-vbt-vdb-lv3 or
                     rf-vbr-vdb-lv4       not  = rf-vbt-vdb-lv4 or
                     rf-vbr-vdb-lv5       not  = rf-vbt-vdb-lv5 or
                     rf-vbr-vdb-lv6       not  = rf-vbt-vdb-lv6
                     go to stp-srt-inp-500.
       stp-srt-inp-480.
      *                  *---------------------------------------------*
      *                  * Incremento del contatore numero elementi    *
      *                  *---------------------------------------------*
           add       1                    to   w-prn-srt-inp-ctr      .
           if        w-prn-srt-inp-ctr    >    1
                     go to stp-srt-inp-500.
       stp-srt-inp-490.
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-440.
       stp-srt-inp-500.
      *                  *---------------------------------------------*
      *                  * Test su contatore numero elementi           *
      *                  *---------------------------------------------*
           if        w-prn-srt-inp-ctr    >    zero
                     go to stp-srt-inp-900
           else      go to stp-srt-inp-600.
       stp-srt-inp-600.
      *              *-------------------------------------------------*
      *              * Composizione record di sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Composizione chiave                         *
      *                  *---------------------------------------------*
           move      rf-vbt-tip-bil       to   srt-tip-bil            .
