           go to     det-sdo-dat-200.
       det-sdo-dat-100.
      *                  *---------------------------------------------*
      *                  * Se necessaria lettura di una scheda         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione record file [mgs]       *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                      *-----------------------------------------*
      *                      * Lettura record file [mgs]               *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "ESECOD    "         to   f-key                  .
           move      w-det-sdo-dat-edr    to   rf-mgs-ann-ese         .
           move      "G"                  to   rf-mgs-tip-rec         .
           move      w-det-sdo-dat-stc    to   rf-mgs-cod-con         .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione saldo inizio anno       *
      *                      *-----------------------------------------*
           move      rf-mgs-sdo-ini       to   w-det-sdo-dat-sie      .
       det-sdo-dat-200.
      *              *-------------------------------------------------*
      *              * Determinazione saldo alla data di partenza      *
      *              *-------------------------------------------------*
           move      w-det-sdo-dat-sie    to   w-det-sdo-dat-sdo      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione per accumulo progressivi men-*
      *              * sili anno in corso fino a mese precedente a     *
      *              * quello indicato da data situazione              *
      *              *-------------------------------------------------*
           move      w-det-sdo-dat-mdr    to   w-det-sdo-dat-ctr      .
       det-sdo-dat-220.
           subtract  1                    from w-det-sdo-dat-ctr      .
           if        w-det-sdo-dat-ctr    =    zero
                     go to  det-sdo-dat-240.
           add       rf-mgs-dar-mes
                    (w-det-sdo-dat-ctr)   to   w-det-sdo-dat-sdo      .
           subtract  rf-mgs-ave-mes
                    (w-det-sdo-dat-ctr)   from w-det-sdo-dat-sdo      .
           go to     det-sdo-dat-220.
       det-sdo-dat-240.
      *              *-------------------------------------------------*
      *              * Controllo se giorno situazione e' fine mese     *
      *              *-------------------------------------------------*
           move      w-det-sdo-dat-dat    to   s-dat                  .
           add       1                    to   s-gio                  .
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Se la data e' corretta vuol dire che il     *
      *                  * giorno situazione non e' a fine mese        *
      *                  *---------------------------------------------*
           if        s-sts                =    spaces
                     go to det-sdo-dat-250.
      *                      *-----------------------------------------*
      *                      * Se fine mese si aggiungono i progressivi*
      *                      * del mese attuale                        *
      *                      *-----------------------------------------*
           add       rf-mgs-dar-mes
                     (w-det-sdo-dat-mdr)  to   w-det-sdo-dat-sdo      .
           subtract  rf-mgs-ave-mes
                     (w-det-sdo-dat-mdr)  from w-det-sdo-dat-sdo      .
      *                      *-----------------------------------------*
      *                      * Si aggiorna il saldo con le rettifiche  *
      *                      * extracontabili desunte dal [mgs] stesso *
      *                      *-----------------------------------------*
           if        rf-mgs-dav-ret
                     (w-det-sdo-dat-mdr)  =    "A"
                     subtract rf-mgs-imp-ret
                              (w-det-sdo-dat-mdr)
                                          from w-det-sdo-dat-sdo
           else      add      rf-mgs-imp-ret
                              (w-det-sdo-dat-mdr)
                                          to   w-det-sdo-dat-sdo      .
      *                      *-----------------------------------------*
      *                      * Se mese richiesto e' quello di chiusura *
      *                      * esercizio, si aggiungono i progressivi  *
      *                      * di bilancio                             *
      *                      *-----------------------------------------*
           if        w-det-sdo-dat-mdr    not  = w-prs-mes-chi
                     go to det-sdo-dat-245.
           add       rf-mgs-dar-bil       to   w-det-sdo-dat-sdo      .
           subtract  rf-mgs-ave-bil       from w-det-sdo-dat-sdo      .
       det-sdo-dat-245.
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     det-sdo-dat-999.
       det-sdo-dat-250.
      *              *-------------------------------------------------*
      *              * Se data bilancio uguale a data attuale si ag-   *
      *              * giungono i progressivi del mese attuale         *
      *              *-------------------------------------------------*
           if        w-det-sdo-dat-dat    not  = w-det-sdo-dat-dta
                     go to  det-sdo-dat-300.
           add       rf-mgs-dar-mes
                     (w-det-sdo-dat-mdr)  to   w-det-sdo-dat-sdo      .
           subtract  rf-mgs-ave-mes
                     (w-det-sdo-dat-mdr)  from w-det-sdo-dat-sdo      .
      *              *-------------------------------------------------*
      *              * Ad aggiornamento con rettifiche bilancio desun- *
      *              * te da [rdb]                                     *
      *              *-------------------------------------------------*
           go to     det-sdo-dat-500.
       det-sdo-dat-300.
      *              *-------------------------------------------------*
      *              * Altrimenti si scansiona il file [mgr] per ag-   *
      *              * giornare il saldo con i movimenti contabili fi- *
      *              * no alla data richiesta                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su file [mgr]                         *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "PDCDAT    "         to   f-key                  .
           move      w-det-sdo-dat-stc    to   rf-mgr-cod-pdc         .
           move      01                   to   s-gio                  .
           move      w-det-sdo-dat-mdr    to   s-mes                  .
           move      w-det-sdo-dat-edr    to   s-saa                  .
           move      s-dat                to   rf-mgr-dat-reg         .
           move      zero                 to   rf-mgr-num-prt         .
           move      zero                 to   rf-mgr-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                      *-----------------------------------------*
      *                      * Test su esito operazione                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-sdo-dat-500.
       det-sdo-dat-400.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale record [mgr]            *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgr                 .
      *                      *-----------------------------------------*
      *                      * Test se 'At End'                        *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-sdo-dat-500.
      *                  *---------------------------------------------*
      *                  * Test sul massimo                            *
      *                  *---------------------------------------------*
           if        rf-mgr-cod-pdc        not  = w-det-sdo-dat-stc or
                     rf-mgr-dat-reg        >    w-det-sdo-dat-dat
                     go to det-sdo-dat-500.
      *                  *---------------------------------------------*
      *                  * Selezione sul record                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se movimento di bilancio si ricicla     *
      *                      *-----------------------------------------*
           if        rf-mgr-snx-mob        not  = "N"
                     go to  det-sdo-dat-400.
      *                  *---------------------------------------------*
      *                  * Aggiornamento saldo alla data               *
      *                  *---------------------------------------------*
           if        rf-mgr-dar-ave       =    "A"
                     subtract rf-mgr-imp-mov
                                          from w-det-sdo-dat-sdo
           else      add      rf-mgr-imp-mov
                                          to   w-det-sdo-dat-sdo      .
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura [mgr]                    *
      *                  *---------------------------------------------*
           go to     det-sdo-dat-400.
       det-sdo-dat-500.
      *              *-------------------------------------------------*
      *              * Aggiornamento saldo con eventuali movimenti di  *
      *              * rettifica desunti dal file [rdb]                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su file file [rdb]                    *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DATPDC    "         to   f-key                  .
           move      w-det-sdo-dat-dat    to   rf-rdb-dat-reg         .
           move      w-det-sdo-dat-stc    to   rf-rdb-cod-pdc         .
           move      zero                 to   rf-rdb-num-prg         .
           move      "pgm/cge/fls/ioc/obj/iofrdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-rdb                 .
      *                      *-----------------------------------------*
      *                      * Test su esito operazione                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-sdo-dat-999.
       det-sdo-dat-600.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale record [rdb]            *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofrdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-rdb                 .
      *                      *-----------------------------------------*
      *                      * Test se 'At End'                        *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-sdo-dat-999.
      *                  *---------------------------------------------*
      *                  * Test sul massimo                            *
      *                  *---------------------------------------------*
           if        rf-rdb-dat-reg       not  = w-det-sdo-dat-dat or
                     rf-rdb-cod-pdc       not  = w-det-sdo-dat-stc
                     go to det-sdo-dat-999.
      *                  *---------------------------------------------*
      *                  * Aggiornamento saldo alla data               *
      *                  *---------------------------------------------*
           if        rf-rdb-dar-ave       =    "A"
                     subtract rf-rdb-imp-mov
                                          from w-det-sdo-dat-sdo
           else      add      rf-rdb-imp-mov
                                          to   w-det-sdo-dat-sdo      .
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura [rdb]                    *
      *                  *---------------------------------------------*
           go to     det-sdo-dat-600.
       det-sdo-dat-999.
           exit.

      *    *===========================================================*
      *    * Determinazione anno di esercizio per contabilita'         *
      *    *-----------------------------------------------------------*
       det-ese-cge-000.
      *              *-------------------------------------------------*
      *              * Determinazione anno di esercizio                *
      *              *-------------------------------------------------*
           move      w-ese-cge-dtr        to   s-dat                  .
           if        w-ese-cge-mce        =    12         or
                     s-mes                >    w-ese-cge-mce
                     move  s-saa          to   w-ese-cge-esa
                     go to det-ese-cge-500.
           subtract  1                    from s-saa                  .
           move      "NS"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-saa                to   w-ese-cge-esa          .
       det-ese-cge-500.
      *              *-------------------------------------------------*
      *              * Determinazione mese di esercizio                *
      *              *-------------------------------------------------*
           move      s-mes                to   w-ese-cge-esm          .
           if        w-ese-cge-mce        =    12
                     go to det-ese-cge-999.
           if        s-mes                >    w-ese-cge-mce
                     subtract w-ese-cge-mce
                                          from w-ese-cge-esm
                     go to det-ese-cge-999.
           if        s-mes                <    w-ese-cge-mce
                     add   12             to   w-ese-cge-esm
                     subtract w-ese-cge-mce
                                          from w-ese-cge-esm
                     go to det-ese-cge-999.
           move      12                   to   w-ese-cge-esm          .
       det-ese-cge-999.
           exit.

      *    *===========================================================*
      *    * Subroutines per l'accettazione del codice tipo bilancio   *
      *    *-----------------------------------------------------------*
           copy      "pgm/bil/prg/cpy/acodztb0.acs"                   .
