           copy      "pgm/cge/prg/cpy/wedtpdc0.wks"                   .

      *    *===========================================================*
      *    * Routine di determinazione saldo ad una data per un sotto- *
      *    * conto contabile                                           *
      *    *-----------------------------------------------------------*
       det-sdo-dat-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore in output                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-sdo-dat-sdo      .
      *              *-------------------------------------------------*
      *              * Se data riferimento a zero : uscita             *
      *              *-------------------------------------------------*
           if        w-det-sdo-dat-dat    =    zero
                     go to det-sdo-dat-999.
      *              *-------------------------------------------------*
      *              * Determinazione mese e anno di esercizio relati- *
      *              * alla data richiesta                             *
      *              *-------------------------------------------------*
           move      w-prs-mes-chi        to   w-ese-cge-mce          .
           move      w-det-sdo-dat-dat    to   w-ese-cge-dtr          .
           perform   det-ese-cge-000      thru det-ese-cge-999        .
           move      w-ese-cge-esa        to   w-det-sdo-dat-edr      .
           move      w-ese-cge-esm        to   w-det-sdo-dat-mdr      .
      *              *-------------------------------------------------*
      *              * Determinazione anno precedente quello della da- *
      *              * ta richiesta                                    *
      *              *-------------------------------------------------*
           move      zero                 to   s-dat                  .
           move      w-det-sdo-dat-dat    to   s-dat                  .
           subtract  1                    from s-saa                  .
           move      "NS"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-saa                to   w-det-sdo-dat-epd      .
      *              *-------------------------------------------------*
      *              * Determinazione data attuale                     *
      *              *-------------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-det-sdo-dat-dta      .
      *              *-------------------------------------------------*
      *              * Determinazione saldo ad inizio anno             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione iniziale                    *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-sdo-dat-sie      .
      *                  *---------------------------------------------*
      *                  * Determinazione se necessario lettura di una *
      *                  * o due schede saldi                          *
      *                  *                                             *
      *                  * - Se non e' mai stata eseguita una chiusura *
      *                  *   si leggono comunque due schede            *
      *                  *                                             *
      *                  *   altrimenti                                *
      *                  *                                             *
      *                  * - Se l'esercizio richiesto e' uguale o in-  *
      *                  *   feriore all'ultimo esercizio di chiusura  *
      *                  *   si legge una sola scheda                  *
      *                  *                                             *
      *                  *   altrimenti                                *
      *                  *                                             *
      *                  * - Se l'esercizio precedente quello della    *
      *                  *   data richiesta e' pari all'esercizio del- *
      *                  *   l'ultima chiusura si legge una sola sche- *
      *                  *   da                                        *
      *                  *                                             *
      *                  *   altrimenti                                *
      *                  *                                             *
      *                  * - Si leggono due schede                     *
      *                  *---------------------------------------------*
           if        w-num-dat-bil-ese    =    zero
                     move  w-det-sdo-dat-epd
                                          to   w-det-sdo-dat-wes
                     go to det-sdo-dat-010
           else if   w-det-sdo-dat-edr    not  > w-num-dat-bil-ese
                     go to det-sdo-dat-100
           else if   w-num-dat-bil-flg    not  = spaces
                     move  w-num-dat-bil-ese
                                          to   w-det-sdo-dat-wes
                     go to det-sdo-dat-010
           else if   w-det-sdo-dat-epd    =    w-num-dat-bil-ese
                     go to det-sdo-dat-100
           else      move  w-det-sdo-dat-epd
                                          to   w-det-sdo-dat-wes
                     go to det-sdo-dat-010.
       det-sdo-dat-010.
      *                  *---------------------------------------------*
      *                  * Se necessaria lettura di due schede         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura scheda esercizio di chiusura    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se conto di tipo Economico : oltre  *
      *                          *-------------------------------------*
           if        w-det-sdo-dat-tsc    =    "E"
                     go to det-sdo-dat-060.
      *                          *-------------------------------------*
      *                          * Lettura record [mgs]                *
      *                          *-------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "ESECOD    "         to   f-key                  .
           move      w-det-sdo-dat-wes    to   rf-mgs-ann-ese         .
           move      "G"                  to   rf-mgs-tip-rec         .
           move      w-det-sdo-dat-stc    to   rf-mgs-cod-con         .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                          *-------------------------------------*
      *                          * Se lettura errata : oltre           *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-sdo-dat-060.
      *                          *-------------------------------------*
      *                          * Determinazione saldo finale eserci- *
      *                          * zio di bilancio                     *
      *                          *-------------------------------------*
           move      rf-mgs-sdo-ini       to   w-det-sdo-dat-sie      .
           move      zero                 to   w-det-sdo-dat-ctr      .
       det-sdo-dat-020.
           add       1                    to   w-det-sdo-dat-ctr      .
           if        w-det-sdo-dat-ctr    >    12
                     go to  det-sdo-dat-040.
           add       rf-mgs-dar-mes
                    (w-det-sdo-dat-ctr)   to   w-det-sdo-dat-sie      .
           subtract  rf-mgs-ave-mes
                    (w-det-sdo-dat-ctr)   from w-det-sdo-dat-sie      .
           go to     det-sdo-dat-020.
       det-sdo-dat-040.
           add       rf-mgs-dar-bil       to   w-det-sdo-dat-sie      .
           subtract  rf-mgs-ave-bil       from w-det-sdo-dat-sie      .
       det-sdo-dat-060.
      *                      *-----------------------------------------*
      *                      * Lettura scheda esercizio di relativo    *
      *                      * alla data richiesta                     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione record file [mgs]   *
      *                          *-------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                          *-------------------------------------*
      *                          * Lettura record [mgs]                *
      *                          *-------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "ESECOD    "         to   f-key                  .
           move      w-det-sdo-dat-edr    to   rf-mgs-ann-ese         .
           move      "G"                  to   rf-mgs-tip-rec         .
           move      w-det-sdo-dat-stc    to   rf-mgs-cod-con         .
           move      "pgm/cge/fls/ioc/obj/iofmgs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgs                 .
      *                          *-------------------------------------*
      *                          * A trattamento valori esercizio      *
