      *    *===========================================================*
      *    * Accettazione campo selezione : Tipo di bilancio           *
      *    *-----------------------------------------------------------*
       acc-tip-bil-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-tip-bil-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-ztb-ope      .
           move      rr-tip-bil           to   w-cod-cod-ztb-cod      .
           move      05                   to   w-cod-cod-ztb-lin      .
           move      30                   to   w-cod-cod-ztb-pos      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-ric    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-ztb-cll-000  thru cod-cod-ztb-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-ztb-foi-000  thru cod-cod-ztb-foi-999    .
       acc-tip-bil-110.
           perform   cod-cod-ztb-cll-000  thru cod-cod-ztb-cll-999    .
           if        w-cod-cod-ztb-ope    =    "F+"
                     go to acc-tip-bil-115.
           if        w-cod-cod-ztb-ope    =    "AC"
                     go to acc-tip-bil-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-tip-bil-115.
           perform   cod-cod-ztb-foi-000  thru cod-cod-ztb-foi-999    .
           go to     acc-tip-bil-110.
       acc-tip-bil-120.
           move      w-cod-cod-ztb-cod    to   v-alf                  .
       acc-tip-bil-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-tip-bil-999.
       acc-tip-bil-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   rr-tip-bil             .
       acc-tip-bil-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [ztb]                      *
      *                  *---------------------------------------------*
           move      rr-tip-bil           to   w-let-arc-ztb-cod      .
           perform   let-arc-ztb-000      thru let-arc-ztb-999        .
           move      w-let-arc-ztb-des    to   rr-tip-bil-des         .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-tip-bil-des-000  thru vis-tip-bil-des-999    .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-ztb-flg    not  = spaces
                     go to acc-tip-bil-100.
       acc-tip-bil-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-tip-bil-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-tip-bil-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-tip-bil-100.
       acc-tip-bil-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo selezione : Descrizione tipo di bi- *
      *    *                                   lancio                  *
      *    *-----------------------------------------------------------*
       vis-tip-bil-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      30                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      rr-tip-bil-des       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       vis-tip-bil-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo selezione : Data riferimento bilancio  *
      *    *-----------------------------------------------------------*
       acc-dat-bil-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-dat-bil-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      07                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-ric    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      rr-dat-bil           to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-dat-bil-999.
       acc-dat-bil-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-dat                to   rr-dat-bil             .
       acc-dat-bil-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        rr-dat-bil           not  = zero
                     go to acc-dat-bil-600.
           if        v-key                =    "UP  "
                     go to acc-dat-bil-600
           else      go to acc-dat-bil-100.
       acc-dat-bil-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-dat-bil-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-dat-bil-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-dat-bil-100.
       acc-dat-bil-999.
           exit.

      *    *===========================================================*
      *    * Controllo su tasto Do in parametri di selezione           *
      *    *-----------------------------------------------------------*
       tdo-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Controllo : Tipo bilancio                       *
      *              *-------------------------------------------------*
           if        rr-tip-bil           not  = spaces
                     go to tdo-ric-sel-200.
           move      "Manca il tipo bilancio                            
      -              "               "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Controllo : Data riferimento bilancio           *
      *              *-------------------------------------------------*
           if        rr-dat-bil           not  = zero
                     go to tdo-ric-sel-300.
           move      "Manca la data di riferimento per il bilancio      
      -              "               "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-300.
      *              *-------------------------------------------------*
      *              * Determinazione se esiste gia' un bilancio rife- *
      *              * rito alla data impostata                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su file [vbv]                         *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DATVDB    "         to   f-key                  .
           move      rr-tip-bil           to   rf-vbv-tip-bil         .
           move      rr-dat-bil           to   rf-vbv-dat-bil         .
           move      zero                 to   rf-vbv-vdb-lv1         .
           move      zero                 to   rf-vbv-vdb-lv2         .
           move      zero                 to   rf-vbv-vdb-lv3         .
           move      zero                 to   rf-vbv-vdb-lv4         .
           move      zero                 to   rf-vbv-vdb-lv5         .
           move      zero                 to   rf-vbv-vdb-lv6         .
           move      "pgm/bil/fls/ioc/obj/iofvbv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vbv                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to tdo-ric-sel-400.
      *                  *---------------------------------------------*
      *                  * Lettura record [vbv]                        *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bil/fls/ioc/obj/iofvbv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vbv                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to tdo-ric-sel-400.
      *                  *---------------------------------------------*
      *                  * Test sul massimo                            *
      *                  *---------------------------------------------*
           if        rf-vbv-tip-bil       not  = rr-tip-bil or
                     rf-vbv-dat-bil       not  = rr-dat-bil
                     go to tdo-ric-sel-400.
      *                  *---------------------------------------------*
      *                  * Avviso all'utente                           *
      *                  *---------------------------------------------*
           perform   tdo-ric-sel-cnf-000  thru tdo-ric-sel-cnf-999    .
      *                      *-----------------------------------------*
      *                      * Test su scelta                          *
      *                      *-----------------------------------------*
           if        w-exp-cnf-ope-sce    =    01
                     go to tdo-ric-sel-920.
       tdo-ric-sel-400.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
       tdo-ric-sel-920.
      *                  *---------------------------------------------*
      *                  * Flag di uscita ad errore                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-999.
           exit.

