      ******************************************************************
       Procedure Division                using f rn-sfo-num           .
      ******************************************************************

      *    *===========================================================*
      *    * Procedure division fissa per tutti i moduli di i-o        *
      *    *-----------------------------------------------------------*
           copy      "swd/ske/ion/ioncp50"                            .

      *    *===========================================================*
      *    * Unstring da record numeri a record [num]                  *
      *    *-----------------------------------------------------------*
       uns-000.
           unstring  rn-sfo-num           into rf-num-dat-num
                                  with pointer z-inx                  .
       uns-999.
           exit.

      *    *===========================================================*
      *    * String da record [num] a record numeri                    *
      *    *-----------------------------------------------------------*
       stg-000.
           string    rf-num-dat-num       
                     delimited  by size        into rn-sfo-num
                                  with pointer z-inx                  .
       stg-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione record numeri                             *
      *    *-----------------------------------------------------------*
       nor-000.
           move      spaces               to   rn-sfo-num             .
           move      zero                 to   rn-sfo-num-scl-ann     .
           move      zero                 to   rn-sfo-num-num-odb     .
       nor-999.
           exit.
           
      *    *===========================================================*
      *    * Composizione componente variabile della chiave            *
      *    *-----------------------------------------------------------*
       key-000.
           move      spaces               to   k-var                  .
           move      rn-sfo-num-scl-ann   to   k-scl-ann              .
       key-999.
           exit.
