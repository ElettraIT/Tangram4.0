           move      w-gen-rig-400 (3)    to   w-all-str-cat (3)      .
           move      w-gen-rig-400 (4)    to   w-all-str-cat (4)      .
           move      w-gen-rig-400 (5)    to   w-all-str-cat (5)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *              *-------------------------------------------------*
      *              * Emissione tag <Causale>                         *
      *              *                                                 *
      *              * '2.1.1.11'                                      *
      *              *-------------------------------------------------*
           move      "Causale"            to   w-sta-emi-xml-pmt      .
           move      "E"                  to   w-sta-emi-xml-ope      .
           move      w-all-str-alf        to   w-sta-emi-xml-val      .
           move      "="                  to   w-sta-emi-xml-ind      .
           perform   emi-tag-xml-000      thru emi-tag-xml-999        .
       gfx-cau-std-200.
      *              *-------------------------------------------------*
      *              * Test se necessaria un'altra riga                *
      *              *-------------------------------------------------*
           if        w-gen-rig-400 (6)    =    spaces
                     go to gfx-cau-std-900.
      *              *-------------------------------------------------*
      *              * Emissione seconda riga di causale da 200 carat- *
      *              * teri equivalente a 5 righe di descrizione       *
      *              *-------------------------------------------------*
           move      200                  to   w-all-str-lun          .
           move      05                   to   w-all-str-num          .
           move      w-gen-rig-400 (6)    to   w-all-str-cat (1)      .
           move      w-gen-rig-400 (7)    to   w-all-str-cat (2)      .
           move      w-gen-rig-400 (8)    to   w-all-str-cat (3)      .
           move      w-gen-rig-400 (9)    to   w-all-str-cat (4)      .
           move      w-gen-rig-400 (10)   to   w-all-str-cat (5)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *              *-------------------------------------------------*
      *              * Emissione tag <Causale>                         *
      *              *                                                 *
      *              * '2.1.1.11'                                      *
      *              *-------------------------------------------------*
           move      "Causale"            to   w-sta-emi-xml-pmt      .
           move      "E"                  to   w-sta-emi-xml-ope      .
           move      w-all-str-alf        to   w-sta-emi-xml-val      .
           move      "="                  to   w-sta-emi-xml-ind      .
           perform   emi-tag-xml-000      thru emi-tag-xml-999        .
       gfx-cau-std-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     gfx-cau-std-999.
       gfx-cau-std-999.
           exit.

