      *              * Normalizzazione record [sff]                    *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsff"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sff                 .
      *              *-------------------------------------------------*
      *              * Lettura record [fit]                            *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMFTF     "        to   f-key                  .
           move      m-scf-xml-prt-doc    to   rf-sff-num-ftf         .
           move      "pgm/scf/fls/ioc/obj/iofsff"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sff                 .
      *                  *---------------------------------------------*
      *                  * Se errore in lettura                        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     move  "#"            to   m-scf-xml-exi-sts
                     go to gfx-900.
       gfx-200.
      *              *-------------------------------------------------*
