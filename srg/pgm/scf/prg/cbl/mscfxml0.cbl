      *              * '2.1.1.4'                                       *
      *              *                                                 *
      *              * In base alla Guida di compilazione (v.04/02/22) *
      *              * si pone come numero il protocollo IVA, precedu- *
      *              * to da una sigla convenzionale e dall'eventuale  *
      *              * numero giornale Iva                             *
      *              *                                                 *
      *              * Esempio: R01/102                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Sigla convenzionale                         *
      *                  *                                             *
      *                  * - 'R' = Reverse Charge                      *
      *                  * - 'E' = Estero                              *
      *                  * - 'M' = Merce CEE                           *
      *                  * - 'N' = Esteri non residenti                *
      *                  *---------------------------------------------*
           if        m-scf-xml-tdo-fel    =    "TD16"
                     move  "R"            to   w-all-str-cat (1)
           else if   m-scf-xml-tdo-fel    =    "TD17"
                     move  "E"            to   w-all-str-cat (1)
           else if   m-scf-xml-tdo-fel    =    "TD18"
                     move  "M"            to   w-all-str-cat (1)
           else if   m-scf-xml-tdo-fel    =    "TD19"
                     move  "N"            to   w-all-str-cat (1)
           else      move  "R"            to   w-all-str-cat (1)      .
      *                  *---------------------------------------------*
      *                  * Editing numero giornale Iva                 *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
