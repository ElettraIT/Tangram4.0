           move      s-saa                to   w-bin-wrk              .
           subtract  21                   from w-bin-wrk              .
           move      2                    to   w-bin-inx              .
           move      w-bin-wrk            to   w-bin-num              .
           move      w-bin-byt(w-bin-inx) to   w-gen-ann-doc          .
       gfx-seq-200.
      *              *-------------------------------------------------*
