       emi-htm-dst-lnk-000.
       emi-htm-dst-lnk-500.
      *              *-------------------------------------------------*
      *              * Da 2022                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Anno documento                              *
      *                  *---------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      04                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "9"                  to   p-edm                  .
      *
           move      rf-xft-ddo-ftf       to   s-dat                  .
           move      s-saa                to   p-num                  .
           add       1900                 to   p-num                  .
      *
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   f-xxx-ann              .
      *                  *---------------------------------------------*
      *                  * Eliminazione estensione da filename         *
      *                  *---------------------------------------------*
           move      rf-xft-nom-xml       to   w-all-str-alf          .
           move      "."                  to   w-all-str-del          .
           perform   all-str-ext-000      thru all-str-ext-999        .
           move      w-all-str-cat (1)    to   f-xxx-fln              .
      *                  *---------------------------------------------*
      *                  * Output                                      *
      *                  *---------------------------------------------*
           move      spaces               to   j-rec                  .
      *
           string    "<td><a href='../../htm/" 
                                delimited by   size
                     f-xxx-ann  delimited by   spaces
                     "/"        delimited by   size
                     f-xxx-fln  delimited by   spaces
                     ".html"    delimited by   spaces
                     "' target='_blank'>"
                                delimited by   size
                     f-xxx-fln  delimited by   spaces
                     "</a>"     delimited by   size
                                          into j-rec                  .
      *
           perform   emi-htm-dst-ptn-000  thru emi-htm-dst-ptn-999    .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     emi-htm-dst-lnk-900.
       emi-htm-dst-lnk-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     emi-htm-dst-lnk-999.
       emi-htm-dst-lnk-999.
           exit.

      *    *===========================================================*
      *    * Esecuzione emissione distinta                             *
      *    *                                                           *
      *    * Subroutine di emissione Tag 'td'                          *
      *    *-----------------------------------------------------------*
       emi-htm-dst-ttd-000.
      *              *-------------------------------------------------*
      *              * Assemblaggio                                    *
      *              *-------------------------------------------------*
           move      240                  to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      "<td>"               to   w-all-str-cat (1)      .
           move      w-det-fil-htm-tag    to   w-all-str-cat (2)      .
           move      "</td>"              to   w-all-str-cat (3)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
           move      w-all-str-alf        to   j-rec                  .
           perform   emi-htm-dst-ptn-000  thru emi-htm-dst-ptn-999    .
       emi-htm-dst-ttd-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     emi-htm-dst-ttd-999.
       emi-htm-dst-ttd-999.
           exit.

      *    *===========================================================*
      *    * Esecuzione emissione distinta                             *
      *    *                                                           *
      *    * Subroutine per script 'Javascript'                        *
      *    *-----------------------------------------------------------*
       emi-htm-dst-jsc-000.
      *              *-------------------------------------------------*
      *              * Assemblaggio                                    *
      *              *-------------------------------------------------*
           move      240                  to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      "<script src='../../../tmp/ind/jsc/"
                                          to   w-all-str-cat (1)      .
           move      w-det-fil-htm-tag    to   w-all-str-cat (2)      .
           move      "'></script>"        to   w-all-str-cat (3)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
           move      w-all-str-alf        to   j-rec                  .
           perform   emi-htm-dst-ptn-000  thru emi-htm-dst-ptn-999    .
       emi-htm-dst-jsc-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     emi-htm-dst-jsc-999.
       emi-htm-dst-jsc-999.
           exit.

      *    *===========================================================*
