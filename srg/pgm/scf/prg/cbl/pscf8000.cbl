                    (03 : 02)             to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-num                to   w-det-dat-num-saa      .
      *
           move      "CV"                 to   v-ope                  .
           move      02                   to   v-car                  .
           move      w-all-str-cat (2)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-num                to   w-det-dat-num-mes      .
      *
           move      "CV"                 to   v-ope                  .
