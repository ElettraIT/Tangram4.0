           move      "POST"               to   o-com                  .
           call      "swd/mod/prg/obj/mopsys"
                                         using o                      .
      *
           if        o-pat                =    "S"
                     move  "S"            to   w-gen-flg-btc
           else      move  "N"            to   w-gen-flg-btc          .
