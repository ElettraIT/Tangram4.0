      *    *===========================================================*
      *    * Visualizzazione rullino in scroll                         *
      *    *-----------------------------------------------------------*
       vis-rul-scr-000.
      *              *-------------------------------------------------*
      *              * Incremento contatore                            *
      *              *-------------------------------------------------*
           add       1                    to   w-gen-vis-ctr          .
      *              *-------------------------------------------------*
      *              * Test su contatore contatore                     *
      *              *-------------------------------------------------*
           if        w-gen-vis-ctr        >    w-gen-vis-max
                     go to vis-rul-scr-200.
       vis-rul-scr-100.
      *              *-------------------------------------------------*
      *              * se entro le max linee                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Stringa da visualizzare                     *
      *                  *---------------------------------------------*
           move      w-gen-vis-str        to   w-gen-vis-lvi
                                              (w-gen-vis-ctr)         .
           move      w-gen-vis-str        to   w-gen-vis-sdv          .
      *                  *---------------------------------------------*
      *                  * Determinazione linea a video                *
      *                  *---------------------------------------------*
           add       3                    to   w-gen-vis-ctr
                                        giving w-gen-vis-lin          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           perform   vis-rul-scr-800      thru vis-rul-scr-809        .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     vis-rul-scr-900.
       vis-rul-scr-200.
      *              *-------------------------------------------------*
      *              * se scroll verso l'alto                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ciclo di scorrimento                        *
      *                  *---------------------------------------------*
           move      zero                 to   w-gen-vis-c01          .
       vis-rul-scr-400.
           add       1                    to   w-gen-vis-c01          .
           if        w-gen-vis-c01        >    w-gen-vis-max
                     go to vis-rul-scr-900.
      *                  *---------------------------------------------*
      *                  * Determinazione secondo contatore            *
      *                  *---------------------------------------------*
           move      w-gen-vis-c01        to   w-gen-vis-c02          .
           add       1                    to   w-gen-vis-c02          .
      *                  *---------------------------------------------*
      *                  * Test se ultimo elemento                     *
      *                  *---------------------------------------------*
           if        w-gen-vis-c01        not  = w-gen-vis-max
                     go to vis-rul-scr-420.
      *                  *---------------------------------------------*
      *                  * Ultimo elemento                             *
      *                  *---------------------------------------------*
           move      w-gen-vis-str        to   w-gen-vis-lvi
                                              (w-gen-vis-c01)         .
           move      w-gen-vis-str        to   w-gen-vis-sdv          .
           move      w-gen-vis-c01        to   w-gen-vis-lin          .
           add       3                    to   w-gen-vis-lin          .
           perform   vis-rul-scr-800      thru vis-rul-scr-809        .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     vis-rul-scr-900.
       vis-rul-scr-420.
      *                  *---------------------------------------------*
      *                  * Scorrimento                                 *
      *                  *---------------------------------------------*
           move      w-gen-vis-lvi 
                    (w-gen-vis-c02)       to   w-gen-vis-lvi
                                              (w-gen-vis-c01)         .
           move      w-gen-vis-lvi 
                    (w-gen-vis-c01)       to   w-gen-vis-sdv          .
           move      w-gen-vis-c01        to   w-gen-vis-lin          .
           add       3                    to   w-gen-vis-lin          .
           perform   vis-rul-scr-800      thru vis-rul-scr-809        .
      *                  *---------------------------------------------*
      *                  * A riciclo                                   *
      *                  *---------------------------------------------*
           go to     vis-rul-scr-400.
       vis-rul-scr-800.
      *              *-------------------------------------------------*
      *              * Subroutine interna di visualizzazione linea     *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      w-gen-vis-lin        to   v-lin                  .
           move      01                   to   v-pos                  .
           move      w-gen-vis-sdv        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-rul-scr-809.
           exit.
       vis-rul-scr-900.
      *              *-------------------------------------------------*
