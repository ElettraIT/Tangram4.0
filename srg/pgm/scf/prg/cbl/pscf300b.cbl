      *    *===========================================================*
      *    * Routine post-conferma di inserimento                      *
      *    *-----------------------------------------------------------*
       pos-cnf-ins-000.
      *              *-------------------------------------------------*
      *              * Aggiornamento default per data registrazione    *
      *              *-------------------------------------------------*
           move      w-key-dat-reg        to   w-def-dat-reg          .
      *              *-------------------------------------------------*
      *              * Aggiornamento default per tipo operazione       *
      *              *-------------------------------------------------*
           move      w-key-tip-ope        to   w-def-tip-ope          .
       pos-cnf-ins-050.
      *              *-------------------------------------------------*
      *              * Lettura record [sfs] con lock                   *
      *              *-------------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMSCF    "         to   f-key                  .
           move      w-tes-num-scf        to   rf-sfs-num-scf         .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfs                 .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to pos-cnf-ins-200.
       pos-cnf-ins-100.
      *              *-------------------------------------------------*
      *              * Se record [sfs] non esistente                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "Attenzione : scadenza non esistente - inserimento 
      -              "non eseguito   "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     pos-cnf-ins-999.
       pos-cnf-ins-200.
      *              *-------------------------------------------------*
      *              * Se record [sfs] esistente                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Aggiornamenti contabili generati dalla ge-  *
      *                  * stione scadenze fornitori a fronte del mo-  *
      *                  * vimento di storno                           *
      *                  *---------------------------------------------*
           perform   cge-scf-sto-000      thru cge-scf-sto-999        .
       pos-cnf-ins-300.
      *                  *---------------------------------------------*
      *                  * Completamento del record scadenze con i da- *
      *                  * ti relativi allo storno                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Data di sistema di ultimo inserimento o *
      *                      * modifica, utente, fase                  *
      *                      *-----------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rf-sfs-ide-dat         .
           move      s-ute                to   rf-sfs-ide-ute         .
           move      s-fas                to   rf-sfs-ide-fas         .
      *                      *-----------------------------------------*
      *                      * Data registrazione movimento            *
      *                      *-----------------------------------------*
           move      w-tes-dat-reg        to   rf-sfs-dtr-sto         .
      *                      *-----------------------------------------*
      *                      * Data registrazione movimento contabile  *
      *                      * a fronte del movimento                  *
      *                      *-----------------------------------------*
           move      l-cge-300-dat-reg    to   rf-sfs-drc-sto         .
      *                      *-----------------------------------------*
      *                      * Numero protocollo movimento contabile   *
      *                      * a fronte del movimento                  *
      *                      *-----------------------------------------*
           move      l-cge-300-num-prt    to   rf-sfs-npc-sto         .
      *                      *-----------------------------------------*
      *                      * Segnale di si/no registrazione nuova    *
      *                      * scadenza a fronte dello storno provvi-  *
      *                      * soriamente a No, aggiornato eventual-   *
      *                      * mente dalla registrazione semi-automa-  *
      *                      * tica                                    *
      *                      *-----------------------------------------*
           move      02                   to   rf-sfs-rns-sto         .
      *                      *-----------------------------------------*
      *                      * Numero nuova scadenza a fronte dello    *
      *                      * storno                                  *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sfs-nns-sto         .
      *                      *-----------------------------------------*
      *                      * Tipo nuova scadenza a fronte dello      *
      *                      * storno                                  *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sfs-tns-sto         .
       pos-cnf-ins-400.
      *                  *---------------------------------------------*
      *                  * Update record [sfs]                         *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfs                 .
       pos-cnf-ins-500.
      *                  *---------------------------------------------*
      *                  * Unlock record [sfs]                         *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfs                 .
       pos-cnf-ins-600.
      *                  *---------------------------------------------*
      *                  * Preparazione del tipo uscita adeguato per   *
      *                  * il caso di richiesta di registrazione di    *
      *                  * nuova scadenza a fronte dello storno        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se non richiesta registrazione nuova    *
      *                      * scadenza : nessuna preparazione         *
      *                      *-----------------------------------------*
           if        w-tes-rns-sto (1)    not  = 01
                     go to pos-cnf-ins-999.
      *                      *-----------------------------------------*
      *                      * Se richiesta registrazione nuova sca-   *
      *                      * denza                                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Flag di richiesta registrazione     *
      *                          * nuova scadenza a fronte dell'opera- *
      *                          * zione appena completata             *
      *                          *-------------------------------------*
           move      "#"                  to   w-key-ric-rns          .
      *                          *-------------------------------------*
      *                          * Data registrazione per nuova sca-   *
      *                          * denza da registrare                 *
      *                          *-------------------------------------*
           move      w-key-dat-reg        to   w-key-dtr-rns          .
      *                          *-------------------------------------*
      *                          * Tipo nuova scadenza da registrare   *
      *                          *-------------------------------------*
           if        w-tes-tns-sto (1)    =    01
                     move  1101           to   w-key-top-rns
           else if   w-tes-tns-sto (1)    =    02
                     move  1102           to   w-key-top-rns
           else if   w-tes-tns-sto (1)    =    03
                     move  1103           to   w-key-top-rns
           else if   w-tes-tns-sto (1)    =    04
                     move  1104           to   w-key-top-rns
           else if   w-tes-tns-sto (1)    =    05
                     move  1105           to   w-key-top-rns
           else if   w-tes-tns-sto (1)    =    06
                     move  1106           to   w-key-top-rns
      *                              *---------------------------------*
      *                              * Test se Bonifico su Estero      *
      *                              *---------------------------------*
           else if   w-tes-tns-sto (1)    =    07
                     if    w-tes-tvl-scf (1)
                                          =    01
                           move  1107     to   w-key-top-rns
                     else  move  1127     to   w-key-top-rns
      *
           else if   w-tes-tns-sto (1)    =    08
                     move  1108           to   w-key-top-rns
           else if   w-tes-tns-sto (1)    =    09
                     move  1109           to   w-key-top-rns
           else if   w-tes-tns-sto (1)    =    10
                     move  1110           to   w-key-top-rns
           else if   w-tes-tns-sto (1)    =    11
                     move  1111           to   w-key-top-rns          .
      *                          *-------------------------------------*
      *                          * Importo della nuova scadenza        *
      *                          *-------------------------------------*
           move      w-tes-imp-scf (1)    to   w-key-imp-rns          .
      *                          *-------------------------------------*
      *                          * Numero della scadenza a fronte del- *
      *                          * la quale deve essere registrata la  *
      *                          * nuova scadenza                      *
      *                          *-------------------------------------*
           move      w-tes-num-scf        to   w-key-nvs-rns          .
      *                          *-------------------------------------*
      *                          * Tipo operazione che ha causato la   *
      *                          * richiesta di registrazione della    *
      *                          * nuova scadenza                      *
      *                          *-------------------------------------*
           move      1200                 to   w-key-tvo-rns          .
       pos-cnf-ins-999.
           exit.

      *    *===========================================================*
      *    * Routine post-conferma di modifica                         *
      *    *-----------------------------------------------------------*
       pos-cnf-mod-000.
      *              *-------------------------------------------------*
      *              * Nessuna azione                                  *
      *              *-------------------------------------------------*
           go to     pos-cnf-mod-999.
       pos-cnf-mod-999.
           exit.

      *    *===========================================================*
      *    * Routine post-conferma di annullamento                     *
      *    *-----------------------------------------------------------*
       pos-cnf-ann-000.
      *              *-------------------------------------------------*
      *              * Lettura record [sfs] con lock                   *
      *              *-------------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMSCF    "         to   f-key                  .
           move      w-tes-num-scf        to   rf-sfs-num-scf         .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfs                 .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to pos-cnf-ann-200.
       pos-cnf-ann-100.
      *              *-------------------------------------------------*
      *              * Se record [sfs] non esistente                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "Attenzione : scadenza non esistente - annullamento
      -              " non eseguito  "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     pos-cnf-ann-999.
       pos-cnf-ann-200.
      *              *-------------------------------------------------*
      *              * Se record [sfs] esistente                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Annullamento del movimento di contabilita'  *
      *                  * generale che era stato a suo tempo genera-  *
      *                  * to a fronte del movimento di storno         *
      *                  *---------------------------------------------*
           move      w-tes-drc-sto (2)    to    w-cge-scf-drc-del     .
           move      w-tes-npc-sto (2)    to    w-cge-scf-npc-del     .
           perform   del-cge-scf-000      thru del-cge-scf-999        .
       pos-cnf-ann-300.
      *                  *---------------------------------------------*
      *                  * Normalizzazione, nel record scadenze, dei   *
      *                  * dati relativi allo storno                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Data di sistema di ultimo inserimento o *
      *                      * modifica, utente, fase                  *
      *                      *-----------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rf-sfs-ide-dat         .
           move      s-ute                to   rf-sfs-ide-ute         .
           move      s-fas                to   rf-sfs-ide-fas         .
      *                      *-----------------------------------------*
      *                      * Data registrazione movimento            *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sfs-dtr-sto         .
      *                      *-----------------------------------------*
      *                      * Data registrazione movimento contabile  *
      *                      * a fronte del movimento                  *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sfs-drc-sto         .
      *                      *-----------------------------------------*
      *                      * Numero protocollo movimento contabile   *
      *                      * a fronte del movimento                  *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sfs-npc-sto         .
      *                      *-----------------------------------------*
      *                      * Segnale di si/no registrazione nuova    *
      *                      * scadenza a fronte dello storno          *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sfs-rns-sto         .
      *                      *-----------------------------------------*
      *                      * Tipo nuova scadenza a fronte dello      *
      *                      * storno                                  *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sfs-tns-sto         .
      *                      *-----------------------------------------*
      *                      * Numero nuova scadenza a fronte dello    *
      *                      * storno                                  *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sfs-nns-sto         .
       pos-cnf-ann-400.
      *                  *---------------------------------------------*
      *                  * Update record [sfs]                         *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfs                 .
       pos-cnf-ann-500.
      *                  *---------------------------------------------*
      *                  * Unlock record [sfs]                         *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfs                 .
       pos-cnf-ann-600.
      *                  *---------------------------------------------*
      *                  * Eventuale messaggio per scadenza gia' re-   *
      *                  * gistrata a fronte dello storno in caso di   *
      *                  * annullamento storno                         *
      *                  *---------------------------------------------*
           perform   mgr-ann-sto-000      thru mgr-ann-sto-999        .
       pos-cnf-ann-999.
           exit.

      *    *===========================================================*
      *    * Emissione messaggio per scadenza gia' registrata a fronte *
      *    * dello storno in caso di annullamento storno               *
      *    *-----------------------------------------------------------*
       mgr-ann-sto-000.
      *              *-------------------------------------------------*
      *              * Se non era stata registrata una nuova scadenza  *
      *              * a fronte dello storno : nessun messaggio        *
      *              *-------------------------------------------------*
           if        w-tes-rns-sto (1)    not  = 01
                     go to mgr-ann-sto-999.
       mgr-ann-sto-100.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       mgr-ann-sto-200.
      *              *-------------------------------------------------*
      *              * Emissione del messaggio                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      21                   to   v-lto                  .
           move      75                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Messaggio nel box                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Linea 1                                 *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      08                   to   v-pos                  .
           move      w-rns-ann-sto-l10    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Linea 2                                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Editing del tipo scadenza           *
      *                          *-------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-scf-lun    to   v-car                  .
           move      w-exp-tip-scf-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-tip-scf-tbl    to   v-txt                  .
           move      w-tes-tns-sto (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-all-str-cat (2)      .
      *                          *-------------------------------------*
      *                          * Inizio preparazione della stringa   *
      *                          *-------------------------------------*
           move      58                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
           move      "denza, di tipo"     to   w-all-str-cat (1)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                          *-------------------------------------*
      *                          * Concatenamento del numero scadenza  *
      *                          * editato                             *
      *                          *-------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      w-tes-nns-sto (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-all-str-cat (3)      .
      *                          *-------------------------------------*
      *                          * Continuazione preparazione stringa  *
      *                          *-------------------------------------*
           move      58                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
           move      w-all-str-alf        to   w-all-str-cat (1)      .
           move      ", nr."              to   w-all-str-cat (2)      .
           move      "."                  to   w-all-str-cat (4)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *                          *-------------------------------------*
      *                          * Visualizzazione                     *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      53                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-all-str-alf        to   v-alf                  .
