      *              * caso gli aggiornamenti contabili non devono     *
      *              * essere eseguiti : uscita con 'N'                *
      *              *-------------------------------------------------*
           if        w-prs-scf-snx-cge    =    "N"
                     move  "N"            to   w-cge-scf-sto-snx
                     go to cge-scf-sto-snx-999.
       cge-scf-sto-snx-025.
      *              *-------------------------------------------------*
      *              * Se il codice causale contabile per il tipo ope- *
      *              * razione di storno e' a zero : uscita con 'N'    *
      *              *-------------------------------------------------*
           if        w-top-cau-cge
                    (w-top-ele-inx)       =    zero
                     move  "N"            to   w-cge-scf-sto-snx
                     go to cge-scf-sto-snx-999.
       cge-scf-sto-snx-100.
      *              *-------------------------------------------------*
      *              * Determinazione del tipo operazione di registra- *
      *              * zione corrispondente al tipo scadenza da stor-  *
      *              * nare, e dell'indice di essa in tabella opera-   *
      *              * zioni                                           *
      *              *-------------------------------------------------*
       cge-scf-sto-snx-125.
      *                  *---------------------------------------------*
      *                  * Determinazione tipo operazione              *
      *                  *---------------------------------------------*
           if        w-tes-tip-scf (01)   =    01
                     move  1101           to   w-cge-scf-sto-wor
           else if   w-tes-tip-scf (01)   =    02
                     move  1102           to   w-cge-scf-sto-wor
           else if   w-tes-tip-scf (01)   =    03
                     move  1103           to   w-cge-scf-sto-wor
           else if   w-tes-tip-scf (01)   =    04
                     move  1104           to   w-cge-scf-sto-wor
           else if   w-tes-tip-scf (01)   =    05
                     move  1105           to   w-cge-scf-sto-wor
           else if   w-tes-tip-scf (01)   =    06
                     move  1106           to   w-cge-scf-sto-wor
      *                      *-----------------------------------------*
      *                      * Test se Bonifico su Estero              *
      *                      *-----------------------------------------*
           else if   w-tes-tip-scf (01)   =    07
                     if    w-tes-tvl-scf (1)
                                          =    01
                           move  1107     to   w-cge-scf-sto-wor
                     else  move  1127     to   w-cge-scf-sto-wor
      *
           else if   w-tes-tip-scf (01)   =    08
                     move  1108           to   w-cge-scf-sto-wor
           else if   w-tes-tip-scf (01)   =    09
                     move  1109           to   w-cge-scf-sto-wor
           else if   w-tes-tip-scf (01)   =    10
                     move  1110           to   w-cge-scf-sto-wor
           else if   w-tes-tip-scf (01)   =    11
                     move  1111           to   w-cge-scf-sto-wor
           else      move  zero           to   w-cge-scf-sto-wor      .
       cge-scf-sto-snx-150.
      *                  *---------------------------------------------*
      *                  * Se non determinabile si esce con 'N'        *
      *                  *---------------------------------------------*
           if        w-cge-scf-sto-wor    =    zero
                     move  "N"            to   w-cge-scf-sto-snx
                     go to cge-scf-sto-snx-999.
       cge-scf-sto-snx-175.
      *                  *---------------------------------------------*
      *                  * Se tipo operazione 1111, e tipo registra-   *
      *                  * zione scadenza per cessione a terzi, si     *
      *                  * porta il tipo operazione a 1161             *
      *                  *---------------------------------------------*
           if        w-cge-scf-sto-wor    =    1111 and
