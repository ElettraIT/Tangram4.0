      *    *===========================================================*
      *    * Determinazione e bufferizzazione generalita' del benefi-  *
      *    * ciario per l'inoltro                                      *
      *    *-----------------------------------------------------------*
       det-gdb-inl-000.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del tipo di inoltro per il *
      *              * pagamento                                       *
      *              *-------------------------------------------------*
           if        rf-sfp-inl-pgf       =    01
                     go to det-gdb-inl-200
           else if   rf-sfp-inl-pgf       =    02
                     go to det-gdb-inl-400
           else if   rf-sfp-inl-pgf       =    03
                     go to det-gdb-inl-600
           else      go to det-gdb-inl-400.
       det-gdb-inl-200.
      *              *-------------------------------------------------*
      *              * Se inoltro alla sede commerciale                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se codice creditore a zero : a lettura da   *
      *                  * anagrafica fornitore contabile              *
      *                  *---------------------------------------------*
           if        rf-sfp-cod-fnt       =    zero
                     go to det-gdb-inl-400.
      *                  *---------------------------------------------*
      *                  * Lettura da anagrafica fornitore commerciale *
      *                  * per la sede                                 *
      *                  *---------------------------------------------*
           move      "C"                  to   w-let-arc-dcf-tle      .
           move      rf-sfp-cod-fnt       to   w-let-arc-dcf-cod      .
           move      spaces               to   w-let-arc-dcf-dpz      .
           perform   let-arc-dcf-000      thru let-arc-dcf-999        .
      *                  *---------------------------------------------*
      *                  * Se record non trovato : a lettura da ana-   *
      *                  * grafica fornitore contabile                 *
      *                  *---------------------------------------------*
           if        w-let-arc-dcf-flg    not  = spaces
                     go to det-gdb-inl-400.
      *                  *---------------------------------------------*
      *                  * Se record trovato                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Spostamento dati                        *
      *                      *-----------------------------------------*
           move      w-let-arc-dcf-rag    to   w-sta-dis-bfc-rag      .
           move      w-let-arc-dcf-via    to   w-sta-dis-bfc-via      .
           move      w-let-arc-dcf-loc    to   w-sta-dis-bfc-loc      .
      *                      *-----------------------------------------*
      *                      * A codice fornitore                      *
      *                      *-----------------------------------------*
           go to     det-gdb-inl-900.
       det-gdb-inl-400.
      *              *-------------------------------------------------*
      *              * Se inoltro alla sede legale                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura da anagrafica fornitore contabile   *
      *                  *---------------------------------------------*
           move      rf-sfp-cod-fnt       to   w-let-arc-fnt-cod      .
           perform   let-arc-fnt-000      thru let-arc-fnt-999        .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda se record trovato op-  *
      *                  * pure no                                     *
      *                  *---------------------------------------------*
           if        w-let-arc-fnt-flg    =    spaces
                     go to det-gdb-inl-420
           else      go to det-gdb-inl-440.
       det-gdb-inl-420.
      *                  *---------------------------------------------*
      *                  * Se record trovato                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Spostamento dati                        *
      *                      *-----------------------------------------*
           move      w-let-arc-fnt-rag    to   w-sta-dis-bfc-rag      .
           move      w-let-arc-fnt-via    to   w-sta-dis-bfc-via      .
           move      w-let-arc-fnt-loc    to   w-sta-dis-bfc-loc      .
      *                      *-----------------------------------------*
      *                      * A codice fornitore                      *
      *                      *-----------------------------------------*
           go to     det-gdb-inl-900.
       det-gdb-inl-440.
      *                  *---------------------------------------------*
      *                  * Se record non trovato                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Riempimento con puntini                 *
      *                      *-----------------------------------------*
           move      all   "."            to   w-sta-dis-bfc-rag      .
           move      all   "."            to   w-sta-dis-bfc-via      .
           move      all   "."            to   w-sta-dis-bfc-loc      .
      *                      *-----------------------------------------*
      *                      * A codice fornitore                      *
      *                      *-----------------------------------------*
           go to     det-gdb-inl-900.
       det-gdb-inl-600.
      *              *-------------------------------------------------*
      *              * Se inoltro alla dipendenza                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se codice fornitore a zero : a lettura da   *
      *                  * anagrafica fornitore commerciale            *
      *                  *---------------------------------------------*
           if        rf-sfp-cod-fnt       =    zero
                     go to det-gdb-inl-200.
      *                  *---------------------------------------------*
      *                  * Se codice dipendenza a spaces : a lettura   *
      *                  * anagrafica fornitore commerciale            *
      *                  *---------------------------------------------*
           if        rf-sfp-dpz-fnt       =    spaces
                     go to det-gdb-inl-200.
      *                  *---------------------------------------------*
      *                  * Lettura da anagrafica fornitore commerciale *
      *                  * per la dipendenza                           *
      *                  *---------------------------------------------*
           move      "D"                  to   w-let-arc-dcf-tle      .
           move      rf-sfp-cod-fnt       to   w-let-arc-dcf-cod      .
           move      rf-sfp-dpz-fnt       to   w-let-arc-dcf-dpz      .
           perform   let-arc-dcf-000      thru let-arc-dcf-999        .
      *                  *---------------------------------------------*
      *                  * Se record non trovato : a lettura da ana-   *
      *                  * grafica fornitore commerciale               *
      *                  *---------------------------------------------*
           if        w-let-arc-dcf-flg    not  = spaces
                     go to det-gdb-inl-200.
      *                  *---------------------------------------------*
      *                  * Se record trovato                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Spostamento dati                        *
      *                      *-----------------------------------------*
           move      w-let-arc-dcf-rag    to   w-sta-dis-bfc-rag      .
           move      w-let-arc-dcf-via    to   w-sta-dis-bfc-via      .
           move      w-let-arc-dcf-loc    to   w-sta-dis-bfc-loc      .
      *                      *-----------------------------------------*
      *                      * A codice fornitore                      *
      *                      *-----------------------------------------*
           go to     det-gdb-inl-900.
       det-gdb-inl-900.
      *              *-------------------------------------------------*
      *              * Codice del fornitore                            *
      *              *-------------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione codice fornitore        *
      *                      *-----------------------------------------*
           move      spaces               to   w-sta-dis-bfc-cdf      .
       det-gdb-inl-932.
      *                      *-----------------------------------------*
      *                      * Codice fornitore, con il seguente for-  *
      *                      * mato :                                  *
      *                      *                                         *
      *                      * Codice fornitore : X/NNNNNNN/DDDD       *
      *                      *                                         *
      *                      * dove :                                  *
      *                      *                                         *
      *                      * X       : F = Fornitore                 *
      *                      *                                         *
      *                      * NNNNNNN : Codice fornitore              *
      *                      *                                         *
      *                      * DDDD    : Sigla della dipendenza        *
      *                      *                                         *
      *                      *-----------------------------------------*
       det-gdb-inl-933.
      *                          *-------------------------------------*
      *                          * Editing preliminare codice fornito- *
      *                          * re                                  *
      *                          *-------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      07                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      rf-sfp-cod-fnt       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * Deviazione a seconda se c'e' o no   *
      *                          * la dipendenza                       *
      *                          *-------------------------------------*
           if        rf-sfp-dpz-fnt       not  = spaces
                     go to det-gdb-inl-936.
       det-gdb-inl-935.
      *                              *---------------------------------*
      *                              * Se non c'e' dipendenza          *
      *                              *---------------------------------*
           string    " - Codice creditore : F/"
                                delimited by   size
                     p-edt      delimited by   spaces
                                          into w-sta-dis-bfc-cdf      .
           go to     det-gdb-inl-940.
       det-gdb-inl-936.
      *                              *---------------------------------*
      *                              * Se c'e' dipendenza              *
      *                              *---------------------------------*
           string    " - Codice creditore : F/"
                                delimited by   size
                     p-edt      delimited by   spaces
                     "-"        delimited by   size
                     rf-sfp-dpz-fnt
                                delimited by   spaces
                                          into w-sta-dis-bfc-cdf      .
           go to     det-gdb-inl-940.
       det-gdb-inl-940.
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     det-gdb-inl-999.
       det-gdb-inl-999.
           exit.

      *    *===========================================================*
