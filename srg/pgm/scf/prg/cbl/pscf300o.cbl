      *    *-----------------------------------------------------------*
       prn-sel-rec-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
      *              *-------------------------------------------------*
      *              * Test su modalita' e tipo valuta pagamento       *
      *              *-------------------------------------------------*
           if        rf-sfp-mod-pgf       =    15 and
                     rf-sfp-tvl-pgf       =    01
                     go to prn-sel-rec-100
           else      go to prn-sel-rec-900.
       prn-sel-rec-100.
      *              *-------------------------------------------------*
      *              * Selezione in funzione del tipo stampa           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo stampa      *
      *                  *---------------------------------------------*
           if        rr-tip-stp           =    01
                     go to prn-sel-rec-110
           else if   rr-tip-stp           =    02
                     go to prn-sel-rec-120
           else if   rr-tip-stp           =    03
                     go to prn-sel-rec-130.
       prn-sel-rec-110.
      *                  *---------------------------------------------*
      *                  * Tipo stampa : definitiva                    *
      *                  *---------------------------------------------*
           if        rf-sfp-fcs-uno       not  = zero
                     go to prn-sel-rec-900.
           go to     prn-sel-rec-200.
       prn-sel-rec-120.
      *                  *---------------------------------------------*
      *                  * Tipo stampa : di prova                      *
      *                  *---------------------------------------------*
           if        rf-sfp-fcs-uno       not  = zero
                     go to prn-sel-rec-900.
           go to     prn-sel-rec-200.
       prn-sel-rec-130.
      *                  *---------------------------------------------*
      *                  * Tipo stampa : ristampa                      *
      *                  *---------------------------------------------*
           if        rf-sfp-fcs-uno       not  > zero
                     go to prn-sel-rec-900.
           go to     prn-sel-rec-200.
       prn-sel-rec-200.
      *              *-------------------------------------------------*
      *              * Test su codice fornitore                        *
      *              *-------------------------------------------------*
           if        rr-cod-fnt           =    zero
                     go to prn-sel-rec-300.
           if        rf-sfp-cod-fnt       not  = rr-cod-fnt
                     go to prn-sel-rec-900.
       prn-sel-rec-300.
      *              *-------------------------------------------------*
      *              * Test su dipendenza fornitore                    *
      *              *-------------------------------------------------*
           if        rr-cod-fnt           =    zero
                     go to prn-sel-rec-400.
           if        rr-dpz-fnt           =    "*    "
                     go to prn-sel-rec-400.
           if        rf-sfp-dpz-fnt       not  = rr-dpz-fnt
                     go to prn-sel-rec-900.
       prn-sel-rec-400.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione delle scadenze appartenenti  *
      *              * al pagamento in corso di trattamento per veri-  *
      *              * ficare la data di scadenza                      *
      *              *-------------------------------------------------*
           move      zero                 to   w-sta-dis-num-scf      .
      *                  *---------------------------------------------*
      *                  * Start su archivio [sfs]                     *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "PGFSCF    "         to   f-key                  .
           move      rf-sfp-num-pgf       to   rf-sfs-num-pgf         .
           move      zero                 to   rf-sfs-num-scf         .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfs                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to prn-sel-rec-440.
       prn-sel-rec-420.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale record [sfs]            *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfs                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to prn-sel-rec-440.
      *                  *---------------------------------------------*
      *                  * Test sul massimo                            *
      *                  *---------------------------------------------*
           if        rf-sfs-num-pgf       not  = rf-sfp-num-pgf
                     go to prn-sel-rec-440.
      *                  *---------------------------------------------*
      *                  * Test su data scadenza minima                *
      *                  *---------------------------------------------*
           if        rf-sfs-dts-scf       <    rr-dsc-min
                     go to prn-sel-rec-420.
      *                  *---------------------------------------------*
      *                  * Test su data scadenza massima               *
      *                  *---------------------------------------------*
           if        rf-sfs-dts-scf       >    rr-dsc-max
                     go to prn-sel-rec-420.
      *                  *---------------------------------------------*
      *                  * Incremento numero scadenze incontrate       *
      *                  *---------------------------------------------*
           add       1                    to   w-sta-dis-num-scf      .
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura sequenziale record [sfs] *
      *                  *---------------------------------------------*
           go to     prn-sel-rec-420.
       prn-sel-rec-440.
      *                  *---------------------------------------------*
      *                  * Test su contatore scadenze trovate          *
      *                  *---------------------------------------------*
           if        w-sta-dis-num-scf    =    zero
                     go to prn-sel-rec-900.
       prn-sel-rec-800.
      *              *-------------------------------------------------*
      *              * Uscita per selezione superata                   *
      *              *-------------------------------------------------*
           go to     prn-sel-rec-999.
       prn-sel-rec-900.
      *              *-------------------------------------------------*
      *              * Uscita per selezione non superata               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita ad errore                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-prn-flg-sub      .
      *                  *---------------------------------------------*
      *                  * Rilascio record [sfp]                       *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfp                 .
       prn-sel-rec-999.
           exit.

