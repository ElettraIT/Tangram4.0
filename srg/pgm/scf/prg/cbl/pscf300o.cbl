      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-ric-flg      .
      *              *-------------------------------------------------*
      *              * Controllo su tipo stampa                        *
      *              *-------------------------------------------------*
           if        rr-tip-stp           not  = zero
                     go to tdo-ric-sel-100.
           move      "Manca la selezione del tipo stampa !              
      -              "               "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Controllo su codice ns. banca                   *
      *              *-------------------------------------------------*
           if        rr-cod-cbp           not  = spaces
                     go to tdo-ric-sel-200.
           move      "Manca il codice nostra banca !              
      -              "               "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Controllo su data scadenza minima e massima     *
      *              *-------------------------------------------------*
           if        rr-dsc-min           =    zero or
                     rr-dsc-max           =    zero
                     go to tdo-ric-sel-300.
           if        rr-dsc-max           not  < rr-dsc-min
                     go to tdo-ric-sel-300.
           move      "Data scadenza massima inferiore a quella minima   
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-300.
      *              *-------------------------------------------------*
      *              * Controllo su numero scadenza minimo e massimo   *
      *              *-------------------------------------------------*
           if        rr-npg-min           =    zero or
                     rr-npg-max           =    zero
                     go to tdo-ric-sel-400.
           if        rr-npg-max           not  < rr-npg-min
                     go to tdo-ric-sel-400.
           move      "Numero scadenza massimo inferiore a quello minimo 
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-400.
      *              *-------------------------------------------------*
      *              * Fine controlli                                  *
      *              *-------------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-900.
