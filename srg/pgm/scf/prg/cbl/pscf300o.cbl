      *    *===========================================================*
      *    * Find su archivio [sfp]                                    *
      *    *-----------------------------------------------------------*
       fnd-arc-sfp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di selezione               *
      *              *-------------------------------------------------*
           move      "N"                  to   w-fnd-arc-sfp-sel      .
      *              *-------------------------------------------------*
      *              * Se programma di interrogazione gia' attivo :    *
      *              * uscita senza alcuna azione                      *
      *              *-------------------------------------------------*
           move      "P?"                 to   s-ope                  .
           move      "pscf3010"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to fnd-arc-sfp-999.
       fnd-arc-sfp-025.
      *              *-------------------------------------------------*
      *              * Scrittura variabile di i.p.c. 'tip-int' per il  *
      *              * livello successivo per il tipo di interrogazio- *
      *              * ne                                              *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "tip-int"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      10                   to   s-car                  .
           move      "INTPGF    "         to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       fnd-arc-sfp-050.
      *              *-------------------------------------------------*
      *              * Scrittura variabile di i.p.c. 'mod-pgf' per il  *
      *              * livello successivo per la modalita' di pagamen- *
      *              * to                                              *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "mod-pgf"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "N"                  to   s-tip                  .
           move      02                   to   s-car                  .
           move      zero                 to   s-dec                  .
           move      spaces               to   s-sgn                  .
           move      w-fnd-arc-sfp-mod    to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       fnd-arc-sfp-075.
      *              *-------------------------------------------------*
      *              * Scrittura variabile di i.p.c. 'tvl-pgf' per il  *
      *              * livello successivo per il tipo valuta del paga- *
      *              * mento                                           *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "tvl-pgf"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "N"                  to   s-tip                  .
           move      02                   to   s-car                  .
           move      zero                 to   s-dec                  .
           move      spaces               to   s-sgn                  .
           move      w-fnd-arc-sfp-tvl    to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       fnd-arc-sfp-100.
      *              *-------------------------------------------------*
      *              * Scrittura variabile di i.p.c. 'sgl-vlt' per il  *
      *              * livello successivo per la sigla valuta del pa-  *
      *              * gamento                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se il tipo valuta non lo prevede : no       *
      *                  * scrittura                                   *
      *                  *---------------------------------------------*
           if        w-fnd-arc-sfp-tvl    not  = 02
                     go to fnd-arc-sfp-125.
      *                  *---------------------------------------------*
      *                  * Scrittura effettiva                         *
      *                  *---------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "sgl-vlt"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      03                   to   s-car                  .
           move      w-fnd-arc-sfp-vlt    to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       fnd-arc-sfp-125.
      *              *-------------------------------------------------*
      *              * Scrittura variabile di i.p.c. 'cbp-pgf' per il  *
      *              * livello successivo per il codice ns. cassa,     *
      *              * banca o c/c postale del pagamento               *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "cbp-pgf"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      10                   to   s-car                  .
           move      w-fnd-arc-sfp-cbp    to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       fnd-arc-sfp-150.
      *              *-------------------------------------------------*
      *              * Scrittura variabile di i.p.c. 'snx-sda' per il  *
      *              * livello successivo per il segnale Si/No solo    *
      *              * pagamenti da addebitare                         *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "snx-sda"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      01                   to   s-car                  .
           move      w-fnd-arc-sfp-sda    to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       fnd-arc-sfp-175.
      *              *-------------------------------------------------*
      *              * Scrittura variabile di i.p.c. 'snx-slc' per il  *
      *              * livello successivo per l'ammissibilita' del ta- *
      *              * sto Slct                                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se non ammesso : no scrittura               *
      *                  *---------------------------------------------*
           if        w-fnd-arc-sfp-sns    not  = "S"
                     go to fnd-arc-sfp-200.
      *                  *---------------------------------------------*
      *                  * Scrittura effettiva                         *
      *                  *---------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "snx-slc"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      01                   to   s-car                  .
           move      "S"                  to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       fnd-arc-sfp-200.
      *              *-------------------------------------------------*
      *              * Richiamo del programma di interrogazione        *
      *              *-------------------------------------------------*
           move      "pgm/scf/prg/obj/pscf3010"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
      *              *-------------------------------------------------*
      *              * Cancellazione del programma di interrogazione   *
      *              *-------------------------------------------------*
           cancel    s-pat                                            .
      *              *-------------------------------------------------*
      *              * Determinazione selezione avvenuta               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se non era ammessa la selezioone : uscita   *
      *                  *---------------------------------------------*
           if        w-fnd-arc-sfp-sns    not  = "S"
                     go to fnd-arc-sfp-999.
      *                  *---------------------------------------------*
      *                  * Lettura variabile di i.p.c. 'num-pgf' dal   *
      *                  * livello successivo per numero pagamento se- *
      *                  * lezionato                                   *
      *                  *---------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "num-pgf"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'esito della let-  *
      *                  * tura                                        *
      *                  *---------------------------------------------*
           if        s-ves                =    spaces
                     go to fnd-arc-sfp-225
           else      go to fnd-arc-sfp-250.
       fnd-arc-sfp-225.
      *                  *---------------------------------------------*
      *                  * Se variabile esistente                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di selezione avvenuta              *
      *                      *-----------------------------------------*
           move      spaces               to   w-fnd-arc-sfp-sel      .
      *                      *-----------------------------------------*
      *                      * Numero pagamento selezionato            *
      *                      *-----------------------------------------*
           move      s-num                to   w-fnd-arc-sfp-num      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     fnd-arc-sfp-999.
       fnd-arc-sfp-250.
      *                  *---------------------------------------------*
      *                  * Se variabile non esistente                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     fnd-arc-sfp-999.
       fnd-arc-sfp-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [cbp]                         *
      *    *-----------------------------------------------------------*
       let-arc-cbp-000.
      *              *-------------------------------------------------*
