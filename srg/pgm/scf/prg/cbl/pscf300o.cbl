           move      zero                 to   w-sta-dis-tip-ddr (1)  .
           move      zero                 to   w-sta-dis-dat-ddr (1)  .
           move      spaces               to   w-sta-dis-num-ddr (1)  .
           move      zero                 to   w-sta-dis-tip-ddr (2)  .
           move      zero                 to   w-sta-dis-dat-ddr (2)  .
           move      spaces               to   w-sta-dis-num-ddr (2)  .
       pre-are-wcc-100.
      *              *-------------------------------------------------*
      *              * Preparazione area editata per codice ABI        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Codice ABI per l'appoggio a zero : nes-  *
      *                  * sun editing, e si omette anche la prepara-  *
      *                  * zione per il codice CAB, sia per la deno-   *
      *                  * minazione che per la localita'              *
