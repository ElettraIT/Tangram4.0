      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Esecuzione sort in ordine ascendente oppure     *
      *              *  discendente                                    *
      *              *-------------------------------------------------*
           if        w-cnt-exe-rou-srt    =    "<"
                     go to exe-rou-srt-140
           else      go to exe-rou-srt-120.
       exe-rou-srt-120.
      *              *-------------------------------------------------*
      *              * Se ordine ascendente                            *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   int-srt-inp-000
                                          thru int-srt-inp-999
                     output procedure     is   qry-rou-pri-000
                                          thru qry-rou-pri-999        .
      *
           go to     exe-rou-srt-900.
       exe-rou-srt-140.
      *              *-------------------------------------------------*
      *              * Se ordine discendente                           *
      *              *-------------------------------------------------*
           sort      srt                  on   descending srt-key
                     input  procedure     is   int-srt-inp-000
                                          thru int-srt-inp-999
                     output procedure     is   qry-rou-pri-000
                                          thru qry-rou-pri-999        .
      *
           go to     exe-rou-srt-900.
       exe-rou-srt-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-rou-srt-999.
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       int-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
       int-srt-inp-010.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione delle richieste          *
      *              *-------------------------------------------------*
           if        rr-dat-car           not  = zero
                     go to int-srt-inp-030
           else if   rr-cod-fnt           not  = zero
                     go to int-srt-inp-050
           else      go to int-srt-inp-100.
       int-srt-inp-030.
      *              *-------------------------------------------------*
      *              * Start su archivio [xft] per data caricamento    *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CARNOM    "         to   f-key                  .
           move      rr-dat-car           to   rf-xft-dat-car         .
           move      spaces               to   rf-xft-nom-xml         .
           move      "pgm/scf/fls/ioc/obj/iofxft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-xft                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to int-srt-inp-900
           else      go to int-srt-inp-200.
       int-srt-inp-050.
      *              *-------------------------------------------------*
      *              * Start su archivio [xft] per fornitore           *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "FNTDDO    "         to   f-key                  .
           move      rr-cod-fnt           to   rf-xft-cod-fnt         .
           move      rr-dat-min           to   rf-xft-ddo-ftf         .
           move      spaces               to   rf-xft-nom-xml         .
           move      "pgm/scf/fls/ioc/obj/iofxft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-xft                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to int-srt-inp-900
           else      go to int-srt-inp-200.
       int-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Start su archivio [xft] per data documento      *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DDONOM    "         to   f-key                  .
           move      rr-dat-min           to   rf-xft-ddo-ftf         .
           move      spaces               to   rf-xft-nom-xml         .
           move      "pgm/scf/fls/ioc/obj/iofxft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-xft                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to int-srt-inp-900
           else      go to int-srt-inp-200.
       int-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [xft]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofxft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-xft                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to int-srt-inp-900.
       int-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione delle richieste      *
      *                  *---------------------------------------------*
           if        rr-dat-car           not  = zero
                     go to int-srt-inp-310
           else if   rr-cod-fnt           not  = zero
                     go to int-srt-inp-320
           else      go to int-srt-inp-330.
       int-srt-inp-310.
      *              *-------------------------------------------------*
      *              * Test su data caricamento                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        rf-xft-dat-car       not  = rr-dat-car
                     go to int-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A selezioni                                 *
      *                  *---------------------------------------------*
           go to     int-srt-inp-400.
       int-srt-inp-320.
      *              *-------------------------------------------------*
      *              * Test su codice fornitore                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        rf-xft-cod-fnt       not  = rr-cod-fnt or
                     rf-xft-ddo-ftf       >    rr-dat-max
                     go to int-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A selezioni                                 *
      *                  *---------------------------------------------*
           go to     int-srt-inp-400.
       int-srt-inp-330.
      *              *-------------------------------------------------*
      *              * Test su data documento                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        rf-xft-ddo-ftf       >    rr-dat-max
