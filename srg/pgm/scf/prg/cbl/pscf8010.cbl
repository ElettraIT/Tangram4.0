      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-xfz-des      .
       let-arc-xfz-999.
           exit.

      *    *===========================================================*
      *    * Determinazione descrizione per le tabelle                 *
      *    *-----------------------------------------------------------*
       det-des-tab-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore di output                *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-des-tab-des      .
       det-des-tab-050.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo tabella         *
      *              *-------------------------------------------------*
           if        w-det-des-tab-tab    =    "NAT"
                     go to det-des-tab-100
           else if   w-det-des-tab-tab    =    "MDP"
                     go to det-des-tab-200
           else if   w-det-des-tab-tab    =    "RDA"
                     go to det-des-tab-300
           else if   w-det-des-tab-tab    =    "CAS"
                     go to det-des-tab-400.
       det-des-tab-100.
      *              *=================================================*
      *              * Natura                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura descrizione                         *
      *                  *---------------------------------------------*
           move      05                   to   w-let-arc-xfz-tip      .
           move      w-det-des-tab-val    to   w-let-arc-xfz-cod      .
           perform   let-arc-xfz-000      thru let-arc-xfz-999        .
           move      w-let-arc-xfz-des    to   w-det-des-tab-des      .
      *                  *---------------------------------------------*
      *                  * Ad eventuale assemblaggio                   *
      *                  *---------------------------------------------*
           go to     det-des-tab-800.
       det-des-tab-200.
      *              *=================================================*
      *              * Modalita' di pagamento                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura descrizione                         *
      *                  *---------------------------------------------*
           move      03                   to   w-let-arc-xfz-tip      .
           move      w-det-des-tab-val    to   w-let-arc-xfz-cod      .
           perform   let-arc-xfz-000      thru let-arc-xfz-999        .
           move      w-let-arc-xfz-des    to   w-det-des-tab-des      .
      *                  *---------------------------------------------*
      *                  * Ad eventuale assemblaggio                   *
      *                  *---------------------------------------------*
           go to     det-des-tab-800.
       det-des-tab-300.
      *              *=================================================*
      *              * Tipo ritenuta                                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura descrizione                         *
      *                  *---------------------------------------------*
           move      06                   to   w-let-arc-xfz-tip      .
           move      w-det-des-tab-val    to   w-let-arc-xfz-cod      .
           perform   let-arc-xfz-000      thru let-arc-xfz-999        .
           move      w-let-arc-xfz-des    to   w-det-des-tab-des      .
      *                  *---------------------------------------------*
      *                  * Ad eventuale assemblaggio                   *
      *                  *---------------------------------------------*
           go to     det-des-tab-800.
       det-des-tab-400.
      *              *=================================================*
      *              * Tipo cassa                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura descrizione                         *
      *                  *---------------------------------------------*
           move      02                   to   w-let-arc-xfz-tip      .
           move      w-det-des-tab-val    to   w-let-arc-xfz-cod      .
           perform   let-arc-xfz-000      thru let-arc-xfz-999        .
           move      w-let-arc-xfz-des    to   w-det-des-tab-des      .
      *                  *---------------------------------------------*
      *                  * Ad eventuale assemblaggio                   *
      *                  *---------------------------------------------*
           go to     det-des-tab-800.
       det-des-tab-800.
      *              *=================================================*
      *              * Eventuale assemblaggio con il codice            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test sul tipo assemblaggio                  *
      *                  *---------------------------------------------*
           if        w-det-des-tab-tip    not  = "C"
                     go to det-des-tab-900.
      *                  *---------------------------------------------*
      *                  * Assemblaggio                                *
      *                  *---------------------------------------------*
           move      w-det-des-tab-lun    to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      w-det-des-tab-val    to   w-all-str-cat (1)      .
           move      "-"                  to   w-all-str-cat (2)      .
           move      w-det-des-tab-des    to   w-all-str-cat (3)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
           move      w-all-str-alf        to   w-det-des-tab-des      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     det-des-tab-900.
       det-des-tab-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-des-tab-999.
       det-des-tab-999.
           exit.

      *    *===========================================================*
      *    * Editing di una data in formato XML                        *
      *    *                                                           *
      *    * Valore in input : data in formato AAAA-MM-GG              *
      *    *                                                           *
      *    * Valore in output: data in formato GG/MM/AAAA              *
      *    *-----------------------------------------------------------*
       edt-dat-xml-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore di output                *
      *              *-------------------------------------------------*
           move      spaces               to   w-edt-dat-wrk-edo      .
      *              *-------------------------------------------------*
      *              * Test se valore in input a spaces                *
      *              *-------------------------------------------------*
           if        w-edt-dat-wrk-edi    =    spaces
                     go to edt-dat-xml-900.
       edt-dat-xml-100.
      *              *-------------------------------------------------*
      *              * Estrazione elementi                             *
      *              *-------------------------------------------------*
           move      w-edt-dat-wrk-edi    to   w-all-str-alf          .
           move      "-"                  to   w-all-str-del          .
           perform   all-str-ext-000      thru all-str-ext-999        .
           move      w-all-str-cat (1)    to   w-edt-dat-wrk-aaa      .
           move      w-all-str-cat (2)    to   w-edt-dat-wrk-mmm      .
           move      w-all-str-cat (3)    to   w-edt-dat-wrk-ggg      .
      *              *-------------------------------------------------*
      *              * Assemblaggio                                    *
      *              *-------------------------------------------------*
           move      10                   to   w-all-str-lun          .
           move      05                   to   w-all-str-num          .
           move      w-edt-dat-wrk-ggg    to   w-all-str-cat (1)      .
           move      "/"                  to   w-all-str-cat (2)      .
           move      w-edt-dat-wrk-mmm    to   w-all-str-cat (3)      .
           move      "/"                  to   w-all-str-cat (4)      .
           move      w-edt-dat-wrk-aaa    to   w-all-str-cat (5)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
           move      w-all-str-alf        to   w-edt-dat-wrk-edo      .
       edt-dat-xml-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     edt-dat-xml-999.
       edt-dat-xml-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [xfx]                         *
      *    *-----------------------------------------------------------*
       let-arc-xfx-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-xfx-flg      .
      *              *-------------------------------------------------*
      *              * Test se chiave vuota                            *
      *              *-------------------------------------------------*
           if        w-let-arc-xfx-fil    =    spaces or
                     w-let-arc-xfx-prg    =    zero
                     go to let-arc-xfx-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione                                 *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofxfx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-xfx                 .
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NOMXML"             to   f-key                  .
           move      w-let-arc-xfx-fil    to   rf-xfx-nom-xml         .
           move      w-let-arc-xfx-prg    to   rf-xfx-num-prg         .
           move      "pgm/scf/fls/ioc/obj/iofxfx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-xfx                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-xfx-400.
       let-arc-xfx-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-xfx-val-ele       to   w-let-arc-xfx-val      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-xfx-999.
       let-arc-xfx-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-xfx-flg      .
           move      all   "."            to   w-let-arc-xfx-val      .
           go to     let-arc-xfx-999.
       let-arc-xfx-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-xfx-val      .
       let-arc-xfx-999.
           exit.

      *    *===========================================================*
      *    * File relative di appoggio [rlt] : Open                    *
      *    *-----------------------------------------------------------*
       fil-rlt-opn-000.
      *              *-------------------------------------------------*
      *              * Preparazione area ausiliaria per controlli i-o  *
      *              * su [rlt]                                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * File name                                   *
      *                  *---------------------------------------------*
           move      "rlt "               to   f-rlt-nam              .
      *                  *---------------------------------------------*
      *                  * File pathname                               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Prelevamento di un pathname unico per   *
      *                      * files temporanei                        *
      *                      *-----------------------------------------*
           move      "UP"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Salvataggio pathname determinato        *
      *                      *-----------------------------------------*
           move      s-pat                to   f-rlt-pat              .
      *                  *---------------------------------------------*
      *                  * File status                                 *
      *                  *---------------------------------------------*
           move      "00"                 to   f-rlt-sts              .
       fil-rlt-opn-100.
      *              *-------------------------------------------------*
      *              * Preparazione seconda area ausiliaria per con-   *
      *              * trolli i-o su [rlt]                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Record number interessato dall'operazione   *
      *                  * di i-o                                      *
      *                  *---------------------------------------------*
           move      zero                 to   w-rlt-krn              .
      *                  *---------------------------------------------*
      *                  * Max record number memorizzato in assoluto   *
      *                  *---------------------------------------------*
           move      zero                 to   w-rlt-max              .
      *                  *---------------------------------------------*
      *                  * Contatore records per singolo documento     *
      *                  *---------------------------------------------*
           move      zero                 to   w-rlt-ctr              .
      *                  *---------------------------------------------*
      *                  * Indice per scansione records per singolo    *
      *                  * documento                                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-rlt-inx              .
       fil-rlt-opn-200.
      *              *-------------------------------------------------*
      *              * Open output [rlt]                               *
      *              *-------------------------------------------------*
           open      output rlt                                       .
      *              *-------------------------------------------------*
      *              * Close [rlt]                                     *
      *              *-------------------------------------------------*
           close     rlt                                              .
      *              *-------------------------------------------------*
      *              * Open i-o [rlt]                                  *
      *              *-------------------------------------------------*
           open      i-o    rlt                                       .
       fil-rlt-opn-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     fil-rlt-opn-999.
       fil-rlt-opn-999.
           exit.

      *    *===========================================================*
      *    * File relative di appoggio [rlt] : Close                   *
      *    *-----------------------------------------------------------*
       fil-rlt-cls-000.
      *              *-------------------------------------------------*
      *              * Se file non aperto : ad uscita                  *
      *              *-------------------------------------------------*
           if        f-rlt-pat            =    spaces
                     go to fil-rlt-cls-900.
       fil-rlt-cls-100.
      *              *-------------------------------------------------*
      *              * Close [rlt]                                     *
      *              *-------------------------------------------------*
           close     rlt                                              .
       fil-rlt-cls-200.
      *              *-------------------------------------------------*
      *              * Delete file [rlt]                               *
      *              *-------------------------------------------------*
           move      "PD"                 to   s-ope                  .
           move      f-rlt-pat            to   s-pat                  .
           move      "R"                  to   s-sts                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       fil-rlt-cls-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     fil-rlt-cls-999.
       fil-rlt-cls-999.
           exit.

      *    *===========================================================*
      *    * File relative di appoggio [rlt] : Put                     *
      *    *-----------------------------------------------------------*
       fil-rlt-put-000.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del valore del record num- *
      *              * ber                                             *
      *              *-------------------------------------------------*
           if        w-rlt-krn            not   > w-rlt-max
                     go to fil-rlt-put-300.
       fil-rlt-put-100.
      *              *-------------------------------------------------*
      *              * Aggiornamento del massimo record number finora  *
      *              * scritto                                         *
      *              *-------------------------------------------------*
           move      w-rlt-krn            to   w-rlt-max              .
       fil-rlt-put-200.
      *              *-------------------------------------------------*
      *              * Se il record number da scrivere e' maggiore del *
      *              * massimo finora scritto                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Scrittura record, se non valida : a ri-     *
      *                  * scrittura                                   *
      *                  *---------------------------------------------*
           write     rlt-rec invalid key
                             go to   fil-rlt-put-300.
           go to     fil-rlt-put-900.
       fil-rlt-put-300.
      *              *-------------------------------------------------*
      *              * Se il record number da scrivere non e' maggiore *
      *              * del massimo finora scritto                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Riscrittura record, se non valida : a       *
      *                  * scrittura                                   *
      *                  *---------------------------------------------*
           rewrite   rlt-rec invalid key
                             go to   fil-rlt-put-200.
           go to     fil-rlt-put-900.
       fil-rlt-put-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     fil-rlt-put-999.
       fil-rlt-put-999.
           exit.

      *    *===========================================================*
      *    * File relative di appoggio [rlt] : Get                     *
      *    *-----------------------------------------------------------*
       fil-rlt-get-000.
           read      rlt   with no lock
                           invalid key
                           go to   fil-rlt-get-999.
       fil-rlt-get-999.
           exit.

      *    *===========================================================*
      *    * File relative di appoggio [rlt] : New                     *
      *    *-----------------------------------------------------------*
       fil-rlt-new-000.
      *              *-------------------------------------------------*
      *              * Contatore records per singolo documento a zero  *
      *              *-------------------------------------------------*
           move      zero                 to   w-rlt-ctr              .
       fil-rlt-new-999.
           exit.

      *    *===========================================================*
      *    * File relative di appoggio [rlt] : Write                   *
      *    *-----------------------------------------------------------*
       fil-rlt-wrt-000.
      *              *-------------------------------------------------*
      *              * Incremento contatore records per singolo docu-  *
      *              * mento                                           *
      *              *-------------------------------------------------*
           add       1                    to   w-rlt-ctr              .
      *              *-------------------------------------------------*
      *              * Preparazione record number                      *
      *              *-------------------------------------------------*
           move      w-rlt-ctr            to   w-rlt-krn              .
      *              *-------------------------------------------------*
      *              * Scrittura effettiva                             *
      *              *-------------------------------------------------*
           perform   fil-rlt-put-000      thru fil-rlt-put-999        .
       fil-rlt-wrt-999.
           exit.

      *    *===========================================================*
      *    * File relative di appoggio [rlt] : Start                   *
      *    *-----------------------------------------------------------*
       fil-rlt-str-000.
      *              *-------------------------------------------------*
      *              * Preparazione status di uscita                   *
      *              *-------------------------------------------------*
           if        w-rlt-inx            <    w-rlt-ctr
                     move  e-not-err      to   w-rlt-sts
           else      move  e-end-fil      to   w-rlt-sts              .
       fil-rlt-str-999.
           exit.

      *    *===========================================================*
      *    * File relative di appoggio [rlt] : Read next               *
      *    *-----------------------------------------------------------*
       fil-rlt-nxt-000.
      *              *-------------------------------------------------*
      *              * Se fine file : uscita con errore                *
      *              *-------------------------------------------------*
           if        w-rlt-inx            not < w-rlt-ctr
                     move  e-end-fil      to   w-rlt-sts
                     go to fil-rlt-nxt-999.
      *              *-------------------------------------------------*
      *              * Incremento indice per scansione                 *
      *              *-------------------------------------------------*
           add       1                    to   w-rlt-inx              .
      *              *-------------------------------------------------*
      *              * Preparazione record number                      *
      *              *-------------------------------------------------*
           move      w-rlt-inx            to   w-rlt-krn              .
      *              *-------------------------------------------------*
      *              * Lettura effettiva                               *
      *              *-------------------------------------------------*
           perform   fil-rlt-get-000      thru fil-rlt-get-999        .
      *              *-------------------------------------------------*
      *              * Status di uscita ad Ok                          *
      *              *-------------------------------------------------*
           move      e-not-err            to   w-rlt-sts              .
       fil-rlt-nxt-999.
           exit.

