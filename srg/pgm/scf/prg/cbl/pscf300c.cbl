      *              * Se tipo funzionamento diverso da Inserimento,   *
      *              * oltre                                           *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-pre-vp1-300.
      *              *-------------------------------------------------*
      *              * Se testata gia' impostata : oltre               *
      *              *-------------------------------------------------*
           if        w-tes-fda-tes (1)    not  = spaces
                     go to acc-pre-vp1-300.
      *              *-------------------------------------------------*
      *              * Caricamento dei buffer scadenze fornitori       *
      *              *-------------------------------------------------*
           perform   car-buf-scf-000      thru car-buf-scf-999        .
      *              *-------------------------------------------------*
      *              * Se esito caricamento negativo : si esce forzan- *
      *              * do il tasto Up                                  *
      *              *-------------------------------------------------*
           if        w-car-buf-scf-flg    not  = spaces
                     move  "UP  "         to   v-key
                     go to acc-pre-vp1-999.
      *              *-------------------------------------------------*
      *              * Attivazione flag di impostazione pagina testata *
      *              *-------------------------------------------------*
           move      "#"                  to   w-tes-fda-tes (1)      .
       acc-pre-vp1-250.
      *              *-------------------------------------------------*
      *              * Se tipo operazione NON di Compensazione : oltre *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        not  = 1650
                     go to acc-pre-vp1-300.
      *              *-------------------------------------------------*
      *              * Determinazione buffer scadenze debitore di la-  *
      *              * voro                                            *
      *              *-------------------------------------------------*
           perform   det-buf-scf-000      thru det-buf-scf-999        .
      *              *-------------------------------------------------*
      *              * Se esito determinazione negativo : si esce for- *
      *              * zando il tasto Up                               *
      *              *-------------------------------------------------*
           if        w-det-buf-scf-flg    not  = spaces
                     move  "UP  "         to   v-key
                     go to acc-pre-vp1-999.
      *              *-------------------------------------------------*
      *              * Caricamento catena scadenze debitori            *
      *              *-------------------------------------------------*
           perform   car-cat-scf-000      thru car-cat-scf-999        .
      *              *-------------------------------------------------*
      *              * Se esito caricamento negativo : si esce forzan- *
      *              * do il tasto Up                                  *
      *              *-------------------------------------------------*
           if        w-car-cat-scf-flg    not  = spaces
                     move  "UP  "         to   v-key
                     go to acc-pre-vp1-999.
       acc-pre-vp1-300.
      *              *-------------------------------------------------*
      *              * Attivazione flag di impostazione pagina testata *
      *              *-------------------------------------------------*
__???_*    move      "#"                  to   w-tes-fda-pt1 (1)      .
      *              *-------------------------------------------------*
      *              * Se non esiste alcuna pagina attiva successiva   *
      *              * alla pagina attuale : uscita                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio numero pagina attuale           *
      *                  *---------------------------------------------*
           move      w-cnt-sts-imp-npt    to   w-cnt-sts-imp-svp      .
       acc-pre-vp1-400.
      *                  *---------------------------------------------*
      *                  * Se all'ultima pagina : ripristino pagina    *
      *                  * salvata ed uscita                           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-npt    not  < w-cnt-sts-imp-mpt
                     move  w-cnt-sts-imp-svp
                                          to   w-cnt-sts-imp-npt
                     go to acc-pre-vp1-999.
      *                  *---------------------------------------------*
      *                  * Incremento numero pagina                    *
      *                  *---------------------------------------------*
           add       1                    to   w-cnt-sts-imp-npt      .
      *                  *---------------------------------------------*
      *                  * Test se pagina da trattare                  *
      *                  *---------------------------------------------*
           perform   snp-tes-reg-000      thru snp-tes-reg-999        .
      *                  *---------------------------------------------*
      *                  * Se no : a re-incremento                     *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-snp    not  = spaces
                     go to acc-pre-vp1-400.
      *                  *---------------------------------------------*
      *                  * Se si : ripristino pagina salvata           *
      *                  *---------------------------------------------*
           move      w-cnt-sts-imp-svp    to   w-cnt-sts-imp-npt      .
       acc-pre-vp1-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazioni pagina testata nr. 1            *
      *    *-----------------------------------------------------------*
       cnt-imp-pt1-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-imp-pt1-flg      .
      *              *-------------------------------------------------*
      *              * Test se la pagina e' da trattare                *
      *              *                                                 *
      *              * N.B.: Il test seguente deve essere pari a quel- *
      *              *       lo contenuto in snp-tes-reg-000/999       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * La pagina e' sempre da trattare             *
      *                  *---------------------------------------------*
           go to     cnt-imp-pt1-100.
       cnt-imp-pt1-100.
      *              *-------------------------------------------------*
      *              * Codice fornitore                                *
      *              *-------------------------------------------------*
           if        w-tes-cod-fnt (1)    not  = zero
                     go to cnt-imp-pt1-120.
           move      "Manca il codice fornitore !                       
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-120.
      *              *-------------------------------------------------*
      *              * Inoltro pagamento                               *
      *              *-------------------------------------------------*
           if        w-tes-inl-pgf (1)    not  = zero and
                     w-tes-inl-pgf (1)    not  > w-exp-inl-pgf-num
                     go to cnt-imp-pt1-130.
           move      "Manca la definizione dell'inoltro pagamento !     
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-130.
           if        w-tes-inl-pgf (1)    not  = 03
                     go to cnt-imp-pt1-140.
           if        w-tes-dpz-fnt (1)    not  = spaces and
                     w-tes-dpz-fnt (1)    not  = "*   "
                     go to cnt-imp-pt1-140.
           move      "Inoltro pagamento incompatibile con dipendenza del
      -              " fornitore !   "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-140.
      *              *-------------------------------------------------*
      *              * Tipo pagamento richiesto                        *
      *              *-------------------------------------------------*
       cnt-imp-pt1-160.
      *              *-------------------------------------------------*
      *              * Codice ns. cassa, banca o c/c postale           *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        =    1650
                     go to cnt-imp-pt1-180.
           if        w-tes-cbp-pgf (1)    not  = spaces
                     go to cnt-imp-pt1-180.
           if        w-tes-tip-ope        =    1510 or
                     w-tes-tip-ope        =    1610
                     go to cnt-imp-pt1-162
           else if   w-tes-tip-ope        =    1520 or
                     w-tes-tip-ope        =    1530 or
                     w-tes-tip-ope        =    1620 or
                     w-tes-tip-ope        =    1630 or
                     w-tes-tip-ope        =    1730 or
                     w-tes-tip-ope        =    1731 or
                     w-tes-tip-ope        =    1750
                     go to cnt-imp-pt1-164
           else if   w-tes-tip-ope        =    1640 or
                     w-tes-tip-ope        =    1740
                     go to cnt-imp-pt1-166
           else      go to cnt-imp-pt1-180.
       cnt-imp-pt1-162.
           move      "Manca il codice nostra cassa !                    
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-164.
           move      "Manca il codice nostra banca !                    
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-166.
           move      "Manca il codice nostro c/c postale !              
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-180.
      *              *-------------------------------------------------*
      *              * Data documento per il pagamento                 *
      *              *-------------------------------------------------*
           if        w-tes-ndo-pgf (1)    =    spaces
                     go to cnt-imp-pt1-200.
           if        w-tes-ddo-pgf (1)    not  = zero
                     go to cnt-imp-pt1-200.
           move      "Manca la data documento per il pagamento !        
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-200.
      *              *-------------------------------------------------*
      *              * Numero documento per il pagamento               *
      *              *-------------------------------------------------*
           if        w-tes-ddo-pgf (1)    =    zero
                     go to cnt-imp-pt1-220.
           if        w-tes-ndo-pgf (1)    not  = spaces
                     go to cnt-imp-pt1-220.
           move      "Manca il numero documento !                       
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-220.
      *              *-------------------------------------------------*
      *              * Codice ABI, CAB e C/C bancario                  *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        =    1650
                     go to cnt-imp-pt1-240.
           if        w-tes-tip-ope        not  = 1730
                     go to cnt-imp-pt1-240.
           if        w-tes-abi-pgf (1)    not  = zero and
                     w-tes-cab-pgf (1)    not  = zero and
                     w-tes-ccc-pgf (1)    not  = spaces
                     go to cnt-imp-pt1-240.
           if        w-tes-abi-pgf (1)    =    zero
                     go to cnt-imp-pt1-222
           else if   w-tes-cab-pgf (1)    =    zero
                     go to cnt-imp-pt1-224
           else if   w-tes-ccc-pgf (1)    =    zero
                     go to cnt-imp-pt1-226.
       cnt-imp-pt1-222.
           move      "Manca il codice ABI per il pagamento !            
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-224.
           move      "Manca il codice CAB per il pagamento !            
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-226.
           move      "Manca il codice c/c bancario per il pagamento !   
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-240.
      *              *-------------------------------------------------*
      *              * Codice c/c postale per il pagamento             *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        not  = 1740
                     go to cnt-imp-pt1-260.
           if        w-tes-ccc-pgf (1)    not  = spaces
                     go to cnt-imp-pt1-260.
           move      "Manca il codice c/c postale per il pagamento !    
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-260.
      *              *-------------------------------------------------*
      *              * Sigla valuta                                    *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        not  = 1731
                     go to cnt-imp-pt1-280.
           if        w-tes-sgl-vlt (1)    not  = spaces
                     go to cnt-imp-pt1-280.
           move      "Manca il codice valuta per il pagamento !         
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-280.
      *              *-------------------------------------------------*
      *              * Codice banca estera per il pagamento            *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        not  = 1731
                     go to cnt-imp-pt1-300.
           if        w-tes-bef-pgf (1)    not  = zero
                     go to cnt-imp-pt1-300.
           move      "Manca il codice banca estera per il pagamento !   
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-300.
      *              *-------------------------------------------------*
      *              * Fine controlli                                  *
      *              *-------------------------------------------------*
           go to     cnt-imp-pt1-999.
       cnt-imp-pt1-900.
      *              *-------------------------------------------------*
      *              * Se controllo non superato                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di errore in uscita                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-imp-pt1-flg      .
       cnt-imp-pt1-999.
           exit.
           
      *    *===========================================================*
      *    * Caricamento dei buffer scadenze fornitori                 *
      *    *-----------------------------------------------------------*
       car-buf-scf-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-car-buf-scf-flg      .
      *              *-------------------------------------------------*
      *              * Azzeramento contatori scadenze scartate durante *
      *              * il caricamento dei buffer                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-car-buf-scf-css (01) .
           move      zero                 to   w-car-buf-scf-css (02) .
           move      zero                 to   w-car-buf-scf-css (03) .
           move      zero                 to   w-car-buf-scf-css (04) .
           move      zero                 to   w-car-buf-scf-css (05) .
           move      zero                 to   w-car-buf-scf-css (06) .
           move      zero                 to   w-car-buf-scf-css (07) .
      *              *-------------------------------------------------*
      *              * Azzeramento contatori numero elementi nei buf-  *
      *              * fer                                             *
      *              *-------------------------------------------------*
           move      zero                 to   w-bsu-num-ele          .
           move      zero                 to   w-bst-num-ele          .
      *              *-------------------------------------------------*
      *              * Azzeramento totale scadenze fornitore nei buf-  *
      *              * fer                                             *
      *              *-------------------------------------------------*
           move      zero                 to   w-bsu-tot-scf          .
           move      zero                 to   w-bst-tot-scf          .
      *              *-------------------------------------------------*
      *              * Messaggio di caricamento in esecuzione          *
      *              *-------------------------------------------------*
           move      " Selezione scadenze da includere nell'operazione i
      -              "n esecuzione   "    to   w-err-box-err-msg      .
           perform   msg-cnt-box-000      thru msg-cnt-box-999        .
       car-buf-scf-100.
      *              *-------------------------------------------------*
      *              * Sort scadenze fornitore                         *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   car-buf-scf-inp-000
                                          thru car-buf-scf-inp-999
                     output procedure     is   car-buf-scf-out-000
                                          thru car-buf-scf-out-999    .
       car-buf-scf-200.
      *              *-------------------------------------------------*
      *              * Cancellazione messaggio di caricamento in ese-  *
      *              * cuzione                                         *
      *              *-------------------------------------------------*
           move      spaces               to   w-err-box-err-msg      .
           perform   msg-cnt-box-000      thru msg-cnt-box-999        .
      *              *-------------------------------------------------*
      *              * Test se contatori scadenze scartate tutti a ze- *
      *              * ro e nessun elemento nei buffer                 *
      *              *-------------------------------------------------*
           if       (w-car-buf-scf-css (01)
                                          =    zero and
                     w-car-buf-scf-css (02)
                                          =    zero and
                     w-car-buf-scf-css (03)
                                          =    zero and
                     w-car-buf-scf-css (04)
                                          =    zero and
                     w-car-buf-scf-css (05)
                                          =    zero and
                     w-car-buf-scf-css (06)
                                          =    zero and
                     w-car-buf-scf-css (07)
                                          =    zero   ) and
                    (w-bsu-num-ele        =    zero   ) and
                    (w-bst-num-ele        =    zero   )
                     go to car-buf-scf-210
           else      go to car-buf-scf-300.
       car-buf-scf-210.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "Nessuna scadenza aperta per il fornitore !        
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di uscita ad errore                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-car-buf-scf-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     car-buf-scf-999.
       car-buf-scf-300.
      *              *-------------------------------------------------*
      *              * Se contatori scadenze scartate tutti a zero :   *
      *              * uscita                                          *
      *              *-------------------------------------------------*
           if        w-car-buf-scf-css (01)
                                          =    zero and
                     w-car-buf-scf-css (02)
                                          =    zero and
                     w-car-buf-scf-css (03)
                                          =    zero and
                     w-car-buf-scf-css (04)
                                          =    zero and
                     w-car-buf-scf-css (05)
                                          =    zero and
                     w-car-buf-scf-css (06)
                                          =    zero and
                     w-car-buf-scf-css (07)
                     go to car-buf-scf-999.
      *              *-------------------------------------------------*
      *              * Altrimenti, box di avviso per scadenze scartate *
      *              *-------------------------------------------------*
           perform   car-buf-scf-box-000  thru car-buf-scf-box-999    .
       car-buf-scf-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort in fase di caricamento scadenze  *
      *    * fornitore                                                 *
      *    *-----------------------------------------------------------*
       car-buf-scf-inp-000.
      *              *-------------------------------------------------*
      *              * Start su file [sfs]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "FNTPGF    "         to   f-key                  .
           move      w-tes-cod-fnt (1)    to   rf-sfs-cod-fnt         .
           move      zero                 to   rf-sfs-num-pgf         .
           move      zero                 to   rf-sfs-num-scf         .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfs                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to car-buf-scf-inp-900.
       car-buf-scf-inp-200.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [sfs]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfs                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to car-buf-scf-inp-900.
       car-buf-scf-inp-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-sfs-cod-fnt       not  = w-tes-cod-fnt (1) or
                     rf-sfs-num-pgf       not  = zero
                     go to car-buf-scf-inp-900.
       car-buf-scf-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni su record [sfs] bloccanti             *
      *              *-------------------------------------------------*
           perform   sel-sfs-blo-000      thru sel-sfs-blo-999        .
      *              *-------------------------------------------------*
      *              * Se selezione superata : oltre                   *
      *              *-------------------------------------------------*
           if        w-sel-sfs-blo-flg    =    zero
                     go to car-buf-scf-inp-420.
      *                  *---------------------------------------------*
      *                  * Determinazione indice contatore di errori   *
      *                  *                                             *
      *                  * N.B.: Solo se incompatibilita' nella sigla  *
      *                  *       valuta                                *
      *                  *---------------------------------------------*
           if        w-sel-sfs-nbl-flg    =    13
                     move  06             to   w-car-buf-scf-inx
           else      go to car-buf-scf-inp-410.
      *                  *---------------------------------------------*
      *                  * Incremento contatore di errori              *
      *                  *---------------------------------------------*
           if        w-car-buf-scf-css
                    (w-car-buf-scf-inx)   <    9999
                     add   1              to   w-car-buf-scf-css
                                              (w-car-buf-scf-inx)     .
       car-buf-scf-inp-410.
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     car-buf-scf-inp-200.
       car-buf-scf-inp-420.
      *              *-------------------------------------------------*
      *              * Selezioni su record [sfs] non bloccanti         *
      *              *-------------------------------------------------*
           perform   sel-sfs-nbl-000      thru sel-sfs-nbl-999        .
      *              *-------------------------------------------------*
      *              * Se selezione superata : oltre                   *
      *              *-------------------------------------------------*
           if        w-sel-sfs-nbl-flg    =    zero
                     go to car-buf-scf-inp-440.
      *                  *---------------------------------------------*
      *                  * Determinazione indice contatore di errori   *
      *                  *---------------------------------------------*
           if        w-sel-sfs-nbl-flg    =    11
                     move  01             to   w-car-buf-scf-inx
           else if   w-sel-sfs-nbl-flg    =    12
                     move  02             to   w-car-buf-scf-inx
           else if   w-sel-sfs-nbl-flg    =    13
                     move  03             to   w-car-buf-scf-inx
           else if   w-sel-sfs-nbl-flg    =    14
                     move  04             to   w-car-buf-scf-inx
           else if   w-sel-sfs-nbl-flg    =    15
                     move  05             to   w-car-buf-scf-inx
           else if   w-sel-sfs-nbl-flg    =    16
                     move  07             to   w-car-buf-scf-inx
           else if   w-sel-sfs-nbl-flg    =    17
                     move  07             to   w-car-buf-scf-inx
           else      go to car-buf-scf-inp-430.
      *                  *---------------------------------------------*
      *                  * Incremento contatore di errori              *
      *                  *---------------------------------------------*
           if        w-car-buf-scf-css
                    (w-car-buf-scf-inx)   <    9999
                     add   1              to   w-car-buf-scf-css
                                              (w-car-buf-scf-inx)     .
       car-buf-scf-inp-430.
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     car-buf-scf-inp-200.
       car-buf-scf-inp-440.
      *              *-------------------------------------------------*
      *              * Fine selezioni sul record                       *
      *              *-------------------------------------------------*
       car-buf-scf-inp-600.
      *              *-------------------------------------------------*
      *              * Composizione sort-record                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Chiave del sort                             *
      *                  *---------------------------------------------*
           if        rf-sfs-dts-scf       =    zero
                     move  w-tes-dat-reg  to   srt-dts-eff
           else      move  rf-sfs-dts-scf to   srt-dts-eff            .
           move      rf-sfs-num-scf       to   srt-num-scf            .
      *                  *---------------------------------------------*
      *                  * Dati del sort                               *
      *                  *---------------------------------------------*
           move      rf-sfs-tip-scf       to   srt-tip-scf            .
           move      rf-sfs-trs-scf       to   srt-trs-scf            .
           move      rf-sfs-tvl-scf       to   srt-tvl-scf            .
