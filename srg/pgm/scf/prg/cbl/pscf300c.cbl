      *    *===========================================================*
      *    * Accettazione campo : Selezione su tipi scadenza           *
      *    *-----------------------------------------------------------*
       acc-sel-tsf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se le impostazioni delle selezioni sono *
      *                      * gia' state tutte completate: no accet-  *
      *                      * tazione                                 *
      *                      *-----------------------------------------*
           if        w-tes-fda-sel (1)    not  = spaces
                     go to acc-sel-tsf-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-sel-tsf (1)    to   w-sav-sel-tsf          .
      *                  *---------------------------------------------*
      *                  * Preparazione work per l'accettazione del    *
      *                  * campo espanso selezione su tipi scadenza    *
      *                  *---------------------------------------------*
           perform   pex-sel-tsf-000      thru pex-sel-tsf-999        .
      *                  *---------------------------------------------*
      *                  * Preparazione default                        *
      *                  *---------------------------------------------*
           if        w-tes-sel-tsf (1)    =    zero
                     if    w-exp-sel-tsf-num
                                          not  < 02
                           move  02       to   w-tes-sel-tsf (1)
                     else  move  01       to   w-tes-sel-tsf (1)      .
       acc-sel-tsf-075.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del numero di ele-   *
      *                  * menti che compongono la tabella delle pos-  *
      *                  * sibili scelte alternative                   *
      *                  *---------------------------------------------*
           if        w-exp-sel-tsf-num    =    zero
                     go to acc-sel-tsf-080
           else if   w-exp-sel-tsf-num    =    1
                     go to acc-sel-tsf-085
           else      go to acc-sel-tsf-090.
       acc-sel-tsf-080.
      *                  *---------------------------------------------*
      *                  * Se zero scelte possibili                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione del valore da accettare *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-sel-tsf (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione del valore              *
      *                      *-----------------------------------------*
           perform   vis-sel-tsf-000      thru vis-sel-tsf-999        .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     acc-sel-tsf-999.
       acc-sel-tsf-085.
      *                  *---------------------------------------------*
      *                  * Se una sola scelta possibile                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Forzatura del valore da accettare       *
      *                      *-----------------------------------------*
           move      w-exp-sel-tsf-vel (1)
                                          to   w-tes-sel-tsf (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione del valore              *
      *                      *-----------------------------------------*
           perform   vis-sel-tsf-000      thru vis-sel-tsf-999        .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     acc-sel-tsf-999.
       acc-sel-tsf-090.
      *                  *---------------------------------------------*
      *                  * Se piu' di una scelta possibile             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se Next Screen da campi precedenti      *
      *                      *-----------------------------------------*
           if        v-key                =    "NXSC"
                     perform vis-sel-tsf-000
                                          thru vis-sel-tsf-999
                     go to acc-sel-tsf-400.
      *                      *-----------------------------------------*
      *                      * Ad accettazione                         *
      *                      *-----------------------------------------*
           go to     acc-sel-tsf-100.
       acc-sel-tsf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazioni generali                       *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-sel-tsf-lun    to   v-car                  .
           move      w-exp-sel-tsf-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-sel-tsf-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      09                   to   v-lin                  .
           move      30                   to   v-pos                  .
       acc-sel-tsf-105.
      *                  *---------------------------------------------*
      *                  * Preparazione indice corrispondente al valo- *
      *                  * re attuale                                  *
      *                  *---------------------------------------------*
           if        w-tes-sel-tsf (1)    =    zero
                     move  zero           to   v-num
                     go to acc-sel-tsf-125.
       acc-sel-tsf-110.
           move      zero                 to   w-exp-sel-tsf-inx      .
       acc-sel-tsf-115.
           add       1                    to   w-exp-sel-tsf-inx      .
           if        w-exp-sel-tsf-inx    >    w-exp-sel-tsf-num
                     move  zero           to   v-num
                     go to acc-sel-tsf-125.
           if        w-exp-sel-tsf-vel
                    (w-exp-sel-tsf-inx)   =    w-tes-sel-tsf (1)
                     move  w-exp-sel-tsf-inx
                                          to   v-num
                     go to acc-sel-tsf-125
           else      go to acc-sel-tsf-115.
       acc-sel-tsf-125.
      *                  *---------------------------------------------*
      *                  * Accettazione                                *
      *                  *---------------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-sel-tsf-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-sel-tsf-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-sel-tsf-999.
