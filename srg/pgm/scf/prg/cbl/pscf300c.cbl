      *                  *---------------------------------------------*
           move      zero                 to   w-vis-sel-tpm-ctr      .
       vis-sel-tpm-100.
           add       1                    to   w-vis-sel-tpm-ctr      .
           if        w-vis-sel-tpm-ctr    >    7
                     go to vis-sel-tpm-200.
      *                      *-----------------------------------------*
      *                      * Progressivo mensile                     *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vlt (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "G"                  to   v-edm                  .
           add       12
                     w-vis-sel-tpm-ctr  giving v-lin                  .
           move      65                   to   v-pos                  .
           move      w-tes-sel-tpm-prg
                    (1                , 
                     w-vis-sel-tpm-ctr,
                     w-vis-sel-tpm-inx)   to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
