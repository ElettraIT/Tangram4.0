      *    *===========================================================*
      *    * Lettura registrazione pre-esistente                       *
      *    *-----------------------------------------------------------*
       rou-let-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-rou-let-reg      .
      *              *-------------------------------------------------*
      *              * Normalizzazione flags di preparazioni defaults  *
      *              * gia' eseguite                                   *
      *              *-------------------------------------------------*
           move      spaces               to   w-fpd-acc-abi-pgf      .
           move      spaces               to   w-fpd-acc-ccc-pgf      .
           move      spaces               to   w-fpd-acc-sgl-vlt      .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del numero pagamento impo- *
      *              * stato                                           *
      *              *-------------------------------------------------*
           if        w-tes-num-pgf        =    zero
                     go to rou-let-reg-100
           else      go to rou-let-reg-300.
       rou-let-reg-100.
      *              *-------------------------------------------------*
      *              * Se numero pagamento a zero : Inserimento        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo funzionamento : Inserimento            *
      *                  *---------------------------------------------*
           move      "I"                  to   w-cnt-mfu-tip-fun      .
       rou-let-reg-120.
      *                  *---------------------------------------------*
      *                  * Test su dati relativi alla registrazione    *
      *                  * contabile                                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test si/no aggiornamenti contabili da   *
      *                      * gestione scadenze fornitori per il mo-  *
      *                      * vimento di pagamento                    *
      *                      *-----------------------------------------*
           perform   cge-scf-pgf-snx-000  thru cge-scf-pgf-snx-999    .
      *                          *-------------------------------------*
      *                          * Se no aggiornamento : nessun con-   *
      *                          * trollo                              *
      *                          *-------------------------------------*
           if        w-cge-scf-pgf-snx    =    "N"
                     go to rou-let-reg-180.
      *                          *-------------------------------------*
      *                          * Confronto tra la data di registra-  *
      *                          * zione del movimento e la data di    *
      *                          * registrazione di contabilita' ge-   *
      *                          * nerale minima : se inferiore si e-  *
      *                          * sce con un messaggio di errore      *
      *                          *-------------------------------------*
           if        w-tes-dat-reg        not  < w-prs-scf-drc-min
                     go to rou-let-reg-140.
           move      "Data di registrazione inferiore al minimo consenti
      -              "to             "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           move      "#"                  to   w-cnt-rou-let-reg      .
           go to     rou-let-reg-999.
       rou-let-reg-140.
      *                          *-------------------------------------*
      *                          * Controllo su sottoconto contabile   *
      *                          * per abbuoni passivi associato al    *
      *                          * tipo movimento                      *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se codice sottoconto a zero     *
      *                              *---------------------------------*
           if        w-top-stc-cge
                    (w-top-ele-inx)       not  = zero
                     go to rou-let-reg-160.
      *                              *---------------------------------*
      *                              * Emissione messaggio             *
      *                              *---------------------------------*
           move      "Attenzione : Manca il sottoconto contabile per abb
      -              "uoni passivi   "    to   w-err-box-err-msg      .
           move      "             associato al tipo movimento di pagame
      -              "nto.           "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           move      "#"                  to   w-cnt-rou-let-reg      .
           go to     rou-let-reg-999.
       rou-let-reg-160.
      *                          *-------------------------------------*
      *                          * Controllo su sottoconto contabile   *
      *                          * per abbuoni attivi associato al     *
      *                          * tipo movimento                      *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se codice sottoconto a zero     *
      *                              *---------------------------------*
           if        w-top-ctp-cge
                    (w-top-ele-inx)       not  = zero
                     go to rou-let-reg-180.
      *                              *---------------------------------*
      *                              * Emissione messaggio             *
      *                              *---------------------------------*
           move      "Attenzione : Manca il sottoconto contabile per abb
      -              "uoni attivi    "    to   w-err-box-err-msg      .
           move      "             associato al tipo movimento di pagame
      -              "nto.           "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           move      "#"                  to   w-cnt-rou-let-reg      .
           go to     rou-let-reg-999.
       rou-let-reg-180.
      *                  *---------------------------------------------*
      *                  * Altri valori automatici inerenti l'inseri-  *
      *                  * mento relativo al tipo pagamento            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Modalita' di pagamento                  *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        =    1510
                     move  01             to   w-tes-mod-pgf (1)
           else if   w-tes-tip-ope        =    1520
                     move  02             to   w-tes-mod-pgf (1)
           else if   w-tes-tip-ope        =    1530
                     move  03             to   w-tes-mod-pgf (1)
      *
           else if   w-tes-tip-ope        =    1610
                     move  01             to   w-tes-mod-pgf (1)
           else if   w-tes-tip-ope        =    1620
                     move  02             to   w-tes-mod-pgf (1)
           else if   w-tes-tip-ope        =    1630
                     move  03             to   w-tes-mod-pgf (1)
           else if   w-tes-tip-ope        =    1640
                     move  04             to   w-tes-mod-pgf (1)
           else if   w-tes-tip-ope        =    1730 or
                     w-tes-tip-ope        =    1731
                     move  13             to   w-tes-mod-pgf (1)
           else if   w-tes-tip-ope        =    1740
                     move  14             to   w-tes-mod-pgf (1)
           else if   w-tes-tip-ope        =    1750
                     move  15             to   w-tes-mod-pgf (1)
           else      move  zero           to   w-tes-mod-pgf (1)      .
      *                      *-----------------------------------------*
      *                      * Tipo valuta per il pagamento            *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        =    1731
                     move  02             to   w-tes-tvl-pgf (1)
           else      move  01             to   w-tes-tvl-pgf (1)      .
      *                      *-----------------------------------------*
      *                      * Sigla, numero decimali e tipo di cambio *
      *                      * per la valuta                           *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        not  = 1731
                     move  c-sgl          to   w-tes-sgl-vlt (1)
                     move  c-dec          to   w-tes-dec-vlt (1)
                     move  c-tdc          to   w-tes-tdc-vlt (1)      .
       rou-let-reg-200.
      *                      *-----------------------------------------*
      *                      * Preparazione tabella progressivi mensi- *
      *                      * li                                      *
      *                      *-----------------------------------------*
           move      w-tes-dat-reg        to   s-dat                  .
           move      s-mes                to   w-rou-let-reg-wms      .
           move      s-saa                to   w-rou-let-reg-wsa      .
      *                          *-------------------------------------*
      *                          * Data di registrazione rientra nel   *
      *                          * mese nr. 5                          *
      *                          *-------------------------------------*
           move      w-rou-let-reg-wms    to   w-tes-sel-tpm-mes
                                              (1, 5)                  .
           move      w-rou-let-reg-wsa    to   w-tes-sel-tpm-saa
                                              (1, 5)                  .
      *                          *-------------------------------------*
      *                          * Ciclo per i 4 mesi precedenti       *
      *                          *-------------------------------------*
           move      5                    to   w-rou-let-reg-inx      .
       rou-let-reg-202.
           subtract  1                    from w-rou-let-reg-inx      .
           if        w-rou-let-reg-inx    =    zero
                     go to rou-let-reg-204.
           subtract  1                    from w-rou-let-reg-wms      .
           if        w-rou-let-reg-wms    =    zero
                     move  12             to   w-rou-let-reg-wms
                     subtract 1           from w-rou-let-reg-wsa      .
           move      w-rou-let-reg-wms    to   w-tes-sel-tpm-mes
                                              (1,
                                               w-rou-let-reg-inx)     .
           move      w-rou-let-reg-wsa    to   w-tes-sel-tpm-saa
                                              (1,
                                               w-rou-let-reg-inx)     .
           go to     rou-let-reg-202.
       rou-let-reg-204.
      *                          *-------------------------------------*
      *                          * Ciclo per i 2 mesi successivi       *
      *                          *-------------------------------------*
           move      w-tes-dat-reg        to   s-dat                  .
           move      s-mes                to   w-rou-let-reg-wms      .
           move      s-saa                to   w-rou-let-reg-wsa      .
           move      5                    to   w-rou-let-reg-inx      .
       rou-let-reg-206.
           add       1                    to   w-rou-let-reg-inx      .
           if        w-rou-let-reg-inx    >    7
                     go to rou-let-reg-250.
           add       1                    to   w-rou-let-reg-wms      .
           if        w-rou-let-reg-wms    >    12
                     move 1               to   w-rou-let-reg-wms
                     add  1               to   w-rou-let-reg-wsa      .
           move      w-rou-let-reg-wms    to   w-tes-sel-tpm-mes
                                              (1,
                                               w-rou-let-reg-inx)     .
           move      w-rou-let-reg-wsa    to   w-tes-sel-tpm-saa
                                              (1,
                                               w-rou-let-reg-inx)     .
           go to     rou-let-reg-206.
       rou-let-reg-250.
      *                  *---------------------------------------------*
      *                  * Assestamento flags per visualizzazione te-  *
      *                  * stata                                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Assestamento flags di impostazione pa-  *
      *                      * gina testata nr. 2                      *
      *                      *-----------------------------------------*
           move      "#"                  to   w-cnt-sts-imp-ptx (2)  .
      *                      *-----------------------------------------*
      *                      * Assestamento flags di ingresso in pa-   *
      *                      * gina testata nr. 2                      *
      *                      *-----------------------------------------*
           move      "#"                  to   w-cnt-sts-ing-ptx (2)  .
      *                  *---------------------------------------------*
      *                  * Assestamento flags per visualizzazione pie- *
      *                  * de                                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Assestamento flags di impostazione pa-  *
      *                      * gine piede                              *
      *                      *-----------------------------------------*
           move      all  "#"             to   w-cnt-sts-imp-ppi      .
      *                      *-----------------------------------------*
      *                      * Assesatmento flags di ingresso in pa-   *
      *                      * gine piede                              *
      *                      *-----------------------------------------*
           move      all  "#"             to   w-cnt-sts-ing-ppi      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     rou-let-reg-999.
       rou-let-reg-300.
      *              *-------------------------------------------------*
      *              * Se numero pagamento diverso da zero             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura record [sfp]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPGF    "         to   f-key                  .
           move      w-tes-num-pgf        to   rf-sfp-num-pgf         .
           move      "pgm/scf/fls/ioc/obj/iofsfp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfp                 .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'esito della let-  *
      *                  * tura                                        *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to rou-let-reg-350.
       rou-let-reg-325.
      *                  *---------------------------------------------*
      *                  * Se record non esistente                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Numero operazione non esistente in archivio       
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Status di uscita ad errore              *
      *                      *-----------------------------------------*
           move      "#"                  to   w-cnt-rou-let-reg      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rou-let-reg-999.
       rou-let-reg-350.
      *                  *---------------------------------------------*
      *                  * Se record esistente                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo funzionamento : Modifica           *
      *                      *-----------------------------------------*
           move      "M"                  to   w-cnt-mfu-tip-fun      .
      *                      *-----------------------------------------*
      *                      * Completamento valori chiave             *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Data registrazione                  *
      *                          *-------------------------------------*
           move      rf-sfp-dtr-pgf       to   w-tes-dat-reg          .
           perform   vis-dat-reg-000      thru vis-dat-reg-999        .
      *                      *-----------------------------------------*
      *                      * Attivazione flags di accettazione       *
      *                      *-----------------------------------------*
           move      "#"                  to   w-tes-fda-tes (1)      .
           move      "#"                  to   w-tes-fda-sel (1)      .
           move      "#"                  to   w-tes-fda-sdc (1)      .
           move      "#"                  to   w-tes-fda-pie (1)      .
       rou-let-reg-400.
      *                      *-----------------------------------------*
      *                      * Determinazione valori attuali testata   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Valori contenuti direttamente in    *
      *                          * record [sfp]                        *
      *                          *-------------------------------------*
           move      rf-sfp-drc-pgf       to   w-tes-drc-pgf (1)      .
           move      rf-sfp-npc-pgf       to   w-tes-npc-pgf (1)      .
           move      rf-sfp-mod-pgf       to   w-tes-mod-pgf (1)      .
           move      rf-sfp-tvl-pgf       to   w-tes-tvl-pgf (1)      .
           move      rf-sfp-cod-fnt       to   w-tes-cod-fnt (1)      .
           move      rf-sfp-dpz-fnt       to   w-tes-dpz-fnt (1)      .
           move      rf-sfp-inl-pgf       to   w-tes-inl-pgf (1)      .
           move      rf-sfp-cbp-pgf       to   w-tes-cbp-pgf (1)      .
           move      rf-sfp-tip-pgf       to   w-tes-tip-pgf (1)      .
           move      rf-sfp-abi-pgf       to   w-tes-abi-pgf (1)      .
           move      rf-sfp-cab-pgf       to   w-tes-cab-pgf (1)      .
           move      rf-sfp-bef-pgf       to   w-tes-bef-pgf (1)      .
           move      rf-sfp-ccc-pgf       to   w-tes-ccc-pgf (1)      .
