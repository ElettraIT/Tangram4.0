           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      49                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Periodo da selezionare dal :          al         "
