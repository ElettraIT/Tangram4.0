                     w-tes-tip-ope        =    1520 or
                     w-tes-tip-ope        =    1610 or
                     w-tes-tip-ope        =    1620
                     go to pex-sel-tsf-100
           else if   w-tes-tip-ope        =    1530 or
                     w-tes-tip-ope        =    1630
                     go to pex-sel-tsf-150
           else if   w-tes-tip-ope        =    1730
                     go to pex-sel-tsf-200
           else if   w-tes-tip-ope        =    1731
                     go to pex-sel-tsf-300
           else if   w-tes-tip-ope        =    1640 or
                     w-tes-tip-ope        =    1740
