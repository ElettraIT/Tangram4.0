           if        w-cnt-cor-tip-agg    =    "+"
                     go to pos-rig-cor-300
           else if   w-cnt-cor-tip-agg    =    "-"
                     go to pos-rig-cor-600
           else      go to pos-rig-cor-999.
       pos-rig-cor-300.
      *              *-------------------------------------------------*
      *              * Se tipo aggiornamento '+'                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se non e' una riga di tipo New non si ese-  *
      *                  * gue alcun aggiornamento                     *
      *                  *---------------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to pos-rig-cor-350.
      *                  *---------------------------------------------*
      *                  * Aggiornamento in piu' per il totale righe   *
      *                  * scadenze selezionate                        *
      *                  *---------------------------------------------*
           add       w-rig-imp-scf (1)    to   w-tes-tot-rss (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione totale righe selezionate    *
      *                  *---------------------------------------------*
           perform   vis-tot-rss-000      thru vis-tot-rss-999        .
       pos-rig-cor-350.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     pos-rig-cor-999.
       pos-rig-cor-600.
      *              *-------------------------------------------------*
      *              * Se tipo aggiornamento '-'                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Aggiornamento in piu' per il totale righe   *
      *                  * scadenze selezionate                        *
      *                  *---------------------------------------------*
           subtract  w-rig-imp-scf (1)    from w-tes-tot-rss (1)      .
