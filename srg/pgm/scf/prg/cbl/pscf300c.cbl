      *                      * pari al totale righe                    *
      *                      *-----------------------------------------*
           move      w-tes-tot-rss (1)    to   w-pie-tot-sfs (1)      .
      *                      *-----------------------------------------*
      *                      * Importo pagamento pari al totale sca-   *
      *                      * denze selezionate                       *
      *                      *-----------------------------------------*
           move      w-pie-tot-sfs (1)    to   w-pie-imp-pgf (1)      .
       cnt-tdo-nok-100.
      *                  *---------------------------------------------*
      *                  * Controllo su : Importo pagamento            *
      *                  *---------------------------------------------*
           if        w-pie-imp-pgf (1)    not  = zero
                     go to cnt-tdo-nok-110.
           move      "Manca l'importo del pagamento                     
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-110.
           if        w-pie-imp-pgf (1)    >    zero
                     go to cnt-tdo-nok-120.
           if        w-tes-tip-ope        =    1510 or
                     w-tes-tip-ope        =    1520 or
                     w-tes-tip-ope        =    1530
                     go to cnt-tdo-nok-120.
      *
           move      "L'importo del pagamento non puo' essere negativo  
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-120.
      *                  *---------------------------------------------*
      *                  * Controllo su : Importo spese addebitate     *
      *                  *---------------------------------------------*
           if        w-tes-tip-ope        not  = 1630 and
                     w-tes-tip-ope        not  = 1640
                     go to cnt-tdo-nok-140.
           if        w-pie-spe-pgf (1)    not  < zero
                     go to cnt-tdo-nok-140.
           move      "L'importo delle spese addebitate non puo' essere n
      -              "egativo     "       to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-140.
      *                  *---------------------------------------------*
      *                  * Controllo su : Acconto o Saldo per il paga- *
      *                  *                mento                        *
      *                  *---------------------------------------------*
           if        w-pie-aos-pgf (1)    not  = zero
                     go to cnt-tdo-nok-160.
           if        w-pie-tot-sfs (1)    =    w-pie-imp-pgf (1)
                     go to cnt-tdo-nok-160
           else if   w-pie-tot-sfs (1)    >    zero          and
                     w-pie-imp-pgf (1)    <    w-pie-tot-sfs (1)
                     go to cnt-tdo-nok-150
           else if   w-pie-tot-sfs (1)    <    zero          and
                     w-pie-imp-pgf (1)    >    w-pie-tot-sfs (1)
                     go to cnt-tdo-nok-150
           else      go to cnt-tdo-nok-160.
       cnt-tdo-nok-150.
           move      "Manca il segnale di acconto/saldo per il pagamento
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-160.
      *                  *---------------------------------------------*
      *                  * Controllo su : Si/No registrazione nuova    *
      *                  *                scadenza a fronte del paga-  *
      *                  *                mento                        *
      *                  *---------------------------------------------*
       cnt-tdo-nok-180.
      *                  *---------------------------------------------*
      *                  * Controllo su : Tipo nuova scadenza a fronte *
      *                  *                del pagamento                *
      *                  *---------------------------------------------*
           if        w-pie-rns-pgf (1)    =    01
                     go to cnt-tdo-nok-190
           else      go to cnt-tdo-nok-200.
       cnt-tdo-nok-190.
           if        w-pie-rns-pgf (1)    not  = zero
                     go to cnt-tdo-nok-200.
           move      "Manca il tipo della nuova scadenza a fronte della 
      -              "differenza     "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-200.
      *              *-------------------------------------------------*
      *              * Controllo di congruenza per pagamento in conto  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da eseguire                         *
      *                  *---------------------------------------------*
           if        w-pie-aos-pgf (1)    not  = 02
                     go to cnt-tdo-nok-300.
           if        w-pie-rns-pgf (1)    not  = 01
                     go to cnt-tdo-nok-300.
      *                  *---------------------------------------------*
      *                  * Salvataggio area w-rig                      *
      *                  *---------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *                  *---------------------------------------------*
      *                  * Salvataggio area catena                     *
      *                  *---------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *                  *---------------------------------------------*
      *                  * Lettura ultima scadenza selezionata         *
      *                  *---------------------------------------------*
           move      "RD"                 to   w-cat-rig-ope          .
           move      w-cat-rig-max        to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Movimento da buffer catena movimenti a work *
      *                  * di lavoro                                   *
      *                  *---------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione importo scadenza            *
      *                  *---------------------------------------------*
           move      w-rig-imp-scf (1)    to   w-cnt-tdo-nok-i01      .
      *                  *---------------------------------------------*
      *                  * Ripristino area w-rig                       *
      *                  *---------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *                  *---------------------------------------------*
      *                  * Ripristino area catena                      *
      *                  *---------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
      *                  *---------------------------------------------*
      *                  * Determinazione differenza tra scadenze se-  *
      *                  * lezionate e importo pagato                  *
      *                  *---------------------------------------------*
           subtract  w-pie-imp-pgf (1)    from w-pie-tot-sfs (1)
                                        giving w-cnt-tdo-nok-i02      .
      *                  *---------------------------------------------*
      *                  * Test che la differenza appena calcolata sia *
      *                  * inferiore all'importo della scadenza        *
      *                  *---------------------------------------------*
           if        w-cnt-tdo-nok-i02    <    w-cnt-tdo-nok-i01
                     go to cnt-tdo-nok-300.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore senza blocco            *
      *                  *---------------------------------------------*
           move      "La differenza tra quanto pagato in conto e la somm
      -              "a delle scaden-"    to   w-err-box-err-msg      .
           move      "ze selezionate e' superiore all'importo dell'ultim
      -              "a scadenza.    "    to   w-err-box-err-m02      .
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       cnt-tdo-nok-300.
      *              *-------------------------------------------------*
      *              * Controllo su registrazione contabile            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se registrazione contabile da eseguire *
      *                  *---------------------------------------------*
           perform   cge-scf-pgf-snx-000  thru cge-scf-pgf-snx-999    .
           if        w-cge-scf-pgf-snx    not  = "S"
                     go to cnt-tdo-nok-500.
      *                  *---------------------------------------------*
      *                  * Determinazione tabella righe movimento con- *
      *                  * tabile                                      *
      *                  *---------------------------------------------*
           perform   det-mov-cge-000      thru det-mov-cge-999        .
      *                  *---------------------------------------------*
      *                  * Test su flag di aggiornamento contabile da  *
      *                  * eseguire                                    *
      *                  *---------------------------------------------*
           if        w-mov-cge-flg-nag    =    spaces
                     go to cnt-tdo-nok-500.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Attenzione : In seguito alle anomalie riscontrate, 
      -              " la registra-  "    to   w-err-box-err-msg      .
           move      "             zione contabile non puo' aver luogo. 
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                      *-----------------------------------------*
      *                      * A errore                                *
      *                      *-----------------------------------------*
           go to     cnt-tdo-nok-950.
       cnt-tdo-nok-500.
      *              *-------------------------------------------------*
      *              * Fine controlli, normalizzazioni                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Segnale di acconto o saldo per il pagamento *
      *                  *---------------------------------------------*
           if        w-pie-tot-sfs (1)    =    w-pie-imp-pgf (1)
                     go to cnt-tdo-nok-510
           else if   w-pie-tot-sfs (1)    >    zero          and
                     w-pie-imp-pgf (1)    <    w-pie-tot-sfs (1)
                     go to cnt-tdo-nok-520
           else if   w-pie-tot-sfs (1)    <    zero          and
                     w-pie-imp-pgf (1)    >    w-pie-tot-sfs (1)
                     go to cnt-tdo-nok-520
           else      go to cnt-tdo-nok-510.
       cnt-tdo-nok-510.
           move      zero                 to   w-pie-aos-pgf (1)      .
       cnt-tdo-nok-520.
      *                  *---------------------------------------------*
      *                  * Segnale di registrazione nuova scadenza a   *
      *                  * fronte della differenza                     *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to cnt-tdo-nok-540.
           if        w-pie-aos-pgf (1)    =    02
                     go to cnt-tdo-nok-540.
           move      zero                 to   w-pie-rns-pgf (1)      .
       cnt-tdo-nok-540.
      *                  *---------------------------------------------*
      *                  * Tipo nuova scadenza a fronte della diffe-   *
      *                  * renza                                       *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to cnt-tdo-nok-560.
           if        w-pie-rns-pgf (1)    not  = 01
                     move  zero           to   w-pie-tns-pgf (1)      .
       cnt-tdo-nok-560.
