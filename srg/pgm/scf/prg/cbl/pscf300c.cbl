      *              *-------------------------------------------------*
           return    srt    at end
                            go to rou-let-reg-out-999.
      *              *-------------------------------------------------*
      *              * Rilettura record [sfs]                          *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMSCF    "         to   f-key                  .
           move      srt-num-scf          to   rf-sfs-num-scf         .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
