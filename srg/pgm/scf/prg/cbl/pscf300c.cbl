           if       (w-cnt-mfu-tip-fun    =    "M"   ) and
                    (w-tes-drc-pgf (1)    =    zero or
                     w-tes-npc-pgf (1)    =    zero  )
                     go to cge-scf-pgf-100.
       cge-scf-pgf-025.
