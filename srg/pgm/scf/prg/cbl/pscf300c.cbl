      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      ">"                  to   v-edm                  .
           move      14                   to   v-lin                  .
           move      42                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      w-tes-sel-dsf (1)    to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-sel-dsf-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-sel-dsf-999.
       acc-sel-dsf-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-dat                to   w-tes-sel-dsf (1)      .
       acc-sel-dsf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-sel-dsf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-sel-dsf-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-sel-dsf-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-sel-dsf-100.
       acc-sel-dsf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Selezione data scadenza iniziale  *
      *    *-----------------------------------------------------------*
       vis-sel-dsf-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-sel-scf (1)    not  = 03
                     go to vis-sel-dsf-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      ">"                  to   v-edm                  .
           move      14                   to   v-lin                  .
           move      42                   to   v-pos                  .
           move      w-tes-sel-dsf (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sel-dsf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Selezione del mese scadenze          *
      *    *-----------------------------------------------------------*
       acc-sel-mes-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-sel-scf (1)    not  = 04
                     go to acc-sel-mes-999.
      *                      *-----------------------------------------*
      *                      * Se le impostazioni delle selezioni sono *
      *                      * gia' state tutte completate: no accet-  *
      *                      * tazione                                 *
      *                      *-----------------------------------------*
           if        w-tes-fda-sel (1)    not  = spaces
                     go to acc-sel-mes-999.
      *                  *---------------------------------------------*
      *                  * Preparazione work per l'accettazione del    *
      *                  * campo espanso selezione del mese scadenze   *
      *                  *---------------------------------------------*
           perform   pex-sel-mes-000      thru pex-sel-mes-999        .
      *                  *---------------------------------------------*
      *                  * Se Next Screen da campi precedenti          *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-sel-mes-400.
       acc-sel-mes-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazioni generali                       *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-sel-mes-lun    to   v-car                  .
           move      w-exp-sel-mes-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-sel-mes-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      13                   to   v-lin                  .
           move      55                   to   v-pos                  .
           move      zero                 to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-sel-mes-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-sel-mes-999.
       acc-sel-mes-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-sel-mes (1)      .
       acc-sel-mes-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-sel-mes-425.
      *                  *---------------------------------------------*
      *                  * Test che il valore non sia a zero, a meno   *
      *                  * che non si sia in Up                        *
      *                  *---------------------------------------------*
           if        w-tes-sel-mes (1)    not  = zero
                     go to acc-sel-mes-500.
           if        v-key                =    "UP  "
                     go to acc-sel-mes-600
           else      go to acc-sel-mes-100.
       acc-sel-mes-500.
      *                  *---------------------------------------------*
      *                  * Test se valore ammissibile                  *
      *                  *---------------------------------------------*
           if        w-tes-sel-mes (1)    >    w-exp-sel-mes-num
                     go to acc-sel-mes-100.
       acc-sel-mes-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino prima riga progressivi mensili   *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      54                   to   v-pos                  .
           move      "Anteriori :"        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione mese selezionato            *
      *                  *---------------------------------------------*
           perform   vis-sel-mes-000      thru vis-sel-mes-999        .
       acc-sel-mes-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-sel-mes-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-sel-mes-100.
       acc-sel-mes-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Selezione del mese scadenze       *
      *    *-----------------------------------------------------------*
       vis-sel-mes-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-sel-scf (1)    not  = 04
                     go to vis-sel-mes-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-sel-mes (1)    to   w-exp-sel-mes-inx      .
           move      w-exp-sel-mes-ele
                    (w-exp-sel-mes-inx)   to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sel-mes-999.
           exit.

      *    *===========================================================*
      *    * Preparazione work per l'accettazione del campo espanso :  *
      *    * Selezione del mese scadenza                               *
      *    *-----------------------------------------------------------*
       pex-sel-mes-000.
      *              *-------------------------------------------------*
      *              * Preparazione elemento pop-up nr. 1              *
      *              *-------------------------------------------------*
           move      "Anteriori "         to   w-exp-sel-mes-ele (1)  .
      *              *-------------------------------------------------*
      *              * Preparazione elementi pop-up dal nr. 2 al nr. 6 *
      *              *-------------------------------------------------*
           move      1                    to   w-exp-sel-mes-ctr      .
       pex-sel-mes-100.
           add       1                    to   w-exp-sel-mes-ctr      .
           if        w-exp-sel-mes-ctr    >    6
                     go to pex-sel-mes-200.
      *                  *---------------------------------------------*
      *                  * Normalizzazione elemento                    *
      *                  *---------------------------------------------*
           move      spaces               to   w-exp-sel-mes-ele
                                              (w-exp-sel-mes-ctr)     .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione mese dell'elemento          *
      *                  *---------------------------------------------*
           move      w-tes-sel-tpm-mes
                    (1, w-exp-sel-mes-ctr)
                                          to   w-exp-sel-mes-inx      .
      *
           move      "LM"                 to   s-ope                  .
           move      "A"                  to   s-tip                  .
           move      w-exp-sel-mes-inx    to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-alf                to   w-exp-sel-mes-mes
                                              (w-exp-sel-mes-ctr)     .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione anno dell'elemento          *
      *                  *---------------------------------------------*
           move      w-tes-sel-tpm-saa
                    (1, w-exp-sel-mes-ctr)
                                          to   w-exp-sel-mes-ann
                                              (w-exp-sel-mes-ctr)     .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     pex-sel-mes-100.
       pex-sel-mes-200.
      *              *-------------------------------------------------*
      *              * Preparazione elemento pop-up nr. 7              *
      *              *-------------------------------------------------*
           move      "Successive"         to   w-exp-sel-mes-ele (7)  .
       pex-sel-mes-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Presa visione per pagina 2   *
      *    *-----------------------------------------------------------*
       acc-pre-vp2-000.
      *              *-------------------------------------------------*
      *              * Controllo su impostazioni pagina testata nr. 2  *
      *              *-------------------------------------------------*
           perform   cnt-imp-pt2-000      thru cnt-imp-pt2-999        .
      *              *-------------------------------------------------*
      *              * Se controllo non superato : si esce forzando il *
      *              * tasto Up                                        *
      *              *-------------------------------------------------*
           if        w-cnt-imp-pt2-flg    not  = spaces
                     move  "UP  "         to   v-key
                     go to acc-pre-vp2-999.
      *              *-------------------------------------------------*
      *              * Se Next Screen si salta l'accettazione caratte- *
      *              * re di presa visione                             *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-pre-vp2-200.
       acc-pre-vp2-100.
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      spaces               to   v-msk                  .
           move      spaces               to   v-alf                  .
           move      spaces               to   v-not                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           if        w-cnt-sts-imp-npt    >    1
                     move  "PRSC"         to   v-pfk (07)             .
           move      "NXSC"               to   v-pfk (08)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vp2-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vp2-999.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-pre-vp2-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pre-vp2-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pre-vp2-000.
       acc-pre-vp2-200.
      *              *-------------------------------------------------*
      *              * Se tipo funzionamento diverso da Inserimento,   *
      *              * oltre                                           *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-pre-vp2-300.
      *              *-------------------------------------------------*
      *              * Se selezioni gia' effettuate : oltre            *
      *              *-------------------------------------------------*
           if        w-tes-fda-sel (1)    not  = spaces
                     go to acc-pre-vp2-300.
      *              *-------------------------------------------------*
      *              * Determinazione buffer scadenze fornitori di la- *
      *              * voro                                            *
      *              *-------------------------------------------------*
           perform   det-buf-scf-000      thru det-buf-scf-999        .
      *              *-------------------------------------------------*
      *              * Se esito determinazione negativo : si esce for- *
      *              * zando il tasto Up                               *
      *              *-------------------------------------------------*
           if        w-det-buf-scf-flg    not  = spaces
                     move  "UP  "         to   v-key
                     go to acc-pre-vp2-999.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di impostazione saldaconto *
      *              *-------------------------------------------------*
           move      spaces               to   w-sdc-flg-imp          .
      *              *-------------------------------------------------*
      *              * Attivazione flag di impostazione pagina sele-   *
      *              * zioni per saldaconto                            *
      *              *-------------------------------------------------*
           move      "#"                  to   w-tes-fda-sel (1)      .
       acc-pre-vp2-300.
      *              *-------------------------------------------------*
      *              * Se non esiste alcuna pagina attiva successiva   *
      *              * alla pagina attuale : uscita                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio numero pagina attuale           *
      *                  *---------------------------------------------*
           move      w-cnt-sts-imp-npt    to   w-cnt-sts-imp-svp      .
       acc-pre-vp2-400.
      *                  *---------------------------------------------*
      *                  * Se all'ultima pagina : ripristino pagina    *
      *                  * salvata ed uscita                           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-npt    not  < w-cnt-sts-imp-mpt
                     move  w-cnt-sts-imp-svp
                                          to   w-cnt-sts-imp-npt
                     go to acc-pre-vp2-999.
      *                  *---------------------------------------------*
      *                  * Incremento numero pagina                    *
      *                  *---------------------------------------------*
           add       1                    to   w-cnt-sts-imp-npt      .
      *                  *---------------------------------------------*
      *                  * Test se pagina da trattare                  *
      *                  *---------------------------------------------*
           perform   snp-tes-reg-000      thru snp-tes-reg-999        .
      *                  *---------------------------------------------*
      *                  * Se no : a re-incremento                     *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-snp    not  = spaces
                     go to acc-pre-vp2-400.
      *                  *---------------------------------------------*
      *                  * Se si : ripristino pagina salvata           *
      *                  *---------------------------------------------*
           move      w-cnt-sts-imp-svp    to   w-cnt-sts-imp-npt      .
       acc-pre-vp2-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazioni pagina testata nr. 2            *
      *    *-----------------------------------------------------------*
       cnt-imp-pt2-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-imp-pt2-flg      .
      *              *-------------------------------------------------*
      *              * Test se la pagina e' da trattare                *
      *              *                                                 *
      *              * N.B.: Il test seguente deve essere pari a quel- *
      *              *       lo contenuto in snp-tes-reg-000/999       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se non in Inserimento : no                  *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to cnt-imp-pt2-999.
      *                  *---------------------------------------------*
      *                  * Se tipo operazione Compensazione : no       *
      *                  *---------------------------------------------*
           if        w-tes-tip-ope        =    1650
                     go to cnt-imp-pt2-999.
      *                  *---------------------------------------------*
      *                  * Se il buffer scadenze fornitori di un solo  *
      *                  * tipo e quello di tutti i tipi,  non conten- *
      *                  * gono elementi, la pagina non e' da trattare *
      *                  *---------------------------------------------*
           if        w-bsu-num-ele        =    zero and
                     w-bst-num-ele        =    zero
                     go to cnt-imp-pt2-999.
      *                  *---------------------------------------------*
      *                  * Altrimenti, la pagina e' da trattare        *
      *                  *---------------------------------------------*
           go to     cnt-imp-pt2-100.
       cnt-imp-pt2-100.
      *              *-------------------------------------------------*
      *              * Selezione su tipo scadenza fornitore            *
      *              *-------------------------------------------------*
           if        w-tes-sel-tsf (1)    not  = zero and
                     w-tes-sel-tsf (1)    not  > w-exp-sel-tsf-num
                     go to cnt-imp-pt2-120.
           move      "Manca la definizione del tipo scadenza da selezion
      -              "are !          "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt2-900.
       cnt-imp-pt2-120.
      *              *-------------------------------------------------*
      *              * Selezione scadenze fornitore                    *
      *              *-------------------------------------------------*
           if        w-tes-sel-scf (1)    not  = zero and
                     w-tes-sel-scf (1)    not  > w-exp-sel-scf-num
                     go to cnt-imp-pt2-140.
           move      "Manca la definizione delle scadenze da selezionare
      -              " !             "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt2-900.
       cnt-imp-pt2-140.
      *              *-------------------------------------------------*
      *              * Selezione su importo scadenze                   *
      *              *-------------------------------------------------*
           if        w-tes-sel-scf (1)    not  = 02
                     go to cnt-imp-pt2-160.
           if        w-tes-sel-imp (1)    not  = zero
                     go to cnt-imp-pt2-160.
           move      "Manca l'importo da selezionare !                  
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt2-900.
       cnt-imp-pt2-160.
      *              *-------------------------------------------------*
      *              * Data scadenza iniziale e finale                 *
      *              *-------------------------------------------------*
           if        w-tes-sel-scf (1)    not  = 03
                     go to cnt-imp-pt2-180.
           if        w-tes-sel-dsi (1)    =    zero or
                     w-tes-sel-dsf (1)    =    zero
                     go to cnt-imp-pt2-180.
           if        w-tes-sel-dsf (1)    not  < w-tes-sel-dsi (1)
                     go to cnt-imp-pt2-180.
           move      "Data periodo iniziale superiore a quella finale ! 
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt2-900.
       cnt-imp-pt2-180.
      *              *-------------------------------------------------*
      *              * Mese da selezionare                             *
      *              *-------------------------------------------------*
           if        w-tes-sel-scf (1)    not  = 04
                     go to cnt-imp-pt2-200.
           if        w-tes-sel-mes (1)    not  = zero and
                     w-tes-sel-mes (1)    not  > w-exp-sel-mes-num
                     go to cnt-imp-pt2-200.
           move      "Manca il mese da selezionare !                    
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt2-900.
       cnt-imp-pt2-200.
      *              *-------------------------------------------------*
      *              * Fine controlli                                  *
      *              *-------------------------------------------------*
       cnt-imp-pt2-800.
      *              *-------------------------------------------------*
      *              * Normalizzazioni                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Data scadenza finale                        *
      *                  *---------------------------------------------*
           if        w-tes-sel-scf (1)    not  = 03
                     go to cnt-imp-pt2-820.
           if        w-tes-sel-dsf (1)    not  = zero
                     go to cnt-imp-pt2-820.
           if        w-tes-sel-dsi (1)    =    zero
                     move  w-tes-sel-dsi (1)
                                          to   w-tes-sel-dsf (1)
           else      move  9999999        to   w-tes-sel-dsf (1)      .
       cnt-imp-pt2-820.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     cnt-imp-pt2-999.
       cnt-imp-pt2-900.
      *              *-------------------------------------------------*
      *              * Se controllo non superato                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di errore in uscita                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-imp-pt2-flg      .
       cnt-imp-pt2-999.
           exit.
           
      *    *===========================================================*
      *    * Determinazione del buffer scadenze fornitori di lavoro    *
      *    *-----------------------------------------------------------*
       det-buf-scf-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-buf-scf-flg      .
      *              *-------------------------------------------------*
      *              * Se tipo operazione, Compensazione, si seleziona *
      *              * il buffer scadenze di tutti i tipi              *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        =    1650
                     go to det-buf-scf-200.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo scadenze forni- *
      *              * tore selezionato                                *
      *              *-------------------------------------------------*
           go to     det-buf-scf-100
                     det-buf-scf-200
                     depending            on  w-tes-sel-tsf (1)       .
       det-buf-scf-100.
      *              *-------------------------------------------------*
      *              * Se selezionato buffer scadenze di un tipo       *
      *              *-------------------------------------------------*
           move      w-bsu                to   w-bsf                  .
      *              *-------------------------------------------------*
      *              * Ad uscita                                       *
      *              *-------------------------------------------------*
           go to     det-buf-scf-900.
       det-buf-scf-200.
      *              *-------------------------------------------------*
      *              * Se selezionato buffer scadenze di tutti i tipi  *
      *              *-------------------------------------------------*
           move      w-bst                to   w-bsf                  .
      *              *-------------------------------------------------*
      *              * Ad uscita                                       *
      *              *-------------------------------------------------*
           go to     det-buf-scf-900.
       det-buf-scf-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-buf-scf-999.
       det-buf-scf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Saldaconto scadenze fornitori        *
      *    *-----------------------------------------------------------*
       acc-sdc-scf-000.
      *              *-------------------------------------------------*
      *              * Se impostazione saldaconto gia' avvenuta        *
      *              *-------------------------------------------------*
           if        w-sdc-flg-imp        =    spaces
                     go to  acc-sdc-scf-100.
           multiply  12                   by   w-sdc-npg-dat
                                        giving w-sdc-ctr-rig          .
           subtract  11                   from w-sdc-ctr-rig          .
           go to     acc-sdc-scf-300.
       acc-sdc-scf-100.
      *              *-------------------------------------------------*
      *              * Determinazione numero massimo pagine            *
      *              *-------------------------------------------------*
           move      w-bsf-num-ele        to   w-sdc-npg-max          .
           divide    12                   into w-sdc-npg-max
                                        giving w-sdc-npg-max
                                     remainder w-sdc-wrk-rem          .
           if        w-sdc-wrk-rem        >    zero
                     add    1             to   w-sdc-npg-max          .
      *              *-------------------------------------------------*
      *              * Preselezione per saldaconto scadenze fornitori  *
      *              *-------------------------------------------------*
           perform   pre-sdc-scf-000      thru pre-sdc-scf-999        .
      *              *-------------------------------------------------*
      *              * Numero pagina visualizzata                      *
      *              *-------------------------------------------------*
           move      zero                 to   w-sdc-npg-vis          .
      *              *-------------------------------------------------*
      *              * Numero riga da trattare                         *
      *              *-------------------------------------------------*
           move      w-sdc-rig-ini        to   w-sdc-ctr-rig          .
       acc-sdc-scf-200.
           add       1                    to   w-sdc-ctr-rig          .
           if        w-sdc-ctr-rig        >    w-bsf-num-ele
                     go to  acc-sdc-scf-900.
       acc-sdc-scf-300.
      *              *-------------------------------------------------*
      *              * Determinazione numero pagina da trattare        *
      *              *-------------------------------------------------*
           divide    12                   into w-sdc-ctr-rig
                                        giving w-sdc-npg-dat
                                     remainder w-sdc-wrk-rem          .
           if        w-sdc-wrk-rem        >    zero
                     add    1             to   w-sdc-npg-dat          .
      *              *-------------------------------------------------*
      *              * Visualizzazione totale scadenze fornitore e to- *
      *              * tale scadenze selezionate                       *
      *              *-------------------------------------------------*
           if        w-sdc-npg-vis        =    zero
                     perform vis-tot-scf-000
                                          thru vis-tot-scf-999
                     perform vis-tot-scs-000
                                          thru vis-tot-scs-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione pagina da trattare              *
      *              *-------------------------------------------------*
           if        w-sdc-npg-dat        not  = w-sdc-npg-vis
                     perform vis-sdc-scf-000
                                          thru vis-sdc-scf-999        .
      *              *-------------------------------------------------*
      *              * Determinazione numero linea                     *
      *              *-------------------------------------------------*
           subtract  1                    from w-sdc-npg-dat
                                        giving w-sdc-wrk-rig          .
           multiply  12                   by   w-sdc-wrk-rig          .
           subtract  w-sdc-wrk-rig        from w-sdc-ctr-rig
                                        giving w-sdc-wrk-lin          .
           add       7                    to   w-sdc-wrk-lin          .
       acc-sdc-scf-400.
      *              *-------------------------------------------------*
      *              * Accettazione riga saldaconto                    *
      *              *-------------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Flag di scadenza selezionata                *
      *                  *---------------------------------------------*
           perform   acc-flg-scs-000      thru acc-flg-scs-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-sdc-scf-900.
      *                  *---------------------------------------------*
      *                  * Test su tipo uscita                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se Up                                   *
      *                      *-----------------------------------------*
           if        v-key                =    "UP  "
                     subtract 1           from w-sdc-ctr-rig
                     go to  acc-sdc-scf-300.
      *                      *-----------------------------------------*
      *                      * Se Down                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "DOWN"
                     go to  acc-sdc-scf-200.
      *                      *-----------------------------------------*
      *                      * Se Next Screen                          *
      *                      *-----------------------------------------*
           if        v-key                not  = "NXSC"
                     go to  acc-sdc-scf-500.
           multiply  12                   by   w-sdc-npg-dat
                                        giving w-sdc-ctr-rig          .
           go to     acc-sdc-scf-200.
       acc-sdc-scf-500.
      *                      *-----------------------------------------*
      *                      * Se Prev Screen                          *
      *                      *-----------------------------------------*
           if        v-key                not  = "PRSC"
                     go to acc-sdc-scf-600.
           if        w-sdc-npg-dat        =    1
                     go to acc-sdc-scf-900.
           subtract  1                    from w-sdc-npg-dat          .
           multiply  12                   by   w-sdc-npg-dat
                                        giving w-sdc-ctr-rig          .
           subtract  11                   from w-sdc-ctr-rig          .
           go to     acc-sdc-scf-300.
       acc-sdc-scf-600.
      *                      *-----------------------------------------*
      *                      * Se Tab                                  *
      *                      *-----------------------------------------*
           if        v-key                =    "TAB "
                     move   w-bsf-num-ele to   w-sdc-ctr-rig
                     go to  acc-sdc-scf-300.
      *                      *-----------------------------------------*
      *                      * Se Back                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "BACK"
                     move   1             to   w-sdc-ctr-rig
                     go to  acc-sdc-scf-300.
      *              *-------------------------------------------------*
      *              * Riciclo a riga successiva                       *
      *              *-------------------------------------------------*
           go to     acc-sdc-scf-200.
       acc-sdc-scf-900.
      *              *-------------------------------------------------*
      *              * Attivazione flag di saldaconto impostato        *
      *              *-------------------------------------------------*
           move      "#"                  to   w-sdc-flg-imp          .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-sdc-scf-999.
       acc-sdc-scf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Saldaconto scadenze fornitori     *
      *    *-----------------------------------------------------------*
       vis-sdc-scf-000.
      *              *-------------------------------------------------*
      *              * Aggiornamento numero pagina visualizzata        *
      *              *-------------------------------------------------*
           move      w-sdc-npg-dat        to   w-sdc-npg-vis          .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Determinazione valore iniziale contatore ele-   *
      *              * menti                                           *
      *              *-------------------------------------------------*
           multiply  12                   by   w-sdc-npg-dat
                                      giving   w-vis-sdc-scf-cte      .
           subtract  12                   from w-vis-sdc-scf-cte      .
      *              *-------------------------------------------------*
      *              * Ciclo si scansione 1..12 righe                  *
      *              *-------------------------------------------------*
           move      zero                 to   w-vis-sdc-scf-ctr      .
       vis-sdc-scf-100.
           add       1                    to   w-vis-sdc-scf-ctr      .
           if        w-vis-sdc-scf-ctr    >    12
                     go to vis-sdc-scf-900.
      *                  *---------------------------------------------*
      *                  * Incremento contatore elementi               *
      *                  *---------------------------------------------*
           add       1                    to   w-vis-sdc-scf-cte      .
      *                  *---------------------------------------------*
      *                  * Test se maggiore del numero elementi nel    *
      *                  * buffer                                      *
      *                  *---------------------------------------------*
           if        w-vis-sdc-scf-cte    >    w-bsf-num-ele
                     go to vis-sdc-scf-200
           else      go to vis-sdc-scf-400.
       vis-sdc-scf-200.
      *                  *---------------------------------------------*
      *                  * Se maggiore                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prima pagina da trattare : oltre     *
      *                      *-----------------------------------------*
           if        w-sdc-npg-dat        =    1
                     go to  vis-sdc-scf-900.
      *                      *-----------------------------------------*
      *                      * Stampa riga bianca                      *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           add       7
                     w-vis-sdc-scf-ctr  giving v-lin                  .
           move      01                   to   v-pos                  .
           move      "           |                     |        |       
      -              "         |   |                "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Riciclo su scansione                    *
      *                      *-----------------------------------------*
           go to     vis-sdc-scf-100.
       vis-sdc-scf-400.
      *                  *---------------------------------------------*
      *                  * Se minore o uguale                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Stampa riga bianca                      *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           add       7
                     w-vis-sdc-scf-ctr  giving v-lin                  .
           move      01                   to   v-pos                  .
           move      "           |                     |        |       
      -              "         |   |                "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione valori elemento         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Tipo scadenza fornitore             *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      11                   to   v-car                  .
           add       7
                     w-vis-sdc-scf-ctr  giving v-lin                  .
           move      01                   to   v-pos                  .
           if        w-bsf-tip-scf
                    (w-vis-sdc-scf-cte)   =    01
                     move  "Rim.Diretta"
                                          to   v-alf
           else if   w-bsf-tip-scf
                    (w-vis-sdc-scf-cte)   =    02
                     move  "Inc.Elettr."
                                          to   v-alf
           else if   w-bsf-tip-scf
                    (w-vis-sdc-scf-cte)   =    03
                     move  "Ri.Ba.     "
                                          to   v-alf
           else if   w-bsf-tip-scf
                    (w-vis-sdc-scf-cte)   =    04
                     move  "C.d.O.     "
                                          to   v-alf
           else if   w-bsf-tip-scf
                    (w-vis-sdc-scf-cte)   =    05
                     move  "M.Av.      "
                                          to   v-alf
           else if   w-bsf-tip-scf
                    (w-vis-sdc-scf-cte)   =    06
                     move  "R.I.D.     "
                                          to   v-alf
           else if   w-bsf-tip-scf
                    (w-vis-sdc-scf-cte)   =    07
                     move  "Bonif.Banc."
                                          to   v-alf
           else if   w-bsf-tip-scf
                    (w-vis-sdc-scf-cte)   =    08
                     move  "C/C Postale"
                                          to   v-alf
           else if   w-bsf-tip-scf
                    (w-vis-sdc-scf-cte)   =    09
                     move  "Ric. Banc."
                                          to   v-alf
           else if   w-bsf-tip-scf
                    (w-vis-sdc-scf-cte)   =    10
                     move  "Tratta    "
                                          to   v-alf
           else if   w-bsf-tip-scf
                    (w-vis-sdc-scf-cte)   =    11
                     move  "Paghero'  "
                                          to   v-alf
           else      move  spaces         to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Tipo documento di riferimento       *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      02                   to   v-car                  .
           add       7
                     w-vis-sdc-scf-ctr  giving v-lin                  .
           move      13                   to   v-pos                  .
           if        w-bsf-tip-ddr
                    (w-vis-sdc-scf-cte)   =    01
                     move  "FT"           to   v-alf
           else if   w-bsf-tip-ddr
                    (w-vis-sdc-scf-cte)   =    02
                     move  "NA"           to   v-alf
           else if   w-bsf-tip-ddr
                    (w-vis-sdc-scf-cte)   =    11
                     move  "NC"           to   v-alf
           else if   w-bsf-tip-ddr
                    (w-vis-sdc-scf-cte)   =    51
                     move  "PP"           to   v-alf
           else if   w-bsf-tip-ddr
                    (w-vis-sdc-scf-cte)   =    99
                     move  "  "           to   v-alf
           else      move  spaces         to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Numero documento di riferimento     *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Allineamento a destra           *
      *                              *---------------------------------*
           move      w-bsf-num-ddr
                    (w-vis-sdc-scf-cte)   to   w-all-str-alf          .
           move      10                   to   w-all-str-lun          .
           perform   all-str-adx-000      thru all-str-adx-999        .
      *                              *---------------------------------*
      *                              * Visualizzazione                 *
      *                              *---------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      10                   to   v-car                  .
           add       7
                     w-vis-sdc-scf-ctr  giving v-lin                  .
           move      15                   to   v-pos                  .
           move      w-all-str-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Data documento di riferimento       *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           add       7
                     w-vis-sdc-scf-ctr  giving v-lin                  .
           move      26                   to   v-pos                  .
           move      w-bsf-dat-ddr
                    (w-vis-sdc-scf-cte)   to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Data scadenza                       *
      *                          *-------------------------------------*
           if        w-bsf-dts-scf
                    (w-vis-sdc-scf-cte)   not  = zero
                     go to vis-sdc-scf-420.
      *                              *---------------------------------*
      *                              * Se a vista                      *
      *                              *---------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      08                   to   v-car                  .
           add       7
                     w-vis-sdc-scf-ctr  giving v-lin                  .
           move      35                   to   v-pos                  .
           move      " A vista"           to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     vis-sdc-scf-440.
       vis-sdc-scf-420.
      *                              *---------------------------------*
      *                              * Se non a vista                  *
      *                              *---------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           add       7
                     w-vis-sdc-scf-ctr  giving v-lin                  .
           move      35                   to   v-pos                  .
           move      w-bsf-dts-scf
                    (w-vis-sdc-scf-cte)   to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sdc-scf-440.
      *                          *-------------------------------------*
      *                          * Importo scadenza                    *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vlt (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "G"                  to   v-edm                  .
           add       7
                     w-vis-sdc-scf-ctr  giving v-lin                  .
           move      44                   to   v-pos                  .
           move      w-bsf-imp-scf
                    (w-vis-sdc-scf-cte)   to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Flag di scadenza selezionata        *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           add       7
                     w-vis-sdc-scf-ctr  giving v-lin                  .
           move      62                   to   v-pos                  .
           move      w-bsf-flg-scs
                    (w-vis-sdc-scf-cte)   to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Importo scadenza selezionata        *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Test se da visualizzare         *
      *                              *---------------------------------*
           if        w-bsf-flg-scs
                    (w-vis-sdc-scf-cte)   not  = "S"
                     go to vis-sdc-scf-460.
      *                              *---------------------------------*
      *                              * Visualizzazione                 *
      *                              *---------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vlt (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "G"                  to   v-edm                  .
           add       7
                     w-vis-sdc-scf-ctr  giving v-lin                  .
           move      65                   to   v-pos                  .
           move      w-bsf-imp-scf
                    (w-vis-sdc-scf-cte)   to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sdc-scf-460.
      *                  *---------------------------------------------*
      *                  * Riciclo su riga successiva                  *
      *                  *---------------------------------------------*
           go to     vis-sdc-scf-100.
       vis-sdc-scf-900.
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sdc-scf-999.
           exit.

      *    *===========================================================*
      *    * Selezione preventiva per funzione saldaconto              *
      *    *-----------------------------------------------------------*
       pre-sdc-scf-000.
      *              *-------------------------------------------------*
      *              * Bufferizzazione totale scadenze fornitore       *
      *              *-------------------------------------------------*
           move      w-bsf-tot-scf        to   w-sdc-tot-scf          .
      *              *-------------------------------------------------*
      *              * Normalizzazione totale scadenze selezionate     *
      *              *-------------------------------------------------*
           move      zero                 to   w-sdc-tot-scs          .
      *              *-------------------------------------------------*
      *              * Determinazione numero riga iniziale in funzione *
      *              * della selezione scadenze fornitore              *
      *              *-------------------------------------------------*
           go to     pre-sdc-scf-100
                     pre-sdc-scf-200
                     pre-sdc-scf-300
                     pre-sdc-scf-400
                     depending            on   w-tes-sel-scf (1)      .
       pre-sdc-scf-100.
      *              *-------------------------------------------------*
      *              * Selezione scadenze : manuale                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Riga iniziale : zero                        *
      *                  *---------------------------------------------*
           move      zero                 to   w-sdc-rig-ini          .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     pre-sdc-scf-999.
       pre-sdc-scf-200.
      *              *-------------------------------------------------*
      *              * Selezione scadenze : Piu' vecchie               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Riga iniziale : zero                        *
      *                  *---------------------------------------------*
           move      zero                 to   w-sdc-rig-ini          .
      *                  *---------------------------------------------*
      *                  * Normalizzazione work per accumulo           *
      *                  *---------------------------------------------*
           move      zero                 to   w-pre-sdc-scf-wpa      .
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione buffer elementi          *
      *                  *---------------------------------------------*
           move      zero                 to   w-pre-sdc-scf-ctr      .
       pre-sdc-scf-210.
           add       1                    to   w-pre-sdc-scf-ctr      .
      *                      *-----------------------------------------*
      *                      * Se superato il numero di elementi : ol- *
      *                      * tre                                     *
      *                      *-----------------------------------------*
           if        w-pre-sdc-scf-ctr    >    w-bsf-num-ele
                     go to pre-sdc-scf-220.
      *                      *-----------------------------------------*
      *                      * Aggiornamento work per accumulo         *
      *                      *-----------------------------------------*
           add       w-bsf-imp-scf
                    (w-pre-sdc-scf-ctr)   to   w-pre-sdc-scf-wpa      .
      *                      *-----------------------------------------*
      *                      * Se risulta superiore all'importo ri-    *
      *                      * chiesto : oltre                         *
      *                      *-----------------------------------------*
           if        w-pre-sdc-scf-wpa    >    w-tes-sel-imp (1)
                     go to pre-sdc-scf-220.
      *                      *-----------------------------------------*
      *                      * Aggiornamento elemento del buffer       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Flag di scadenza selezionata        *
      *                          *-------------------------------------*
           move      "S"                  to   w-bsf-flg-scs
                                              (w-pre-sdc-scf-ctr)     .
      *                      *-----------------------------------------*
      *                      * Aggiornamento totale scadenze selezio-  *
      *                      * nate                                    *
      *                      *-----------------------------------------*
           add       w-bsf-imp-scf
                    (w-pre-sdc-scf-ctr)   to   w-sdc-tot-scs          .
      *                      *-----------------------------------------*
      *                      * Riciclo su prossimo elemento            *
      *                      *-----------------------------------------*
           go to     pre-sdc-scf-210.
       pre-sdc-scf-220.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     pre-sdc-scf-999.
       pre-sdc-scf-300.
      *              *-------------------------------------------------*
      *              * Tipo saldaconto : per periodo                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizializzazione numero riga iniziale       *
      *                  *---------------------------------------------*
           move      zero                 to   w-sdc-rig-ini          .
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione buffer elementi          *
      *                  *---------------------------------------------*
           move      zero                 to   w-pre-sdc-scf-ctr      .
       pre-sdc-scf-320.
           add       1                    to   w-pre-sdc-scf-ctr      .
      *                      *-----------------------------------------*
      *                      * Se superato il numero di elementi : ol- *
      *                      * tre                                     *
      *                      *-----------------------------------------*
           if        w-pre-sdc-scf-ctr    >    w-bsf-num-ele
                     go to pre-sdc-scf-380.
      *                      *-----------------------------------------*
      *                      * Test su data scadenza iniziale          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se scadenza a vista                 *
      *                          *-------------------------------------*
           if        w-bsf-dts-scf
                    (w-pre-sdc-scf-ctr)   not  = zero
                     go to pre-sdc-scf-322.
           if        w-tes-dat-reg        <    w-tes-sel-dsi (1)
                     go to pre-sdc-scf-320
           else      go to pre-sdc-scf-330.
       pre-sdc-scf-322.
      *                          *-------------------------------------*
      *                          * Se scadenza normale                 *
      *                          *-------------------------------------*
           if        w-bsf-dts-scf
                    (w-pre-sdc-scf-ctr)   <    w-tes-sel-dsi (1)
                     go to pre-sdc-scf-320
           else      go to pre-sdc-scf-330.
       pre-sdc-scf-330.
      *                      *-----------------------------------------*
      *                      * Test su data scadenza finale            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se scadenza a vista                 *
      *                          *-------------------------------------*
           if        w-bsf-dts-scf
                    (w-pre-sdc-scf-ctr)   not  = zero
                     go to pre-sdc-scf-332.
           if        w-tes-dat-reg        >    w-tes-sel-dsf (1)
                     go to pre-sdc-scf-320
           else      go to pre-sdc-scf-360.
       pre-sdc-scf-332.
      *                          *-------------------------------------*
      *                          * Se scadenza normale                 *
      *                          *-------------------------------------*
           if        w-bsf-dts-scf
                    (w-pre-sdc-scf-ctr)   >    w-tes-sel-dsf (1)
                     go to pre-sdc-scf-320
           else      go to pre-sdc-scf-360.
       pre-sdc-scf-360.
      *                      *-----------------------------------------*
      *                      * Aggiornamento numero riga iniziale      *
      *                      *-----------------------------------------*
           if        w-sdc-rig-ini        =    zero
                     move     w-pre-sdc-scf-ctr
                                          to   w-sdc-rig-ini
                     subtract 1           from w-sdc-rig-ini          .
      *                      *-----------------------------------------*
      *                      * Aggiornamento elemento del buffer       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Flag di scadenza selezionata        *
      *                          *-------------------------------------*
           move      "S"                  to   w-bsf-flg-scs
                                              (w-pre-sdc-scf-ctr)     .
      *                      *-----------------------------------------*
      *                      * Aggiornamento totale scadenze selezio-  *
      *                      * nate                                    *
      *                      *-----------------------------------------*
           add       w-bsf-imp-scf
                    (w-pre-sdc-scf-ctr)   to   w-sdc-tot-scs          .
      *                      *-----------------------------------------*
      *                      * Riciclo su prossimo elemento            *
      *                      *-----------------------------------------*
           go to     pre-sdc-scf-320.
       pre-sdc-scf-380.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     pre-sdc-scf-999.
       pre-sdc-scf-400.
      *              *-------------------------------------------------*
      *              * Tipo saldaconto : mensile                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione data iniziale e finale del   *
      *                  * mese selezionato                            *
      *                  *---------------------------------------------*
           move      w-tes-sel-mes (1)    to   w-pre-sdc-scf-inx      .
      *                      *-----------------------------------------*
      *                      * Data iniziale                           *
      *                      *-----------------------------------------*
           move      w-tes-sel-tpm-saa
                    (1, w-pre-sdc-scf-inx)
                                          to   s-saa                  .
           move      w-tes-sel-tpm-mes
                    (1, w-pre-sdc-scf-inx)
                                          to   s-mes                  .
           move      01                   to   s-gio                  .
           move      s-dat                to   w-pre-sdc-scf-wdi      .
      *                      *-----------------------------------------*
      *                      * Data finale                             *
      *                      *-----------------------------------------*
           move      w-pre-sdc-scf-wdi    to   s-dat                  .
           move      31                   to   s-gio                  .
       pre-sdc-scf-405.
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                not  = spaces
                     subtract 1           from s-gio
                     go to pre-sdc-scf-405.
           move      s-dat                to   w-pre-sdc-scf-wdf      .
      *                      *-----------------------------------------*
      *                      * Eventuale correzione data iniziale, se  *
      *                      * selezionato 'Anteriori'                 *
      *                      *-----------------------------------------*
           if        w-tes-sel-mes (1)    =    01
                     move  zero           to   w-pre-sdc-scf-wdi      .
      *                      *-----------------------------------------*
      *                      * Eventuale correzione data finale, se    *
      *                      * selezionato 'Successivi'                *
      *                      *-----------------------------------------*
           if        w-tes-sel-mes (1)    =    07
                     move  9999999        to   w-pre-sdc-scf-wdf      .
       pre-sdc-scf-410.
      *                  *---------------------------------------------*
      *                  * Inizializzazione numero riga iniziale       *
      *                  *---------------------------------------------*
           move      zero                 to   w-sdc-rig-ini          .
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione buffer elementi          *
      *                  *---------------------------------------------*
           move      zero                 to   w-pre-sdc-scf-ctr      .
       pre-sdc-scf-420.
           add       1                    to   w-pre-sdc-scf-ctr      .
      *                      *-----------------------------------------*
      *                      * Se superato il numero di elementi : ol- *
      *                      * tre                                     *
      *                      *-----------------------------------------*
           if        w-pre-sdc-scf-ctr    >    w-bsf-num-ele
                     go to pre-sdc-scf-480.
      *                      *-----------------------------------------*
      *                      * Test su data scadenza iniziale          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se scadenza a vista                 *
      *                          *-------------------------------------*
           if        w-bsf-dts-scf
                    (w-pre-sdc-scf-ctr)   not  = zero
                     go to pre-sdc-scf-422.
           if        w-tes-dat-reg        <    w-pre-sdc-scf-wdi
                     go to pre-sdc-scf-420
           else      go to pre-sdc-scf-430.
       pre-sdc-scf-422.
      *                          *-------------------------------------*
      *                          * Se scadenza normale                 *
      *                          *-------------------------------------*
           if        w-bsf-dts-scf
                    (w-pre-sdc-scf-ctr)   <    w-pre-sdc-scf-wdi
                     go to pre-sdc-scf-420
           else      go to pre-sdc-scf-430.
       pre-sdc-scf-430.
      *                      *-----------------------------------------*
      *                      * Test su data scadenza finale            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se scadenza a vista                 *
      *                          *-------------------------------------*
           if        w-bsf-dts-scf
                    (w-pre-sdc-scf-ctr)   not  = zero
                     go to pre-sdc-scf-432.
           if        w-tes-dat-reg        >    w-pre-sdc-scf-wdf
                     go to pre-sdc-scf-420
           else      go to pre-sdc-scf-460.
       pre-sdc-scf-432.
      *                          *-------------------------------------*
      *                          * Se scadenza normale                 *
      *                          *-------------------------------------*
           if        w-bsf-dts-scf
                    (w-pre-sdc-scf-ctr)   >    w-pre-sdc-scf-wdf
                     go to pre-sdc-scf-420
           else      go to pre-sdc-scf-460.
       pre-sdc-scf-460.
      *                      *-----------------------------------------*
      *                      * Aggiornamento numero riga iniziale      *
      *                      *-----------------------------------------*
           if        w-sdc-rig-ini        =    zero
                     move     w-pre-sdc-scf-ctr
                                          to   w-sdc-rig-ini
                     subtract 1           from w-sdc-rig-ini          .
      *                      *-----------------------------------------*
      *                      * Aggiornamento elemento del buffer       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Flag di scadenza selezionata        *
      *                          *-------------------------------------*
           move      "S"                  to   w-bsf-flg-scs
                                              (w-pre-sdc-scf-ctr)     .
      *                      *-----------------------------------------*
      *                      * Aggiornamento totale scadenze selezio-  *
      *                      * nate                                    *
      *                      *-----------------------------------------*
           add       w-bsf-imp-scf
                    (w-pre-sdc-scf-ctr)   to   w-sdc-tot-scs          .
      *                      *-----------------------------------------*
      *                      * Riciclo su prossimo elemento            *
      *                      *-----------------------------------------*
           go to     pre-sdc-scf-420.
       pre-sdc-scf-480.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     pre-sdc-scf-999.
       pre-sdc-scf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo saldaconto : Flag scadenza selezionata *
      *    *-----------------------------------------------------------*
       acc-flg-scs-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-bsf-flg-scs
                    (w-sdc-ctr-rig)       to   w-sav-flg-scs          .
       acc-flg-scs-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      62                   to   v-pos                  .
           if        w-sdc-ctr-rig        >    1
                     move   "UP  "        to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           if        w-sdc-npg-dat        >    1
                     move   "PRSC"        to   v-pfk (07)             .
           if        w-sdc-npg-dat        <    w-sdc-npg-max
                     move   "NXSC"        to   v-pfk (08)             .
           if        w-sdc-ctr-rig        >    1
                     move   "BACK"        to   v-pfk (09)             .
           if        w-sdc-ctr-rig        <    w-bsf-num-ele
                     move   "TAB "        to   v-pfk (10)             .
           move      "SLCT"               to   v-pfk (11)             .
           move      "EXPD"               to   v-pfk (12)             .
           move      w-bsf-flg-scs
                    (w-sdc-ctr-rig)       to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-flg-scs-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-flg-scs-999.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-bsf-flg-scs
                                              (w-sdc-ctr-rig)         .
       acc-flg-scs-200.
      *              *-------------------------------------------------*
      *              * Se Expand                                       *
      *              *-------------------------------------------------*
           if        v-key                not  = "EXPD"
                     go to acc-flg-scs-250.
      *                  *---------------------------------------------*
      *                  * Se campo modificato : ripristino valore pre-*
      *                  * cedente e reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-bsf-flg-scs
                    (w-sdc-ctr-rig)       not  = w-sav-flg-scs
                     move  w-sav-flg-scs  to   w-bsf-flg-scs
                                              (w-sdc-ctr-rig)
                     go to acc-flg-scs-100.
      *                  *---------------------------------------------*
      *                  * Espansione su scadenze fornitori            *
      *                  *---------------------------------------------*
           move      "N"                  to   w-esp-arc-sfs-sns      .
           move      w-bsf-num-scf
                    (w-sdc-ctr-rig)       to   w-esp-arc-sfs-num      .
           perform   esp-arc-sfs-000      thru esp-arc-sfs-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo a reimpostazione                    *
      *                  *---------------------------------------------*
           go to     acc-flg-scs-100.
       acc-flg-scs-250.
      *              *-------------------------------------------------*
      *              * Se Up, Down, Prsc, Nxsc, Tab e Back             *
      *              *-------------------------------------------------*
           if        v-key                not  = "UP  " and
                     v-key                not  = "DOWN" and
                     v-key                not  = "PRSC" and
                     v-key                not  = "NXSC" and
                     v-key                not  = "TAB " and
                     v-key                not  = "BACK"
                     go to acc-flg-scs-300.
      *                  *---------------------------------------------*
      *                  * Se campo modificato : ripristino valore pre-*
      *                  * cedente e reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-bsf-flg-scs
                    (w-sdc-ctr-rig)       not  = w-sav-flg-scs
                     move  w-sav-flg-scs  to   w-bsf-flg-scs
                                              (w-sdc-ctr-rig)
                     go to acc-flg-scs-100.
      *                  *---------------------------------------------*
      *                  * Altrimenti : uscita                         *
      *                  *---------------------------------------------*
           go to     acc-flg-scs-999.
       acc-flg-scs-300.
      *              *-------------------------------------------------*
      *              * Se Slct                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "SLCT"
                     go to acc-flg-scs-400.
      *                  *---------------------------------------------*
      *                  * Se campo modificato : ripristino valore pre-*
      *                  * cedente e reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-bsf-flg-scs
                    (w-sdc-ctr-rig)       not  = w-sav-flg-scs
                     move  w-sav-flg-scs  to   w-bsf-flg-scs
                                              (w-sdc-ctr-rig)
                     go to acc-flg-scs-100.
      *                  *---------------------------------------------*
      *                  * Azioni per Slct                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se scadenza gia' selezionata            *
      *                      *-----------------------------------------*
           if        w-bsf-flg-scs
                    (w-sdc-ctr-rig)       not  = "S"
                     go to  acc-flg-scs-320.
      *                          *-------------------------------------*
      *                          * Aggiornamento flag di scadenza se-  *
      *                          * lezionata                           *
      *                          *-------------------------------------*
           if        w-bsf-snx-pbl
                    (w-sdc-ctr-rig)       =    "S"
                     move  "*"            to   w-bsf-flg-scs
                                              (w-sdc-ctr-rig)
           else      move  spaces         to   w-bsf-flg-scs
                                              (w-sdc-ctr-rig)         .
      *                          *-------------------------------------*
      *                          * Aggiornamento totale scadenze sele- *
      *                          * zionate                             *
      *                          *-------------------------------------*
           subtract  w-bsf-imp-scf
                    (w-sdc-ctr-rig)       from w-sdc-tot-scs          .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-flg-scs-340.
       acc-flg-scs-320.
      *                      *-----------------------------------------*
      *                      * Se scadenza non selezionata             *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Aggiornamento flag di scadenza se-  *
      *                          * lezionata                           *
      *                          *-------------------------------------*
           move      "S"                  to   w-bsf-flg-scs
                                              (w-sdc-ctr-rig)         .
      *                          *-------------------------------------*
      *                          * Aggiornamento totale scadenze sele- *
      *                          * zionate                             *
      *                          *-------------------------------------*
           add       w-bsf-imp-scf
                    (w-sdc-ctr-rig)       to   w-sdc-tot-scs          .
       acc-flg-scs-340.
      *                      *-----------------------------------------*
      *                      * Visualizzazione flag di scadenza sele-  *
      *                      * zionata                                 *
      *                      *-----------------------------------------*
           perform   vis-flg-scs-000      thru vis-flg-scs-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione importo scadenza sele-  *
      *                      * zionata                                 *
      *                      *-----------------------------------------*
           perform   vis-imp-scs-000      thru vis-imp-scs-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione totale scadenze sele-   *
      *                      * zionate                                 *
      *                      *-----------------------------------------*
           perform   vis-tot-scs-000      thru vis-tot-scs-999        .
      *                      *-----------------------------------------*
      *                      * Uscita come per Down                    *
      *                      *-----------------------------------------*
           move      "DOWN"               to   v-key                  .
           go to     acc-flg-scs-999.
       acc-flg-scs-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
           if        w-bsf-flg-scs
                    (w-sdc-ctr-rig)       not  = "S" and
                     w-bsf-flg-scs
                    (w-sdc-ctr-rig)       not  = "*" and
                     w-bsf-flg-scs
                    (w-sdc-ctr-rig)       not  = spaces
                     move  w-sav-flg-scs  to   w-bsf-flg-scs
                                              (w-sdc-ctr-rig)
                     go to acc-flg-scs-100.
      *                  *---------------------------------------------*
      *                  * Test se valore compatibile con flag Si/No   *
      *                  * pagamento bloccato                          *
      *                  *---------------------------------------------*
           if        w-bsf-flg-scs
                    (w-sdc-ctr-rig)       =    "*" and
                     w-bsf-snx-pbl
                    (w-sdc-ctr-rig)       not  = "S"
                     move  w-sav-flg-scs  to   w-bsf-flg-scs
                                              (w-sdc-ctr-rig)
                     go to acc-flg-scs-100.
           if        w-bsf-flg-scs
                    (w-sdc-ctr-rig)       =    spaces and
                     w-bsf-snx-pbl
                    (w-sdc-ctr-rig)       =    "S"
                     move  w-sav-flg-scs  to   w-bsf-flg-scs
                                              (w-sdc-ctr-rig)
                     go to acc-flg-scs-100.
       acc-flg-scs-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-bsf-flg-scs
                    (w-sdc-ctr-rig)       =    w-sav-flg-scs
                     go to acc-flg-scs-800.
      *                  *---------------------------------------------*
      *                  * Eventuale controaggiornamento totale sca-   *
      *                  * denze selezionate                           *
      *                  *---------------------------------------------*
           if        w-sav-flg-scs        =    "S"
                     subtract w-bsf-imp-scf
                             (w-sdc-ctr-rig)
                                          from w-sdc-tot-scs          .
      *                  *---------------------------------------------*
      *                  * Eventuale aggiornamento totale scadenze     *
      *                  * selezionate                                 *
      *                  *---------------------------------------------*
           if        w-bsf-flg-scs
                    (w-sdc-ctr-rig)       =    "S"
                     add      w-bsf-imp-scf
                             (w-sdc-ctr-rig)
                                          to   w-sdc-tot-scs          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione importo scadenza seleziona- *
      *                  * ta                                          *
      *                  *---------------------------------------------*
           perform   vis-imp-scs-000      thru vis-imp-scs-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione totale scadenze seleziona-  *
      *                  * te                                          *
      *                  *---------------------------------------------*
           perform   vis-tot-scs-000      thru vis-tot-scs-999        .
       acc-flg-scs-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-flg-scs-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-flg-scs-100.
       acc-flg-scs-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo saldaconto : Flag scadenza selezio- *
      *    *                                    nata                   *
      *    *-----------------------------------------------------------*
       vis-flg-scs-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      62                   to   v-pos                  .
           move      w-bsf-flg-scs
                    (w-sdc-ctr-rig)       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-flg-scs-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo saldaconto : Importo scadenza sele- *
      *    *                                    zionata                *
      *    *-----------------------------------------------------------*
       vis-imp-scs-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vlt (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      65                   to   v-pos                  .
           if        w-bsf-flg-scs
                    (w-sdc-ctr-rig)       =    "S"
                     move  w-bsf-imp-scf
                          (w-sdc-ctr-rig) to   v-num
           else      move  zero           to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-imp-scs-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo saldaconto : Totale scadenze sele-  *
      *    *                                    zionate                *
      *    *-----------------------------------------------------------*
       vis-tot-scs-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vlt (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "G"                  to   v-edm                  .
           move      21                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-sdc-tot-scs        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tot-scs-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo saldaconto : Totale scadenze forni- *
      *    *                                    tore                   *
      *    *-----------------------------------------------------------*
       vis-tot-scf-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vlt (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "G"                  to   v-edm                  .
           move      21                   to   v-lin                  .
           move      44                   to   v-pos                  .
           move      w-sdc-tot-scf        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tot-scf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Presa visione per pagina 3   *
      *    *-----------------------------------------------------------*
       acc-pre-vp3-000.
      *              *-------------------------------------------------*
      *              * Controllo su impostazioni pagina testata nr. 3  *
      *              *-------------------------------------------------*
           perform   cnt-imp-pg3-000      thru cnt-imp-pg3-999        .
      *              *-------------------------------------------------*
      *              * Se controllo non superato : si esce forzando il *
      *              * tasto Up                                        *
      *              *-------------------------------------------------*
           if        w-cnt-imp-pg3-flg    not  = spaces
                     move  "UP  "         to   v-key
                     go to acc-pre-vp3-999.
      *              *-------------------------------------------------*
      *              * Se Next Screen si salta l'accettazione caratte- *
      *              * re di presa visione                             *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-pre-vp3-200.
       acc-pre-vp3-100.
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      spaces               to   v-msk                  .
           move      spaces               to   v-alf                  .
           move      spaces               to   v-not                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           if        w-cnt-sts-imp-npt    >    1
                     move  "PRSC"         to   v-pfk (07)             .
           move      "NXSC"               to   v-pfk (08)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vp3-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vp3-999.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-pre-vp3-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pre-vp3-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pre-vp3-000.
       acc-pre-vp3-200.
      *              *-------------------------------------------------*
      *              * Se tipo funzionamento diverso da Inserimento,   *
      *              * oltre                                           *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-pre-vp3-300.
      *              *-------------------------------------------------*
      *              * Se saldaconto gia' impostato : oltre            *
      *              *-------------------------------------------------*
           if        w-tes-fda-sdc (1)    not  = spaces
                     go to acc-pre-vp3-300.
      *              *-------------------------------------------------*
      *              * Caricamento catena scadenze fornitori           *
      *              *-------------------------------------------------*
           perform   car-cat-scf-000      thru car-cat-scf-999        .
      *              *-------------------------------------------------*
      *              * Se esito caricamento negativo : si esce forzan- *
      *              * do il tasto Up                                  *
      *              *-------------------------------------------------*
           if        w-car-cat-scf-flg    not  = spaces
                     move  "UP  "         to   v-key
                     go to acc-pre-vp3-999.
      *              *-------------------------------------------------*
      *              * Attivazione flag di impostazione saldaconto     *
      *              *-------------------------------------------------*
           move      "#"                  to   w-tes-fda-sdc (1)      .
       acc-pre-vp3-300.
      *              *-------------------------------------------------*
      *              * Se non esiste alcuna pagina attiva successiva   *
      *              * alla pagina attuale : uscita                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio numero pagina attuale           *
      *                  *---------------------------------------------*
           move      w-cnt-sts-imp-npt    to   w-cnt-sts-imp-svp      .
       acc-pre-vp3-400.
      *                  *---------------------------------------------*
      *                  * Se all'ultima pagina : ripristino pagina    *
      *                  * salvata ed uscita                           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-npt    not  < w-cnt-sts-imp-mpt
                     move  w-cnt-sts-imp-svp
                                          to   w-cnt-sts-imp-npt
                     go to acc-pre-vp3-999.
      *                  *---------------------------------------------*
      *                  * Incremento numero pagina                    *
      *                  *---------------------------------------------*
           add       1                    to   w-cnt-sts-imp-npt      .
      *                  *---------------------------------------------*
      *                  * Test se pagina da trattare                  *
      *                  *---------------------------------------------*
           perform   snp-tes-reg-000      thru snp-tes-reg-999        .
      *                  *---------------------------------------------*
      *                  * Se no : a re-incremento                     *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-snp    not  = spaces
                     go to acc-pre-vp3-400.
      *                  *---------------------------------------------*
      *                  * Se si : ripristino pagina salvata           *
      *                  *---------------------------------------------*
           move      w-cnt-sts-imp-svp    to   w-cnt-sts-imp-npt      .
       acc-pre-vp3-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazioni pagina testata nr. 3            *
      *    *-----------------------------------------------------------*
       cnt-imp-pg3-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-imp-pg3-flg      .
      *              *-------------------------------------------------*
      *              * Test se la pagina e' da trattare                *
      *              *                                                 *
      *              * N.B.: Il test seguente deve essere pari a quel- *
      *              *       lo contenuto in snp-tes-reg-000/999       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se non in Inserimento : no                  *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to cnt-imp-pg3-999.
      *                  *---------------------------------------------*
      *                  * Se il buffer scadenze fornitori di un solo  *
      *                  * tipo e quello di tutti i tipi,  non conten- *
      *                  * gono elementi, la pagina non e' da trattare *
      *                  *---------------------------------------------*
           if        w-bsu-num-ele        =    zero and
                     w-bst-num-ele        =    zero
                     go to cnt-imp-pg3-999.
      *                  *---------------------------------------------*
      *                  * Se il buffer scadenze fornitori non contie- *
      *                  * ne elementi, la pagina non e' da trattare   *
      *                  *---------------------------------------------*
           if        w-bsf-num-ele        =    zero
                     go to cnt-imp-pg3-999.
      *                  *---------------------------------------------*
      *                  * Altrimenti, la pagina e' da trattare        *
      *                  *---------------------------------------------*
           go to     cnt-imp-pg3-100.
       cnt-imp-pg3-100.
      *              *-------------------------------------------------*
      *              * Nessun controllo                                *
      *              *-------------------------------------------------*
       cnt-imp-pg3-120.
      *              *-------------------------------------------------*
      *              * Fine controlli                                  *
      *              *-------------------------------------------------*
       cnt-imp-pg3-800.
      *              *-------------------------------------------------*
      *              * Normalizzazioni                                 *
      *              *-------------------------------------------------*
       cnt-imp-pg3-820.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     cnt-imp-pg3-999.
       cnt-imp-pg3-900.
      *              *-------------------------------------------------*
      *              * Se controllo non superato                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di errore in uscita                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-imp-pg3-flg      .
       cnt-imp-pg3-999.
           exit.
           
      *    *===========================================================*
      *    * Caricamento catena scadenze fornitori                     *
      *    *-----------------------------------------------------------*
       car-cat-scf-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-car-cat-scf-flg      .
      *              *-------------------------------------------------*
      *              * Inizializzazione totale righe scadenze selezio- *
      *              * nate                                            *
      *              *-------------------------------------------------*
           move      zero                 to   w-tes-tot-rss (1)      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione buffer scadenze fornitori    *
      *              *-------------------------------------------------*
           move      zero                 to   w-car-cat-scf-ctr      .
       car-cat-scf-100.
           add       1                    to   w-car-cat-scf-ctr      .
           if        w-car-cat-scf-ctr    >    w-bsf-num-ele
                     go to car-cat-scf-999.
      *                  *---------------------------------------------*
      *                  * Test se scadenza selezionata                *
      *                  *---------------------------------------------*
           if        w-bsf-flg-scs
                    (w-car-cat-scf-ctr)   not  = "S"
                     go to car-cat-scf-100.
      *                  *---------------------------------------------*
      *                  * Append in catena                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se Append non possibile : uscita con    *
      *                      * errore                                  *
      *                      *-----------------------------------------*
           if        w-cat-rig-app        not  = spaces
                     go to car-cat-scf-900.
      *                      *-----------------------------------------*
      *                      * Append                                  *
      *                      *-----------------------------------------*
           move      "AP"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       car-cat-scf-200.
      *                  *---------------------------------------------*
      *                  * Normalizzazione riga                        *
      *                  *---------------------------------------------*
           perform   nor-nok-rig-000      thru nor-nok-rig-999        .
      *                  *---------------------------------------------*
      *                  * Composizione riga                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Aggiornamento del numero progressivo    *
      *                      *-----------------------------------------*
           perform   prg-rig-cor-000      thru prg-rig-cor-999        .
      *                      *-----------------------------------------*
      *                      * Numero scadenza fornitore               *
      *                      *-----------------------------------------*
           move      w-bsf-num-scf
                    (w-car-cat-scf-ctr)   to   w-rig-num-scf (1)      .
      *                      *-----------------------------------------*
      *                      * Tipo scadenza fornitore                 *
      *                      *-----------------------------------------*
           move      w-bsf-tip-scf
                    (w-car-cat-scf-ctr)   to   w-rig-tip-scf (1)      .
      *                      *-----------------------------------------*
      *                      * Tipo registrazione scadenza fornitore   *
      *                      *-----------------------------------------*
           move      w-bsf-trs-scf
                    (w-car-cat-scf-ctr)   to   w-rig-trs-scf (1)      .
      *                      *-----------------------------------------*
      *                      * Tipo valuta scadenza fornitore          *
      *                      *-----------------------------------------*
           move      w-bsf-tvl-scf
                    (w-car-cat-scf-ctr)   to   w-rig-tvl-scf (1)      .
      *                      *-----------------------------------------*
      *                      * Tipo documento di riferimento           *
      *                      *-----------------------------------------*
           move      w-bsf-tip-ddr
                    (w-car-cat-scf-ctr)   to   w-rig-tip-ddr (1)      .
      *                      *-----------------------------------------*
      *                      * Numero documento di riferimento         *
      *                      *-----------------------------------------*
           move      w-bsf-num-ddr
                    (w-car-cat-scf-ctr)   to   w-rig-num-ddr (1)      .
      *                      *-----------------------------------------*
      *                      * Data documento di riferimento           *
      *                      *-----------------------------------------*
           move      w-bsf-dat-ddr
                    (w-car-cat-scf-ctr)   to   w-rig-dat-ddr (1)      .
      *                      *-----------------------------------------*
      *                      * Importo scadenza                        *
      *                      *-----------------------------------------*
           move      w-bsf-imp-scf
                    (w-car-cat-scf-ctr)   to   w-rig-imp-scf (1)      .
      *                      *-----------------------------------------*
      *                      * Data scadenza                           *
      *                      *-----------------------------------------*
           move      w-bsf-dts-scf
                    (w-car-cat-scf-ctr)   to   w-rig-dts-scf (1)      .
      *                      *-----------------------------------------*
      *                      * Si/No pagamento bloccato                *
      *                      *-----------------------------------------*
           move      w-bsf-snx-pbl
                    (w-car-cat-scf-ctr)   to   w-rig-snx-pbl (1)      .
      *                  *---------------------------------------------*
      *                  * Update catena                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-max        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Aggiornamento totale righe scadenze sele-   *
      *                  * zionate                                     *
      *                  *---------------------------------------------*
           add       w-bsf-imp-scf
                    (w-car-cat-scf-ctr)   to   w-tes-tot-rss (1)      .
      *              *-------------------------------------------------*
      *              * Riciclo scansione buffer scadenze fornitori     *
      *              *-------------------------------------------------*
           go to     car-cat-scf-100.
       car-cat-scf-900.
      *              *-------------------------------------------------*
      *              * Messaggio di errore per esubero numero righe    *
      *              *-------------------------------------------------*
           move      "Numero scadenze da trattare oltre il massimo previ
      -              "sto !          "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *              *-------------------------------------------------*
      *              * Flag di uscita ad errore                        *
      *              *-------------------------------------------------*
           move      "#"                  to   w-car-cat-scf-flg      .
       car-cat-scf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione corpo a partire dalla riga con numero d'or-  *
      *    * dine : w-cnt-cor-nrg-dac                                  *
      *    *-----------------------------------------------------------*
       acc-cor-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione tipo uscita da corpo            *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-cor      .
      *              *-------------------------------------------------*
      *              * Confronto tra numero d'ordine riga da accettare *
      *              * e numero d'ordine dell'ultima riga              *
      *              *-------------------------------------------------*
           if        w-cnt-cor-nrg-dac    not  > w-cat-rig-max
                     go to acc-cor-reg-025.
      *              *-------------------------------------------------*
      *              * Se oltre numero riga massimo e Append non pos-  *
      *              * sibile si esce con status di uscita "+"         *
      *              *-------------------------------------------------*
           if        w-cat-rig-app        not  = spaces
                     move  "+"            to   w-cnt-tus-acc-cor
                     go to acc-cor-reg-990.
      *              *-------------------------------------------------*
      *              * Se oltre numero riga massimo e Append possibile *
      *              * si esegue l'operazione di Append                *
      *              *-------------------------------------------------*
           move      w-cat-rig-max        to   w-cnt-cor-nrg-dac      .
           add       1                    to   w-cnt-cor-nrg-dac      .
           move      "AP"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       acc-cor-reg-025.
      *              *-------------------------------------------------*
      *              * Video in 'OFF'                                  *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Prompts per corpo                               *
      *              *-------------------------------------------------*
           if        w-cnt-sts-pmt-cor    =    spaces
                     perform pmt-cor-reg-000
                                          thru pmt-cor-reg-999
                     move    "#"          to   w-cnt-sts-pmt-cor      .
      *              *-------------------------------------------------*
      *              * Visualizzazione dati corpo                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione nr pagina da visualizzare    *
      *                  *---------------------------------------------*
           move      w-cnt-cor-nrg-dac    to   w-cnt-cor-nrp-dav      .
           add       w-lin-num-lin-vis    to   w-cnt-cor-nrp-dav      .
           subtract  1                    from w-cnt-cor-nrp-dav      .
           divide    w-lin-num-lin-vis    into w-cnt-cor-nrp-dav      .
      *                  *---------------------------------------------*
      *                  * Se non e' visualizzata nessuna pagina corpo *
      *                  * o una pagina corpo diversa da quella da vi- *
      *                  * sualizzare si procede alla visualizzazione  *
      *                  *---------------------------------------------*
           if        w-cnt-sts-vis-cor    =    spaces           or
                     w-cnt-cor-nrp-vis    not  = w-cnt-cor-nrp-dav
                     perform vis-cor-reg-000
                                          thru vis-cor-reg-999
                     move    "#"          to   w-cnt-sts-vis-cor
                     move    w-cnt-cor-nrp-dav
                                          to   w-cnt-cor-nrp-vis      .
      *              *-------------------------------------------------*
      *              * Lettura riga da catena                          *
      *              *-------------------------------------------------*
           move      "RD"                 to   w-cat-rig-ope          .
           move      w-cnt-cor-nrg-dac    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se riga nuova si normalizza il corpo            *
      *              *-------------------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to acc-cor-reg-050.
           perform   nor-nok-rig-000      thru nor-nok-rig-999        .
           move      w-rig-val-aep (1)    to   w-rig-val-aep (2)      .
       acc-cor-reg-050.
      *              *-------------------------------------------------*
      *              * Routine pre-accettazione riga corpo             *
      *              *-------------------------------------------------*
           perform   pre-rig-cor-000      thru pre-rig-cor-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts per riga d'accettazione *
      *              *-------------------------------------------------*
           perform   pmt-rig-cor-000      thru pmt-rig-cor-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione dati per riga di accettazione   *
      *              *-------------------------------------------------*
           perform   vis-rig-cor-000      thru vis-rig-cor-999        .
      *              *-------------------------------------------------*
      *              * Video in 'ON'                                   *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Flag di status impostazione corpo               *
      *              *-------------------------------------------------*
           if        w-cat-rig-max        =    zero
                     move  spaces         to   w-cnt-sts-imp-cor
           else      move  "#"            to   w-cnt-sts-imp-cor      .
           if        w-cat-rig-max        =    1        and
                     w-cat-rig-new        not  = spaces and
                     w-cat-rig-lst        not  = spaces
                     move  spaces         to   w-cnt-sts-imp-cor      .
      *              *-------------------------------------------------*
      *              * Flag di status impostione riga attuale          *
      *              *-------------------------------------------------*
           if        w-cat-rig-new        =    spaces
                     move  "#"            to   w-cnt-sts-imp-rig
           else      move  spaces         to   w-cnt-sts-imp-rig      .
      *              *-------------------------------------------------*
      *              * Indicatore linea in corso di trattamento        *
      *              *-------------------------------------------------*
           move      "I"                  to   w-cnt-cor-tvi-rig      .
           move      w-cnt-cor-nrg-dac    to   w-cnt-cor-nrg-dav      .
           perform   vis-lin-cor-000      thru vis-lin-cor-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazione tipo uscita da riga corpo       *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-rig      .
       acc-cor-reg-100.
      *              *-------------------------------------------------*
      *              * Accettazioni                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo impostazione : primo campo riga corpo  *
      *                  *---------------------------------------------*
           move      "C"                  to   w-cnt-mfu-tip-imp      .
      *                  *---------------------------------------------*
      *                  * Accettazione numero scadenza fornitore      *
      *                  *---------------------------------------------*
           perform   acc-num-scf-000      thru acc-num-scf-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-925.
      *                  *---------------------------------------------*
      *                  * Tipo impostazione : altri campi riga corpo  *
      *                  *---------------------------------------------*
           move      "R"                  to   w-cnt-mfu-tip-imp      .
       acc-cor-reg-200.
      *                  *---------------------------------------------*
      *                  * Normalizzazione func-key di impostazione    *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Accettazione presa visione per corpo        *
      *                  *---------------------------------------------*
           perform   acc-pvi-cor-000      thru acc-pvi-cor-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
       acc-cor-reg-800.
      *              *-------------------------------------------------*
      *              * Controllo finale su riga impostata              *
      *              *-------------------------------------------------*
           perform   cnt-tdo-rig-000      thru cnt-tdo-rig-999        .
           if        w-cnt-tdo-rig-flg    not  = spaces
                     move  spaces         to   w-cnt-tdo-rig-flg
                     move  "UP  "         to   v-key
                     go to acc-cor-reg-200.
       acc-cor-reg-900.
      *              *-------------------------------------------------*
      *              * Tests per uscita significativa da interno riga  *
      *              *-------------------------------------------------*
           if        w-cnt-tus-acc-rig    =    spaces or
                     w-cnt-tus-acc-rig    =    "S"
                     go to acc-cor-reg-905
           else if   w-cnt-tus-acc-rig    =    "R"
                     go to acc-cor-reg-910.
      *                  *---------------------------------------------*
      *                  * Se Exit da interno riga                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga New funzionamento come per Remv *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to acc-cor-reg-915.
      *                      *-----------------------------------------*
      *                      * Se riga non New                         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Visualizzazione numero riga         *
      *                          *-------------------------------------*
           move      "N"                  to   w-cnt-cor-tvi-rig      .
           move      w-cnt-cor-nrg-dac    to   w-cnt-cor-nrg-dav      .
           perform   vis-lin-cor-000      thru vis-lin-cor-999        .
           go to     acc-cor-reg-000.
       acc-cor-reg-905.
      *                  *---------------------------------------------*
      *                  * Se Do da interno riga                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se record di tipo New attribuzione del  *
      *                      * numero progressivo per la riga          *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to acc-cor-reg-907.
           perform   prg-rig-cor-000      thru prg-rig-cor-999        .
       acc-cor-reg-907.
      *                      *-----------------------------------------*
      *                      * Routine post-accettazione riga          *
      *                      *-----------------------------------------*
           move      "+"                  to   w-cnt-cor-tip-agg      .
           perform   pos-rig-cor-000      thru pos-rig-cor-999        .
      *                      *-----------------------------------------*
      *                      * Update riga in catena movimenti         *
      *                      *-----------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cnt-cor-nrg-dac    to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione linea corpo             *
      *                      *-----------------------------------------*
           move      "R"                  to   w-cnt-cor-tvi-rig      .
           move      w-cnt-cor-nrg-dac    to   w-cnt-cor-nrg-dav      .
           perform   vis-lin-cor-000      thru vis-lin-cor-999        .
      *                      *-----------------------------------------*
      *                      * Incremento del numero d'ordine della    *
      *                      * riga da accettare                       *
      *                      *-----------------------------------------*
           add       1                    to   w-cnt-cor-nrg-dac      .
           go to     acc-cor-reg-000.
       acc-cor-reg-910.
      *                  *---------------------------------------------*
      *                  * Se Remv da interno riga                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga non new : routine post-accetta- *
