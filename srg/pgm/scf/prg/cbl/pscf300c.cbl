      *                  *---------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "num-scf"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'esito della let-  *
      *                  * tura                                        *
      *                  *---------------------------------------------*
           if        s-ves                =    spaces
                     go to esp-arc-sfs-365
           else      go to esp-arc-sfs-370.
       esp-arc-sfs-365.
      *                  *---------------------------------------------*
      *                  * Se variabile esistente                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di selezione avvenuta              *
      *                      *-----------------------------------------*
           move      spaces               to   w-esp-arc-sfs-sel      .
      *                      *-----------------------------------------*
      *                      * Numero scadenza selezionata             *
      *                      *-----------------------------------------*
           move      s-num                to   w-esp-arc-sfs-num      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     esp-arc-sfs-999.
       esp-arc-sfs-370.
      *                  *---------------------------------------------*
      *                  * Se variabile non esistente                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     esp-arc-sfs-999.
       esp-arc-sfs-999.
           exit.

      *    *===========================================================*
      *    * Selezioni bloccanti su record [sfs]                       *
      *    *                                                           *
      *    * Input  :                                                  *
      *    *                                                           *
      *    *  - Area w-tes e record [sfs] da esaminare                 *
      *    *                                                           *
      *    * Output :                                                  *
      *    *                                                           *
      *    *  - w-sel-sfs-blo-flg : Flag fondamentale di uscita        *
      *    *    - 00 : Selezione superata                              *
      *    *    - nn : Selezione non superata, con causa codice nn     *
      *    *                                                           *
      *    *           - 10 : Codice fornitore diverso                 *
      *    *           - 11 : Tipo scadenza non riconosciuto           *
      *    *                                                           *
      *    *           - 13 : Codice valuta della scadenza diverso da  *
      *    *                  quello del pagamento in atto             *
      *    *           - 14 : Status scadenza indicante movimenti suc- *
      *    *                  cessivi a quello di registrazione        *
      *    *           - 15 : Data di registrazione del movimento di   *
      *    *                  registrazione scadenza superiore alla    *
      *    *                  data di registrazione dell'operazione in *
      *    *                  corso                                    *
      *    *           - 16 : Importo scadenza non superiore a zero    *
      *    *           - 17 : La scadenza e' bloccata                  *
      *    *           - 18 : La scadenza e' in fase di pulizia        *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       sel-sfs-blo-000.
      *              *-------------------------------------------------*
      *              * Selezione su codice fornitore, che sia ricono-  *
      *              * sciuto                                          *
      *              *-------------------------------------------------*
           if        rf-sfs-cod-fnt       =    w-tes-cod-fnt (1)
                     go to sel-sfs-blo-050.
           move      10                   to   w-sel-sfs-blo-flg      .
           move      "Codice fornitore diverso da quello dichiarato per 
      -              "l'operazione   "    to   w-sel-sfs-blo-err      .
           go to     sel-sfs-blo-999.
       sel-sfs-blo-050.
      *              *-------------------------------------------------*
      *              * Selezione su tipo scadenza, che sia riconosciu- *
      *              * to                                              *
      *              *-------------------------------------------------*
           if        rf-sfs-tip-scf       =    01 or
                     rf-sfs-tip-scf       =    02 or
                     rf-sfs-tip-scf       =    03 or
                     rf-sfs-tip-scf       =    04 or
                     rf-sfs-tip-scf       =    05 or
                     rf-sfs-tip-scf       =    06 or
                     rf-sfs-tip-scf       =    07 or
                     rf-sfs-tip-scf       =    08 or
                     rf-sfs-tip-scf       =    09 or
                     rf-sfs-tip-scf       =    10 or
                     rf-sfs-tip-scf       =    11
                     go to sel-sfs-blo-100.
           move      11                   to   w-sel-sfs-blo-flg      .
           move      "Tipo scadenza non riconosciuto                    
      -              "               "    to   w-sel-sfs-blo-err      .
           go to     sel-sfs-blo-999.
       sel-sfs-blo-100.
      *              *-------------------------------------------------*
      *              * Selezione su tipo valuta, che sia compatibile   *
      *              *-------------------------------------------------*
       sel-sfs-blo-200.
      *              *-------------------------------------------------*
      *              * Selezione su sigla valuta, che sia compatibile  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test di selezione                           *
      *                  *---------------------------------------------*
           if        w-tes-tip-ope        not  = 1731
                     go to sel-sfs-blo-300.
      *                  *---------------------------------------------*
      *                  * Test di selezione                           *
      *                  *---------------------------------------------*
           if        rf-sfs-sgl-vlt       =    w-tes-sgl-vlt (1) and
                     rf-sfs-dec-vlt       =    w-tes-dec-vlt (1) and
                     rf-sfs-tdc-vlt       =    w-tes-tdc-vlt (1)
                     go to sel-sfs-blo-300.
      *                  *---------------------------------------------*
      *                  * Trattamento errore                          *
      *                  *---------------------------------------------*
           move      13                   to   w-sel-sfs-blo-flg      .
           move      "Sigla valuta della scadenza incompatibile         
      -              "               "    to   w-sel-sfs-blo-err      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     sel-sfs-blo-999.
       sel-sfs-blo-300.
      *              *-------------------------------------------------*
      *              * Selezione su status della scadenza, che non in- *
      *              * dichi movimenti successivi a quello di regi-    *
      *              * strazione                                       *
      *              *-------------------------------------------------*
           if        rf-sfs-dtr-sto       =    zero and
                     rf-sfs-num-pgf       =    zero
                     go to sel-sfs-blo-400.
           move      14                   to   w-sel-sfs-blo-flg      .
           move      "La scadenza ha subito movimenti successivi alla re
      -              "gistrazione    "    to   w-sel-sfs-blo-err      .
           go to     sel-sfs-blo-999.
       sel-sfs-blo-400.
      *              *-------------------------------------------------*
      *              * Selezione sulla data di registrazione movimento *
      *              * di registrazione scadenza, che non sia superio- *
      *              * re alla data di registrazione in corso          *
      *              *                                                 *
      *              * Nota : Questa selezione e' stata inibita per    *
      *              *        consentire di registrare pagamenti di    *
      *              *        tipo contrassegno anche se la fattura    *
      *              *        e' stata registrata in un momento suc-   *
      *              *        cessivo, ad esempio cumulativamente a    *
      *              *        fine settimana.                          *
      *              *        In questo modo, sempreche' la registra-  *
      *              *        zione del pagamento avvenga fisicamente  *
      *              *        dopo la registrazione della fattura, il  *
      *              *        movimento di cassa o di banca relativo   *
      *              *        al pagamento sara' registrato nella da-  *
      *              *        ta corretta, consentendo in tal modo     *
      *              *        i controlli di quadratura della cassa o  *
      *              *        della banca.                             *
      *              *-------------------------------------------------*
           go to     sel-sfs-blo-500.
       sel-sfs-blo-401.
           if        rf-sfs-dtr-rgs       not > w-tes-dat-reg
                     go to sel-sfs-blo-500.
           move      15                   to   w-sel-sfs-blo-flg      .
           move      "Data registrazione scadenza superiore alla data de
      -              "ll'operazione  "    to   w-sel-sfs-blo-err      .
           go to     sel-sfs-blo-999.
       sel-sfs-blo-500.
      *              *-------------------------------------------------*
      *              * Selezione su importo scadenza per riscossione   *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        not  = 1510 and
                     w-tes-tip-ope        not  = 1520 and
                     w-tes-tip-ope        not  = 1530
                     go to sel-sfs-blo-510.
           go to     sel-sfs-blo-600.
       sel-sfs-blo-510.
      *              *-------------------------------------------------*
      *              * Selezione su importo scadenza, che sia superio- *
      *              * re a zero                                       *
      *              *-------------------------------------------------*
           if        rf-sfs-imp-scf       >    zero
                     go to sel-sfs-blo-600
           else      go to sel-sfs-blo-520.
       sel-sfs-blo-520.
           move      16                   to   w-sel-sfs-blo-flg      .
           move      "Importo scadenza non positivo                     
      -              "               "    to   w-sel-sfs-blo-err      .
           go to     sel-sfs-blo-999.
       sel-sfs-blo-600.
      *              *-------------------------------------------------*
      *              * Selezione su flag bloccanti                     *
      *              *-------------------------------------------------*
           if        rf-sfs-flg-blo       =    spaces
                     go to sel-sfs-blo-700.
           move      17                   to   w-sel-sfs-blo-flg      .
           move      "La scadenza e' stata sottoposta ad elaborazioni   
      -              "               "    to   w-sel-sfs-blo-err      .
           go to     sel-sfs-blo-999.
       sel-sfs-blo-700.
      *              *-------------------------------------------------*
      *              * Selezione su flag di pulizia                    *
      *              *-------------------------------------------------*
           if        rf-sfs-flg-pul       =    spaces
                     go to sel-sfs-blo-800.
           move      18                   to   w-sel-sfs-blo-flg      .
           move      "La scadenza e' in corso di eliminazione           
      -              "               "    to   w-sel-sfs-blo-err      .
           go to     sel-sfs-blo-999.
       sel-sfs-blo-800.
      *              *-------------------------------------------------*
      *              * Selezione superata                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-sel-sfs-blo-flg      .
           move      spaces               to   w-sel-sfs-blo-err      .
       sel-sfs-blo-999.
           exit.

      *    *===========================================================*
      *    * Selezioni non bloccanti su record [sfs]                   *
      *    *                                                           *
      *    * Input  :                                                  *
      *    *                                                           *
      *    *  - Area w-tes e record [sfs] da esaminare                 *
      *    *                                                           *
      *    * Output :                                                  *
      *    *                                                           *
      *    *  - w-sel-sfs-nbl-flg : Flag fondamentale di uscita        *
      *    *    - 00 : Selezione superata                              *
      *    *    - nn : Selezione non superata, con causa codice nn     *
      *    *                                                           *
      *    *           - 11 : Codice dipendenza del fornitore          *
      *    *           - 12 : Inoltro pagamento                        *
      *    *           - 13 : Nostra banca d'appoggio                  *
      *    *           - 14 : Codici ABI, CAB e C/C bancario           *
      *    *           - 15 : Codice C/C postale                       *
      *    *           - 16 : Codice banca estera                      *
      *    *                                                           *
      *    *           - 17 : Tipo valuta della scadenza difforme      *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       sel-sfs-nbl-000.
      *              *-------------------------------------------------*
      *              * Codice dipendenza del fornitore                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test di selezione                           *
      *                  *---------------------------------------------*
           if        rf-sfs-dpz-fnt       =    w-tes-dpz-fnt (1)
                     go to sel-sfs-nbl-100.
      *                  *---------------------------------------------*
      *                  * Trattamento errore                          *
      *                  *---------------------------------------------*
           move      11                   to   w-sel-sfs-nbl-flg      .
           move      "Diverso codice dipendenza del fornitore           
      -              "               "    to   w-sel-sfs-nbl-err      .
           go to     sel-sfs-nbl-999.
       sel-sfs-nbl-100.
      *              *-------------------------------------------------*
      *              * Inoltro pagamento al fornitore                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test di selezione                           *
      *                  *---------------------------------------------*
           if        rf-sfs-inl-scf       =    w-tes-inl-pgf (1)
                     go to sel-sfs-nbl-150.
      *                  *---------------------------------------------*
      *                  * Trattamento errore                          *
      *                  *---------------------------------------------*
           move      12                   to   w-sel-sfs-nbl-flg      .
           move      "Inoltro scadenza diverso dall'inoltro pagamento   
      -              "               "    to   w-sel-sfs-nbl-err      .
           go to     sel-sfs-nbl-999.
       sel-sfs-nbl-150.
      *              *-------------------------------------------------*
      *              * Tipo valuta                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test di selezione                           *
      *                  *---------------------------------------------*
           if        rf-sfs-tvl-scf       =    w-tes-tvl-pgf (1)
                     go to sel-sfs-nbl-200.
      *                  *---------------------------------------------*
      *                  * Trattamento errore                          *
      *                  *---------------------------------------------*
           move      17                   to   w-sel-sfs-nbl-flg      .
           move      "Tipo valuta per la scadenza incompatibile         
      -              "               "    to   w-sel-sfs-nbl-err      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     sel-sfs-nbl-999.
       sel-sfs-nbl-200.
      *              *-------------------------------------------------*
      *              * Nostra banca d'appoggio per Avvisi di Scadenza  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo scadenza                       *
      *                  *---------------------------------------------*
           if        rf-sfs-tip-scf       not  = 02 and
                     rf-sfs-tip-scf       not  = 03 and
                     rf-sfs-tip-scf       not  = 04 and
                     rf-sfs-tip-scf       not  = 05 and
                     rf-sfs-tip-scf       not  = 06 and
                     rf-sfs-tip-scf       not  = 09 and
                     rf-sfs-tip-scf       not  = 10 and
                     rf-sfs-tip-scf       not  = 11
                     go to sel-sfs-nbl-300.
      *                  *---------------------------------------------*
      *                  * Test su tipo registrazione scadenza         *
      *                  *---------------------------------------------*
           if        rf-sfs-trs-scf       not  = 01
                     go to sel-sfs-nbl-300.
      *                  *---------------------------------------------*
      *                  * Test su tipo operazione di pagamento        *
      *                  *---------------------------------------------*
           if        w-tes-tip-ope        not  = 1750
                     go to sel-sfs-nbl-300.
      *                  *---------------------------------------------*
      *                  * Se codice nostra banca d'appoggio contenuta *
      *                  * nella scadenza e' a spazi : selezione supe- *
      *                  * rata                                        *
      *                  *---------------------------------------------*
           if        rf-sfs-cbp-nsb       =    spaces
                     go to sel-sfs-nbl-300.
      *                  *---------------------------------------------*
      *                  * Test di selezione                           *
      *                  *---------------------------------------------*
           if        rf-sfs-cbp-nsb       =    w-tes-cbp-pgf (1)
                     go to sel-sfs-nbl-300.
      *                  *---------------------------------------------*
      *                  * Trattamento errore                          *
      *                  *---------------------------------------------*
           move      13                   to   w-sel-sfs-nbl-flg      .
           move      "Diversa nostra banca d'appoggio                   
      -              "               "    to   w-sel-sfs-nbl-err      .
           go to     sel-sfs-nbl-999.
       sel-sfs-nbl-300.
      *              *-------------------------------------------------*
      *              * Codice ABI, CAB e c/c per il pagamento          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo scadenza                       *
      *                  *---------------------------------------------*
           if        rf-sfs-tip-scf       not  = 07
                     go to sel-sfs-nbl-400.
      *                  *---------------------------------------------*
      *                  * Test su tipo operazione di pagamento        *
      *                  *---------------------------------------------*
           if        w-tes-tip-ope        not  = 1730
                     go to sel-sfs-nbl-400.
      *                  *---------------------------------------------*
      *                  * Test di selezione                           *
      *                  *---------------------------------------------*
           if        rf-sfs-abi-fnt       =    w-tes-abi-pgf (1) and
                     rf-sfs-cab-fnt       =    w-tes-cab-pgf (1) and
                     rf-sfs-ccc-fnt       =    w-tes-ccc-pgf (1)
                     go to sel-sfs-nbl-400.
      *                  *---------------------------------------------*
      *                  * Trattamento errore                          *
      *                  *---------------------------------------------*
           move      14                   to   w-sel-sfs-nbl-flg      .
           move      "Diversi codici ABI, CAB e C/C bancario            
      -              "               "    to   w-sel-sfs-nbl-err      .
           go to     sel-sfs-nbl-999.
       sel-sfs-nbl-400.
      *              *-------------------------------------------------*
      *              * Codice c/c postale per il pagamento             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo scadenza                       *
      *                  *---------------------------------------------*
           if        rf-sfs-tip-scf       not  = 08
                     go to sel-sfs-nbl-500.
      *                  *---------------------------------------------*
      *                  * Test su tipo operazione di pagamento        *
      *                  *---------------------------------------------*
           if        w-tes-tip-ope        not  = 1740
                     go to sel-sfs-nbl-500.
      *                  *---------------------------------------------*
      *                  * Test di selezione                           *
      *                  *---------------------------------------------*
           if        rf-sfs-ccc-fnt       =    w-tes-ccc-pgf (1)
                     go to sel-sfs-nbl-500.
      *                  *---------------------------------------------*
      *                  * Trattamento errore                          *
      *                  *---------------------------------------------*
           move      15                   to   w-sel-sfs-nbl-flg      .
           move      "Diverso codice C/C postale                        
      -              "               "    to   w-sel-sfs-nbl-err      .
           go to     sel-sfs-nbl-999.
       sel-sfs-nbl-500.
      *              *-------------------------------------------------*
      *              * Codice banca estera del fornitore               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo scadenza                       *
      *                  *---------------------------------------------*
           if        rf-sfs-tip-scf       not  = 07
                     go to sel-sfs-nbl-600.
      *                  *---------------------------------------------*
      *                  * Test su tipo valuta scadenza                *
      *                  *---------------------------------------------*
           if        rf-sfs-tvl-scf       not  = 02
                     go to sel-sfs-nbl-600.
      *                  *---------------------------------------------*
      *                  * Test su tipo operazione di pagamento        *
      *                  *---------------------------------------------*
           if        w-tes-tip-ope        not  = 1731
                     go to sel-sfs-nbl-600.
      *                  *---------------------------------------------*
      *                  * Test di selezione                           *
      *                  *---------------------------------------------*
           if        rf-sfs-cod-bef       =    w-tes-bef-pgf (1)
                     go to sel-sfs-nbl-600.
      *                  *---------------------------------------------*
      *                  * Trattamento errore                          *
      *                  *---------------------------------------------*
           move      16                   to   w-sel-sfs-nbl-flg      .
           move      "Diverso codice banca estera                       
      -              "               "    to   w-sel-sfs-nbl-err      .
           go to     sel-sfs-nbl-999.
       sel-sfs-nbl-600.
      *              *-------------------------------------------------*
      *              * Selezioni superate                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-sel-sfs-nbl-flg      .
           move      spaces               to   w-sel-sfs-nbl-err      .
       sel-sfs-nbl-999.
           exit.

      *    *===========================================================*
      *    * Routine di attribuzione numero pagamento                  *
      *    *-----------------------------------------------------------*
       att-sfp-num-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfpnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfp-num             .
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [numddp]                                  *
      *              *-------------------------------------------------*
           move      w-sfp-num-scl-ann    to   rn-sfp-num-scl-ann     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [numddp]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfpnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfp-num             .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-sfp-num-400.
       att-sfp-num-200.
      *              *-------------------------------------------------*
      *              * Se record non esistente                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Scrittura record normalizzato               *
      *                  *---------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfpnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfp-num             .
      *                  *---------------------------------------------*
      *                  * Unlock record                               *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfpnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfp-num             .
      *                  *---------------------------------------------*
      *                  * Ripetizione dell'intera operazione          *
      *                  *---------------------------------------------*
           go to     att-sfp-num-000.
       att-sfp-num-400.
      *              *-------------------------------------------------*
      *              * Se record esistente                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore pre-incremento           *
      *                  *---------------------------------------------*
           move      rn-sfp-num-num-pgf   to   w-sfp-num-num-pgf      .
           move      w-sfp-num-r01-num    to   w-sfp-num-val-pre      .
      *                  *---------------------------------------------*
      *                  * Preparazione valore post-incremento         *
      *                  *---------------------------------------------*
           move      w-sfp-num-val-pre    to   w-sfp-num-val-pos      .
           add       1                    to   w-sfp-num-val-pos      .
           if        w-sfp-num-val-pos    =    zero
                     move  1              to   w-sfp-num-val-pos      .
      *                  *---------------------------------------------*
      *                  * Preparazione numero pagamento completo      *
      *                  *---------------------------------------------*
           move      w-sfp-num-scl-ann    to   w-sfp-num-r01-saa      .
           move      w-sfp-num-val-pos    to   w-sfp-num-r01-num      .
      *                  *---------------------------------------------*
      *                  * Aggiornamento numero pagamento              *
      *                  *---------------------------------------------*
           move      w-sfp-num-num-pgf    to   rn-sfp-num-num-pgf     .
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfpnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfp-num             .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'esito dell'opera- *
      *                  * zione di update                             *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-sfp-num-600.
       att-sfp-num-500.
      *                  *---------------------------------------------*
      *                  * Se errore in operazione di update           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfpnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfp-num             .
      *                      *-----------------------------------------*
      *                      * Ripetizione dell'intera operazione      *
      *                      *-----------------------------------------*
           go to     att-sfp-num-000.
       att-sfp-num-600.
      *                  *---------------------------------------------*
      *                  * Se nessun errore in operazione di update    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfpnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfp-num             .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     att-sfp-num-999.
       att-sfp-num-999.
           exit.

      *    *===========================================================*
      *    * Routine di ripristino numero pagamento                    *
      *    *-----------------------------------------------------------*
       rip-sfp-num-000.
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [numddp]                                  *
      *              *-------------------------------------------------*
           move      w-sfp-num-scl-ann    to   rn-sfp-num-scl-ann     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [numddp]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfpnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfp-num             .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to rip-sfp-num-400.
       rip-sfp-num-200.
      *              *-------------------------------------------------*
      *              * Se record non esistente                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Unlock record                               *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfpnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfp-num             .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     rip-sfp-num-999.
       rip-sfp-num-400.
      *              *-------------------------------------------------*
      *              * Se record esistente                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Confronto tra il numero pagamento attuale   *
      *                  * contenuto nel record numerazioni ed il va-  *
      *                  * lore post-incremento, e deviazione in fun-  *
      *                  * zione dell'esito del test                   *
      *                  *---------------------------------------------*
           move      rn-sfp-num-num-pgf   to   w-sfp-num-num-pgf      .
           if        w-sfp-num-r01-num    =    w-sfp-num-val-pos
                     go to rip-sfp-num-600.
       rip-sfp-num-500.
      *                  *---------------------------------------------*
      *                  * Se numero pagamento attuale contenuto nel   *
      *                  * record numerazioni diverso dal valore post- *
      *                  * incremento                                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfpnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfp-num             .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rip-sfp-num-999.
       rip-sfp-num-600.
      *                  *---------------------------------------------*
      *                  * Se numero pagamento attuale contenuto nel   *
      *                  * record numerazioni uguale al valore post-   *
      *                  * incremento                                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controaggiornamento del valore attuale  *
      *                      * contenuto nel record numerazioni, ri-   *
      *                      * portandolo al valore pre-incremento     *
      *                      *-----------------------------------------*
           move      w-sfp-num-val-pre    to   w-sfp-num-r01-num      .
           if        w-sfp-num-val-pre    =    zero
                     move  zero           to   w-sfp-num-num-pgf      .
           move      w-sfp-num-num-pgf    to   rn-sfp-num-num-pgf     .
      *                      *-----------------------------------------*
      *                      * Update record numerazioni               *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfpnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfp-num             .
      *                      *-----------------------------------------*
      *                      * Unlock record numerazioni               *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfpnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfp-num             .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rip-sfp-num-999.
       rip-sfp-num-999.
           exit.

