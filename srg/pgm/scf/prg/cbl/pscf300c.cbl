       cge-scf-pgf-snx-000.
      *              *-------------------------------------------------*
      *              * Se le personalizzazioni indicano che in ogni    *
      *              * caso gli aggiornamenti contabili non devono     *
      *              * essere eseguiti : uscita con 'N'                *
      *              *-------------------------------------------------*
           if        w-prs-scf-snx-cge    =    "N"
                     move  "N"            to   w-cge-scf-pgf-snx
                     go to cge-scf-pgf-snx-999.
       cge-scf-pgf-snx-025.
      *              *-------------------------------------------------*
      *              * Se il tipo operazione non prevede aggiornamento *
      *              * contabile : uscita con 'N'                      *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        not  = 1510 and
                     w-tes-tip-ope        not  = 1520 and
                     w-tes-tip-ope        not  = 1530 and
      *
                     w-tes-tip-ope        not  = 1610 and
                     w-tes-tip-ope        not  = 1620 and
                     w-tes-tip-ope        not  = 1630 and
                     w-tes-tip-ope        not  = 1640
                     move  "N"            to   w-cge-scf-pgf-snx
                     go to cge-scf-pgf-snx-999.
      *              *-------------------------------------------------*
      *              * Se il codice causale contabile per il tipo ope- *
      *              * razione di pagamento e' a zero : uscita con 'N' *
      *              *-------------------------------------------------*
           if        w-top-cau-cge
                    (w-top-ele-inx)       =    zero
                     move  "N"            to   w-cge-scf-pgf-snx
                     go to cge-scf-pgf-snx-999.
       cge-scf-pgf-snx-050.
      *              *-------------------------------------------------*
      *              * Altrimenti si esce con 'S'                      *
      *              *-------------------------------------------------*
           move      "S"                  to   w-cge-scf-pgf-snx      .
       cge-scf-pgf-snx-999.
           exit.

