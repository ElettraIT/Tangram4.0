           move      spaces               to   w-tes-fda-sel (1)      .
           move      spaces               to   w-tes-fda-sdc (1)      .
           move      spaces               to   w-tes-fda-pie (1)      .
           move      zero                 to   w-tes-drc-pgf (1)      .
           move      zero                 to   w-tes-npc-pgf (1)      .
           move      zero                 to   w-tes-mod-pgf (1)      .
           move      zero                 to   w-tes-tvl-pgf (1)      .
           move      zero                 to   w-tes-cod-fnt (1)      .
           move      spaces               to   w-tes-cod-fnt-rag (1)  .
           move      zero                 to   w-tes-cod-fnt-cge (1)  .
           move      spaces               to   w-tes-dpz-fnt (1)      .
           move      spaces               to   w-tes-dpz-fnt-rag (1)  .
           move      spaces               to   w-tes-dpz-fnt-via (1)  .
           move      spaces               to   w-tes-dpz-fnt-loc (1)  .
           move      zero                 to   w-tes-inl-pgf (1)      .
           move      spaces               to   w-tes-cbp-pgf (1)      .
           move      spaces               to   w-tes-cbp-pgf-des (1)  .
           move      zero                 to   w-tes-cbp-pgf-stc (1)  .
           move      zero                 to   w-tes-tip-pgf (1)      .
           move      zero                 to   w-tes-abi-pgf (1)      .
           move      spaces               to   w-tes-abi-pgf-den (1)  .
           move      zero                 to   w-tes-cab-pgf (1)      .
           move      spaces               to   w-tes-cab-pgf-den (1)  .
           move      zero                 to   w-tes-bef-pgf (1)      .
           move      spaces               to   w-tes-bef-pgf-des (1)  .
           move      spaces               to   w-tes-bef-pgf-fil (1)  .
           move      spaces               to   w-tes-bef-pgf-ccc (1)  .
           move      spaces               to   w-tes-ccc-pgf (1)      .
           move      spaces               to   w-tes-sgl-vlt (1)      .
           move      zero                 to   w-tes-dec-vlt (1)      .
           move      spaces               to   w-tes-tdc-vlt (1)      .
           move      zero                 to   w-tes-cdc-pgf (1)      .
           move      zero                 to   w-tes-ddo-pgf (1)      .
           move      spaces               to   w-tes-ndo-pgf (1)      .
           move      zero                 to   w-tes-sel-tsf (1)      .
           move      zero                 to   w-tes-sel-scf (1)      .
           move      zero                 to   w-tes-sel-imp (1)      .
           move      zero                 to   w-tes-sel-dsi (1)      .
           move      zero                 to   w-tes-sel-dsf (1)      .
           move      zero                 to   w-tes-sel-mes (1)      .
           move      zero                 to   w-nor-nok-tes-ctr      .
       nor-nok-tes-100.
           add       1                    to   w-nor-nok-tes-ctr      .
           if        w-nor-nok-tes-ctr    >    7
                     go to nor-nok-tes-120.
           move      zero                 to   w-tes-sel-tpm-saa
                                              (1,
                                               w-nor-nok-tes-ctr)     .
           move      zero                 to   w-tes-sel-tpm-mes
                                              (1,
                                               w-nor-nok-tes-ctr)     .
           move      zero                 to   w-tes-sel-tpm-prg
                                              (1,
                                               w-nor-nok-tes-ctr,
                                               1                )     .
           move      zero                 to   w-tes-sel-tpm-prg
                                              (1,
                                               w-nor-nok-tes-ctr,
                                               2                )     .
           go to     nor-nok-tes-100.
       nor-nok-tes-120.
           move      zero                 to   w-tes-sel-tpm-tot
                                              (1, 1)                  .
           move      zero                 to   w-tes-sel-tpm-tot
                                              (1, 2)                  .
           move      zero                 to   w-tes-tot-rss (1)      .
           move      zero                 to   w-tes-num-adp (1)      .
           move      zero                 to   w-tes-fcs-uno (1)      .
           move      zero                 to   w-tes-fcs-due (1)      .
