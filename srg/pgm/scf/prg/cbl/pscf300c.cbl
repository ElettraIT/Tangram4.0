      *              *-------------------------------------------------*
           move      w-exp-sel-tsf-n05    to   w-exp-sel-tsf-num      .
           move      w-exp-sel-tsf-t05    to   w-exp-sel-tsf-tbl      .
           move      w-exp-sel-tsf-v05    to   w-exp-sel-tsf-val      .
