      *    *===========================================================*
      *    * Input procedure per sort in fase di caricamento righe     *
      *    * scadenze fornitore relative ad un operazione di pagamento *
      *    *-----------------------------------------------------------*
       rou-let-reg-inp-000.
      *              *-------------------------------------------------*
      *              * Start su file [sfs]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "FNTPGF    "         to   f-key                  .
           move      w-tes-cod-fnt (1)    to   rf-sfs-cod-fnt         .
           move      w-tes-num-pgf        to   rf-sfs-num-pgf         .
           move      zero                 to   rf-sfs-num-scf         .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfs                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rou-let-reg-inp-999.
       rou-let-reg-inp-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [sfs]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfs                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rou-let-reg-inp-999.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-sfs-cod-fnt       not  = w-tes-cod-fnt (1) or
                     rf-sfs-num-pgf       not  = w-tes-num-pgf
                     go to rou-let-reg-inp-999.
       rou-let-reg-inp-300.
      *              *-------------------------------------------------*
      *              * Composizione sort-record                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Chiave del sort                             *
      *                  *---------------------------------------------*
           if        rf-sfs-dts-scf       =    zero
                     move  w-tes-dat-reg  to   srt-dts-eff
           else      move  rf-sfs-dts-scf to   srt-dts-eff            .
           move      rf-sfs-num-scf       to   srt-num-scf            .
      *                  *---------------------------------------------*
      *                  * Dati del sort                               *
      *                  *---------------------------------------------*
           move      rf-sfs-tip-scf       to   srt-tip-scf            .
           move      rf-sfs-trs-scf       to   srt-trs-scf            .
           move      rf-sfs-tvl-scf       to   srt-tvl-scf            .
           move      rf-sfs-tip-ddr       to   srt-tip-ddr            .
           move      rf-sfs-num-ddr       to   srt-num-ddr            .
           move      rf-sfs-dat-ddr       to   srt-dat-ddr            .
           if        rf-sfs-tvl-scf       =    02
                     move  rf-sfs-iiv-scf to   srt-imp-scf
           else      move  rf-sfs-imp-scf to   srt-imp-scf            .
           if        rf-sfs-tip-ddr       =    11
                     multiply -1          by   srt-imp-scf            .
           move      rf-sfs-dts-scf       to   srt-dts-scf            .
           move      rf-sfs-snx-pbl       to   srt-snx-pbl            .
       rou-let-reg-inp-400.
      *              *-------------------------------------------------*
      *              * Rilascio record al sort                         *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       rou-let-reg-inp-500.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale record [sfs]     *
      *              *-------------------------------------------------*
           go to     rou-let-reg-inp-100.
       rou-let-reg-inp-999.
           exit.

      *    *===========================================================*
      *    * Output procedure per sort in fase di caricamento righe    *
