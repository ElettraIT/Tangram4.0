      *                      * Valori contenuti direttamente in record *
      *                      * [sfs]                                   *
      *                      *-----------------------------------------*
           move      rf-sfs-num-scf       to   w-rig-num-scf (1)      .
           move      rf-sfs-tip-scf       to   w-rig-tip-scf (1)      .
           move      rf-sfs-trs-scf       to   w-rig-trs-scf (1)      .
           move      rf-sfs-tvl-scf       to   w-rig-tvl-scf (1)      .
           move      rf-sfs-tip-ddr       to   w-rig-tip-ddr (1)      .
           move      rf-sfs-num-ddr       to   w-rig-num-ddr (1)      .
           move      rf-sfs-dat-ddr       to   w-rig-dat-ddr (1)      .
           if        rf-sfs-tvl-scf       =    02
                     move  rf-sfs-iiv-scf to   w-rig-imp-scf (1)
