      *                      *-----------------------------------------*
      *                      * Preparazione link-area per riga movi-   *
      *                      * mento                                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Tipo operazione                     *
      *                          *-------------------------------------*
           move      "W+"                 to   l-cge-300-tip-ope      .
      *                          *-------------------------------------*
      *                          * Codice sottoconto                   *
      *                          *-------------------------------------*
           move      w-top-stc-cge
                    (w-top-ele-inx)       to   l-cge-300-cod-pdc      .
      *                          *-------------------------------------*
      *                          * Tipo archivio                       *
      *                          *-------------------------------------*
           move      "G"                  to   l-cge-300-tip-arc      .
      *                          *-------------------------------------*
      *                          * Codice archivio                     *
      *                          *-------------------------------------*
           move      zero                 to   l-cge-300-cod-arc      .
      *                          *-------------------------------------*
      *                          * Data riferimento                    *
      *                          *-------------------------------------*
           move      zero                 to   l-cge-300-dat-rif      .
      *                          *-------------------------------------*
      *                          * Numero riferimento                  *
      *                          *-------------------------------------*
           move      spaces               to   l-cge-300-num-rif      .
      *                          *-------------------------------------*
      *                          * Dare/Avere                          *
      *                          *-------------------------------------*
           move      "D"                  to   l-cge-300-dar-ave      .
      *                          *-------------------------------------*
      *                          * Importo movimento : importo abbuono *
      *                          *-------------------------------------*
           move      w-cge-scf-pgf-abb    to   l-cge-300-imp-mov      .
      *                      *-----------------------------------------*
      *                      * Richiamo sottoprogramma per aggiorna-   *
      *                      * menti contabili                         *
      *                      *-----------------------------------------*
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
       cge-scf-pgf-700.
      *                  *---------------------------------------------*
      *                  * Riga per abbuono attivo                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se esistente                       *
      *                      *-----------------------------------------*
           if        w-cge-scf-pgf-sna    not  = "A"
                     go to cge-scf-pgf-800.
      *                      *-----------------------------------------*
      *                      * Normalizzazione work-area riga movimen- *
      *                      * to per aggiornamenti contabili          *
      *                      *-----------------------------------------*
           move      "N+"                 to   l-cge-300-tip-ope      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                      *-----------------------------------------*
      *                      * Preparazione link-area per riga movi-   *
      *                      * mento                                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Tipo operazione                     *
      *                          *-------------------------------------*
           move      "W+"                 to   l-cge-300-tip-ope      .
      *                          *-------------------------------------*
      *                          * Codice sottoconto                   *
      *                          *-------------------------------------*
           move      w-top-ctp-cge
                    (w-top-ele-inx)       to   l-cge-300-cod-pdc      .
      *                          *-------------------------------------*
      *                          * Tipo archivio                       *
      *                          *-------------------------------------*
           move      "G"                  to   l-cge-300-tip-arc      .
      *                          *-------------------------------------*
      *                          * Codice archivio                     *
      *                          *-------------------------------------*
           move      zero                 to   l-cge-300-cod-arc      .
      *                          *-------------------------------------*
      *                          * Data riferimento                    *
      *                          *-------------------------------------*
           move      zero                 to   l-cge-300-dat-rif      .
      *                          *-------------------------------------*
      *                          * Numero riferimento                  *
      *                          *-------------------------------------*
           move      spaces               to   l-cge-300-num-rif      .
      *                          *-------------------------------------*
      *                          * Dare/Avere                          *
      *                          *-------------------------------------*
           move      "A"                  to   l-cge-300-dar-ave      .
      *                          *-------------------------------------*
      *                          * Importo movimento : importo abbuono *
      *                          *-------------------------------------*
           move      w-cge-scf-pgf-abb    to   l-cge-300-imp-mov      .
      *                      *-----------------------------------------*
      *                      * Richiamo sottoprogramma per aggiorna-   *
      *                      * menti contabili                         *
      *                      *-----------------------------------------*
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
       cge-scf-pgf-800.
      *                  *---------------------------------------------*
      *                  * Riga per contropartita del pagamento        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione work-area riga movimen- *
      *                      * to per aggiornamenti contabili          *
      *                      *-----------------------------------------*
           move      "N+"                 to   l-cge-300-tip-ope      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                      *-----------------------------------------*
      *                      * Preparazione link-area per riga movi-   *
      *                      * mento successiva alla prima             *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Tipo operazione                     *
      *                          *-------------------------------------*
           move      "W+"                 to   l-cge-300-tip-ope      .
      *                          *-------------------------------------*
      *                          * Codice sottoconto                   *
      *                          *                                     *
      *                          * - se 1510 o 1610 : Sottoconto cassa *
      *                          *                    contanti         *
      *                          * - se 1520 o 1620 : Sottoconto cassa *
      *                          *                    assegni          *
      *                          *-------------------------------------*
           move      w-tes-cbp-pgf-stc (1)
                                          to   l-cge-300-cod-pdc      .
      *                          *-------------------------------------*
      *                          * Tipo archivio                       *
      *                          *-------------------------------------*
           move      "G"                  to   l-cge-300-tip-arc      .
      *                          *-------------------------------------*
      *                          * Codice archivio                     *
      *                          *-------------------------------------*
           move      zero                 to   l-cge-300-cod-arc      .
      *                          *-------------------------------------*
      *                          * Data riferimento                    *
      *                          *-------------------------------------*
           move      zero                 to   l-cge-300-dat-rif      .
      *                          *-------------------------------------*
      *                          * Numero riferimento                  *
      *                          *-------------------------------------*
           move      spaces               to   l-cge-300-num-rif      .
      *                          *-------------------------------------*
      *                          * Dare/Avere                          *
      *                          *-------------------------------------*
           if        w-pie-imp-pgf (1)    <    zero
                     move  "D"            to   l-cge-300-dar-ave
           else      move  "A"            to   l-cge-300-dar-ave      .
      *                          *-------------------------------------*
      *                          * Importo movimento                   *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Importo pagamento               *
      *                              *---------------------------------*
           move      w-pie-imp-pgf (1)    to   l-cge-300-imp-mov      .
           if        w-pie-imp-pgf (1)    <    zero
                     multiply -1          by   l-cge-300-imp-mov      .
      *                              *---------------------------------*
      *                              * Aggiustamento con spese addebi- *
      *                              * tate                            *
      *                              *---------------------------------*
           if        w-pie-spe-pgf (1)    >    zero and
                     w-tes-cbp-pgf-sto (1)
                                          not  = zero
                     add   w-pie-spe-pgf (1)
                                          to   l-cge-300-imp-mov      .
      *                      *-----------------------------------------*
      *                      * Richiamo sottoprogramma per aggiorna-   *
      *                      * menti contabili                         *
      *                      *-----------------------------------------*
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
       cge-scf-pgf-999.
           exit.

      *    *===========================================================*
      *    * Determinazione se presenti dipendenze per il fornitore    *
      *    * commerciale                                               *
      *    *-----------------------------------------------------------*
       det-snd-dcf-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di esito                   *
      *              *-------------------------------------------------*
           move      "N"                  to   w-det-snd-dcf-snx      .
      *              *-------------------------------------------------*
      *              * Normalizzazione codice dipendenza unica         *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-snd-dcf-dpz      .
      *              *-------------------------------------------------*
      *              * Normalizzazione contatore                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-snd-dcf-ctr      .
      *              *-------------------------------------------------*
      *              * Start su file [dcf]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CODFNT    "         to   f-key                  .
           move      w-det-snd-dcf-fnt    to   rf-dcf-cod-fnt         .
           move      spaces               to   rf-dcf-dpz-fnt         .
           move      "pgm/dcf/fls/ioc/obj/iofdcf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcf                 .
      *              *-------------------------------------------------*
      *              * Se Start errata : uscita con flag a 'no'        *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-snd-dcf-999.
       det-snd-dcf-100.
      *              *-------------------------------------------------*
      *              * Next su [dcf]                                   *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcf/fls/ioc/obj/iofdcf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcf                 .
      *              *-------------------------------------------------*
      *              * Se 'at end' : a test finale                     *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-snd-dcf-800.
      *              *-------------------------------------------------*
      *              * Max su [dcf], se non superato : a test finale   *
      *              *-------------------------------------------------*
           if        rf-dcf-cod-fnt       not  = w-det-snd-dcf-fnt
                     go to det-snd-dcf-800.
       det-snd-dcf-200.
      *              *-------------------------------------------------*
      *              * Test sul codice dipendenza                      *
      *              *-------------------------------------------------*
           if        rf-dcf-dpz-fnt       =    spaces
                     go to det-snd-dcf-100.
       det-snd-dcf-300.
      *              *-------------------------------------------------*
      *              * Incremento contatore                            *
      *              *-------------------------------------------------*
           add       1                    to   w-det-snd-dcf-ctr      .
       det-snd-dcf-300.
      *              *-------------------------------------------------*
      *              * Bufferizzazione del primo codice dipendenza     *
      *              *-------------------------------------------------*
           if        w-det-snd-dcf-ctr    >    1
                     go to det-snd-dcf-500.
           move      rf-dcf-dpz-fnt       to   w-det-snd-dcf-dpz      .
       det-snd-dcf-500.
      *              *-------------------------------------------------*
      *              * Riciclo a record [dcf] successivo               *
      *              *-------------------------------------------------*
           go to     det-snd-dcf-100.
       det-snd-dcf-800.
      *              *-------------------------------------------------*
      *              * Determinazione finale                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se durante la ricerca e' stato trovato un   *
      *                  * numero di dipendenze superiore a zero si    *
      *                  * esce con il flag di presenza a 'S'          *
      *                  *---------------------------------------------*
           if        w-det-snd-dcf-ctr    >    zero
                     go to det-snd-dcf-900
           else      go to det-snd-dcf-999.
       det-snd-dcf-900.
      *              *-------------------------------------------------*
      *              * Uscita per dipendenze trovate                   *
      *              *-------------------------------------------------*
           move      "S"                  to   w-det-snd-dcf-snx      .
       det-snd-dcf-999.
           exit.

      *    *===========================================================*
      *    * Preparazione movimento di contabilita' generale           *
      *    *-----------------------------------------------------------*
       det-mov-cge-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni iniziali                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Contatore numero di scadenze bufferizzate   *
      *                  *---------------------------------------------*
           move      zero                 to   w-mov-cge-ctr-scf      .
      *                  *---------------------------------------------*
      *                  * Contatore numero di righe movimento buffe-  *
      *                  * rizzate                                     *
      *                  *---------------------------------------------*
           move      zero                 to   w-mov-cge-ctr-rig      .
      *                  *---------------------------------------------*
      *                  * Flag di aggiornamento non eseguibile per a- *
      *                  * nomalie intervenute nella rilettura catena  *
      *                  * righe                                       *
      *                  *---------------------------------------------*
           move      spaces               to   w-mov-cge-flg-nag      .
      *                  *---------------------------------------------*
      *                  * Accumulo per il sottoconto di pagamento,    *
      *                  * ovvero per l'importo in Avere               *
      *                  *---------------------------------------------*
           move      zero                 to   w-mov-cge-acc-sdp      .
      *              *-------------------------------------------------*
      *              * Salvataggio catena movimenti                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio area w-rig                      *
      *                  *---------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *                  *---------------------------------------------*
      *                  * Salvataggio area catena                     *
      *                  *---------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Start su righe corpo in catena movimenti        *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se start non valida : a fine trattamento    *
      *                  * righe                                       *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to det-mov-cge-500.
       det-mov-cge-100.
      *              *-------------------------------------------------*
      *              * Next su righe corpo in catena movimenti         *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se at end : a fine trattamento righe        *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to det-mov-cge-500.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to det-mov-cge-100.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work per *
      *              * riga w-rig                                      *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se numero scadenza a zero : riciclo             *
      *              *-------------------------------------------------*
           if        w-rig-num-scf (1)    =    zero
                     go to det-mov-cge-100.
       det-mov-cge-200.
      *              *-------------------------------------------------*
      *              * Determinazione indice su tabella tipi operazio- *
      *              * ne, relativo al tipo operazione di registrazio- *
      *              * che ha generato la scadenza in esame            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione codice tipo operazione di    *
      *                  * registrazione                               *
      *                  *---------------------------------------------*
           if        w-rig-tip-scf (1)    =    01
                     move  1101           to   w-mov-cge-wop-reg
           else if   w-rig-tip-scf (1)    =    02
                     move  1102           to   w-mov-cge-wop-reg
           else if   w-rig-tip-scf (1)    =    03
                     move  1103           to   w-mov-cge-wop-reg
           else if   w-rig-tip-scf (1)    =    04
                     move  1104           to   w-mov-cge-wop-reg
           else if   w-rig-tip-scf (1)    =    05
                     move  1105           to   w-mov-cge-wop-reg
           else if   w-rig-tip-scf (1)    =    06
                     move  1106           to   w-mov-cge-wop-reg
           else if   w-rig-tip-scf (1)    =    07
                     if       w-rig-tvl-scf (1)
                                          =    01
                              move  1107  to   w-mov-cge-wop-reg
                     else if  w-rig-tvl-scf (1)
                                          =    02
                              move  1127  to   w-mov-cge-wop-reg
                     else     move  zero  to   w-mov-cge-wop-reg
           else if   w-rig-tip-scf (1)    =    08
                     move  1108           to   w-mov-cge-wop-reg
           else if   w-rig-tip-scf (1)    =    09
                     move  1109           to   w-mov-cge-wop-reg
           else if   w-rig-tip-scf (1)    =    10
                     move  1110           to   w-mov-cge-wop-reg
           else if   w-rig-tip-scf (1)    =    11
                     if       w-rig-trs-scf (1)
                                          =    01
                              move  1111  to   w-mov-cge-wop-reg
                     else if  w-rig-trs-scf (1)
                                          =    02
                              move  1161  to   w-mov-cge-wop-reg
                     else     move  zero  to   w-mov-cge-wop-reg
           else      move  zero           to   w-mov-cge-wop-reg      .
      *                  *---------------------------------------------*
      *                  * Se non determinabile si pone in On il flag  *
      *                  * di aggiornamento contabile da non eseguire, *
      *                  * e si escludono le totalizzazioni per il mo- *
      *                  * vimento di contabilita' generale            *
      *                  *---------------------------------------------*
           if        w-mov-cge-wop-reg    not  = zero
                     go to det-mov-cge-220.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      w-rig-num-scf (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      spaces               to   w-err-box-err-msg      .
           string    "Attenzione : Anomalia relativa alla scadenza nr. "
                                delimited by   size
                     v-edt      delimited by   spaces
                     "!"        delimited by   size
                                          into w-err-box-err-msg      .
           move      "             Il tipo della scadenza non e' riconos
      -              "ciuto.         "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                      *-----------------------------------------*
      *                      * Flag di aggiornamento contabile da non  *
      *                      * eseguire                                *
      *                      *-----------------------------------------*
           move      "#"                  to   w-mov-cge-flg-nag      .
      *                      *-----------------------------------------*
      *                      * A riciclo su lettura catena             *
      *                      *-----------------------------------------*
           go to     det-mov-cge-400.
       det-mov-cge-220.
      *                  *---------------------------------------------*
      *                  * Ricerca del tipo operazione cosi' determi-  *
      *                  * nato in tabella tipi operazione.            *
      *                  * Se non si trova l'elemento si pone in On il *
      *                  * flag di aggiornamento contabile da non ese- *
      *                  * guire e si escludono le totalizzazioni      *
      *                  *---------------------------------------------*
           move      zero                 to   w-mov-cge-wix-reg      .
       det-mov-cge-240.
           add       1                    to   w-mov-cge-wix-reg      .
           if        w-mov-cge-wix-reg    >    w-top-ele-num
                     go to det-mov-cge-260.
           if        w-top-cod-top
                    (w-mov-cge-wix-reg)   =    w-mov-cge-wop-reg
                     go to det-mov-cge-300
           else      go to det-mov-cge-240.
       det-mov-cge-260.
      *                      *-----------------------------------------*
      *                      * Se l'indice non e' determinato          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Messaggio di errore                 *
      *                          *-------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      w-rig-num-scf (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      spaces               to   w-err-box-err-msg      .
           string    "Attenzione : Anomalia relativa alla scadenza nr. "
                                delimited by   size
                     v-edt      delimited by   spaces
                     "!"        delimited by   size
                                          into w-err-box-err-msg      .
           move      "             Tipo operazione di registrazione non 
      -              "personalizzato."    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                          *-------------------------------------*
      *                          * Flag di aggiornamento contabile da  *
      *                          * non eseguire                        *
      *                          *-------------------------------------*
           move      "#"                  to   w-mov-cge-flg-nag      .
      *                          *-------------------------------------*
      *                          * A riciclo su lettura catena         *
      *                          *-------------------------------------*
           go to     det-mov-cge-400.
       det-mov-cge-300.
      *              *-------------------------------------------------*
      *              * Incremento numero scadenze bufferizzate         *
      *              *-------------------------------------------------*
           add       1                    to   w-mov-cge-ctr-scf      .
      *              *-------------------------------------------------*
      *              * Accumulo per il sottoconto di pagamento, ovvero *
      *              * per l'importo in Avere                          *
      *              *-------------------------------------------------*
           add       w-rig-imp-scf (1)    to   w-mov-cge-acc-sdp      .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda che esistano o meno sia la *
      *              * causale contabile che il sottoconto contabile,  *
      *              * per il tipo di operazione di registrazione in   *
      *              * esame                                           *
      *              *-------------------------------------------------*
           if        w-top-cau-cge
                    (w-mov-cge-wix-reg)   =    zero or
                     w-top-stc-cge
                    (w-mov-cge-wix-reg)   =    zero
                     go to det-mov-cge-320
           else      go to det-mov-cge-340.
       det-mov-cge-320.
      *              *-------------------------------------------------*
      *              * Se o la causale contabile o il sottoconto con-  *
      *              * tabile, non esistenti                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Incremento numero elementi in tabella       *
      *                  *---------------------------------------------*
           add       1                    to   w-mov-cge-ctr-rig      .
      *                  *---------------------------------------------*
      *                  * Tipo sottoconto                             *
      *                  *---------------------------------------------*
           move      "F"                  to   w-mov-cge-tip-con
                                              (w-mov-cge-ctr-rig)     .
      *                  *---------------------------------------------*
      *                  * Codice del sottoconto per la riga           *
      *                  *---------------------------------------------*
           move      w-tes-cod-fnt (1)    to   w-mov-cge-cod-con
                                              (w-mov-cge-ctr-rig)     .
      *                  *---------------------------------------------*
      *                  * Data documento di riferimento               *
      *                  *---------------------------------------------*
           move      w-rig-dat-ddr (1)    to   w-mov-cge-dat-rif
                                              (w-mov-cge-ctr-rig)     .
      *                  *---------------------------------------------*
      *                  * Numero documento di riferimento             *
      *                  *---------------------------------------------*
           move      w-rig-num-ddr (1)    to   w-mov-cge-num-rif
                                              (w-mov-cge-ctr-rig)     .
      *                  *---------------------------------------------*
      *                  * Flag di Dare/Avere                          *
      *                  *---------------------------------------------*
           move      spaces               to   w-mov-cge-dar-ave
                                              (w-mov-cge-ctr-rig)     .
      *                  *---------------------------------------------*
      *                  * Importo per la riga                         *
      *                  *---------------------------------------------*
           move      w-rig-imp-scf (1)    to   w-mov-cge-imp-rig
                                              (w-mov-cge-ctr-rig)     .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     det-mov-cge-400.
       det-mov-cge-340.
      *              *-------------------------------------------------*
      *              * Se la causale contabile e il sottoconto conta-  *
      *              * bile entrambi esistenti                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ciclo per determinare se codice sottoconto  *
      *                  * gia' presente in tabella                    *
      *                  *---------------------------------------------*
           move      zero                 to   w-mov-cge-inx-001      .
       det-mov-cge-342.
           add       1                    to   w-mov-cge-inx-001      .
      *                      *-----------------------------------------*
      *                      * Se oltre il numero elementi memorizzati *
      *                      * a inizializzazione nuovo elemento       *
      *                      *-----------------------------------------*
           if        w-mov-cge-inx-001    >    w-mov-cge-ctr-rig
                     go to det-mov-cge-344.
      *                      *-----------------------------------------*
      *                      * Se tipo sottoconto, Fornitore : riciclo *
      *                      *-----------------------------------------*
           if        w-mov-cge-tip-con
                    (w-mov-cge-inx-001)   =    "F"
                     go to det-mov-cge-342.
      *                      *-----------------------------------------*
      *                      * Se elemento gia' presente ad aggiorna-  *
      *                      * mento                                   *
      *                      *-----------------------------------------*
           if        w-mov-cge-cod-con
                    (w-mov-cge-inx-001)   =    w-top-stc-cge
                                              (w-mov-cge-wix-reg)
                     go to det-mov-cge-346.
      *                      *-----------------------------------------*
      *                      * Riciclo                                 *
      *                      *-----------------------------------------*
           go to     det-mov-cge-342.
       det-mov-cge-344.
      *                  *---------------------------------------------*
      *                  * Inizializzazione nuovo elemento             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Incremento numero elementi in tabella   *
      *                      *-----------------------------------------*
           add       1                    to   w-mov-cge-ctr-rig      .
      *                      *-----------------------------------------*
      *                      * Tipo sottoconto                         *
      *                      *-----------------------------------------*
           move      "G"                  to   w-mov-cge-tip-con
                                              (w-mov-cge-ctr-rig)     .
      *                      *-----------------------------------------*
      *                      * Codice del sottoconto                   *
      *                      *-----------------------------------------*
           move      w-top-stc-cge
                    (w-mov-cge-wix-reg)   to   w-mov-cge-cod-con
                                              (w-mov-cge-ctr-rig)     .
      *                      *-----------------------------------------*
      *                      * Data di riferimento                     *
      *                      *-----------------------------------------*
           move      zero                 to   w-mov-cge-dat-rif
                                              (w-mov-cge-ctr-rig)     .
      *                      *-----------------------------------------*
      *                      * Numero di riferimento                   *
      *                      *-----------------------------------------*
           move      spaces               to   w-mov-cge-num-rif
                                              (w-mov-cge-ctr-rig)     .
      *                      *-----------------------------------------*
      *                      * Flag di Dare/Avere                      *
      *                      *-----------------------------------------*
           move      spaces               to   w-mov-cge-dar-ave
                                              (w-mov-cge-ctr-rig)     .
      *                      *-----------------------------------------*
      *                      * Importo per la riga                     *
      *                      *-----------------------------------------*
           move      zero                 to   w-mov-cge-imp-rig
                                              (w-mov-cge-ctr-rig)     .
       det-mov-cge-346.
      *                  *---------------------------------------------*
      *                  * Aggiornamento elemento                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Aggiornamento importo per la riga       *
      *                      *-----------------------------------------*
           add       w-rig-imp-scf (1)    to   w-mov-cge-imp-rig
                                              (w-mov-cge-inx-001)     .
       det-mov-cge-348.
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     det-mov-cge-400.
       det-mov-cge-400.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura catena                       *
      *              *-------------------------------------------------*
           go to     det-mov-cge-100.
       det-mov-cge-500.
      *              *-------------------------------------------------*
      *              * Ripristino catena movimenti                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino area w-rig                       *
      *                  *---------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *                  *---------------------------------------------*
      *                  * Ripristino area catena                      *
      *                  *---------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
      *              *-------------------------------------------------*
      *              * Test su numero elementi bufferizzati            *
      *              *-------------------------------------------------*
           if        w-mov-cge-ctr-rig    >    zero
                     go to det-mov-cge-600.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "Attenzione : Anomalia relativa alla registrazione 
      -              "contabile.     "    to   w-err-box-err-msg      .
           move      "             Numero righe di registrazione a zero.
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                  *---------------------------------------------*
      *                  * Flag di aggiornamento contabile da non ese- *
      *                  * guire                                       *
      *                  *---------------------------------------------*
           move      "#"                  to   w-mov-cge-flg-nag      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-mov-cge-999.
       det-mov-cge-600.
      *              *-------------------------------------------------*
      *              * Aggiustamento ultimo elemento se registrazione  *
      *              * in conto                                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se registrazione non in conto : oltre       *
      *                  *---------------------------------------------*
           if        w-pie-aos-pgf (1)    not  = 02
                     go to det-mov-cge-700.
      *                  *---------------------------------------------*
      *                  * Se importo pagamento non inferiore ad accu- *
      *                  * mulo per il pagamento : oltre               *
      *                  *---------------------------------------------*
           if        w-pie-imp-pgf (1)    not  < w-mov-cge-acc-sdp
                     go to det-mov-cge-700.
      *                  *---------------------------------------------*
      *                  * Differenza tra importo pagato e accumulo    *
      *                  * per il pagamento in work                    *
      *                  *---------------------------------------------*
           move      w-mov-cge-acc-sdp    to   w-mov-cge-wrk-s11      .
           subtract  w-pie-imp-pgf (1)    from w-mov-cge-wrk-s11      .
      *                  *---------------------------------------------*
      *                  * Se tale differenza non e' minore dell'im-   *
      *                  * porto dell'ultimo elemento in tabella       *
      *                  *---------------------------------------------*
           if        w-mov-cge-wrk-s11    <    w-mov-cge-imp-rig
                                              (w-mov-cge-ctr-rig)
                     go to det-mov-cge-650.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "La differenza tra quanto pagato in conto e la somm
      -              "a delle scaden-"    to   w-err-box-err-msg      .
           move      "ze selezionate e' superiore all'importo dell'ultim
      -              "a scadenza.    "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                      *-----------------------------------------*
      *                      * Flag di aggiornamento contabile da non  *
      *                      * eseguire                                *
      *                      *-----------------------------------------*
           move      "#"                  to   w-mov-cge-flg-nag      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     det-mov-cge-999.
       det-mov-cge-650.
      *                  *---------------------------------------------*
      *                  * Aggiustamento importo dell'ultima scadenza  *
      *                  *---------------------------------------------*
           subtract  w-mov-cge-wrk-s11    from w-mov-cge-imp-rig
                                              (w-mov-cge-ctr-rig)     .
      *                  *---------------------------------------------*
      *                  * Aggiustamento work per accumulo per il pa-  *
      *                  * gamento                                     *
      *                  *---------------------------------------------*
           subtract  w-mov-cge-wrk-s11    from w-mov-cge-acc-sdp      .
       det-mov-cge-700.
      *              *-------------------------------------------------*
      *              * Test su accumulo per il pagamento               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo di operazione                  *
      *                  *---------------------------------------------*
           if        w-tes-tip-ope        not  = 1510 and
                     w-tes-tip-ope        not  = 1520 and
                     w-tes-tip-ope        not  = 1530
                     go to det-mov-cge-750.
      *                  *---------------------------------------------*
      *                  * Test su importo                             *
      *                  *---------------------------------------------*
           if        w-mov-cge-acc-sdp    <    zero
                     go to det-mov-cge-800.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "Attenzione: Anomalia relativa alla registrazione c
      -              "ontabile.      "    to   w-err-box-err-msg      .
           move      "            Importo contropartita contabile in Ave
      -              "re positivo    "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                  *---------------------------------------------*
      *                  * Flag di aggiornamento contabile da non ese- *
      *                  * guire                                       *
      *                  *---------------------------------------------*
           move      "#"                  to   w-mov-cge-flg-nag      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-mov-cge-999.
       det-mov-cge-750.
      *                  *---------------------------------------------*
      *                  * Test su importo                             *
      *                  *---------------------------------------------*
           if        w-mov-cge-acc-sdp    >    zero
                     go to det-mov-cge-800.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "Attenzione: Anomalia relativa alla registrazione c
      -              "ontabile.      "    to   w-err-box-err-msg      .
           move      "            Importo contropartita contabile in Ave
      -              "re non positivo"    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                  *---------------------------------------------*
      *                  * Flag di aggiornamento contabile da non ese- *
      *                  * guire                                       *
      *                  *---------------------------------------------*
           move      "#"                  to   w-mov-cge-flg-nag      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-mov-cge-999.
       det-mov-cge-800.
      *              *-------------------------------------------------*
      *              * Determinazione flag di Dare/Avere e assestamen- *
      *              * to importo in riga                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-mov-cge-inx-001      .
       det-mov-cge-820.
           add       1                    to   w-mov-cge-inx-001      .
           if        w-mov-cge-inx-001    >    w-mov-cge-ctr-rig
                     go to det-mov-cge-900.
           if        w-mov-cge-imp-rig
                    (w-mov-cge-inx-001)   =    zero
                     go to det-mov-cge-820.
           if        w-mov-cge-imp-rig
                    (w-mov-cge-inx-001)   >    zero
                     move  "D"            to   w-mov-cge-dar-ave
                                              (w-mov-cge-inx-001)
           else      move  "A"            to   w-mov-cge-dar-ave
                                              (w-mov-cge-inx-001)
                     multiply -1          by   w-mov-cge-imp-rig
                                              (w-mov-cge-inx-001)     .
           go to     det-mov-cge-820.
       det-mov-cge-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-mov-cge-999.
       det-mov-cge-999.
           exit.
           
      *    *===========================================================*
      *    * Annullamento del movimento di contabilita' generale che   *
      *    * era stato a suo tempo generato a fronte del movimento di  *
      *    * scadenze fornitori                                        *
      *    *-----------------------------------------------------------*
       del-cge-scf-000.
      *              *-------------------------------------------------*
      *              * Se data registrazione o numero protocollo della *
      *              * registrazione contabile da annullare a zero :   *
      *              * uscita senza alcuna azione                      *
      *              *-------------------------------------------------*
           if        w-cge-scf-drc-del    =    zero or
                     w-cge-scf-npc-del    =    zero
                     go to del-cge-scf-999.
      *              *-------------------------------------------------*
      *              * Preparazione link-area per annullamento regi-   *
      *              * strazione di contabilita'                       *
      *              *-------------------------------------------------*
           move      "DE"                 to   l-cge-300-tip-ope      .
           move      w-cge-scf-drc-del    to   l-cge-300-dat-reg      .
           move      w-cge-scf-npc-del    to   l-cge-300-num-prt      .
      *              *-------------------------------------------------*
      *              * Richiamo sottoprogramma per aggiornamenti con-  *
      *              * tabili                                          *
      *              *-------------------------------------------------*
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
       del-cge-scf-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [fnt]                         *
      *    *-----------------------------------------------------------*
       let-arc-fnt-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-fnt-flg      .
      *              *-------------------------------------------------*
      *              * Test se codice fornitore a zero                 *
      *              *-------------------------------------------------*
           if        w-let-arc-fnt-cod    =    zero
                     go to let-arc-fnt-500.
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODFNT    "         to   f-key                  .
           move      w-let-arc-fnt-cod    to   rf-fnt-cod-fnt         .
           move      "pgm/cge/fls/ioc/obj/ioffnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fnt                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-fnt-400.
       let-arc-fnt-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-fnt-rag-soc       to   w-let-arc-fnt-rag      .
           move      rf-fnt-via-fnt       to   w-let-arc-fnt-via      .
           move      rf-fnt-loc-fnt       to   w-let-arc-fnt-loc      .
           move      rf-fnt-cod-cge       to   w-let-arc-fnt-cge      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-fnt-999.
       let-arc-fnt-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-fnt-flg      .
           move      all   "."            to   w-let-arc-fnt-rag      .
           go to     let-arc-fnt-600.
       let-arc-fnt-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-fnt-rag      .
       let-arc-fnt-600.
           move      spaces               to   w-let-arc-fnt-via      .
           move      spaces               to   w-let-arc-fnt-loc      .
           move      zero                 to   w-let-arc-fnt-cge      .
       let-arc-fnt-999.
           exit.

      *    *===========================================================*
      *    * Routine lettura archivio dipendenza fornitore in [dcf]    *
      *    *-----------------------------------------------------------*
       let-arc-dcf-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-dcf-flg      .
      *              *-------------------------------------------------*
      *              * Test se codice fornitore a zero                 *
      *              *-------------------------------------------------*
           if        w-let-arc-dcf-cod    =    zero
                     go to let-arc-dcf-500.
      *              *-------------------------------------------------*
      *              * Test se codice dipendenza a spaces, solo se ri- *
      *              * chiesta di lettura specificamente di una dipen- *
      *              * denza                                           *
      *              *-------------------------------------------------*
           if        w-let-arc-dcf-dpz    =    spaces and
                     w-let-arc-dcf-tle    =    "D"
                     go to let-arc-dcf-500.
      *              *-------------------------------------------------*
      *              * Test se codice dipendenza a "*   ", solo se ri- *
      *              * chiesta di lettura specificamente di una dipen- *
      *              * denza                                           *
      *              *-------------------------------------------------*
           if        w-let-arc-dcf-dpz    =    "*   " and
                     w-let-arc-dcf-tle    =    "D"
                     go to let-arc-dcf-450.
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODFNT    "         to   f-key                  .
           move      w-let-arc-dcf-cod    to   rf-dcf-cod-fnt         .
           move      w-let-arc-dcf-dpz    to   rf-dcf-dpz-fnt         .
           move      "pgm/dcf/fls/ioc/obj/iofdcf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcf                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-dcf-400.
       let-arc-dcf-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-dcf-rag-soc       to   w-let-arc-dcf-rag      .
           move      rf-dcf-via-dcf       to   w-let-arc-dcf-via      .
           move      rf-dcf-loc-dcf       to   w-let-arc-dcf-loc      .
           move      rf-dcf-cod-abi       to   w-let-arc-dcf-abi      .
           move      rf-dcf-cod-cab       to   w-let-arc-dcf-cab      .
           move      rf-dcf-ccc-app       to   w-let-arc-dcf-ccc      .
           move      rf-dcf-ccp-app       to   w-let-arc-dcf-ccp      .
           if        w-let-arc-dcf-tle    =    "D"
                     move  spaces         to   w-let-arc-dcf-ban
           else      move  rf-dcf-nos-ban to   w-let-arc-dcf-ban
           move      rf-dcf-cod-vlt       to   w-let-arc-dcf-vlt      .
           move      rf-dcf-inl-dcm       to   w-let-arc-dcf-inl      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-dcf-999.
       let-arc-dcf-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-dcf-flg      .
           move      all   "."            to   w-let-arc-dcf-rag      .
           go to     let-arc-dcf-600.
       let-arc-dcf-450.
      *              *-------------------------------------------------*
      *              * Normalizzazione per codice dipendenza "*   "    *
      *              *-------------------------------------------------*
           move      "Sia la sede che tutte le dipendenze     "
                                          to   w-let-arc-dcf-rag      .
           go to     let-arc-dcf-600.
       let-arc-dcf-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-dcf-rag      .
       let-arc-dcf-600.
           move      spaces               to   w-let-arc-dcf-via      .
           move      spaces               to   w-let-arc-dcf-loc      .
           move      zero                 to   w-let-arc-dcf-abi      .
           move      zero                 to   w-let-arc-dcf-cab      .
           move      zero                 to   w-let-arc-dcf-ccc      .
           move      spaces               to   w-let-arc-dcf-ccp      .
           move      spaces               to   w-let-arc-dcf-ban      .
           move      spaces               to   w-let-arc-dcf-vlt      .
           move      zero                 to   w-let-arc-dcf-inl      .
       let-arc-dcf-999.
           exit.

