      *                  * Test che il valore non sia a zero, a meno   *
      *                  * che non si sia in Up                        *
      *                  *---------------------------------------------*
           if        w-tes-sel-tsf (1)    not  = zero
                     go to acc-sel-tsf-500.
           if        v-key                =    "UP  "
                     go to acc-sel-tsf-600
           else      go to acc-sel-tsf-100.
       acc-sel-tsf-500.
      *                  *---------------------------------------------*
      *                  * Test se valore ammissibile                  *
      *                  *---------------------------------------------*
           if        w-tes-sel-tsf (1)    >    w-exp-sel-tsf-num
                     go to acc-sel-tsf-100.
       acc-sel-tsf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-sel-tsf (1)    =    w-sav-sel-tsf
                     go to acc-sel-tsf-800.
