      *                          *-------------------------------------*
           move      w-let-arc-cbp-bpp    to   w-tes-cbp-pgf-stc (1)  .
           if        w-tes-cbp-pgf-stc (1)
                                          not  = zero
                     go to acc-cbp-pgf-545.
           move      "Manca il sottoconto contabile per bonifici postali
      -              " passivi, asso-"    to   w-err-box-err-msg      .
           move      "ciato al codice c/c postale                       
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           go to     acc-cbp-pgf-100.
