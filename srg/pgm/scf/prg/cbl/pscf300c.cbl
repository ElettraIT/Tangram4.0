           call      s-pat               using f
                                               rf-sfs                 .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to rou-let-reg-out-300
           else      go to rou-let-reg-out-200.
       rou-let-reg-out-200.
      *              *-------------------------------------------------*
      *              * Se scadenza non trovata in [sfs]                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Incremento numero scadenze non esistenti    *
      *                  *---------------------------------------------*
           add       1                    to   w-rou-let-reg-nsn      .
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      srt-num-scf          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      spaces               to   w-err-box-err-msg      .
           string    "Attenzione : Scadenza nr. "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " non esistente in archivio!"
                                delimited by   size
                                          into w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura record da sort           *
      *                  *---------------------------------------------*
           go to     rou-let-reg-out-100.
       rou-let-reg-out-300.
      *              *-------------------------------------------------*
      *              * Se scadenza esistente in [sfs]                  *
      *              *-------------------------------------------------*
