           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riga corpo di accettazione    *
      *    *-----------------------------------------------------------*
       pmt-rig-cor-000.
      *              *-------------------------------------------------*
      *              * Erase linee impegnate dall'area di impostazione *
      *              * della singola riga corpo espansa a piede        *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      20                   to   v-lin                  .
           move      21                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts per riga corpo espansa  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Numero scadenza                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      17                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Numero scadenza :"  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Data scadenza                               *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      17                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Data scadenza   :"  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Importo scadenza                            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      40                   to   v-pos                  .
           move      "Importo :"          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Accettazione : Numero scadenza fornitore                  *
      *    *-----------------------------------------------------------*
       acc-num-scf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-num-scf (1)    to   w-sav-num-scf          .
       acc-num-scf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino valore precedente                *
      *                  *---------------------------------------------*
           move      w-sav-num-scf        to   w-rig-num-scf (1)      .
      *                  *---------------------------------------------*
      *                  * Parametri generici                          *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      20                   to   v-lin                  .
           move      19                   to   v-pos                  .
      *                  *---------------------------------------------*
      *                  * Tasti funzione                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Up   : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "UP  "               to   v-pfk (01)             .
      *                      *-----------------------------------------*
      *                      * Down : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "DOWN"         to   v-pfk (02)             .
      *                      *-----------------------------------------*
      *                      * Find : ammesso solo se record new e se  *
      *                      * il primo campo ammette il Find          *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     move  "FIND"         to   v-pfk (03)             .
      *                      *-----------------------------------------*
      *                      * Insr : sempre ammesso, a meno che non   *
      *                      *        si sia in un record New oppure   *
      *                      *        manchi spazio per l'inserimento  *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces and
                     w-cat-rig-ins        =    spaces
                     move  "INSR"         to   v-pfk (04)             .
      *                      *-----------------------------------------*
      *                      * Do   : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "DO  "               to   v-pfk (05)             .
      *                      *-----------------------------------------*
      *                      * Remv : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "REMV"               to   v-pfk (06)             .
      *                      *-----------------------------------------*
      *                      * Prsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "PRSC"               to   v-pfk (07)             .
      *                      *-----------------------------------------*
      *                      * Nxsc : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "NXSC"         to   v-pfk (08)             .
      *                      *-----------------------------------------*
      *                      * Back : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sulla prima riga     *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    not  = 1
                     move  "BACK"         to   v-pfk (09)             .
      *                      *-----------------------------------------*
      *                      * Tab  : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'ultima riga e   *
      *                      *        che questa sia in Append         *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces or
                     w-cat-rig-lst        =    spaces
                     move  "TAB "         to   v-pfk (10)             .
      *                      *-----------------------------------------*
      *                      * Slct : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'unica riga      *
      *                      *-----------------------------------------*
           if        w-cat-rig-max        not  = 1
                     move  "SLCT"         to   v-pfk (11)             .
      *                      *-----------------------------------------*
      *                      * Expd : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "EXPD"               to   v-pfk (12)             .
      *                      *-----------------------------------------*
      *                      * Valore di accettazione                  *
      *                      *-----------------------------------------*
           move      w-rig-num-scf (1)    to   v-num                  .
       acc-num-scf-200.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine di accettazione     *
      *                      *-----------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Return                                       *
      *              *-------------------------------------------------*
           if        v-key                =    spaces
                     go to acc-num-scf-400.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-num-scf-225.
      *                  *---------------------------------------------*
      *                  * Find su scadenze fornitori                  *
      *                  *---------------------------------------------*
           move      "S"                  to   w-fnd-arc-sfs-sns      .
           move      w-tes-cod-fnt (1)    to   w-fnd-arc-sfs-fnt      .
           move      w-tes-dpz-fnt (1)    to   w-fnd-arc-sfs-dpf      .
      *
           if        w-tes-tip-ope        =    1510
                     move  01             to   w-fnd-arc-sfs-tip
           else if   w-tes-tip-ope        =    1520
                     move  01             to   w-fnd-arc-sfs-tip
           else if   w-tes-tip-ope        =    1610
                     move  01             to   w-fnd-arc-sfs-tip
           else if   w-tes-tip-ope        =    1620
                     move  01             to   w-fnd-arc-sfs-tip
           else if   w-tes-tip-ope        =    1530
                     move  06             to   w-fnd-arc-sfs-tip
           else if   w-tes-tip-ope        =    1630
                     move  06             to   w-fnd-arc-sfs-tip
           else if   w-tes-tip-ope        =    1640
                     move  08             to   w-fnd-arc-sfs-tip
           else if   w-tes-tip-ope        =    1730 or
                     w-tes-tip-ope        =    1731
                     move  07             to   w-fnd-arc-sfs-tip
           else if   w-tes-tip-ope        =    1740
                     move  08             to   w-fnd-arc-sfs-tip
           else if   w-tes-tip-ope        =    1750
                     move  02             to   w-fnd-arc-sfs-tip
           else      move  zero           to   w-fnd-arc-sfs-tip      .
      *
           if        w-tes-tip-ope        =    1731
                     move  02             to   w-fnd-arc-sfs-tvl
           else      move  01             to   w-fnd-arc-sfs-tvl      .
      *
           move      01                   to   w-fnd-arc-sfs-trs      .
      *
           if        w-tes-tip-ope        =    1731
                     move  w-tes-sgl-vlt (1)
                                          to   w-fnd-arc-sfs-vlt
           else      move  spaces         to   w-fnd-arc-sfs-vlt      .
      *
           move      "S"                  to   w-fnd-arc-sfs-sdp      .
      *                      *-----------------------------------------*
      *                      * Richiamo routine                        *
      *                      *-----------------------------------------*
           perform   fnd-arc-sfs-000      thru fnd-arc-sfs-999        .
      *                  *---------------------------------------------*
      *                  * Se selezione non effettuata : a reimposta-  *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           if        w-fnd-arc-sfs-sel    not  = spaces
                     go to acc-num-scf-100.
      *                  *---------------------------------------------*
      *                  * Numero scadenza selezionata in campo di de- *
      *                  * stinazione                                  *
      *                  *---------------------------------------------*
           move      w-fnd-arc-sfs-num    to   w-rig-num-scf (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione numero scadenza selezionata *
      *                  *---------------------------------------------*
           perform   vis-num-scf-000      thru vis-num-scf-999        .
      *                  *---------------------------------------------*
      *                  * Normalizzazione function-key di impostazio- *
      *                  * ne                                          *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Continuazione post-impostazione             *
      *                  *---------------------------------------------*
           go to     acc-num-scf-400.
       acc-num-scf-225.
      *              *-------------------------------------------------*
      *              * Se Expd                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "EXPD"
                     go to acc-num-scf-250.
      *                  *---------------------------------------------*
      *                  * Espansione su scadenze fornitori            *
      *                  *---------------------------------------------*
           if        w-rig-num-scf (1)    =    zero
                     move  "S"            to   w-esp-arc-sfs-sns
           else      move  "N"            to   w-esp-arc-sfs-sns      .
           move      v-num                to   w-esp-arc-sfs-num      .
           perform   esp-arc-sfs-000      thru esp-arc-sfs-999        .
      *                  *---------------------------------------------*
      *                  * Se selezione non effettuata : a reimposta-  *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           if        w-esp-arc-sfs-sel    not  = spaces
                     go to acc-num-scf-100.
      *                  *---------------------------------------------*
      *                  * Ripresa numero scadenza selezionata         *
      *                  *---------------------------------------------*
           move      w-esp-arc-sfs-num    to   w-rig-num-scf (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione numero scadenza selezionata *
      *                  *---------------------------------------------*
           perform   vis-num-scf-000      thru vis-num-scf-999        .
      *                  *---------------------------------------------*
      *                  * Normalizzazione function-key di impostazio- *
      *                  * ne                                          *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Continuazione post-impostazione             *
      *                  *---------------------------------------------*
           go to     acc-num-scf-400.
       acc-num-scf-250.
      *              *-------------------------------------------------*
      *              * Se Slct                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "SLCT"
                     go to acc-num-scf-300
           else      go to acc-num-scf-350.
       acc-num-scf-300.
      *                  *---------------------------------------------*
      *                  * Conversione numero riga impostato in forma- *
      *                  * to numerico                                 *
      *                  *---------------------------------------------*
           move      v-num                to   w-cnt-slc-rap-num      .
       acc-num-scf-320.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato minore di 1 o mag- *
      *                  * maggiore del massimo : reimpostazione       *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    zero       or
                     w-cnt-slc-rap-num    >    w-cat-rig-max
                     go to acc-num-scf-100.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato pari a numero riga *
      *                  * attuale : reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    w-cnt-cor-nrg-dac
                     go to acc-num-scf-100.
      *                  *---------------------------------------------*
      *                  * Preparazione parametri e uscita             *
      *                  *---------------------------------------------*
           move      w-cnt-slc-rap-num    to   w-cnt-slc-num-rig      .
           move      "."                  to   w-cnt-tus-acc-rig      .
           go to     acc-num-scf-999.
       acc-num-scf-350.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-num-scf-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-rig
                     go to acc-num-scf-999.
      *              *-------------------------------------------------*
      *              * Se premuto un altro tasto funzione non deve es- *
      *              * sere avvenuta variazione del campo d'impostaz.  *
      *              *-------------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-num-scf-100.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     move  "U"            to   w-cnt-tus-acc-rig
                     go to acc-num-scf-999.
      *              *-------------------------------------------------*
      *              * Se Down                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DOWN"
                     move  "D"            to   w-cnt-tus-acc-rig
                     go to acc-num-scf-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-num-scf-999
                     else    go to acc-num-scf-100.
      *              *-------------------------------------------------*
      *              * Se Insr                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "INSR"
                     move  "I"            to   w-cnt-tus-acc-rig
                     go to acc-num-scf-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-num-scf-999.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "TAB "
                     move  "T"            to   w-cnt-tus-acc-rig
                     go to acc-num-scf-999.
      *              *-------------------------------------------------*
      *              * Se Back                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "BACK"
                     move  "B"            to   w-cnt-tus-acc-rig
                     go to acc-num-scf-999.
      *              *-------------------------------------------------*
      *              * Se Nxsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     move  "N"            to   w-cnt-tus-acc-rig
                     go to acc-num-scf-999.
      *              *-------------------------------------------------*
      *              * Se Prsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "PRSC"
                     move  "P"            to   w-cnt-tus-acc-rig
                     go to acc-num-scf-999.
       acc-num-scf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del valore precedente  *
      *                  *---------------------------------------------*
           if        w-sav-num-scf        =    zero
                     go to acc-num-scf-450.
       acc-num-scf-425.
