      *    *===========================================================*
      *    * Routine post-conferma di modifica                         *
      *    *-----------------------------------------------------------*
       pos-cnf-mod-000.
      *              *-------------------------------------------------*
      *              * Determinazione del tipo di modifica intervenuta *
      *              * nell'operazione di pagamento e dei relativi     *
      *              * flags indicatori                                *
      *              *-------------------------------------------------*
           perform   det-mod-pgf-000      thru det-mod-pgf-999        .
      *              *-------------------------------------------------*
      *              * Se il tipo di modifica non comporta alcuna va-  *
      *              * riazione : uscita                               *
      *              *-------------------------------------------------*
           if        w-mod-pgf-rec-sfp    =    spaces and
                     w-mod-pgf-cge-scf    =    spaces
                     go to pos-cnf-mod-999.
       pos-cnf-mod-050.
      *              *-------------------------------------------------*
      *              * Aggiornamenti contabili                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Annullamento del movimento di contabilita'  *
      *                  * generale che era stato a suo tempo genera-  *
      *                  * to a fronte del movimento di pagamento      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se il tipo di modifica non comporta va- *
      *                      * riazione all'eventuale registrazione    *
      *                      * contabile : nessuna azione              *
      *                      *-----------------------------------------*
           if        w-mod-pgf-cge-scf    =    spaces
                     go to pos-cnf-mod-075.
      *                      *-----------------------------------------*
      *                      * Altrimenti : esecuzione                 *
      *                      *-----------------------------------------*
           move      w-tes-drc-pgf (2)    to    w-cge-scf-drc-del     .
           move      w-tes-npc-pgf (2)    to    w-cge-scf-npc-del     .
           perform   del-cge-scf-000      thru  del-cge-scf-999       .
       pos-cnf-mod-075.
      *                  *---------------------------------------------*
      *                  * Aggiornamenti contabili generati dalla ge-  *
      *                  * stione scadenze fornitori a fronte del mo-  *
      *                  * vimento di pagamento                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se il tipo di modifica non comporta va- *
      *                      * riazione all'eventuale registrazione    *
      *                      * contabile : nessuna azione              *
      *                      *-----------------------------------------*
           if        w-mod-pgf-cge-scf    =    spaces
                     go to pos-cnf-mod-100.
      *                      *-----------------------------------------*
      *                      * Altrimenti : esecuzione                 *
      *                      *-----------------------------------------*
           perform   cge-scf-pgf-000      thru cge-scf-pgf-999        .
       pos-cnf-mod-100.
      *              *-------------------------------------------------*
      *              * Trattamento file [sfp] : Testata pagamento      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [sfp]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfp                 .
      *                  *---------------------------------------------*
      *                  * Composizione record [sfp]                   *
      *                  *---------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rf-sfp-ide-dat         .
           move      s-ute                to   rf-sfp-ide-ute         .
           move      s-fas                to   rf-sfp-ide-fas         .
           move      w-tes-dat-reg        to   rf-sfp-dtr-pgf         .
           move      w-tes-num-pgf        to   rf-sfp-num-pgf         .
           move      w-tes-mod-pgf (1)    to   rf-sfp-mod-pgf         .
           move      w-tes-tvl-pgf (1)    to   rf-sfp-tvl-pgf         .
           move      w-tes-cod-fnt (1)    to   rf-sfp-cod-fnt         .
           move      w-tes-dpz-fnt (1)    to   rf-sfp-dpz-fnt         .
           move      w-tes-inl-pgf (1)    to   rf-sfp-inl-pgf         .
           move      w-tes-cbp-pgf (1)    to   rf-sfp-cbp-pgf         .
           move      w-tes-tip-pgf (1)    to   rf-sfp-tip-pgf         .
           move      w-tes-abi-pgf (1)    to   rf-sfp-abi-pgf         .
           move      w-tes-cab-pgf (1)    to   rf-sfp-cab-pgf         .
           move      w-tes-bef-pgf (1)    to   rf-sfp-bef-pgf         .
           move      w-tes-ccc-pgf (1)    to   rf-sfp-ccc-pgf         .
           move      w-tes-sgl-vlt (1)    to   rf-sfp-sgl-vlt         .
           move      w-tes-dec-vlt (1)    to   rf-sfp-dec-vlt         .
           move      w-tes-tdc-vlt (1)    to   rf-sfp-tdc-vlt         .
           move      w-tes-cdc-pgf (1)    to   rf-sfp-cdc-pgf         .
           move      w-pie-iiv-pgf (1)    to   rf-sfp-iiv-pgf         .
           move      w-pie-imp-pgf (1)    to   rf-sfp-imp-pgf         .
           move      w-pie-spe-pgf (1)    to   rf-sfp-spe-pgf         .
           move      w-tes-ddo-pgf (1)    to   rf-sfp-ddo-pgf         .
           move      w-tes-ndo-pgf (1)    to   rf-sfp-ndo-pgf         .
           move      w-pie-dvf-bfc (1)    to   rf-sfp-dvf-bfc         .
           move      w-pie-aos-pgf (1)    to   rf-sfp-aos-pgf         .
           move      w-pie-rns-pgf (1)    to   rf-sfp-rns-pgf         .
           move      w-pie-nns-pgf (1)    to   rf-sfp-nns-pgf         .
           move      w-pie-tns-pgf (1)    to   rf-sfp-tns-pgf         .
           move      w-tes-num-adp (1)    to   rf-sfp-num-adp         .
           move      w-tes-fcs-uno (1)    to   rf-sfp-fcs-uno         .
