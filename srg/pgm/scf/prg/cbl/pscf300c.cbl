           else if   w-tes-tip-ope        =    1530 or
                     w-tes-tip-ope        =    1630
                     go to rou-let-reg-642
           else if   w-tes-tip-ope        =    1640
                     go to rou-let-reg-643
           else      go to rou-let-reg-644.
       rou-let-reg-641.
      *                                          *---------------------*
      *                                          * Tipo operazione :   *
      *                                          * 1510 o 1610         *
      *                                          *---------------------*
           move      "Attenzione : Manca il sottoconto per oneri su paga
      -              "mento associato"    to   w-err-box-err-msg      .
           move      "             al codice nostra cassa.              
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           go to     rou-let-reg-644.
       rou-let-reg-642.
      *                                          *---------------------*
      *                                          * Tipo operazione :   *
      *                                          * 1530 o 1630         *
      *                                          *---------------------*
           move      "Attenzione : Manca il sottoconto per oneri bancari
      -              "associato al   "    to   w-err-box-err-msg      .
