      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Open files                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * [sfs]                                       *
      *                  *---------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfs                 .
      *                  *---------------------------------------------*
      *                  * [sfp]                                       *
      *                  *---------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfp                 .
      *                  *---------------------------------------------*
      *                  * [dcf]                                       *
      *                  *---------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/dcf/fls/ioc/obj/iofdcf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcf                 .
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Ciclo per lettura scadenze                      *
      *              *-------------------------------------------------*
           if        rr-cod-fnt           not  = zero
                     go to stp-srt-inp-500.
      *                  *---------------------------------------------*
      *                  * Se tutti i fornitori : scadenze a vista     *
      *                  *---------------------------------------------*
           if        rr-snx-scv           not  = "S"
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Start su file [sfs]                         *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DTSSCF    "         to   f-key                  .
           move      zero                 to   rf-sfs-dts-scf         .
           move      zero                 to   rf-sfs-num-scf         .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfs                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-200.
       stp-srt-inp-120.
      *                  *---------------------------------------------*
      *                  * Read Next su file [sfs]                     *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfs                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Test sul massimo                            *
      *                  *---------------------------------------------*
           if        rf-sfs-dts-scf       not  = zero
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Selezione sul record                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se tipo scadenza compreso tra quel-*
      *                      * li richiesti                            *
      *                      *-----------------------------------------*
           if        rr-snx-tsc
                    (rf-sfs-tip-scf)      not  = "S"
                     go to stp-srt-inp-120.
      *                      *-----------------------------------------*
      *                      * Selezione su status della scadenza      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione status scadenza for- *
      *                          * nitore                              *
      *                          *-------------------------------------*
           move      rr-dat-bcm           to   w-det-srd-scf-drd      .
           perform   det-srd-scf-000      thru det-srd-scf-999        .
      *                          *-------------------------------------*
      *                          * Tests                               *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Su status scadenza              *
      *                              *---------------------------------*
           if        w-det-srd-scf-sts    not  = "A"
                     go to stp-srt-inp-120.
      *                              *---------------------------------*
      *                              * Su sigla ultima operazione ese- *
      *                              * guita sulla scadenza            *
      *                              *---------------------------------*
           if        w-det-srd-scf-suo    not  = "REG"
                     go to stp-srt-inp-120.
      *                      *-----------------------------------------*
      *                      * Lettura archivio [dcf] principale       *
      *                      *-----------------------------------------*
           move      rf-sfs-cod-fnt       to   w-let-arc-dcf-fnt      .
           move      spaces               to   w-let-arc-dcf-dpz      .
           perform   let-arc-dcf-000      thru let-arc-dcf-999        .
           move      w-let-arc-dcf-rsu    to   w-stp-srt-inp-rsu      .
           move      w-let-arc-dcf-rag    to   w-stp-srt-inp-rfp      .
      *                      *-----------------------------------------*
      *                      * Lettura archivio [dcf] dipendenza       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da eseguire                 *
      *                          *-------------------------------------*
           if        rf-sfs-dpz-fnt       =    spaces
                     go to stp-srt-inp-140.
      *                          *-------------------------------------*
      *                          * Lettura                             *
      *                          *-------------------------------------*
           move      rf-sfs-cod-fnt       to   w-let-arc-dcf-fnt      .
           move      rf-sfs-dpz-fnt       to   w-let-arc-dcf-dpz      .
           perform   let-arc-dcf-000      thru let-arc-dcf-999        .
           move      w-let-arc-dcf-rag    to   w-stp-srt-inp-rdf      .
       stp-srt-inp-140.
      *                      *-----------------------------------------*
      *                      * Composizione record di Sort             *
      *                      *-----------------------------------------*
           move      rf-sfs-dts-scf       to   srt-dts-srt            .
           move      zero                 to   srt-dts-eff            .
           move      w-stp-srt-inp-rsu    to   srt-rag-key            .
           move      rf-sfs-cod-fnt       to   srt-cod-fnt            .
