      *                      *-----------------------------------------*
           if        w-rig-imp-pgf (1)    not  < w-mov-cge-tot-spp
                     go to det-mov-cge-460.
      *                      *-----------------------------------------*
      *                      * Differenza tra importo pagamento e to-  *
      *                      * tale scadenze per il pagamento in work  *
      *                      *-----------------------------------------*
           move      w-mov-cge-tot-spp    to   w-mov-cge-wrk-s11      .
           subtract  w-rig-imp-pgf (1)    from w-mov-cge-wrk-s11      .
      *                      *-----------------------------------------*
      *                      * Se tale differenza non e' minore dell'  *
      *                      * importo dell'ultimo elemento in tabel-  *
      *                      * la                                      *
      *                      *-----------------------------------------*
           if        w-mov-cge-wrk-s11    <    w-mov-cge-imp-rig
                                              (w-mov-cge-ctr-rig)
                     go to det-mov-cge-430.
       det-mov-cge-425.
      *                          *-------------------------------------*
      *                          * Messaggio di errore                 *
      *                          *-------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      w-rig-num-pgf (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      spaces               to   w-err-box-err-msg      .
           string    "Attenzione : Anomalia relativa al pagamento nr. "
                                delimited by   size
                     v-edt      delimited by   spaces
                     "!"        delimited by   size
                                          into w-err-box-err-msg      .
           move      "             Importo in conto non imputabile all'u
      -              "ltima scadenza "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                          *-------------------------------------*
      *                          * Flag di aggiornamento contabile da  *
      *                          * non eseguire                        *
      *                          *-------------------------------------*
           move      "#"                  to   w-mov-cge-flg-nag      .
      *                          *-------------------------------------*
      *                          * Riciclo su prossimo pagamento       *
      *                          *-------------------------------------*
           go to     det-mov-cge-100.
       det-mov-cge-430.
      *                      *-----------------------------------------*
      *                      * Aggiustamento importo dell'ultima riga  *
      *                      *-----------------------------------------*
           subtract  w-mov-cge-wrk-s11    from w-mov-cge-imp-rig
                                              (w-mov-cge-ctr-rig)     .
      *                      *-----------------------------------------*
      *                      * Aggiustamento totale scadenze per paga- *
      *                      * mento                                   *
      *                      *-----------------------------------------*
           subtract  w-mov-cge-wrk-s11    from w-mov-cge-tot-spp      .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     det-mov-cge-460.
       det-mov-cge-440.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : 1831; cioe' addebito su   *
      *                  * estero                                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se sigla valuta pari a quella base :    *
      *                      * come per addebito normale               *
      *                      *-----------------------------------------*
           if        w-tes-sgl-vlt (1)    =    c-sgl
                     go to det-mov-cge-420.
      *                      *-----------------------------------------*
      *                      * Se importo pagamento non inferiore al   *
      *                      * totale scadenze in valuta per il paga-  *
      *                      * mento : oltre                           *
      *                      *-----------------------------------------*
           if        w-rig-imp-pgf (1)    not  < w-mov-cge-tiv-spp
                     go to det-mov-cge-460.
      *                      *-----------------------------------------*
      *                      * Differenza tra importo pagamento e to-  *
      *                      * tale scadenze in valuta per il pagamen- *
      *                      * to in work                              *
      *                      *-----------------------------------------*
           move      w-mov-cge-tiv-spp    to   w-mov-cge-dif-iiv      .
           subtract  w-rig-imp-pgf (1)    from w-mov-cge-dif-iiv      .
      *                      *-----------------------------------------*
      *                      * Se tale differenza non e' minore dell'  *
      *                      * importo in valuta dell'ultimo elemento  *
      *                      * in tabella                              *
      *                      *-----------------------------------------*
           if        w-mov-cge-dif-iiv    <    w-mov-cge-iiv-rig
                                              (w-mov-cge-ctr-rig)
                     go to det-mov-cge-450.
      *                          *-------------------------------------*
      *                          * A messaggio di errore               *
      *                          *-------------------------------------*
           go to     det-mov-cge-425.
       det-mov-cge-450.
      *                      *-----------------------------------------*
      *                      * Aggiustamento importo in valuta dell'   *
      *                      * ultima riga                             *
      *                      *-----------------------------------------*
           subtract  w-mov-cge-dif-iiv    from w-mov-cge-iiv-rig
                                              (w-mov-cge-ctr-rig)     .
      *                      *-----------------------------------------*
      *                      * Aggiustamento totale scadenze in valuta *
      *                      * per il pagamento                        *
      *                      *-----------------------------------------*
           subtract  w-mov-cge-dif-iiv    from w-mov-cge-tiv-spp      .
      *                      *-----------------------------------------*
      *                      * Aggiustamento importo in valuta base    *
      *                      * dell'ultima riga                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se coefficiente di cambio del- *
      *                          * ultima riga non zero                *
      *                          *-------------------------------------*
           if        w-mov-cge-cdc-rig
                    (w-mov-cge-ctr-rig)   not  = zero
                     move  w-mov-cge-cdc-rig
                          (w-mov-cge-ctr-rig)
                                          to   w-mov-cge-wrk-cdc
                     go to det-mov-cge-455.
      *                          *-------------------------------------*
      *                          * Se zero, determinazione coefficien- *
      *                          * te di cambio medio dell'ultima ri-  *
      *                          * ga                                  *
      *                          *-------------------------------------*
           move      w-tes-sgl-vlt (1)    to   w-cvs-vlt-sgl          .
           move      w-tes-dec-vlt (1)    to   w-cvs-vlt-dec          .
           move      w-tes-tdc-vlt (1)    to   w-cvs-vlt-tdc          .
           move      w-mov-cge-iiv-rig
                    (w-mov-cge-ctr-rig)   to   w-cvs-vlt-aav          .
           move      w-mov-cge-imp-rig
                    (w-mov-cge-ctr-rig)   to   w-cvs-vlt-avb          .
           perform   cvs-cdc-aab-000      thru cvs-cdc-aab-999        .
           move      w-cvs-vlt-cdc        to   w-mov-cge-wrk-cdc      .
       det-mov-cge-455.
      *                          *-------------------------------------*
      *                          * Calcolo dell'importo in valuta base *
      *                          * della differenza tra importo paga-  *
      *                          * mento e totale scadenze in valuta   *
      *                          * per il pagamento                    *
      *                          *-------------------------------------*
           move      w-tes-sgl-vlt (1)    to   w-cvs-vlt-sgl          .
           move      w-tes-dec-vlt (1)    to   w-cvs-vlt-dec          .
           move      w-tes-tdc-vlt (1)    to   w-cvs-vlt-tdc          .
           move      w-mov-cge-wrk-cdc    to   w-cvs-vlt-cdc          .
           move      w-mov-cge-dif-iiv    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
           move      w-cvs-vlt-avb        to   w-mov-cge-dif-ivb      .
      *                      *-----------------------------------------*
      *                      * Aggiustamento importo in valuta base    *
      *                      * dell' ultima riga                       *
      *                      *-----------------------------------------*
           subtract  w-mov-cge-dif-ivb    from w-mov-cge-imp-rig
                                              (w-mov-cge-ctr-rig)     .
      *                      *-----------------------------------------*
      *                      * Aggiustamento totale scadenze in valuta *
      *                      * base per il pagamento                   *
      *                      *-----------------------------------------*
           subtract  w-mov-cge-dif-ivb    from w-mov-cge-tot-spp      .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     det-mov-cge-460.
       det-mov-cge-460.
      *              *-------------------------------------------------*
      *              * Test su totale scadenze per il pagamento        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo operazione  *
      *                  *---------------------------------------------*
           if        w-tes-tip-ope        =    1830 or
                     w-tes-tip-ope        =    1840 or
                     w-tes-tip-ope        =    1850
                     go to det-mov-cge-462
           else if   w-tes-tip-ope        =    1831
                     go to det-mov-cge-464.
       det-mov-cge-462.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : 1830, 1840 o 1850; cioe'  *
      *                  * tipi operazione non in valuta               *
      *                  *---------------------------------------------*
           if        w-mov-cge-tot-spp    >    zero
                     go to det-mov-cge-470.
           go to     det-mov-cge-468.
       det-mov-cge-464.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : 1831; cioe' addebito su   *
      *                  * estero                                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se sigla valuta pari a quella base :    *
      *                      * come per addebito normale               *
      *                      *-----------------------------------------*
           if        w-tes-sgl-vlt (1)    =    c-sgl
                     go to det-mov-cge-462.
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-mov-cge-tot-spp    >    zero and
                     w-mov-cge-tiv-spp    >    zero
                     go to det-mov-cge-470.
           go to     det-mov-cge-468.
       det-mov-cge-468.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      w-rig-num-pgf (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      spaces               to   w-err-box-err-msg      .
           string    "Attenzione : Anomalia relativa al pagamento nr. "
                                delimited by   size
                     v-edt      delimited by   spaces
                     "!"        delimited by   size
                                          into w-err-box-err-msg      .
           move      "             Totale scadenze incluse nel pagamento
      -              " non positivo  "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .

      *                  *---------------------------------------------*
      *                  * Flag di aggiornamento contabile da non ese- *
      *                  * guire                                       *
      *                  *---------------------------------------------*
           move      "#"                  to   w-mov-cge-flg-nag      .
      *                  *---------------------------------------------*
      *                  * Riciclo su prossimo pagamento               *
      *                  *---------------------------------------------*
           go to     det-mov-cge-100.
       det-mov-cge-470.
      *              *-------------------------------------------------*
      *              * Aggiornamento totale abbuoni                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se registrazione in conto : oltre           *
      *                  *---------------------------------------------*
           if        w-rig-aos-pgf (1)    =    02
                     go to det-mov-cge-480.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo operazione  *
      *                  *---------------------------------------------*
           if        w-tes-tip-ope        =    1830 or
                     w-tes-tip-ope        =    1840 or
                     w-tes-tip-ope        =    1850
                     go to det-mov-cge-472
           else if   w-tes-tip-ope        =    1831
                     go to det-mov-cge-474.
       det-mov-cge-472.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : 1830, 1840 o 1850; cioe'  *
      *                  * tipi operazione non in valuta               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se importo pagamento pari al totale     *
      *                      * scadenze per il pagamento : oltre       *
      *                      *-----------------------------------------*
           if        w-rig-imp-pgf (1)    =    w-mov-cge-tot-spp
                     go to det-mov-cge-480.
      *                      *-----------------------------------------*
      *                      * Differenza tra totale scadenze per il   *
      *                      * pagamento e importo pagamento in work   *
      *                      *-----------------------------------------*
           move      w-mov-cge-tot-spp    to   w-mov-cge-wrk-s11      .
           subtract  w-rig-imp-pgf (1)    from w-mov-cge-wrk-s11      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento progressivo abbuoni       *
      *                      *-----------------------------------------*
           add       w-mov-cge-wrk-s11    to   w-mov-cge-acc-abb      .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     det-mov-cge-480.
       det-mov-cge-474.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : 1831; cioe' addebito su   *
      *                  * estero                                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se sigla valuta pari a quella base :    *
      *                      * come per addebito normale               *
      *                      *-----------------------------------------*
           if        w-tes-sgl-vlt (1)    =    c-sgl
                     go to det-mov-cge-472.
      *                      *-----------------------------------------*
      *                      * Se importo pagamento pari al totale     *
      *                      * scadenze in valuta per il pagamento :   *
      *                      * oltre                                   *
      *                      *-----------------------------------------*
           if        w-rig-imp-pgf (1)    =    w-mov-cge-tiv-spp
                     go to det-mov-cge-480.
      *                      *-----------------------------------------*
      *                      * Differenza tra importo pagamento e to-  *
      *                      * tale scadenze in valuta per il pagamen- *
      *                      * to in work                              *
      *                      *-----------------------------------------*
           move      w-mov-cge-tiv-spp    to   w-mov-cge-dif-iiv      .
           subtract  w-rig-imp-pgf (1)    from w-mov-cge-dif-iiv      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento progressivo abbuoni       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione dell'importo abbuoni *
      *                          * in valuta base al coefficiente di   *
      *                          * cambio dell'addebito                *
      *                          *-------------------------------------*
           move      w-tes-sgl-vlt (1)    to   w-cvs-vlt-sgl          .
           move      w-tes-dec-vlt (1)    to   w-cvs-vlt-dec          .
           move      w-tes-tdc-vlt (1)    to   w-cvs-vlt-tdc          .
           move      w-pie-cdc-adp (1)    to   w-cvs-vlt-cdc          .
           move      w-mov-cge-dif-iiv    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
           add       w-cvs-vlt-avb        to   w-mov-cge-acc-abb      .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     det-mov-cge-480.
       det-mov-cge-480.
      *              *-------------------------------------------------*
      *              * Aggiornamento numero pagamenti per l'addebito   *
      *              *-------------------------------------------------*
           add       1                    to   w-mov-cge-ctr-ppa      .
      *              *-------------------------------------------------*
      *              * Aggiornamento totale pagamenti per l'addebito   *
      *              *-------------------------------------------------*
           add       w-mov-cge-tot-spp    to   w-mov-cge-tot-ppa      .
      *              *-------------------------------------------------*
      *              * Aggiornamento indice in tabella per ripartenza  *
      *              * su nuovo pagamento                              *
      *              *-------------------------------------------------*
           move      w-mov-cge-ctr-rig    to   w-mov-cge-inx-npg      .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura catena                       *
      *              *-------------------------------------------------*
           go to     det-mov-cge-100.
       det-mov-cge-500.
      *              *-------------------------------------------------*
      *              * Ripristino catena movimenti                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino area w-rig                       *
      *                  *---------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *                  *---------------------------------------------*
      *                  * Ripristino area catena                      *
      *                  *---------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
      *              *-------------------------------------------------*
      *              * Test su numero elementi bufferizzati            *
      *              *-------------------------------------------------*
           if        w-mov-cge-ctr-rig    >    zero
                     go to det-mov-cge-600.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "Attenzione : Anomalia relativa alla registrazione 
      -              "contabile.     "    to   w-err-box-err-msg      .
           move      "             Numero righe di registrazione a zero.
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                  *---------------------------------------------*
      *                  * Flag di aggiornamento contabile da non ese- *
      *                  * guire                                       *
      *                  *---------------------------------------------*
           move      "#"                  to   w-mov-cge-flg-nag      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-mov-cge-999.
       det-mov-cge-600.
      *              *-------------------------------------------------*
      *              * Test su totale pagamenti per l'addebito         *
      *              *-------------------------------------------------*
           if        w-mov-cge-tot-ppa    >    zero
                     go to det-mov-cge-700.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "Attenzione: Anomalia relativa alla registrazione c
      -              "ontabile.      "    to   w-err-box-err-msg      .
           move      "            Importo contropartita contabile in Ave
      -              "re non positivo"    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                  *---------------------------------------------*
      *                  * Flag di aggiornamento contabile da non ese- *
      *                  * guire                                       *
      *                  *---------------------------------------------*
           move      "#"                  to   w-mov-cge-flg-nag      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-mov-cge-999.
       det-mov-cge-700.
      *              *-------------------------------------------------*
      *              * Determinazione flag di Dare/Avere e assestamen- *
      *              * to importi in riga                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-mov-cge-inx-001      .
       det-mov-cge-820.
           add       1                    to   w-mov-cge-inx-001      .
           if        w-mov-cge-inx-001    >    w-mov-cge-ctr-rig
                     go to det-mov-cge-900.
           if        w-mov-cge-imp-rig
                    (w-mov-cge-inx-001)   =    zero
                     go to det-mov-cge-820.
           if        w-mov-cge-imp-rig
                    (w-mov-cge-inx-001)   >    zero
                     move  "D"            to   w-mov-cge-dar-ave
                                              (w-mov-cge-inx-001)
           else      move  "A"            to   w-mov-cge-dar-ave
                                              (w-mov-cge-inx-001)
                     multiply -1          by   w-mov-cge-iiv-rig
                                              (w-mov-cge-inx-001)
                     multiply -1          by   w-mov-cge-imp-rig
                                              (w-mov-cge-inx-001)     .
           go to     det-mov-cge-820.
       det-mov-cge-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-mov-cge-999.
       det-mov-cge-999.
           exit.
           
      *    *===========================================================*
      *    * Annullamento del movimento di contabilita' generale che   *
      *    * era stato a suo tempo generato a fronte del movimento di  *
      *    * scadenze fornitori                                        *
      *    *-----------------------------------------------------------*
       del-cge-scf-000.
      *              *-------------------------------------------------*
      *              * Se data registrazione o numero protocollo della *
      *              * registrazione contabile da annullare a zero :   *
      *              * uscita senza alcuna azione                      *
      *              *-------------------------------------------------*
           if        w-cge-scf-drc-del    =    zero or
                     w-cge-scf-npc-del    =    zero
                     go to del-cge-scf-999.
      *              *-------------------------------------------------*
      *              * Preparazione link-area per annullamento regi-   *
      *              * strazione di contabilita'                       *
      *              *-------------------------------------------------*
           move      "DE"                 to   l-cge-300-tip-ope      .
           move      w-cge-scf-drc-del    to   l-cge-300-dat-reg      .
           move      w-cge-scf-npc-del    to   l-cge-300-num-prt      .
      *              *-------------------------------------------------*
      *              * Richiamo sottoprogramma per aggiornamenti con-  *
      *              * tabili                                          *
      *              *-------------------------------------------------*
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
       del-cge-scf-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [fnt]                         *
      *    *-----------------------------------------------------------*
       let-arc-fnt-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-fnt-flg      .
      *              *-------------------------------------------------*
      *              * Test se codice fornitore a zero                 *
      *              *-------------------------------------------------*
           if        w-let-arc-fnt-cod    =    zero
                     go to let-arc-fnt-500.
