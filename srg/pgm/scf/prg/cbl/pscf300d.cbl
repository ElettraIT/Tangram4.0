      *                  * Normalizzazione record [sfa]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfa"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfa                 .
      *                  *---------------------------------------------*
      *                  * Composizione record [sfa]                   *
      *                  *---------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rf-sfa-ide-dat         .
           move      s-ute                to   rf-sfa-ide-ute         .
           move      s-fas                to   rf-sfa-ide-fas         .
           move      w-tes-dat-reg        to   rf-sfa-dtr-adp         .
           move      l-cge-300-dat-reg    to   rf-sfa-drc-adp         .
           move      l-cge-300-num-prt    to   rf-sfa-npc-adp         .
           move      w-tes-num-adp        to   rf-sfa-num-adp         .
           move      w-tes-mod-adp (1)    to   rf-sfa-mod-adp         .
           move      w-tes-tvl-adp (1)    to   rf-sfa-tvl-adp         .
           move      w-tes-cbp-adp (1)    to   rf-sfa-cbp-adp         .
           move      w-tes-tip-adp (1)    to   rf-sfa-tip-adp         .
           move      w-tes-cas-adp (1)    to   rf-sfa-cas-adp         .
           move      w-tes-sgl-vlt (1)    to   rf-sfa-sgl-vlt         .
           move      w-tes-dec-vlt (1)    to   rf-sfa-dec-vlt         .
           move      w-tes-tdc-vlt (1)    to   rf-sfa-tdc-vlt         .
           move      w-pie-cdc-adp (1)    to   rf-sfa-cdc-adp         .
           move      w-pie-iiv-adp (1)    to   rf-sfa-iiv-adp         .
           move      w-pie-imp-adp (1)    to   rf-sfa-imp-adp         .
           move      w-tes-ddo-adp (1)    to   rf-sfa-ddo-adp         .
           move      w-tes-ndo-adp (1)    to   rf-sfa-ndo-adp         .
           move      w-pie-spe-adp (1)    to   rf-sfa-spe-adp         .
           move      w-tes-fcs-uno (1)    to   rf-sfa-fcs-uno         .
           move      w-tes-fcs-due (1)    to   rf-sfa-fcs-due         .
