      *    *===========================================================*
      *    * Accettazione campo : Saldaconto pagamenti fornitori       *
      *    *-----------------------------------------------------------*
       acc-sdc-pgf-000.
      *              *-------------------------------------------------*
      *              * Se impostazione saldaconto gia' avvenuta        *
      *              *-------------------------------------------------*
           if        w-sdc-flg-imp        =    spaces
                     go to  acc-sdc-pgf-100.
           multiply  12                   by   w-sdc-npg-dat
                                        giving w-sdc-ctr-rig          .
           subtract  11                   from w-sdc-ctr-rig          .
           go to     acc-sdc-pgf-300.
       acc-sdc-pgf-100.
      *              *-------------------------------------------------*
      *              * Determinazione numero massimo pagine            *
      *              *-------------------------------------------------*
           move      w-bpf-num-ele        to   w-sdc-npg-max          .
           divide    12                   into w-sdc-npg-max
                                        giving w-sdc-npg-max
                                     remainder w-sdc-wrk-rem          .
           if        w-sdc-wrk-rem        >    zero
                     add    1             to   w-sdc-npg-max          .
      *              *-------------------------------------------------*
      *              * Preselezione per saldaconto pagamenti           *
      *              *-------------------------------------------------*
           perform   pre-sdc-pgf-000      thru pre-sdc-pgf-999        .
      *              *-------------------------------------------------*
      *              * Numero pagina visualizzata                      *
      *              *-------------------------------------------------*
           move      zero                 to   w-sdc-npg-vis          .
      *              *-------------------------------------------------*
      *              * Numero riga da trattare                         *
      *              *-------------------------------------------------*
           move      w-sdc-rig-ini        to   w-sdc-ctr-rig          .
       acc-sdc-pgf-200.
           add       1                    to   w-sdc-ctr-rig          .
           if        w-sdc-ctr-rig        >    w-bpf-num-ele
                     go to  acc-sdc-pgf-900.
       acc-sdc-pgf-300.
      *              *-------------------------------------------------*
      *              * Determinazione numero pagina da trattare        *
      *              *-------------------------------------------------*
           divide    12                   into w-sdc-ctr-rig
                                        giving w-sdc-npg-dat
                                     remainder w-sdc-wrk-rem          .
           if        w-sdc-wrk-rem        >    zero
                     add    1             to   w-sdc-npg-dat          .
      *              *-------------------------------------------------*
      *              * Visualizzazione totale pagamenti fornitori e    *
      *              * totale pagamenti selezionati                    *
      *              *-------------------------------------------------*
           if        w-sdc-npg-vis        =    zero
                     perform vis-tot-pgf-000
                                          thru vis-tot-pgf-999
                     perform vis-tot-pgs-000
                                          thru vis-tot-pgs-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione pagina da trattare              *
      *              *-------------------------------------------------*
           if        w-sdc-npg-dat        not  = w-sdc-npg-vis
                     perform vis-sdc-pgf-000
                                          thru vis-sdc-pgf-999        .
      *              *-------------------------------------------------*
      *              * Determinazione numero linea                     *
      *              *-------------------------------------------------*
           subtract  1                    from w-sdc-npg-dat
                                        giving w-sdc-wrk-rig          .
           multiply  12                   by   w-sdc-wrk-rig          .
           subtract  w-sdc-wrk-rig        from w-sdc-ctr-rig
                                        giving w-sdc-wrk-lin          .
           add       7                    to   w-sdc-wrk-lin          .
       acc-sdc-pgf-400.
      *              *-------------------------------------------------*
      *              * Accettazione riga saldaconto                    *
      *              *-------------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Flag di pagamento selezionato               *
      *                  *---------------------------------------------*
           perform   acc-flg-pgs-000      thru acc-flg-pgs-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-sdc-pgf-900.
      *                  *---------------------------------------------*
      *                  * Test su tipo uscita                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se Up                                   *
      *                      *-----------------------------------------*
           if        v-key                =    "UP  "
                     subtract 1           from w-sdc-ctr-rig
                     go to  acc-sdc-pgf-300.
      *                      *-----------------------------------------*
      *                      * Se Down                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "DOWN"
                     go to  acc-sdc-pgf-200.
      *                      *-----------------------------------------*
      *                      * Se Next Screen                          *
      *                      *-----------------------------------------*
           if        v-key                not  = "NXSC"
                     go to  acc-sdc-pgf-500.
           multiply  12                   by   w-sdc-npg-dat
                                        giving w-sdc-ctr-rig          .
           go to     acc-sdc-pgf-200.
       acc-sdc-pgf-500.
      *                      *-----------------------------------------*
      *                      * Se Prev Screen                          *
      *                      *-----------------------------------------*
           if        v-key                not  = "PRSC"
                     go to acc-sdc-pgf-600.
           if        w-sdc-npg-dat        =    1
                     go to acc-sdc-pgf-900.
           subtract  1                    from w-sdc-npg-dat          .
           multiply  12                   by   w-sdc-npg-dat
                                        giving w-sdc-ctr-rig          .
           subtract  11                   from w-sdc-ctr-rig          .
           go to     acc-sdc-pgf-300.
       acc-sdc-pgf-600.
      *                      *-----------------------------------------*
      *                      * Se Tab                                  *
      *                      *-----------------------------------------*
           if        v-key                =    "TAB "
                     move   w-bpf-num-ele to   w-sdc-ctr-rig
                     go to  acc-sdc-pgf-300.
      *                      *-----------------------------------------*
      *                      * Se Back                                 *
      *                      *-----------------------------------------*
           if        v-key                =    "BACK"
                     move   1             to   w-sdc-ctr-rig
                     go to  acc-sdc-pgf-300.
      *              *-------------------------------------------------*
      *              * Riciclo a riga successiva                       *
      *              *-------------------------------------------------*
           go to     acc-sdc-pgf-200.
       acc-sdc-pgf-900.
      *              *-------------------------------------------------*
      *              * Attivazione flag di saldaconto impostato        *
      *              *-------------------------------------------------*
           move      "#"                  to   w-sdc-flg-imp          .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-sdc-pgf-999.
       acc-sdc-pgf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Saldaconto pagamenti fornitori    *
      *    *-----------------------------------------------------------*
       vis-sdc-pgf-000.
      *              *-------------------------------------------------*
      *              * Aggiornamento numero pagina visualizzata        *
      *              *-------------------------------------------------*
           move      w-sdc-npg-dat        to   w-sdc-npg-vis          .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Determinazione valore iniziale contatore ele-   *
      *              * menti                                           *
      *              *-------------------------------------------------*
           multiply  12                   by   w-sdc-npg-dat
                                      giving   w-vis-sdc-pgf-cte      .
           subtract  12                   from w-vis-sdc-pgf-cte      .
      *              *-------------------------------------------------*
      *              * Ciclo si scansione 1..12 righe                  *
      *              *-------------------------------------------------*
           move      zero                 to   w-vis-sdc-pgf-ctr      .
       vis-sdc-pgf-100.
           add       1                    to   w-vis-sdc-pgf-ctr      .
           if        w-vis-sdc-pgf-ctr    >    12
                     go to vis-sdc-pgf-900.
      *                  *---------------------------------------------*
      *                  * Incremento contatore elementi               *
      *                  *---------------------------------------------*
           add       1                    to   w-vis-sdc-pgf-cte      .
      *                  *---------------------------------------------*
      *                  * Test se maggiore del numero elementi nel    *
      *                  * buffer                                      *
      *                  *---------------------------------------------*
           if        w-vis-sdc-pgf-cte    >    w-bpf-num-ele
                     go to vis-sdc-pgf-200
           else      go to vis-sdc-pgf-400.
       vis-sdc-pgf-200.
      *                  *---------------------------------------------*
      *                  * Se maggiore                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prima pagina da trattare : oltre     *
      *                      *-----------------------------------------*
           if        w-sdc-npg-dat        =    1
                     go to  vis-sdc-pgf-900.
      *                      *-----------------------------------------*
      *                      * Stampa riga bianca                      *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           add       7
                     w-vis-sdc-pgf-ctr  giving v-lin                  .
           move      01                   to   v-pos                  .
           move      "                                             |    
      -              "            |   |             "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Riciclo su scansione                    *
      *                      *-----------------------------------------*
           go to     vis-sdc-pgf-100.
       vis-sdc-pgf-400.
      *                  *---------------------------------------------*
      *                  * Se minore o uguale                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Visualizzazione valori elemento         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Dipendenza fornitore                *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      04                   to   v-car                  .
           add       7
                     w-vis-sdc-pgf-ctr  giving v-lin                  .
           move      01                   to   v-pos                  .
           move      w-bpf-dpz-fnt
                    (w-vis-sdc-pgf-cte)   to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Ragione sociale fornitore           *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           add       7
                     w-vis-sdc-pgf-ctr  giving v-lin                  .
           move      06                   to   v-pos                  .
           move      w-bpf-rag-fnt
                    (w-vis-sdc-pgf-cte)   to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sdc-pgf-420.
      *                          *-------------------------------------*
      *                          * Importo pagamento                   *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Importo pagamento               *
      *                              *---------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vlt (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "G"                  to   v-edm                  .
           add       7
                     w-vis-sdc-pgf-ctr  giving v-lin                  .
           move      47                   to   v-pos                  .
           move      w-bpf-imp-pgf
                    (w-vis-sdc-pgf-cte)   to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Flag di pagamento selezionato       *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           add       7
                     w-vis-sdc-pgf-ctr  giving v-lin                  .
           move      65                   to   v-pos                  .
           move      w-bpf-flg-pgs
                    (w-vis-sdc-pgf-cte)   to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Importo pagamento selezionato       *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Test se da visualizzare         *
      *                              *---------------------------------*
           if        w-bpf-flg-pgs
                    (w-vis-sdc-pgf-cte)   not  = "S"
                     go to vis-sdc-pgf-460.
      *                              *---------------------------------*
      *                              * Visualizzazione                 *
      *                              *---------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           if        w-bpf-imp-pgf
                    (w-vis-sdc-pgf-cte)   >    999999999 or
                     w-bpf-imp-pgf
                    (w-vis-sdc-pgf-cte)   <   -999999999
                     move  11             to   v-car
           else      move  09             to   v-car                  .
           move      w-tes-dec-vlt (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "G"                  to   v-edm                  .
           add       7
                     w-vis-sdc-pgf-ctr  giving v-lin                  .
           move      68                   to   v-pos                  .
           move      w-bpf-imp-pgf
                    (w-vis-sdc-pgf-cte)   to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sdc-pgf-460.
      *                  *---------------------------------------------*
      *                  * Riciclo su riga successiva                  *
      *                  *---------------------------------------------*
           go to     vis-sdc-pgf-100.
       vis-sdc-pgf-900.
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sdc-pgf-999.
           exit.

      *    *===========================================================*
