           move      80                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "N.R                         Fornitore             
      -              "                Importo       "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
