           else if   w-tes-tip-ope        =    1850
                     go to rou-let-reg-641
           else      go to rou-let-reg-645.
       rou-let-reg-641.
      *                                          *---------------------*
      *                                          * Tipo operazione :   *
      *                                          * 1830, 1831 o 1850   *
      *                                          *---------------------*
           move      "Attenzione : Manca il sottoconto per oneri bancari
      -              "associato al   "    to   w-err-box-err-msg      .
           move      "             codice nostra banca.                 
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           go to     rou-let-reg-645.
       rou-let-reg-643.
      *                                          *---------------------*
      *                                          * Tipo operazione :   *
      *                                          * 1840                *
      *                                          *---------------------*
           move      "Attenzione : Manca il sottoconto per oneri postali
      -              "associato al   "    to   w-err-box-err-msg      .
           move      "             nostro c/c postale.                  
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           go to     rou-let-reg-645.
       rou-let-reg-645.
      *                                      *-------------------------*
      *                                      * 'Visualizzazione'       *
      *                                      *-------------------------*
           move      "V"                  to   w-cnt-mfu-tip-fun      .
       rou-let-reg-650.
      *                              *---------------------------------*
      *                              * Controllo su sottoconto diffe-  *
      *                              * renze cambio passive associato  *
      *                              * al codice nostra banca o c/c    *
      *                              * postale                         *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Test se controllo da effet- *
      *                                  * tuare                       *
      *                                  *-----------------------------*
           if        w-tes-tip-ope        not  = 1831
                     go to rou-let-reg-670.
      *                                  *-----------------------------*
      *                                  * Se codice sottoconto a zero *
      *                                  *-----------------------------*
           if        w-tes-cbp-adp-sdp (1)
                                          not  = zero
                     go to rou-let-reg-670.
      *                                      *-------------------------*
      *                                      * Se si e' gia in visua-  *
      *                                      * lizzazione : nessuna    *
      *                                      * azione                  *
      *                                      *-------------------------*
           if        w-cnt-mfu-tip-fun    =    "V"
                     go to rou-let-reg-670.
      *                                      *-------------------------*
      *                                      * Emissione messaggio     *
      *                                      *-------------------------*
           move      "Attenzione : Manca il sottoconto contabile per dif
      -              "ferenze cambio "    to   w-err-box-err-msg      .
           move      "             passive, associato al codice banca.  
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                                      *-------------------------*
      *                                      * 'Visualizzazione'       *
      *                                      *-------------------------*
           move      "V"                  to   w-cnt-mfu-tip-fun      .
       rou-let-reg-670.
      *                              *---------------------------------*
      *                              * Controllo su sottoconto diffe-  *
      *                              * renze cambio attive associato   *
      *                              * al codice nostra banca o c/c    *
      *                              * postale                         *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Test se controllo da effet- *
      *                                  * tuare                       *
      *                                  *-----------------------------*
           if        w-tes-tip-ope        not  = 1831
                     go to rou-let-reg-680.
      *                                  *-----------------------------*
      *                                  * Se codice sottoconto a zero *
      *                                  *-----------------------------*
           if        w-tes-cbp-adp-sda (1)
                                          not  = zero
                     go to rou-let-reg-680.
      *                                      *-------------------------*
      *                                      * Se si e' gia in visua-  *
      *                                      * lizzazione : nessuna    *
      *                                      * azione                  *
      *                                      *-------------------------*
           if        w-cnt-mfu-tip-fun    =    "V"
                     go to rou-let-reg-680.
      *                                      *-------------------------*
      *                                      * Emissione messaggio     *
      *                                      *-------------------------*
           move      "Attenzione : Manca il sottoconto contabile per dif
      -              "ferenze cambio "    to   w-err-box-err-msg      .
           move      "             attive, associato al codice banca.   
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                                      *-------------------------*
      *                                      * 'Visualizzazione'       *
      *                                      *-------------------------*
           move      "V"                  to   w-cnt-mfu-tip-fun      .
       rou-let-reg-680.
      *                              *---------------------------------*
      *                              * Fine controlli su sottoconti    *
      *                              * per aggiornamento contabile     *
      *                              *---------------------------------*
           go to     rou-let-reg-700.
       rou-let-reg-700.
      *                      *-----------------------------------------*
      *                      * Fine controlli per forzare la sola Vi-  *
      *                      * sualizzazione                           *
      *                      *-----------------------------------------*
       rou-let-reg-800.
      *                      *-----------------------------------------*
      *                      * Caricamento righe, con ordinamento per  *
      *                      * data registrazione pagamento            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Messaggio di caricamento in esecu-  *
      *                          * zione                               *
      *                          *-------------------------------------*
           move      "              Caricamento operazione in esecuzione
      -              "               "    to   w-err-box-err-msg      .
           perform   msg-cnt-box-000      thru msg-cnt-box-999        .
      *                          *-------------------------------------*
      *                          * Sort                                *
      *                          *-------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   rou-let-reg-inp-000
                                          thru rou-let-reg-inp-999
                     output procedure     is   rou-let-reg-out-000
                                          thru rou-let-reg-out-999    .
      *                          *-------------------------------------*
      *                          * Messaggio di fine caricamento       *
      *                          *-------------------------------------*
           move      spaces               to   w-err-box-err-msg      .
           perform   msg-cnt-box-000      thru msg-cnt-box-999        .
      *                          *-------------------------------------*
      *                          * Se pagamenti non esistenti in ri-   *
      *                          * lettura pagamenti dell'addebito,    *
      *                          * oppure se anomalia nei pagamenti:   *
      *                          * sola visualizzazione                *
      *                          *-------------------------------------*
           if        w-rou-let-reg-npn    =    zero and
                     w-rou-let-reg-npa    =    zero   
                     go to rou-let-reg-820.
           if        w-cnt-mfu-tip-fun    =    "I"
                     move  "#"            to   w-cnt-rou-let-reg
                     go to rou-let-reg-999
           else      move  "V"            to   w-cnt-mfu-tip-fun      .
       rou-let-reg-820.
      *                          *-------------------------------------*
      *                          * Valore testata : totale righe paga- *
      *                          * menti selezionati                   *
      *                          *-------------------------------------*
           move      w-rou-let-reg-igc    to   w-tes-tot-rps (1)      .
       rou-let-reg-900.
      *                      *-----------------------------------------*
      *                      * Determinazione valori attuali piede     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Valori provenienti dalla testata    *
      *                          *-------------------------------------*
           move      w-tes-tot-rps (1)    to   w-pie-tot-pfs (1)      .
      *                          *-------------------------------------*
      *                          * Valori contenuti direttamente in    *
      *                          * record [sfa]                        *
      *                          *-------------------------------------*
           move      rf-sfa-iiv-adp       to   w-pie-iiv-adp (1)      .
           move      zero                 to   w-pie-cdc-dtr (1)      .
           move      rf-sfa-cdc-adp       to   w-pie-cdc-adp (1)      .
           move      rf-sfa-imp-adp       to   w-pie-imp-adp (1)      .
           move      rf-sfa-spe-adp       to   w-pie-spe-adp (1)      .
      *                      *-----------------------------------------*
      *                      * Valori precedenti piede                 *
      *                      *-----------------------------------------*
           move      w-pie-val-aep (1)    to   w-pie-val-aep (2)      .
       rou-let-reg-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort in fase di caricamento righe     *
      *    * pagamenti fornitore relative ad un operazione di addebito *
      *    *-----------------------------------------------------------*
       rou-let-reg-inp-000.
      *              *-------------------------------------------------*
      *              * Start su file [sfp]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CBPADP    "         to   f-key                  .
           move      w-tes-cbp-adp (1)    to   rf-sfp-cbp-pgf         .
           move      w-tes-num-adp        to   rf-sfp-num-adp         .
           move      zero                 to   rf-sfp-num-pgf         .
           move      "pgm/scf/fls/ioc/obj/iofsfp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfp                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rou-let-reg-inp-999.
       rou-let-reg-inp-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [sfp]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfp                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rou-let-reg-inp-999.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-sfp-cbp-pgf       not  = w-tes-cbp-adp (1) or
                     rf-sfp-num-adp       not  = w-tes-num-adp
                     go to rou-let-reg-inp-999.
       rou-let-reg-inp-300.
      *              *-------------------------------------------------*
      *              * Composizione sort-record                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Chiave del sort                             *
      *                  *---------------------------------------------*
           move      rf-sfp-dtr-pgf       to   srt-dtr-pgf            .
           move      rf-sfp-num-pgf       to   srt-num-pgf            .
      *                  *---------------------------------------------*
      *                  * Dati del sort                               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Valori contenuti direttamente in record *
      *                      * [sfp]                                   *
      *                      *-----------------------------------------*
           move      rf-sfp-cod-fnt       to   srt-cod-fnt            .
           move      rf-sfp-dpz-fnt       to   srt-dpz-fnt            .
           move      rf-sfp-imp-pgf       to   srt-imp-pgf            .
           move      rf-sfp-aos-pgf       to   srt-aos-pgf            .
      *                      *-----------------------------------------*
      *                      * Valori contenuti indirettamente in re-  *
      *                      * cord [sfp]                              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Lettura archivio [dcf]              *
      *                          *-------------------------------------*
           if        rf-sfp-dpz-fnt       =    spaces
                     move  "C"            to   w-let-arc-dcf-tle
           else      move  "D"            to   w-let-arc-dcf-tle      .
           move      rf-sfp-cod-fnt       to   w-let-arc-dcf-cod      .
           move      rf-sfp-dpz-fnt       to   w-let-arc-dcf-dpz      .
           perform   let-arc-dcf-000      thru let-arc-dcf-999        .
           move      w-let-arc-dcf-rag    to   srt-rag-fnt            .
       rou-let-reg-inp-400.
      *              *-------------------------------------------------*
      *              * Rilascio record al sort                         *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       rou-let-reg-inp-500.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale record [sfp]     *
      *              *-------------------------------------------------*
           go to     rou-let-reg-inp-100.
       rou-let-reg-inp-999.
           exit.

      *    *===========================================================*
      *    * Output procedure per sort in fase di caricamento righe    *
      *    * pagamenti fornitore relative ad un operazione di addebito *
      *    *-----------------------------------------------------------*
       rou-let-reg-out-000.
      *              *-------------------------------------------------*
      *              * Preparazioni iniziali                           *
      *              *-------------------------------------------------*
       rou-let-reg-out-025.
      *                  *---------------------------------------------*
      *                  * Normalizzazione parametri in output per il  *
      *                  * caricamento iniziale pagamenti per addebi-  *
      *                  * to per mezzo della rilettura dell'operazio- *
      *                  * ne pre-esistente                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Numero di pagamenti caricati            *
      *                      *-----------------------------------------*
           move      zero                 to   w-rou-let-reg-npc      .
      *                      *-----------------------------------------*
      *                      * Importo globale caricato                *
      *                      *-----------------------------------------*
           move      zero                 to   w-rou-let-reg-igc      .
      *                      *-----------------------------------------*
      *                      * Numero di pagamenti non esistenti nella *
      *                      * rilettura dopo il sort                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-rou-let-reg-npn      .
      *                      *-----------------------------------------*
      *                      * Numero di pagamenti con anomalie nella  *
      *                      * rilettura dopo il sort                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-rou-let-reg-npa      .
       rou-let-reg-out-100.
      *              *-------------------------------------------------*
      *              * Lettura record da sort                          *
      *              *-------------------------------------------------*
           return    srt    at end
                            go to rou-let-reg-out-999.
      *              *-------------------------------------------------*
      *              * Rilettura record [sfp]                          *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPGF    "         to   f-key                  .
           move      srt-num-pgf          to   rf-sfp-num-pgf         .
           move      "pgm/scf/fls/ioc/obj/iofsfp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfp                 .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to rou-let-reg-out-300
           else      go to rou-let-reg-out-200.
       rou-let-reg-out-200.
      *              *-------------------------------------------------*
      *              * Se pagamento non trovato in [sfp]               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Incremento numero pagamenti non esistenti   *
      *                  *---------------------------------------------*
           add       1                    to   w-rou-let-reg-npn      .
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      srt-num-pgf          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      spaces               to   w-err-box-err-msg      .
           string    "Attenzione : Pagamento nr. "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " non esistente in archivio!"
                                delimited by   size
                                          into w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura record da sort           *
      *                  *---------------------------------------------*
           go to     rou-let-reg-out-100.
       rou-let-reg-out-300.
      *              *-------------------------------------------------*
      *              * Se pagamento esistente in [sfp]                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Append in catena                            *
      *                  *---------------------------------------------*
           move      "AP"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Normalizzazione riga                        *
      *                  *---------------------------------------------*
           perform   nor-nok-rig-000      thru nor-nok-rig-999        .
      *                  *---------------------------------------------*
      *                  * Composizione riga                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Aggiornamento del numero progressivo    *
      *                      *-----------------------------------------*
           perform   prg-rig-cor-000      thru prg-rig-cor-999        .
      *                      *-----------------------------------------*
      *                      * Valori contenuti direttamente in record *
      *                      * [sfp]                                   *
      *                      *-----------------------------------------*
           move      rf-sfp-num-pgf       to   w-rig-num-pgf (1)      .
           move      rf-sfp-cod-fnt       to   w-rig-cod-fnt (1)      .
           move      rf-sfp-dpz-fnt       to   w-rig-dpz-fnt (1)      .
           move      rf-sfp-imp-pgf       to   w-rig-imp-pgf (1)      .
           move      rf-sfp-aos-pgf       to   w-rig-aos-pgf (1)      .
      *                      *-----------------------------------------*
      *                      * Valori contenuti indirettamente in re-  *
      *                      * cord [sfp]                              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Lettura archivio [dcf]              *
      *                          *-------------------------------------*
           if        rf-sfp-dpz-fnt       =    spaces
                     move  "C"            to   w-let-arc-dcf-tle
           else      move  "D"            to   w-let-arc-dcf-tle      .
           move      rf-sfp-cod-fnt       to   w-let-arc-dcf-cod      .
           move      rf-sfp-dpz-fnt       to   w-let-arc-dcf-dpz      .
           perform   let-arc-dcf-000      thru let-arc-dcf-999        .
           move      w-let-arc-dcf-rag    to   w-rig-rag-fnt (1)      .
      *                  *---------------------------------------------*
      *                  * Valori attuali in valori precedenti         *
      *                  *---------------------------------------------*
           move      w-rig-val-aep (1)    to   w-rig-val-aep (2)      .
      *                  *---------------------------------------------*
      *                  * Update catena                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-max        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Incremento numero pagamenti caricati        *
      *                  *---------------------------------------------*
           add       1                    to   w-rou-let-reg-npc      .
      *                  *---------------------------------------------*
      *                  * Aggiornamento totale righe pagamenti sele-  *
      *                  * zionati                                     *
      *                  *---------------------------------------------*
           add       rf-sfp-imp-pgf       to   w-rou-let-reg-igc      .
       rou-let-reg-out-600.
      *                  *---------------------------------------------*
      *                  * Tests vari su pagamento caricato            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Su flags di elaborazione bloccanti      *
      *                      *-----------------------------------------*
           if        rf-sfp-flg-blo       =    spaces
                     go to rou-let-reg-out-620.
      *                          *-------------------------------------*
      *                          * Messaggio di errore                 *
      *                          *-------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      srt-num-pgf          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      spaces               to   w-err-box-err-msg      .
           string    "Attenzione : Anomalia relativa al pagamento nr. "
                                delimited by   size
                     v-edt      delimited by   spaces
                     "!"        delimited by   size
                                          into w-err-box-err-msg      .
           move      "             Il pagamento e' stata sottoposto ad e
      -              "laborazioni.   "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                          *-------------------------------------*
      *                          * Incremento numero pagamenti con a-  *
      *                          * nomalie                             *
      *                          *-------------------------------------*
           add       1                    to   w-rou-let-reg-npa      .
       rou-let-reg-out-620.
      *                      *-----------------------------------------*
      *                      * Su flags di sottoponibilita' a pulizia  *
      *                      *-----------------------------------------*
           if        rf-sfp-flg-pul       =    spaces
                     go to rou-let-reg-out-640.
      *                          *-------------------------------------*
      *                          * Messaggio di errore                 *
      *                          *-------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      srt-num-pgf          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      spaces               to   w-err-box-err-msg      .
           string    "Attenzione : Anomalia relativa al pagamento nr. "
                                delimited by   size
                     v-edt      delimited by   spaces
                     "!"        delimited by   size
                                          into w-err-box-err-msg      .
           move      "             Il pagamento e' in corso di eliminazi
      -              "one.           "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                          *-------------------------------------*
      *                          * Incremento numero pagamenti con a-  *
      *                          * nomalie                             *
      *                          *-------------------------------------*
           add       1                    to   w-rou-let-reg-npa      .
       rou-let-reg-out-640.
      *                      *-----------------------------------------*
      *                      * Fine controlli su pagamento caricato    *
      *                      *-----------------------------------------*
           go to     rou-let-reg-out-900.
       rou-let-reg-out-900.
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura record da sort           *
      *                  *---------------------------------------------*
           go to     rou-let-reg-out-100.
       rou-let-reg-out-999.
           exit.

      *    *===========================================================*
      *    * Routine pre-accettazioni per inserimento                  *
      *    *-----------------------------------------------------------*
       pre-acc-ins-000.
