      *    *===========================================================*
      *    * Accettazione : Numero pagamento fornitore                 *
      *    *-----------------------------------------------------------*
       acc-num-pgf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-num-pgf (1)    to   w-sav-num-pgf          .
       acc-num-pgf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino valore precedente                *
      *                  *---------------------------------------------*
           move      w-sav-num-pgf        to   w-rig-num-pgf (1)      .
      *                  *---------------------------------------------*
      *                  * Parametri generici                          *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      20                   to   v-lin                  .
           move      19                   to   v-pos                  .
      *                  *---------------------------------------------*
      *                  * Tasti funzione                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Up   : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "UP  "               to   v-pfk (01)             .
      *                      *-----------------------------------------*
      *                      * Down : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "DOWN"         to   v-pfk (02)             .
      *                      *-----------------------------------------*
      *                      * Find : ammesso solo se record new e se  *
      *                      * il primo campo ammette il Find          *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     move  "FIND"         to   v-pfk (03)             .
      *                      *-----------------------------------------*
      *                      * Insr : sempre ammesso, a meno che non   *
      *                      *        si sia in un record New oppure   *
      *                      *        manchi spazio per l'inserimento  *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces and
                     w-cat-rig-ins        =    spaces
                     move  "INSR"         to   v-pfk (04)             .
      *                      *-----------------------------------------*
      *                      * Do   : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "DO  "               to   v-pfk (05)             .
      *                      *-----------------------------------------*
      *                      * Remv : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "REMV"               to   v-pfk (06)             .
      *                      *-----------------------------------------*
      *                      * Prsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "PRSC"               to   v-pfk (07)             .
      *                      *-----------------------------------------*
      *                      * Nxsc : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "NXSC"         to   v-pfk (08)             .
      *                      *-----------------------------------------*
      *                      * Back : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sulla prima riga     *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    not  = 1
                     move  "BACK"         to   v-pfk (09)             .
      *                      *-----------------------------------------*
      *                      * Tab  : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'ultima riga e   *
      *                      *        che questa sia in Append         *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces or
                     w-cat-rig-lst        =    spaces
                     move  "TAB "         to   v-pfk (10)             .
      *                      *-----------------------------------------*
      *                      * Slct : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'unica riga      *
      *                      *-----------------------------------------*
           if        w-cat-rig-max        not  = 1
                     move  "SLCT"         to   v-pfk (11)             .
      *                      *-----------------------------------------*
      *                      * Expd : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "EXPD"               to   v-pfk (12)             .
      *                      *-----------------------------------------*
      *                      * Valore di accettazione                  *
      *                      *-----------------------------------------*
           move      w-rig-num-pgf (1)    to   v-num                  .
       acc-num-pgf-200.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine di accettazione     *
      *                      *-----------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Return                                       *
      *              *-------------------------------------------------*
           if        v-key                =    spaces
                     go to acc-num-pgf-400.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-num-pgf-225.
           move      "S"                  to   w-fnd-arc-sfp-sns      .
           if        w-tes-tip-ope        =    1830 or
                     w-tes-tip-ope        =    1831
                     move  13             to   w-fnd-arc-sfp-mod
           else if   w-tes-tip-ope        =    1840
                     move  14             to   w-fnd-arc-sfp-mod
           else if   w-tes-tip-ope        =    1850
                     move  15             to   w-fnd-arc-sfp-mod
           else      move  zero           to   w-fnd-arc-sfp-mod      .
           if        w-tes-tip-ope        =    1831
                     move  02             to   w-fnd-arc-sfp-tvl
           else      move  01             to   w-fnd-arc-sfp-tvl      .
           if        w-tes-tip-ope        =    1831
                     move  w-tes-sgl-vlt (1)
                                          to   w-fnd-arc-sfp-vlt
           else      move  spaces         to   w-fnd-arc-sfp-vlt      .
           move      w-tes-cbp-adp (1)    to   w-fnd-arc-sfp-cbp      .
           move      "S"                  to   w-fnd-arc-sfp-sda      .
           perform   fnd-arc-sfp-000      thru fnd-arc-sfp-999        .
      *                  *---------------------------------------------*
      *                  * Se selezione non effettuata : a reimposta-  *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           if        w-fnd-arc-sfp-sel    not  = spaces
                     go to acc-num-pgf-100.
      *                  *---------------------------------------------*
      *                  * Numero pagamento selezionato in campo di    *
      *                  * destinazione                                *
      *                  *---------------------------------------------*
           move      w-fnd-arc-sfp-num    to   w-rig-num-pgf (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione numero pagamento seleziona- *
      *                  * to                                          *
      *                  *---------------------------------------------*
           perform   vis-num-pgf-000      thru vis-num-pgf-999        .
      *                  *---------------------------------------------*
      *                  * Normalizzazione function-key di impostazio- *
      *                  * ne                                          *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Continuazione post-impostazione             *
      *                  *---------------------------------------------*
           go to     acc-num-pgf-400.
       acc-num-pgf-225.
      *              *-------------------------------------------------*
      *              * Se Expd                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "EXPD"
                     go to acc-num-pgf-250.
      *                  *---------------------------------------------*
      *                  * Espansione su pagamenti fornitori           *
      *                  *---------------------------------------------*
           if        w-rig-num-pgf (1)    =    zero
                     move  "S"            to   w-esp-arc-sfp-sns
           else      move  "N"            to   w-esp-arc-sfp-sns      .
           move      v-num                to   w-esp-arc-sfp-num      .
           perform   esp-arc-sfp-000      thru esp-arc-sfp-999        .
      *                  *---------------------------------------------*
      *                  * Se selezione non effettuata : a reimposta-  *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           if        w-esp-arc-sfp-sel    not  = spaces
                     go to acc-num-pgf-100.
      *                  *---------------------------------------------*
      *                  * Ripresa numero pagamento selezionato        *
      *                  *---------------------------------------------*
           move      w-esp-arc-sfp-num    to   w-rig-num-pgf (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione numero pagamento seleziona- *
      *                  * to                                          *
      *                  *---------------------------------------------*
           perform   vis-num-pgf-000      thru vis-num-pgf-999        .
      *                  *---------------------------------------------*
      *                  * Normalizzazione function-key di impostazio- *
      *                  * ne                                          *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Continuazione post-impostazione             *
      *                  *---------------------------------------------*
           go to     acc-num-pgf-400.
       acc-num-pgf-250.
      *              *-------------------------------------------------*
      *              * Se Slct                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "SLCT"
                     go to acc-num-pgf-300
           else      go to acc-num-pgf-350.
       acc-num-pgf-300.
      *                  *---------------------------------------------*
      *                  * Conversione numero riga impostato in forma- *
      *                  * to numerico                                 *
      *                  *---------------------------------------------*
           move      v-num                to   w-cnt-slc-rap-num      .
       acc-num-pgf-320.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato minore di 1 o mag- *
      *                  * maggiore del massimo : reimpostazione       *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    zero       or
                     w-cnt-slc-rap-num    >    w-cat-rig-max
                     go to acc-num-pgf-100.
      *                  *---------------------------------------------*
