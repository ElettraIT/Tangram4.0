      *    * Accettazione campo saldaconto : Flag di pagamento sele-   *
      *    *                                 zionato                   *
      *    *-----------------------------------------------------------*
       acc-flg-pgs-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-bpf-flg-pgs
                    (w-sdc-ctr-rig)       to   w-sav-flg-pgs          .
       acc-flg-pgs-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      65                   to   v-pos                  .
           if        w-sdc-ctr-rig        >    1
                     move   "UP  "        to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           if        w-sdc-npg-dat        <    w-sdc-npg-max
                     move   "NXSC"        to   v-pfk (06)             .
           if        w-sdc-npg-dat        >    1
                     move   "PRSC"        to   v-pfk (07)             .
           if        w-sdc-ctr-rig        <    w-bpf-num-ele
                     move   "TAB "        to   v-pfk (08)             .
           if        w-sdc-ctr-rig        >    1
                     move   "BACK"        to   v-pfk (09)             .
           move      "SLCT"               to   v-pfk (10)             .
           move      "EXPD"               to   v-pfk (12)             .
           move      w-bpf-flg-pgs
                    (w-sdc-ctr-rig)       to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-flg-pgs-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-flg-pgs-999.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-bpf-flg-pgs
                                              (w-sdc-ctr-rig)         .
       acc-flg-pgs-200.
      *              *-------------------------------------------------*
      *              * Se Expand                                       *
      *              *-------------------------------------------------*
           if        v-key                not  = "EXPD"
                     go to acc-flg-pgs-250.
      *                  *---------------------------------------------*
      *                  * Se campo modificato : ripristino valore pre-*
      *                  * cedente e reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-bpf-flg-pgs
                    (w-sdc-ctr-rig)       not  = w-sav-flg-pgs
                     move  w-sav-flg-pgs  to   w-bpf-flg-pgs
                                              (w-sdc-ctr-rig)
                     go to acc-flg-pgs-100.
      *                  *---------------------------------------------*
      *                  * Espansione su pagamenti fornitori           *
      *                  *---------------------------------------------*
           move      "N"                  to   w-esp-arc-sfp-sns      .
           move      w-bpf-num-pgf
                    (w-sdc-ctr-rig)       to   w-esp-arc-sfp-num      .
           perform   esp-arc-sfp-000      thru esp-arc-sfp-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo a reimpostazione                    *
      *                  *---------------------------------------------*
           go to     acc-flg-pgs-100.
       acc-flg-pgs-250.
      *              *-------------------------------------------------*
      *              * Se Up, Down, Prsc, Nxsc, Tab e Back             *
      *              *-------------------------------------------------*
           if        v-key                not  = "UP  " and
                     v-key                not  = "DOWN" and
                     v-key                not  = "PRSC" and
                     v-key                not  = "NXSC" and
                     v-key                not  = "TAB " and
                     v-key                not  = "BACK"
                     go to acc-flg-pgs-300.
      *                  *---------------------------------------------*
      *                  * Se campo modificato : ripristino valore pre-*
      *                  * cedente e reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-bpf-flg-pgs
                    (w-sdc-ctr-rig)       not  = w-sav-flg-pgs
                     move  w-sav-flg-pgs  to   w-bpf-flg-pgs
                                              (w-sdc-ctr-rig)
                     go to acc-flg-pgs-100.
      *                  *---------------------------------------------*
      *                  * Altrimenti : uscita                         *
      *                  *---------------------------------------------*
           go to     acc-flg-pgs-999.
       acc-flg-pgs-300.
      *              *-------------------------------------------------*
      *              * Se Slct                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "SLCT"
                     go to acc-flg-pgs-400.
      *                  *---------------------------------------------*
      *                  * Se campo modificato : ripristino valore pre-*
      *                  * cedente e reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-bpf-flg-pgs
                    (w-sdc-ctr-rig)       not  = w-sav-flg-pgs
                     move  w-sav-flg-pgs  to   w-bpf-flg-pgs
                                              (w-sdc-ctr-rig)
                     go to acc-flg-pgs-100.
      *                  *---------------------------------------------*
      *                  * Azioni per Slct                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se pagamento gia' selezionato           *
      *                      *-----------------------------------------*
           if        w-bpf-flg-pgs
                    (w-sdc-ctr-rig)       not  = "S"
                     go to  acc-flg-pgs-320.
      *                          *-------------------------------------*
      *                          * Aggiornamento flag di pagamento se- *
      *                          * lezionato                           *
      *                          *-------------------------------------*
           move      spaces               to   w-bpf-flg-pgs
                                              (w-sdc-ctr-rig)         .
      *                          *-------------------------------------*
      *                          * Aggiornamento totale pagamenti se-  *
      *                          * lezionati                           *
      *                          *-------------------------------------*
           subtract  w-bpf-imp-pgf
                    (w-sdc-ctr-rig)       from w-sdc-tot-pgs          .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-flg-pgs-340.
       acc-flg-pgs-320.
      *                      *-----------------------------------------*
      *                      * Se pagamento non selezionato            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Aggiornamento flag di pagamento se- *
      *                          * lezionato                           *
      *                          *-------------------------------------*
           move      "S"                  to   w-bpf-flg-pgs
                                              (w-sdc-ctr-rig)         .
      *                          *-------------------------------------*
      *                          * Aggiornamento totale pagamenti se-  *
      *                          * lezionati                           *
      *                          *-------------------------------------*
           add       w-bpf-imp-pgf
                    (w-sdc-ctr-rig)       to   w-sdc-tot-pgs          .
       acc-flg-pgs-340.
      *                      *-----------------------------------------*
      *                      * Visualizzazione flag di pagamento sele- *
      *                      * zionato                                 *
      *                      *-----------------------------------------*
           perform   vis-flg-pgs-000      thru vis-flg-pgs-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione importo pagamento sele- *
      *                      * zionato                                 *
      *                      *-----------------------------------------*
           perform   vis-imp-pgs-000      thru vis-imp-pgs-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione totale pagamenti sele-  *
      *                      * zionati                                 *
      *                      *-----------------------------------------*
           perform   vis-tot-pgs-000      thru vis-tot-pgs-999        .
      *                      *-----------------------------------------*
      *                      * Uscita come per Down                    *
      *                      *-----------------------------------------*
           move      "DOWN"               to   v-key                  .
           go to     acc-flg-pgs-999.
       acc-flg-pgs-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
           if        w-bpf-flg-pgs
                    (w-sdc-ctr-rig)       not  = "S" and
                     w-bpf-flg-pgs
                    (w-sdc-ctr-rig)       not  = spaces
                     move  w-sav-flg-pgs  to   w-bpf-flg-pgs
                                              (w-sdc-ctr-rig)
                     go to acc-flg-pgs-100.
       acc-flg-pgs-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-bpf-flg-pgs
                    (w-sdc-ctr-rig)       =    w-sav-flg-pgs
                     go to acc-flg-pgs-800.
      *                  *---------------------------------------------*
      *                  * Eventuale controaggiornamento totale paga-  *
      *                  * menti selezionati                           *
      *                  *---------------------------------------------*
           if        w-sav-flg-pgs        =    "S"
                     subtract w-bpf-imp-pgf
                             (w-sdc-ctr-rig)
                                          from w-sdc-tot-pgs          .
      *                  *---------------------------------------------*
      *                  * Eventuale aggiornamento totale pagamenti    *
      *                  * selezionati                                 *
      *                  *---------------------------------------------*
           if        w-bpf-flg-pgs
                    (w-sdc-ctr-rig)       =    "S"
                     add      w-bpf-imp-pgf
                             (w-sdc-ctr-rig)
                                          to   w-sdc-tot-pgs          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione importo pagamento selezio-  *
      *                  * nato                                        *
      *                  *---------------------------------------------*
           perform   vis-imp-pgs-000      thru vis-imp-pgs-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione totale pagamenti seleziona- *
      *                  * ti                                          *
      *                  *---------------------------------------------*
           perform   vis-tot-pgs-000      thru vis-tot-pgs-999        .
       acc-flg-pgs-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-flg-pgs-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-flg-pgs-100.
       acc-flg-pgs-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo saldaconto : Flag di pagamento se-  *
      *    *                                    lezionato              *
      *    *-----------------------------------------------------------*
       vis-flg-pgs-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-bpf-flg-pgs
                    (w-sdc-ctr-rig)       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-flg-pgs-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo saldaconto : Importo pagamento se-  *
      *    *                                    lezionato              *
      *    *-----------------------------------------------------------*
       vis-imp-pgs-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           if        w-bpf-imp-pgf
                    (w-sdc-ctr-rig)       >    999999999 or
                     w-bpf-imp-pgf
                    (w-sdc-ctr-rig)       <   -999999999
                     move  11             to   v-car
           else      move  09             to   v-car                  .
           move      w-tes-dec-vlt (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      w-sdc-wrk-lin        to   v-lin                  .
           move      68                   to   v-pos                  .
           if        w-bpf-flg-pgs
                    (w-sdc-ctr-rig)       =    "S"
                     move  w-bpf-imp-pgf
                          (w-sdc-ctr-rig) to   v-num
           else      move  zero           to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-imp-pgs-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo saldaconto : Totale pagamenti sele- *
      *    *                                    zionati                *
      *    *-----------------------------------------------------------*
       vis-tot-pgs-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           if        w-sdc-tot-pgs        >    999999999 or
                     w-sdc-tot-pgs        <   -999999999
                     move  11             to   v-car
           else      move  09             to   v-car                  .
           move      w-tes-dec-vlt (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "G"                  to   v-edm                  .
           move      21                   to   v-lin                  .
           move      68                   to   v-pos                  .
           move      w-sdc-tot-pgs        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tot-pgs-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo saldaconto : Totale pagamenti for-  *
      *    *                                    nitori                 *
      *    *-----------------------------------------------------------*
       vis-tot-pgf-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vlt (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "G"                  to   v-edm                  .
           move      21                   to   v-lin                  .
           move      47                   to   v-pos                  .
           move      w-sdc-tot-pgf        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tot-pgf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Presa visione per pagina 2   *
      *    *-----------------------------------------------------------*
       acc-pre-vp2-000.
      *              *-------------------------------------------------*
      *              * Controllo su impostazioni pagina testata nr. 2  *
      *              *-------------------------------------------------*
           perform   cnt-imp-pg2-000      thru cnt-imp-pg2-999        .
      *              *-------------------------------------------------*
      *              * Se controllo non superato : si esce forzando il *
      *              * tasto Up                                        *
      *              *-------------------------------------------------*
           if        w-cnt-imp-pg2-flg    not  = spaces
                     move  "UP  "         to   v-key
                     go to acc-pre-vp2-999.
      *              *-------------------------------------------------*
      *              * Se Next Screen si salta l'accettazione caratte- *
      *              * re di presa visione                             *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-pre-vp2-200.
       acc-pre-vp2-100.
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      spaces               to   v-msk                  .
           move      spaces               to   v-alf                  .
           move      spaces               to   v-not                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           if        w-cnt-sts-imp-npt    >    1
                     move  "PRSC"         to   v-pfk (07)             .
           move      "NXSC"               to   v-pfk (08)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vp2-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vp2-999.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-pre-vp2-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pre-vp2-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pre-vp2-000.
       acc-pre-vp2-200.
      *              *-------------------------------------------------*
      *              * Se tipo funzionamento diverso da Inserimento,   *
      *              * oltre                                           *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-pre-vp2-300.
      *              *-------------------------------------------------*
      *              * Se saldaconto gia' impostato : oltre            *
      *              *-------------------------------------------------*
           if        w-tes-fda-sdc (1)    not  = spaces
                     go to acc-pre-vp2-300.
      *              *-------------------------------------------------*
      *              * Caricamento catena pagamenti fornitori          *
      *              *-------------------------------------------------*
           perform   car-cat-pgf-000      thru car-cat-pgf-999        .
      *              *-------------------------------------------------*
      *              * Se esito caricamento negativo : si esce forzan- *
      *              * do il tasto Up                                  *
      *              *-------------------------------------------------*
           if        w-car-cat-pgf-flg    not  = spaces
                     move  "UP  "         to   v-key
                     go to acc-pre-vp2-999.
      *              *-------------------------------------------------*
      *              * Attivazione flag di impostazione saldaconto     *
      *              *-------------------------------------------------*
           move      "#"                  to   w-tes-fda-sdc (1)      .
       acc-pre-vp2-300.
      *              *-------------------------------------------------*
      *              * Se non esiste alcuna pagina attiva successiva   *
      *              * alla pagina attuale : uscita                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio numero pagina attuale           *
      *                  *---------------------------------------------*
           move      w-cnt-sts-imp-npt    to   w-cnt-sts-imp-svp      .
       acc-pre-vp2-400.
      *                  *---------------------------------------------*
      *                  * Se all'ultima pagina : ripristino pagina    *
      *                  * salvata ed uscita                           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-npt    not  < w-cnt-sts-imp-mpt
                     move  w-cnt-sts-imp-svp
                                          to   w-cnt-sts-imp-npt
                     go to acc-pre-vp2-999.
      *                  *---------------------------------------------*
      *                  * Incremento numero pagina                    *
      *                  *---------------------------------------------*
           add       1                    to   w-cnt-sts-imp-npt      .
      *                  *---------------------------------------------*
      *                  * Test se pagina da trattare                  *
      *                  *---------------------------------------------*
           perform   snp-tes-reg-000      thru snp-tes-reg-999        .
      *                  *---------------------------------------------*
      *                  * Se no : a re-incremento                     *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-snp    not  = spaces
                     go to acc-pre-vp2-400.
      *                  *---------------------------------------------*
      *                  * Se si : ripristino pagina salvata           *
      *                  *---------------------------------------------*
           move      w-cnt-sts-imp-svp    to   w-cnt-sts-imp-npt      .
       acc-pre-vp2-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazioni pagina testata nr. 2            *
      *    *-----------------------------------------------------------*
       cnt-imp-pg2-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-imp-pg2-flg      .
      *              *-------------------------------------------------*
      *              * Test se la pagina e' da trattare                *
      *              *                                                 *
      *              * N.B.: Il test seguente deve essere pari a quel- *
      *              *       lo contenuto in snp-tes-reg-000/999       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se non in Inserimento : no                  *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to cnt-imp-pg2-999.
      *                  *---------------------------------------------*
      *                  * Se il buffer pagamenti fornitori non con-   *
      *                  * tiene elementi, la pagina non e' da tratta- *
      *                  * re                                          *
      *                  *---------------------------------------------*
           if        w-bpf-num-ele        =    zero
                     go to cnt-imp-pg2-999.
      *                  *---------------------------------------------*
      *                  * Altrimenti, la pagina e' da trattare        *
      *                  *---------------------------------------------*
           go to     cnt-imp-pg2-100.
       cnt-imp-pg2-100.
      *              *-------------------------------------------------*
      *              * Nessun controllo                                *
      *              *-------------------------------------------------*
       cnt-imp-pg2-120.
      *              *-------------------------------------------------*
      *              * Fine controlli                                  *
      *              *-------------------------------------------------*
       cnt-imp-pg2-800.
      *              *-------------------------------------------------*
      *              * Normalizzazioni                                 *
      *              *-------------------------------------------------*
       cnt-imp-pg2-820.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     cnt-imp-pg2-999.
       cnt-imp-pg2-900.
      *              *-------------------------------------------------*
      *              * Se controllo non superato                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di errore in uscita                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-imp-pg2-flg      .
       cnt-imp-pg2-999.
           exit.
           
      *    *===========================================================*
      *    * Caricamento catena pagamenti fornitori                    *
      *    *-----------------------------------------------------------*
       car-cat-pgf-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-car-cat-pgf-flg      .
      *              *-------------------------------------------------*
      *              * Inizializzazione totale righe pagamenti sele-   *
      *              * zionati                                         *
      *              *-------------------------------------------------*
           move      zero                 to   w-tes-tot-rps (1)      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione buffer pagamenti fornitori   *
      *              *-------------------------------------------------*
           move      zero                 to   w-car-cat-pgf-ctr      .
       car-cat-pgf-100.
           add       1                    to   w-car-cat-pgf-ctr      .
           if        w-car-cat-pgf-ctr    >    w-bpf-num-ele
                     go to car-cat-pgf-999.
      *                  *---------------------------------------------*
      *                  * Test se pagamento selezionato               *
      *                  *---------------------------------------------*
           if        w-bpf-flg-pgs
                    (w-car-cat-pgf-ctr)   not  = "S"
                     go to car-cat-pgf-100.
      *                  *---------------------------------------------*
      *                  * Append in catena                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se Append non possibile : uscita con    *
      *                      * errore                                  *
      *                      *-----------------------------------------*
           if        w-cat-rig-app        not  = spaces
                     go to car-cat-pgf-900.
      *                      *-----------------------------------------*
      *                      * Append                                  *
      *                      *-----------------------------------------*
           move      "AP"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       car-cat-pgf-200.
      *                  *---------------------------------------------*
      *                  * Normalizzazione riga                        *
      *                  *---------------------------------------------*
           perform   nor-nok-rig-000      thru nor-nok-rig-999        .
      *                  *---------------------------------------------*
