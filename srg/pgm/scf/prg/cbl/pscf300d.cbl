           if        w-tes-num-adp        =    zero
                     go to rou-let-reg-100
           else      go to rou-let-reg-300.
       rou-let-reg-100.
      *              *-------------------------------------------------*
      *              * Se numero addebito a zero : Inserimento         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo funzionamento : Inserimento            *
      *                  *---------------------------------------------*
           move      "I"                  to   w-cnt-mfu-tip-fun      .
       rou-let-reg-120.
      *                  *---------------------------------------------*
      *                  * Test su dati relativi alla registrazione    *
      *                  * contabile                                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test si/no aggiornamenti contabili da   *
      *                      * gestione scadenze fornitori per il mo-  *
      *                      * vimento di addebito                     *
      *                      *-----------------------------------------*
           perform   cge-scf-adp-snx-000  thru cge-scf-adp-snx-999    .
      *                          *-------------------------------------*
      *                          * Se no aggiornamento : nessun con-   *
      *                          * trollo                              *
      *                          *-------------------------------------*
           if        w-cge-scf-adp-snx    =    "N"
                     go to rou-let-reg-180.
      *                          *-------------------------------------*
      *                          * Confronto tra la data di registra-  *
      *                          * zione del movimento e la data di    *
      *                          * registrazione di contabilita' ge-   *
      *                          * nerale minima : se inferiore si e-  *
      *                          * sce con un messaggio di errore      *
      *                          *-------------------------------------*
           if        w-tes-dat-reg        not  < w-prs-scf-drc-min
                     go to rou-let-reg-140.
           move      "Data di registrazione inferiore al minimo consenti
      -              "to             "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           move      "#"                  to   w-cnt-rou-let-reg      .
           go to     rou-let-reg-999.
       rou-let-reg-140.
      *                          *-------------------------------------*
      *                          * Controllo su sottoconto contabile   *
      *                          * per abbuoni passivi associato al    *
      *                          * tipo movimento                      *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se codice sottoconto a zero     *
      *                              *---------------------------------*
           if        w-top-stc-cge
                    (w-top-ele-inx)       not  = zero
                     go to rou-let-reg-160.
      *                              *---------------------------------*
      *                              * Emissione messaggio             *
      *                              *---------------------------------*
           move      "Attenzione : Manca il sottoconto contabile per abb
      -              "uoni passivi   "    to   w-err-box-err-msg      .
           move      "             associato al tipo movimento di addebi
      -              "to.            "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           move      "#"                  to   w-cnt-rou-let-reg      .
           go to     rou-let-reg-999.
       rou-let-reg-160.
      *                          *-------------------------------------*
      *                          * Controllo su sottoconto contabile   *
      *                          * per abbuoni attivi associato al     *
      *                          * tipo movimento                      *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se codice sottoconto a zero     *
      *                              *---------------------------------*
           if        w-top-ctp-cge
                    (w-top-ele-inx)       not  = zero
                     go to rou-let-reg-180.
      *                              *---------------------------------*
      *                              * Emissione messaggio             *
      *                              *---------------------------------*
           move      "Attenzione : Manca il sottoconto contabile per abb
      -              "uoni attivi    "    to   w-err-box-err-msg      .
           move      "             associato al tipo movimento di addebi
      -              "to.            "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           move      "#"                  to   w-cnt-rou-let-reg      .
           go to     rou-let-reg-999.
       rou-let-reg-180.
      *                  *---------------------------------------------*
      *                  * Altri valori automatici inerenti l'inseri-  *
      *                  * mento relativo all'addebito                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Modalita' di addebito                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        =    1830 or
                     w-tes-tip-ope        =    1831
                     move  13             to   w-tes-mod-adp (1)
           else if   w-tes-tip-ope        =    1840
                     move  14             to   w-tes-mod-adp (1)
           else if   w-tes-tip-ope        =    1850
                     move  15             to   w-tes-mod-adp (1)
           else      move  zero           to   w-tes-mod-adp (1)      .
      *                      *-----------------------------------------*
      *                      * Tipo valuta per l'addebito              *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        =    1831
                     move  02             to   w-tes-tvl-adp (1)
           else      move  01             to   w-tes-tvl-adp (1)      .
      *                      *-----------------------------------------*
      *                      * Sigla, numero decimali e tipo di cambio *
      *                      * per la valuta                           *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        not  = 1831
                     move  c-sgl          to   w-tes-sgl-vlt (1)
                     move  c-dec          to   w-tes-dec-vlt (1)
                     move  c-tdc          to   w-tes-tdc-vlt (1)
                     move  c-cdc          to   w-pie-cdc-adp (1)      .
       rou-let-reg-250.
      *                  *---------------------------------------------*
      *                  * Assestamento flags per visualizzazione pie- *
      *                  * de                                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Assestamento flags di impostazione pa-  *
      *                      * gine piede                              *
      *                      *-----------------------------------------*
           move      all  "#"             to   w-cnt-sts-imp-ppi      .
      *                      *-----------------------------------------*
      *                      * Assesatmento flags di ingresso in pa-   *
      *                      * gine piede                              *
      *                      *-----------------------------------------*
           move      all  "#"             to   w-cnt-sts-ing-ppi      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     rou-let-reg-999.
       rou-let-reg-300.
      *              *-------------------------------------------------*
      *              * Se numero addebito diverso da zero              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura record [sfa]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMADP    "         to   f-key                  .
           move      w-tes-num-adp        to   rf-sfa-num-adp         .
           move      "pgm/scf/fls/ioc/obj/iofsfa"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfa                 .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'esito della let-  *
      *                  * tura                                        *
