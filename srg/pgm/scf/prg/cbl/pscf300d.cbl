      *    *===========================================================*
      *    * Selezioni bloccanti su record [sfp]                       *
      *    *                                                           *
      *    * Input  :                                                  *
      *    *                                                           *
      *    *  - Area w-tes e record [sfp] da esaminare                 *
      *    *                                                           *
      *    * Output :                                                  *
      *    *                                                           *
      *    *  - w-sel-sfp-blo-flg : Flag fondamentale di uscita        *
      *    *    - 00 : Selezione superata                              *
      *    *    - nn : Selezione non superata, con causa codice nn     *
      *    *           - 11 : Modalita' di pagamento non riconosciuto  *
      *    *           - 12 : Tipo valuta del pagamento non ammissi-   *
      *    *                  bile per l'addebito in atto              *
      *    *           - 13 : Codice valuta del pagamento diverso da   *
      *    *                  quello dell'addebito in atto             *
      *    *           - 14 : Status pagamento indicante movimenti     *
      *    *                  successivi a quello di registrazione     *
      *    *           - 15 : Data di registrazione del movimento di   *
      *    *                  pagamento superiore alla data di regi-   *
      *    *                  strazione dell'operazione in corso       *
      *    *           - 16 : Importo pagamento non superiore a zero   *
      *    *           - 17 : Il pagamento e' bloccato                 *
      *    *           - 18 : Il pagamento e' in fase di pulizia       *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       sel-sfp-blo-000.
      *              *-------------------------------------------------*
      *              * Selezione su modalita' di pagamento, che sia    *
      *              * compatibile                                     *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        =    1830 and
                     rf-sfp-mod-pgf       =    13
                     go to sel-sfp-blo-100
           else if   w-tes-tip-ope        =    1831 and
                     rf-sfp-mod-pgf       =    13
                     go to sel-sfp-blo-100
           else if   w-tes-tip-ope        =    1840 and
                     rf-sfp-mod-pgf       =    14
                     go to sel-sfp-blo-100
           else if   w-tes-tip-ope        =    1850 and
                     rf-sfp-mod-pgf       =    15
                     go to sel-sfp-blo-100.
           move      11                   to   w-sel-sfp-blo-flg      .
           move      "Tipo pagamento non compatibile con l'addebito in c                    
      -              "orso.          "    to   w-sel-sfp-blo-err      .
           go to     sel-sfp-blo-999.
       sel-sfp-blo-100.
      *              *-------------------------------------------------*
      *              * Selezione su tipo valuta, che sia compatibile   *
      *              *-------------------------------------------------*
           if        rf-sfp-tvl-pgf       =    w-tes-tvl-adp (1)
                     go to sel-sfp-blo-200.
           move      12                   to   w-sel-sfp-blo-flg      .
           move      "Tipo valuta per il pagamento incompatibile        
      -              "               "    to   w-sel-sfp-blo-err      .
           go to     sel-sfp-blo-999.
       sel-sfp-blo-200.
      *              *-------------------------------------------------*
      *              * Selezione su sigla valuta, che sia compatibile  *
      *              *-------------------------------------------------*
           if        rf-sfp-sgl-vlt       =    w-tes-sgl-vlt (1) and
                     rf-sfp-dec-vlt       =    w-tes-dec-vlt (1) and
                     rf-sfp-tdc-vlt       =    w-tes-tdc-vlt (1)
                     go to sel-sfp-blo-300.
           move      13                   to   w-sel-sfp-blo-flg      .
           move      "Sigla valuta del pagamento incompatibile          
      -              "               "    to   w-sel-sfp-blo-err      .
           go to     sel-sfp-blo-999.
       sel-sfp-blo-300.
      *              *-------------------------------------------------*
      *              * Selezione su status del pagamento, che non in-  *
      *              * dichi movimenti successivi a quello di regi-    *
      *              * strazione                                       *
      *              *-------------------------------------------------*
           if        rf-sfp-num-adp       =    zero
                     go to sel-sfp-blo-400.
           move      14                   to   w-sel-sfp-blo-flg      .
           move      "Il pagamento e' gia' stato sottoposto all'operazio
      -              "ne di addebito."    to   w-sel-sfp-blo-err      .
           go to     sel-sfp-blo-999.
       sel-sfp-blo-400.
      *              *-------------------------------------------------*
      *              * Selezione sulla data di registrazione movimento *
      *              * di registrazione pagamento, che non sia supe-   *
      *              * riore alla data di registrazione in corso       *
      *              *-------------------------------------------------*
           if        rf-sfp-dtr-pgf       not > w-tes-dat-reg
                     go to sel-sfp-blo-500.
           move      15                   to   w-sel-sfp-blo-flg      .
           move      "Data registrazione pagamento superiore alla data d
      -              "ell'operazione "    to   w-sel-sfp-blo-err      .
           go to     sel-sfp-blo-999.
       sel-sfp-blo-500.
      *              *-------------------------------------------------*
      *              * Selezione su importo pagamento, che sia supe-   *
      *              * riore a zero                                    *
      *              *-------------------------------------------------*
           if        rf-sfp-imp-pgf       >    zero
                     go to sel-sfp-blo-600.
           move      16                   to   w-sel-sfp-blo-flg      .
           move      "Importo pagamento non positivo                    
      -              "               "    to   w-sel-sfp-blo-err      .
           go to     sel-sfp-blo-999.
       sel-sfp-blo-600.
      *              *-------------------------------------------------*
      *              * Selezione su flag bloccanti                     *
      *              *-------------------------------------------------*
           if        rf-sfp-flg-blo       =    spaces
                     go to sel-sfp-blo-700.
           move      17                   to   w-sel-sfp-blo-flg      .
           move      "Il pagamento e' stata sottoposto ad elaborazioni  
      -              "               "    to   w-sel-sfp-blo-err      .
           go to     sel-sfp-blo-999.
       sel-sfp-blo-700.
      *              *-------------------------------------------------*
      *              * Selezione su flag di pulizia                    *
      *              *-------------------------------------------------*
           if        rf-sfp-flg-pul       =    spaces
                     go to sel-sfp-blo-800.
           move      18                   to   w-sel-sfp-blo-flg      .
           move      "Il pagamento e' in corso di eliminazione          
      -              "               "    to   w-sel-sfp-blo-err      .
           go to     sel-sfp-blo-999.
       sel-sfp-blo-800.
      *              *-------------------------------------------------*
      *              * Selezione superata                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-sel-sfp-blo-flg      .
           move      spaces               to   w-sel-sfp-blo-err      .
       sel-sfp-blo-999.
           exit.

      *    *===========================================================*
      *    * Selezioni non bloccanti su record [sfp]                   *
      *    *                                                           *
      *    * Input  :                                                  *
      *    *                                                           *
      *    *  - Area w-tes e record [sfp] da esaminare                 *
      *    *                                                           *
      *    * Output :                                                  *
      *    *                                                           *
      *    *  - w-sel-sfp-nbl-flg : Flag fondamentale di uscita        *
      *    *    - 00 : Selezione superata                              *
      *    *    - nn : Selezione non superata, con causa codice nn     *
      *    *           - 11 : Codice fornitore                         *
      *    *           - 12 : Codice dipendenza del fornitore          *
      *    *           - 13 : Codice nostra banca o c/c postale diver- *
      *    *                  so da quello dell'addebito in atto       *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       sel-sfp-nbl-000.
      *              *-------------------------------------------------*
      *              * Codice fornitore                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se zero : nessuna selezione                 *
      *                  *---------------------------------------------*
           if        w-tes-sel-fnt (1)    =    zero
                     go to sel-sfp-nbl-100.
      *                  *---------------------------------------------*
      *                  * Test di selezione                           *
      *                  *---------------------------------------------*
           if        rf-sfp-cod-fnt       =    w-tes-sel-fnt (1)
                     go to sel-sfp-nbl-100.
      *                  *---------------------------------------------*
      *                  * Trattamento errore                          *
      *                  *---------------------------------------------*
           move      11                   to   w-sel-sfp-nbl-flg      .
           move      "Diverso codice fornitore                          
      -              "               "    to   w-sel-sfp-nbl-err      .
           go to     sel-sfp-nbl-999.
       sel-sfp-nbl-100.
      *              *-------------------------------------------------*
      *              * Codice dipendenza del fornitore                 *
      *              *-------------------------------------------------*
           if        w-tes-sel-fnt (1)    =    zero
                     go to sel-sfp-nbl-200.
           if        w-tes-sel-dpf (1)    =    "*    "
                     go to sel-sfp-nbl-200.
      *                  *---------------------------------------------*
      *                  * Test di selezione                           *
      *                  *---------------------------------------------*
           if        rf-sfp-dpz-fnt       =    w-tes-sel-dpf (1)
                     go to sel-sfp-nbl-200.
      *                  *---------------------------------------------*
      *                  * Trattamento errore                          *
      *                  *---------------------------------------------*
           move      12                   to   w-sel-sfp-nbl-flg      .
           move      "Diverso codice dipendenza del fornitore           
      -              "               "    to   w-sel-sfp-nbl-err      .
           go to     sel-sfp-nbl-999.
       sel-sfp-nbl-200.
      *              *-------------------------------------------------*
      *              * Selezione su codice ns. banca o c/c postale     *
      *              *-------------------------------------------------*
           if        rf-sfp-cbp-pgf       =    w-tes-cbp-adp (1)
                     go to sel-sfp-nbl-300.
           move      13                   to   w-sel-sfp-nbl-flg      .
           if        w-tes-tip-ope        =    1830 or
                     w-tes-tip-ope        =    1831 or
                     w-tes-tip-ope        =    1850
                     go to sel-sfp-nbl-210
           else if   w-tes-tip-ope        =    1840
                     go to sel-sfp-nbl-220.
       sel-sfp-nbl-210.
           move      "Diverso codice nostra Banca                       
      -              "               "    to   w-sel-sfp-nbl-err      .
           go to     sel-sfp-nbl-999.
       sel-sfp-nbl-220.
           move      "Diverso codice nostro C/C Postale                 
      -              "               "    to   w-sel-sfp-nbl-err      .
           go to     sel-sfp-nbl-999.
       sel-sfp-nbl-300.
      *              *-------------------------------------------------*
      *              * Selezioni superate                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-sel-sfp-nbl-flg      .
           move      spaces               to   w-sel-sfp-nbl-err      .
       sel-sfp-nbl-999.
           exit.

      *    *===========================================================*
      *    * Routine di attribuzione numero addebito                   *
      *    *-----------------------------------------------------------*
       att-sfa-num-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfanum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfa-num             .
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [sfanum]                                  *
      *              *-------------------------------------------------*
           move      w-sfa-num-scl-ann    to   rn-sfa-num-scl-ann     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [sfanum]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfanum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfa-num             .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-sfa-num-400.
       att-sfa-num-200.
      *              *-------------------------------------------------*
      *              * Se record non esistente                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Scrittura record normalizzato               *
      *                  *---------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfanum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfa-num             .
      *                  *---------------------------------------------*
      *                  * Unlock record                               *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfanum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfa-num             .
      *                  *---------------------------------------------*
      *                  * Ripetizione dell'intera operazione          *
      *                  *---------------------------------------------*
           go to     att-sfa-num-000.
       att-sfa-num-400.
      *              *-------------------------------------------------*
      *              * Se record esistente                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore pre-incremento           *
      *                  *---------------------------------------------*
           move      rn-sfa-num-num-adp   to   w-sfa-num-num-adp      .
           move      w-sfa-num-r01-num    to   w-sfa-num-val-pre      .
      *                  *---------------------------------------------*
      *                  * Preparazione valore post-incremento         *
      *                  *---------------------------------------------*
           move      w-sfa-num-val-pre    to   w-sfa-num-val-pos      .
           add       1                    to   w-sfa-num-val-pos      .
           if        w-sfa-num-val-pos    =    zero
                     move  1              to   w-sfa-num-val-pos      .
      *                  *---------------------------------------------*
      *                  * Preparazione numero addebito completo       *
      *                  *---------------------------------------------*
           move      w-sfa-num-scl-ann    to   w-sfa-num-r01-saa      .
           move      w-sfa-num-val-pos    to   w-sfa-num-r01-num      .
      *                  *---------------------------------------------*
      *                  * Aggiornamento numero addebito               *
      *                  *---------------------------------------------*
           move      w-sfa-num-num-adp    to   rn-sfa-num-num-adp     .
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfanum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfa-num             .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'esito dell'opera- *
      *                  * zione di update                             *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-sfa-num-600.
       att-sfa-num-500.
      *                  *---------------------------------------------*
      *                  * Se errore in operazione di update           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfanum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfa-num             .
      *                      *-----------------------------------------*
      *                      * Ripetizione dell'intera operazione      *
      *                      *-----------------------------------------*
           go to     att-sfa-num-000.
       att-sfa-num-600.
      *                  *---------------------------------------------*
      *                  * Se nessun errore in operazione di update    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfanum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfa-num             .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     att-sfa-num-999.
       att-sfa-num-999.
           exit.

      *    *===========================================================*
      *    * Routine di ripristino numero addebito                     *
      *    *-----------------------------------------------------------*
       rip-sfa-num-000.
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [sfanum]                                  *
      *              *-------------------------------------------------*
           move      w-sfa-num-scl-ann    to   rn-sfa-num-scl-ann     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [sfanum]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfanum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfa-num             .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to rip-sfa-num-400.
       rip-sfa-num-200.
      *              *-------------------------------------------------*
      *              * Se record non esistente                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Unlock record                               *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfanum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfa-num             .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     rip-sfa-num-999.
       rip-sfa-num-400.
      *              *-------------------------------------------------*
      *              * Se record esistente                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Confronto tra il numero addebito attuale    *
      *                  * contenuto nel record numerazioni ed il va-  *
      *                  * lore post-incremento, e deviazione in fun-  *
      *                  * zione dell'esito del test                   *
      *                  *---------------------------------------------*
           move      rn-sfa-num-num-adp   to   w-sfa-num-num-adp      .
           if        w-sfa-num-r01-num    =    w-sfa-num-val-pos
                     go to rip-sfa-num-600.
       rip-sfa-num-500.
      *                  *---------------------------------------------*
      *                  * Se numero addebito attuale contenuto nel    *
      *                  * record numerazioni diverso dal valore post- *
      *                  * incremento                                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfanum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfa-num             .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rip-sfa-num-999.
       rip-sfa-num-600.
      *                  *---------------------------------------------*
      *                  * Se numero addebito attuale contenuto nel    *
      *                  * record numerazioni uguale al valore post-   *
      *                  * incremento                                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controaggiornamento del valore attuale  *
      *                      * contenuto nel record numerazioni, ri-   *
      *                      * portandolo al valore pre-incremento     *
      *                      *-----------------------------------------*
           move      w-sfa-num-val-pre    to   w-sfa-num-r01-num      .
           if        w-sfa-num-val-pre    =    zero
                     move  zero           to   w-sfa-num-num-adp      .
           move      w-sfa-num-num-adp    to   rn-sfa-num-num-adp     .
      *                      *-----------------------------------------*
      *                      * Update record numerazioni               *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfanum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfa-num             .
      *                      *-----------------------------------------*
      *                      * Unlock record numerazioni               *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfanum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfa-num             .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rip-sfa-num-999.
       rip-sfa-num-999.
           exit.

      *    *===========================================================*
