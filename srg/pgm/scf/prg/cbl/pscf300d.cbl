           move      w-tes-sel-fnt (1)    to   w-let-arc-dcf-cod      .
           move      w-tes-sel-dpf (1)    to   w-let-arc-dcf-dpz      .
           perform   let-arc-dcf-000      thru let-arc-dcf-999        .
      *                      *-----------------------------------------*
      *                      * Memorizzazione valori letti da anagra-  *
      *                      * fica commerciale della dipendenza in    *
      *                      * dati per la dipendenza                  *
      *                      *-----------------------------------------*
           move      w-let-arc-dcf-rag    to   w-tes-sel-dpf-rag (1)  .
           move      w-let-arc-dcf-via    to   w-tes-sel-dpf-via (1)  .
