      *    *===========================================================*
      *    * Determinazione del tipo di modifica intervenuta nell'ope- *
      *    * razione di addebito, e dei relativi flags indicatori      *
      *    *-----------------------------------------------------------*
       det-mod-adp-000.
      *              *-------------------------------------------------*
      *              * Flags a Spaces                                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-mod-adp-rec-sfa      .
           move      spaces               to   w-mod-adp-cge-adp      .
       det-mod-adp-100.
      *              *-------------------------------------------------*
      *              * Tests se avvenute modifiche al record [sfa]     *
      *              *-------------------------------------------------*
           if        w-tes-val-aep (1)    not  = w-tes-val-aep (2) or
                     w-pie-val-aep (1)    not  = w-pie-val-aep (2)
                     move  "#"            to   w-mod-adp-rec-sfa      .
       det-mod-adp-200.
      *              *-------------------------------------------------*
      *              * Tests se avvenute modifiche di natura contabile *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Sottoconto associato alla ns. banca o c/c   *
      *                  * postale                                     *
      *                  *---------------------------------------------*
           if        w-tes-cbp-adp-stc (1)
                                          not  = w-tes-cbp-adp-stc (2)
                     move  "#"            to   w-mod-adp-cge-adp      .
      *                  *---------------------------------------------*
      *                  * Sottoconto oneri associato alla ns. banca o *
      *                  * c/c postale                                 *
      *                  *---------------------------------------------*
           if        w-tes-cbp-adp-sto (1)
                                          not  = w-tes-cbp-adp-sto (2)
                     move  "#"            to   w-mod-adp-cge-adp      .
      *                  *---------------------------------------------*
      *                  * Sottoconto differenze cambio passive asso-  *
      *                  * ciato alla ns. banca                        *
      *                  *---------------------------------------------*
           if        w-tes-tip-ope        not  = 1831
                     go to det-mod-adp-220.
           if        w-tes-cbp-adp-sdp (1)
                                          not  = w-tes-cbp-adp-sdp (2)
                     move  "#"            to   w-mod-adp-cge-adp      .
       det-mod-adp-220.
      *                  *---------------------------------------------*
      *                  * Sottoconto differenze cambio attive asso-   *
      *                  * ciato alla ns. banca                        *
      *                  *---------------------------------------------*
           if        w-tes-tip-ope        not  = 1831
                     go to det-mod-adp-240.
           if        w-tes-cbp-adp-sda (1)
                                          not  = w-tes-cbp-adp-sda (2)
                     move  "#"            to   w-mod-adp-cge-adp      .
       det-mod-adp-240.
      *                  *---------------------------------------------*
      *                  * Data documento                              *
      *                  *---------------------------------------------*
           if        w-tes-ddo-adp (1)    not  = w-tes-ddo-adp (2)
                     move  "#"            to   w-mod-adp-cge-adp      .
      *                  *---------------------------------------------*
      *                  * Numero documento                            *
      *                  *---------------------------------------------*
           if        w-tes-ndo-adp (1)    not  = w-tes-ndo-adp (2)
                     move  "#"            to   w-mod-adp-cge-adp      .
      *                  *---------------------------------------------*
      *                  * Totale righe pagamenti selezionati          *
      *                  *---------------------------------------------*
           if        w-tes-tot-rps (1)    not  = w-tes-tot-rps (2)
                     move  "#"            to   w-mod-adp-cge-adp      .
      *                  *---------------------------------------------*
      *                  * Totale pagamenti fornitori selezionati      *
      *                  *---------------------------------------------*
           if        w-pie-tot-pfs (1)    not  = w-pie-tot-pfs (2)
                     move  "#"            to   w-mod-adp-cge-adp      .
      *                  *---------------------------------------------*
      *                  * Importo addebito, in valuta                 *
      *                  *---------------------------------------------*
           if        w-pie-iiv-adp (1)    not  = w-pie-iiv-adp (2)
                     move  "#"            to   w-mod-adp-cge-adp      .
      *                  *---------------------------------------------*
      *                  * Importo addebito                            *
      *                  *---------------------------------------------*
           if        w-pie-imp-adp (1)    not  = w-pie-imp-adp (2)
                     move  "#"            to   w-mod-adp-cge-adp      .
      *                  *---------------------------------------------*
      *                  * Importo spese                               *
      *                  *---------------------------------------------*
           if        w-pie-spe-adp (1)    not  = w-pie-spe-adp (2)
                     move  "#"            to   w-mod-adp-cge-adp      .
       det-mod-adp-999.
           exit.

      *    *===========================================================*
      *    * Routine post-conferma di annullamento                     *
      *    *-----------------------------------------------------------*
       pos-cnf-ann-000.
      *              *-------------------------------------------------*
      *              * Annullamento del movimento di contabilita' ge-  *
      *              * nerale che era stato a suo tempo generato a     *
      *              * fronte del movimento di scadenze fornitori di   *
      *              * addebito                                        *
      *              *-------------------------------------------------*
           move      w-tes-drc-adp (2)    to    w-cge-scf-drc-del     .
           move      w-tes-npc-adp (2)    to    w-cge-scf-npc-del     .
           perform   del-cge-scf-000      thru  del-cge-scf-999       .
      *              *-------------------------------------------------*
      *              * Eliminazione del numero addebito da tutti i pa- *
      *              * gamenti appartenenti all'addebito               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su file [sfp]                         *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "ADPPGF    "         to   f-key                  .
           move      w-tes-num-adp        to   rf-sfp-num-adp         .
           move      zero                 to   rf-sfp-num-pgf         .
           move      "pgm/scf/fls/ioc/obj/iofsfp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfp                 .
      *                      *-----------------------------------------*
      *                      * Test su esito operazione                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to pos-cnf-ann-500.
       pos-cnf-ann-100.
      *                  *---------------------------------------------*
      *                  * Ottenimento sequenziale record [sfp]        *
      *                  *---------------------------------------------*
           move      "GN"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfp                 .
      *                      *-----------------------------------------*
      *                      * Test se 'At end'                        *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to pos-cnf-ann-180.
      *                      *-----------------------------------------*
      *                      * Test sul massimo                        *
      *                      *-----------------------------------------*
           if        rf-sfp-num-adp       not  = w-tes-num-adp
                     go to pos-cnf-ann-180.
      *                      *-----------------------------------------*
      *                      * Azzeramento numero addebito             *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sfp-num-adp         .
      *                      *-----------------------------------------*
      *                      * Update record [sfp]                     *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfp                 .
      *                      *-----------------------------------------*
      *                      * Unlock [sfp]                            *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfp                 .
      *                      *-----------------------------------------*
      *                      * Riciclo su ottenimento sequenziale re-  *
      *                      * cord [sfp]                              *
      *                      *-----------------------------------------*
           go to     pos-cnf-ann-100.
       pos-cnf-ann-180.
      *                      *-----------------------------------------*
      *                      * Unlock finale di [sfp]                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfp                 .
       pos-cnf-ann-500.
      *              *-------------------------------------------------*
      *              * Cancellazione record dell'addebito da [sfa]     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura addebito da [sfa], con lock         *
      *                  *---------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMADP    "         to   f-key                  .
           move      w-tes-num-adp        to   rf-sfa-num-adp         .
           move      "pgm/scf/fls/ioc/obj/iofsfa"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfa                 .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'esito della let-  *
      *                  * tura                                        *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to pos-cnf-ann-600.
       pos-cnf-ann-550.
      *                  *---------------------------------------------*
      *                  * Se addebito non trovato                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     pos-cnf-ann-999.
       pos-cnf-ann-600.
      *                  *---------------------------------------------*
      *                  * Se addebito esistente                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Delete su [sfa]                         *
      *                      *-----------------------------------------*
           move      "DE"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfa"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfa                 .
      *                      *-----------------------------------------*
      *                      * Unlock di [sfa]                         *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfa"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfa                 .
       pos-cnf-ann-700.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     pos-cnf-ann-999.
       pos-cnf-ann-999.
           exit.

      *    *===========================================================*
      *    * Test Si/No aggiornamenti contabili da gestione scadenze   *
      *    * fornitori per i movimenti di addebito                     *
      *    *-----------------------------------------------------------*
       cge-scf-adp-snx-000.
      *              *-------------------------------------------------*
      *              * Se le personalizzazioni indicano che in ogni    *
      *              * caso gli aggiornamenti contabili non devono     *
      *              * essere eseguiti : uscita con 'N'                *
      *              *-------------------------------------------------*
           if        w-prs-scf-snx-cge    =    "N"
                     move  "N"            to   w-cge-scf-adp-snx
                     go to cge-scf-adp-snx-999.
       cge-scf-adp-snx-025.
      *              *-------------------------------------------------*
      *              * Se il codice causale contabile per il tipo ope- *
      *              * razione di addebito e' a zero : uscita con 'N'  *
      *              *-------------------------------------------------*
           if        w-top-cau-cge
                    (w-top-ele-inx)       =    zero
                     move  "N"            to   w-cge-scf-adp-snx
                     go to cge-scf-adp-snx-999.
       cge-scf-adp-snx-050.
      *              *-------------------------------------------------*
      *              * Altrimenti si esce con 'S'                      *
      *              *-------------------------------------------------*
           move      "S"                  to   w-cge-scf-adp-snx      .
       cge-scf-adp-snx-999.
           exit.

      *    *===========================================================*
      *    * Aggiornamenti contabili generati dalla gestione scadenze  *
      *    * fornitori a fronte del movimento di addebito              *
      *    *                                                           *
      *    * Nota : Vedere i commenti per il modulo 'pscf3000' per le  *
      *    *        generalita' sugli aggiornamenti contabili riguar-  *
      *    *        danti la gestione scadenze fornitori.              *
      *    *-----------------------------------------------------------*
       cge-scf-adp-000.
      *              *-------------------------------------------------*
      *              * Se si e' in modifica di una registrazione che   *
      *              * non aveva generato nessun movimento contabile,  *
      *              * non si genera il movimento contabile            *
      *              *-------------------------------------------------*
           if       (w-cnt-mfu-tip-fun    =    "M"   ) and
                    (w-tes-drc-adp (1)    =    zero or
                     w-tes-npc-adp (1)    =    zero  )
                     go to cge-scf-adp-100.
       cge-scf-adp-025.
      *              *-------------------------------------------------*
      *              * Test se aggiornamento da eseguire               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se in assoluto l'aggiornamento e' da   *
      *                  * eseguire                                    *
      *                  *---------------------------------------------*
           perform   cge-scf-adp-snx-000  thru cge-scf-adp-snx-999    .
      *                  *---------------------------------------------*
      *                  * Se No' : a no aggiornamento                 *
      *                  *---------------------------------------------*
           if        w-cge-scf-adp-snx    not  = "S"
                     go to cge-scf-adp-100.
       cge-scf-adp-050.
      *                  *---------------------------------------------*
      *                  * Se la routine di totalizzazioni per il mo-  *
      *                  * vimento di contabilita' generale ha posto   *
      *                  * in On il flag di 'No aggiornamenti contabi- *
      *                  * li' : a No aggiornamento                    *
      *                  *---------------------------------------------*
           if        w-mov-cge-flg-nag    not  = spaces
                     go to cge-scf-adp-100.
       cge-scf-adp-060.
      *                  *---------------------------------------------*
      *                  * Se totale addebito a zero : a No aggiorna-  *
      *                  * mento                                       *
      *                  *---------------------------------------------*
           if        w-mov-cge-tot-ppa    =    zero
                     go to cge-scf-adp-100.
       cge-scf-adp-075.
      *                  *---------------------------------------------*
      *                  * Test se esiste almeno una riga per la re-   *
      *                  * gistrazione contabile con importo diverso   *
      *                  * da zero.                                    *
      *                  *                                             *
      *                  * Se si' : ad aggiornamento                   *
      *                  * Se no  : a no aggiornamento                 *
      *                  *                                             *
      *                  * Nota : Se si', l'indice per la scansione    *
      *                  *        sulle righe del movimento di con-    *
      *                  *        tabilita' generale punta gia' al     *
      *                  *        primo elemento utile                 *
      *                  *---------------------------------------------*
           if        w-mov-cge-ctr-ppa    not  > zero
                     go to cge-scf-adp-100.
           move      zero                 to   w-mov-cge-inx-001      .
       cge-scf-adp-080.
           add       1                    to   w-mov-cge-inx-001      .
           if        w-mov-cge-inx-001    >    w-mov-cge-ctr-rig
                     go to cge-scf-adp-100.
           if        w-mov-cge-imp-rig
                    (w-mov-cge-inx-001)   not  = zero
                     go to cge-scf-adp-200
           else      go to cge-scf-adp-080.
       cge-scf-adp-100.
      *              *-------------------------------------------------*
      *              * Se No aggiornamento                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Data registrazione movimento contabile : a  *
      *                  * zero                                        *
      *                  *---------------------------------------------*
           move      zero                 to   l-cge-300-dat-reg      .
      *                  *---------------------------------------------*
      *                  * Numero protocollo movimento contabile : a   *
      *                  * zero                                        *
      *                  *---------------------------------------------*
           move      zero                 to   l-cge-300-num-prt      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     cge-scf-adp-999.
       cge-scf-adp-200.
      *              *-------------------------------------------------*
      *              * Esecuzione aggiornamento contabile : viene ese- *
      *              * guita una registrazione in base alla tabella    *
      *              * righe movimento di contabilita' generale pre-   *
      *              * parata                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione del tipo di abbuono          *
      *                  *---------------------------------------------*
           move      w-mov-cge-acc-abb    to   w-cge-scf-adp-abb      .
           if        w-cge-scf-adp-abb    =    zero
                     move  "N"            to   w-cge-scf-adp-sna
                     move  zero           to   w-cge-scf-adp-abb
                     go to cge-scf-adp-220.
           if        w-cge-scf-adp-abb    >    zero
                     move  "A"            to   w-cge-scf-adp-sna
                     go to cge-scf-adp-220
           else      move  "P"            to   w-cge-scf-adp-sna
                     multiply     -1      by   w-cge-scf-adp-abb      .
       cge-scf-adp-220.
      *                      *-----------------------------------------*
      *                      * Se esiste un abbuono ma il sottoconto   *
      *                      * per gli abbuoni e' a zero : no abbuono  *
      *                      *-----------------------------------------*
           if        w-cge-scf-adp-sna    =    "P"           and
                     w-top-stc-cge
                    (w-top-ele-inx)       =    zero
                     move  "N"            to   w-cge-scf-adp-sna
                     move  zero           to   w-cge-scf-adp-abb
                     go to cge-scf-adp-240.
           if        w-cge-scf-adp-sna    =    "A"           and
                     w-top-ctp-cge
                    (w-top-ele-inx)       =    zero
                     move  "N"            to   w-cge-scf-adp-sna
                     move  zero           to   w-cge-scf-adp-abb
                     go to cge-scf-adp-240.
       cge-scf-adp-240.
      *                  *---------------------------------------------*
      *                  * Determinazione del tipo e importo diffe-    *
      *                  * renza cambio                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se tipo operazione diverso da 1831: no  *
      *                      * differenza cambio                       *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        not  = 1831
                     move  "N"            to   w-cge-scf-adp-snd
                     move  zero           to   w-cge-scf-adp-dfc
                     go to cge-scf-adp-260.
      *                      *-----------------------------------------*
      *                      * Se sigla valuta pari a quella base: no  *
      *                      * differenza cambio                       *
      *                      *-----------------------------------------*
           if        w-tes-sgl-vlt (1)    =    c-sgl
                     move  "N"            to   w-cge-scf-adp-snd
                     move  zero           to   w-cge-scf-adp-dfc
                     go to cge-scf-adp-260.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-mov-cge-tot-ppa    to   w-cge-scf-adp-dfc      .
           subtract  w-pie-imp-adp (1)    from w-cge-scf-adp-dfc      .
           if        w-cge-scf-adp-sna    =    "A"
                     subtract w-cge-scf-adp-abb
                                          from w-cge-scf-adp-dfc
           else if   w-cge-scf-adp-sna    =    "P"
                     add      w-cge-scf-adp-abb
                                          to   w-cge-scf-adp-dfc      .
           if        w-cge-scf-adp-dfc    =    zero
                     move  "N"            to   w-cge-scf-adp-snd
                     move  zero           to   w-cge-scf-adp-dfc
                     go to cge-scf-adp-260.
           if        w-cge-scf-adp-dfc    >    zero
                     move  "A"            to   w-cge-scf-adp-snd
                     go to cge-scf-adp-260
           else      move  "P"            to   w-cge-scf-adp-snd
                     multiply     -1      by   w-cge-scf-adp-dfc      .
       cge-scf-adp-260.
      *                      *-----------------------------------------*
      *                      * Se esiste una differenza cambio ma il   *
      *                      * sottoconto per le differenze cambio e'  *
      *                      * a zero : no differenza cambio           *
      *                      *-----------------------------------------*
           if        w-cge-scf-adp-snd    =    "P"           and
                     w-tes-cbp-adp-sdp (1)
                                          =    zero
                     move  "N"            to   w-cge-scf-adp-snd
                     move  zero           to   w-cge-scf-adp-dfc
                     go to cge-scf-adp-300.
           if        w-cge-scf-adp-snd    =    "A"           and
                     w-tes-cbp-adp-sda (1)
                                          =    zero
                     move  "N"            to   w-cge-scf-adp-snd
                     move  zero           to   w-cge-scf-adp-dfc
                     go to cge-scf-adp-300.
       cge-scf-adp-300.
      *                  *---------------------------------------------*
      *                  * Normalizzazione work-area testata e prima   *
      *                  * riga movimento per aggiornamenti contabili  *
      *                  *---------------------------------------------*
           move      "NO"                 to   l-cge-300-tip-ope      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                  *---------------------------------------------*
      *                  * Preparazione link-area per testata e prima  *
      *                  * riga movimento per il Dare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo operazione                         *
      *                      *-----------------------------------------*
           move      "WR"                 to   l-cge-300-tip-ope      .
      *                      *-----------------------------------------*
      *                      * Data di registrazione                   *
      *                      *-----------------------------------------*
           move      w-tes-dat-reg        to   l-cge-300-dat-reg      .
      *                      *-----------------------------------------*
      *                      * Codice causale contabile                *
      *                      *-----------------------------------------*
           move      w-top-cau-cge
                    (w-top-ele-inx)       to   l-cge-300-cod-cau      .
      *                      *-----------------------------------------*
      *                      * Descrizione causale                     *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-des-cau      .
      *                      *-----------------------------------------*
      *                      * Si/No data scadenza                     *
      *                      *-----------------------------------------*
           move      "N"                  to   l-cge-300-snx-dts      .
      *                      *-----------------------------------------*
      *                      * Data scadenza                           *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-dat-sca      .
      *                      *-----------------------------------------*
      *                      * Data documento per l'addebito           *
      *                      *-----------------------------------------*
           move      w-tes-ddo-adp (1)    to   l-cge-300-dat-doc      .
      *                      *-----------------------------------------*
      *                      * Numero documento per l'addebito         *
      *                      *-----------------------------------------*
           move      w-tes-ndo-adp (1)    to   l-cge-300-num-doc      .
      *                      *-----------------------------------------*
      *                      * Trattamento primo elemento in tabella   *
      *                      * scrivibile                              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Deviazione in funzione del tipo     *
      *                          * conto                               *
      *                          *-------------------------------------*
           if        w-mov-cge-tip-con
                    (w-mov-cge-inx-001)   =    "F"
                     go to cge-scf-adp-310
           else if   w-mov-cge-tip-con
                    (w-mov-cge-inx-001)   =    "G"
                     go to cge-scf-adp-320.
       cge-scf-adp-310.
      *                          *-------------------------------------*
      *                          * Tipo conto : Fornitore              *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Codice sottoconto               *
      *                              *---------------------------------*
           move      w-mov-cge-cod-con
                    (w-mov-cge-inx-001)   to   l-cge-300-cod-pdc      .
      *                              *---------------------------------*
      *                              * Tipo archivio                   *
      *                              *---------------------------------*
           move      "F"                  to   l-cge-300-tip-arc      .
      *                              *---------------------------------*
      *                              * Codice archivio                 *
      *                              *---------------------------------*
           move      w-mov-cge-cod-arc
                    (w-mov-cge-inx-001)   to   l-cge-300-cod-arc      .
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     cge-scf-adp-340.
       cge-scf-adp-320.
      *                          *-------------------------------------*
      *                          * Tipo conto : Generale               *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Codice sottoconto               *
      *                              *---------------------------------*
           move      w-mov-cge-cod-con
                    (w-mov-cge-inx-001)   to   l-cge-300-cod-pdc      .
      *                              *---------------------------------*
      *                              * Tipo archivio                   *
      *                              *---------------------------------*
           move      "G"                  to   l-cge-300-tip-arc      .
      *                              *---------------------------------*
      *                              * Codice archivio                 *
      *                              *---------------------------------*
           move      zero                 to   l-cge-300-cod-arc      .
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     cge-scf-adp-340.
       cge-scf-adp-340.
      *                          *-------------------------------------*
      *                          * Data riferimento                    *
      *                          *-------------------------------------*
           move      w-mov-cge-dat-rif
                    (w-mov-cge-inx-001)   to   l-cge-300-dat-rif      .
      *                          *-------------------------------------*
      *                          * Numero riferimento                  *
      *                          *-------------------------------------*
           move      w-mov-cge-num-rif
                    (w-mov-cge-inx-001)   to   l-cge-300-num-rif      .
      *                          *-------------------------------------*
      *                          * Dare/Avere                          *
      *                          *-------------------------------------*
           move      w-mov-cge-dar-ave
                    (w-mov-cge-inx-001)   to   l-cge-300-dar-ave      .
      *                          *-------------------------------------*
      *                          * Importo movimento                   *
      *                          *-------------------------------------*
           move      w-mov-cge-imp-rig
                    (w-mov-cge-inx-001)   to   l-cge-300-imp-mov      .
      *                  *---------------------------------------------*
      *                  * Richiamo sottoprogramma per aggiornamenti   *
      *                  * contabili                                   *
      *                  *---------------------------------------------*
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione tabella movimenti di ge- *
      *                  * nerale a partire da w-mov-cge-inx-001       *
      *                  *---------------------------------------------*
           move      w-mov-cge-inx-001    to   w-cge-scf-adp-ctr      .
       cge-scf-adp-400.
           add       1                    to   w-cge-scf-adp-ctr      .
           if        w-cge-scf-adp-ctr    >    w-mov-cge-ctr-rig
                     go to cge-scf-adp-500.
      *                      *-----------------------------------------*
      *                      * Normalizzazione work-area riga movimen- *
      *                      * to per aggiornamenti contabili          *
      *                      *-----------------------------------------*
           move      "N+"                 to   l-cge-300-tip-ope      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                      *-----------------------------------------*
      *                      * Preparazione link-area per riga movi-   *
      *                      * mento                                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Tipo operazione                     *
      *                          *-------------------------------------*
           move      "W+"                 to   l-cge-300-tip-ope      .
      *                          *-------------------------------------*
      *                          * Deviazione in funzione del tipo     *
      *                          * conto                               *
      *                          *-------------------------------------*
           if        w-mov-cge-tip-con
                    (w-cge-scf-adp-ctr)   =    "F"
                     go to cge-scf-adp-410
           else if   w-mov-cge-tip-con
                    (w-cge-scf-adp-ctr)   =    "G"
                     go to cge-scf-adp-420.
       cge-scf-adp-410.
      *                          *-------------------------------------*
      *                          * Tipo conto : Fornitore              *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Codice sottoconto               *
      *                              *---------------------------------*
           move      w-mov-cge-cod-con
                    (w-cge-scf-adp-ctr)   to   l-cge-300-cod-pdc      .
      *                              *---------------------------------*
      *                              * Tipo archivio                   *
      *                              *---------------------------------*
           move      "F"                  to   l-cge-300-tip-arc      .
      *                              *---------------------------------*
      *                              * Codice archivio                 *
      *                              *---------------------------------*
           move      w-mov-cge-cod-arc
                    (w-cge-scf-adp-ctr)   to   l-cge-300-cod-arc      .
