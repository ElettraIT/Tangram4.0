      *    *===========================================================*
      *    * Prompt per : Saldaconto pagamenti fornitori               *
      *    *-----------------------------------------------------------*
       pmt-sdc-pgf-000.
      *              *-------------------------------------------------*
      *              * Intestazione banca o c/c postale                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Composizione stringa                        *
      *                  *---------------------------------------------*
           move      spaces               to   w-pmt-sdc-pgf-x80      .
           move      1                    to   w-pmt-sdc-pgf-pnt      .
      *                      *-----------------------------------------*
      *                      * Prompt                                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Deviazione in funzione del tipo o-  *
      *                          * perazione                           *
      *                          *-------------------------------------*
           if        w-tes-tip-ope        =    1830 or
                     w-tes-tip-ope        =    1831 or
                     w-tes-tip-ope        =    1850
                     go to pmt-sdc-pgf-010
           else if   w-tes-tip-ope        =    1840
                     go to pmt-sdc-pgf-020
           else      go to pmt-sdc-pgf-080.
       pmt-sdc-pgf-010.
           string    "Nostra banca : "
                                delimited by   size
                                          into w-pmt-sdc-pgf-x80
                                  with pointer w-pmt-sdc-pgf-pnt      .
           go to     pmt-sdc-pgf-030.
       pmt-sdc-pgf-020.
           string    "Nostro C/C postale : "
                                delimited by   size
                                          into w-pmt-sdc-pgf-x80
                                  with pointer w-pmt-sdc-pgf-pnt      .
           go to     pmt-sdc-pgf-030.
       pmt-sdc-pgf-030.
      *                      *-----------------------------------------*
      *                      * Codice e descrizione banca o c/c posta- *
      *                      * le                                      *
      *                      *-----------------------------------------*
           string    w-tes-cbp-adp (1)
                                delimited by   spaces
                     "  "       delimited by   size
                     w-tes-cbp-adp-des (1)
                                delimited by   size
                                          into w-pmt-sdc-pgf-x80
                                  with pointer w-pmt-sdc-pgf-pnt      .
      *                  *---------------------------------------------*
      *                  * Stampa stringa composta                     *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      w-pmt-sdc-pgf-x80    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       pmt-sdc-pgf-080.
      *              *-------------------------------------------------*
      *              * Trattini a linea 05                             *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      all   "-"            to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Linea di fincatura                              *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "                  Fornitore                  |    
      -              " Importo    | I |   Addebito  "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Sottolineatura fincatura                        *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "---------------------------------------------|----
      -              "------------|---|-------------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       pmt-sdc-pgf-100.
      *              *-------------------------------------------------*
      *              * Colonne per saldaconto                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore numero linea     *
      *                  *---------------------------------------------*
           move      07                   to   w-pmt-sdc-pgf-ctr      .
       pmt-sdc-pgf-120.
      *                  *---------------------------------------------*
      *                  * Ciclo da linea 08 a linea 19                *
      *                  *---------------------------------------------*
           add       1                    to   w-pmt-sdc-pgf-ctr      .
           if        w-pmt-sdc-pgf-ctr    >    19
                     go to pmt-sdc-pgf-200.
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      w-pmt-sdc-pgf-ctr    to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "                                             |    
      -              "            |   |             "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Riciclo                                 *
      *                      *-----------------------------------------*
           go to     pmt-sdc-pgf-120.
       pmt-sdc-pgf-200.
      *              *-------------------------------------------------*
      *              * Trattini a linea 20                             *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      all   "-"            to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Prompts per totali a linea 21                   *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "                                      Totali |    
      -              "            |   |             "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       pmt-sdc-pgf-999.
