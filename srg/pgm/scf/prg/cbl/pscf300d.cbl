      *              *-------------------------------------------------*
           if        w-tes-fda-tes (1)    not  = spaces
                     go to acc-pre-vp1-300.
      *              *-------------------------------------------------*
      *              * Caricamento del buffer pagamenti fornitori      *
      *              *-------------------------------------------------*
           perform   car-buf-pgf-000      thru car-buf-pgf-999        .
      *              *-------------------------------------------------*
      *              * Se esito caricamento negativo : si esce forzan- *
      *              * do il tasto Up                                  *
      *              *-------------------------------------------------*
           if        w-car-buf-pgf-flg    not  = spaces
                     move  "UP  "         to   v-key
                     go to acc-pre-vp1-999.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di impostazione saldaconto *
      *              *-------------------------------------------------*
           move      spaces               to   w-sdc-flg-imp          .
      *              *-------------------------------------------------*
      *              * Attivazione flag di impostazione pagina testata *
      *              *-------------------------------------------------*
           move      "#"                  to   w-tes-fda-tes (1)      .
       acc-pre-vp1-300.
      *              *-------------------------------------------------*
      *              * Se non esiste alcuna pagina attiva successiva   *
      *              * alla pagina attuale : uscita                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio numero pagina attuale           *
      *                  *---------------------------------------------*
           move      w-cnt-sts-imp-npt    to   w-cnt-sts-imp-svp      .
       acc-pre-vp1-400.
      *                  *---------------------------------------------*
      *                  * Se all'ultima pagina : ripristino pagina    *
      *                  * salvata ed uscita                           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-npt    not  < w-cnt-sts-imp-mpt
                     move  w-cnt-sts-imp-svp
                                          to   w-cnt-sts-imp-npt
                     go to acc-pre-vp1-999.
      *                  *---------------------------------------------*
      *                  * Incremento numero pagina                    *
      *                  *---------------------------------------------*
           add       1                    to   w-cnt-sts-imp-npt      .
      *                  *---------------------------------------------*
      *                  * Test se pagina da trattare                  *
      *                  *---------------------------------------------*
           perform   snp-tes-reg-000      thru snp-tes-reg-999        .
      *                  *---------------------------------------------*
      *                  * Se no : a re-incremento                     *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-snp    not  = spaces
                     go to acc-pre-vp1-400.
      *                  *---------------------------------------------*
      *                  * Se si : ripristino pagina salvata           *
      *                  *---------------------------------------------*
           move      w-cnt-sts-imp-svp    to   w-cnt-sts-imp-npt      .
       acc-pre-vp1-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazioni pagina testata nr. 1            *
      *    *-----------------------------------------------------------*
       cnt-imp-pg1-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-imp-pg1-flg      .
      *              *-------------------------------------------------*
      *              * Test se la pagina e' da trattare                *
      *              *                                                 *
      *              * N.B.: Il test seguente deve essere pari a quel- *
      *              *       lo contenuto in snp-tes-reg-000/999       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * La pagina e' sempre da trattare             *
      *                  *---------------------------------------------*
           go to     cnt-imp-pg1-100.
       cnt-imp-pg1-100.
      *              *-------------------------------------------------*
      *              * Codice nostra banca o c/c postale               *
      *              *-------------------------------------------------*
           if        w-tes-cbp-adp (1)    not  = spaces
                     go to cnt-imp-pg1-120.
           if        w-tes-tip-ope        =    1830 or
                     w-tes-tip-ope        =    1831 or
                     w-tes-tip-ope        =    1850
                     go to cnt-imp-pg1-102
           else if   w-tes-tip-ope        =    1840
                     go to cnt-imp-pg1-104.
       cnt-imp-pg1-102.
           move      "Manca il codice nostra banca !                    
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pg1-900.
       cnt-imp-pg1-104.
           move      "Manca il codice nostro c/c postale !              
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pg1-900.
       cnt-imp-pg1-120.
      *              *-------------------------------------------------*
      *              * Data documento per l'addebito                   *
      *              *-------------------------------------------------*
           if        w-tes-ndo-adp (1)    =    spaces
                     go to cnt-imp-pg1-140.
           if        w-tes-ddo-adp (1)    not  = zero
                     go to cnt-imp-pg1-140.
           move      "Manca la data documento per l'addebito !          
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pg1-900.
       cnt-imp-pg1-140.
      *              *-------------------------------------------------*
      *              * Numero documento per l'addebito                 *
      *              *-------------------------------------------------*
           if        w-tes-ddo-adp (1)    =    zero
                     go to cnt-imp-pg1-160.
           if        w-tes-ndo-adp (1)    not  = spaces
                     go to cnt-imp-pg1-160.
           move      "Manca il numero documento !                       
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pg1-900.
       cnt-imp-pg1-160.
      *              *-------------------------------------------------*
      *              * Selezione su codice fornitore                   *
      *              *-------------------------------------------------*
       cnt-imp-pg1-180.
      *              *-------------------------------------------------*
      *              * Selezione su dipendenza fornitore               *
      *              *-------------------------------------------------*
       cnt-imp-pg1-200.
      *              *-------------------------------------------------*
      *              * Sigla valuta                                    *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        not  = 1831
                     go to cnt-imp-pg1-220.
           if        w-tes-sgl-vlt (1)    not  = spaces
                     go to cnt-imp-pg1-220.
           move      "Manca il codice valuta per l'addebito !           
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pg1-900.
       cnt-imp-pg1-220.
      *              *-------------------------------------------------*
      *              * Fine controlli                                  *
      *              *-------------------------------------------------*
           go to     cnt-imp-pg1-999.
       cnt-imp-pg1-900.
      *              *-------------------------------------------------*
      *              * Se controllo non superato                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di errore in uscita                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-imp-pg1-flg      .
       cnt-imp-pg1-999.
           exit.
           
      *    *===========================================================*
      *    * Caricamento dei buffer pagamenti fornitori                *
      *    *-----------------------------------------------------------*
       car-buf-pgf-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-car-buf-pgf-flg      .
      *              *-------------------------------------------------*
      *              * Azzeramento contatori pagamenti scartati duran- *
      *              * te il caricamento del buffer                    *
      *              *-------------------------------------------------*
           move      zero                 to   w-car-buf-pgf-cps (01) .
           move      zero                 to   w-car-buf-pgf-cps (02) .
           move      zero                 to   w-car-buf-pgf-cps (03) .
           move      zero                 to   w-car-buf-pgf-cps (04) .
           move      zero                 to   w-car-buf-pgf-cps (05) .
           move      zero                 to   w-car-buf-pgf-cps (06) .
           move      zero                 to   w-car-buf-pgf-cps (07) .
      *              *-------------------------------------------------*
      *              * Azzeramento contatori numero elementi nel buf-  *
      *              * fer                                             *
      *              *-------------------------------------------------*
           move      zero                 to   w-bpf-num-ele          .
      *              *-------------------------------------------------*
      *              * Azzeramento totale pagamenti fornitori nel buf- *
      *              * fer                                             *
      *              *-------------------------------------------------*
           move      zero                 to   w-bpf-tot-pgf          .
      *              *-------------------------------------------------*
      *              * Messaggio di caricamento in esecuzione          *
      *              *-------------------------------------------------*
           move      "  Selezione pagamenti da includere nell'addebito i
      -              "n esecuzione   "    to   w-err-box-err-msg      .
           perform   msg-cnt-box-000      thru msg-cnt-box-999        .
       car-buf-pgf-100.
      *              *-------------------------------------------------*
      *              * Sort pagamenti fornitore                        *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   car-buf-pgf-inp-000
                                          thru car-buf-pgf-inp-999
                     output procedure     is   car-buf-pgf-out-000
                                          thru car-buf-pgf-out-999    .
       car-buf-pgf-200.
      *              *-------------------------------------------------*
      *              * Cancellazione messaggio di caricamento in ese-  *
      *              * cuzione                                         *
      *              *-------------------------------------------------*
           move      spaces               to   w-err-box-err-msg      .
           perform   msg-cnt-box-000      thru msg-cnt-box-999        .
      *              *-------------------------------------------------*
      *              * Test se contatori pagamenti scartati tutti a    *
      *              * zero e nessun elemento nel buffer               *
      *              *-------------------------------------------------*
           if       (w-car-buf-pgf-cps (01)
                                          =    zero and
                     w-car-buf-pgf-cps (02)
                                          =    zero and
                     w-car-buf-pgf-cps (03)
                                          =    zero and
                     w-car-buf-pgf-cps (04)
                                          =    zero and
                     w-car-buf-pgf-cps (05)
                                          =    zero and
                     w-car-buf-pgf-cps (06)
                                          =    zero and
                     w-car-buf-pgf-cps (07)
                                          =    zero   ) and
                    (w-bpf-num-ele        =    zero   )

                     go to car-buf-pgf-210
           else      go to car-buf-pgf-300.
       car-buf-pgf-210.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo opera-  *
      *                      * zione                                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        =    1830 or
                     w-tes-tip-ope        =    1831 or
                     w-tes-tip-ope        =    1850
                     go to car-buf-pgf-212
           else if   w-tes-tip-ope        =    1840
                     go to car-buf-pgf-214
           else      go to car-buf-pgf-216.
       car-buf-pgf-212.
      *                      *-----------------------------------------*
      *                      * Tipo operazione : 1830, 1831 o 1850     *
      *                      *-----------------------------------------*
           move      "Nessun pagamento da addebitare per la Banca indica
      -              "ta !           "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     car-buf-pgf-216.
       car-buf-pgf-214.
      *                      *-----------------------------------------*
      *                      * Tipo operazione : 1840                  *
      *                      *-----------------------------------------*
           move      "Nessun pagamento da addebitare per il C/C Postale 
      -              "indicato !     "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     car-buf-pgf-216.
       car-buf-pgf-216.
      *                  *---------------------------------------------*
      *                  * Flag di uscita ad errore                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-car-buf-pgf-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     car-buf-pgf-999.
       car-buf-pgf-300.
      *              *-------------------------------------------------*
      *              * Se contatori pagamenti scartati tutti a zero :  *
      *              * uscita                                          *
      *              *-------------------------------------------------*
           if        w-car-buf-pgf-cps (01)
                                          =    zero and
                     w-car-buf-pgf-cps (02)
                                          =    zero and
                     w-car-buf-pgf-cps (03)
                                          =    zero and
                     w-car-buf-pgf-cps (04)
                                          =    zero and
                     w-car-buf-pgf-cps (05)
                                          =    zero and
                     w-car-buf-pgf-cps (06)
                                          =    zero and
                     w-car-buf-pgf-cps (07)
                     go to car-buf-pgf-999.
      *              *-------------------------------------------------*
      *              * Altrimenti, box di avviso per pagamenti scarta- *
      *              * ti                                              *
      *              *-------------------------------------------------*
           perform   car-buf-pgf-box-000  thru car-buf-pgf-box-999    .
       car-buf-pgf-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort in fase di caricamento pagamenti *
      *    * fornitore                                                 *
      *    *-----------------------------------------------------------*
       car-buf-pgf-inp-000.
      *              *-------------------------------------------------*
      *              * Start su file [sfp]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CBPADP    "         to   f-key                  .
           move      w-tes-cbp-adp (1)    to   rf-sfp-cbp-pgf         .
           move      zero                 to   rf-sfp-num-adp         .
           move      zero                 to   rf-sfp-num-pgf         .
           move      "pgm/scf/fls/ioc/obj/iofsfp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfp                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to car-buf-pgf-inp-999.
       car-buf-pgf-inp-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [sfp]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfp                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to car-buf-pgf-inp-999.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-sfp-cbp-pgf       not  = w-tes-cbp-adp (1) or
                     rf-sfp-num-adp       not  = zero
                     go to car-buf-pgf-inp-999.
      *              *-------------------------------------------------*
      *              * Selezioni su record [sfp] bloccanti             *
      *              *-------------------------------------------------*
           perform   sel-sfp-blo-000      thru sel-sfp-blo-999        .
      *              *-------------------------------------------------*
      *              * Se selezione superata : oltre                   *
      *              *-------------------------------------------------*
           if        w-sel-sfp-blo-flg    =    zero
                     go to car-buf-pgf-inp-120.
      *                  *---------------------------------------------*
      *                  * Determinazione indice contatore di errori   *
      *                  *                                             *
      *                  * N.B.: Solo se incompatibilita' nella sigla  *
      *                  *       valuta                                *
      *                  *---------------------------------------------*
           if        w-sel-sfp-blo-flg    =    13
                     move  03             to   w-car-buf-pgf-inx
           else      go to car-buf-pgf-inp-110.
      *                  *---------------------------------------------*
      *                  * Incremento contatore di errori              *
      *                  *---------------------------------------------*
           if        w-car-buf-pgf-cps
                    (w-car-buf-pgf-inx)   <    9999
                     add   1              to   w-car-buf-pgf-cps
                                              (w-car-buf-pgf-inx)     .
       car-buf-pgf-inp-110.
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     car-buf-pgf-inp-100.
       car-buf-pgf-inp-120.
      *              *-------------------------------------------------*
      *              * Selezioni su record [sfp] non bloccanti         *
      *              *-------------------------------------------------*
           perform   sel-sfp-nbl-000      thru sel-sfp-nbl-999        .
      *              *-------------------------------------------------*
      *              * Se selezione superata : oltre                   *
      *              *-------------------------------------------------*
           if        w-sel-sfp-nbl-flg    =    zero
                     go to car-buf-pgf-inp-140.
      *                  *---------------------------------------------*
      *                  * Determinazione indice contatore di errori   *
      *                  *---------------------------------------------*
           if        w-sel-sfp-nbl-flg    =    11
                     move  01             to   w-car-buf-pgf-inx
           else if   w-sel-sfp-nbl-flg    =    12
                     move  02             to   w-car-buf-pgf-inx
           else      go to car-buf-pgf-inp-130.
      *                  *---------------------------------------------*
      *                  * Incremento contatore di errori              *
      *                  *---------------------------------------------*
           if        w-car-buf-pgf-cps
                    (w-car-buf-pgf-inx)   <    9999
                     add   1              to   w-car-buf-pgf-cps
                                              (w-car-buf-pgf-inx)     .
       car-buf-pgf-inp-130.
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     car-buf-pgf-inp-100.
       car-buf-pgf-inp-140.
      *              *-------------------------------------------------*
      *              * Fine selezioni sul record                       *
      *              *-------------------------------------------------*
       car-buf-pgf-inp-300.
      *              *-------------------------------------------------*
      *              * Composizione sort-record                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Chiave del sort                             *
      *                  *---------------------------------------------*
           move      rf-sfp-dtr-pgf       to   srt-dtr-pgf            .
           move      rf-sfp-num-pgf       to   srt-num-pgf            .
      *                  *---------------------------------------------*
      *                  * Dati del sort                               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Valori contenuti direttamente in record *
      *                      * [sfp]                                   *
      *                      *-----------------------------------------*
           move      rf-sfp-cod-fnt       to   srt-cod-fnt            .
           move      rf-sfp-dpz-fnt       to   srt-dpz-fnt            .
           move      rf-sfp-imp-pgf       to   srt-imp-pgf            .
           move      rf-sfp-aos-pgf       to   srt-aos-pgf            .
      *                      *-----------------------------------------*
      *                      * Valori contenuti indirettamente in re-  *
      *                      * cord [sfp]                              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Lettura archivio [dcf]              *
      *                          *-------------------------------------*
           if        rf-sfp-dpz-fnt       =    spaces
                     move  "C"            to   w-let-arc-dcf-tle
           else      move  "D"            to   w-let-arc-dcf-tle      .
           move      rf-sfp-cod-fnt       to   w-let-arc-dcf-cod      .
           move      rf-sfp-dpz-fnt       to   w-let-arc-dcf-dpz      .
           perform   let-arc-dcf-000      thru let-arc-dcf-999        .
           move      w-let-arc-dcf-rag    to   srt-rag-fnt            .
       car-buf-pgf-inp-400.
      *              *-------------------------------------------------*
      *              * Rilascio record al sort                         *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       car-buf-pgf-inp-500.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale record [sfp]     *
      *              *-------------------------------------------------*
           go to     car-buf-pgf-inp-100.
       car-buf-pgf-inp-999.
           exit.

      *    *===========================================================*
      *    * Output procedure per sort in fase di caricamento pagamen- *
      *    * ti fornitore                                              *
      *    *-----------------------------------------------------------*
       car-buf-pgf-out-000.
      *              *-------------------------------------------------*
      *              * Lettura record da sort                          *
      *              *-------------------------------------------------*
           return    srt    at end
                            go to car-buf-pgf-out-999.
       car-buf-pgf-out-100.
      *              *-------------------------------------------------*
      *              * Caricamento buffer pagamenti fornitore          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Memorizzazione elemento nel buffer          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se gia' raggiunto il massimo       *
      *                      *-----------------------------------------*
           if        w-bpf-num-ele        <    w-bpf-max-ele
                     go to car-buf-pgf-out-120.
      *                          *-------------------------------------*
      *                          * Incremento contatore pagamenti      *
      *                          * scartati nr. 08                     *
      *                          *-------------------------------------*
           if        w-car-buf-pgf-cps (08)
                                          <    9999
                     add   1              to   w-car-buf-pgf-cps (08) .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     car-buf-pgf-out-200.
       car-buf-pgf-out-120.
      *                      *-----------------------------------------*
      *                      * Incremento numero elementi              *
      *                      *-----------------------------------------*
           add       1                    to   w-bpf-num-ele          .
      *                      *-----------------------------------------*
      *                      * Memorizzazione nuovo elemento           *
      *                      *-----------------------------------------*
           move      srt-num-pgf          to   w-bpf-num-pgf
                                              (w-bpf-num-ele)         .
           move      srt-cod-fnt          to   w-bpf-cod-fnt
                                              (w-bpf-num-ele)         .
           move      srt-dpz-fnt          to   w-bpf-dpz-fnt
                                              (w-bpf-num-ele)         .
           move      srt-rag-fnt          to   w-bpf-rag-fnt
                                              (w-bpf-num-ele)         .
           move      srt-imp-pgf          to   w-bpf-imp-pgf
                                              (w-bpf-num-ele)         .
           move      spaces               to   w-bpf-flg-pgs
                                              (w-bpf-num-ele)         .
           move      srt-aos-pgf          to   w-bpf-aos-pgf
                                              (w-bpf-num-ele)         .
      *                      *-----------------------------------------*
      *                      * Aggiornamento totali pagamenti fornito- *
      *                      * ri                                      *
      *                      *-----------------------------------------*
           add       srt-imp-pgf          to   w-bpf-tot-pgf          .
       car-buf-pgf-out-200.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura record da sort               *
      *              *-------------------------------------------------*
           go to     car-buf-pgf-out-000.
       car-buf-pgf-out-999.
           exit.

      *    *===========================================================*
      *    * Box di avviso per pagamenti scartati                      *
      *    *-----------------------------------------------------------*
       car-buf-pgf-box-000.
      *              *-------------------------------------------------*
      *              * Determinazione numero parametri da esporre nel  *
      *              * messaggio                                       *
      *              *-------------------------------------------------*
           move      2                    to   w-car-buf-pgf-wnp      .
           if        w-car-buf-pgf-cps (03)
                                          not  = zero
                     add   1              to   w-car-buf-pgf-wnp      .
      *              *-------------------------------------------------*
      *              * Se numero parametri da esporre nel messaggio    *
      *              * oltre il limite dei 4 previsti, si forza a 4    *
      *              *-------------------------------------------------*
           if        w-car-buf-pgf-wnp    >    4
                     move  4              to   w-car-buf-pgf-wnp      .
      *              *-------------------------------------------------*
      *              * Determinazione numero linea iniziale e finale   *
      *              * del box                                         *
      *              *-------------------------------------------------*
           if        w-car-buf-pgf-wnp    =    2
                     move  08             to   w-car-buf-pgf-bli
                     move  20             to   w-car-buf-pgf-blf
           else if   w-car-buf-pgf-wnp    =    3
                     move  08             to   w-car-buf-pgf-bli
                     move  21             to   w-car-buf-pgf-blf
           else if   w-car-buf-pgf-wnp    =    4
                     move  07             to   w-car-buf-pgf-bli
                     move  21             to   w-car-buf-pgf-blf      .
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
