      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-sts-ing-ppx
                                              (w-cnt-sts-imp-npp)     .
      *                  *---------------------------------------------*
      *                  * Video in 'ON'                               *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Accettazione dati piede                     *
      *                  *---------------------------------------------*
           perform   acc-pie-reg-000      thru acc-pie-reg-999        .
      *                  *---------------------------------------------*
      *                  * Se tipo uscita definitivo                   *
      *                  *---------------------------------------------*
           if        w-cnt-tus-acc-pie    =    "S" or
                     w-cnt-tus-acc-pie    =    "X" or
                     w-cnt-tus-acc-pie    =    "E"
                     move  w-cnt-tus-acc-pie
                                          to   w-cnt-tus-acc-nok
                     go to acc-nok-reg-999.
      *                  *---------------------------------------------*
      *                  * Se spostamento di pagina                    *
      *                  *---------------------------------------------*
           if        w-cnt-tus-acc-pie    =    "-"
                     go to acc-nok-reg-610
           else      go to acc-nok-reg-650.
       acc-nok-reg-610.
      *                      *-----------------------------------------*
      *                      * Se spostamento a pagina precedente      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se la pagina attuale e' 1 : ad ac-  *
      *                          * cettazione corpo 2                  *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-npp    >    1
                     go to acc-nok-reg-620.
      *                              *---------------------------------*
      *                              * Nr riga corpo 2 da accettare :  *
      *                              * max + 1                         *
      *                              *---------------------------------*
           move      w-cat-rg2-max        to   w-cnt-co2-nrg-dac      .
           if        w-cat-rg2-app        =    spaces
                     add   1              to   w-cnt-co2-nrg-dac      .
           go to     acc-nok-reg-500.
       acc-nok-reg-620.
      *                          *-------------------------------------*
      *                          * Status di visualizzazione prompts e *
      *                          * dati della pagina attuale a : no    *
      *                          *-------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-ppx
                                              (w-cnt-sts-imp-npp)     .
           move      spaces               to   w-cnt-sts-vis-ppx
                                              (w-cnt-sts-imp-npp)     .
       acc-nok-reg-630.
      *                          *-------------------------------------*
      *                          * Decremento numero pagina attuale    *
      *                          *-------------------------------------*
           subtract  1                    from w-cnt-sts-imp-npp      .
       acc-nok-reg-640.
      *                          *-------------------------------------*
      *                          * Test se pagina da trattare          *
      *                          *-------------------------------------*
           perform   snp-pie-reg-000      thru snp-pie-reg-999        .
      *                          *-------------------------------------*
      *                          * Se no : decremento ulteriore, a me- *
      *                          *         no di non essere a pagina 1 *
      *                          *         caso in cui si va' ad ac-   *
      *                          *         cettazione corpo 2          *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-snx    not  = spaces
                     go to acc-nok-reg-610.
      *                          *-------------------------------------*
      *                          * Riciclo ad impostazione piede       *
      *                          *-------------------------------------*
           go to     acc-nok-reg-600.
       acc-nok-reg-650.
      *                      *-----------------------------------------*
      *                      * Se spostamento a pagina successiva      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Salvataggio numero pagina attuale   *
      *                          *-------------------------------------*
           move      w-cnt-sts-imp-npp    to   w-cnt-sts-imp-spp      .
       acc-nok-reg-660.
      *                          *-------------------------------------*
      *                          * Status di impostazione dati della   *
      *                          * della pagina attuale a : si'        *
      *                          *-------------------------------------*
           move      "#"                  to   w-cnt-sts-imp-ppx
                                              (w-cnt-sts-imp-npp)     .
      *                          *-------------------------------------*
      *                          * Se la pagina attuale e' la massima  *
      *                          * si pone lo status di impostazione   *
      *                          * dati generale piede a si'           *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-npp    not  < w-cnt-sts-imp-mpp
                     move  "#"            to   w-cnt-sts-imp-pie      .
      *                          *-------------------------------------*
      *                          * Se la pagina attuale e' la massima  *
      *                          * si va' a conferma impostazioni      *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-npp    not  < w-cnt-sts-imp-mpp
                     move  w-cnt-sts-imp-spp
                                          to   w-cnt-sts-imp-npp
                     go to acc-nok-reg-800.
      *                          *-------------------------------------*
      *                          * Incremento numero pagina attuale    *
      *                          *-------------------------------------*
           add       1                    to   w-cnt-sts-imp-npp      .
      *                          *-------------------------------------*
      *                          * Test se pagina da trattare          *
      *                          *-------------------------------------*
           perform   snp-pie-reg-000      thru snp-pie-reg-999        .
      *                          *-------------------------------------*
      *                          * Se no : a re-incremento             *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-snx    not  = spaces
                     go to acc-nok-reg-660.
      *                          *-------------------------------------*
      *                          * Status di visualizzazione prompts e *
      *                          * dati della pagina impostata a : no  *
      *                          *-------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-ppx
                                              (w-cnt-sts-imp-spp)     .
           move      spaces               to   w-cnt-sts-vis-ppx
                                              (w-cnt-sts-imp-spp)     .
      *                          *-------------------------------------*
      *                          * Riciclo ad impostazione piede       *
      *                          *-------------------------------------*
           go to     acc-nok-reg-600.
       acc-nok-reg-800.
      *              *-------------------------------------------------*
      *              * Conferma impostazioni                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Se attualmente visualizzato il corpo 2 si   *
      *                  * esegue la visualizzazione dei prompts della *
      *                  * riga corpo 2 espansa                        *
      *                  *---------------------------------------------*
           if        w-cnt-sts-pmt-co2    =    spaces
                     go to acc-nok-reg-805.
           perform   pmt-rig-co2-000      thru pmt-rig-co2-999        .
       acc-nok-reg-805.
      *                  *---------------------------------------------*
      *                  * Cancellazione eventuali note operative      *
      *                  *---------------------------------------------*
           move      "NT"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-nok-reg-810.
      *                  *---------------------------------------------*
      *                  * Test se sola visualizzazione                *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "V"
                     go to acc-nok-reg-820
           else      go to acc-nok-reg-830.
       acc-nok-reg-820.
      *                      *-----------------------------------------*
      *                      * Accettazione se sola visualizzazione    *
      *                      *-----------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      "#VIS"               to   v-not                  .
           move      spaces               to   v-alf                  .
           move      "E"                  to   v-msk                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           if        v-key                not  = spaces
                     go to acc-nok-reg-840.
           if        v-alf                =    "E"
                     move  "EXIT"         to   v-key                  .
           go to     acc-nok-reg-840.
       acc-nok-reg-830.
      *                      *-----------------------------------------*
      *                      * Accettazione se inserimento o modifica  *
      *                      *-----------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      "#SAV"               to   v-not                  .
           move      spaces               to   v-alf                  .
           move      "SNE"                to   v-msk                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           if        v-key                not  = spaces
                     go to acc-nok-reg-840.
           if        v-alf                =    "S"
                     move   "DO  "        to   v-key
           else if   v-alf                =    "E"
                     move   "EXIT"        to   v-key
           else if   v-alf                =    "N"
                     move   "UP  "        to   v-key                  .
       acc-nok-reg-840.
      *                  *---------------------------------------------*
      *                  * Test su risposta dell'utente                *
      *                  *---------------------------------------------*
           if        v-key                =    "DO  "
                     go to acc-nok-reg-850
           else if   v-key                =    "EXIT"
                     go to acc-nok-reg-860
           else if   v-key                =    "UP  "
                     go to acc-nok-reg-870
           else      go to acc-nok-reg-810.
       acc-nok-reg-850.
      *                  *---------------------------------------------*
      *                  * Se Do                                       *
      *                  *---------------------------------------------*
           move      "S"                  to   w-cnt-tus-acc-nok      .
           perform   cnt-tdo-nok-000      thru cnt-tdo-nok-999        .
           if        w-cnt-tdo-nok-flg    not  = spaces
                     go to acc-nok-reg-870.
           go to     acc-nok-reg-999.
       acc-nok-reg-860.
      *                  *---------------------------------------------*
      *                  * Se Exit                                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Subroutine di controllo per Exit        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se Exit non attivato : come 'Up'    *
      *                          *-------------------------------------*
           perform   exe-acc-cmp-exi-000  thru exe-acc-cmp-exi-999    .
           if        w-cnt-acc-flg-exi    not  = spaces
                     go to acc-nok-reg-870.
      *                          *-------------------------------------*
      *                          * Se Exit attivato                    *
      *                          *-------------------------------------*
           move      "E"                  to   w-cnt-tus-acc-nok      .
           go to     acc-nok-reg-999.
       acc-nok-reg-870.
      *                  *---------------------------------------------*
      *                  * Se Up                                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ad accettazione piede                   *
      *                      *-----------------------------------------*
           move      spaces               to   v-key                  .
           go to     acc-nok-reg-640.
       acc-nok-reg-999.
           exit.

      *    *===========================================================*
      *    * Determinazione numero pagine che compongono la testata    *
      *    *-----------------------------------------------------------*
       dmp-tes-reg-000.
      *              *-------------------------------------------------*
      *              * La testata e' composta di nr. 4 pagine          *
      *              *-------------------------------------------------*
           move      4                    to   w-cnt-sts-imp-mpt      .
       dmp-tes-reg-999.
           exit.

      *    *===========================================================*
      *    * Determinazione si/no pagina w-cnt-sts-imp-npt da trattare *
      *    *-----------------------------------------------------------*
       snp-tes-reg-000.
      *              *-------------------------------------------------*
      *              * Flag di uscita a Si                             *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-sts-imp-snp      .
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del numero pagina        *
      *              *-------------------------------------------------*
           go to     snp-tes-reg-100
                     snp-tes-reg-200
                     snp-tes-reg-300
                     snp-tes-reg-400
                     depending            on   w-cnt-sts-imp-npt      .
       snp-tes-reg-100.
      *              *-------------------------------------------------*
      *              * Se pagina 1                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita comunque a Si                *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-imp-snp      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     snp-tes-reg-999.
       snp-tes-reg-200.
      *              *-------------------------------------------------*
      *              * Se pagina 2                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita comunque a Si                *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-sts-imp-snp      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     snp-tes-reg-999.
       snp-tes-reg-300.
      *              *-------------------------------------------------*
      *              * Se pagina 3                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se ritenuta d'acconto                  *
      *                  *---------------------------------------------*
           if        w-tes-snx-rda (1)    not  = "S"
                     move  "#"            to   w-cnt-sts-imp-snp
                     go to snp-tes-reg-999.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     snp-tes-reg-999.
       snp-tes-reg-400.
      *              *-------------------------------------------------*
      *              * Se pagina 4                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se registrazione contabile da eseguire *
      *                  *---------------------------------------------*
           perform   cge-scf-ftf-snx-000  thru cge-scf-ftf-snx-999    .
      *                  *---------------------------------------------*
      *                  * Se registrazione contabile da non eseguire: *
      *                  * no, altrimenti si                           *
      *                  *---------------------------------------------*
           if        w-cge-scf-ftf-snx    =    "N"
                     move  "#"            to   w-cnt-sts-imp-snp
                     go to snp-tes-reg-999.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     snp-tes-reg-999.
       snp-tes-reg-999.
           exit.

      *    *===========================================================*
      *    * Accettazione testata registrazione                        *
      *    *-----------------------------------------------------------*
       acc-tes-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione tipo uscita                     *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-tes      .
      *              *-------------------------------------------------*
      *              * Normalizzazione function-key                    *
      *              *-------------------------------------------------*
           move      spaces               to   v-key                  .
      *              *-------------------------------------------------*
      *              * Tipo impostazione : testata                     *
      *              *-------------------------------------------------*
           move      "T"                  to   w-cnt-mfu-tip-imp      .
      *              *-------------------------------------------------*
      *              * Accettazioni                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del numero pagina    *
      *                  *---------------------------------------------*
           go to     acc-tes-reg-100
                     acc-tes-reg-200
                     acc-tes-reg-300
                     acc-tes-reg-400
                     depending            on   w-cnt-sts-imp-npt      .
           go to     acc-tes-reg-999.
       acc-tes-reg-100.
      *                  *---------------------------------------------*
      *                  * Pagina 1                                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione func-key d'impostazione *
      *                      *-----------------------------------------*
           move      spaces               to   v-key                  .
      *                      *-----------------------------------------*
      *                      * Codice fornitore                        *
      *                      *-----------------------------------------*
           perform   acc-cod-fnt-000      thru acc-cod-fnt-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
       acc-tes-reg-105.
      *                      *-----------------------------------------*
      *                      * Codice dipendenza fornitore             *
      *                      *-----------------------------------------*
           perform   acc-dpz-fnt-000      thru acc-dpz-fnt-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-100.
       acc-tes-reg-110.
      *                      *-----------------------------------------*
      *                      * Si/no documento elettronico             *
      *                      *-----------------------------------------*
           perform   acc-snx-sdi-000      thru acc-snx-sdi-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-105.
       acc-tes-reg-112.
      *                      *-----------------------------------------*
      *                      * Nome documento elettronico              *
      *                      *-----------------------------------------*
           perform   acc-fil-sdi-000      thru acc-fil-sdi-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-110.
       acc-tes-reg-115.
      *                      *-----------------------------------------*
      *                      * Data documento                          *
      *                      *-----------------------------------------*
           perform   acc-ddo-ftf-000      thru acc-ddo-ftf-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-110.
       acc-tes-reg-120.
      *                      *-----------------------------------------*
      *                      * Numero documento                        *
      *                      *-----------------------------------------*
           perform   acc-ndo-ftf-000      thru acc-ndo-ftf-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-115.
           go to     acc-tes-reg-130.
       acc-tes-reg-125.
      *                      *-----------------------------------------*
      *                      * Esclusione da statistiche               *
      *                      *-----------------------------------------*
           perform   acc-snx-saf-000      thru acc-snx-saf-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-115.
       acc-tes-reg-130.
      *                      *-----------------------------------------*
      *                      * Sigla valuta                            *
      *                      *-----------------------------------------*
           perform   acc-sgl-vlt-000      thru acc-sgl-vlt-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-125.
       acc-tes-reg-140.
      *                      *-----------------------------------------*
      *                      * Coefficiente di cambio                  *
      *                      *-----------------------------------------*
           perform   acc-cdc-ftf-000      thru acc-cdc-ftf-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-130.
       acc-tes-reg-150.
      *                      *-----------------------------------------*
      *                      * Importo in valuta                       *
      *                      *-----------------------------------------*
           perform   acc-iiv-ftf-000      thru acc-iiv-ftf-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-140.
       acc-tes-reg-160.
      *                      *-----------------------------------------*
      *                      * Importo fattura fornitore               *
      *                      *-----------------------------------------*
           perform   acc-imp-ftf-000      thru acc-imp-ftf-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-150.
      *                      *-----------------------------------------*
      *                      * Se Next Screen                          *
      *                      *-----------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-tes-reg-190.
      *                      *-----------------------------------------*
      *                      * Presa visione per pagina 1              *
      *                      *-----------------------------------------*
           perform   acc-pre-vpg-000      thru acc-pre-vpg-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-tes      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-160.
       acc-tes-reg-190.
      *                      *-----------------------------------------*
      *                      * Flag di accettazione pagina testata 1   *
      *                      *-----------------------------------------*
           move      "#"                  to   w-tes-fda-pt1 (1)      .
      *                      *-----------------------------------------*
      *                      * Fine Pagina                             *
      *                      *-----------------------------------------*
           move      "+"                  to   w-cnt-tus-acc-tes      .
           go to     acc-tes-reg-999.
       acc-tes-reg-200.
      *                  *---------------------------------------------*
      *                  * Pagina 2                                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Inoltro pagamenti al fornitore          *
      *                      *-----------------------------------------*
           perform   acc-inl-pgf-000      thru acc-inl-pgf-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     move  "-"            to   w-cnt-tus-acc-tes
                     go to acc-tes-reg-999.
       acc-tes-reg-205.
      *                      *-----------------------------------------*
      *                      * Contropartita acquisti                  *
      *                      *-----------------------------------------*
           perform   acc-ctp-acq-000      thru acc-ctp-acq-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-200.
       acc-tes-reg-210.
      *                      *-----------------------------------------*
      *                      * Codice forma di pagamento               *
      *                      *-----------------------------------------*
           perform   acc-cod-fop-000      thru acc-cod-fop-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-205.
       acc-tes-reg-215.
      *                      *-----------------------------------------*
      *                      * Codice nostra banca di appoggio         *
      *                      *-----------------------------------------*
           perform   acc-nsb-ftf-000      thru acc-nsb-ftf-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-210.
       acc-tes-reg-220.
      *                      *-----------------------------------------*
      *                      * Codice ABI del fornitore                *
      *                      *-----------------------------------------*
           perform   acc-abi-ftf-000      thru acc-abi-ftf-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-215.
       acc-tes-reg-225.
      *                      *-----------------------------------------*
      *                      * Codice CAB del fornitore                *
      *                      *-----------------------------------------*
           perform   acc-cab-ftf-000      thru acc-cab-ftf-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-220.
       acc-tes-reg-230.
      *                      *-----------------------------------------*
      *                      * Codice C/C del fornitore                *
      *                      *-----------------------------------------*
           perform   acc-ccc-ftf-000      thru acc-ccc-ftf-999        .
