      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-zcc-flg      .
           move      all   "."            to   w-let-arc-zcc-des      .
           go to     let-arc-zcc-600.
       let-arc-zcc-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-zcc-des      .
       let-arc-zcc-600.
           move      spaces               to   w-let-arc-zcc-tmi      .
           move      spaces               to   w-let-arc-zcc-snb      .
       let-arc-zcc-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [ztr]                         *
      *    *-----------------------------------------------------------*
           copy      "pgm/rda/prg/cpy/larcztr0.lts"                   .

      *    *===========================================================*
      *    * Routine di lettura archivio [zci]                         *
      *    *-----------------------------------------------------------*
           copy      "pgm/cge/prg/cpy/larczci0.lts"                   .

      *    *===========================================================*
      *    * Routine di lettura archivio [cli]                         *
      *    *-----------------------------------------------------------*
       let-arc-cli-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-cli-flg      .
      *              *-------------------------------------------------*
      *              * Test se codice cliente a zero                   *
      *              *-------------------------------------------------*
           if        w-let-arc-cli-cod    =    zero
                     go to let-arc-cli-500.
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLI    "         to   f-key                  .
           move      w-let-arc-cli-cod    to   rf-cli-cod-cli         .
           move      "pgm/cge/fls/ioc/obj/iofcli"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cli                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-cli-400.
       let-arc-cli-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-cli-rag-soc       to   w-let-arc-cli-rag      .
           move      rf-cli-via-cli       to   w-let-arc-cli-via      .
           move      rf-cli-loc-cli       to   w-let-arc-cli-loc      .
           move      rf-cli-cod-cge       to   w-let-arc-cli-cge      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-cli-999.
       let-arc-cli-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-cli-flg      .
           move      all   "."            to   w-let-arc-cli-rag      .
           go to     let-arc-cli-600.
       let-arc-cli-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-cli-rag      .
       let-arc-cli-600.
           move      spaces               to   w-let-arc-cli-via      .
           move      spaces               to   w-let-arc-cli-loc      .
           move      zero                 to   w-let-arc-cli-cge      .
       let-arc-cli-999.
           exit.

      *    *===========================================================*
      *    * Determinazione se presenti dipendenze per il fornitore    *
      *    * commerciale                                               *
      *    *-----------------------------------------------------------*
       det-snd-dcf-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di esito                   *
      *              *-------------------------------------------------*
           move      "N"                  to   w-det-snd-dcf-snx      .
      *              *-------------------------------------------------*
      *              * Normalizzazione codice dipendenza unica         *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-snd-dcf-dpz      .
      *              *-------------------------------------------------*
      *              * Normalizzazione contatore                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-snd-dcf-ctr      .
      *              *-------------------------------------------------*
      *              * Start su file [dcf]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CODFNT    "         to   f-key                  .
           move      w-det-snd-dcf-fnt    to   rf-dcf-cod-fnt         .
           move      spaces               to   rf-dcf-dpz-fnt         .
           move      "pgm/dcf/fls/ioc/obj/iofdcf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcf                 .
      *              *-------------------------------------------------*
      *              * Se Start errata : uscita con flag a 'no'        *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-snd-dcf-999.
       det-snd-dcf-100.
      *              *-------------------------------------------------*
      *              * Next su [dcf]                                   *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcf/fls/ioc/obj/iofdcf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcf                 .
      *              *-------------------------------------------------*
      *              * Se 'at end' : a test finale                     *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-snd-dcf-800.
      *              *-------------------------------------------------*
      *              * Max su [dcf], se non superato : a test finale   *
      *              *-------------------------------------------------*
           if        rf-dcf-cod-fnt       not  = w-det-snd-dcf-fnt
                     go to det-snd-dcf-800.
       det-snd-dcf-200.
      *              *-------------------------------------------------*
      *              * Test sul codice dipendenza                      *
      *              *-------------------------------------------------*
           if        rf-dcf-dpz-fnt       =    spaces
                     go to det-snd-dcf-100.
       det-snd-dcf-300.
      *              *-------------------------------------------------*
      *              * Incremento contatore                            *
      *              *-------------------------------------------------*
           add       1                    to   w-det-snd-dcf-ctr      .
       det-snd-dcf-300.
      *              *-------------------------------------------------*
      *              * Bufferizzazione del primo codice dipendenza     *
      *              *-------------------------------------------------*
           if        w-det-snd-dcf-ctr    >    1
                     go to det-snd-dcf-500.
           move      rf-dcf-dpz-fnt       to   w-det-snd-dcf-dpz      .
       det-snd-dcf-500.
      *              *-------------------------------------------------*
      *              * Riciclo a record [dcf] successivo               *
      *              *-------------------------------------------------*
           go to     det-snd-dcf-100.
       det-snd-dcf-800.
      *              *-------------------------------------------------*
      *              * Determinazione finale                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se durante la ricerca e' stato trovato un   *
      *                  * numero di dipendenze superiore a zero si    *
      *                  * esce con il flag di presenza a 'S'          *
      *                  *---------------------------------------------*
           if        w-det-snd-dcf-ctr    >    zero
                     go to det-snd-dcf-900
           else      go to det-snd-dcf-999.
       det-snd-dcf-900.
      *              *-------------------------------------------------*
      *              * Uscita per dipendenze trovate                   *
      *              *-------------------------------------------------*
           move      "S"                  to   w-det-snd-dcf-snx      .
       det-snd-dcf-999.
           exit.

      *    *===========================================================*
      *    * Determinazione valori testata indotti da record [dcf]     *
      *    * principale                                                *
      *    *-----------------------------------------------------------*
       det-vlt-dcf-000.
      *              *-------------------------------------------------*
      *              * Valori da estrarre solo in tipo funzionamento : *
      *              * 'inserimento'                                   *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to det-vlt-dcf-100.
      *                  *---------------------------------------------*
      *                  * Valori                                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice e descrizione contropartita agli *
      *                      * acquisti                                *
      *                      *-----------------------------------------*
           move      rf-dcf-ctp-acq       to   w-tes-ctp-acq (1)      .
           move      w-tes-ctp-acq (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-tes-ctp-acq-des (1)  .
      *                      *-----------------------------------------*
      *                      * Inoltro pagamenti                       *
      *                      *-----------------------------------------*
           move      rf-dcf-inl-pgt       to   w-tes-inl-pgf (1)      .
      *                      *-----------------------------------------*
      *                      * Codice e descrizione forma di pagamento *
      *                      *-----------------------------------------*
           move      rf-dcf-cod-fop       to   w-tes-cod-fop (1)      .
           move      w-tes-cod-fop (1)    to   w-let-arc-yfp-cod      .
           perform   let-arc-yfp-000      thru let-arc-yfp-999        .
           move      w-let-arc-yfp-des    to   w-tes-cod-fop-des (1)  .
      *                  *---------------------------------------------*
      *                  * Codice nostra banca di appoggio per il do-  *
      *                  * cumento                                     *
      *                  *---------------------------------------------*
           move      rf-dcf-nos-ban       to   w-tes-nsb-ftf (1)      .
       det-vlt-dcf-100.
      *              *-------------------------------------------------*
      *              * Valori da estrarre con qualsiasi tipo funziona- *
      *              * mento                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Codice nostra banca di appoggio associato   *
      *                  * al fornitore                                *
      *                  *---------------------------------------------*
           move      rf-dcf-nos-ban       to   w-tes-nsb-aaf (1)      .
      *                  *---------------------------------------------*
      *                  * Codice e descrizione nostra banca di appog- *
      *                  * gio per il documento                        *
      *                  *---------------------------------------------*
           move      02                   to   w-let-arc-cbp-tip      .
           move      w-tes-nsb-ftf (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
           move      w-let-arc-cbp-des    to   w-tes-nsb-ftf-des (1)  .
      *                  *---------------------------------------------*
      *                  * Codice e descrizione ABI del fornitore      *
      *                  *---------------------------------------------*
           move      rf-dcf-cod-abi       to   w-tes-abi-aaf (1)      .
           move      w-tes-abi-aaf (1)    to   w-let-arc-axi-cod      .
           perform   let-arc-axi-000      thru let-arc-axi-999        .
           move      w-let-arc-axi-den    to   w-tes-abi-aaf-den (1)  .
      *                  *---------------------------------------------*
      *                  * Codice e descrizione CAB del fornitore      *
      *                  *---------------------------------------------*
           move      rf-dcf-cod-cab       to   w-tes-cab-aaf (1)      .
           move      w-tes-abi-aaf (1)    to   w-let-arc-axs-abi      .
           move      w-tes-cab-aaf (1)    to   w-let-arc-axs-cab      .
           perform   let-arc-axs-000      thru let-arc-axs-999        .
           move      w-let-arc-axs-den    to   w-tes-cab-aaf-den (1)  .
      *                  *---------------------------------------------*
      *                  * C/c appoggio del fornitore                  *
      *                  *---------------------------------------------*
           move      rf-dcf-ccc-app       to   w-tes-ccc-aaf (1)      .
      *                  *---------------------------------------------*
      *                  * C/c postale del fornitore                   *
      *                  *---------------------------------------------*
           move      rf-dcf-ccp-app       to   w-tes-ccp-aaf (1)      .
      *                  *---------------------------------------------*
      *                  * Codici CIN                                  *
      *                  *---------------------------------------------*
           move      rf-dcf-cin-ita       to   w-tes-cod-fnt-cin (1)  .
           move      rf-dcf-cin-eur       to   w-tes-cod-fnt-ceu (1)  .
       det-vlt-dcf-999.
           exit.

      *    *===========================================================*
      *    * Determinazione valori testata indotti da record [dcf]     *
      *    * relativo alla dipendenza del fornitore                    *
      *    *-----------------------------------------------------------*
       det-vlt-dcd-000.
      *              *-------------------------------------------------*
      *              * Se codice dipendenza a spazi : uscita           *
      *              *-------------------------------------------------*
           if        w-tes-dpz-fnt (1)    =    spaces
                     go to det-vlt-dcd-999.
      *              *-------------------------------------------------*
      *              * Codice e descrizione ABI dipendenza             *
      *              *-------------------------------------------------*
           move      rf-dcf-cod-abi       to   w-tes-abi-adf (1)      .
           move      w-tes-abi-adf (1)    to   w-let-arc-axi-cod      .
           perform   let-arc-axi-000      thru let-arc-axi-999        .
           move      w-let-arc-axi-den    to   w-tes-abi-adf-den (1)  .
      *              *-------------------------------------------------*
      *              * Codice e descrizione CAB dipendenza             *
      *              *-------------------------------------------------*
           move      rf-dcf-cod-cab       to   w-tes-cab-adf (1)      .
           move      w-tes-abi-adf (1)    to   w-let-arc-axs-abi      .
           move      w-tes-cab-adf (1)    to   w-let-arc-axs-cab      .
           perform   let-arc-axs-000      thru let-arc-axs-999        .
           move      w-let-arc-axs-den    to   w-tes-cab-adf-den (1)  .
      *              *-------------------------------------------------*
      *              * C/c bancario della dipendenza                   *
      *              *-------------------------------------------------*
           move      rf-dcf-ccc-app       to   w-tes-ccc-adf (1)      .
      *              *-------------------------------------------------*
      *              * C/c postale della dipendenza                    *
      *              *-------------------------------------------------*
           move      rf-dcf-ccp-app       to   w-tes-ccp-adf (1)      .
       det-vlt-dcd-999.
           exit.

      *    *===========================================================*
      *    * Determinazione valori testata indotti da inoltro pagamen- *
      *    * to                                                        *
      *    *-----------------------------------------------------------*
       det-vlt-ipg-000.
      *              *-------------------------------------------------*
      *              * Se dipendenza non esistente                     *
      *              *-------------------------------------------------*
           if        w-tes-dpz-fnt (1)    not  = spaces
                     go to det-vlt-ipg-500.
       det-vlt-ipg-100.
      *                  *---------------------------------------------*
      *                  * Codice ABI                                  *
      *                  *---------------------------------------------*
           move      w-tes-abi-aaf (1)    to   w-tes-abi-ftf (1)      .
           move      w-tes-abi-aaf-den (1)
                                          to   w-tes-abi-ftf-den (1)  .
      *                  *---------------------------------------------*
      *                  * Codice CAB                                  *
      *                  *---------------------------------------------*
           move      w-tes-cab-aaf (1)    to   w-tes-cab-ftf (1)      .
           move      w-tes-cab-aaf-den (1)
                                          to   w-tes-cab-ftf-den (1)  .
      *                  *---------------------------------------------*
      *                  * C/c bancario                                *
      *                  *---------------------------------------------*
           move      w-tes-ccc-aaf (1)    to   w-tes-ccc-ftf (1)      .
      *                  *---------------------------------------------*
      *                  * C/c postale                                 *
      *                  *---------------------------------------------*
           move      w-tes-ccp-aaf (1)    to   w-tes-ccp-ftf (1)      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-vlt-ipg-999.
       det-vlt-ipg-500.
      *              *-------------------------------------------------*
      *              * Se dipendenza esistente                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se inoltro pagamento alla sede o alla sede  *
      *                  * legale: valori derivati da [dcf] principale *
      *                  *---------------------------------------------*
           if        w-tes-inl-pgf (1)    =    01 or
                     w-tes-inl-pgf (1)    =    02
                     go to det-vlt-ipg-100.
      *                  *---------------------------------------------*
      *                  * Codice ABI                                  *
      *                  *---------------------------------------------*
           move      w-tes-abi-adf (1)    to   w-tes-abi-ftf (1)      .
           move      w-tes-abi-adf-den (1)
                                          to   w-tes-abi-ftf-den (1)  .
      *                  *---------------------------------------------*
      *                  * Codice CAB                                  *
      *                  *---------------------------------------------*
           move      w-tes-cab-adf (1)    to   w-tes-cab-ftf (1)      .
           move      w-tes-cab-adf-den (1)
                                          to   w-tes-cab-ftf-den (1)  .
      *                  *---------------------------------------------*
      *                  * C/c bancario                                *
      *                  *---------------------------------------------*
           move      w-tes-ccc-adf (1)    to   w-tes-ccc-ftf (1)      .
      *                  *---------------------------------------------*
      *                  * C/c postale                                 *
      *                  *---------------------------------------------*
           move      w-tes-ccp-adf (1)    to   w-tes-ccp-ftf (1)      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-vlt-ipg-999.
       det-vlt-ipg-999.
           exit.

      *    *===========================================================*
      *    * Determinazione valori testata dipendenti dalla forma di   *
      *    * pagamento                                                 *
      *    *-----------------------------------------------------------*
       det-vlt-yfp-000.
      *              *-------------------------------------------------*
      *              * Valori da estrarre solo in tipo funzionamento : *
      *              * 'inserimento'                                   *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to det-vlt-yfp-050.
       det-vlt-yfp-050.
      *              *-------------------------------------------------*
      *              * Valori da estrarre con qualsiasi tipo funziona- *
      *              * mento                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione valori testata di appoggio  *
      *                  * alle impostazioni dei campi relativi ai pa- *
      *                  * pagamenti                                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-tes-app-pgf (1)      .
           move      spaces               to   w-tes-snx-spm (1)      .
           move      spaces               to   w-tes-snx-qaf (1)      .
           move      spaces               to   w-tes-snx-act (1)      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione valori testata associati al-*
      *                  * la forma pagamento                          *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-vlt-yfp-ctr      .
       det-vlt-yfp-060.
           add       1                    to   w-det-vlt-yfp-ctr      .
           if        w-det-vlt-yfp-ctr    >    3
                     go to det-vlt-yfp-080.
           move      zero                 to   w-tes-cod-pag
                                              (1, w-det-vlt-yfp-ctr)  .
           move      zero                 to   w-tes-tip-amm
                                              (1, w-det-vlt-yfp-ctr)  .
           move      zero                 to   w-tes-per-toi
                                              (1, w-det-vlt-yfp-ctr)  .
           move      zero                 to   w-tes-dim-act
                                              (1, w-det-vlt-yfp-ctr)  .
           move      zero                 to   w-tes-tip-pag
                                              (1, w-det-vlt-yfp-ctr)  .
           move      zero                 to   w-tes-num-sca
                                              (1, w-det-vlt-yfp-ctr)  .
           move      zero                 to   w-tes-dec-prs
                                              (1, w-det-vlt-yfp-ctr)  .
           move      zero                 to   w-tes-dap-mes
                                              (1, w-det-vlt-yfp-ctr)  .
           move      zero                 to   w-tes-dap-gio
                                              (1, w-det-vlt-yfp-ctr)  .
           move      zero                 to   w-tes-ggg-int
                                              (1, w-det-vlt-yfp-ctr)  .
           move      zero                 to   w-tes-tip-scm
                                              (1, w-det-vlt-yfp-ctr)  .
           move      zero                 to   w-tes-gio-scm
                                              (1, w-det-vlt-yfp-ctr)  .
           go to     det-vlt-yfp-060.
       det-vlt-yfp-080.
      *                  *---------------------------------------------*
      *                  * Se forma di pagamento a zero : uscita       *
      *                  *---------------------------------------------*
           if        w-tes-cod-fop (1)    =    zero
                     go to det-vlt-yfp-999.
      *                  *---------------------------------------------*
      *                  * Ciclo per tre codici pagamento possibili    *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-vlt-yfp-ctr      .
       det-vlt-yfp-100.
           add       1                    to   w-det-vlt-yfp-ctr      .
           if        w-det-vlt-yfp-ctr    >    3
                     go to det-vlt-yfp-999.
           if        rf-yfp-cod-pag
                    (w-det-vlt-yfp-ctr)   =    zero
                     go to det-vlt-yfp-100.
      *                      *-----------------------------------------*
      *                      * Campi testata derivati da record [yfp]  *
      *                      *-----------------------------------------*
           move      rf-yfp-cod-pag
                    (w-det-vlt-yfp-ctr)   to   w-tes-cod-pag
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-yfp-tip-amm
                    (w-det-vlt-yfp-ctr)   to   w-tes-tip-amm
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-yfp-per-toi
                    (w-det-vlt-yfp-ctr)   to   w-tes-per-toi
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-yfp-dim-act
                    (w-det-vlt-yfp-ctr)   to   w-tes-dim-act
                                              (1, w-det-vlt-yfp-ctr)  .
      *                      *-----------------------------------------*
      *                      * Campi testata derivati da record [zpg]  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione record [zpg]        *
      *                          *-------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofzpg"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zpg                 .
      *                          *-------------------------------------*
      *                          * Lettura record [zpg]                *
      *                          *-------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODPAG"             to   f-key                  .
           move      w-tes-cod-pag
                    (1, w-det-vlt-yfp-ctr)
                                          to   rf-zpg-cod-pag         .
           move      "pgm/gep/fls/ioc/obj/iofzpg"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zpg                 .
           move      rf-zpg-tip-pag       to   w-tes-tip-pag
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-zpg-num-sca       to   w-tes-num-sca
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-zpg-dec-prs       to   w-tes-dec-prs
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-zpg-dap-mes       to   w-tes-dap-mes
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-zpg-dap-gio       to   w-tes-dap-gio
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-zpg-ggg-int       to   w-tes-ggg-int
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-zpg-tip-scm       to   w-tes-tip-scm
                                              (1, w-det-vlt-yfp-ctr)  .
           move      rf-zpg-gio-scm       to   w-tes-gio-scm
                                              (1, w-det-vlt-yfp-ctr)  .
       det-vlt-yfp-200.
      *                  *---------------------------------------------*
      *                  * Valori testata di appoggio alle successive  *
      *                  * impostazioni                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo appoggio per pagamento             *
      *                      *-----------------------------------------*
           if        w-tes-app-pgf (1)    not  = zero
                     go to det-vlt-yfp-220.
           if        rf-zpg-tip-pag       =    02 or
                     rf-zpg-tip-pag       =    03 or
                     rf-zpg-tip-pag       =    04 or
                     rf-zpg-tip-pag       =    05 or
                     rf-zpg-tip-pag       =    06 or
                     rf-zpg-tip-pag       =    09 or
                     rf-zpg-tip-pag       =    10 or
                     rf-zpg-tip-pag       =    11
                     move  01             to   w-tes-app-pgf (1)
           else if  (rf-zpg-tip-pag       =    07    ) and
                    (w-tes-tip-ope        =    0001 or
                     w-tes-tip-ope        =    0002 or
                     w-tes-tip-ope        =    0003 or
                     w-tes-tip-ope        =    0007 or
                     w-tes-tip-ope        =    0008 or
                     w-tes-tip-ope        =    0009  )
                     move  02             to   w-tes-app-pgf (1)
           else if   rf-zpg-tip-pag       =    08
                     move  03             to   w-tes-app-pgf (1)
           else if  (rf-zpg-tip-pag       =    07    ) and
                    (w-tes-tip-ope        =    0011 or
                     w-tes-tip-ope        =    0012 or
                     w-tes-tip-ope        =    0022 or
                     w-tes-tip-ope        =    0033 or
                     w-tes-tip-ope        =    0111 or
                     w-tes-tip-ope        =    0112 or
                     w-tes-tip-ope        =    0222 or
                     w-tes-tip-ope        =    0333 or
                     w-tes-tip-ope        =    0444  )
                     move  04             to   w-tes-app-pgf (1)      .
       det-vlt-yfp-220.
      *                      *-----------------------------------------*
      *                      * Si/no data scadenza pagamento manuale   *
      *                      *-----------------------------------------*
           if        rf-zpg-dec-prs       =    01
                     move  "S"            to   w-tes-snx-spm (1)      .
      *                      *-----------------------------------------*
      *                      * Si/no impostazione quota a forfait      *
      *                      *-----------------------------------------*
           if        rf-yfp-tip-amm
                    (w-det-vlt-yfp-ctr)   =    06 or
                     rf-yfp-tip-amm
                    (w-det-vlt-yfp-ctr)   =    07 or
                     rf-yfp-tip-amm
                    (w-det-vlt-yfp-ctr)   =    08 or
                     rf-yfp-tip-amm
                    (w-det-vlt-yfp-ctr)   =    09
                     move  "S"            to   w-tes-snx-qaf (1)      .
      *                      *-----------------------------------------*
      *                      * Si/no impostazione acconto              *
      *                      *-----------------------------------------*
           if        rf-yfp-dim-act
                    (w-det-vlt-yfp-ctr)   =    02
                     move  "S"            to   w-tes-snx-act (1)      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-vlt-yfp-100.
       det-vlt-yfp-999.
           exit.

      *    *===========================================================*
      *    * Determinazione tipo operazione, causale e sottoconto con- *
      *    * tabile per registrazione scadenza fornitore               *
      *    *-----------------------------------------------------------*
       det-tcs-rsf-000.
      *              *-------------------------------------------------*
      *              * Determinazione indice su tabella tipi operazio- *
      *              * ne, relativo al tipo operazione di registrazio- *
      *              * ne per la scadenza in esame                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione codice tipo operazione di    *
      *                  * registrazione                               *
      *                  *---------------------------------------------*
           if        w-rg2-tip-scf (1)    =    01
                     move  1101           to   w-det-tcs-rsf-top
           else if   w-rg2-tip-scf (1)    =    02
                     move  1102           to   w-det-tcs-rsf-top
           else if   w-rg2-tip-scf (1)    =    03
                     move  1103           to   w-det-tcs-rsf-top
           else if   w-rg2-tip-scf (1)    =    04
                     move  1104           to   w-det-tcs-rsf-top
           else if   w-rg2-tip-scf (1)    =    05
                     move  1105           to   w-det-tcs-rsf-top
           else if   w-rg2-tip-scf (1)    =    06
                     move  1106           to   w-det-tcs-rsf-top
           else if   w-rg2-tip-scf (1)    =    07
                     if       w-rg2-tvl-scf (1)
                                          =    01
                              move  1107  to   w-det-tcs-rsf-top
                     else if  w-rg2-tvl-scf (1)
                                          =    02
                              move  1127  to   w-det-tcs-rsf-top
                     else     move  zero  to   w-det-tcs-rsf-top
           else if   w-rg2-tip-scf (1)    =    08
                     move  1108           to   w-det-tcs-rsf-top
           else if   w-rg2-tip-scf (1)    =    09
                     move  1109           to   w-det-tcs-rsf-top
           else if   w-rg2-tip-scf (1)    =    10
                     move  1110           to   w-det-tcs-rsf-top
           else if   w-rg2-tip-scf (1)    =    11
                     move  1111           to   w-det-tcs-rsf-top
           else      move  zero           to   w-det-tcs-rsf-top      .
      *                  *---------------------------------------------*
      *                  * Ricerca del tipo operazione cosi' determi-  *
      *                  * nato in tabella tipi operazione.            *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-tcs-rsf-inx      .
       det-tcs-rsf-100.
           add       1                    to   w-det-tcs-rsf-inx      .
           if        w-det-tcs-rsf-inx    >    w-top-ele-num
                     go to det-tcs-rsf-999.
           if        w-top-cod-top
                    (w-det-tcs-rsf-inx)   =    w-det-tcs-rsf-top
                     go to det-tcs-rsf-120.
           go to     det-tcs-rsf-100.
       det-tcs-rsf-120.
      *              *-------------------------------------------------*
      *              * Bufferizzazione codice tipo operazione di regi- *
      *              * strazione scadenza fornitore                    *
      *              *-------------------------------------------------*
           move      w-det-tcs-rsf-top    to   w-rg2-top-rsf (1)      .
      *              *-------------------------------------------------*
      *              * Bufferizzazione codice causale contabile per    *
      *              * registrazione scadenza fornitore                *
      *              *-------------------------------------------------*
           move      w-top-cau-cge
                    (w-det-tcs-rsf-inx)   to   w-rg2-cau-rsf (1)      .
      *              *-------------------------------------------------*
      *              * Bufferizzazione codice sottoconto contabile per *
      *              * registrazione scadenza fornitore                *
      *              *-------------------------------------------------*
           move      w-top-stc-cge
                    (w-det-tcs-rsf-inx)   to   w-rg2-stc-rsf (1)      .
       det-tcs-rsf-999.
           exit.

      *    *===========================================================*
      *    * Determinazione saldo righe movimento contabile relative   *
      *    * al fornitore                                              *
      *    *-----------------------------------------------------------*
       det-sdo-rmf-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione iniziale                        *
      *              *-------------------------------------------------*
           move      zero                 to   w-tes-sdo-rmf (1)      .
      *              *-------------------------------------------------*
      *              * Salvataggio catena movimenti                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio area w-rig                      *
      *                  *---------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *                  *---------------------------------------------*
      *                  * Salvataggio area catena                     *
      *                  *---------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione righe movimento contabile    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su righe corpo in catena movimenti    *
      *                  *---------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se start non valida : a fine ciclo          *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to det-sdo-rmf-900.
       det-sdo-rmf-100.
      *                  *---------------------------------------------*
      *                  * Next su righe corpo in catena movimenti     *
      *                  *---------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se at end : a fine ciclo                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to det-sdo-rmf-900.
      *                  *---------------------------------------------*
      *                  * Se buffer catena movimenti a spaces : rici- *
      *                  * clo                                         *
      *                  *---------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to det-sdo-rmf-100.
      *                  *---------------------------------------------*
      *                  * Movimento da buffer catena movimenti a work *
      *                  * per riga w-rig                              *
      *                  *---------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *                  *---------------------------------------------*
      *                  * Test su tipo e codice conto                 *
      *                  *---------------------------------------------*
           if        w-rig-tip-con (1)    not  = "F"            or
                     w-rig-cod-con (1)    not  = w-tes-cod-fnt (1)
                     go to det-sdo-rmf-100.
      *                  *---------------------------------------------*
      *                  * Aggiornamento saldo fornitore               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo docu-   *
      *                      * mento                                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        =    0003 or
                     w-tes-tip-ope        =    0033 or
                     w-tes-tip-ope        =    0333
                     go to det-sdo-rmf-120
           else      go to det-sdo-rmf-140.
       det-sdo-rmf-120.
      *                      *-----------------------------------------*
      *                      * Se nota di accredito                    *
      *                      *-----------------------------------------*
           if        w-rig-dar-ave (1)    =    "A"
                     subtract w-rig-imp-mov (1)
                                          from w-tes-sdo-rmf (1)
           else      add      w-rig-imp-mov (1)
                                          to   w-tes-sdo-rmf (1)      .
           go to     det-sdo-rmf-200.
       det-sdo-rmf-140.
      *                      *-----------------------------------------*
      *                      * Se fattura, nota di addebito o bolla    *
      *                      * doganale                                *
      *                      *-----------------------------------------*
           if        w-rig-dar-ave (1)    =    "D"
                     subtract w-rig-imp-mov (1)
                                          from w-tes-sdo-rmf (1)
           else      add      w-rig-imp-mov (1)
                                          to   w-tes-sdo-rmf (1)      .
           go to     det-sdo-rmf-200.
       det-sdo-rmf-200.
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura catena                   *
      *                  *---------------------------------------------*
           go to     det-sdo-rmf-100.
       det-sdo-rmf-900.
      *              *-------------------------------------------------*
      *              * Ripristino catena movimenti                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino area w-rig                       *
      *                  *---------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *                  *---------------------------------------------*
      *                  * Ripristino area catena                      *
      *                  *---------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       det-sdo-rmf-999.
           exit.

      *    *===========================================================*
      *    * Determinazione primo protocollo di CGE e quanti di essi   *
      *    * sono necessari                                            *
      *    *-----------------------------------------------------------*
       det-prt-cge-000.
      *              *-------------------------------------------------*
      *              * Se si e' in modifica di una registrazione che   *
      *              * non aveva generato nessun movimento contabile,  *
      *              * non si generera' il movimento contabile e quin- *
      *              * di non si deve prelevare alcun numero protocol- *
      *              * lo                                              *
      *              *-------------------------------------------------*
           if       (w-cnt-mfu-tip-fun    =    "M"   ) and
                    (w-tes-drg-cge (1)    =    zero or
                     w-tes-npr-cge (1)    =    zero  )
                     go to det-prt-cge-999.
      *              *-------------------------------------------------*
      *              * Test se registrazione contabile da eseguire     *
      *              *-------------------------------------------------*
           perform   cge-scf-ftf-snx-000  thru cge-scf-ftf-snx-999    .
      *              *-------------------------------------------------*
      *              * Se registrazione contabile da non eseguire : u- *
      *              * scita                                           *
      *              *-------------------------------------------------*
           if        w-cge-scf-ftf-snx    =    "N"
                     go to det-prt-cge-999.
      *              *-------------------------------------------------*
      *              * Inizializzazione numero protocollo necessari    *
      *              *-------------------------------------------------*
           move      1                    to   w-det-prt-cge-npn      .
      *              *-------------------------------------------------*
      *              * Determinazione numeri protocollo necessari      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su righe corpo 2 in catena movimenti  *
      *                  *---------------------------------------------*
           move      "ST"                 to   w-cat-rg2-ope          .
           move      1                    to   w-cat-rg2-num          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
      *                  *---------------------------------------------*
      *                  * Se start non valida : a fine ciclo          *
      *                  *---------------------------------------------*
           if        w-cat-rg2-exs        not  = spaces
                     go to det-prt-cge-200.
       det-prt-cge-100.
      *                  *---------------------------------------------*
      *                  * Next su righe corpo in catena movimenti     *
      *                  *---------------------------------------------*
           move      "RN"                 to   w-cat-rg2-ope          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
      *                  *---------------------------------------------*
      *                  * Se at end : a fine ciclo                    *
      *                  *---------------------------------------------*
           if        w-cat-rg2-exs        not  = spaces
                     go to det-prt-cge-200.
      *                  *---------------------------------------------*
      *                  * Movimento da buffer catena movimenti a work *
      *                  * per riga w-rg2                              *
      *                  *---------------------------------------------*
           move      w-cat-rg2-buf        to   w-rg2                  .
      *                  *---------------------------------------------*
      *                  * Test se esistono causale di contabilita' e  *
      *                  * sottoconto per registrazione scadenza       *
      *                  *---------------------------------------------*
           if        w-rg2-cau-rsf (1)    =    zero or
                     w-rg2-stc-rsf (1)    =    zero
                     go to det-prt-cge-100.
      *                  *---------------------------------------------*
      *                  * Incremento numero protocolli necessari      *
      *                  *---------------------------------------------*
           add       1                    to   w-det-prt-cge-npn      .
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura catena                   *
      *                  *---------------------------------------------*
           go to     det-prt-cge-100.
       det-prt-cge-200.
      *              *-------------------------------------------------*
      *              * Prelievo numeri protocollo                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record                      *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtcge"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-cge             .
      *                  *---------------------------------------------*
      *                  * Lettura tabella numerazioni [prtcge]        *
      *                  *---------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      w-tes-drg-cge (1)    to   s-dat                  .
           move      s-saa                to   rn-prt-cge-saa-dtr     .
           move      "pgm/cge/num/ioc/obj/inprtcge"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-cge             .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to det-prt-cge-300.
      *                  *---------------------------------------------*
      *                  * Record non trovato                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione dati                    *
      *                      *-----------------------------------------*
           move      zero                 to   rn-prt-cge-num-prt     .
      *                      *-----------------------------------------*
      *                      * Scrittura record normalizzato           *
      *                      *-----------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtcge"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-cge             .
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtcge"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-cge             .
      *                      *-----------------------------------------*
      *                      * Ripetizione dell'intera operazione      *
      *                      *-----------------------------------------*
           go to     det-prt-cge-200.
       det-prt-cge-300.
      *                  *---------------------------------------------*
      *                  * Record trovato                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Movimento da record a work              *
      *                      *-----------------------------------------*
           move      rn-prt-cge-num-prt   to   w-det-prt-cge-wnp      .
       det-prt-cge-310.
      *                      *-----------------------------------------*
      *                      * Salvataggio numero protocollo           *
      *                      *-----------------------------------------*
           move      w-det-prt-cge-wnp    to   w-det-prt-cge-snp      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento numero protocollo         *
      *                      *-----------------------------------------*
           add       w-det-prt-cge-npn    to   w-det-prt-cge-wnp      .
           if        w-det-prt-cge-wnp    >    9999999
                     move  zero           to   w-det-prt-cge-wnp
                     go to det-prt-cge-310.
      *                      *-----------------------------------------*
      *                      * Movimento da work a record              *
      *                      *-----------------------------------------*
           move      w-det-prt-cge-wnp    to   rn-prt-cge-num-prt     .
      *                      *-----------------------------------------*
      *                      * Update record                           *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtcge"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-cge             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-prt-cge-200.
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtcge"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-cge             .
      *              *-------------------------------------------------*
      *              * Determinazione primo protocollo da utilizzare   *
      *              *-------------------------------------------------*
           move      w-det-prt-cge-snp    to   w-tes-npr-cge (1)      .
           add       1                    to   w-tes-npr-cge (1)      .
      *              *-------------------------------------------------*
      *              * Determinazione numeri di protocollo da utiliz-  *
      *              * zare                                            *
      *              *-------------------------------------------------*
           move      w-det-prt-cge-npn    to   w-tes-nrg-cge (1)      .
       det-prt-cge-999.
           exit.

      *    *===========================================================*
      *    * Determinazione primo numero scadenza e quanti di essi     *
      *    * sono necessari                                            *
      *    *-----------------------------------------------------------*
       det-num-rsf-000.
      *              *-------------------------------------------------*
      *              * Determinazione numero scadenze necessari        *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-num-rsf-npn      .
           move      zero                 to   w-det-num-rsf-ctr      .
      *                  *---------------------------------------------*
      *                  * Start su righe corpo 2 in catena movimenti  *
      *                  *---------------------------------------------*
           move      "ST"                 to   w-cat-rg2-ope          .
           move      1                    to   w-cat-rg2-num          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
      *                  *---------------------------------------------*
      *                  * Se start non valida : a fine ciclo          *
      *                  *---------------------------------------------*
           if        w-cat-rg2-exs        not  = spaces
                     go to det-num-rsf-100.
       det-num-rsf-050.
      *                  *---------------------------------------------*
      *                  * Next su righe corpo in catena movimenti     *
      *                  *---------------------------------------------*
           move      "RN"                 to   w-cat-rg2-ope          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
      *                  *---------------------------------------------*
      *                  * Se at end : a fine ciclo                    *
      *                  *---------------------------------------------*
           if        w-cat-rg2-exs        not  = spaces
                     go to det-num-rsf-100.
      *                  *---------------------------------------------*
      *                  * Se buffer catena movimenti a spaces : rici- *
      *                  * clo                                         *
      *                  *---------------------------------------------*
           if        w-cat-rg2-buf        =    spaces
                     go to det-num-rsf-050.
      *                  *---------------------------------------------*
      *                  * Movimento da buffer catena movimenti a work *
      *                  * per riga w-rg2                              *
      *                  *---------------------------------------------*
           move      w-cat-rg2-buf        to   w-rg2                  .
      *                  *---------------------------------------------*
      *                  * Test se esiste il tipo operazione per regi- *
      *                  * strazione scadenza fornitore                *
      *                  *---------------------------------------------*
           if        w-rg2-top-rsf (1)    =    zero
                     go to det-num-rsf-050.
      *                  *---------------------------------------------*
      *                  * Incremento numero protocolli necessari      *
      *                  *---------------------------------------------*
           add       1                    to   w-det-num-rsf-npn      .
      *                  *---------------------------------------------*
      *                  * Riciclo su lettura catena                   *
      *                  *---------------------------------------------*
           go to     det-num-rsf-050.
       det-num-rsf-100.
      *              *-------------------------------------------------*
      *              * Prelievo numeri protocollo                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record                      *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfsnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfs-num             .
      *                  *---------------------------------------------*
      *                  * Lettura tabella numerazioni [numsdb]        *
      *                  *---------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      w-tes-dat-reg        to   s-dat                  .
           move      s-saa                to   rn-sfs-num-scl-ann     .
           move      "pgm/scf/num/ioc/obj/insfsnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfs-num             .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to det-num-rsf-200.
      *                  *---------------------------------------------*
      *                  * Record non trovato                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione dati                    *
      *                      *-----------------------------------------*
           move      zero                 to   rn-sfs-num-num-scf     .
      *                      *-----------------------------------------*
      *                      * Scrittura record normalizzato           *
      *                      *-----------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfsnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfs-num             .
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfsnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfs-num             .
      *                      *-----------------------------------------*
      *                      * Ripetizione dell'intera operazione      *
      *                      *-----------------------------------------*
           go to     det-num-rsf-100.
       det-num-rsf-200.
      *                  *---------------------------------------------*
      *                  * Record trovato                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Movimento da record a work              *
      *                      *-----------------------------------------*
           move      rn-sfs-num-num-scf   to   w-det-num-rsf-wns      .
           move      w-det-num-rsf-wnp    to   w-det-num-rsf-wap      .
       det-num-rsf-210.
      *                      *-----------------------------------------*
      *                      * Salvataggio numero scadenza             *
      *                      *-----------------------------------------*
           move      w-det-num-rsf-wns    to   w-det-num-rsf-sns      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento numero progressivo        *
      *                      *-----------------------------------------*
           add       w-det-num-rsf-npn    to   w-det-num-rsf-wap      .
           if        w-det-num-rsf-wap    >    99999999
                     move  zero           to   w-det-num-rsf-wap
                     go to det-num-rsf-210.
      *                      *-----------------------------------------*
      *                      * Movimento da work a record              *
      *                      *-----------------------------------------*
           move      w-det-num-rsf-wap    to   w-det-num-rsf-wnp      .
           move      w-tes-dat-reg        to   s-dat                  .
           move      s-saa                to   w-det-num-rsf-wsa      .
           move      w-det-num-rsf-wns    to   rn-sfs-num-num-scf     .
      *                      *-----------------------------------------*
      *                      * Update record                           *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfsnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfs-num             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-num-rsf-100.
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfsnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfs-num             .
      *              *-------------------------------------------------*
      *              * Determinazione primo numero scadenza da utiliz- *
      *              * zare                                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Numero scadenza salvato in work di comodo   *
      *                  *---------------------------------------------*
           move      w-det-num-rsf-sns    to   w-det-num-rsf-wns      .
      *                  *---------------------------------------------*
      *                  * Forzatura di secolo/anno                    *
      *                  *---------------------------------------------*
           move      w-tes-dat-reg        to   s-dat                  .
           move      s-saa                to   w-det-num-rsf-wsa      .
      *                  *---------------------------------------------*
      *                  * Da work di comodo a work di testata         *
      *                  *---------------------------------------------*
           move      w-det-num-rsf-wns    to   w-tes-npr-scf (1)      .
           add       1                    to   w-tes-npr-scf (1)      .
      *              *-------------------------------------------------*
      *              * Determinazione numeri scadenza da utilizzare    *
      *              *-------------------------------------------------*
           move      w-det-num-rsf-npn    to   w-tes-nrg-scf (1)      .
       det-num-rsf-999.
           exit.

      *    *===========================================================*
      *    * Determinazione del valore mediante applicazione di una %  *
      *    * di ritenuta                                               *
      *    *-----------------------------------------------------------*
       det-val-rit-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni iniziali                        *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-val-rit-ris      .
           move      zero                 to   w-det-val-rit-s11      .
           move      zero                 to   w-det-val-rit-s13      .
      *              *-------------------------------------------------*
      *              * Se valore a zero : uscita                       *
      *              *-------------------------------------------------*
           if        w-det-val-rit-ibl    =    zero
                     go to det-val-rit-999.
      *              *-------------------------------------------------*
      *              * Se % a zero : uscita                            *
      *              *-------------------------------------------------*
           if        w-det-val-rit-per    =    zero
                     go to det-val-rit-999.
      *              *-------------------------------------------------*
      *              * Calcolo della % imponibile                      *
      *              *-------------------------------------------------*
           if        w-det-val-rit-pim    =    100  or
                     w-det-val-rit-pim    =    zero
                     go to det-val-rit-200.
       det-val-rit-100.
      *              *-------------------------------------------------*
      *              * Calcolo imponibile                              *
      *              *-------------------------------------------------*
           move      w-det-val-rit-ibl    to   w-det-val-rit-s13      .
           multiply  w-det-val-rit-pim    by   w-det-val-rit-s13      .
           divide    100                  into w-det-val-rit-s13
                                        giving w-det-val-rit-s11
                                                         rounded      .
           move      w-det-val-rit-s11    to   w-det-val-rit-ibl      .
       det-val-rit-200.
      *              *-------------------------------------------------*
      *              * Calcolo del valore effettivo                    *
      *              *-------------------------------------------------*
           move      w-det-val-rit-ibl    to   w-det-val-rit-s13      .
           multiply  w-det-val-rit-per    by   w-det-val-rit-s13      .
           divide    100                  into w-det-val-rit-s13
                                        giving w-det-val-rit-s11
                                                         rounded      .
           move      w-det-val-rit-s11    to   w-det-val-rit-ris      .
       det-val-rit-999.
           exit.

      *    *===========================================================*
      *    * Controllo codice iva                                      *
      *    *-----------------------------------------------------------*
       ctl-cod-iva-000.
      *              *-------------------------------------------------*
      *              * Controllo                                       *
      *              *-------------------------------------------------*
           move      "CT"                 to   d-imp-iva-tip-ope      .
           perform   det-imp-iva-cll-000  thru det-imp-iva-cll-999    .
       ctl-cod-iva-999.
           exit.

      *    *===========================================================*
      *    * Routine di attribuzione numero protocollo iva fornitori   *
      *    *-----------------------------------------------------------*
       att-prt-ivf-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
      *              *-------------------------------------------------*
      *              * Lettura numerazione                             *
      *              *-------------------------------------------------*
           move      w-num-prt-ivf-dat    to   s-dat                  .
           move      s-saa                to   rn-prt-ivf-saa-dtr     .
           move      w-num-prt-ivf-ngi    to   rn-prt-ivf-cod-num     .
           move      "GT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
           if        f-sts                =    e-not-err
                     go to att-prt-ivf-100.
      *              *-------------------------------------------------*
      *              * Se numerazione non esistente la si crea norma-  *
      *              * lizzata a zero                                  *
      *              *-------------------------------------------------*
           move      zero                 to   rn-prt-ivf-num-prt     .
           move      "PT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
           go to     att-prt-ivf-000.
       att-prt-ivf-100.
      *              *-------------------------------------------------*
      *              * Se numerazione esistente                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valore originale            *
      *                  *---------------------------------------------*
           move      rn-prt-ivf-num-prt   to   w-num-prt-ivf-dec      .
      *                  *---------------------------------------------*
      *                  * Incremento numero protocollo                *
      *                  *---------------------------------------------*
           add       1                    to   rn-prt-ivf-num-prt     .
           if        rn-prt-ivf-num-prt   =    zero
                     move  1              to   rn-prt-ivf-num-prt     .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione numero protocollo           *
      *                  *---------------------------------------------*
           move      rn-prt-ivf-num-prt   to   w-num-prt-ivf-prt      .
           move      rn-prt-ivf-num-prt   to   w-num-prt-ivf-inc      .
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
      *                  *---------------------------------------------*
      *                  * Se errori ripete l'intera operazione        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to att-prt-ivf-000.
      *                  *---------------------------------------------*
      *                  * Unlock                                      *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
       att-prt-ivf-999.
           exit.

      *    *===========================================================*
      *    * Routine di ratifica numero protocollo iva fornitori       *
      *    *-----------------------------------------------------------*
       rat-prt-ivf-000.
      *              *-------------------------------------------------*
      *              * Se il valore e' stato ratificato : uscita       *
      *              *-------------------------------------------------*
           if        w-num-prt-ivf-prt    =    w-num-prt-ivf-inc
                     go to rat-prt-ivf-999.
      *              *-------------------------------------------------*
      *              * Se il valore impostato e' inferiore al valore   *
      *              * originale si esegue il ripristino               *
      *              *-------------------------------------------------*
           if        w-num-prt-ivf-prt    >    w-num-prt-ivf-inc
                     go to rat-prt-ivf-200.
           perform   rip-prt-ivf-000      thru rip-prt-ivf-999        .
           move      spaces               to   w-num-prt-ivf-flg      .
           go to     rat-prt-ivf-999.
       rat-prt-ivf-200.
      *              *-------------------------------------------------*
      *              * Se il valore impostato e' superiore al valore   *
      *              * originale si chiede all'operatore se la numera- *
      *              * zione dovra' poi proseguire con il numero suc-  *
      *              * cessivo                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione numero progressivo editato     *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-num-prt-ivf-prt    to   v-num                  .
           add       1                    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Richiesta all'operatore                     *
      *                  *---------------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      spaces               to   v-not                  .
           string    "La numerazione dovra' poi proseguire dal numero "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " (S/N) ?" delimited by   size
                                          into v-not                  .
           move      spaces               to   v-alf                  .
           move      "SN"                 to   v-msk                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Esame risposta                              *
      *                  *---------------------------------------------*
           if        v-alf                =    "S"
                     go to rat-prt-ivf-400
           else if   v-alf                =    "N"
                     go to rat-prt-ivf-999
           else      go to rat-prt-ivf-200.
       rat-prt-ivf-400.
      *                  *---------------------------------------------*
      *                  * Se risposta 'Si'                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Aggiornamento numerazione               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Lettura numerazione                 *
      *                          *-------------------------------------*
           move      w-num-prt-ivf-dat    to   s-dat                  .
           move      s-saa                to   rn-prt-ivf-saa-dtr     .
           move      w-num-prt-ivf-ngi    to   rn-prt-ivf-cod-num     .
           move      "GT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
           if        f-sts                =    e-not-err
                     go to rat-prt-ivf-600.
      *                          *-------------------------------------*
      *                          * Se numerazione non esistente la si  *
      *                          * crea normalizzata a zero            *
      *                          *-------------------------------------*
           move      zero                 to   rn-prt-ivf-num-prt     .
           move      "PT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
           go to     rat-prt-ivf-400.
       rat-prt-ivf-600.
      *                          *-------------------------------------*
      *                          * Aggiornamento numerazione           *
      *                          *-------------------------------------*
           move      w-num-prt-ivf-prt    to   rn-prt-ivf-num-prt     .
           move      "UP"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
           if        f-sts                not  = e-not-err
                     go to rat-prt-ivf-400.
       rat-prt-ivf-800.
      *                          *-------------------------------------*
      *                          * Unlock della numerazione            *
      *                          *-------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
       rat-prt-ivf-999.
           exit.

      *    *===========================================================*
      *    * Routine di ripristino numero protocollo iva fornitori     *
      *    *-----------------------------------------------------------*
       rip-prt-ivf-000.
      *              *-------------------------------------------------*
      *              * Lettura numerazione                             *
      *              *-------------------------------------------------*
           move      w-num-prt-ivf-dat    to   s-dat                  .
           move      s-saa                to   rn-prt-ivf-saa-dtr     .
           move      w-num-prt-ivf-ngi    to   rn-prt-ivf-cod-num     .
           move      "GT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
           if        f-sts                =    e-not-err
                     go to rip-prt-ivf-100.
      *              *-------------------------------------------------*
      *              * Se numerazione non esistente la si crea norma-  *
      *              * lizzata a zero                                  *
      *              *-------------------------------------------------*
           move      zero                 to   rn-prt-ivf-num-prt     .
           move      "PT"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
           go to     rip-prt-ivf-000.
       rip-prt-ivf-100.
      *              *-------------------------------------------------*
      *              * Se numerazione esistente                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Controllo se il valore attuale della nume-  *
      *                  * razione e' tuttora inalterato rispetto al-  *
      *                  * l'aggiornamento eseguito in fase di attri-  *
      *                  * buzione del numero                          *
      *                  *---------------------------------------------*
           if        rn-prt-ivf-num-prt   =    w-num-prt-ivf-inc
                     go to rip-prt-ivf-200
           else      go to rip-prt-ivf-400.
       rip-prt-ivf-200.
      *                  *---------------------------------------------*
      *                  * Se il valore risulta inalterato             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controaggiornamento numerazione         *
      *                      *-----------------------------------------*
           move      w-num-prt-ivf-dec    to   rn-prt-ivf-num-prt     .
           move      "UP"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rip-prt-ivf-000.
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
           go to     rip-prt-ivf-999.
       rip-prt-ivf-400.
      *                  *---------------------------------------------*
      *                  * Se il valore risulta cambiato               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se il cambiamento corrisponde alla for- *
      *                      * zatura eseguita dall'operatore stesso   *
      *                      * in caso di impostazione di un numero    *
      *                      * superiore al progressivo : si controag- *
      *                      * giorna senza alcun messaggio            *
      *                      *-----------------------------------------*
           if        rn-prt-ivf-num-prt   =    w-num-prt-ivf-prt
                     go to rip-prt-ivf-200.
      *                      *-----------------------------------------*
      *                      * Se il cambiamento invece e' dovuto al   *
      *                      * fatto che un altro utente ha nel frat-  *
      *                      * tempo prelevato un numero progressivo   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Unlock                              *
      *                          *-------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/inprtivf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-prt-ivf             .
      *                          *-------------------------------------*
      *                          * Messaggio all'operatore che il nu-  *
      *                          * mero deve essere recuperato manual- *
      *                          * mente                               *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Preparazione numero progressivo *
      *                              * editato                         *
      *                              *---------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-num-prt-ivf-inc    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                              *---------------------------------*
      *                              * Messaggio all'operatore         *
      *                              *---------------------------------*
           move      "Attenzione: un altro utente ha nel frattempo prele
      -              "vato un numero."    to   w-err-box-err-msg      .
           string    "Pertanto il numero "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " dovra' essere recuperato manualmente."
                                delimited by   size
                                          into w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       rip-prt-ivf-999.
           exit.

      *    *===========================================================*
      *    * Routine di conversione da altra valuta a valuta base      *
      *    *-----------------------------------------------------------*
           copy      "swd/std/prg/cpy/wcvsvlt0.cps"                   .

      *    *===========================================================*
      *    * Calcolo tabella scadenze                                  *
      *    *-----------------------------------------------------------*
           copy      "pgm/fat/prg/cpy/dtblscd0.dts"                   .

      *    *===========================================================*
      *    * Controllo di congruenza tra data e numero per [mgi]       *
      *    *-----------------------------------------------------------*
       rou-cdn-mgi-000.
      *              *-------------------------------------------------*
      *              * Chiamata modulo                                 *
      *              *-------------------------------------------------*
           move      "CP"                 to   l-cge-300-tip-ope      .
           move      w-tes-npr-cge (1)    to   l-cge-300-num-prt      .
           move      "F"                  to   l-cge-300-tip-arc      .
           move      w-tes-drg-cge (1)    to   l-cge-300-dat-reg      .
           move      w-tes-ngi-iva (1)    to   l-cge-300-cod-num      .
           move      w-tes-npt-iva (1)    to   l-cge-300-prt-iva      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
       rou-cdn-mgi-999.
           exit.

      *    *===========================================================*
      *    * Controllo di congruenza tra data e numero per [mgi]       *
      *    *                                                           *
      *    * Subroutine per messaggio di errore                        *
      *    *-----------------------------------------------------------*
       rou-cdn-mgi-msg-000.
      *              *-------------------------------------------------*
      *              * Emissione del messaggio di errore               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing numero progressivo del numero docu- *
      *                  * mento letto                                 *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      l-cge-300-prt-iva    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-all-str-cat (2)      .
      *                  *---------------------------------------------*
