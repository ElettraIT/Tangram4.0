           move      w-tes-cab-aaf (1)    to   w-rg2-cab-scf (1)      .
           move      w-tes-cab-aaf-den (1)
                                          to   w-rg2-cab-scf-den (1)  .
           move      w-tes-ccc-aaf (1)    to   w-rg2-ccc-scf (1)      .
