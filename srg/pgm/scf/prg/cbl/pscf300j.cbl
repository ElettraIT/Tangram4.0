      *    * tore                                                      *
      *    *-----------------------------------------------------------*
       rip-sff-num-000.
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [sffnum]                                  *
      *              *-------------------------------------------------*
           move      w-sff-num-scl-ann    to   rn-sff-num-scl-ann     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [sffnum]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insffnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sff-num             .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to rip-sff-num-400.
       rip-sff-num-200.
      *              *-------------------------------------------------*
      *              * Se record non esistente                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Unlock record                               *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insffnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sff-num             .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     rip-sff-num-999.
       rip-sff-num-400.
      *              *-------------------------------------------------*
      *              * Se record esistente                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Confronto tra il numero registrazione at-   *
      *                  * tuale contenuto nel record numerazioni ed   *
      *                  * il valore post-incremento, e deviazione in  *
      *                  * funzione dell'esito del test                *
      *                  *---------------------------------------------*
           move      rn-sff-num-num-ftf   to   w-sff-num-num-ftf      .
           if        w-sff-num-r01-num    =    w-sff-num-val-pos
                     go to rip-sff-num-600.
       rip-sff-num-500.
      *                  *---------------------------------------------*
      *                  * Se numero registrazione attuale contenuto   *
      *                  * nel record numerazioni diverso dal valore   *
      *                  * post-incremento                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insffnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sff-num             .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rip-sff-num-999.
       rip-sff-num-600.
      *                  *---------------------------------------------*
      *                  * Se numero registrazione attuale contenuto   *
      *                  * nel record numerazioni uguale al valore     *
      *                  * post-incremento                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controaggiornamento del valore attuale  *
      *                      * contenuto nel record numerazioni, ri-   *
      *                      * portandolo al valore pre-incremento     *
      *                      *-----------------------------------------*
           move      w-sff-num-val-pre    to   w-sff-num-r01-num      .
           if        w-sff-num-val-pre    =    zero
                     move  zero           to   w-sff-num-num-ftf      .
           move      w-sff-num-num-ftf    to   rn-sff-num-num-ftf     .
      *                      *-----------------------------------------*
      *                      * Update record numerazioni               *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insffnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sff-num             .
      *                      *-----------------------------------------*
      *                      * Unlock record numerazioni               *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insffnum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sff-num             .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rip-sff-num-999.
       rip-sff-num-999.
           exit.

