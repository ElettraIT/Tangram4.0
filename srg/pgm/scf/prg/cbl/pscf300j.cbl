      *                  * Salvataggio importo movimento precedente    *
      *                  *---------------------------------------------*
           move      w-rig-imp-mov (1)    to   w-sav-imp-mov          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione importo movimento a zero    *
      *                  *---------------------------------------------*
           move      zero                 to   w-rig-imp-mov (1)      .
           perform   vis-imp-mov-000      thru vis-imp-mov-999        .
      *                  *---------------------------------------------*
      *                  * Ripristino importo movimento precedente     *
      *                  *---------------------------------------------*
           move      w-sav-imp-mov        to   w-rig-imp-mov (1)      .
      *                  *---------------------------------------------*
      *                  * Inversione del segnale di Dare o Avere      *
      *                  *---------------------------------------------*
           if        w-rig-dar-ave (1)    =    "A"
                     move  "D"            to   w-rig-dar-ave (1)
           else      move  "A"            to   w-rig-dar-ave (1)      .
