      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-rig-900.
       cnt-tdo-rig-160.
      *                  *---------------------------------------------*
      *                  * Commento in riga                            *
      *                  *---------------------------------------------*
       cnt-tdo-rig-180.
      *                  *---------------------------------------------*
      *                  * Data e numero riferimento                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se campo da accettare              *
      *                      *-----------------------------------------*
           if        w-rig-tip-con (1)    not  = "C" and
                     w-rig-tip-con (1)    not  = "F"
                     go to cnt-tdo-rig-200.
      *                      *-----------------------------------------*
      *                      * Se valore non ammesso : errore          *
      *                      *-----------------------------------------*
           if        w-rig-dat-rif (1)    =    zero   and
                     w-rig-num-rif (1)    =    spaces
                     go to cnt-tdo-rig-200.
           if        w-rig-dat-rif (1)    not  = zero   and
                     w-rig-num-rif (1)    not  = spaces
                     go to cnt-tdo-rig-200.
           move      "Non e' ammessa una data riferimento senza numero r
      -              "iferimento     "    to   w-err-box-err-msg      .
           move      "o viceversa                                       
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           go to     cnt-tdo-rig-950.
       cnt-tdo-rig-200.
      *                  *---------------------------------------------*
      *                  * Importo movimento                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore non ammesso : errore          *
      *                      *-----------------------------------------*
           if        w-rig-imp-mov (1)    not  = zero
                     go to cnt-tdo-rig-220.
           move      "Manca l'importo movimento                         
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-rig-900.
       cnt-tdo-rig-220.
      *              *-------------------------------------------------*
      *              * Fine controlli                                  *
      *              *-------------------------------------------------*
       cnt-tdo-rig-600.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     cnt-tdo-rig-999.
       cnt-tdo-rig-900.
      *              *-------------------------------------------------*
      *              * Se controllo non superato                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
       cnt-tdo-rig-950.
      *                  *---------------------------------------------*
      *                  * Flag di errore in uscita                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-rig-flg      .
       cnt-tdo-rig-999.
           exit.

      *    *===========================================================*
      *    * Preparazioni pre-accettazione riga corpo                  *
      *    *-----------------------------------------------------------*
       pre-rig-cor-000.
      *              *-------------------------------------------------*
      *              * Salvataggio valori riga pre-accettazione        *
      *              *-------------------------------------------------*
           move      w-rig-imp-mov (1)    to   w-srp-imp-mov          .
           move      w-rig-dar-ave (1)    to   w-srp-dar-ave          .
       pre-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Attribuzione del numero progressivo per la riga New       *
      *    *-----------------------------------------------------------*
       prg-rig-cor-000.
      *              *-------------------------------------------------*
      *              * Prelevamento da area di controllo catena        *
      *              *-------------------------------------------------*
           move      w-cat-rig-prg        to   w-rig-num-prg (1)      .
       prg-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Azioni post-accettazione riga corpo                       *
      *    *-----------------------------------------------------------*
       pos-rig-cor-000.
      *              *-------------------------------------------------*
      *              * Controaggiornamento                             *
      *              *-------------------------------------------------*
           if        w-srp-dar-ave        =    "A"
                     add        w-srp-imp-mov
                                          to   w-tes-sdo-rmc (1)
           else      subtract   w-srp-imp-mov
                                          from w-tes-sdo-rmc (1)      .
      *              *-------------------------------------------------*
      *              * Aggiornamento, se necessario                    *
      *              *-------------------------------------------------*
           if        w-cnt-cor-tip-agg    not  = "+"
                     go to pos-rig-cor-100.
           if        w-rig-dar-ave (1)    =    "A"
                     subtract  w-rig-imp-mov (1)
                                          from w-tes-sdo-rmc (1)
           else      add        w-rig-imp-mov (1)
                                          to   w-tes-sdo-rmc (1)      .
       pos-rig-cor-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione saldo righe movimento contabile *
      *              *-------------------------------------------------*
           perform   vis-sdo-rmc-000      thru vis-sdo-rmc-999        .
       pos-rig-cor-200.
      *              *-------------------------------------------------*
      *              * Determinazione data e numero riferimento per pa-*
      *              * reggiamento automatico acconti                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se funzione non utilizzata : oltre          *
      *                  *---------------------------------------------*
           if        w-tes-imp-pap (1)    =    spaces
                     go to pos-rig-cor-300.
      *                  *---------------------------------------------*
      *                  * Se non si e' in riga 1 : oltre              *
      *                  *---------------------------------------------*
           if        w-cat-rig-cur        not  = 1
                     go to pos-rig-cor-300.
      *                  *---------------------------------------------*
      *                  * Data riferimento                            *
      *                  *---------------------------------------------*
           if        w-rig-dat-rif (1)    not  = zero
                     move  w-rig-dat-rif (1)
                                          to   w-lpa-dri-doc
                     go to pos-rig-cor-220.
           move      w-tes-ddo-ftf (1)    to   w-lpa-dri-doc          .
       pos-rig-cor-220.
      *                  *---------------------------------------------*
      *                  * Numero riferimento                          *
      *                  *---------------------------------------------*
           if        w-rig-num-rif (1)    not  = spaces
                     move  w-rig-num-rif (1)
                                          to   w-lpa-nri-doc
                     go to pos-rig-cor-300.
           move      w-tes-ndo-ftf (1)    to   w-lpa-nri-doc          .
       pos-rig-cor-300.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     pos-rig-cor-999.
       pos-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Determinazione si/no corpo 2 da trattare                  *
      *    *-----------------------------------------------------------*
       snp-co2-reg-000.
      *              *-------------------------------------------------*
      *              * Flag di uscita a Si                             *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-sts-imp-sn2      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     snp-co2-reg-999.
       snp-co2-reg-999.
           exit.

      *    *===========================================================*
      *    * Accettazione corpo 2 a partire dalla riga con numero      *
      *    * d'ordine : w-cnt-co2-nrg-dac                              *
      *    *-----------------------------------------------------------*
       acc-co2-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione tipo uscita da corpo            *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-co2      .
      *              *-------------------------------------------------*
      *              * Caricamento catena scadenze fornitore           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se non da effettuare : oltre                *
      *                  *---------------------------------------------*
           if        w-tes-fdc-scf (1)    not  = spaces
                     go to acc-co2-reg-010.
      *                  *---------------------------------------------*
      *                  * Richiamo routine                            *
      *                  *---------------------------------------------*
           perform   car-cat-scf-000      thru car-cat-scf-999        .
      *                  *---------------------------------------------*
      *                  * Aggiornamento flag di caricamento righe mo- *
      *                  * vimento contabile                           *
      *                  *---------------------------------------------*
           move      "#"                  to   w-tes-fdc-scf (1)      .
       acc-co2-reg-010.
      *              *-------------------------------------------------*
      *              * Confronto tra numero d'ordine riga da accettare *
      *              * e numero d'ordine dell'ultima riga              *
      *              *-------------------------------------------------*
           if        w-cnt-co2-nrg-dac    not  > w-cat-rg2-max
                     go to acc-co2-reg-025.
      *              *-------------------------------------------------*
      *              * Se oltre numero riga massimo e Append non pos-  *
      *              * sibile si esce con status di uscita "+"         *
      *              *-------------------------------------------------*
           if        w-cat-rg2-app        not  = spaces
                     move  "+"            to   w-cnt-tus-acc-co2
                     go to acc-co2-reg-990.
      *              *-------------------------------------------------*
      *              * Se oltre numero riga massimo e Append possibile *
      *              * si esegue l'operazione di Append                *
      *              *-------------------------------------------------*
           move      w-cat-rg2-max        to   w-cnt-co2-nrg-dac      .
           add       1                    to   w-cnt-co2-nrg-dac      .
           move      "AP"                 to   w-cat-rg2-ope          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
       acc-co2-reg-025.
      *              *-------------------------------------------------*
      *              * Video in 'OFF'                                  *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Prompts per corpo                               *
      *              *-------------------------------------------------*
           if        w-cnt-sts-pmt-co2    =    spaces
                     perform pmt-co2-reg-000
                                          thru pmt-co2-reg-999
                     move    "#"          to   w-cnt-sts-pmt-co2      .
      *              *-------------------------------------------------*
      *              * Visualizzazione dati corpo                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione nr pagina da visualizzare    *
      *                  *---------------------------------------------*
           move      w-cnt-co2-nrg-dac    to   w-cnt-co2-nrp-dav      .
           add       w-ln2-num-lin-vis    to   w-cnt-co2-nrp-dav      .
           subtract  1                    from w-cnt-co2-nrp-dav      .
           divide    w-ln2-num-lin-vis    into w-cnt-co2-nrp-dav      .
      *                  *---------------------------------------------*
      *                  * Se non e' visualizzata nessuna pagina corpo *
      *                  * o una pagina corpo diversa da quella da vi- *
      *                  * sualizzare si procede alla visualizzazione  *
      *                  *---------------------------------------------*
           if        w-cnt-sts-vis-co2    =    spaces           or
                     w-cnt-co2-nrp-vis    not  = w-cnt-co2-nrp-dav
                     perform vis-co2-reg-000
                                          thru vis-co2-reg-999
                     move    "#"          to   w-cnt-sts-vis-co2
                     move    w-cnt-co2-nrp-dav
                                          to   w-cnt-co2-nrp-vis      .
      *              *-------------------------------------------------*
      *              * Lettura riga da catena                          *
      *              *-------------------------------------------------*
           move      "RD"                 to   w-cat-rg2-ope          .
           move      w-cnt-co2-nrg-dac    to   w-cat-rg2-num          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
           move      w-cat-rg2-buf        to   w-rg2                  .
      *              *-------------------------------------------------*
      *              * Se riga nuova si normalizza il corpo            *
      *              *-------------------------------------------------*
           if        w-cat-rg2-new        =    spaces
                     go to acc-co2-reg-050.
           perform   nor-nok-rg2-000      thru nor-nok-rg2-999        .
           move      w-rg2-val-aep (1)    to   w-rg2-val-aep (2)      .
       acc-co2-reg-050.
      *              *-------------------------------------------------*
      *              * Routine pre-accettazione riga corpo             *
      *              *-------------------------------------------------*
           perform   pre-rig-co2-000      thru pre-rig-co2-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts per riga d'accettazione *
      *              *-------------------------------------------------*
           perform   pmt-rig-co2-000      thru pmt-rig-co2-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione dati per riga di accettazione   *
      *              *-------------------------------------------------*
           perform   vis-rig-co2-000      thru vis-rig-co2-999        .
      *              *-------------------------------------------------*
      *              * Video in 'ON'                                   *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Flag di status impostazione corpo               *
      *              *-------------------------------------------------*
           if        w-cat-rg2-max        =    zero
                     move  spaces         to   w-cnt-sts-imp-co2
           else      move  "#"            to   w-cnt-sts-imp-co2      .
           if        w-cat-rg2-max        =    1        and
                     w-cat-rg2-new        not  = spaces and
                     w-cat-rg2-lst        not  = spaces
                     move  spaces         to   w-cnt-sts-imp-co2      .
      *              *-------------------------------------------------*
      *              * Flag di status impostione riga attuale          *
      *              *-------------------------------------------------*
           if        w-cat-rg2-new        =    spaces
                     move  "#"            to   w-cnt-sts-imp-rg2
           else      move  spaces         to   w-cnt-sts-imp-rg2      .
      *              *-------------------------------------------------*
      *              * Indicatore linea in corso di trattamento        *
      *              *-------------------------------------------------*
           move      "I"                  to   w-cnt-co2-tvi-rig      .
           move      w-cnt-co2-nrg-dac    to   w-cnt-co2-nrg-dav      .
           perform   vis-lin-co2-000      thru vis-lin-co2-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazione tipo uscita da riga corpo       *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-rg2      .
       acc-co2-reg-100.
      *              *-------------------------------------------------*
      *              * Accettazioni                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo impostazione : primo campo riga corpo  *
      *                  *---------------------------------------------*
           move      "C"                  to   w-cnt-mfu-tip-imp      .
      *                  *---------------------------------------------*
      *                  * Tipo riga per scadenza fornitore            *
      *                  *---------------------------------------------*
           perform   acc-tip-rig-000      thru acc-tip-rig-999        .
           if        w-cnt-tus-acc-rg2    not  = spaces
                     go to acc-co2-reg-925.
      *                  *---------------------------------------------*
      *                  * Tipo impostazione : altri campi riga corpo  *
      *                  *---------------------------------------------*
           move      "R"                  to   w-cnt-mfu-tip-imp      .
       acc-co2-reg-150.
      *                  *---------------------------------------------*
      *                  * Normalizzazione func-key di impostazione    *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Si/no pagamento bloccato                    *
      *                  *---------------------------------------------*
           perform   acc-snx-pbl-000      thru acc-snx-pbl-999        .
           if        w-cnt-tus-acc-rg2    not  = spaces
                     go to acc-co2-reg-900.
       acc-co2-reg-200.
      *                  *---------------------------------------------*
      *                  * Data scadenza                               *
      *                  *---------------------------------------------*
           perform   acc-dts-scf-000      thru acc-dts-scf-999        .
           if        w-cnt-tus-acc-rg2    not  = spaces
                     go to acc-co2-reg-900.
           if        v-key                =    "UP  "
                     go to acc-co2-reg-150.
       acc-co2-reg-250.
      *                  *---------------------------------------------*
      *                  * Importo in valuta scadenza fornitore        *
      *                  *---------------------------------------------*
           perform   acc-iiv-scf-000      thru acc-iiv-scf-999        .
           if        w-cnt-tus-acc-rg2    not  = spaces
                     go to acc-co2-reg-900.
           if        v-key                =    "UP  "
                     go to acc-co2-reg-200.
       acc-co2-reg-300.
      *                  *---------------------------------------------*
      *                  * Importo scadenza fornitore                  *
      *                  *---------------------------------------------*
           perform   acc-imp-scf-000      thru acc-imp-scf-999        .
           if        w-cnt-tus-acc-rg2    not  = spaces
                     go to acc-co2-reg-900.
           if        v-key                =    "UP  "
                     go to acc-co2-reg-250.
       acc-co2-reg-350.
      *                  *---------------------------------------------*
      *                  * Nostra banca d'appoggio per scadenza forni- *
      *                  * tore                                        *
      *                  *---------------------------------------------*
           perform   acc-cbp-scf-000      thru acc-cbp-scf-999        .
           if        w-cnt-tus-acc-rg2    not  = spaces
                     go to acc-co2-reg-900.
           if        v-key                =    "UP  "
                     go to acc-co2-reg-300.
       acc-co2-reg-400.
      *                  *---------------------------------------------*
      *                  * Codice ABI banca per scadenza fornitore     *
      *                  *---------------------------------------------*
           perform   acc-abi-scf-000      thru acc-abi-scf-999        .
           if        w-cnt-tus-acc-rg2    not  = spaces
                     go to acc-co2-reg-900.
           if        v-key                =    "UP  "
                     go to acc-co2-reg-350.
       acc-co2-reg-450.
      *                  *---------------------------------------------*
      *                  * Codice CAB sportello per scadenza fornitore *
      *                  *---------------------------------------------*
           perform   acc-cab-scf-000      thru acc-cab-scf-999        .
           if        w-cnt-tus-acc-rg2    not  = spaces
                     go to acc-co2-reg-900.
           if        v-key                =    "UP  "
                     go to acc-co2-reg-400.
       acc-co2-reg-500.
      *                  *---------------------------------------------*
      *                  * C/C bancario per scadenza fornitore         *
      *                  *---------------------------------------------*
           perform   acc-ccc-scf-000      thru acc-ccc-scf-999        .
           if        w-cnt-tus-acc-rg2    not  = spaces
                     go to acc-co2-reg-900.
           if        v-key                =    "UP  "
                     go to acc-co2-reg-450.
       acc-co2-reg-550.
      *                  *---------------------------------------------*
      *                  * C/C postale per scadenza fornitore          *
      *                  *---------------------------------------------*
           perform   acc-ccp-scf-000      thru acc-ccp-scf-999        .
           if        w-cnt-tus-acc-rg2    not  = spaces
                     go to acc-co2-reg-900.
           if        v-key                =    "UP  "
                     go to acc-co2-reg-500.
       acc-co2-reg-600.
      *                  *---------------------------------------------*
      *                  * Banca estera per scadenza fornitore         *
      *                  *---------------------------------------------*
           perform   acc-bef-scf-000      thru acc-bef-scf-999        .
           if        w-cnt-tus-acc-rg2    not  = spaces
                     go to acc-co2-reg-900.
           if        v-key                =    "UP  "
                     go to acc-co2-reg-550.
       acc-co2-reg-700.
      *                  *---------------------------------------------*
      *                  * Presa visione per riga corpo                *
      *                  *---------------------------------------------*
           perform   acc-pre-vrc-000      thru acc-pre-vrc-999        .
           if        w-cnt-tus-acc-rg2    not  = spaces
                     go to acc-co2-reg-900.
           if        v-key                =    "UP  "
                     go to acc-co2-reg-600.
       acc-co2-reg-800.
      *              *-------------------------------------------------*
      *              * Controllo finale su riga impostata              *
      *              *-------------------------------------------------*
           perform   cnt-tdo-rg2-000      thru cnt-tdo-rg2-999        .
           if        w-cnt-tdo-rg2-flg    not  = spaces
                     move  spaces         to   w-cnt-tdo-rg2-flg
                     move  "UP  "         to   v-key
                     go to acc-co2-reg-200.
       acc-co2-reg-900.
      *              *-------------------------------------------------*
      *              * Tests per uscita significativa da interno riga  *
      *              *-------------------------------------------------*
           if        w-cnt-tus-acc-rg2    =    spaces or
                     w-cnt-tus-acc-rg2    =    "S"
                     go to acc-co2-reg-905
           else if   w-cnt-tus-acc-rg2    =    "R"
                     go to acc-co2-reg-910.
      *                  *---------------------------------------------*
      *                  * Se Exit da interno riga                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga New funzionamento come per Remv *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        not  = spaces
                     go to acc-co2-reg-915.
      *                      *-----------------------------------------*
      *                      * Se riga non New                         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Visualizzazione numero riga         *
      *                          *-------------------------------------*
           move      "N"                  to   w-cnt-co2-tvi-rig      .
           move      w-cnt-co2-nrg-dac    to   w-cnt-co2-nrg-dav      .
           perform   vis-lin-co2-000      thru vis-lin-co2-999        .
           go to     acc-co2-reg-000.
       acc-co2-reg-905.
      *                  *---------------------------------------------*
      *                  * Se Do da interno riga                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se record di tipo New attribuzione del  *
      *                      * numero progressivo per la riga          *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        =    spaces
                     go to acc-co2-reg-907.
           perform   prg-rig-co2-000      thru prg-rig-co2-999        .
       acc-co2-reg-907.
      *                      *-----------------------------------------*
      *                      * Routine post-accettazione riga          *
      *                      *-----------------------------------------*
           move      "+"                  to   w-cnt-co2-tip-agg      .
           perform   pos-rig-co2-000      thru pos-rig-co2-999        .
      *                      *-----------------------------------------*
      *                      * Update riga in catena movimenti         *
      *                      *-----------------------------------------*
           move      "UP"                 to   w-cat-rg2-ope          .
           move      w-cnt-co2-nrg-dac    to   w-cat-rg2-num          .
           move      w-rg2                to   w-cat-rg2-buf          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione linea corpo             *
      *                      *-----------------------------------------*
           move      "R"                  to   w-cnt-co2-tvi-rig      .
           move      w-cnt-co2-nrg-dac    to   w-cnt-co2-nrg-dav      .
           perform   vis-lin-co2-000      thru vis-lin-co2-999        .
      *                      *-----------------------------------------*
      *                      * Incremento del numero d'ordine della    *
      *                      * riga da accettare                       *
      *                      *-----------------------------------------*
           add       1                    to   w-cnt-co2-nrg-dac      .
           go to     acc-co2-reg-000.
       acc-co2-reg-910.
      *                  *---------------------------------------------*
      *                  * Se Remv da interno riga                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga non new : routine post-accetta- *
      *                      * zione riga                              *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        not  = spaces
                     go to acc-co2-reg-915.
           move      "-"                  to   w-cnt-co2-tip-agg      .
           perform   pos-rig-co2-000      thru pos-rig-co2-999        .
       acc-co2-reg-915.
      *                      *-----------------------------------------*
      *                      * Visualizzazione numero riga a spaces se *
      *                      * si e' in Append                         *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        not  = spaces and
                     w-cat-rg2-lst        not  = spaces
                     move    "S"          to   w-cnt-co2-tvi-rig
                     move    w-cnt-co2-nrg-dac
                                          to   w-cnt-co2-nrg-dav
                     perform vis-lin-co2-000
                                          thru vis-lin-co2-999        .
      *                      *-----------------------------------------*
      *                      * Numero pagina attualmente  visualizzata *
      *                      * a zero per forzare la rivisualizzazione *
      *                      * a meno che non si sia in Append         *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        =    spaces or
                     w-cat-rg2-lst        =    spaces
                     move  zero           to   w-cnt-co2-nrp-vis      .
      *                      *-----------------------------------------*
      *                      * Rimozione record dalla catena           *
      *                      *-----------------------------------------*
           move      "RM"                 to   w-cat-rg2-ope          .
           move      w-cnt-co2-nrg-dac    to   w-cat-rg2-num          .
           perform   cll-sub-ct2-000      thru cll-sub-ct2-999        .
      *                      *-----------------------------------------*
      *                      * Segnale di almeno una modifica          *
      *                      *-----------------------------------------*
