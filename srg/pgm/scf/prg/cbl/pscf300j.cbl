      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-rg2-flg      .
       cnt-tdo-rg2-100.
      *              *-------------------------------------------------*
      *              * Controlli                                       *
      *              *-------------------------------------------------*
       cnt-tdo-rg2-120.
      *                  *---------------------------------------------*
      *                  * Tipo scadenza fornitore                     *
      *                  *---------------------------------------------*
       cnt-tdo-rg2-140.
      *                  *---------------------------------------------*
      *                  * Data scadenza                               *
      *                  *---------------------------------------------*
       cnt-tdo-rg2-160.
      *                  *---------------------------------------------*
      *                  * Importo in valuta scadenza fornitore        *
      *                  *---------------------------------------------*
           if        w-rg2-tvl-scf (1)    not  = 02
                     go to cnt-tdo-rg2-180.
           if        w-rg2-iiv-scf (1)    not  = zero
                     go to cnt-tdo-rg2-180.
           move      "Manca l'importo in valuta della scadenza          
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-rg2-900.
       cnt-tdo-rg2-180.
      *                  *---------------------------------------------*
      *                  * Importo scadenza fornitore                  *
      *                  *---------------------------------------------*
           if        w-rg2-imp-scf (1)    not  = zero
                     go to cnt-tdo-rg2-200.
           move      "Manca l'importo della scadenza                    
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-rg2-900.
       cnt-tdo-rg2-200.
      *                  *---------------------------------------------*
      *                  * Nostra banca d'appoggio per scadenza forni- *
      *                  * tore                                        *
      *                  *---------------------------------------------*
       cnt-tdo-rg2-220.
      *                  *---------------------------------------------*
      *                  * Codice ABI banca per scadenza fornitore     *
      *                  *---------------------------------------------*
           if        w-rg2-tip-scf (1)    not  = 07 or
                     w-rg2-tvl-scf (1)    not  = 01
                     go to cnt-tdo-rg2-240.
           if        w-rg2-abi-scf (1)    not  = zero
                     go to cnt-tdo-rg2-240.
           move      "Manca il codice ABI della banca di appoggio per il
      -              " bonifico      "    to   w-err-box-err-msg      .
           go to     cnt-tdo-rg2-900.
       cnt-tdo-rg2-240.
      *                  *---------------------------------------------*
      *                  * Codice CAB sportello per scadenza fornitore *
      *                  *---------------------------------------------*
           if        w-rg2-tip-scf (1)    not  = 07 or
                     w-rg2-tvl-scf (1)    not  = 01
                     go to cnt-tdo-rg2-260.
           if        w-rg2-cab-scf (1)    not  = zero
                     go to cnt-tdo-rg2-260.
           move      "Manca il codice CAB della banca di appoggio per il
      -              " bonifico      "    to   w-err-box-err-msg      .
           go to     cnt-tdo-rg2-900.
       cnt-tdo-rg2-260.
      *                  *---------------------------------------------*
      *                  * C/C bancario per scadenza fornitore         *
      *                  *---------------------------------------------*
           if        w-rg2-tip-scf (1)    not  = 07 or
                     w-rg2-tvl-scf (1)    not  = 01
                     go to cnt-tdo-rg2-280.
           if        w-rg2-ccc-scf (1)    not  = spaces
                     go to cnt-tdo-rg2-280.
           move      "Manca la sigla C/C della banca di appoggio per il 
      -              "bonifico       "    to   w-err-box-err-msg      .
           go to     cnt-tdo-rg2-900.
       cnt-tdo-rg2-280.
      *                  *---------------------------------------------*
      *                  * C/C postale per scadenza fornitore          *
      *                  *---------------------------------------------*
           if        w-rg2-tip-scf (1)    not  = 08
                     go to cnt-tdo-rg2-300.
           if        w-rg2-ccp-scf (1)    not  = spaces
                     go to cnt-tdo-rg2-300.
           move      "Manca la sigla del C/C Postale di appoggio        
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-rg2-900.
       cnt-tdo-rg2-300.
      *                  *---------------------------------------------*
      *                  * Banca estera per scadenza fornitore         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo scadenza                   *
      *                      *-----------------------------------------*
           if        w-rg2-tip-scf (1)    not  = 07 or
                     w-rg2-tvl-scf (1)    not  = 02
                     go to cnt-tdo-rg2-320.
      *                      *-----------------------------------------*
      *                      * Test su codice banca estera             *
      *                      *-----------------------------------------*
           if        w-rg2-bef-scf (1)    not  = zero
                     go to cnt-tdo-rg2-320.
           move      "Manca il codice banca estera di appoggio per il bo
      -              "nifico         "    to   w-err-box-err-msg      .
           go to     cnt-tdo-rg2-900.
       cnt-tdo-rg2-320.
      *              *-------------------------------------------------*
      *              * Fine controlli, normalizzazioni                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione tipo operazione, causale e   *
      *                  * sottoconto per registrazione scadenza for-  *
      *                  * nitore                                      *
      *                  *---------------------------------------------*
           perform   det-tcs-rsf-000      thru det-tcs-rsf-999        .
      *                  *---------------------------------------------*
      *                  * Si/no pagamento bloccato                    *
      *                  *---------------------------------------------*
           if        w-rg2-snx-pbl (1)    not  = "N"
                     move  "S"            to   w-rg2-snx-pbl (1)      .
       cnt-tdo-rg2-600.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     cnt-tdo-rg2-999.
       cnt-tdo-rg2-900.
      *              *-------------------------------------------------*
      *              * Se controllo non superato                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di errore in uscita                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-rg2-flg      .
       cnt-tdo-rg2-999.
           exit.

