                    (w-all-str-i01)       to   w-trd-scx-mod
                                              (w-all-str-i01)         .
           move      m-xml-for-imp-pag
                    (w-all-str-i01)       to   w-trd-scx-imp
                                              (w-all-str-i01)         .
           move      m-xml-for-dat-scd
