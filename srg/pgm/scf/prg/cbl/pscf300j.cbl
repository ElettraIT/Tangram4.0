      *    *===========================================================*
      *    * Aggiornamento record [xft]                                *
      *    *-----------------------------------------------------------*
       upd-rec-xft-000.
      *              *-------------------------------------------------*
      *              * Test se da effettuare                           *
      *              *-------------------------------------------------*
           if        w-tes-fil-sdi (1)    =    spaces
                     go to upd-rec-xft-900.
       upd-rec-xft-100.
      *              *-------------------------------------------------*
      *              * Normalizzazione record [xft]                    *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofxft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-xft                 .
      *              *-------------------------------------------------*
      *              * Lettura, con lock, del record                   *
      *              *-------------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NOMXML"             to   f-key                  .
           move      w-tes-fil-sdi (1)    to   rf-xft-nom-xml         .
           move      "pgm/scf/fls/ioc/obj/iofxft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-xft                 .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to upd-rec-xft-300.
       upd-rec-xft-200.
      *              *-------------------------------------------------*
      *              * Se record [xft] non esistente                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     upd-rec-xft-900.
       upd-rec-xft-300.
      *              *-------------------------------------------------*
      *              * Se record [xft] esistente                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale aggiornamento codice fornitore    *
      *                  *---------------------------------------------*
           if        w-tes-cod-fnt (1)    =    rf-xft-cod-fnt
                     go to upd-rec-xft-320.
           move      w-tes-cod-fnt (1)    to   rf-xft-cod-fnt         .
       upd-rec-xft-320.
      *                  *---------------------------------------------*
      *                  * Eventuale aggiornamento data caricamento    *
      *                  *---------------------------------------------*
           if        rf-xft-dat-csg       not  = zero
                     go to upd-rec-xft-340.
      *
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rf-xft-dat-csg         .
       upd-rec-xft-340.
      *                  *---------------------------------------------*
      *                  * Aggiornamento protocollo fattura            *
      *                  *---------------------------------------------*
           move      w-tes-num-ftf        to   rf-xft-num-ftf         .
       upd-rec-xft-400.
      *              *-------------------------------------------------*
      *              * Update record                                   *
      *              *-------------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofxft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-xft                 .
       upd-rec-xft-500.
      *              *-------------------------------------------------*
      *              * Release                                         *
      *              *-------------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofxft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-xft                 .
       upd-rec-xft-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     upd-rec-xft-999.
       upd-rec-xft-999.
           exit.

      *    *===========================================================*
      *    * Aggiornamenti eventuale ritenuta d'acconto                *
      *    *-----------------------------------------------------------*
       wrt-mov-rda-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo funzionamento   *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to wrt-mov-rda-500.
       wrt-mov-rda-100.
      *              *-------------------------------------------------*
      *              * Se inserimento                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se movimento soggetto a ritenuta       *
      *                  *---------------------------------------------*
           if        w-tes-snx-rda (1)    not  = "S"
                     go to wrt-mov-rda-900.
       wrt-mov-rda-120.
      *                  *---------------------------------------------*
      *                  * Attribuzione numero protocollo              *
      *                  *---------------------------------------------*
           move      w-tes-dat-reg        to   w-det-prt-rda-ddo      .
           perform   att-rda-prt-000      thru att-rda-prt-999        .
           move      w-det-prt-rda-num    to   w-tes-prt-rda (1)      .
      *                  *---------------------------------------------*
      *                  * Raccolta dati [raa]                         *
      *                  *---------------------------------------------*
           move      w-tes-cod-fnt (1)    to   w-let-arc-raa-cod      .
           perform   let-arc-raa-000      thru let-arc-raa-999        .
      *                      *-----------------------------------------*
      *                      * Test su esito lettura                   *
      *                      *-----------------------------------------*
           if        w-let-arc-raa-flg    not  = spaces
                     go to wrt-mov-rda-900.
       wrt-mov-rda-200.
      *                  *---------------------------------------------*
      *                  * Write record [ram]                          *
      *                  *---------------------------------------------*
           perform   wrt-rec-ram-000      thru wrt-rec-ram-999        .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     wrt-mov-rda-900.
       wrt-mov-rda-500.
      *              *-------------------------------------------------*
      *              * Se modifica                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se movimento precedentemente soggetto  *
      *                  * a ritenuta                                  *
      *                  *---------------------------------------------*
           if        w-tes-snx-rda (2)    not  = "N"
                     go to wrt-mov-rda-700.
       wrt-mov-rda-600.
      *                  *---------------------------------------------*
      *                  * Inserimento nuova registrazione             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Come per inserimento                    *
      *                      *-----------------------------------------*
           go to     wrt-mov-rda-120.
       wrt-mov-rda-700.
      *                  *---------------------------------------------*
      *                  * Modifica registrazione                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se movimento soggetto a ritenuta   *
      *                      *-----------------------------------------*
           if        w-tes-snx-rda (1)    not  = "S"
                     go to wrt-mov-rda-800.
      *                      *-----------------------------------------*
      *                      * Raccolta dati [raa]                     *
      *                      *-----------------------------------------*
           move      w-tes-cod-fnt (1)    to   w-let-arc-raa-cod      .
           perform   let-arc-raa-000      thru let-arc-raa-999        .
      *                          *-------------------------------------*
      *                          * Test su esito lettura               *
      *                          *-------------------------------------*
           if        w-let-arc-raa-flg    not  = spaces
                     go to wrt-mov-rda-900.
      *                      *-----------------------------------------*
      *                      * Rewrite record [ram]                    *
      *                      *-----------------------------------------*
           perform   rew-rec-ram-000      thru rew-rec-ram-999        .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     wrt-mov-rda-900.
       wrt-mov-rda-800.
      *                  *---------------------------------------------*
      *                  * Canellazione registrazione                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Delete record [ram]                     *
      *                      *-----------------------------------------*
           perform   del-rec-ram-000      thru del-rec-ram-999        .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     wrt-mov-rda-900.
       wrt-mov-rda-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     wrt-mov-rda-999.
       wrt-mov-rda-999.
           exit.

      *    *===========================================================*
      *    * Cancellazione eventuale ritenuta d'acconto                *
      *    *-----------------------------------------------------------*
       del-mov-rda-000.
      *              *-------------------------------------------------*
      *              * Test se protocollo esistente                    *
      *              *-------------------------------------------------*
           if        w-tes-prt-rda (1)    =    zero
                     go to del-mov-rda-900.
      *              *-------------------------------------------------*
      *              * Delete record [ram]                             *
      *              *-------------------------------------------------*
           perform   del-rec-ram-000      thru del-rec-ram-999        .
       del-mov-rda-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     del-mov-rda-999.
       del-mov-rda-999.
           exit.

      *    *===========================================================*
      *    * Routine di attribuzione numero protocollo                 *
      *    *-----------------------------------------------------------*
       att-rda-prt-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/rda/num/ioc/obj/inrdaprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-rda-prt             .
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [rdaprt]                                  *
      *              *-------------------------------------------------*
           move      w-det-prt-rda-ddo    to   s-dat                  .
           move      s-saa                to   w-det-prt-rda-saa      .
           move      w-det-prt-rda-saa    to   rn-rda-prt-scl-ann     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [rdaprt]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/rda/num/ioc/obj/inrdaprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-rda-prt             .
      *              *-------------------------------------------------*
      *              * Test su esito operazione                        *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-rda-prt-100.
      *                  *---------------------------------------------*
      *                  * Record non trovato                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Composizione record normalizzato        *
      *                      *-----------------------------------------*
           move      zero                 to   rn-rda-prt-num-prt     .
      *                      *-----------------------------------------*
      *                      * Scrittura record normalizzato           *
      *                      *-----------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/rda/num/ioc/obj/inrdaprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-rda-prt             .
      *                      *-----------------------------------------*
      *                      * Ripetizione dell'intera operazione      *
      *                      *-----------------------------------------*
           go to     att-rda-prt-000.
       att-rda-prt-100.
      *                  *---------------------------------------------*
      *                  * Record trovato                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Numero protocollo in work di comodo     *
      *                      *-----------------------------------------*
           move      rn-rda-prt-num-prt   to   w-det-prt-rda-num      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento numero protocollo         *
      *                      *-----------------------------------------*
           add       1                    to   w-det-prt-rda-prg      .
           if        w-det-prt-rda-prg    =    zero
                     move  1              to   w-det-prt-rda-prg      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione numero protocollo       *
      *                      *-----------------------------------------*
           move      w-det-prt-rda-ddo    to   s-dat                  .
           move      s-saa                to   w-det-prt-rda-saa      .
           move      w-det-prt-rda-num    to   rn-rda-prt-num-prt     .
      *                      *-----------------------------------------*
      *                      * Update record                           *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/rda/num/ioc/obj/inrdaprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-rda-prt             .
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/rda/num/ioc/obj/inrdaprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-rda-prt             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to att-rda-prt-000.
       att-rda-prt-999.
           exit.

      *    *===========================================================*
