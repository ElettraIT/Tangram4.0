      *              *-------------------------------------------------*
           perform   cmp-rec-ram-000      thru cmp-rec-ram-999        .
      *              *-------------------------------------------------*
      *              * Put record                                      *
      *              *-------------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/rda/fls/ioc/obj/iofram"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ram                 .
       wrt-rec-ram-999.
           exit.

