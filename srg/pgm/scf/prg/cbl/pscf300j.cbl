      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
           if        w-rg2-snx-pbl (1)    not  = spaces and
                     w-rg2-snx-pbl (1)    not  = "N"    and
                     w-rg2-snx-pbl (1)    not  = "S"
