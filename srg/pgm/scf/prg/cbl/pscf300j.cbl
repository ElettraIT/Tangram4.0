           move      13                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      21                   to   v-lin                  .
           if        w-rig-dar-ave (1)    =    "A"
                     move  63             to   v-pos
           else      move  48             to   v-pos                  .
           move      "GB"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           if        w-cat-rig-cur        not  = 1
                     move  "REMV"         to   v-pfk (06)             .
______*    if        w-cat-rig-cur        not  = 1
                     move  "TAB "         to   v-pfk (10)             .
           move      w-rig-imp-mov (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
