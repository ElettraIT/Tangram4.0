      *              *-------------------------------------------------*
           if        w-trd-scx-mod
                    (w-cat-rg2-cur)       =    "MP01"
                     move  "RD"           to   w-all-str-cat (2)
           else if   w-trd-scx-mod
                    (w-cat-rg2-cur)       =    "MP02"
                     move  "RD"           to   w-all-str-cat (2)
           else if   w-trd-scx-mod
                    (w-cat-rg2-cur)       =    "MP03"
                     move  "RD"           to   w-all-str-cat (2)
           else if   w-trd-scx-mod
                    (w-cat-rg2-cur)       =    "MP04"
                     move  "RD"           to   w-all-str-cat (2)
           else if   w-trd-scx-mod
                    (w-cat-rg2-cur)       =    "MP05"
                     move  "BB"           to   w-all-str-cat (2)
           else if   w-trd-scx-mod
                    (w-cat-rg2-cur)       =    "MP06"
                     move  "PC"           to   w-all-str-cat (2)
           else if   w-trd-scx-mod
                    (w-cat-rg2-cur)       =    "MP07"
                     move  "MAV"          to   w-all-str-cat (2)
           else if   w-trd-scx-mod
                    (w-cat-rg2-cur)       =    "MP08"
                     move  "RD"           to   w-all-str-cat (2)
           else if   w-trd-scx-mod
                    (w-cat-rg2-cur)       =    "MP09"
                     move  "RID"          to   w-all-str-cat (2)
           else if   w-trd-scx-mod
