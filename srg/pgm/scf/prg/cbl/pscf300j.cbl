      *    * Prompt per : Importo scadenza fornitore                   *
      *    *-----------------------------------------------------------*
       pmt-imp-scf-000.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda della sigla valuta         *
      *              *-------------------------------------------------*
           if        w-tes-sgl-vlt (1)    =    c-sgl
                     go to pmt-imp-scf-100
           else      go to pmt-imp-scf-200.
       pmt-imp-scf-100.
      *              *-------------------------------------------------*
      *              * Se sigla valuta pari a quella base              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Prompt                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Importo scadenza :" to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     pmt-imp-scf-999.
       pmt-imp-scf-200.
      *              *-------------------------------------------------*
      *              * Se sigla valuta diversa da quella base          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valuta base                                 *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      39                   to   v-pos                  .
           move      c-sgl                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Prompt                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      43                   to   v-pos                  .
           move      ":"                  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     pmt-imp-scf-999.
       pmt-imp-scf-999.
           exit.

      *    *===========================================================*
      *    * Prompt per : Si/No pagamento bloccato                     *
      *    *-----------------------------------------------------------*
       pmt-snx-pbl-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      17                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      60                   to   v-pos                  .
           move      "Pagam. bloccato :"  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-snx-pbl-999.
           exit.

      *    *===========================================================*
      *    * Prompt per : Appoggio scadenza fornitore                  *
      *    *-----------------------------------------------------------*
       pmt-app-scf-000.
      *              *-------------------------------------------------*
      *              * Erase linee impegnate                           *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      19                   to   v-lin                  .
           move      21                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo scadenza        *
      *              *-------------------------------------------------*
           if        w-rg2-tip-scf (1)    =    01
                     go to pmt-app-scf-100
           else if   w-rg2-tip-scf (1)    =    02 or
                     w-rg2-tip-scf (1)    =    03 or
                     w-rg2-tip-scf (1)    =    04 or
                     w-rg2-tip-scf (1)    =    05 or
                     w-rg2-tip-scf (1)    =    06
                     go to pmt-app-scf-200
           else if   w-rg2-tip-scf (1)    =    07
                     go to pmt-app-scf-300
           else if   w-rg2-tip-scf (1)    =    08
                     go to pmt-app-scf-400
           else if   w-rg2-tip-scf (1)    =    09 or
                     w-rg2-tip-scf (1)    =    10 or
                     w-rg2-tip-scf (1)    =    11
                     go to pmt-app-scf-200
           else      go to pmt-app-scf-999.
       pmt-app-scf-100.
      *              *-------------------------------------------------*
      *              * Se tipo scadenza : 01                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Nessun prompt                               *
      *                  *---------------------------------------------*
           go to     pmt-app-scf-999.
       pmt-app-scf-200.
      *              *-------------------------------------------------*
      *              * Se tipo scadenza : 02, 03, 04, 05, 06, 09, 10,  *
      *              *                    11                           *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Ns. banca        :" to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           go to     pmt-app-scf-999.
       pmt-app-scf-300.
      *              *-------------------------------------------------*
      *              * Se tipo scadenza : 07                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo validita'   *
      *                  * scadenza                                    *
      *                  *---------------------------------------------*
           if        w-rg2-tvl-scf (1)    =    01
                     go to pmt-app-scf-320
           else      go to pmt-app-scf-340.
       pmt-app-scf-320.
      *                  *---------------------------------------------*
      *                  * Se tipo Italia : 01                         *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "ABI              :" to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "CAB              :" to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "C/C [IBAN]       :" to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           go to     pmt-app-scf-999.
       pmt-app-scf-340.
      *                  *---------------------------------------------*
      *                  * Se tipo Estero : 02                         *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Banca estera     :" to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           go to     pmt-app-scf-999.
       pmt-app-scf-400.
      *              *-------------------------------------------------*
      *              * Se tipo scadenza : 08                           *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "C/C Postale      :" to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           go to     pmt-app-scf-999.
       pmt-app-scf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Tipo riga per scadenza fornitore     *
      *    *-----------------------------------------------------------*
       acc-tip-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione valore di default              *
      *                  *---------------------------------------------*
           if       (w-rg2-tip-rig (1)    =    spaces) and
                    (w-tes-tip-ope        =    0011 or
                     w-tes-tip-ope        =    0012 or
                     w-tes-tip-ope        =    0022 or
                     w-tes-tip-ope        =    0033 or
                     w-tes-tip-ope        =    0111 or
                     w-tes-tip-ope        =    0112 or
                     w-tes-tip-ope        =    0222 or
                     w-tes-tip-ope        =    0333  )
                     move  "BB  "         to   w-rg2-tip-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rg2-tip-rig (1)    to   w-sav-tip-rig          .
       acc-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino valore precedente                *
      *                  *---------------------------------------------*
           move      w-sav-tip-rig        to   w-rg2-tip-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Parametri generici                          *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      20                   to   v-pos                  .
      *                  *---------------------------------------------*
      *                  * Tasti funzione                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Up   : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "UP  "               to   v-pfk (01)             .
      *                      *-----------------------------------------*
      *                      * Down : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-co2    not  = spaces
                     move  "DOWN"         to   v-pfk (02)             .
      *                      *-----------------------------------------*
      *                      * Find : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "FIND"               to   v-pfk (03)             .
      *                      *-----------------------------------------*
      *                      * Insr : sempre ammesso, a meno che non   *
      *                      *        si sia in un record New oppure   *
      *                      *        manchi spazio per l'inserimento  *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        =    spaces and
                     w-cat-rg2-ins        =    spaces
                     move  "INSR"         to   v-pfk (04)             .
      *                      *-----------------------------------------*
      *                      * Do   : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "DO  "               to   v-pfk (05)             .
      *                      *-----------------------------------------*
      *                      * Remv : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "REMV"               to   v-pfk (06)             .
      *                      *-----------------------------------------*
      *                      * Prsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "PRSC"               to   v-pfk (07)             .
      *                      *-----------------------------------------*
      *                      * Nxsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "NXSC"               to   v-pfk (08)             .
      *                      *-----------------------------------------*
      *                      * Back : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sulla prima riga     *
      *                      *-----------------------------------------*
           if        w-cnt-co2-nrg-dac    not  = 1
                     move  "BACK"         to   v-pfk (09)             .
      *                      *-----------------------------------------*
      *                      * Tab  : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'ultima riga e   *
      *                      *        che questa sia in Append         *
      *                      *-----------------------------------------*
           if        w-cat-rg2-new        =    spaces or
                     w-cat-rg2-lst        =    spaces
                     move  "TAB "         to   v-pfk (10)             .
      *                      *-----------------------------------------*
      *                      * Slct : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'unica riga      *
      *                      *-----------------------------------------*
           if        w-cat-rg2-max        not  = 1
                     move  "SLCT"         to   v-pfk (11)             .
      *                      *-----------------------------------------*
      *                      * Valore di accettazione                  *
      *                      *-----------------------------------------*
           move      w-rg2-tip-rig (1)    to   v-alf                  .
       acc-tip-rig-200.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine di accettazione     *
      *                      *-----------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Return                                       *
      *              *-------------------------------------------------*
           if        v-key                =    spaces
                     go to acc-tip-rig-400.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-tip-rig-250.
      *                  *---------------------------------------------*
      *                  * Find su tipi riga                           *
      *                  *---------------------------------------------*
           perform   fnd-tip-rig-000      thru fnd-tip-rig-999        .
           if        w-fnd-tip-rig-sel    not  = spaces
                     go to acc-tip-rig-100.
           move      w-fnd-tip-rig-tri    to   w-rg2-tip-rig (1)
                                               v-alf                  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione tipo riga                   *
      *                  *---------------------------------------------*
           perform   vis-tip-rig-000      thru vis-tip-rig-999        .
           move      spaces               to   v-key                  .
           go to     acc-tip-rig-400.
       acc-tip-rig-250.
      *              *-------------------------------------------------*
      *              * Se Slct                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "SLCT"
                     go to acc-tip-rig-300
           else      go to acc-tip-rig-350.
       acc-tip-rig-300.
      *                  *---------------------------------------------*
      *                  * Conversione numero riga impostato in forma- *
      *                  * to numerico                                 *
      *                  *---------------------------------------------*
           move      v-alf                to   w-cnt-slc-rap-alf      .
           move      zero                 to   w-cnt-slc-rap-num      .
           move      6                    to   w-cnt-wrk-ctr-001      .
           move      5                    to   w-cnt-wrk-ctr-002      .
       acc-tip-rig-310.
           subtract  1                    from w-cnt-wrk-ctr-001      .
           if        w-cnt-wrk-ctr-001   =    zero
                     go to acc-tip-rig-320.
           if        w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   <    "0"   or
                     w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   >    "9"
                     go to acc-tip-rig-310.
           move      w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   to   w-cnt-slc-rap-cif
                                              (w-cnt-wrk-ctr-002)     .
           subtract  1                    from w-cnt-wrk-ctr-002      .
           go to     acc-tip-rig-310.
       acc-tip-rig-320.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato minore di 1 o mag- *
      *                  * maggiore del massimo : reimpostazione       *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    zero       or
                     w-cnt-slc-rap-num    >    w-cat-rg2-max
                     go to acc-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato pari a numero riga *
      *                  * attuale : reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    w-cnt-co2-nrg-dac
                     go to acc-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Preparazione parametri e uscita             *
      *                  *---------------------------------------------*
           move      w-cnt-slc-rap-num    to   w-cnt-slc-num-rig      .
           move      "."                  to   w-cnt-tus-acc-rg2      .
           go to     acc-tip-rig-999.
       acc-tip-rig-350.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rg2
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-rg2
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se premuto un altro tasto funzione non deve es- *
      *              * sere avvenuta variazione del campo d'impostaz.  *
      *              *-------------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     move  "U"            to   w-cnt-tus-acc-rg2
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Down                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DOWN"
                     move  "D"            to   w-cnt-tus-acc-rg2
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rg2
                             go to acc-tip-rig-999
                     else    go to acc-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Se Insr                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "INSR"
                     move  "I"            to   w-cnt-tus-acc-rg2
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rg2
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "TAB "
                     move  "T"            to   w-cnt-tus-acc-rg2
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Back                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "BACK"
                     move  "B"            to   w-cnt-tus-acc-rg2
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Nxsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     move  "N"            to   w-cnt-tus-acc-rg2
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Prsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "PRSC"
                     move  "P"            to   w-cnt-tus-acc-rg2
                     go to acc-tip-rig-999.
       acc-tip-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se impostazione a vuoto                     *
      *                  *    - se in Append : come Down purche' non   *
      *                  *                     ci siano zero righe     *
      *                  *    - altrimenti   : reimpostazione          *
      *                  *---------------------------------------------*
           if        v-alf                =    spaces
                     if    w-cat-rg2-new  not  = spaces and
                           w-cat-rg2-lst  not  = spaces and
                           w-cnt-sts-imp-co2
                                          not  = spaces
                           move  "D"      to   w-cnt-tus-acc-rg2
                           go to acc-tip-rig-999
                     else  go to acc-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Se non e' uno dei tipi previsti si tratta   *
      *                  * come per il tasto Slct                      *
      *                  *---------------------------------------------*
           if        v-alf                not  = "RD  " and
                     v-alf                not  = "IE  " and
                     v-alf                not  = "RIBA" and
                     v-alf                not  = "CDO " and
                     v-alf                not  = "MAV " and
                     v-alf                not  = "RID " and
                     v-alf                not  = "BB  " and
                     v-alf                not  = "CCP " and
                     v-alf                not  = "RB  " and
                     v-alf                not  = "TR  " and
                     v-alf                not  = "PC  "
                     go to acc-tip-rig-300.
      *                  *---------------------------------------------*
      *                  * Se record non New non si ammette la modifi- *
      *                  * ca del valore                               *
      *                  *---------------------------------------------*
           if        w-cat-rg2-new        =    spaces and
                     v-mod                not  = spaces
                     go to acc-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Se tipo tipo documento CEE o Estero, il     *
      *                  * valore non puo' che essere : BB o RID       *
      *                  *---------------------------------------------*
           if       (w-tes-tip-ope        =    0011 or
                     w-tes-tip-ope        =    0012 or
                     w-tes-tip-ope        =    0022 or
                     w-tes-tip-ope        =    0033 or
                     w-tes-tip-ope        =    0111 or
                     w-tes-tip-ope        =    0112 or
                     w-tes-tip-ope        =    0222 or
                     w-tes-tip-ope        =    0333  ) and
                     v-alf                not  = "BB  " and
                     v-alf                not  = "RID "
                     go to acc-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Valore impostato in campo di destinazione   *
      *                  *---------------------------------------------*
           move      v-alf                to   w-rg2-tip-rig (1)      .
       acc-tip-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se riga non New : oltre                     *
      *                  *---------------------------------------------*
           if        w-cat-rg2-new        =    spaces
                     go to acc-tip-rig-800.
      *                  *---------------------------------------------*
      *                  * Determinazione tipo scadenza fornitore      *
      *                  *---------------------------------------------*
           if        w-rg2-tip-rig (1)    =    "RD  "
                     move  01             to   w-rg2-tip-scf (1)
           else if   w-rg2-tip-rig (1)    =    "IE  "
                     move  02             to   w-rg2-tip-scf (1)
           else if   w-rg2-tip-rig (1)    =    "RIBA"
                     move  03             to   w-rg2-tip-scf (1)
           else if   w-rg2-tip-rig (1)    =    "CDO "
                     move  04             to   w-rg2-tip-scf (1)
           else if   w-rg2-tip-rig (1)    =    "MAV "
                     move  05             to   w-rg2-tip-scf (1)
           else if   w-rg2-tip-rig (1)    =    "RID "
                     move  06             to   w-rg2-tip-scf (1)
           else if   w-rg2-tip-rig (1)    =    "BB  "
                     move  07             to   w-rg2-tip-scf (1)
           else if   w-rg2-tip-rig (1)    =    "CCP "
                     move  08             to   w-rg2-tip-scf (1)
           else if   w-rg2-tip-rig (1)    =    "RB  "
                     move  09             to   w-rg2-tip-scf (1)
           else if   w-rg2-tip-rig (1)    =    "TR  "
                     move  10             to   w-rg2-tip-scf (1)
           else if   w-rg2-tip-rig (1)    =    "PC  "
                     move  11             to   w-rg2-tip-scf (1)
           else      move  zero           to   w-rg2-tip-scf (1)      .
      *                  *---------------------------------------------*
      *                  * Determinazione tipo valuta scadenza forni-  *
      *                  * tore                                        *
      *                  *---------------------------------------------*
           if       (w-rg2-tip-scf (1)    =    07    ) and
                    (w-tes-tip-ope        =    0011 or
                     w-tes-tip-ope        =    0012 or
                     w-tes-tip-ope        =    0022 or
                     w-tes-tip-ope        =    0033 or
                     w-tes-tip-ope        =    0111 or
                     w-tes-tip-ope        =    0112 or
                     w-tes-tip-ope        =    0222 or
                     w-tes-tip-ope        =    0333  )
                     move  02             to   w-rg2-tvl-scf (1)
