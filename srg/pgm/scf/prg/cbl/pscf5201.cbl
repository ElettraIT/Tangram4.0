           move      rf-sfs-dts-scf       to   srt-dts-eff            .
           move      w-let-arc-dcf-rsu    to   srt-rag-key            .
           move      rf-sfs-cod-fnt       to   srt-cod-fnt            .
           move      rf-sfs-dpz-fnt       to   srt-dpz-fnt            .
           move      rf-sfs-num-scf       to   srt-num-scf            .
           move      rf-sfs-tip-scf       to   srt-tip-scf            .
           move      rf-sfs-sgl-vlt       to   srt-sgl-vlt            .
           move      rf-sfs-dec-vlt       to   srt-dec-vlt            .
           move      rf-sfs-imp-scf       to   srt-imp-scf            .
           if        rf-sfs-tip-ddr       =    11
                     multiply -1          by   srt-imp-scf            .
           move      rf-sfs-snx-pbl       to   srt-snx-pbl            .
           move      w-let-arc-dcf-rag    to   srt-rag-soc            .
           move      rf-sfs-num-ddr       to   srt-num-ddr            .
           move      rf-sfs-dat-ddr       to   srt-dat-ddr            .
           move      rf-sfs-imp-ddr       to   srt-imp-ddr            .
           if        rf-sfs-tip-ddr       =    11
                     multiply -1          by   srt-imp-ddr            .
      *                      *-----------------------------------------*
      *                      * Rilascio del record al Sort             *
      *                      *-----------------------------------------*
           release   srt-rec                                          .
      *                      *-----------------------------------------*
      *                      * Riciclo su Read Next [sfs]              *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-220.
       stp-srt-inp-300.
