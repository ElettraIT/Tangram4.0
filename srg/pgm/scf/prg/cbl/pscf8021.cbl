                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione delle richieste          *
      *              *-------------------------------------------------*
           if        rr-dat-car           not  = zero
                     go to stp-srt-inp-030
           else if   rr-cod-fnt           not  = zero
                     go to stp-srt-inp-050
           else      go to stp-srt-inp-100.
       stp-srt-inp-030.
      *              *-------------------------------------------------*
      *              * Start su archivio [xft] per data caricamento    *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CARNOM    "         to   f-key                  .
           move      rr-dat-car           to   rf-xft-dat-car         .
           move      spaces               to   rf-xft-nom-xml         .
           move      "pgm/scf/fls/ioc/obj/iofxft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-xft                 .
      *                  *---------------------------------------------*
      *                  * Test su esito start                         *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A Read Next                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-050.
      *              *-------------------------------------------------*
      *              * Start su archivio [xft] per fornitore           *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "FNTDDO    "         to   f-key                  .
           move      rr-cod-fnt           to   rf-xft-cod-fnt         .
           move      rr-dat-min           to   rf-xft-ddo-ftf         .
           move      spaces               to   rf-xft-nom-xml         .
           move      "pgm/scf/fls/ioc/obj/iofxft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-xft                 .
      *                  *---------------------------------------------*
      *                  * Test su esito start                         *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A Read Next                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Start su archivio [xft] per data registrazione  *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DDONOM    "         to   f-key                  .
           move      rr-dat-min           to   rf-xft-ddo-ftf         .
           move      spaces               to   rf-xft-nom-xml         .
           move      "pgm/scf/fls/ioc/obj/iofxft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-xft                 .
      *                  *---------------------------------------------*
      *                  * Test su esito start                         *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A Read Next                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Read-next su archivio [xft]                     *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofxft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-xft                 .
      *                  *---------------------------------------------*
      *                  * Test su esito start                         *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione delle richieste      *
      *                  *---------------------------------------------*
           if        rr-dat-car           not  = zero
                     go to stp-srt-inp-310
           else if   rr-cod-fnt           not  = zero
                     go to stp-srt-inp-320
           else      go to stp-srt-inp-330.
       stp-srt-inp-310.
      *                  *---------------------------------------------*
      *                  * Test su data caricamento                    *
      *                  *---------------------------------------------*
           if        rf-xft-dat-car       not  = rr-dat-car
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A Selezioni                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-400.
       stp-srt-inp-320.
      *                  *---------------------------------------------*
      *                  * Test su codice fornitore                    *
      *                  *---------------------------------------------*
           if        rf-xft-cod-fnt       not  = rr-cod-fnt or
                     rf-xft-ddo-ftf       >    rr-dat-max
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A Selezioni                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-400.
       stp-srt-inp-330.
      *                  *---------------------------------------------*
      *                  * Test su data documento                      *
      *                  *---------------------------------------------*
           if        rf-xft-ddo-ftf       >    rr-dat-max
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A Selezioni                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-400.
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni sul record [xft]                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice fornitore                    *
      *                  *---------------------------------------------*
           if        rr-cod-fnt           =    zero
                     go to stp-srt-inp-410.
           if        rf-xft-cod-fnt       not  = rr-cod-fnt
                     go to stp-srt-inp-200.
       stp-srt-inp-410.
      *                  *---------------------------------------------*
      *                  * Test su tipo documento                      *
      *                  *---------------------------------------------*
           if        rr-tdo-sdi           =    spaces
                     go to stp-srt-inp-420.
           if        rf-xft-tdo-ftf       not  = rr-tdo-sdi
                     go to stp-srt-inp-200.
       stp-srt-inp-420.
      *                  *---------------------------------------------*
      *                  * Test su numero documento                    *
      *                  *---------------------------------------------*
           if        rr-num-doc           =    spaces
                     go to stp-srt-inp-430.
           if        rf-xft-ndo-ftf       not  = rr-num-doc
                     go to stp-srt-inp-200.
       stp-srt-inp-430.
      *                  *---------------------------------------------*
      *                  * Test su data caricamento                    *
      *                  *---------------------------------------------*
           if        rr-dat-car           =    zero
                     go to stp-srt-inp-440.
           if        rf-xft-dat-car       not  = rr-dat-car
                     go to stp-srt-inp-200.
       stp-srt-inp-440.
      *                  *---------------------------------------------*
      *                  * Test su data min                            *
      *                  *---------------------------------------------*
           if        rr-dat-min           =    zero
                     go to stp-srt-inp-450.
           if        rf-xft-ddo-ftf       <    rr-dat-min
                     go to stp-srt-inp-200.
       stp-srt-inp-450.
      *                  *---------------------------------------------*
      *                  * Test su data max                            *
      *                  *---------------------------------------------*
           if        rr-dat-max           =    zero
                     go to stp-srt-inp-460.
           if        rf-xft-ddo-ftf       >    rr-dat-max
                     go to stp-srt-inp-200.
       stp-srt-inp-460.
      *                  *---------------------------------------------*
      *                  * Test su si/no senza codice fornitore        *
      *                  *---------------------------------------------*
           if        rr-sns-cdf           not  = 2
                     go to stp-srt-inp-500.
           if        rf-xft-cod-fnt       not  = zero
                     go to stp-srt-inp-200.
       stp-srt-inp-500.
      *              *-------------------------------------------------*
      *              * Preparazione record di Sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione iniziale                    *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Chiave di sort                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Data caricamento                        *
      *                      *-----------------------------------------*
           move      rf-xft-dat-car       to   srt-dat-car            .
      *                      *-----------------------------------------*
      *                      * Nome file                               *
      *                      *-----------------------------------------*
           move      rf-xft-nom-xml       to   srt-nom-xml            .
      *                  *---------------------------------------------*
      *                  * Dati di sort                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo documento                          *
      *                      *-----------------------------------------*
           move      rf-xft-tdo-ftf       to   srt-tip-doc            .
      *                      *-----------------------------------------*
      *                      * Codice archivio                         *
      *                      *-----------------------------------------*
           move      rf-xft-cod-fnt       to   srt-cod-arc            .
      *                      *-----------------------------------------*
      *                      * Codice dipendenza archivio              *
      *                      *-----------------------------------------*
           move      rf-xft-dpz-fnt       to   srt-dpz-arc            .
      *                      *-----------------------------------------*
      *                      * Ragione sociale archivio                *
      *                      *-----------------------------------------*
           move      rf-xft-rag-ftf       to   srt-rag-arc            .
      *                      *-----------------------------------------*
      *                      * Data documento                          *
      *                      *-----------------------------------------*
           move      rf-xft-ddo-ftf       to   srt-dat-doc            .
      *                      *-----------------------------------------*
      *                      * Numero documento                        *
      *                      *-----------------------------------------*
           move      rf-xft-ndo-ftf       to   srt-num-doc            .
      *                      *-----------------------------------------*
      *                      * Totale documento                        *
      *                      *-----------------------------------------*
           move      rf-xft-tot-ftf       to   srt-tot-doc            .
      *                      *-----------------------------------------*
      *                      * Nome file                               *
      *                      *-----------------------------------------*
           move      rf-xft-nom-xml       to   srt-nom-xml            .
      *                      *-----------------------------------------*
      *                      * Nome allegato                           *
      *                      *-----------------------------------------*
           move      rf-xft-nom-att       to   srt-nom-att            .
       stp-srt-inp-700.
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Riciclo a record [xft] successivo               *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-999.
           exit.

