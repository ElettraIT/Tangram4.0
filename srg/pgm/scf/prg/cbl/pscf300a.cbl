           move      "pgm/gep/fls/ioc/obj/iofobp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-obp                 .
       pos-cnf-mod-999.
           exit.

      *    *===========================================================*
      *    * Determinazione del tipo di modifica intervenuta nell'ope- *
      *    * razione di registrazione, e dei relativi flags indicatori *
      *    *-----------------------------------------------------------*
       det-mod-reg-000.
      *              *-------------------------------------------------*
      *              * Flags a Spaces                                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-mod-reg-rec-sfs      .
           move      spaces               to   w-mod-reg-cge-scf      .
       det-mod-reg-100.
      *              *-------------------------------------------------*
      *              * Tests su campi interessati                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Data di scadenza                            *
      *                  *---------------------------------------------*
           if        w-tes-dts-scf (1)    not  = w-tes-dts-scf (2)
                     move  "#"            to   w-mod-reg-rec-sfs      .
      *                  *---------------------------------------------*
      *                  * Codice fornitore                            *
      *                  *---------------------------------------------*
           if        w-tes-cod-fnt (1)    not  = w-tes-cod-fnt (2)
                     move  "#"            to   w-mod-reg-rec-sfs
                     move  "#"            to   w-mod-reg-cge-scf      .
      *                  *---------------------------------------------*
      *                  * Codice dipendenza del fornitore             *
      *                  *---------------------------------------------*
           if        w-tes-dpz-fnt (1)    not  = w-tes-dpz-fnt (2)
                     move  "#"            to   w-mod-reg-rec-sfs      .
      *                  *---------------------------------------------*
      *                  * Inoltro scadenza al fornitore               *
      *                  *---------------------------------------------*
           if        w-tes-inl-scf (1)    not  = w-tes-inl-scf (2)
                     move  "#"            to   w-mod-reg-rec-sfs      .
      *                  *---------------------------------------------*
      *                  * Parametri valuta                            *
      *                  *---------------------------------------------*
           if        w-tes-sgl-vlt (1)    not  = w-tes-sgl-vlt (2) or
                     w-tes-dec-vlt (1)    not  = w-tes-dec-vlt (2) or
                     w-tes-tdc-vlt (1)    not  = w-tes-tdc-vlt (2)
                     move  "#"            to   w-mod-reg-rec-sfs      .
      *                  *---------------------------------------------*
      *                  * Coefficiente di cambio                      *
      *                  *---------------------------------------------*
           if        w-tes-cdc-scf (1)    not  = w-tes-cdc-scf (2)
                     move  "#"            to   w-mod-reg-rec-sfs      .
      *                  *---------------------------------------------*
      *                  * Importo scadenza, in valuta                 *
      *                  *---------------------------------------------*
           if        w-tes-iiv-scf (1)    not  = w-tes-iiv-scf (2)
                     move  "#"            to   w-mod-reg-rec-sfs      .
      *                  *---------------------------------------------*
      *                  * Importo scadenza                            *
      *                  *---------------------------------------------*
           if        w-tes-imp-scf (1)    not  = w-tes-imp-scf (2)
                     move  "#"            to   w-mod-reg-rec-sfs
                     move  "#"            to   w-mod-reg-cge-scf      .
      *                  *---------------------------------------------*
      *                  * Data documento di riferimento               *
      *                  *---------------------------------------------*
           if        w-tes-dat-ddr (1)    not  = w-tes-dat-ddr (2)
                     move  "#"            to   w-mod-reg-rec-sfs
                     move  "#"            to   w-mod-reg-cge-scf      .
      *                  *---------------------------------------------*
      *                  * Numero documento di riferimento             *
      *                  *---------------------------------------------*
           if        w-tes-num-ddr (1)    not  = w-tes-num-ddr (2)
                     move  "#"            to   w-mod-reg-rec-sfs
                     move  "#"            to   w-mod-reg-cge-scf      .
      *                  *---------------------------------------------*
      *                  * Tipo documento di riferimento               *
      *                  *---------------------------------------------*
           if        w-tes-tip-ddr (1)    not  = w-tes-tip-ddr (2)
                     move  "#"            to   w-mod-reg-rec-sfs      .
      *                  *---------------------------------------------*
      *                  * Importo documento di riferimento            *
      *                  *---------------------------------------------*
           if        w-tes-imp-ddr (1)    not  = w-tes-imp-ddr (2)
                     move  "#"            to   w-mod-reg-rec-sfs      .
      *                  *---------------------------------------------*
      *                  * Numero rata documento di riferimento        *
      *                  *---------------------------------------------*
           if        w-tes-nra-ddr (1)    not  = w-tes-nra-ddr (2)
                     move  "#"            to   w-mod-reg-rec-sfs      .
      *                  *---------------------------------------------*
      *                  * Codice ABI del fornitore                    *
      *                  *---------------------------------------------*
           if        w-tes-abi-fnt (1)    not  = w-tes-abi-fnt (2)
                     move  "#"            to   w-mod-reg-rec-sfs      .
      *                  *---------------------------------------------*
      *                  * Codice CAB del fornitore                    *
      *                  *---------------------------------------------*
           if        w-tes-cab-fnt (1)    not  = w-tes-cab-fnt (2)
                     move  "#"            to   w-mod-reg-rec-sfs      .
      *                  *---------------------------------------------*
      *                  * Conto corrente bancario o postale fornitore *
      *                  *---------------------------------------------*
           if        w-tes-ccc-fnt (1)    not  = w-tes-ccc-fnt (2)
                     move  "#"            to   w-mod-reg-rec-sfs      .
      *                  *---------------------------------------------*
      *                  * Codice nostra banca d'appoggio              *
      *                  *---------------------------------------------*
           if        w-tes-cbp-nsb (1)    not  = w-tes-cbp-nsb (2)
                     move  "#"            to   w-mod-reg-rec-sfs      .
      *                  *---------------------------------------------*
      *                  * Dati banca estera                           *
      *                  *---------------------------------------------*
           if        w-tes-cod-bef (1)    not  = w-tes-cod-bef (2)
                     move  "#"            to   w-mod-reg-rec-sfs      .
      *                  *---------------------------------------------*
      *                  * Si/No pagamento bloccato                    *
      *                  *---------------------------------------------*
           if        w-tes-snx-pbl (1)    not  = w-tes-snx-pbl (2)
                     move  "#"            to   w-mod-reg-rec-sfs      .
      *                  *---------------------------------------------*
      *                  * Obbligato principale                        *
      *                  *---------------------------------------------*
           if        w-tes-obp-rag-obp (1)
                                          not  = w-tes-obp-rag-obp (2)
                     move  "#"            to   w-mod-reg-rec-sfs      .
           if        w-tes-obp-via-obp (1)
                                          not  = w-tes-obp-via-obp (2)
                     move  "#"            to   w-mod-reg-rec-sfs      .
           if        w-tes-obp-loc-obp (1)
                                          not  = w-tes-obp-loc-obp (2)
                     move  "#"            to   w-mod-reg-rec-sfs      .
       det-mod-reg-999.
           exit.

      *    *===========================================================*
      *    * Routine post-conferma di annullamento                     *
      *    *-----------------------------------------------------------*
       pos-cnf-ann-000.
      *              *-------------------------------------------------*
      *              * Annullamento del movimento di contabilita' ge-  *
      *              * nerale che era stato a suo tempo generato a     *
      *              * fronte del movimento scadenze fornitori di re-  *
      *              * gistrazione                                     *
      *              *-------------------------------------------------*
           move      w-tes-drc-rgs (2)    to    w-cge-scf-drc-del     .
           move      w-tes-npc-rgs (2)    to    w-cge-scf-npc-del     .
           perform   del-cge-scf-000      thru del-cge-scf-999        .
       pos-cnf-ann-100.
      *              *-------------------------------------------------*
      *              * Composizione records [sfs] e [obp]              *
      *              *-------------------------------------------------*
           perform   cmp-sfs-obp-000      thru cmp-sfs-obp-999        .
       pos-cnf-ann-200.
      *              *-------------------------------------------------*
      *              * Delete record [sfs]                             *
      *              *-------------------------------------------------*
           move      "DE"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfs                 .
       pos-cnf-ann-300.
      *              *-------------------------------------------------*
      *              * Delete record [obp]                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo operazione                     *
      *                  *---------------------------------------------*
           if        w-tes-tip-ope        not  = 1127 and
                     w-tes-tip-ope        not  = 1161
                     go to pos-cnf-ann-999.
      *                  *---------------------------------------------*
      *                  * Esecuzione delete record                    *
      *                  *---------------------------------------------*
           move      "DE"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofobp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-obp                 .
       pos-cnf-ann-999.
           exit.

      *    *===========================================================*
      *    * Composizione records [sfs] e [obp]                        *
      *    *-----------------------------------------------------------*
       cmp-sfs-obp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record [sfs]                    *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfs                 .
      *              *-------------------------------------------------*
      *              * Composizione record [sfs]                       *
      *              *-------------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rf-sfs-ide-dat         .
           move      s-ute                to   rf-sfs-ide-ute         .
           move      s-fas                to   rf-sfs-ide-fas         .
           move      w-tes-dat-reg        to   rf-sfs-dtr-rgs         .
           move      w-tes-drc-rgs (1)    to   rf-sfs-drc-rgs         .
           move      w-tes-npc-rgs (1)    to   rf-sfs-npc-rgs         .
           move      w-tes-prt-ffo (1)    to   rf-sfs-prt-ffo         .
           move      w-tes-num-scf        to   rf-sfs-num-scf         .
           move      w-tes-tip-scf (1)    to   rf-sfs-tip-scf         .
           move      w-tes-trs-scf (1)    to   rf-sfs-trs-scf         .
           move      w-tes-tvl-scf (1)    to   rf-sfs-tvl-scf         .
           move      w-tes-dts-scf (1)    to   rf-sfs-dts-scf         .
           move      w-tes-cod-fnt (1)    to   rf-sfs-cod-fnt         .
           move      w-tes-dpz-fnt (1)    to   rf-sfs-dpz-fnt         .
           move      w-tes-inl-scf (1)    to   rf-sfs-inl-scf         .
           move      w-tes-sgl-vlt (1)    to   rf-sfs-sgl-vlt         .
           move      w-tes-dec-vlt (1)    to   rf-sfs-dec-vlt         .
           move      w-tes-tdc-vlt (1)    to   rf-sfs-tdc-vlt         .
           move      w-tes-cdc-scf (1)    to   rf-sfs-cdc-scf         .
           move      w-tes-iiv-scf (1)    to   rf-sfs-iiv-scf         .
           move      w-tes-imp-scf (1)    to   rf-sfs-imp-scf         .
           move      w-tes-dat-ddr (1)    to   rf-sfs-dat-ddr         .
           move      w-tes-num-ddr (1)    to   rf-sfs-num-ddr         .
           move      w-tes-tip-ddr (1)    to   rf-sfs-tip-ddr         .
           move      w-tes-imp-ddr (1)    to   rf-sfs-imp-ddr         .
           move      w-tes-nra-ddr (1)    to   rf-sfs-nra-ddr         .
           move      w-tes-abi-fnt (1)    to   rf-sfs-abi-fnt         .
           move      w-tes-cab-fnt (1)    to   rf-sfs-cab-fnt         .
           move      w-tes-ccc-fnt (1)    to   rf-sfs-ccc-fnt         .
           move      w-tes-cbp-nsb (1)    to   rf-sfs-cbp-nsb         .
           move      w-tes-cod-bef (1)    to   rf-sfs-cod-bef         .
           move      w-tes-snx-pbl (1)    to   rf-sfs-snx-pbl         .
           move      w-tes-dtr-sto (1)    to   rf-sfs-dtr-sto         .
           move      w-tes-drc-sto (1)    to   rf-sfs-drc-sto         .
           move      w-tes-npc-sto (1)    to   rf-sfs-npc-sto         .
           move      w-tes-rns-sto (1)    to   rf-sfs-rns-sto         .
           move      w-tes-nns-sto (1)    to   rf-sfs-nns-sto         .
           move      w-tes-tns-sto (1)    to   rf-sfs-tns-sto         .
           move      w-tes-num-pgf (1)    to   rf-sfs-num-pgf         .
           move      w-tes-fcs-uno (1)    to   rf-sfs-fcs-uno         .
           move      w-tes-fcs-due (1)    to   rf-sfs-fcs-due         .
           move      w-tes-fcs-tre (1)    to   rf-sfs-fcs-tre         .
           move      w-tes-flg-ela (1)    to   rf-sfs-flg-ela         .
           move      w-tes-flg-pul (1)    to   rf-sfs-flg-pul         .
           move      w-tes-alx-exp (1)    to   rf-sfs-alx-exp         .
       cmp-sfs-obp-200.
      *              *-------------------------------------------------*
      *              * Normalizzazione record [obp]                    *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofobp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-obp                 .
      *                  *---------------------------------------------*
      *                  * In caso di presenza di obbligato principale *
      *                  *---------------------------------------------*
           if        w-tes-tip-ope        not  = 1161
                     go to cmp-sfs-obp-999.
      *                      *-----------------------------------------*
      *                      * Composizione                            *
      *                      *-----------------------------------------*
           move      51                   to   rf-obp-tip-obp         .
           move      w-tes-num-scf        to   rf-obp-num-obp         .
           move      w-tes-obp-rag-obp (1)
                                          to   rf-obp-rag-obp         .
           move      w-tes-obp-via-obp (1)
                                          to   rf-obp-via-obp         .
           move      w-tes-obp-loc-obp (1)
                                          to   rf-obp-loc-obp         .
           move      spaces               to   rf-obp-alx-exp         .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     cmp-sfs-obp-999.
       cmp-sfs-obp-999.
           exit.

      *    *===========================================================*
      *    * Test Si/No aggiornamenti contabili da gestione scadenze   *
      *    * fornitori per i movimenti di registrazione                *
      *    *-----------------------------------------------------------*
       cge-scf-reg-snx-000.
      *              *-------------------------------------------------*
      *              * Se le personalizzazioni indicano che in ogni    *
      *              * caso gli aggiornamenti contabili non devono     *
      *              * essere eseguiti : uscita con 'N'                *
      *              *-------------------------------------------------*
           if        w-prs-scf-snx-cge    =    "N"
                     move  "N"            to   w-cge-scf-reg-snx
                     go to cge-scf-reg-snx-999.
      *              *-------------------------------------------------*
      *              * Se il codice causale contabile per il tipo ope- *
      *              * razione di registrazione e' a zero : uscita con *
      *              * 'N'                                             *
      *              *-------------------------------------------------*
           if        w-top-cau-cge
                    (w-top-ele-inx)       =    zero
                     move  "N"            to   w-cge-scf-reg-snx
                     go to cge-scf-reg-snx-999.
      *              *-------------------------------------------------*
      *              * Se il codice sottoconto contabile per il tipo   *
      *              * operazione di registrazione e' a zero : uscita  *
      *              * con 'N'                                         *
      *              *-------------------------------------------------*
           if        w-top-stc-cge
                    (w-top-ele-inx)       =    zero
                     move  "N"            to   w-cge-scf-reg-snx
                     go to cge-scf-reg-snx-999.
      *              *-------------------------------------------------*
      *              * Altrimenti : uscita con 'S'                     *
      *              *-------------------------------------------------*
           move      "S"                  to   w-cge-scf-reg-snx      .
       cge-scf-reg-snx-999.
           exit.

      *    *===========================================================*
      *    * Aggiornamenti contabili generati dalla gestione scadenze  *
      *    * fornitori a fronte del movimento di registrazione         *
      *    *                                                           *
      *    * Nota : Vedere i commenti per il modulo 'pscf3000' per le  *
      *    *        generalita' sugli aggiornamenti contabili riguar-  *
      *    *        danti la gestione scadenze passive.                *
      *    *-----------------------------------------------------------*
       cge-scf-reg-000.
      *              *-------------------------------------------------*
      *              * Se si e' in modifica di una registrazione che   *
      *              * non aveva generato nessun movimento contabile,  *
      *              * non si genera il movimento contabile            *
      *              *-------------------------------------------------*
           if       (w-cnt-mfu-tip-fun    =    "M"   ) and
                    (w-tes-drc-rgs (1)    =    zero or
                     w-tes-npc-rgs (1)    =    zero  )
                     go to cge-scf-reg-100.
      *              *-------------------------------------------------*
      *              * Test se aggiornamento da eseguire               *
      *              *-------------------------------------------------*
           perform   cge-scf-reg-snx-000  thru cge-scf-reg-snx-999    .
      *              *-------------------------------------------------*
      *              * Se Si' : ad aggiornamenti                       *
      *              *-------------------------------------------------*
           if        w-cge-scf-reg-snx    =    "S"
                     go to cge-scf-reg-200.
       cge-scf-reg-100.
      *              *-------------------------------------------------*
      *              * Se No                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Data registrazione movimento contabile : a  *
      *                  * zero                                        *
      *                  *---------------------------------------------*
           move      zero                 to   l-cge-300-dat-reg      .
      *                  *---------------------------------------------*
      *                  * Numero protocollo movimento contabile : a   *
      *                  * zero                                        *
      *                  *---------------------------------------------*
           move      zero                 to   l-cge-300-num-prt      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     cge-scf-reg-999.
       cge-scf-reg-200.
      *              *-------------------------------------------------*
      *              * Esecuzione aggiornamento contabile : viene ese- *
      *              * guita una registrazione con il seguente forma-  *
      *              * to :                                            *
      *              *                                                 *
      *              * - Dare  : Fornitore                             *
      *              * - Avere : Sottoconto contabile per registrazio- *
      *              *           ne scadenza                           *
      *              *                                                 *
      *              *-------------------------------------------------*
       cge-scf-reg-300.
      *                  *---------------------------------------------*
      *                  * Normalizzazione work-area testata e prima   *
      *                  * riga movimento per aggiornamenti contabili  *
      *                  *---------------------------------------------*
           move      "NO"                 to   l-cge-300-tip-ope      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                  *---------------------------------------------*
      *                  * Preparazione link-area per testata e prima  *
      *                  * riga movimento                              *
      *                  *                                             *
      *                  * Nota : i seguenti campi non vengono prepa-  *
      *                  *        rati in quanto gia' normalizzati :   *
      *                  *                                             *
      *                  *        - Numero protocollo                  *
      *                  *        - Descrizione per codice causale     *
      *                  *        - Codice numerazione                 *
      *                  *        - Numero protocollo Iva              *
      *                  *        - Commento in riga                   *
      *                  *        - Castelletto Iva                    *
      *                  *        - Totale documento Iva               *
      *                  *                                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo operazione                         *
      *                      *-----------------------------------------*
           move      "WR"                 to   l-cge-300-tip-ope      .
      *                      *-----------------------------------------*
      *                      * Data di registrazione                   *
      *                      *                                         *
      *                      * Nota : Se pre-esiste una data registra- *
      *                      *        zione contabile la si conserva   *
      *                      *        comunque.                        *
      *                      *                                         *
      *                      *        Cio' per salvaguardare eventua-  *
      *                      *        li date di registrazione conta-  *
      *                      *        bile diverse dalla data di regi- *
      *                      *        strazione movimento, come avvie- *
      *                      *        ne per esempio con le scadenze   *
      *                      *        indotte da una registrazione di  *
      *                      *        fattura fornitore in cui la da-  *
      *                      *        ta contabile sia stata forzata.  *
      *                      *-----------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "I"
                     move  w-tes-dat-reg  to   l-cge-300-dat-reg
           else if   w-tes-drc-rgs (2)    not  = zero
                     move  w-tes-drc-rgs (2)
                                          to   l-cge-300-dat-reg
           else      move  w-tes-dat-reg  to   l-cge-300-dat-reg      .
      *                      *-----------------------------------------*
      *                      * Codice causale contabile                *
      *                      *-----------------------------------------*
           move      w-top-cau-cge
                    (w-top-ele-inx)       to   l-cge-300-cod-cau      .
      *                      *-----------------------------------------*
      *                      * Descrizione causale                     *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-des-cau      .
      *                      *-----------------------------------------*
      *                      * Si/No data scadenza                     *
      *                      *-----------------------------------------*
           move      "N"                  to   l-cge-300-snx-dts      .
      *                      *-----------------------------------------*
      *                      * Data scadenza                           *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-dat-sca      .
      *                      *-----------------------------------------*
      *                      * Data documento                          *
      *                      *-----------------------------------------*
           move      w-tes-dat-reg        to   l-cge-300-dat-doc      .
      *                      *-----------------------------------------*
      *                      * Numero documento                        *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      w-tes-num-scf        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   l-cge-300-num-doc      .
      *                      *-----------------------------------------*
      *                      * Codice sottoconto                       *
      *                      *-----------------------------------------*
           move      w-tes-cod-fnt-cge (1)
                                          to   l-cge-300-cod-pdc      .
      *                      *-----------------------------------------*
      *                      * Tipo archivio                           *
      *                      *-----------------------------------------*
           move      "F"                  to   l-cge-300-tip-arc      .
      *                      *-----------------------------------------*
      *                      * Codice archivio                         *
      *                      *-----------------------------------------*
           move      w-tes-cod-fnt (1)    to   l-cge-300-cod-arc      .
      *                      *-----------------------------------------*
      *                      * Data riferimento                        *
      *                      *-----------------------------------------*
           move      w-tes-dat-ddr (1)    to   l-cge-300-dat-rif      .
      *                      *-----------------------------------------*
      *                      * Numero riferimento                      *
      *                      *-----------------------------------------*
           move      w-tes-num-ddr (1)    to   l-cge-300-num-rif      .
      *                      *-----------------------------------------*
      *                      * Dare/Avere                              *
      *                      *-----------------------------------------*
           move      "D"                  to   l-cge-300-dar-ave      .
      *                      *-----------------------------------------*
      *                      * Importo movimento                       *
      *                      *-----------------------------------------*
