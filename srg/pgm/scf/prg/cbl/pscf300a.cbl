      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-inl-scf-lun    to   v-car                  .
           move      w-exp-inl-scf-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-inl-scf-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
