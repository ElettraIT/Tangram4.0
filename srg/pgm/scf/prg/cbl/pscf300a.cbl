      *    *===========================================================*
      *    * Accettazione campo : Numero scadenza fornitore            *
      *    *-----------------------------------------------------------*
       acc-num-scf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-num-scf-025.
      *                  *---------------------------------------------*
      *                  * Se in fase di registrazione nuova scadenza  *
      *                  * a fronte dell'operazione appena completata  *
      *                  * si forza il valore zero, in modo da forza-  *
      *                  * re il prelevamento automatico di un numero  *
      *                  * scadenza progressivo, e si continua dopo    *
      *                  * l'accettazione stessa                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se non in fase di registrazione nuova   *
      *                      * scadenza a fronte dell'operazione appe- *
      *                      * na completata : ad accettazione         *
      *                      *-----------------------------------------*
           if        w-key-flg-rns        =    spaces
                     go to acc-num-scf-100.
      *                      *-----------------------------------------*
      *                      * Zero in numero scadenza                 *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-num-scf          .
      *                      *-----------------------------------------*
      *                      * Normalizzazione function-key di impo-   *
      *                      * stazione                                *
      *                      *-----------------------------------------*
           move      spaces               to   v-key                  .
      *                      *-----------------------------------------*
      *                      * A post accettazione                     *
      *                      *-----------------------------------------*
           go to     acc-num-scf-400.
       acc-num-scf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se viene eseguita l'accettazione effettiva  *
      *                  * si pone comunque in Off il flag di regi-    *
      *                  * strazionene nuova scadenza a fronte dell'o- *
      *                  * perazione appena completata                 *
      *                  *---------------------------------------------*
           move      spaces               to   w-key-flg-rns          .
      *                  *---------------------------------------------*
      *                  * Accettazione effettiva                      *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      06                   to   v-lin                  .
           move      22                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXPD"               to   v-pfk (12)             .
           move      w-tes-num-scf        to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-num-scf-999.
       acc-num-scf-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-num-scf          .
       acc-num-scf-250.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-num-scf-300.
      *                  *---------------------------------------------*
      *                  * Find su scadenze fornitori                  *
      *                  *---------------------------------------------*
           move      "S"                  to   w-fnd-arc-sfs-sns      .
           move      zero                 to   w-fnd-arc-sfs-fnt      .
           move      spaces               to   w-fnd-arc-sfs-dpf      .
           if        w-tes-tip-ope        =    1101
                     move  01             to   w-fnd-arc-sfs-tip
                     move  01             to   w-fnd-arc-sfs-trs
                     move  01             to   w-fnd-arc-sfs-tvl
           else if   w-tes-tip-ope        =    1102
                     move  02             to   w-fnd-arc-sfs-tip
                     move  01             to   w-fnd-arc-sfs-trs
                     move  01             to   w-fnd-arc-sfs-tvl
           else if   w-tes-tip-ope        =    1103
                     move  03             to   w-fnd-arc-sfs-tip
                     move  01             to   w-fnd-arc-sfs-trs
                     move  01             to   w-fnd-arc-sfs-tvl
           else if   w-tes-tip-ope        =    1104
                     move  04             to   w-fnd-arc-sfs-tip
                     move  01             to   w-fnd-arc-sfs-trs
                     move  01             to   w-fnd-arc-sfs-tvl
           else if   w-tes-tip-ope        =    1105
                     move  05             to   w-fnd-arc-sfs-tip
                     move  01             to   w-fnd-arc-sfs-trs
                     move  01             to   w-fnd-arc-sfs-tvl
           else if   w-tes-tip-ope        =    1106
                     move  06             to   w-fnd-arc-sfs-tip
                     move  01             to   w-fnd-arc-sfs-trs
                     move  01             to   w-fnd-arc-sfs-tvl
           else if   w-tes-tip-ope        =    1107
                     move  07             to   w-fnd-arc-sfs-tip
                     move  01             to   w-fnd-arc-sfs-trs
                     move  01             to   w-fnd-arc-sfs-tvl
           else if   w-tes-tip-ope        =    1108
                     move  08             to   w-fnd-arc-sfs-tip
                     move  01             to   w-fnd-arc-sfs-trs
                     move  01             to   w-fnd-arc-sfs-tvl
           else if   w-tes-tip-ope        =    1109
                     move  09             to   w-fnd-arc-sfs-tip
                     move  01             to   w-fnd-arc-sfs-trs
                     move  01             to   w-fnd-arc-sfs-tvl
           else if   w-tes-tip-ope        =    1110
                     move  10             to   w-fnd-arc-sfs-tip
                     move  01             to   w-fnd-arc-sfs-trs
                     move  01             to   w-fnd-arc-sfs-tvl
           else if   w-tes-tip-ope        =    1111
                     move  11             to   w-fnd-arc-sfs-tip
                     move  01             to   w-fnd-arc-sfs-trs
                     move  01             to   w-fnd-arc-sfs-tvl
           else if   w-tes-tip-ope        =    1127
                     move  07             to   w-fnd-arc-sfs-tip
                     move  01             to   w-fnd-arc-sfs-trs
                     move  02             to   w-fnd-arc-sfs-tvl
           else if   w-tes-tip-ope        =    1161
                     move  11             to   w-fnd-arc-sfs-tip
                     move  02             to   w-fnd-arc-sfs-trs
                     move  01             to   w-fnd-arc-sfs-tvl
           else      move  zero           to   w-fnd-arc-sfs-tip
                     move  zero           to   w-fnd-arc-sfs-trs
                     move  zero           to   w-fnd-arc-sfs-tvl      .
           move      spaces               to   w-fnd-arc-sfs-vlt      .
           move      "N"                  to   w-fnd-arc-sfs-sdp      .
           perform   fnd-arc-sfs-000      thru fnd-arc-sfs-999        .
      *                  *---------------------------------------------*
      *                  * Se selezione non effettuata : a reimposta-  *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           if        w-fnd-arc-sfs-sel    not  = spaces
                     go to acc-num-scf-100.
      *                  *---------------------------------------------*
      *                  * Ripresa numero scadenza selezionata         *
      *                  *---------------------------------------------*
           move      w-fnd-arc-sfs-num    to   w-tes-num-scf          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione numero scadenza selezionata *
      *                  *---------------------------------------------*
           perform   vis-num-scf-000      thru vis-num-scf-999        .
      *                  *---------------------------------------------*
      *                  * Forzatura simulata del tasto Do             *
      *                  *---------------------------------------------*
           move      "DO  "               to   v-key                  .
           go to     acc-num-scf-400.
       acc-num-scf-300.
      *              *-------------------------------------------------*
      *              * Se Expd                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "EXPD"
                     go to acc-num-scf-400.
      *                  *---------------------------------------------*
      *                  * Espansione su scadenze fornitori            *
      *                  *---------------------------------------------*
           move      "S"                  to   w-esp-arc-sfs-sns      .
           move      w-tes-num-scf        to   w-esp-arc-sfs-num      .
           perform   esp-arc-sfs-000      thru esp-arc-sfs-999        .
      *                  *---------------------------------------------*
      *                  * Se selezione non effettuata : a reimposta-  *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           if        w-esp-arc-sfs-sel    not  = spaces
                     go to acc-num-scf-100.
      *                  *---------------------------------------------*
      *                  * Ripresa numero scadenza selezionata         *
      *                  *---------------------------------------------*
           move      w-esp-arc-sfs-num    to   w-tes-num-scf          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione numero scadenza selezionata *
      *                  *---------------------------------------------*
           perform   vis-num-scf-000      thru vis-num-scf-999        .
      *                  *---------------------------------------------*
      *                  * Forzatura simulata del tasto Do             *
      *                  *---------------------------------------------*
           move      "DO  "               to   v-key                  .
           go to     acc-num-scf-400.
       acc-num-scf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-num-scf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del tasto funzione u-  *
      *                  * tilizzato                                   *
      *                  *---------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-num-scf-650
           else      go to acc-num-scf-700.
       acc-num-scf-650.
      *                  *---------------------------------------------*
      *                  * Se terminazione con tasto Up                *
      *                  *---------------------------------------------*
       acc-num-scf-655.
      *                      *-----------------------------------------*
      *                      * Normalizzazione e visualizzazione nume- *
      *                      * ro scadenza                             *
      *                      *-----------------------------------------*
           if        w-tes-num-scf        =    zero
                     go to acc-num-scf-660.
           move      zero                 to   w-tes-num-scf          .
           perform   vis-num-scf-000      thru vis-num-scf-999        .
       acc-num-scf-660.
      *                      *-----------------------------------------*
      *                      * Forzatura del tasto Exit                *
      *                      *-----------------------------------------*
           move      "EXIT"               to   v-key                  .
      *                      *-----------------------------------------*
      *                      * Forzatura del tipo uscita per Up        *
      *                      *-----------------------------------------*
           move      "U"                  to   w-cnt-tus-acc-key      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     acc-num-scf-999.
       acc-num-scf-700.
      *                  *---------------------------------------------*
      *                  * In tutti gli altri casi                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     acc-num-scf-800.
       acc-num-scf-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-num-scf-999.
           perform   cnt-key-vuo-000      thru cnt-key-vuo-999        .
           if        w-cnt-key-vuo-flg    not  = spaces
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-num-scf-999.
           perform   cnt-tdo-key-000      thru cnt-tdo-key-999        .
           if        w-cnt-tdo-key-flg    not  = spaces
                     go to acc-num-scf-100
           else      move  "S"            to   w-cnt-tus-acc-key
                     go to acc-num-scf-999.
       acc-num-scf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Numero scadenza fornitore         *
      *    *-----------------------------------------------------------*
       vis-num-scf-000.
           move      "DS"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      06                   to   v-lin                  .
           move      22                   to   v-pos                  .
           move      w-tes-num-scf        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-num-scf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campi non chiave della registrazione         *
      *    *-----------------------------------------------------------*
       acc-nok-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-nok      .
      *              *-------------------------------------------------*
      *              * Visualizzazione tipo funzionamento              *
      *              *-------------------------------------------------*
           perform   vis-tip-fun-000      thru vis-tip-fun-999        .
      *              *-------------------------------------------------*
      *              * Assestamento status di impostazione se in modi- *
      *              * fica o visualizzazione, per testata             *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "M" or
                     w-cnt-mfu-tip-fun    =    "V"
                     move  "#"            to   w-cnt-sts-imp-tes
                     move  all "#"        to   w-cnt-sts-imp-pte
                     move  all "#"        to   w-cnt-sts-ing-pte      .
       acc-nok-reg-200.
      *              *-------------------------------------------------*
      *              * Trattamento testata                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione del numero di pagine che     *
      *                  * compongono la testata                       *
      *                  *---------------------------------------------*
           perform   dmp-tes-reg-000      thru dmp-tes-reg-999        .
      *                  *---------------------------------------------*
      *                  * Video in 'OFF'                              *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Prompts per campi chiave                    *
      *                  *---------------------------------------------*
           if        w-cnt-sts-pmt-key    =    spaces
                     perform pmt-key-reg-000
                                          thru pmt-key-reg-999
                     move    "#"          to   w-cnt-sts-pmt-key      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione dati campi chiave           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-vis-key    =    spaces
                     perform vis-key-reg-000
                                          thru vis-key-reg-999
                     move    "#"          to   w-cnt-sts-vis-key      .
      *                  *---------------------------------------------*
      *                  * Prompts per pagina di testata               *
      *                  *---------------------------------------------*
           if        w-cnt-sts-pmt-ptx
                    (w-cnt-sts-imp-npt)   =    spaces
                     perform pmt-tes-reg-000
                                          thru pmt-tes-reg-999
                     move    "#"          to   w-cnt-sts-pmt-ptx
                                              (w-cnt-sts-imp-npt)     .
      *                  *---------------------------------------------*
      *                  * Visualizzazione dati pagina testata         *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "M"      or
                     w-cnt-mfu-tip-fun    =    "V"      or
                     w-cnt-sts-imp-ptx
                    (w-cnt-sts-imp-npt)   not  = spaces or
                     w-cnt-sts-ing-ptx
                    (w-cnt-sts-imp-npt)   not  = spaces
                     if    w-cnt-sts-vis-ptx
                          (w-cnt-sts-imp-npt)
                                          =    spaces
                           perform vis-tes-reg-000
                                          thru vis-tes-reg-999
                           move    "#"    to   w-cnt-sts-vis-ptx
                                              (w-cnt-sts-imp-npt)     .
      *                  *---------------------------------------------*
      *                  * Flag di ingresso in pagina di testata       *
      *                  *---------------------------------------------*
