      *    *===========================================================*
      *    * Riaggiornamento della scadenza o del pagamento a fronte   *
      *    * della quale e' stata registrata la nuova scadenza         *
      *    *-----------------------------------------------------------*
       agg-dat-nvs-000.
      *              *-------------------------------------------------*
      *              * Se non in fase di registrazione nuova scadenza  *
      *              * a fronte dell'operazione appena completata : u- *
      *              * scita senza alcuna azione                       *
      *              *-------------------------------------------------*
           if        w-key-flg-rns        =    spaces
                     go to agg-dat-nvs-999.
       agg-dat-nvs-025.
      *              *-------------------------------------------------*
      *              * Se tipo operazione che ha causato la richiesta  *
      *              * di registrazione nuova scadenza non riconosciu- *
      *              * to : uscita senza alcuna azione                 *
      *              *-------------------------------------------------*
           if        w-key-tvo-rns        not  = 1200 and
                     w-key-tvo-rns        not  = 1600
                     go to agg-dat-nvs-999.
       agg-dat-nvs-100.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo operazione che  *
      *              * ha causato la richiesta di registrazione nuova  *
      *              * scadenza                                        *
      *              *-------------------------------------------------*
           if        w-key-tvo-rns        =    1200
                     go to agg-dat-nvs-200
           else if   w-key-tvo-rns        =    1600
                     go to agg-dat-nvs-300.
       agg-dat-nvs-200.
      *              *-------------------------------------------------*
      *              * Se registrazione nuova scadenza a fronte di una *
      *              * operazione di storno                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se numero della scadenza a fronte della     *
      *                  * quale deve essere registrata una nuova sca- *
      *                  * denza a zero : uscita senza alcuna azione   *
      *                  *---------------------------------------------*
           if        w-key-nvs-rns        =    zero
                     go to agg-dat-nvs-999.
      *                  *---------------------------------------------*
      *                  * Aggiornamento record [sfs]                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ottenimento record [sfs]                *
      *                      *-----------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMSCF    "         to   f-key                  .
           move      w-key-nvs-rns        to   rf-sfs-num-scf         .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfs                 .
      *                      *-----------------------------------------*
      *                      * Se record non esistente : uscita        *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-dat-nvs-999.
      *                      *-----------------------------------------*
      *                      * Aggiornamento dati record               *
      *                      *-----------------------------------------*
           move      01                   to   rf-sfs-rns-sto         .
           move      w-tes-num-scf        to   rf-sfs-nns-sto         .
           move      w-tes-tip-scf (1)    to   rf-sfs-tns-sto         .
      *                      *-----------------------------------------*
      *                      * Update record [sfs]                     *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfs                 .
      *                      *-----------------------------------------*
      *                      * Rilascio record [sfs]                   *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfs                 .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     agg-dat-nvs-999.
       agg-dat-nvs-300.
      *              *-------------------------------------------------*
      *              * Se registrazione nuova scadenza a fronte di una *
      *              * operazione di pagamento                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se numero del pagamento a fronte del quale  *
      *                  * deve essere registrata una nuova scadenza   *
      *                  * a zero : uscita senza alcuna azione         *
      *                  *---------------------------------------------*
           if        w-key-nvp-rns        =    zero
                     go to agg-dat-nvs-999.
      *                  *---------------------------------------------*
      *                  * Aggiornamento record [sfp]                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ottenimento record [sfp]                *
      *                      *-----------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMPGF    "         to   f-key                  .
           move      w-key-nvp-rns        to   rf-sfp-num-pgf         .
           move      "pgm/scf/fls/ioc/obj/iofsfp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfp                 .
      *                      *-----------------------------------------*
      *                      * Se record non esistente : uscita        *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-dat-nvs-999.
      *                      *-----------------------------------------*
      *                      * Aggiornamento dati record               *
      *                      *-----------------------------------------*
           move      01                   to   rf-sfp-rns-pgf         .
           move      w-tes-num-scf        to   rf-sfp-nns-pgf         .
           move      w-tes-tip-scf (1)    to   rf-sfp-tns-pgf         .
      *                      *-----------------------------------------*
      *                      * Update record [sfp]                     *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfp                 .
      *                      *-----------------------------------------*
      *                      * Rilascio record [sfp]                   *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfp                 .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     agg-dat-nvs-999.
       agg-dat-nvs-999.
           exit.

      *    *===========================================================*
