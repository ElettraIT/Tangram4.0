      *                      * Assemblaggio                            *
      *                      *-----------------------------------------*
           move      30                   to   w-all-str-lun          .
           move      05                   to   w-all-str-num          .
      *
           if        rf-sfs-tip-ddr       =    01
                     move  "Fattura"      to   w-all-str-cat (1)
           else if   rf-sfs-tip-ddr       =    02
                     move  "Nota di debito"
                                          to   w-all-str-cat (1)
           else      move  "Documento"    to   w-all-str-cat (1)      .
      *
           if        rf-sfs-num-ddr       not  = spaces
