      *                  *---------------------------------------------*
      *                  * File pathname per [0u2]                     *
      *                  *---------------------------------------------*
           move      f-ouf-pat            to   f-ou2-pat              .
      *                  *---------------------------------------------*
      *                  * File status per [0u2]                       *
      *                  *---------------------------------------------*
           move      "00"                 to   f-ou2-sts              .
       ouf-fil-cls-120.
      *                  *---------------------------------------------*
      *                  * Open Extend file [ou2]                      *
      *                  *---------------------------------------------*
           open      extend ou2                                       .
       ouf-fil-cls-130.
      *                  *---------------------------------------------*
      *                  * Soppressione carattere di 'EOF'             *
      *                  *---------------------------------------------*
           go to     ouf-fil-cls-140.
      *                  *---------------------------------------------*
      *                  * Scrittura file [ou2]                        *
      *                  *---------------------------------------------*
           move      x'1A'                to   ou2-chr                .
           write     ou2-rec                                          .
       ouf-fil-cls-140.
      *                  *---------------------------------------------*
      *                  * Close file [ou2]                            *
      *                  *---------------------------------------------*
           close     ou2                                              .
       ouf-fil-cls-999.
           exit.
       ouf-fil-wrt-000.
      *              *=================================================*
      *              * Write file [ouf]                                *
      *              *-------------------------------------------------*
       ouf-fil-wrt-100.
      *                  *---------------------------------------------*
      *                  * Incremento progressivo record emessi        *
      *                  *---------------------------------------------*
           add       1                    to   w-ads-sia-gen-rpt      .
       ouf-fil-wrt-200.
      *                  *---------------------------------------------*
      *                  * Completamento con carattere CR              *
      *                  *---------------------------------------------*
           move      x'0D'                to   ouf-crx                .
       ouf-fil-wrt-200.
      *                  *---------------------------------------------*
      *                  * Completamento con carattere LF              *
      *                  *---------------------------------------------*
           move      x'0A'                to   ouf-lfx                .
       ouf-fil-wrt-300.
      *                  *---------------------------------------------*
      *                  * Scrittura effettiva                         *
      *                  *---------------------------------------------*
           write     ouf-rec                                          .
       ouf-fil-wrt-999.
           exit.

      *    *===========================================================*
      *    * Routine per la scrittura record in file Line-Sequential   *
      *    *                                                           *
      *    * Tipo : UNIX                                               *
      *    *-----------------------------------------------------------*
       put-nxt-seq-000.
      *              *-------------------------------------------------*
      *              * Test su personalizzazione relativa al tipo di   *
      *              * file da emettere : UNIX o MS-DOS                *
      *              *-------------------------------------------------*
           if        w-prs-tip-fsm        not  = "U"
                     go to put-nxt-seq-999.
      *              *-------------------------------------------------*
      *              * Incremento progressivo record emessi            *
      *              *-------------------------------------------------*
           add       1                    to   w-ads-sia-gen-rpt      .
       put-nxt-seq-200.
      *              *-------------------------------------------------*
      *              * Scrittura record in file Line-Sequential        *
      *              *-------------------------------------------------*
           move      "PN"                 to   g-ope                  .
           call      "swd/mod/prg/obj/mlsfil"
                                         using g                      .
       put-nxt-seq-999.
           exit.

      *    *===========================================================*
      *    * Routine per il controllo di errore in scrittura record in *
      *    * file Line-Sequential                                      *
      *    *-----------------------------------------------------------*
       tst-err-wrt-000.
      *              *-------------------------------------------------*
      *              * Se errori : messaggio ed uscita con flag di er- *
      *              * rore                                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se controllo da effettuare             *
      *                  *---------------------------------------------*
           if        w-prs-tip-fsm        not  = "U"
                     go to tst-err-wrt-999.
      *                  *---------------------------------------------*
      *                  * Controllo                                   *
      *                  *---------------------------------------------*
           if        g-sts                =    e-not-err
                     go to tst-err-wrt-999.
      *                  *---------------------------------------------*
      *                  * Messaggio                                   *
      *                  *---------------------------------------------*
           move      "Attenzione : Errore nella generazione dell'archivi
      -              "o di supporto. "    to   w-err-box-err-msg      .
           move      "             Operazione non eseguita (Write error)
      -              " !             "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                  *---------------------------------------------*
      *                  * Flag ad errore                              *
      *                  *---------------------------------------------*
           move      "#"                  to   w-ads-tab-out-flg      .
       tst-err-wrt-999.
           exit.

      *    *===========================================================*
      *    * Determinazione numero ordine di bonifico                  *
      *    *-----------------------------------------------------------*
       det-sfo-num-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo stampa          *
      *              *-------------------------------------------------*
           if        rr-tip-stp           =    01
                     go to det-sfo-num-100
           else if   rr-tip-stp           =    03
                     go to det-sfo-num-300
           else      go to det-sfo-num-900.
       det-sfo-num-100.
      *              *-------------------------------------------------*
      *              * Se stampa definitiva                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione secolo ed anno                 *
      *                  *---------------------------------------------*
           move      w-ads-tab-inp-dpr    to   s-dat                  .
           move      s-saa                to   w-sfo-num-scl-ann      .
      *                  *---------------------------------------------*
      *                  * Richiamo routine di attribuzione            *
      *                  *---------------------------------------------*
           perform   att-sfo-num-000      thru att-sfo-num-999        .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     det-sfo-num-900.
       det-sfo-num-300.
      *              *-------------------------------------------------*
      *              * Ristampa                                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Come per stampa definitiva                  *
      *                  *---------------------------------------------*
           go to     det-sfo-num-100.
       det-sfo-num-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-sfo-num-999.
       det-sfo-num-999.
           exit.

      *    *===========================================================*
      *    * Routine di attribuzione numero ordine di bonifico         *
      *    *-----------------------------------------------------------*
       att-sfo-num-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfonum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfo-num             .
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [sfonum]                                  *
      *              *-------------------------------------------------*
           move      w-sfo-num-scl-ann    to   rn-sfo-num-scl-ann     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [sfonum]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfonum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfo-num             .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-sfo-num-400.
       att-sfo-num-200.
      *              *-------------------------------------------------*
      *              * Se record non esistente                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Scrittura record normalizzato               *
      *                  *---------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfonum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfo-num             .
      *                  *---------------------------------------------*
      *                  * Unlock record                               *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfonum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfo-num             .
      *                  *---------------------------------------------*
      *                  * Ripetizione dell'intera operazione          *
      *                  *---------------------------------------------*
           go to     att-sfo-num-000.
       att-sfo-num-400.
      *              *-------------------------------------------------*
      *              * Se record esistente                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore pre-incremento           *
      *                  *---------------------------------------------*
           move      rn-sfo-num-num-odb   to   w-sfo-num-num-odb      .
           move      w-sfo-num-r01-num    to   w-sfo-num-val-pre      .
      *                  *---------------------------------------------*
      *                  * Preparazione valore post-incremento         *
      *                  *---------------------------------------------*
           move      w-sfo-num-val-pre    to   w-sfo-num-val-pos      .
           add       1                    to   w-sfo-num-val-pos      .
           if        w-sfo-num-val-pos    =    zero
                     move  1              to   w-sfo-num-val-pos      .
      *                  *---------------------------------------------*
      *                  * Preparazione numero addebito completo       *
      *                  *---------------------------------------------*
           move      w-sfo-num-scl-ann    to   w-sfo-num-r01-saa      .
           move      w-sfo-num-val-pos    to   w-sfo-num-r01-num      .
      *                  *---------------------------------------------*
      *                  * Aggiornamento numero addebito               *
      *                  *---------------------------------------------*
           move      w-sfo-num-num-odb    to   rn-sfo-num-num-odb     .
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfonum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfo-num             .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'esito dell'opera- *
      *                  * zione di update                             *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-sfo-num-600.
       att-sfo-num-500.
      *                  *---------------------------------------------*
      *                  * Se errore in operazione di update           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfonum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfo-num             .
      *                      *-----------------------------------------*
      *                      * Ripetizione dell'intera operazione      *
      *                      *-----------------------------------------*
           go to     att-sfo-num-000.
       att-sfo-num-600.
      *                  *---------------------------------------------*
      *                  * Se nessun errore in operazione di update    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/scf/num/ioc/obj/insfonum"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-sfo-num             .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     att-sfo-num-999.
       att-sfo-num-999.
           exit.

