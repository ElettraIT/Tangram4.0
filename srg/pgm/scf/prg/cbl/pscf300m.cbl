      *              * pagamento                                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-ads-sia-gen-sap      .
       buf-sfs-pag-100.
      *              *-------------------------------------------------*
      *              * Start su archivio [sfs]                         *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "PGFSCF    "         to   f-key                  .
           move      rf-sfp-num-pgf       to   rf-sfs-num-pgf         .
           move      zero                 to   rf-sfs-num-scf         .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfs                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to buf-sfs-pag-600.
       buf-sfs-pag-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [sfs]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/scf/fls/ioc/obj/iofsfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sfs                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to buf-sfs-pag-600.
       buf-sfs-pag-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-sfs-num-pgf       not  = rf-sfp-num-pgf
                     go to buf-sfs-pag-600.
       buf-sfs-pag-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Incremento numero scadenze incontrate       *
      *                  *---------------------------------------------*
           add       1                    to   w-ads-sia-gen-sap      .
      *                  *---------------------------------------------*
      *                  * Se oltre 15 scadenze : a ciclo di emissione *
      *                  *---------------------------------------------*
           if        w-ads-sia-gen-sap    >    15
                     move  15             to   w-ads-sia-gen-sap
                     go to buf-sfs-pag-600.
       buf-sfs-pag-450.
      *              *-------------------------------------------------*
      *              * Bufferizzazione                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Numero scadenza                             *
      *                  *---------------------------------------------*
