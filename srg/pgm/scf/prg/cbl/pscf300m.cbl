      *    *===========================================================*
      *    * Routines per il trattamento del file [ouf] per la compo-  *
      *    * sizione del file di supporto in formato MS-DOS            *
      *    *-----------------------------------------------------------*
       ouf-fil-det-000.
      *              *=================================================*
      *              * Determinazione name e pathname completo per il  *
      *              * file [ouf]                                      *
      *              *-------------------------------------------------*
       ouf-fil-det-100.
      *                  *---------------------------------------------*
      *                  * File name                                   *
      *                  *---------------------------------------------*
           move      "ouf "               to   f-ouf-nam              .
       ouf-fil-det-200.
      *                  *---------------------------------------------*
      *                  * File pathname                               *
      *                  *---------------------------------------------*
       ouf-fil-det-210.
      *                      *-----------------------------------------*
      *                      * Composizione di una stringa composta    *
      *                      * come segue :                            *
      *                      *                                         *
      *                      * aabbbbcc.nnn                            *
      *                      *                                         *
      *                      * dove : aa   = valore fisso 'DP'         *
      *                      *                                         *
      *                      *        bbbb = sigla azienda             *
      *                      *                                         *
      *                      *        cc   = anno di due cifre         *
      *                      *                                         *
      *                      *        nnn  = numero distinta           *
      *                      *                                         *
      *                      *-----------------------------------------*
           move      spaces               to   w-ads-tab-ndf-dos      .
           string    "bi"       delimited by   size
                     w-ads-tab-ndf-azi
                                delimited by   spaces
                     w-ads-tab-ndf-n02-a34
                                delimited by   size
                     "."        delimited by   size
                     w-ads-tab-ndf-n05
                                delimited by   size
                                          into w-ads-tab-ndf-dos      .
       ouf-fil-det-220.
      *                      *-----------------------------------------*
      *                      * Trasformazione in lowercase             *
      *                      *-----------------------------------------*
           move      w-ads-tab-ndf-dos    to   w-all-str-alf          .
           move      12                   to   w-all-str-lun          .
           perform   all-str-low-000      thru all-str-low-999        .
           move      w-all-str-alf        to   w-ads-tab-ndf-dos      .
       ouf-fil-det-230.
      *                      *-----------------------------------------*
      *                      * Concatenamento preliminare con /cbi     *
      *                      *-----------------------------------------*
           move      16                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
           move      "cbi/"               to   w-all-str-cat (1)      .
           move      w-ads-tab-ndf-dos    to   w-all-str-cat (2)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *                      *-----------------------------------------*
      *                      * Concatenamento eventuale con '.TXT'     *
      *                      *-----------------------------------------*
           if        w-prs-tip-fsm        not  = "T"
                     go to ouf-fil-det-280.
      *                      *-----------------------------------------*
      *                      * Concatenamento                          *
      *                      *-----------------------------------------*
           move      40                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
           move      w-all-str-alf        to   w-all-str-cat (1)      .
           move      ".txt"               to   w-all-str-cat (2)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
       ouf-fil-det-280.
      *                      *-----------------------------------------*
      *                      * Pathname completo sotto /abd/asc        *
      *                      *-----------------------------------------*
           move      "AS"                 to   s-ope                  .
           move      w-all-str-alf        to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-pat                to   f-ouf-pat              .
       ouf-fil-det-300.
      *                  *---------------------------------------------*
      *                  * File status                                 *
      *                  *---------------------------------------------*
           move      "00"                 to   f-ouf-sts              .
       ouf-fil-det-999.
           exit.
       ouf-fil-opo-000.
      *              *-------------------------------------------------*
      *              * Open output file [ouf]                          *
      *              *-------------------------------------------------*
           open      output ouf                                       .
       ouf-fil-opo-999.
           exit.
       ouf-fil-cls-000.
      *              *=================================================*
      *              * Close file [ouf]                                *
      *              *-------------------------------------------------*
           close     ouf                                              .
       ouf-fil-cls-100.
      *              *-------------------------------------------------*
      *              * Completamento del file [ouf] con il carattere   *
      *              * di fine-file x'1A'                              *
      *              *-------------------------------------------------*
       ouf-fil-cls-110.
      *                  *---------------------------------------------*
      *                  * File name per [0u2]                         *
      *                  *---------------------------------------------*
