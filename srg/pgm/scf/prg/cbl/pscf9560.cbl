      *    *===========================================================*
      *    * Esecuzione accettazione di un campo                       *
      *    *-----------------------------------------------------------*
       exe-acc-cmp-000.
      *              *-------------------------------------------------*
      *              * Abilitazione tasto di funzione EXIT             *
      *              *-------------------------------------------------*
           move      "EXIT"               to   v-pfk(11)              .
      *              *-------------------------------------------------*
      *              * Se in impostazione campi chiave : no DELT       *
      *              *-------------------------------------------------*
           if        y-are-tip-fun        =    "K"
                     go to exe-acc-cmp-200.
      *              *-------------------------------------------------*
      *              * Se in inserimento : no DELT                     *
      *              *-------------------------------------------------*
           if        y-are-tip-fun        =    "I"
                     go to exe-acc-cmp-200.
      *              *-------------------------------------------------*
      *              * Se gia' avvenuta almeno una modifica : no DELT  *
      *              *-------------------------------------------------*
           if        y-are-flg-aum        not  = spaces
                     go to exe-acc-cmp-200.
      *              *-------------------------------------------------*
      *              * Abilitazione tasto di funzione DELT             *
      *              *-------------------------------------------------*
           move      "DELT"               to   v-pfk(12)              .
      *              *-------------------------------------------------*
      *              * Salvataggio parametri di impostazione           *
      *              *-------------------------------------------------*
           move      v-tip                to   y-are-sav-tip          .
           move      v-car                to   y-are-sav-car          .
           move      v-lin                to   y-are-sav-lin          .
           move      v-pos                to   y-are-sav-pos          .
           if        v-tip                =    "N"
                     move  v-dec          to   y-are-sav-dec
                     move  v-sgn          to   y-are-sav-sgn
                     move  v-edm          to   y-are-sav-edm
                     move  v-msk          to   y-are-sav-msk
                     move  v-num          to   y-are-sav-num
           else if   v-tip                =    "D"
                     move  v-dat          to   y-are-sav-dat
           else if   v-tip                =    "T"
                     move  v-ldt          to   y-are-sav-ldt
                     move  v-txt          to   y-are-sav-txt
           else      move  v-alf          to   y-are-sav-alf          .
           move      v-ufk                to   y-are-sav-ufk          .
       exe-acc-cmp-200.
      *              *-------------------------------------------------*
      *              * Accettazione                                    *
      *              *-------------------------------------------------*
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Memorizzazione segnale di campo modificato      *
      *              *-------------------------------------------------*
           move      v-mod                to   y-are-sav-mod          .
      *              *-------------------------------------------------*
      *              * Test se premuto tasto di funzione DELT          *
      *              *-------------------------------------------------*
           if        v-key                not  = "DELT"
                     go to exe-acc-cmp-900.
      *              *-------------------------------------------------*
      *              * Se il campo impostato ha modificato il valore   *
      *              * precedente : ripetizione impostazione           *
      *              *-------------------------------------------------*
           if        y-are-sav-mod        =    spaces
                     go to exe-acc-cmp-400.
       exe-acc-cmp-300.
      *              *-------------------------------------------------*
      *              * Ripristino parametri di impostazione            *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      y-are-sav-tip        to   v-tip                  .
           move      y-are-sav-car        to   v-car                  .
           move      y-are-sav-lin        to   v-lin                  .
           move      y-are-sav-pos        to   v-pos                  .
           if        v-tip                =    "N" or
                     v-tip                =    "V" or
                     v-tip                =    "P" or
                     v-tip                =    "E"
                     move  y-are-sav-dec  to   v-dec
                     move  y-are-sav-sgn  to   v-sgn
                     move  y-are-sav-edm  to   v-edm
                     move  y-are-sav-msk  to   v-msk
                     move  y-are-sav-num  to   v-num
           else if   v-tip                =    "D"
                     move  y-are-sav-dat  to   v-dat
           else if   v-tip                =    "T"
                     move  y-are-sav-ldt  to   v-ldt
                     move  y-are-sav-txt  to   v-txt
           else      move  y-are-sav-alf  to   v-alf                  .
           move      y-are-sav-ufk        to   v-ufk                  .
      *              *-------------------------------------------------*
      *              * Ritorno alla impostazione                       *
      *              *-------------------------------------------------*
           go to     exe-acc-cmp-200.
       exe-acc-cmp-400.
      *              *-------------------------------------------------*
      *              * Salvataggio linee 23 e 24 di note operative     *
      *              *-------------------------------------------------*
           move      "GL"                 to   v-ope                  .
           move      23                   to   v-lin                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      v-alf                to   y-are-sav-l23          .
           move      "GL"                 to   v-ope                  .
           move      24                   to   v-lin                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      v-alf                to   y-are-sav-l24          .
      *              *-------------------------------------------------*
      *              * Cancellazione note operative attuali            *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           move      spaces               to   v-not                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Richiesta conferma annullamento                 *
      *              *-------------------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      "Conferma operazione di annullamento (S/N/E) ?"
                                          to   v-not                  .
           move      "N"                  to   v-alf                  .
           move      "SNE"                to   v-msk                  .
           move      "DELT"               to   v-pfk (1)              .
           move      "UP  "               to   v-pfk (2)              .
           move      "EXIT"               to   v-pfk (3)              .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           if        v-key                =    spaces
                     if      v-alf        =    "S"
                             move  "DELT" to   v-key
                             go to exe-acc-cmp-500
                     else if v-alf        =    "N"
                             move  "UP  " to   v-key
                             go to exe-acc-cmp-500
                     else    move  "EXIT" to   v-key                  .
       exe-acc-cmp-500.
      *              *-------------------------------------------------*
      *              * Se function key DELT o EXIT si esce             *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT" or
                     v-key                =    "EXIT"
                     go to exe-acc-cmp-999.
      *              *-------------------------------------------------*
      *              * Ripristino linee 23 e 24 di note operative      *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           move      y-are-sav-l23        to   v-nt1                  .
           move      y-are-sav-l24        to   v-nt2                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Ripristino parametri e poi reimpostazione       *
      *              *-------------------------------------------------*
           go to     exe-acc-cmp-300.
       exe-acc-cmp-900.
      *              *-------------------------------------------------*
      *              * Flag globale di avvenuta almeno una modifica    *
      *              *-------------------------------------------------*
           if        y-are-sav-mod        not  = spaces
                     move  "#"            to   y-are-flg-aum          .
       exe-acc-cmp-999.
           exit.

