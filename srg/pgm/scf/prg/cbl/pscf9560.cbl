      *                  *---------------------------------------------*
      *                  * Se function-key 'DELT' o 'EXIT'si esce      *
      *                  *---------------------------------------------*
           if        v-key                =    "DELT" or
                     v-key                =    "EXIT"
                     go to z-acc-non-key-999.
      *                  *---------------------------------------------*
      *                  * Se function-key 'UP' si torna all'imposta-  *
      *                  * zione dell'ultima riga di castelletto impo- *
      *                  * stata                                       *
      *                  *---------------------------------------------*
           if        v-key                not  = "UP  "
                     go to  z-acc-non-key-220.
           add       1                    to   w-cst-max-rig          .
           if        w-cst-max-rig        >    6
                     move   6             to   w-cst-max-rig          .
           add       1                    to   w-cst-ctr-rig          .
           if        w-cst-ctr-rig        >    6
                     move   6             to   w-cst-ctr-rig          .
                     go to  z-acc-non-key-110.
       z-acc-non-key-220.
      *                  *---------------------------------------------*
      *                  * Se il campo e' stato variato rispetto al    *
      *                  * valore precedente si attiva il flag di for- *
      *                  * zatura totale documento                     *
      *                  *---------------------------------------------*
           if        v-num                not  = rf-sff-iva-tdo
                     move   "F"           to   w-tot-flg-frz
           else      move   spaces        to   w-tot-flg-frz          .
      *                  *---------------------------------------------*
      *                  * Movimento valore in record file             *
      *                  *---------------------------------------------*
           move      v-num                to   rf-sff-iva-tdo         .
      *                  *---------------------------------------------*
      *                  * Se function-key 'DO' si esce                *
      *                  *---------------------------------------------*
           if        v-key                =    "DO  "
                     go to z-acc-non-key-999.
      *              *-------------------------------------------------*
