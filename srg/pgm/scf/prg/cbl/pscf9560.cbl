       z-acc-non-key-150.
      *                  *---------------------------------------------*
      *                  * Se function-key 'DO  ' si esce se almeno la *
      *                  * prima riga di castelletto non e' vuota      *
      *                  *---------------------------------------------*
           if        v-key                not  = "DO  "
                     go to  z-acc-non-key-160.
           if        rf-sff-iva-cod (1)   =    zero and
                     rf-sff-iva-ibl (1)   =    zero and
                     rf-sff-iva-imp (1)   =    zero
                     go to  z-acc-non-key-110
           else      go to  z-acc-non-key-999.
       z-acc-non-key-160.
