      *              * Start su [sdb] per protocollo fattura           *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "GT"                 to   f-cfr                  .
           move      "PFCNRS    "         to   f-key                  .
           move      rf-fit-num-prt       to   rf-sdb-prt-fcl         .
           move      zero                 to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata                             *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to sel-fit-rec-scd-900.
       sel-fit-rec-scd-200.
      *              *-------------------------------------------------*
      *              * Next su [sdb]                                   *
      *              *-------------------------------------------------*
