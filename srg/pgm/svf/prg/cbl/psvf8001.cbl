      *    *===========================================================*
      *    * Emissione sequenziale dati per grafico                    *
      *    *-----------------------------------------------------------*
       exe-sqz-grf-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
           if        rr-gen-grf           not  = "S"
                     go to exe-sqz-grf-900.
           if        rr-tip-dts           not  = 04
                     go to exe-sqz-grf-900.
           if        rr-num-pdr           >    03
                     go to exe-sqz-grf-900.
           if        rr-tmo-ftr           not  = spaces
                     go to exe-sqz-grf-900.
       exe-sqz-grf-100.
      *              *-------------------------------------------------*
      *              * Normalizzazione preliminare valori grafico      *
      *              *-------------------------------------------------*
           move      "NO"                 to   m-gen-grf-tip-ope      .
           move      "pgm/svf/prg/obj/mgengrf0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using m-gen-grf              .
       exe-sqz-grf-150.
      *              *-------------------------------------------------*
      *              * Preparazione dati di generazione grafico        *
      *              *-------------------------------------------------*
           move      "EG"                 to   m-gen-grf-tip-ope      .
           move      "C"                  to   m-gen-grf-tip-grf      .
           move      spaces               to   m-gen-grf-tip-arc      .
           move      zero                 to   m-gen-grf-cod-arc      .
           move      spaces               to   m-gen-grf-mne-arc      .
           move      rr-num-pdr           to   m-gen-grf-num-prd      .
           move      "Statistica di vendita "
                                          to   m-gen-grf-tit-grf      .
           move      "svf800"             to   m-gen-grf-fil-nam      .
       exe-sqz-grf-200.
      *              *-------------------------------------------------*
      *              * Emissione dati mensili per periodo              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione date periodi                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-liv-gen-cst-ct1      .
       exe-sqz-grf-300.
           add       1                    to   w-liv-gen-cst-ct1      .
           if        w-liv-gen-cst-ct1    >    rr-num-pdr
                     go to exe-sqz-grf-800.
           if        w-liv-gen-cst-ct1    =    01
                     move  rr-p1d-min     to   m-gen-grf-prd-min
                                              (w-liv-gen-cst-ct1)
                     move  rr-p1d-max     to   m-gen-grf-prd-max
                                              (w-liv-gen-cst-ct1)
           else if   w-liv-gen-cst-ct1    =    02
                     move  rr-p2d-min     to   m-gen-grf-prd-min
                                              (w-liv-gen-cst-ct1)
                     move  rr-p2d-max     to   m-gen-grf-prd-max
                                              (w-liv-gen-cst-ct1)
           else      move  rr-p3d-min     to   m-gen-grf-prd-min
                                              (w-liv-gen-cst-ct1)
                     move  rr-p3d-max     to   m-gen-grf-prd-max
                                              (w-liv-gen-cst-ct1)     .
       exe-sqz-grf-400.
      *              *-------------------------------------------------*
      *              * Ciclo dati mensili                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-liv-gen-cst-ctr      .
       exe-sqz-grf-500.
           add       1                    to   w-liv-gen-cst-ctr      .
           if        w-liv-gen-cst-ctr    >    12
                     go to exe-sqz-grf-600.
      *                  *---------------------------------------------*
      *                  * Preparazione dato mensile                   *
      *                  *---------------------------------------------*
           if        w-liv-gen-cst-ct1    =    01
                     move  w-liv-gen-mes-p1r
                          (w-liv-gen-cst-ctr)
                                          to   m-gen-grf-mes-val
                                              (w-liv-gen-cst-ct1,
                                               w-liv-gen-cst-ctr)
           else if   w-liv-gen-cst-ct1    =    02
                     move  w-liv-gen-mes-p2r
                          (w-liv-gen-cst-ctr)
                                          to   m-gen-grf-mes-val
                                              (w-liv-gen-cst-ct1,
                                               w-liv-gen-cst-ctr)
           else      move  w-liv-gen-mes-p3r
                          (w-liv-gen-cst-ctr)
                                          to   m-gen-grf-mes-val
                                              (w-liv-gen-cst-ct1,
                                               w-liv-gen-cst-ctr)     .
      *                  *---------------------------------------------*
      *                  * Riciclo a mese successivo                   *
      *                  *---------------------------------------------*
           go to     exe-sqz-grf-500.
       exe-sqz-grf-600.
      *                  *---------------------------------------------*
      *                  * Riciclo a periodo successivo                *
      *                  *---------------------------------------------*
           go to     exe-sqz-grf-300.
       exe-sqz-grf-800.
      *              *-------------------------------------------------*
      *              * Chiamata modulo generazione grafico             *
      *              *-------------------------------------------------*
           move      "pgm/svf/prg/obj/mgengrf0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using m-gen-grf              .
       exe-sqz-grf-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-sqz-grf-999.
       exe-sqz-grf-999.
           exit.

      *    *===========================================================*
      *    * Emissione sequenziale dati per grafico                    *
      *    *                                                           *
      *    * Ciclo di emissione grafico per un tipo movimento          *
      *    *-----------------------------------------------------------*
       exe-sqz-grf-tmo-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
           if        rr-gen-grf           not  = "S"
                     go to exe-sqz-grf-tmo-900.
           if        rr-tip-dts           not  = 04
                     go to exe-sqz-grf-tmo-900.
           if        rr-num-pdr           >    03
                     go to exe-sqz-grf-tmo-900.
           if        rr-tmo-ftr           =    spaces
                     go to exe-sqz-grf-tmo-900.
       exe-sqz-grf-tmo-100.
      *              *-------------------------------------------------*
      *              * Normalizzazione preliminare valori grafico      *
      *              *-------------------------------------------------*
           move      "NO"                 to   m-gen-grf-tip-ope      .
           move      "pgm/svf/prg/obj/mgengrf0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using m-gen-grf              .
       exe-sqz-grf-tmo-150.
      *              *-------------------------------------------------*
      *              * Preparazione dati di generazione grafico        *
      *              *-------------------------------------------------*
           move      "EG"                 to   m-gen-grf-tip-ope      .
           move      "C"                  to   m-gen-grf-tip-grf      .
           move      "T"                  to   m-gen-grf-tip-arc      .
           move      zero                 to   m-gen-grf-cod-arc      .
           move      rr-tmo-ftr           to   m-gen-grf-mne-arc      .
           move      rr-num-pdr           to   m-gen-grf-num-prd      .
      *
           move      40                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
           move      "Fatturato :"        to   w-all-str-cat (1)      .
           move      w-liv-tmo-des-tmo    to   w-all-str-cat (2)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *
           move      w-all-str-alf        to   m-gen-grf-tit-grf      .
           move      "svf800"             to   m-gen-grf-fil-nam      .
       exe-sqz-grf-tmo-200.
      *              *-------------------------------------------------*
      *              * Emissione dati mensili per periodo              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione date periodi                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-liv-tmo-cst-ct1      .
       exe-sqz-grf-tmo-300.
           add       1                    to   w-liv-tmo-cst-ct1      .
           if        w-liv-tmo-cst-ct1    >    rr-num-pdr
                     go to exe-sqz-grf-tmo-800.
           if        w-liv-tmo-cst-ct1    =    01
                     move  rr-p1d-min     to   m-gen-grf-prd-min
                                              (w-liv-tmo-cst-ct1)
                     move  rr-p1d-max     to   m-gen-grf-prd-max
                                              (w-liv-tmo-cst-ct1)
           else if   w-liv-tmo-cst-ct1    =    02
                     move  rr-p2d-min     to   m-gen-grf-prd-min
                                              (w-liv-tmo-cst-ct1)
                     move  rr-p2d-max     to   m-gen-grf-prd-max
                                              (w-liv-tmo-cst-ct1)
           else      move  rr-p3d-min     to   m-gen-grf-prd-min
                                              (w-liv-tmo-cst-ct1)
                     move  rr-p3d-max     to   m-gen-grf-prd-max
                                              (w-liv-tmo-cst-ct1)     .
       exe-sqz-grf-tmo-400.
      *              *-------------------------------------------------*
      *              * Ciclo dati mensili                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-liv-tmo-cst-ctr      .
       exe-sqz-grf-tmo-500.
           add       1                    to   w-liv-tmo-cst-ctr      .
           if        w-liv-tmo-cst-ctr    >    12
                     go to exe-sqz-grf-tmo-600.
      *                  *---------------------------------------------*
      *                  * Preparazione dato mensile                   *
      *                  *---------------------------------------------*
           if        w-liv-tmo-cst-ct1    =    01
                     move  w-liv-tmo-mes-p1r
                          (w-liv-tmo-cst-ctr)
                                          to   m-gen-grf-mes-val
                                              (w-liv-tmo-cst-ct1,
                                               w-liv-tmo-cst-ctr)
           else if   w-liv-tmo-cst-ct1    =    02
                     move  w-liv-tmo-mes-p2r
                          (w-liv-tmo-cst-ctr)
                                          to   m-gen-grf-mes-val
                                              (w-liv-tmo-cst-ct1,
                                               w-liv-tmo-cst-ctr)
           else      move  w-liv-tmo-mes-p3r
                          (w-liv-tmo-cst-ctr)
                                          to   m-gen-grf-mes-val
                                              (w-liv-tmo-cst-ct1,
                                               w-liv-tmo-cst-ctr)     .
      *                  *---------------------------------------------*
      *                  * Riciclo a mese successivo                   *
      *                  *---------------------------------------------*
           go to     exe-sqz-grf-tmo-500.
       exe-sqz-grf-tmo-600.
      *                  *---------------------------------------------*
      *                  * Riciclo a periodo successivo                *
      *                  *---------------------------------------------*
           go to     exe-sqz-grf-tmo-300.
       exe-sqz-grf-tmo-800.
      *              *-------------------------------------------------*
      *              * Chiamata modulo generazione grafico             *
      *              *-------------------------------------------------*
           move      "pgm/svf/prg/obj/mgengrf0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using m-gen-grf              .
       exe-sqz-grf-tmo-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-sqz-grf-tmo-999.
       exe-sqz-grf-tmo-999.
           exit.

