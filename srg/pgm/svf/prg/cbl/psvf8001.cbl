      *                      * in negativo                             *
      *                      *-----------------------------------------*
           if        srt-val-sta-sn1      =    "S"
                     if    srt-val-sta-pon
                                          not  = "N"
                           add      srt-val-sta-val
                                          to   kk0-val-f1p
                     else  subtract srt-val-sta-val
                                          from kk0-val-f1p            .
      *                      *-----------------------------------------*
      *                      * Aggiornamento 2. periodo in positivo o  *
      *                      * in negativo                             *
      *                      *-----------------------------------------*
           if        srt-val-sta-sn2      =    "S"
