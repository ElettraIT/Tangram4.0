                                          to   kk0-val-f2p
                     else  subtract srt-val-sta-val
                                          from kk0-val-f2p            .
      *                      *-----------------------------------------*
      *                      * Aggiornamento 3. periodo in positivo o  *
      *                      * in negativo                             *
      *                      *-----------------------------------------*
           if        srt-val-sta-sn3      =    "S"
                     if    srt-val-sta-pon
                                          not  = "N"
                           add      srt-val-sta-val
                                          to   kk0-val-f3p
                     else  subtract srt-val-sta-val
                                          from kk0-val-f3p            .
      *                      *-----------------------------------------*
      *                      * Riscrittura record file ad indici, se   *
      *                      * errori : a rilettura                    *
      *                      *-----------------------------------------*
           rewrite   kk0-rec
                            invalid key
                            go to   agg-abc-kk0-550.
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     agg-abc-kk0-999.
       agg-abc-kk0-999.
