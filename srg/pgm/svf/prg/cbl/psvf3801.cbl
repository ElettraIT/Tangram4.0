           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      05                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      spaces               to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      009                  to   p-pos                  .
           move      w-stp-cmd-csc-cod    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-cmd-csc-700.
      *                  *---------------------------------------------*
      *                  * Mnemonico per la classe                     *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      05                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      016                  to   p-pos                  .
           move      w-stp-cmd-csc-mne    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-cmd-csc-750.
