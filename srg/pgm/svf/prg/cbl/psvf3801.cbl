      *    *===========================================================*
      *    * Subroutine per la stampa del codice cliente e della sua   *
      *    * ragione sociale                                           *
      *    *                                                           *
      *    * - Parametri in input                                      *
      *    *                                                           *
      *    *   - w-stp-ccl-rsc-cod : Codice del cliente                *
      *    *                                                           *
      *    *   - w-stp-ccl-rsc-mne : Mnemonico del cliente             *
      *    *                                                           *
      *    *   - w-stp-ccl-rsc-dpz : Dipendenza del cliente            *
      *    *                                                           *
      *    *   - w-stp-ccl-rsc-rag : Ragione sociale del cliente       *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       stp-ccl-rsc-000.
      *              *-------------------------------------------------*
      *              * Se le personalizzazioni indicano che si deve e- *
      *              * sporre il mnemonico si va' al trattamento per   *
      *              * il mnemonico, altrimenti si va' al trattamento  *
      *              * per il codice numerico                          *
      *              *-------------------------------------------------*
           if        w-prs-svf-cli-tco    =    "M"
                     go to stp-ccl-rsc-200.
       stp-ccl-rsc-100.
      *              *-------------------------------------------------*
      *              * Trattamento del codice numerico                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing                                     *
      *                  *---------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      07                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      spaces               to   p-edm                  .
           move      w-stp-ccl-rsc-cod    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Codice numerico editato in area editata di  *
      *                  * comodo                                      *
      *                  *---------------------------------------------*
           move      p-edt                to   w-stp-ccl-rsc-e10      .
      *                  *---------------------------------------------*
      *                  * A trattamento codice editato                *
      *                  *---------------------------------------------*
           go to     stp-ccl-rsc-300.
       stp-ccl-rsc-200.
      *              *-------------------------------------------------*
      *              * Trattamento del mnemonico                       *
      *              *-------------------------------------------------*
       stp-ccl-rsc-210.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda se mnemonico a spaces  *
      *                  * oppure no                                   *
      *                  *---------------------------------------------*
           if        w-stp-ccl-rsc-mne    =    spaces
                     go to stp-ccl-rsc-230.
       stp-ccl-rsc-220.
      *                  *---------------------------------------------*
      *                  * Se mnemonico diverso da spaces              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Mnemonico in area editata di comodo     *
      *                      *-----------------------------------------*
           move      w-stp-ccl-rsc-mne    to   w-stp-ccl-rsc-e10      .
      *                      *-----------------------------------------*
      *                      * A trattamento codice editato            *
      *                      *-----------------------------------------*
           go to     stp-ccl-rsc-300.
       stp-ccl-rsc-230.
      *                  *---------------------------------------------*
      *                  * Se mnemonico a spaces                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing del codice numerico             *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      07                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      w-stp-ccl-rsc-cod    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Composizione area editata di comodo     *
      *                      *-----------------------------------------*
           move      spaces               to   w-stp-ccl-rsc-e10      .
           string    "("        delimited by   size
                     p-edt      delimited by spaces
                     ")"        delimited by size
                                          into w-stp-ccl-rsc-e10      .
      *                      *-----------------------------------------*
      *                      * A trattamento codice editato            *
      *                      *-----------------------------------------*
           go to     stp-ccl-rsc-300.
       stp-ccl-rsc-300.
      *              *-------------------------------------------------*
      *              * Trattamento codice editato                      *
      *              *-------------------------------------------------*
       stp-ccl-rsc-310.
      *                  *---------------------------------------------*
      *                  * Stampa codice editato                       *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      10                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      w-stp-ccl-rsc-e10    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-ccl-rsc-320.
      *                  *---------------------------------------------*
      *                  * Se codice dipendenza a spaces : non la si   *
      *                  * stampa                                      *
      *                  *---------------------------------------------*
           if        w-stp-ccl-rsc-dpz    =    spaces
                     go to stp-ccl-rsc-400.
       stp-ccl-rsc-330.
      *                  *---------------------------------------------*
      *                  * Determinazione della lunghezza del codice   *
      *                  * editato senza considerare gli spazi in coda *
      *                  *---------------------------------------------*
           move      zero                 to   w-stp-ccl-rsc-c01      .
           inspect   w-stp-ccl-rsc-e10
                                      tallying w-stp-ccl-rsc-c01
                                  for trailing spaces                 .
           move      10                   to   w-stp-ccl-rsc-c02      .
           subtract  w-stp-ccl-rsc-c01    from w-stp-ccl-rsc-c02      .
      *                  *---------------------------------------------*
      *                  * Stampa lineetta di separazione              *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      01                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           add       w-stp-ccl-rsc-c02    to   p-pos                  .
           move      "-"                  to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Stampa dipendenza                           *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      04                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           add       w-stp-ccl-rsc-c02    to   p-pos                  .
           add       1                    to   p-pos                  .
           move      w-stp-ccl-rsc-dpz    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-ccl-rsc-340.
      *                  *---------------------------------------------*
      *                  * A stampa ragione sociale                    *
      *                  *---------------------------------------------*
           go to     stp-ccl-rsc-400.
       stp-ccl-rsc-400.
      *              *-------------------------------------------------*
      *              * Ragione sociale del cliente                     *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      40                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      p-lnr                to   p-lin                  .
           move      017                  to   p-pos                  .
           move      w-stp-ccl-rsc-rag    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-ccl-rsc-999.
           exit.

      *    *===========================================================*
      *    * Subroutine per stampa voci 'Fatturato' e '%'              *
      *    *                                                           *
      *    * - Parametri in input                                      *
      *    *                                                           *
      *    *   - w-stp-sta-fep-f01 : Valore fatturato 1                *
      *    *                                                           *
      *    *   - w-stp-sta-fep-f02 : Valore fatturato 2                *
      *    *                                                           *
      *    *   - w-stp-sta-fep-p01 : Valore % di variazione 1          *
      *    *                                                           *
      *    *   - w-stp-sta-fep-f03 : Valore fatturato 3                *
      *    *                                                           *
      *    *   - w-stp-sta-fep-p02 : Valore % di variazione 2          *
      *    *                                                           *
      *    *   - w-stp-sta-fep-not : Valore del campo 'Note'           *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       stp-sta-fep-000.
      *              *-------------------------------------------------*
      *              * Valore fatturato 1                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing                                     *
      *                  *---------------------------------------------*
           move      w-stp-sta-fep-f01    to   w-stp-edt-fat-fat      .
           perform   stp-edt-fat-000      thru stp-edt-fat-999        .
      *                  *---------------------------------------------*
      *                  * In area di stampa                           *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      16                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      061                  to   p-pos                  .
           move      w-stp-edt-fat-edt    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-sta-fep-100.
      *              *-------------------------------------------------*
      *              * Se numero periodi di riferimento non superiore  *
      *              * a 1 : a stampa Note                             *
      *              *-------------------------------------------------*
           if        rr-num-pdr           not  = 02 and
                     rr-num-pdr           not  = 03
                     go to stp-sta-fep-900.
       stp-sta-fep-200.
      *              *-------------------------------------------------*
      *              * Valore fatturato 2                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing                                     *
      *                  *---------------------------------------------*
           move      w-stp-sta-fep-f02    to   w-stp-edt-fat-fat      .
           perform   stp-edt-fat-000      thru stp-edt-fat-999        .
      *                  *---------------------------------------------*
      *                  * In area di stampa                           *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      16                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      079                  to   p-pos                  .
           move      w-stp-edt-fat-edt    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-sta-fep-300.
      *              *-------------------------------------------------*
      *              * Valore % di variazione 1                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing                                     *
      *                  *---------------------------------------------*
           move      w-stp-sta-fep-f01    to   w-stp-edt-pdv-1ov      .
           move      w-stp-sta-fep-f02    to   w-stp-edt-pdv-2ov      .
           move      w-stp-sta-fep-p01    to   w-stp-edt-pdv-pdv      .
           perform   stp-edt-pdv-000      thru stp-edt-pdv-999        .
      *                  *---------------------------------------------*
      *                  * In area di stampa                           *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      07                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      098                  to   p-pos                  .
           move      w-stp-edt-pdv-edt    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-sta-fep-400.
      *              *-------------------------------------------------*
      *              * Se numero periodi di riferimento non superiore  *
      *              * a 2 : a stampa Note                             *
      *              *-------------------------------------------------*
           if        rr-num-pdr           not  = 03
                     go to stp-sta-fep-900.
       stp-sta-fep-500.
      *              *-------------------------------------------------*
      *              * Valore fatturato 3                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing                                     *
      *                  *---------------------------------------------*
           move      w-stp-sta-fep-f03    to   w-stp-edt-fat-fat      .
           perform   stp-edt-fat-000      thru stp-edt-fat-999        .
      *                  *---------------------------------------------*
      *                  * In area di stampa                           *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      16                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      107                  to   p-pos                  .
           move      w-stp-edt-fat-edt    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-sta-fep-600.
      *              *-------------------------------------------------*
      *              * Valore % di variazione 2                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing                                     *
      *                  *---------------------------------------------*
           move      w-stp-sta-fep-f02    to   w-stp-edt-pdv-1ov      .
           move      w-stp-sta-fep-f03    to   w-stp-edt-pdv-2ov      .
           move      w-stp-sta-fep-p02    to   w-stp-edt-pdv-pdv      .
           perform   stp-edt-pdv-000      thru stp-edt-pdv-999        .
      *                  *---------------------------------------------*
      *                  * In area di stampa                           *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      07                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      126                  to   p-pos                  .
           move      w-stp-edt-pdv-edt    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-sta-fep-900.
      *              *-------------------------------------------------*
