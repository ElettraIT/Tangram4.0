      *                  *---------------------------------------------*
       cmp-srt-rec-210.
      *                      *-----------------------------------------*
      *                      * Valore ABC                              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Forzato a zero                      *
      *                          *-------------------------------------*
           move      zero                 to   srt-k01-val-abc        .
       cmp-srt-rec-215.
      *                      *-----------------------------------------*
      *                      * Flag di codice diverso da zero ma non   *
      *                      * trovato in archivio codici statistici   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Solo se tipo ordinamento classe :   *
      *                          *  - ABC decrescente                  *
      *                          *  - ABC crescente                    *
      *                          *  - Per descrizione                  *
      *                          *  - Per mnemonico                    *
      *                          * altrimenti forzato a zero           *
      *                          *-------------------------------------*
           if        rr-tor-csc           not  = 01 and
                     rr-tor-csc           not  = 02 and
                     rr-tor-csc           not  = 03 and
                     rr-tor-csc           not  = 05
                     move  zero           to   srt-k01-flg-eon
                     go to cmp-srt-rec-220.
      *                          *-------------------------------------*
      *                          * Se codice a zero : si forza '9'     *
      *                          *-------------------------------------*
           if        w-sel-fit-cod-csc    =    zero
                     move  9              to   srt-k01-flg-eon
                     go to cmp-srt-rec-220.
      *                          *-------------------------------------*
      *                          * Se codice diverso da zero : si pone *
      *                          * a seconda del flag di esistenza     *
      *                          *-------------------------------------*
           if        w-sel-fit-flg-csc    =    spaces
                     move  1              to   srt-k01-flg-eon
           else      move  5              to   srt-k01-flg-eon        .
       cmp-srt-rec-220.
