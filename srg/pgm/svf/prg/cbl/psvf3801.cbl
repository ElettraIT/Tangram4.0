      *                      *-----------------------------------------*
           move      w-let-cli-dcc-cli    to   w-sel-fit-cod-cli      .
      *                      *-----------------------------------------*
      *                      * Codice dipendenza per il cliente        *
      *                      *-----------------------------------------*
           move      w-let-cli-dcc-dpz    to   w-sel-fit-dpz-cli      .
      *                      *-----------------------------------------*
      *                      * Ragione sociale per il cliente          *
      *                      *-----------------------------------------*
           move      w-let-cli-dcc-rag    to   w-sel-fit-rag-cli      .
      *                      *-----------------------------------------*
      *                      * Mnemonico per il cliente                *
      *                      *-----------------------------------------*
           move      w-let-cli-dcc-mne    to   w-sel-fit-mne-cli      .
      *                      *-----------------------------------------*
      *                      * Codice categoria sconto in chiusura     *
      *                      *                                         *
      *                      * N.B.: se nella testata documento non e' *
      *                      *       presente la categoria sconto, si  *
      *                      *       utilizza quella in anagrafica del *
      *                      *       cliente                           *
      *                      *-----------------------------------------*
           move      rf-fit-csc-aac       to   w-sel-fit-scc-cli      .
      *
           if        w-sel-fit-scc-cli    =    zero
                     move  w-let-cli-dcc-scc
                                          to   w-sel-fit-scc-cli      .
      *                      *-----------------------------------------*
      *                      * Codice categoria sconto in riga         *
      *                      *                                         *
      *                      * N.B.: se nella testata documento non e' *
      *                      *       presente la categoria sconto, si  *
      *                      *       utilizza quella in anagrafica del *
      *                      *       cliente                           *
      *                      *-----------------------------------------*
           move      rf-fit-csr-aac       to   w-sel-fit-scr-cli      .
      *
           if        w-sel-fit-scr-cli    =    zero
                     move  w-let-cli-dcc-scr
                                          to   w-sel-fit-scr-cli      .
       sel-fit-rec-200.
      *              *-------------------------------------------------*
      *              * Selezione su codice categoria sconto cliente    *
      *              *-------------------------------------------------*
       sel-fit-rec-225.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del tipo di categoria  *
      *                  * sconto cliente selezionata                  *
      *                  *---------------------------------------------*
           if        rr-tcs-cli           =    01
                     go to sel-fit-rec-250
           else if   rr-tcs-cli           =    02
                     go to sel-fit-rec-275.
       sel-fit-rec-250.
      *                  *---------------------------------------------*
      *                  * Se tipo di categoria sconto cliente : 01,   *
      *                  * in chiusura                                 *
      *                  *---------------------------------------------*
       sel-fit-rec-255.
