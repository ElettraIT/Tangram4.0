                     go to stp-fnc-vrt-025
           else if   rr-tcs-cli           =    02
                     go to stp-fnc-vrt-026.
       stp-fnc-vrt-025.
      *                          *-------------------------------------*
      *                          * 01 : in chiusura                    *
      *                          *-------------------------------------*
