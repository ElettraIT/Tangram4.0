      *                      * ma non trovato in archivio codici sta-  *
      *                      * tistici                                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Solo se tipo ordinamento catalogo : *
      *                          *  - ABC decrescente sul fatturato    *
      *                          *  - ABC decrescente sulla quantita'  *
      *                          *  - ABC crescente sul fatturato      *
      *                          *  - ABC crescente sulla quantita'    *
      *                          *  - Per descrizione catalogo         *
      *                          * altrimenti forzato a zero           *
      *                          *-------------------------------------*
           if        rr-tor-csp           not  = 01 and
                     rr-tor-csp           not  = 02 and
                     rr-tor-csp           not  = 03 and
                     rr-tor-csp           not  = 04 and
                     rr-tor-csp           not  = 05 and
                     rr-tor-csp           not  = 07
                     move  zero           to   srt-k01-flg-eon
                     go to cmp-srt-rec-220.
      *                          *-------------------------------------*
      *                          * Se codice a spazi : si forza '9'    *
      *                          *-------------------------------------*
            if       w-sel-fir-cod-cpv    =    spaces
                     move  9              to   srt-k01-flg-eon
                     go to cmp-srt-rec-220.
      *                          *-------------------------------------*
      *                          * Se codice diverso da zero : si pone *
      *                          * a seconda del valore della descri-  *
      *                          * zione                               *
      *                          *-------------------------------------*
           if        w-sel-fir-des-csp    not  = spaces
                     move  1              to   srt-k01-flg-eon
