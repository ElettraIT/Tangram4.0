      *                              *---------------------------------*
      *                              * 2. quantita'                    *
      *                              *---------------------------------*
           move      zero                 to   w-mod-not-svf-q02      .
      *                              *---------------------------------*
      *                              * 2. fatturato                    *
      *                              *---------------------------------*
           move      zero                 to   w-mod-not-svf-f02      .
      *                              *---------------------------------*
      *                              * 1. % di variazione              *
      *                              *---------------------------------*
           move      zero                 to   w-mod-not-svf-p01      .
      *                              *---------------------------------*
      *                              * 3. quantita'                    *
      *                              *---------------------------------*
           move      zero                 to   w-mod-not-svf-q03      .
      *                              *---------------------------------*
      *                              * 3. fatturato                    *
      *                              *---------------------------------*
           move      zero                 to   w-mod-not-svf-f03      .
      *                              *---------------------------------*
      *                              * 2. % di variazione              *
      *                              *---------------------------------*
           move      zero                 to   w-mod-not-svf-p02      .
      *                              *---------------------------------*
      *                              * Tipo documento                  *
