      *    *===========================================================*
      *    * Determinazione se prodotto fatturato da una data in poi   *
      *    * ed eventuale ultima data fattura                          *
      *    *-----------------------------------------------------------*
       det-fat-pro-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-fat-pro-flg      .
           move      zero                 to   w-det-fat-pro-duf      .
           move      spaces               to   w-det-fat-pro-tuf      .
           move      zero                 to   w-det-fat-pro-ctr      .
       det-fat-pro-050.
      *              *-------------------------------------------------*
      *              * Test preliminari                                *
      *              *-------------------------------------------------*
           if        w-det-fat-pro-cod    =    zero
                     go to det-fat-pro-900.
       det-fat-pro-100.
      *              *-------------------------------------------------*
      *              * Start su file [fir]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "PRODAT    "         to   f-key                  .
           move      01                   to   rf-fir-tip-mag         .
           move      w-det-fat-pro-cod    to   rf-fir-num-pro         .
           move      w-det-fat-pro-dat    to   rf-fir-dat-doc         .
           move      zero                 to   rf-fir-num-prt         .
           move      zero                 to   rf-fir-num-prg         .
           move      "pgm/fat/fls/ioc/obj/ioffir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fir                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : a test su contatore       *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-fat-pro-600.
       det-fat-pro-200.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Next su [fir]                                   *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/fat/fls/ioc/obj/ioffir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fir                 .
      *                  *---------------------------------------------*
      *                  * Se 'at end' : a test su contatore           *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-fat-pro-600.
       det-fat-pro-300.
      *              *-------------------------------------------------*
      *              * Max su [fir]                                    *
      *              *-------------------------------------------------*
           if        rf-fir-tip-mag       not  = 01                or
                     rf-fir-num-pro       not  = w-det-fat-pro-cod
                     go to det-fat-pro-600.
       det-fat-pro-400.
      *              *-------------------------------------------------*
      *              * Selezione sul codice dipendenza                 *
      *              *-------------------------------------------------*
           if        rf-fir-cod-dpz       not  = w-det-fat-pro-dpz
                     go to det-fat-pro-200.
       det-fat-pro-500.
      *              *-------------------------------------------------*
      *              * Incremento contatore                            *
      *              *-------------------------------------------------*
           add       1                    to   w-det-fat-pro-ctr      .
       det-fat-pro-600.
      *              *-------------------------------------------------*
      *              * Test su contatore                               *
      *              *-------------------------------------------------*
           if        w-det-fat-pro-ctr    >    zero
                     move  "#"            to   w-det-fat-pro-flg
                     go to det-fat-pro-900.
       det-fat-pro-700.
      *              *-------------------------------------------------*
      *              * Determinazione ultima data fatturato            *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "PRODAT    "         to   f-key                  .
           move      01                   to   rf-fir-tip-mag         .
           move      w-det-fat-pro-cod    to   rf-fir-num-pro         .
           move      w-det-fat-pro-dat    to   rf-fir-dat-doc         .
           move      zero                 to   rf-fir-num-prt         .
           move      zero                 to   rf-fir-num-prg         .
           move      "pgm/fat/fls/ioc/obj/ioffir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fir                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : ad uscita                 *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-fat-pro-900.
       det-fat-pro-720.
      *              *-------------------------------------------------*
      *              * Previous su [fir]                               *
      *              *-------------------------------------------------*
           move      "RP"                 to   f-ope                  .
           move      "pgm/fat/fls/ioc/obj/ioffir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fir                 .
           
      *                  *---------------------------------------------*
      *                  * Se 'at end' : ad uscita                     *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-fat-pro-900.
       det-fat-pro-725.
      *              *-------------------------------------------------*
      *              * Previous su [fir]                               *
      *              *-------------------------------------------------*
           move      "RP"                 to   f-ope                  .
           move      "pgm/fat/fls/ioc/obj/ioffir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fir                 .
      *                  *---------------------------------------------*
      *                  * Se 'at end' : ad uscita                     *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-fat-pro-900.
       det-fat-pro-730.
      *              *-------------------------------------------------*
      *              * Max su [fir]                                    *
      *              *-------------------------------------------------*
           if        rf-fir-tip-mag       not  = 01                or
                     rf-fir-num-pro       not  = w-det-fat-pro-cod
                     go to det-fat-pro-900.
       det-fat-pro-740.
      *              *-------------------------------------------------*
      *              * Selezione sul codice dipendenza                 *
      *              *-------------------------------------------------*
           if        rf-fir-cod-dpz       not  = w-det-fat-pro-dpz
                     go to det-fat-pro-720.
       det-fat-pro-750.
      *              *-------------------------------------------------*
      *              * Bufferizzazione dati ultima fattura             *
      *              *-------------------------------------------------*
           move      rf-fir-dat-doc       to   w-det-fat-pro-duf      .
           move      rf-fir-cod-tmo       to   w-det-fat-pro-tuf      .
       det-fat-pro-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-fat-pro-999.
       det-fat-pro-999.
           exit.

