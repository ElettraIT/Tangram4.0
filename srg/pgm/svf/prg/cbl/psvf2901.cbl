      *                      *-----------------------------------------*
           move      zero                 to   w-sel-fit-ctr-ele      .
       stp-srt-inp-410.
      *                      *-----------------------------------------*
      *                      * Start su file [fit]                     *
      *                      *-----------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CLIDAT    "         to   f-key                  .
           move      rf-dcc-cod-cli       to   rf-fit-cod-cli         .
           move      rr-p1d-min           to   rf-fit-dat-doc         .
