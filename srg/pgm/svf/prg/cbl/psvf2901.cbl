      *                  *---------------------------------------------*
           if        rr-dac-min           =    zero and
                     rr-dac-max           =    zero
                     go to stp-srt-inp-520.
           if        rf-dcc-dat-aqz       <    rr-dac-min or
                     rf-dcc-dat-aqz       >    rr-dac-max
                     go to stp-srt-inp-200.
       stp-srt-inp-520.
      *                  *---------------------------------------------*
      *                  * Selezione su status cliente                 *
      *                  *---------------------------------------------*
           if        rf-dcc-sta-tus       =    01 and
                     rr-sel-sco (01 : 01) =    spaces
                     go to stp-srt-inp-200.
           if        rf-dcc-sta-tus       =    11 and
                     rr-sel-sco (02 : 01) =    spaces
                     go to stp-srt-inp-200.
           if        rf-dcc-sta-tus       =    21 and
                     rr-sel-sco (03 : 01) =    spaces
                     go to stp-srt-inp-200.
           if        rf-dcc-sta-tus       =    51 and
                     rr-sel-sco (04 : 01) =    spaces
                     go to stp-srt-inp-200.
           if        rf-dcc-sta-tus       =    52 and
                     rr-sel-sco (05 : 01) =    spaces
                     go to stp-srt-inp-200.
           if        rf-dcc-sta-tus       =    61 and
                     rr-sel-sco (06 : 01) =    spaces
                     go to stp-srt-inp-200.
           if        rf-dcc-sta-tus       =    62 and
                     rr-sel-sco (07 : 01) =    spaces
                     go to stp-srt-inp-200.
           if        rf-dcc-sta-tus       =    71 and
                     rr-sel-sco (08 : 01) =    spaces
                     go to stp-srt-inp-200.
           if        rf-dcc-sta-tus       =    72 and
                     rr-sel-sco (09 : 01) =    spaces
                     go to stp-srt-inp-200.
       stp-srt-inp-600.
