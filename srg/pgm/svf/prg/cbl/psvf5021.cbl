      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione contatore records [dcp] letti  *
      *              * da filtro di ordinamento e selezione            *
      *              *-------------------------------------------------*
           move      zero                 to   w-stp-srt-inp-ctr      .
      *              *-------------------------------------------------*
      *              * Start filtro di ordinamento e selezione per il  *
      *              * file [dcp]                                      *
      *              *-------------------------------------------------*
           move      "ST"                 to   f-ope                  .
           move      rr-fso-dcp           to   f-key                  .
           move      "pgm/dcp/prg/obj/bzosdcp0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *              *-------------------------------------------------*
      *              * Se errore su Start : ad uscita                  *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-300.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Read Next filtro di ordinamento e selezione per *
      *              * file [dcp]                                      *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcp/prg/obj/bzosdcp0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *              *-------------------------------------------------*
      *              * Se At End : ad uscita                           *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Incremento contatore records [dcp] letti da     *
      *              * filtro di ordinamento e selezione               *
      *              *-------------------------------------------------*
           add       1                    to   w-stp-srt-inp-ctr      .
       stp-srt-inp-120.
      *              *-------------------------------------------------*
      *              * Selezione su campagna di vendita                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da effettuare                       *
      *                  *---------------------------------------------*
           if        rr-dat-cdv           =    zero
                     go to stp-srt-inp-150.
      *                  *---------------------------------------------*
      *                  * Lettura record per campagna di vendita      *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "LSTPRO    "         to   f-key                  .
           move      03                   to   rf-lst-tip-rec         .
           move      spaces               to   rf-lst-cod-lst         .
           move      zero                 to   rf-lst-cod-cli         .
           move      c-sgl                to   rf-lst-sgl-vlt         .
           move      rf-dcp-num-pro       to   rf-lst-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
      *                  *---------------------------------------------*
      *                  * Se record campagna di vendita non trovato : *
      *                  * a riciclo su filtro prodotti                *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-100.
      *                  *---------------------------------------------*
      *                  * Test su data campagna di vendita            *
      *                  *---------------------------------------------*
           if        rf-lst-dva-ini       >    rr-dat-cdv
                     go to stp-srt-inp-100.
           if        rf-lst-dva-fin       <    rr-dat-cdv
                     go to stp-srt-inp-100.
       stp-srt-inp-150.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione file [fir] per un solo pro-  *
      *              * dotto                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizializzazione lettura sequenziale archi- *
      *                  * vio [fir] per un solo prodotto              *
      *                  *---------------------------------------------*
           perform   fil-fir-ing-000      thru fil-fir-ing-999        .
       stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale archivio [fir] per un   *
      *                  * solo prodotto                               *
      *                  *---------------------------------------------*
           perform   fil-fir-get-000      thru fil-fir-get-999        .
      *                  *---------------------------------------------*
      *                  * Se fine file : a riciclo su lettura filtro  *
      *                  *---------------------------------------------*
           if        w-mod-fat-fir-flg    not  = spaces
                     go to stp-srt-inp-250.
      *                  *---------------------------------------------*
      *                  * Se quantita' e fatturato sono entrambi a    *
      *                  * zero : si ignora il record                  *
      *                  *---------------------------------------------*
           if        w-mod-fat-fir-qta    =    zero and
                     w-mod-fat-fir-val    =    zero
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Se i valori non incidono sulla statistica   *
      *                  * ne' in positivo ne' in negativo : si igno-  *
      *                  * ra il record                                *
      *                  *---------------------------------------------*
           if        w-mod-fat-fir-pon    not  = "P" and
                     w-mod-fat-fir-pon    not  = "N"
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Se i valori non incidono su nessuno dei tre *
      *                  * periodi della statistica : si ignora il re- *
      *                  * cord                                        *
      *                  *---------------------------------------------*
           if        w-mod-fat-fir-sn1    not  = "S" and
                     w-mod-fat-fir-sn2    not  = "S" and
                     w-mod-fat-fir-sn3    not  = "S"
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Selezione sul record [fit] in esame         *
      *                  *---------------------------------------------*
           perform   sel-fit-rec-000      thru sel-fit-rec-999        .
      *                  *---------------------------------------------*
      *                  * Se selezione non superata : si  ignora il   *
      *                  * record                                      *
      *                  *---------------------------------------------*
           if        w-sel-fit-flg-exi    not  = spaces
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Selezione sul record [fir] in esame         *
      *                  *---------------------------------------------*
           perform   sel-fir-rec-000      thru sel-fir-rec-999        .
      *                  *---------------------------------------------*
      *                  * Se selezione non superata : si  ignora il   *
      *                  * record                                      *
      *                  *---------------------------------------------*
           if        w-sel-fir-flg-exi    not  = spaces
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Composizione record [srt] dalle aree :      *
      *                  * - [fit]                                     *
      *                  * - [fir]                                     *
      *                  * - w-sel-fit                                 *
      *                  * - w-sel-fir                                 *
      *                  * - w-mod-fat-fir                             *
      *                  * - w-not-fat-fir                             *
      *                  * - rr                                        *
      *                  *---------------------------------------------*
           perform   cmp-srt-rec-000      thru cmp-srt-rec-999        .
      *                  *---------------------------------------------*
      *                  * Aggiornamento file appoggio ad indici [kk0] *
      *                  *---------------------------------------------*
           perform   agg-fil-kk0-000      thru agg-fil-kk0-999        .
      *                  *---------------------------------------------*
      *                  * Rilascio del record al Sort                 *
      *                  *---------------------------------------------*
           release   srt-rec                                          .
      *                  *---------------------------------------------*
      *                  * Riciclo alla lettura sequenziale archivio   *
      *                  * [fir]                                       *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-250.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale filtro di ordi-  *
      *              * namento e selezione                             *
      *              *-------------------------------------------------*
            go to    stp-srt-inp-100.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Inizializzazione lettura sequenziale archivio [fir] per   *
      *    * un solo codice prodotto                                   *
      *    *-----------------------------------------------------------*
       fil-fir-ing-000.
      *              *-------------------------------------------------*
      *              * Richiamo funzione 'CS' del modulo 'mfatfir0'    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice prodotto                         *
      *                      *-----------------------------------------*
           move      rf-dcp-num-pro       to   w-mod-fat-fir-pro      .
      *                      *-----------------------------------------*
      *                      * Numero periodi di riferimento           *
      *                      *-----------------------------------------*
           if        rr-num-pdr           =    11 or
                     rr-num-pdr           =    12
                     move  02             to   w-mod-fat-fir-npr
           else if   rr-num-pdr           =    21 or
                     rr-num-pdr           =    22
                     move  01             to   w-mod-fat-fir-npr
           else      move  rr-num-pdr     to   w-mod-fat-fir-npr      .
      *                      *-----------------------------------------*
      *                      * Tipo calcolo voce 'Costo del Fatturato' *
      *                      *-----------------------------------------*
           if        rr-num-pdr           =    21
                     move  "P"            to   w-mod-fat-fir-ccf
           else if   rr-num-pdr           =    22
                     move  "U"            to   w-mod-fat-fir-ccf
           else      move  spaces         to   w-mod-fat-fir-ccf      .
      *                      *-----------------------------------------*
      *                      * 1. periodo, data min                    *
      *                      *-----------------------------------------*
           move      rr-p1d-min           to   w-mod-fat-fir-p1i      .
      *                      *-----------------------------------------*
      *                      * 1. periodo, data max                    *
      *                      *-----------------------------------------*
           move      rr-p1d-max           to   w-mod-fat-fir-p1f      .
      *                      *-----------------------------------------*
      *                      * 2. periodo, data min                    *
      *                      *-----------------------------------------*
           move      rr-p2d-min           to   w-mod-fat-fir-p2i      .
      *                      *-----------------------------------------*
      *                      * Ritaratura della data 2. periodo min in *
      *                      * presenza di data valorizzazione         *
      *                      *-----------------------------------------*
           if        rr-num-pdr           =    21   or
                     rr-num-pdr           =    22
                     move  rr-dat-val     to   w-mod-fat-fir-p2i      .
      *                      *-----------------------------------------*
      *                      * 2. periodo, data max                    *
      *                      *-----------------------------------------*
           move      rr-p2d-max           to   w-mod-fat-fir-p2f      .
      *                      *-----------------------------------------*
      *                      * 3. periodo, data min                    *
      *                      *-----------------------------------------*
           move      rr-p3d-min           to   w-mod-fat-fir-p3i      .
      *                      *-----------------------------------------*
      *                      * 3. periodo, data max                    *
      *                      *-----------------------------------------*
           move      rr-p3d-max           to   w-mod-fat-fir-p3f      .
      *                  *---------------------------------------------*
      *                  * Chiamata modulo                             *
      *                  *---------------------------------------------*
           perform   mod-fat-fir-cds-000  thru mod-fat-fir-cds-999    .
       fil-fir-ing-999.
           exit.

      *    *===========================================================*
      *    * Lettura sequenziale archivio [fir] per un solo codice     *
      *    * prodotto                                                  *
      *    *-----------------------------------------------------------*
       fil-fir-get-000.
      *              *-------------------------------------------------*
      *              * Richiamo funzione 'CG' del modulo 'mfatfir0'    *
      *              *-------------------------------------------------*
           perform   mod-fat-fir-cdg-000  thru mod-fat-fir-cdg-999    .
       fil-fir-get-999.
           exit.

      *    *===========================================================*
      *    * Selezioni su record [fit] in esame                        *
      *    *-----------------------------------------------------------*
       sel-fit-rec-000.
      *              *-------------------------------------------------*
      *              * Selezione su codice dipendenza                  *
      *              *-------------------------------------------------*
       sel-fit-rec-005.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del numero di dipen-   *
      *                  * denze selezionate                           *
      *                  *---------------------------------------------*
           if        rr-dpz-inu           not  = zero
                     go to sel-fit-rec-010
           else if   rr-dpz-ctr-dpz       =    rr-dpz-ctr-sel
                     go to sel-fit-rec-015
           else      go to sel-fit-rec-020.
       sel-fit-rec-010.
      *                  *---------------------------------------------*
      *                  * Se una sola dipendenza selezionata          *
      *                  *---------------------------------------------*
           if        rf-fit-cod-dpz       =    rr-dpz-inu
                     go to sel-fit-rec-100
           else      go to sel-fit-rec-900.
       sel-fit-rec-015.
      *                  *---------------------------------------------*
      *                  * Se tutte le dipendenze selezionate          *
      *                  *---------------------------------------------*
           go to     sel-fit-rec-100.
       sel-fit-rec-020.
      *                  *---------------------------------------------*
      *                  * Se solo alcune dipendenze selezionate       *
      *                  *---------------------------------------------*
