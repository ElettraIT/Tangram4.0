      *                      *-----------------------------------------*
           go to     rip-cdp-ndo-999.
       rip-cdp-ndo-400.
      *                  *---------------------------------------------*
      *                  * Se il valore risulta cambiato               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se il cambiamento corrisponde alla for- *
      *                      * zatura eseguita dall'operatore stesso   *
      *                      * in caso di impostazione di un numero    *
      *                      * superiore al progressivo : si controag- *
      *                      * giorna senza alcun messaggio            *
      *                      *-----------------------------------------*
           if        rn-cdp-ndo-num-doc   =    w-att-cdp-ndo-num
                     go to rip-cdp-ndo-200.
      *                      *-----------------------------------------*
      *                      * Se il cambiamento invece e' dovuto al   *
      *                      * fatto che un altro utente ha nel frat-  *
      *                      * tempo prelevato un numero progressivo   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Unlock                              *
      *                          *-------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/cdp/num/ioc/obj/incdpndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-cdp-ndo             .
      *                          *-------------------------------------*
      *                          * Messaggio all'operatore che il nu-  *
      *                          * mero deve essere recuperato manual- *
      *                          * mente                               *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Salvataggio del video attuale   *
      *                              *---------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Video in Off                    *
      *                              *---------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Box                             *
      *                              *---------------------------------*
           move      "BX"                 to   v-ope                  .
           move      09                   to   v-lin                  .
           move      18                   to   v-lto                  .
           move      08                   to   v-pos                  .
           move      73                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Messaggi entro il box           *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Titolo centrale             *
      *                                  *-----------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "                     A T T E N Z I O N E          
      -              "            "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                  *-----------------------------*
      *                                  * Riga messaggio 1            *
      *                                  *-----------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "Un altro utente ha nel frattempo prelevato un nume
      -              "ro !        "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                  *-----------------------------*
      *                                  * Riga messaggio 2            *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Preparazione numero do- *
      *                                      * cumento editato         *
      *                                      *-------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-att-cdp-ndo-new    to   w-att-cdp-ndo-wnu      .
           move      w-att-cdp-ndo-wpr    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                                      *-------------------------*
      *                                      * Visualizzazione         *
      *                                      *-------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           string    "Pertanto il numero  "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " dovra' essere recuperato manualmente."
                                delimited by   size
                                          into v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                  *-----------------------------*
      *                                  * Riga messaggio 3            *
      *                                  *-----------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "                                                  
      -              "         [ ]"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                      *-------------------------*
      *                                      * Video in On             *
      *                                      *-------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                      *-------------------------*
      *                                      * Accettazione carattere  *
      *                                      * di presa visione        *
      *                                      *-------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      17                   to   v-lin                  .
           move      70                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                      *-------------------------*
      *                                      * Ripristino immagine     *
      *                                      * video                   *
      *                                      *-------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       rip-cdp-ndo-999.
           exit.

