      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione valore di default              *
      *                  *---------------------------------------------*
           if        w-tes-tmo-cdp        not  = spaces
                     go to acc-tmo-cdp-100.
           move      w-def-tmo-cdp        to   w-tes-tmo-cdp          .
       acc-tmo-cdp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-des-ycp-ope      .
           move      w-tes-tmo-cdp        to   w-cod-des-ycp-cod      .
           move      04                   to   w-cod-des-ycp-lin      .
           move      18                   to   w-cod-des-ycp-pos      .
           move      04                   to   w-cod-des-ycp-dln      .
           move      24                   to   w-cod-des-ycp-dps      .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   cod-des-ycp-cll-000  thru cod-des-ycp-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-des-ycp-foi-000  thru cod-des-ycp-foi-999    .
       acc-tmo-cdp-110.
