           move      w-tes-dec-qta (1)    to   rf-cdp-dec-qta         .
           move      w-tes-qta-dap (1)    to   rf-cdp-qta-dap         .
           move      w-tes-cod-dsl (1)    to   rf-cdp-cod-dsl         .
           move      w-tes-snx-2qt (1)    to   rf-cdp-snx-2qt         .
           move      w-tes-dec-2qt (1)    to   rf-cdp-dec-2qt         .
           move      w-tes-qta-a02 (1)    to   rf-cdp-qta-a02         .
           move      w-tes-snx-3qt (1)    to   rf-cdp-snx-3qt         .
           move      w-tes-dec-3qt (1)    to   rf-cdp-dec-3qt         .
           move      w-tes-qta-a03 (1)    to   rf-cdp-qta-a03         .
           move      w-tes-ctr-stp (1)    to   rf-cdp-ctr-stp         .
           move      w-tes-sdc-ccs (1)    to   rf-cdp-sdc-ccs         .
           move      w-tes-flg-cch (1)    to   rf-cdp-flg-cch         .
           move      w-tes-flg-ela (1)    to   rf-cdp-flg-ela         .
           move      w-tes-flg-pul (1)    to   rf-cdp-flg-pul         .
           move      w-tes-alx-exp (1)    to   rf-cdp-alx-exp         .
       cmp-rec-cdp-999.
           exit.

