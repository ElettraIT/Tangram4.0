           move      "pgm/cdp/fls/ioc/obj/iofyrc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-yrc                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-yrc-400.
       let-arc-yrc-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-yrc-des-rdc       to   w-let-arc-yrc-des      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
