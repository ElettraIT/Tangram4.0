      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Start su file [cdp]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "IDEDOC    "         to   f-key                  .
           move      rr-dat-min           to   rf-cdp-dat-doc         .
           move      rr-dpz-inu           to   rf-cdp-cod-dpz         .
           move      zero                 to   rf-cdp-num-doc         .
           move      spaces               to   rf-cdp-tmo-cdp         .
           move      zero                 to   rf-cdp-num-prt         .
           move      "pgm/cdp/fls/ioc/obj/iofcdp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cdp                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [cdp]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cdp/fls/ioc/obj/iofcdp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cdp                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-120.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su data commessa massima               *
      *                  *---------------------------------------------*
           if        rf-cdp-dat-doc       >    rr-dat-max
                     go to stp-srt-inp-999.
      *              *-------------------------------------------------*
      *              * Selezione sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice dipendenza                   *
      *                  *---------------------------------------------*
           if        rf-cdp-cod-dpz       not  = rr-dpz-inu
                     go to stp-srt-inp-100.
      *                  *---------------------------------------------*
      *                  * Test su flag di commessa chiusa             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione dello stato del- *
      *                      * le commesse richiesto                   *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-121
                     stp-srt-inp-122
                     stp-srt-inp-123
                     depending            on   rr-sts-cdp             .
       stp-srt-inp-121.
      *                      *-----------------------------------------*
      *                      * Se solo commesse da evadere             *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test su flag di commessa chiusa     *
      *                          *-------------------------------------*
           if        rf-cdp-flg-cch       not  = spaces
                     go to stp-srt-inp-100.
           go to     stp-srt-inp-130.
       stp-srt-inp-122.
      *                      *-----------------------------------------*
      *                      * Se solo commesse gia' evase             *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Nessun test                         *
      *                          *-------------------------------------*
           go to     stp-srt-inp-130.
       stp-srt-inp-123.
      *                      *-----------------------------------------*
      *                      * Se tutte le commesse                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Nessun test                         *
      *                          *-------------------------------------*
