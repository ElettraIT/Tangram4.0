           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      v-lnr                to   v-lin                  .
           move      17                   to   v-pos                  .
           if        rf-cdp-tip-mag       =    01
                     move  "[P]"          to   v-alf
           else      move  "[S]"          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
