           add       1                    to   w-ovy-exe-inx          .
           move      w-ovy-exe-pos        to   w-ovy-exe-spv
                                              (w-ovy-exe-inx)         .
           call      w-ovy-exe-pat       using i-ide
                                               w-ovy-exe
                                               w-tin
                                               w-spg                  .
       qry-trt-fun-335.
      *                  *---------------------------------------------*
      *                  * Cancellazione del sottoprogramma            *
      *                  *---------------------------------------------*
           move      w-ovy-exe-spv
                    (w-ovy-exe-inx)       to   w-ovy-exe-pos          .
           cancel    w-ovy-exe-pat                                    .
           subtract  1                    from w-ovy-exe-inx          .
       qry-trt-fun-340.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     qry-trt-fun-999.
       qry-trt-fun-900.
      *              *-------------------------------------------------*
      *              * Se function-key non riconosciuta                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione function key                *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Uscita senza alcuna azione                  *
      *                  *---------------------------------------------*
           go to     qry-trt-fun-999.
       qry-trt-fun-999.
           exit.

      *    *===========================================================*
      *    * Determinazione status della commessa di produzione        *
      *    *-----------------------------------------------------------*
       det-sts-cdp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status commessa di produzione   *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-sts-cdp-sts      .
      *              *-------------------------------------------------*
      *              * Normalizzazione quantita' determinata dalla     *
      *              * scansione del file [vpt]                        *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-sts-cdp-qta      .
      *              *-------------------------------------------------*
      *              * Normalizzazione quantita' da evadere            *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-sts-cdp-qde      .
      *              *-------------------------------------------------*
      *              * Start su file [vpt] per calcolo della quantita' *
      *              * eventualmente evasa                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "RIFCDP    "         to   f-key                  .
           move      rf-cdp-num-prt       to   rf-vpt-prt-cdp         .
           move      zero                 to   rf-vpt-num-prt         .
           move      "pgm/vdp/fls/ioc/obj/iofvpt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vpt                 .
      *              *-------------------------------------------------*
      *              * Se Start errata : a determinazione finale       *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-sts-cdp-800.
       det-sts-cdp-100.
      *              *-------------------------------------------------*
      *              * Next su [vpt]                                   *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/vdp/fls/ioc/obj/iofvpt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vpt                 .
      *              *-------------------------------------------------*
      *              * Se 'at end' : a determinazione finale status    *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-sts-cdp-800.
       det-sts-cdp-200.
      *              *-------------------------------------------------*
      *              * Max su [vpt], se non superato : a determinazio- *
      *              * ne finale                                       *
      *              *-------------------------------------------------*
           if        rf-vpt-prt-cdp       not  = rf-cdp-num-prt
                     go to det-sts-cdp-800.
      *              *-------------------------------------------------*
      *              * Cumulo della quantita' prodotta                 *
      *              *-------------------------------------------------*
           add       rf-vpt-qta-pdt       to   w-det-sts-cdp-qta      .
       det-sts-cdp-400.
      *              *-------------------------------------------------*
      *              * Riciclo a versamento da produzione successivo   *
      *              *-------------------------------------------------*
           go to     det-sts-cdp-100.
       det-sts-cdp-800.
      *              *-------------------------------------------------*
      *              * Determinazione finale dello status delle com-   *
      *              * messe di produzione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se quantita' rilevata a zero : commessa in- *
      *                  * evasa                                       *
      *                  *---------------------------------------------*
           if        w-det-sts-cdp-qta    =    zero
                     move  01             to   w-det-sts-cdp-sts
                     go to det-sts-cdp-999.
      *                  *---------------------------------------------*
      *                  * Confronto con la quantita' in commessa      *
      *                  *---------------------------------------------*
           if        w-det-sts-cdp-qta    <    rf-cdp-qta-dap
                     go to det-sts-cdp-820.
      *                      *-----------------------------------------*
      *                      * Se uguale o maggiore di quella in com-  *
      *                      * messa                                   *
      *                      *-----------------------------------------*
           move      02                   to   w-det-sts-cdp-sts      .
           go to     det-sts-cdp-999.
       det-sts-cdp-820.
      *                      *-----------------------------------------*
      *                      * Se minore di quella in commessa         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * determinazione della quantita' da   *
      *                          * evadere                             *
      *                          *-------------------------------------*
           subtract  w-det-sts-cdp-qta    from rf-cdp-qta-dap
                                        giving w-det-sts-cdp-qde      .
      *                          *-------------------------------------*
      *                          * Test su segnale di commessa comun-  *
      *                          * que considerata saldata             *
      *                          *-------------------------------------*
           if        rf-cdp-sdc-ccs       =    spaces
                     move  01             to   w-det-sts-cdp-sts
           else      move  02             to   w-det-sts-cdp-sts      .
       det-sts-cdp-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [ycp]                         *
      *    *-----------------------------------------------------------*
       let-arc-ycp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-ycp-flg      .
      *              *-------------------------------------------------*
      *              * Test se codice a spazi                          *
      *              *-------------------------------------------------*
           if        w-let-arc-ycp-cod    =    spaces
                     go to let-arc-ycp-500.
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODTCP"             to   f-key                  .
           move      w-let-arc-ycp-cod    to   rf-ycp-cod-tcp         .
           move      w-let-arc-ycp-dpz    to   rf-ycp-cod-dpz         .
           move      "pgm/cdp/fls/ioc/obj/iofycp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ycp                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-ycp-400.
       let-arc-ycp-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-ycp-des-tcp       to   w-let-arc-ycp-des      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-ycp-999.
       let-arc-ycp-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-ycp-flg      .
           move      all   "."            to   w-let-arc-ycp-des      .
           go to     let-arc-ycp-999.
       let-arc-ycp-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-ycp-des      .
       let-arc-ycp-999.
           exit.

      *    *===========================================================*
      *    * Memorizzazione sottoprogramma in attivita'                *
      *    *-----------------------------------------------------------*
       mem-spg-att-000.
      *              *-------------------------------------------------*
      *              * Se numero elementi in tabella gia' pari al mas- *
      *              * simo numero di elementi possibili : uscita per  *
      *              * memorizzazione non avvenuta                     *
      *              *-------------------------------------------------*
           if        w-spg-ele-num        =    w-spg-ele-max
                     move  "N"            to   w-spg-snx-gat
                     go to mem-spg-att-999.
      *              *-------------------------------------------------*
      *              * Incremento numero elementi in tabella           *
      *              *-------------------------------------------------*
           add       1                    to   w-spg-ele-num          .
      *              *-------------------------------------------------*
      *              * Memorizzazione codice alfanumerico del tipo di  *
      *              * interrogazione                                  *
      *              *-------------------------------------------------*
           move      w-spg-alf-gat        to   w-spg-alf-tin
                                              (w-spg-ele-num)         .
      *              *-------------------------------------------------*
      *              * Uscita per memorizzazione avvenuta              *
      *              *-------------------------------------------------*
           move      spaces               to   w-spg-snx-gat          .
       mem-spg-att-999.
           exit.

      *    *===========================================================*
      *    * Eliminazione sottoprogramma in attivita'                  *
      *    *-----------------------------------------------------------*
       eli-spg-att-000.
      *              *-------------------------------------------------*
      *              * Se numero elementi in tabella a zero : uscita   *
      *              *-------------------------------------------------*
           if        w-spg-ele-num        =    zero
                     go to eli-spg-att-999.
      *              *-------------------------------------------------*
      *              * Se l'ultimo elemento in tabella non e' pari a   *
      *              * quello da eliminare : uscita                    *
      *              *-------------------------------------------------*
           if        w-spg-alf-tin
                    (w-spg-ele-num)       not  = w-spg-alf-gat
                     go to eli-spg-att-999.
      *              *-------------------------------------------------*
      *              * Decremento numero elementi in tabella           *
      *              *-------------------------------------------------*
           subtract  1                    from w-spg-ele-num          .
       eli-spg-att-999.
           exit.

      *    *===========================================================*
      *    * Test se sottoprogramma gia' attivo                        *
      *    *-----------------------------------------------------------*
       tst-spg-gat-000.
      *              *-------------------------------------------------*
      *              * Risposta a : non gia' attivo                    *
      *              *-------------------------------------------------*
           move      spaces               to   w-spg-snx-gat          .
      *              *-------------------------------------------------*
      *              * Se codice alfanumerico del tipo di interroga-   *
      *              * zione a spaces : uscita                         *
      *              *-------------------------------------------------*
           if        w-spg-alf-gat        =    spaces
                     go to tst-spg-gat-999.
      *              *-------------------------------------------------*
      *              * Indice per scansione su tabella a zero          *
      *              *-------------------------------------------------*
           move      zero                 to   w-spg-ele-inx          .
       tst-spg-gat-200.
      *              *-------------------------------------------------*
      *              * Incremento indice per scansione su tabella      *
      *              *-------------------------------------------------*
           add       1                    to   w-spg-ele-inx          .
      *              *-------------------------------------------------*
      *              * Se oltre numero elementi memorizzati : uscita   *
      *              *-------------------------------------------------*
           if        w-spg-ele-inx        >    w-spg-ele-num
                     go to tst-spg-gat-999.
      *              *-------------------------------------------------*
      *              * Se l'elemento non e' quello cercato : riciclo   *
      *              * su elemento successivo                          *
      *              *-------------------------------------------------*
           if        w-spg-alf-tin
                    (w-spg-ele-inx)       not  = w-spg-alf-gat
                     go to tst-spg-gat-200.
       tst-spg-gat-400.
      *              *-------------------------------------------------*
      *              * Risposta a : gia' attivo                        *
      *              *-------------------------------------------------*
           move      "S"                  to   w-spg-snx-gat          .
       tst-spg-gat-999.
           exit.

      *    *===========================================================*
      *    * Subroutines per l'accettazione tipo movimento per commes- *
      *    * sa di produzione                                          *
      *    *-----------------------------------------------------------*
           copy      "pgm/cdp/prg/cpy/acdeycp0.acs"                   .
