      *    *===========================================================*
      *    * Editing del codice sottoconto con appoggio a sx o dx      *
      *    *-----------------------------------------------------------*
           copy      "pgm/cge/prg/cpy/wedtpdc0.wks"                   .

      *    *===========================================================*
      *    * Routine di stampa cornice inferiore o superiore           *
      *    *-----------------------------------------------------------*
       stp-crn-soi-000.
      *              *-------------------------------------------------*
      *              * Interlinea                                      *
      *              *-------------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Stampa cornice                                  *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      096                  to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      "+-------------------------------------------------
      -              "---------------------------------------------+"
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-crn-soi-999.
           exit.

      *    *===========================================================*
      *    * Routine di stampa cornice intermedia                      *
      *    *-----------------------------------------------------------*
       stp-crn-int-000.
      *              *-------------------------------------------------*
      *              * Stampa cornice                                  *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      092                  to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      003                  to   p-pos                  .
           move      all "-"              to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-crn-int-999.
           exit.

      *    *===========================================================*
      *    * Routine di stampa literal del campo                       *
      *    *-----------------------------------------------------------*
       stp-lit-cmp-000.
      *              *-------------------------------------------------*
      *              * Incremento del puntatore                        *
      *              *-------------------------------------------------*
           add       1                    to   w-pcl-lit-inx          .
           if        w-pcl-lit-inx        >    w-pcl-lit-max
                     go to stp-lit-cmp-999.
      *              *-------------------------------------------------*
      *              * Determinazione lunghezza literal                *
      *              *-------------------------------------------------*
           move      w-pcl-ele-lit
                    (w-pcl-lit-inx)       to   w-det-lun-lit-str      .
           perform   det-lun-lit-000      thru det-lun-lit-999        .
      *              *-------------------------------------------------*
      *              * Literal                                         *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      w-det-lun-lit-car    to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-pcl-ele-plt
                    (w-pcl-lit-inx)       to   p-pos                  .
           move      w-pcl-ele-lit
                    (w-pcl-lit-inx)       to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-lit-cmp-999.
           exit.

      *    *===========================================================*
      *    * Routine di stampa bordo sinistro o destro                 *
      *    *-----------------------------------------------------------*
       stp-brd-sod-000.
      *              *-------------------------------------------------*
      *              * Selezione destro o sinistro                     *
      *              *-------------------------------------------------*
           if        w-stp-brd-sod-sgn    =    "S"
                     move  001            to   p-pos
           else      move  096            to   p-pos                  .
      *              *-------------------------------------------------*
      *              * Stampa                                          *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      001                  to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      "|"                  to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-brd-sod-999.
           exit.

      *    *===========================================================*
      *    * Routine di stampa interlinea con bordo destro o sinistro  *
      *    * senza controllo sulle linee residue                       *
      *    *-----------------------------------------------------------*
       stp-int-bds-000.
      *              *-------------------------------------------------*
      *              * Bordo a destra                                  *
      *              *-------------------------------------------------*
           move      "D"                  to   w-stp-brd-sod-sgn      .
           perform   stp-brd-sod-000      thru stp-brd-sod-999        .
      *              *-------------------------------------------------*
      *              * Interlinea                                      *
      *              *-------------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Bordo a sinistra                                *
      *              *-------------------------------------------------*
           move      "S"                  to   w-stp-brd-sod-sgn      .
           perform   stp-brd-sod-000      thru stp-brd-sod-999        .
       stp-int-bds-999.
           exit.

