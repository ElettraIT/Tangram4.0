      *              *-------------------------------------------------*
       acc-rig-psr-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-rig-psr-620.
      *                  *---------------------------------------------*
      *                  * Tasti funzione                              *
      *                  *---------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-rig-psr-650
           else if   v-key                =    "DOWN"
                     go to acc-rig-psr-700
           else if   v-key                =    "DO  "
                     go to acc-rig-psr-800
           else      go to acc-rig-psr-710.
       acc-rig-psr-650.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        w-edt-psr-pes-c01    =    1
                     go to acc-rig-psr-999.
           subtract  1                    from w-edt-psr-pes-c01      .
           go to     acc-rig-psr-100.
       acc-rig-psr-700.
      *              *-------------------------------------------------*
      *              * Se Down                                         *
      *              *-------------------------------------------------*
           go to     acc-rig-psr-999.
       acc-rig-psr-710.
      *              *-------------------------------------------------*
      *              * Se Return                                       *
      *              *-------------------------------------------------*
           if        w-edt-psr-pes-c01    =    05
                     go to acc-rig-psr-999.
      *                  *---------------------------------------------*
      *                  * Incremento contatore                        *
      *                  *---------------------------------------------*
           add       1                    to   w-edt-psr-pes-c01      .
           go to     acc-rig-psr-100.
       acc-rig-psr-800.
      *              *-------------------------------------------------*
