           exit.

      *    *===========================================================*
      *    * Aggiornamento record [aaf]                                *
      *    *-----------------------------------------------------------*
       upd-rec-aaf-000.
      *              *-------------------------------------------------*
      *              * Lettura, con lock, del record                   *
      *              *-------------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "PRFNFM    "         to   f-key                  .
           move      01                   to   rf-aaf-tip-mag         .
           move      w-rig-num-pro        to   rf-aaf-num-pro         .
           move      w-tes-cod-fnt        to   rf-aaf-cod-dcf         .
           move      spaces               to   rf-aaf-fda-pif         .
           move      "pgm/dcf/fls/ioc/obj/iofaaf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-aaf                 .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to upd-rec-aaf-250.
       upd-rec-aaf-200.
      *              *-------------------------------------------------*
      *              * Se record [aaf] non esistente                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     upd-rec-aaf-900.
       upd-rec-aaf-250.
      *              *-------------------------------------------------*
      *              * Se record [aaf] esistente                       *
      *              *-------------------------------------------------*
       upd-rec-aaf-300.
      *                  *---------------------------------------------*
      *                  * Aggiornamento dati nel record               *
      *                  *---------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rf-aaf-ide-dat         .
           move      s-ute                to   rf-aaf-ide-ute         .
           move      s-fas                to   rf-aaf-ide-fas         .
           move      w-rig-cop-sfn        to   rf-aaf-cop-sfn         .
           move      w-rig-dpr-acq        to   rf-aaf-dec-prz         .
           move      w-rig-tip-pza        to   rf-aaf-tip-pza         .
           move      w-rig-sgl-vlt        to   rf-aaf-sgl-vlt         .
           move      w-rig-prz-pes        to   rf-aaf-prz-pes (1)     .
           move      w-rig-psr-pes (1)    to   rf-aaf-psr-pes (1, 1)  .
           move      w-rig-psr-pes (2)    to   rf-aaf-psr-pes (1, 2)  .
           move      w-rig-psr-pes (3)    to   rf-aaf-psr-pes (1, 3)  .
           move      w-rig-psr-pes (4)    to   rf-aaf-psr-pes (1, 4)  .
           move      w-rig-psr-pes (5)    to   rf-aaf-psr-pes (1, 5)  .
      *                      *-----------------------------------------*
      *                      * Prezzo riferito a quantita'             *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test                                *
      *                          *-------------------------------------*
           if        w-rig-prz-raq        =    zero or
                     w-rig-prz-raq        =    1
                     go to upd-rec-aaf-400.
      *                          *-------------------------------------*
      *                          * Forzatura parametri                 *
      *                          *-------------------------------------*
           move      "P"                  to   rf-aaf-snx-tum         .
           if        w-rig-prz-raq        =    1000
                     move  "MGL"          to   rf-aaf-umf-tum
           else if   w-rig-prz-raq        =    100
                     move  "CNT"          to   rf-aaf-umf-tum
           else if   w-rig-prz-raq        =    10
                     move  "DCN"          to   rf-aaf-umf-tum
           else      move  "NNN"          to   rf-aaf-umf-tum         .
           move      3                    to   rf-aaf-nde-tum         .
           move      w-rig-prz-raq        to   rf-aaf-cmo-tum         .
           move      1                    to   rf-aaf-cdi-tum         .
       upd-rec-aaf-400.
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/dcf/fls/ioc/obj/iofaaf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-aaf                 .
       upd-rec-aaf-500.
      *                  *---------------------------------------------*
      *                  * Release                                     *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/dcf/fls/ioc/obj/iofaaf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-aaf                 .
       upd-rec-aaf-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     upd-rec-aaf-999.
       upd-rec-aaf-999.
           exit.

