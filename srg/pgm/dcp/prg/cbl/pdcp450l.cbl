       acc-fso-dcp-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-fso-dcp          .
       acc-fso-dcp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura codice filtro selezione e ordina-   *
      *                  * mento per file [dcp]                        *
      *                  *---------------------------------------------*
           move      w-tes-fso-dcp        to   w-let-fso-dcp-cod      .
           perform   let-fso-dcp-000      thru let-fso-dcp-999        .
           move      w-let-fso-dcp-des    to   w-tes-fso-dcp-des      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione filtro          *
      *                  *---------------------------------------------*
           perform   vis-fso-dcp-des-000  thru vis-fso-dcp-des-999    .
      *                  *---------------------------------------------*
      *                  * Se codice filtro non esistente : a reimpo-  *
      *                  * stazione                                    *
      *                  *---------------------------------------------*
           if        w-let-fso-dcp-flg    not  = spaces
                     go to acc-fso-dcp-100.
       acc-fso-dcp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-fso-dcp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-fso-dcp-999.
           perform   cnt-key-vuo-000      thru cnt-key-vuo-999        .
           if        w-cnt-key-vuo-flg    not  = spaces
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-fso-dcp-999.
           perform   cnt-tdo-key-000      thru cnt-tdo-key-999        .
           if        w-cnt-tdo-key-flg    not  = spaces
                     go to acc-fso-dcp-100
           else      move  "S"            to   w-cnt-tus-acc-key
                     go to acc-fso-dcp-999.
       acc-fso-dcp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice filtro per selezione ed    *
      *    *                         ordinamento file [dcp]            *
      *    *-----------------------------------------------------------*
       vis-fso-dcp-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-fso-dcp        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-fso-dcp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Descrizione codice filtro per se- *
      *    *                         lezione ed ordinamento file [dcp] *
      *    *-----------------------------------------------------------*
       vis-fso-dcp-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-fso-dcp-des    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-fso-dcp-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : % di sconto                          *
      *    *-----------------------------------------------------------*
       acc-psr-pes-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore 01..05           *
      *                  *---------------------------------------------*
           move      01                   to   w-edt-psr-pes-c01      .
      *                  *---------------------------------------------*
      *                  * Test se richiesta sostituzione              *
      *                  *---------------------------------------------*
           if        w-tes-psr-pes-sns    =    zero
                     go to acc-psr-pes-100.
      *                  *---------------------------------------------*
      *                  * Forzatura del tasto Pf1                     *
      *                  *---------------------------------------------*
           move      "[1] "               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * A test su Pf1                               *
      *                  *---------------------------------------------*
           go to     acc-psr-pes-300.
       acc-psr-pes-100.
      *              *-------------------------------------------------*
      *              * Note operative                                  *
      *              *-------------------------------------------------*
           if        w-edt-psr-pes-c01    not  = 1
                     go to acc-psr-pes-110.
      *
           move      "NT"                 to   v-ope                  .
           move      "[F1] per sostituzione"
                                          to   v-not                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-psr-pes-110.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      09                   to   v-lin                  .
           move      w-edt-psr-pes-c01    to   v-pos                  .
           if        w-edt-psr-pes-c01    >    5
                     subtract  5          from v-pos                  .
           multiply  06                   by   v-pos                  .
           add       24                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "TAB "               to   v-pfk (10)             .
           if        w-edt-psr-pes-c01    =    1
                     move  "[1] "         to   v-pfk (14)             .
           move      w-tes-psr-pes
                    (w-edt-psr-pes-c01)   to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Cancellazione eventuali note operative          *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-psr-pes-999.
       acc-psr-pes-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-psr-pes
                                              (w-edt-psr-pes-c01)     .
       acc-psr-pes-300.
      *              *-------------------------------------------------*
      *              * Se Pf1                                          *
      *              *-------------------------------------------------*
           if        v-key                not  = "[1] "
                     go to acc-psr-pes-400.
      *                  *---------------------------------------------*
      *                  * Subroutine di accettazione valore sostitu-  *
      *                  * tivo                                        *
      *                  *---------------------------------------------*
           perform   acc-psr-pes-sos-000  thru acc-psr-pes-sos-999    .
           if        w-cnt-tus-acc-key    not  = spaces
                     go to acc-psr-pes-999.
      *                  *---------------------------------------------*
      *                  * Visualizzazione sostituzione effettuata     *
      *                  *---------------------------------------------*
           perform   vis-psr-pes-sos-000  thru vis-psr-pes-sos-999    .
      *                  *---------------------------------------------*
      *                  * Se sostituzione non effettuata ma impostati *
      *                  * valori : rivisualizzazione valori impostati *
      *                  *---------------------------------------------*
           if        w-tes-psr-pes-sns    not  = zero
                     go to acc-psr-pes-800.
      *                  *---------------------------------------------*
      *                  * Visualizzazione codice impostato            *
      *                  *---------------------------------------------*
           perform   vis-psr-pes-000      thru vis-psr-pes-999        .
       acc-psr-pes-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-psr-pes-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-psr-pes-620
           else if   v-key                =    "DOWN"
                     go to acc-psr-pes-630
           else if   v-key                =    "TAB "
                     go to acc-psr-pes-700
           else if   v-key                =    "DO  "
                     go to acc-psr-pes-800
           else      go to acc-psr-pes-630.
       acc-psr-pes-620.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        w-edt-psr-pes-c01    =    1
                     go to acc-psr-pes-999.
           subtract  1                    from w-edt-psr-pes-c01      .
           go to     acc-psr-pes-100.
       acc-psr-pes-630.
      *              *-------------------------------------------------*
      *              * Se Down o Return                                *
      *              *-------------------------------------------------*
           go to     acc-psr-pes-999.
       acc-psr-pes-700.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        w-edt-psr-pes-c01    =    05
                     go to acc-psr-pes-999.
      *                  *---------------------------------------------*
      *                  * Incremento contatore                        *
      *                  *---------------------------------------------*
           add       1                    to   w-edt-psr-pes-c01      .
           go to     acc-psr-pes-100.
       acc-psr-pes-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-psr-pes-999.
           perform   cnt-key-vuo-000      thru cnt-key-vuo-999        .
           if        w-cnt-key-vuo-flg    not  = spaces
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-psr-pes-999.
           perform   cnt-tdo-key-000      thru cnt-tdo-key-999        .
           if        w-cnt-tdo-key-flg    not  = spaces
                     go to acc-psr-pes-100
           else      move  "S"            to   w-cnt-tus-acc-key
                     go to acc-psr-pes-999.
       acc-psr-pes-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Percentuali di sconto in riga     *
      *    *-----------------------------------------------------------*
       vis-psr-pes-000.
           move      spaces               to   w-edt-psr-pes          .
           move      zero                 to   w-edt-psr-pes-c01      .
       vis-psr-pes-200.
           add       1                    to   w-edt-psr-pes-c01      .
           if        w-edt-psr-pes-c01    >    5
                     go to vis-psr-pes-500.
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      w-tes-psr-pes 
                    (w-edt-psr-pes-c01)   to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-edt-psr-pes-ele
                                              (w-edt-psr-pes-c01)     .
           go to     vis-psr-pes-200.
       vis-psr-pes-500.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      30                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-edt-psr-pes        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       vis-psr-pes-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : % di sconto                          *
      *    *                                                           *
      *    * Subroutine di sostituzione                                *
      *    *-----------------------------------------------------------*
       acc-psr-pes-sos-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione segnale di sostituzione     *
      *                  *---------------------------------------------*
           move      zero                 to   w-tes-psr-pes-sns      .
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      w-lpt-psr-pes-lin    to   v-lin                  .
           subtract  1                    from v-lin                  .
           move      w-lpt-psr-pes-pos    to   v-pos                  .
           subtract  1                    from v-pos                  .
           move      w-lpt-psr-pes-lin    to   v-lto                  .
           add       2                    to   v-lto                  .
           move      w-lpt-psr-pes-pos    to   v-pto                  .
           add       50                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-psr-pes-sos-010.
      *                  *---------------------------------------------*
      *                  * Prompts per il box                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Valore da sostituire                    *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      15                   to   v-car                  .
           move      w-lpt-psr-pes-lin    to   v-lin                  .
           move      w-lpt-psr-pes-pos    to   v-pos                  .
           move      "Da sostituire :"    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Con                                     *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      15                   to   v-car                  .
           move      w-lpt-psr-pes-lin    to   v-lin                  .
           add       01                   to   v-lin                  .
           move      w-lpt-psr-pes-pos    to   v-pos                  .
           move      "Con           :"    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in 'ON'                               *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-psr-pes-sos-100.
      *              *-------------------------------------------------*
      *              * Visualizzazioni                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione valore da sostituire        *
      *                  *---------------------------------------------*
           perform   vis-psr-pes-so1-000  thru vis-psr-pes-so1-999    .
      *                  *---------------------------------------------*
      *                  * Visualizzazione valore sostitutivo          *
      *                  *---------------------------------------------*
           perform   vis-psr-pes-so2-000  thru vis-psr-pes-so2-999    .
       acc-psr-pes-sos-200.
      *              *-------------------------------------------------*
      *              * Accettazioni                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore da sostituire                        *
      *                  *---------------------------------------------*
           perform   acc-psr-pes-so1-000  thru acc-psr-pes-so1-999    .
           if        w-cnt-tus-acc-key    not  = spaces
                     go to acc-psr-pes-sos-600.
           if        v-key                =    "DOWN"
                     go to acc-psr-pes-sos-600.
       acc-psr-pes-sos-300.
      *                  *---------------------------------------------*
      *                  * Valore sostitutivo                          *
      *                  *---------------------------------------------*
           perform   acc-psr-pes-so2-000  thru acc-psr-pes-so2-999    .
           if        w-cnt-tus-acc-key    not  = spaces
                     go to acc-psr-pes-sos-600.
           if        v-key                =    "UP  "
                     go to acc-psr-pes-sos-200.
       acc-psr-pes-sos-600.
      *              *-------------------------------------------------*
      *              * Controlli su valori accettati                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se i valori sono a zero : a dipendenze dal- *
      *                  * le impostazioni                             *
      *                  *---------------------------------------------*
           if        w-tes-psr-pes (1)    =    zero  and
                     w-tes-psr-pes (2)    =    zero  and
                     w-tes-psr-pes (3)    =    zero  and
                     w-tes-psr-pes (4)    =    zero  and
                     w-tes-psr-pes (5)    =    zero  and
                     w-tes-psr-sos (1)    =    zero  and
                     w-tes-psr-sos (2)    =    zero  and
                     w-tes-psr-sos (3)    =    zero  and
                     w-tes-psr-sos (4)    =    zero  and
                     w-tes-psr-sos (5)    =    zero
                     go to acc-psr-pes-sos-800.
      *                  *---------------------------------------------*
      *                  * Che i valori non siano uguali               *
      *                  *---------------------------------------------*
           if        w-tes-psr-pes (1)    not  = w-tes-psr-sos (1) or
                     w-tes-psr-pes (2)    not  = w-tes-psr-sos (2) or
                     w-tes-psr-pes (3)    not  = w-tes-psr-sos (3) or
                     w-tes-psr-pes (4)    not  = w-tes-psr-sos (4) or
                     w-tes-psr-pes (5)    not  = w-tes-psr-sos (5)
                     go to acc-psr-pes-sos-800.
      *                      *-----------------------------------------*
      *                      * Normalizzazione valori sostitutivo      *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-psr-sos (1)      .
           move      zero                 to   w-tes-psr-sos (2)      .
           move      zero                 to   w-tes-psr-sos (3)      .
           move      zero                 to   w-tes-psr-sos (4)      .
           move      zero                 to   w-tes-psr-sos (5)      .
      *                      *-----------------------------------------*
      *                      * Segnale di sostituzione non effettuata  *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-psr-pes-sns      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     acc-psr-pes-sos-900.
       acc-psr-pes-sos-800.
      *              *-------------------------------------------------*
      *              * Dipendenza dalle impostazioni                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Segnale di sostituzione effettuata          *
      *                  *---------------------------------------------*
           if        w-tes-psr-pes (1)    not  = zero or
                     w-tes-psr-pes (2)    not  = zero or
                     w-tes-psr-pes (3)    not  = zero or
                     w-tes-psr-pes (4)    not  = zero or
                     w-tes-psr-pes (5)    not  = zero or
                     w-tes-psr-sos (1)    not  = zero or
                     w-tes-psr-sos (2)    not  = zero or
                     w-tes-psr-sos (3)    not  = zero or
                     w-tes-psr-sos (4)    not  = zero or
                     w-tes-psr-sos (5)    not  = zero
                     move  1              to   w-tes-psr-pes-sns      .
       acc-psr-pes-sos-900.
      *              *-------------------------------------------------*
      *              * Normalizzazione stato di uscita                 *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-key      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-psr-pes-sos-999.
       acc-psr-pes-sos-999.
           exit.

