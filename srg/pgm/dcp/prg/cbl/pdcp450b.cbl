      *                  *---------------------------------------------*
           move      "[1] "               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * A test su Pf1                               *
      *                  *---------------------------------------------*
           go to     acc-cat-scr-300.
       acc-cat-scr-100.
      *              *-------------------------------------------------*
      *              * Note operative                                  *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           move      "[F1] per sostituzione"
                                          to   v-not                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cmn-zcs-003-ope      .
           move      w-tes-cat-scr        to   w-cmn-zcs-003-cod      .
           move      w-lpt-cat-scr-lin    to   w-cmn-zcs-003-lin      .
           move      w-lpt-cat-scr-pos    to   w-cmn-zcs-003-pos      .
           move      w-lpt-cat-scr-lin    to   w-cmn-zcs-003-dln      .
           move      w-lpt-cat-scr-pos    to   w-cmn-zcs-003-dps      .
           add       07                   to   w-cmn-zcs-003-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "[1] "               to   v-pfk (14)             .
           perform   cmn-zcs-003-cll-000  thru cmn-zcs-003-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cmn-zcs-003-foi-000  thru cmn-zcs-003-foi-999    .
       acc-cat-scr-110.
           perform   cmn-zcs-003-cll-000  thru cmn-zcs-003-cll-999    .
           if        w-cmn-zcs-003-ope    =    "F+"
                     go to acc-cat-scr-115.
           if        w-cmn-zcs-003-ope    =    "AC"
                     go to acc-cat-scr-120.
