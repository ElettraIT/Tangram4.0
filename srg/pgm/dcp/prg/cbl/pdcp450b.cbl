      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      16                   to   v-lin                  .
           move      w-cix-ctr-001        to   v-pos                  .
           if        w-cix-ctr-001        >    5
                     subtract  5          from v-pos                  .
           multiply  06                   by   v-pos                  .
           add       24                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "TAB "               to   v-pfk (10)             .
           move      w-tes-per-scr
                    (w-cix-ctr-001)       to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-per-scr-999.
       acc-per-scr-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-per-scr
                                              (w-cix-ctr-001)         .
       acc-per-scr-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-per-scr-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-per-scr-620
           else if   v-key                =    "DOWN"
                     go to acc-per-scr-630
           else if   v-key                =    "TAB "
                     go to acc-per-scr-700
           else if   v-key                =    "DO  "
                     go to acc-per-scr-800
           else      go to acc-per-scr-630.
       acc-per-scr-620.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        w-cix-ctr-001        =    1
                     go to acc-per-scr-999.
           subtract  1                    from w-cix-ctr-001          .
           go to     acc-per-scr-100.
       acc-per-scr-630.
      *              *-------------------------------------------------*
      *              * Se Down o Return                                *
      *              *-------------------------------------------------*
           go to     acc-per-scr-999.
       acc-per-scr-700.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        w-cix-ctr-001        =    05
                     go to acc-per-scr-999.
      *                  *---------------------------------------------*
      *                  * Incremento contatore                        *
      *                  *---------------------------------------------*
           add       1                    to   w-cix-ctr-001          .
           go to     acc-per-scr-100.
       acc-per-scr-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-per-scr-999.
           perform   cnt-key-vuo-000      thru cnt-key-vuo-999        .
