      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zci-ope      .
           move      w-edt-iva-cie        to   w-cod-mne-zci-cod      .
           move      w-lpt-cod-iva-lin    to   w-cod-mne-zci-lin      .
           move      w-lpt-cod-iva-pos    to   w-cod-mne-zci-pos      .
           move      w-lpt-cod-iva-lin    to   w-cod-mne-zci-dln      .
           move      w-lpt-cod-iva-pos    to   w-cod-mne-zci-dps      .
           add       11                   to   w-cod-mne-zci-dps      .
           move      "<BD"                to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "DO  "               to   v-pfk (05)             .
