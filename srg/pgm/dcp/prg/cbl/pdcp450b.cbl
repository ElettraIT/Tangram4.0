      *    *===========================================================*
      *    * Accettazione campo : Categoria sconto in riga             *
      *    *                                                           *
      *    * Subroutine di sostituzione                                *
      *    *-----------------------------------------------------------*
       acc-cat-scr-sos-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione segnale di sostituzione     *
      *                  *---------------------------------------------*
           move      zero                 to   w-tes-cat-scr-sns      .
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      w-lpt-cat-scr-lin    to   v-lin                  .
           subtract  1                    from v-lin                  .
           move      w-lpt-cat-scr-pos    to   v-pos                  .
           subtract  1                    from v-pos                  .
           move      w-lpt-cat-scr-lin    to   v-lto                  .
           add       1                    to   v-lto                  .
           move      w-lpt-cat-scr-pos    to   v-pto                  .
           add       50                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cat-scr-sos-010.
      *                  *---------------------------------------------*
      *                  * Prompts per il box                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Valore da sostituire                    *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      15                   to   v-car                  .
           move      w-lpt-cat-scr-lin    to   v-lin                  .
           move      w-lpt-cat-scr-pos    to   v-pos                  .
           move      "Da sostituire :"    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Con                                     *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      w-lpt-cat-scr-lin    to   v-lin                  .
           move      w-lpt-cat-scr-pos    to   v-pos                  .
           add       29                   to   v-pos                  .
           move      "Con :"              to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in 'ON'                               *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cat-scr-sos-100.
      *              *-------------------------------------------------*
      *              * Visualizzazioni                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione valore da sostituire        *
      *                  *---------------------------------------------*
           perform   vis-cat-scr-so1-000  thru vis-cat-scr-so1-999    .
      *                  *---------------------------------------------*
      *                  * Visualizzazione valore sostitutivo          *
      *                  *---------------------------------------------*
           perform   vis-cat-scr-so2-000  thru vis-cat-scr-so2-999    .
       acc-cat-scr-sos-200.
      *              *-------------------------------------------------*
      *              * Accettazioni                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore da sostituire                        *
      *                  *---------------------------------------------*
           perform   acc-cat-scr-so1-000  thru acc-cat-scr-so1-999    .
           if        w-cnt-tus-acc-key    not  = spaces
                     go to acc-cat-scr-sos-600.
           if        v-key                =    "UP  "
                     go to acc-cat-scr-sos-600.
           if        v-key                =    "DOWN"
                     go to acc-cat-scr-sos-600.
       acc-cat-scr-sos-300.
      *                  *---------------------------------------------*
      *                  * Valore sostitutivo                          *
      *                  *---------------------------------------------*
           perform   acc-cat-scr-so2-000  thru acc-cat-scr-so2-999    .
           if        w-cnt-tus-acc-key    not  = spaces
                     go to acc-cat-scr-sos-600.
           if        v-key                =    "UP  "
                     go to acc-cat-scr-sos-200.
       acc-cat-scr-sos-600.
      *              *-------------------------------------------------*
      *              * Controlli su valori accettati                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se i valori sono a zero : a dipendenze dal- *
      *                  * le impostazioni                             *
      *                  *---------------------------------------------*
           if        w-tes-cat-scr        =    zero  and
                     w-tes-csr-sos        =    zero
                     go to acc-cat-scr-sos-800.
      *                  *---------------------------------------------*
      *                  * Che i valori non siano uguali               *
      *                  *---------------------------------------------*
           if        w-tes-cat-scr        not  = w-tes-csr-sos
                     go to acc-cat-scr-sos-800.
      *                      *-----------------------------------------*
      *                      * Normalizzazione valore sostitutivo      *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-csr-sos          .
      *                      *-----------------------------------------*
      *                      * Segnale di sostituzione non effettuata  *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-cat-scr-sns      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     acc-cat-scr-sos-900.
       acc-cat-scr-sos-800.
      *              *-------------------------------------------------*
      *              * Dipendenza dalle impostazioni                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Segnale di sostituzione effettuata          *
      *                  *---------------------------------------------*
           if        w-tes-cat-scr        not  = zero or
                     w-tes-csr-sos        not  = zero
                     move  1              to   w-tes-cat-scr-sns      .
       acc-cat-scr-sos-900.
      *              *-------------------------------------------------*
      *              * Normalizzazione stato di uscita                 *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-key      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-cat-scr-sos-999.
       acc-cat-scr-sos-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Categoria sconto in riga             *
      *    *                                                           *
      *    * Subroutine di visualizzazione sostituzione                *
      *    *-----------------------------------------------------------*
       vis-cat-scr-sos-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del segnale di sostitu-  *
      *              * zione effettuata                                *
      *              *-------------------------------------------------*
           if        w-tes-cat-scr-sns    =    zero
                     go to vis-cat-scr-sos-100
           else      go to vis-cat-scr-sos-500.
       vis-cat-scr-sos-100.
      *              *-------------------------------------------------*
      *              * Se sostituzione non effettuata                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      50                   to   v-car                  .
           move      w-lpt-cat-scr-lin    to   v-lin                  .
           move      w-lpt-cat-scr-pos    to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     vis-cat-scr-sos-900.
       vis-cat-scr-sos-500.
      *              *-------------------------------------------------*
      *              * Se sostituzione effettuata                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing codice da sostituire                *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-tes-cat-scr        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Concatenamento prima parte                  *
      *                  *---------------------------------------------*
           move      spaces               to   w-vis-lit-sos          .
           move      50                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      "( Sostituzione di :"
                                          to   w-all-str-cat (1)      .
           move      v-edt                to   w-all-str-cat (2)      .
           move      "- con :"            to   w-all-str-cat (3)      .
