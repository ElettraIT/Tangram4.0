      *    *===========================================================*
      *    * Lettura delle referenze relative al codice iva e codice   *
      *    * contropartita da offrire come default in anagrafica [dcp] *
      *    *-----------------------------------------------------------*
       ref-def-iec-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione tabella iniziale                *
      *              *-------------------------------------------------*
           move      zero                 to   w-ref-def-iec-c01      .
       ref-def-iec-100.
           add       1                    to   w-ref-def-iec-c01      .
           if        w-ref-def-iec-c01    >    9
                     go to ref-def-iec-120.
           move      zero                 to   w-ref-def-iec-civ
                                              (w-ref-def-iec-c01)     .
           move      zero                 to   w-ref-def-iec-ccp
                                              (w-ref-def-iec-c01)     .
           go to     ref-def-iec-100.
       ref-def-iec-120.
      *              *-------------------------------------------------*
      *              * Start per lettura referenza multipla            *
      *              *-------------------------------------------------*
           move      "Rs"                 to   s-ope                  .
           move      "pgm/dcp/dcp[civ-ccp]"
                                          to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        s-ves                not  = spaces
                     go to ref-def-iec-999.
       ref-def-iec-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale referenza multipla          *
      *              *-------------------------------------------------*
           move      "Rn"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        s-ves                not  = spaces
                     go to ref-def-iec-999.
      *              *-------------------------------------------------*
      *              * Valore referenza in comodo ridefinito           *
      *              *-------------------------------------------------*
           move      s-alf                to   w-ref-def-iec-str      .
      *              *-------------------------------------------------*
      *              * Test su valore 'aaa'                            *
      *              *-------------------------------------------------*
           if        w-ref-def-iec-aaa    not  numeric
                     go to ref-def-iec-200.
           if        w-ref-def-iec-aaa    not  < 1 and
                     w-ref-def-iec-aaa    not  > 9
                     go to ref-def-iec-220
           else      go to ref-def-iec-200.
       ref-def-iec-220.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore contenuto in 'bbb'       *
      *              *-------------------------------------------------*
           if        w-ref-def-iec-bbb    not  numeric
                     move  zero           to   w-ref-def-iec-bbb      .
      *              *-------------------------------------------------*
      *              * Normalizzazione valore contenuto in 'ccc'       *
      *              *-------------------------------------------------*
           if        w-ref-def-iec-ccc    not  numeric
                     move  zero           to   w-ref-def-iec-ccc      .
      *              *-------------------------------------------------*
      *              * Bufferizzazione in tabella                      *
      *              *-------------------------------------------------*
           move      w-ref-def-iec-bbb    to   w-ref-def-iec-civ
                                              (w-ref-def-iec-aaa)     .
           move      w-ref-def-iec-ccc    to   w-ref-def-iec-ccp
                                              (w-ref-def-iec-aaa)     .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale referenza        *
      *              *-------------------------------------------------*
           go to     ref-def-iec-200.
       ref-def-iec-999.
           exit.

