           move      21                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Provvigioni        :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       pmt-rig-cpv-999.
