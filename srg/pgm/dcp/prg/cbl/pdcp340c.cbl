      *                  *---------------------------------------------*
           if        rr-num-lst           =    01
                     go to acc-num-lst-620
           else if   rr-num-lst           =    02
                     go to acc-num-lst-640
           else if   rr-num-lst           =    03
                     go to acc-num-lst-660
           else      go to acc-num-lst-700.
