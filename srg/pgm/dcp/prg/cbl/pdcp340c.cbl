      *    *===========================================================*
      *    * Routine di determinazione valori letti da codici listini  *
      *    *-----------------------------------------------------------*
       det-val-lst-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione iniziale                        *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-val-lst-vl1      .
           move      spaces               to   w-det-val-lst-vl2      .
           move      spaces               to   w-det-val-lst-vl3      .
           move      spaces               to   w-det-val-lst-vl4      .
           move      zero                 to   w-det-val-lst-dc1      .
           move      zero                 to   w-det-val-lst-dc2      .
           move      zero                 to   w-det-val-lst-dc3      .
           move      zero                 to   w-det-val-lst-dc4      .
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del numero listini da    *
      *              * stampare                                        *
      *              *-------------------------------------------------*
           if        rr-num-lst           =    04
                     go to det-val-lst-100
           else if   rr-num-lst           =    03
                     go to det-val-lst-200
           else if   rr-num-lst           =    02
                     go to det-val-lst-300
           else if   rr-num-lst           =    01
                     go to det-val-lst-400.
       det-val-lst-100.
      *              *-------------------------------------------------*
      *              * Se quattro listini da stampare                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura valori associati al listino 4       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura tabella [zls]                   *
      *                      *-----------------------------------------*
           move      rr-cod-ls4           to   w-let-arc-zls-cod      .
           perform   let-arc-zls-000      thru let-arc-zls-999        .
      *                      *-----------------------------------------*
      *                      * Memorizzazione sigla valuta             *
      *                      *-----------------------------------------*
           move      w-let-arc-zls-vlt    to   w-det-val-lst-vl4      .
      *                      *-----------------------------------------*
      *                      * Lettura tabella [zvl]                   *
      *                      *-----------------------------------------*
           move      w-let-arc-zls-vlt    to   w-let-arc-zvl-cod      .
           perform   let-arc-zvl-000      thru let-arc-zvl-999        .
      *                      *-----------------------------------------*
      *                      * Memorizzazione numero decimali valuta   *
      *                      *-----------------------------------------*
           move      w-let-arc-zvl-dec    to   w-det-val-lst-dc4      .
       det-val-lst-200.
      *              *-------------------------------------------------*
      *              * Se tre listini da stampare                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura valori associati al listino 3       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura tabella [zls]                   *
      *                      *-----------------------------------------*
           move      rr-cod-ls3           to   w-let-arc-zls-cod      .
           perform   let-arc-zls-000      thru let-arc-zls-999        .
      *                      *-----------------------------------------*
      *                      * Memorizzazione sigla valuta             *
      *                      *-----------------------------------------*
           move      w-let-arc-zls-vlt    to   w-det-val-lst-vl3      .
      *                      *-----------------------------------------*
      *                      * Lettura tabella [zvl]                   *
      *                      *-----------------------------------------*
           move      w-let-arc-zls-vlt    to   w-let-arc-zvl-cod      .
           perform   let-arc-zvl-000      thru let-arc-zvl-999        .
      *                      *-----------------------------------------*
      *                      * Memorizzazione numero decimali valuta   *
      *                      *-----------------------------------------*
           move      w-let-arc-zvl-dec    to   w-det-val-lst-dc3      .
       det-val-lst-300.
      *              *-------------------------------------------------*
      *              * Se due listini da stampare                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura valori associati al listino 2       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura tabella [zls]                   *
      *                      *-----------------------------------------*
           move      rr-cod-ls2           to   w-let-arc-zls-cod      .
           perform   let-arc-zls-000      thru let-arc-zls-999        .
      *                      *-----------------------------------------*
      *                      * Memorizzazione sigla valuta             *
      *                      *-----------------------------------------*
           move      w-let-arc-zls-vlt    to   w-det-val-lst-vl2      .
      *                      *-----------------------------------------*
      *                      * Lettura tabella [zvl]                   *
      *                      *-----------------------------------------*
           move      w-let-arc-zls-vlt    to   w-let-arc-zvl-cod      .
           perform   let-arc-zvl-000      thru let-arc-zvl-999        .
      *                      *-----------------------------------------*
      *                      * Memorizzazione numero decimali valuta   *
      *                      *-----------------------------------------*
           move      w-let-arc-zvl-dec    to   w-det-val-lst-dc2      .
       det-val-lst-400.
      *              *-------------------------------------------------*
      *              * Se un listino da stampare                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura valori associati al listino 1       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura tabella [zls]                   *
      *                      *-----------------------------------------*
           move      rr-cod-ls1           to   w-let-arc-zls-cod      .
           perform   let-arc-zls-000      thru let-arc-zls-999        .
      *                      *-----------------------------------------*
      *                      * Memorizzazione sigla valuta             *
      *                      *-----------------------------------------*
           move      w-let-arc-zls-vlt    to   w-det-val-lst-vl1      .
      *                      *-----------------------------------------*
      *                      * Lettura tabella [zvl]                   *
      *                      *-----------------------------------------*
           move      w-let-arc-zls-vlt    to   w-let-arc-zvl-cod      .
           perform   let-arc-zvl-000      thru let-arc-zvl-999        .
      *                      *-----------------------------------------*
      *                      * Memorizzazione numero decimali valuta   *
      *                      *-----------------------------------------*
           move      w-let-arc-zvl-dec    to   w-det-val-lst-dc1      .
       det-val-lst-999.
           exit.

      *    *===========================================================*
      *    * Determinazione della descrizione da stampare              *
      *    *-----------------------------------------------------------*
       det-des-stp-000.
      *              *-------------------------------------------------*
      *              * Preparazione valore di uscita con la descri-    *
      *              * ne anagrafica del prodotto                      *
      *              *-------------------------------------------------*
           move      w-det-des-stp-dpr    to   w-det-des-stp-des      .
           move      spaces               to   w-det-des-stp-dag      .
      *              *-------------------------------------------------*
      *              * Normalizzazione contatore righe di descrizione  *
      *              * aggiuntive                                      *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-des-stp-cra      .
      *              *-------------------------------------------------*
      *              * Normalizzazione contatore righe descrizione     *
      *              *-------------------------------------------------*
           move      1                    to   w-det-des-stp-ctr      .
       det-des-stp-400.
      *              *-------------------------------------------------*
      *              * Lettura di una eventuale descrizione prodotto   *
      *              * specifica per il listino                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su segnale di presenza descrizione per *
      *                  * il listino                                  *
      *                  *---------------------------------------------*
           if        w-det-des-stp-daa    =    zero
                     go to det-des-stp-600.
      *                  *---------------------------------------------*
      *                  * Lettura                                     *
      *                  *---------------------------------------------*
           move      04                   to   w-let-arc-pdx-rec      .
           move      zero                 to   w-let-arc-pdx-arc      .
           move      "I  "                to   w-let-arc-pdx-lng      .
           move      w-det-des-stp-pro    to   w-let-arc-pdx-pro      .
           move      spaces               to   w-let-arc-pdx-fmt      .
           perform   let-arc-pdx-000      thru let-arc-pdx-999        .
      *                  *---------------------------------------------*
      *                  * Test su esito della lettura                 *
      *                  *---------------------------------------------*
           if        w-let-arc-pdx-flg    not  = spaces
                     go to det-des-stp-600.
       det-des-stp-420.
      *                  *---------------------------------------------*
      *                  * Se record trovato                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda se si tratta di    *
      *                      * descrizione aggiuntiva o alternativa    *
      *                      *-----------------------------------------*
           if        w-det-des-stp-daa    =    2 or
                     w-det-des-stp-daa    =    3
                     go to det-des-stp-460.
       det-des-stp-440.
      *                      *-----------------------------------------*
      *                      * Se descrizione alternativa              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Descrizione letta in valore di      *
      *                          * uscita                              *
      *                          *-------------------------------------*
           move      w-let-arc-pdx-des    to   w-det-des-stp-des      .
      *                          *-------------------------------------*
      *                          * Contatore righe descrizione         *
      *                          *-------------------------------------*
           move      w-let-arc-pdx-ctr    to   w-det-des-stp-ctr      .
      *                          *-------------------------------------*
      *                          * Ad uscita                           *
      *                          *-------------------------------------*
           go to     det-des-stp-900.
       det-des-stp-460.
      *                      *-----------------------------------------*
      *                      * Se descrizione aggiuntiva               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Descrizione letta in valore di      *
      *                          * uscita                              *
      *                          *-------------------------------------*
           move      w-let-arc-pdx-des    to   w-det-des-stp-dag      .
      *                          *-------------------------------------*
      *                          * Contatore righe descrizione         *
      *                          *-------------------------------------*
           move      w-let-arc-pdx-ctr    to   w-det-des-stp-cra      .
      *                          *-------------------------------------*
      *                          * A lettura eventuale descrizione     *
      *                          * specifica per i documenti           *
      *                          *-------------------------------------*
           go to     det-des-stp-600.
       det-des-stp-600.
      *              *-------------------------------------------------*
      *              * Lettura di una eventuale descrizione prodotto   *
      *              * specifica per i documenti                       *
      *              *-------------------------------------------------*
           move      01                   to   w-let-arc-pdx-rec      .
           move      zero                 to   w-let-arc-pdx-arc      .
           move      "I  "                to   w-let-arc-pdx-lng      .
           move      w-det-des-stp-pro    to   w-let-arc-pdx-pro      .
           move      spaces               to   w-let-arc-pdx-fmt      .
           perform   let-arc-pdx-000      thru let-arc-pdx-999        .
      *                  *---------------------------------------------*
      *                  * Test su esito della lettura                 *
      *                  *---------------------------------------------*
           if        w-let-arc-pdx-flg    not  = spaces
                     go to det-des-stp-800.
       det-des-stp-620.
      *                  *---------------------------------------------*
      *                  * Se record trovato                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Descrizione letta in valore di uscita   *
      *                      *-----------------------------------------*
           move      w-let-arc-pdx-des    to   w-det-des-stp-des      .
      *                      *-----------------------------------------*
      *                      * Contatore righe descrizione             *
      *                      *-----------------------------------------*
           move      w-let-arc-pdx-ctr    to   w-det-des-stp-ctr      .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     det-des-stp-900.
       det-des-stp-800.
      *              *-------------------------------------------------*
      *              * Se non trovata alcuna descrizione specifica, si *
      *              * utilizza quella anagrafica del prodotto         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     det-des-stp-900.
       det-des-stp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-des-stp-999.
       det-des-stp-999.
           exit.

      *    *===========================================================*
      *    * Determinazione prezzo con Iva                             *
      *    *-----------------------------------------------------------*
       det-prz-iva-000.
      *              *-------------------------------------------------*
      *              * Test preliminare                                *
      *              *-------------------------------------------------*
           if        w-det-val-stp-prz    =    zero
                     go to det-prz-iva-900.
       det-prz-iva-100.
      *              *-------------------------------------------------*
      *              * Determinazione                                  *
      *              *-------------------------------------------------*
           move      rf-dcp-cod-iva       to   w-det-prz-iva-cod      .
           move      zero                 to   w-det-prz-iva-001      .
           move      zero                 to   w-det-prz-iva-002      .
           move      zero                 to   w-det-prz-iva-003      .
           move      w-det-val-stp-prz    to   w-det-prz-iva-s13      .
           multiply  w-det-prz-iva-cod    by   w-det-prz-iva-s13      .
           divide    100                  into w-det-prz-iva-s13
                                        giving w-det-prz-iva-imp
                                     remainder w-det-prz-iva-s13      .
           if        w-det-prz-iva-s13    >    zero
                     add       1          to   w-det-prz-iva-imp
           else if   w-det-prz-iva-s13    <    zero
                     subtract  1          from w-det-prz-iva-imp      .
           add       w-det-prz-iva-imp    to   w-det-val-stp-prz      .
       det-prz-iva-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-prz-iva-999.
       det-prz-iva-999.
           exit.

      *    *===========================================================*
      *    * Routine lettura tabella [pdx] per scansione delle righe   *
      *    *-----------------------------------------------------------*
       let-arc-pdx-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-pdx-flg      .
      *              *-------------------------------------------------*
      *              * Normalizzazione contatore                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-let-arc-pdx-ctr      .
      *              *-------------------------------------------------*
      *              * Normalizzazione valore in uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-pdx-des      .
       let-arc-pdx-100.
      *              *-------------------------------------------------*
      *              * Start su file [pdx]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "TRCLNG    "         to   f-key                  .
           move      w-let-arc-pdx-rec    to   rf-pdx-tip-rec         .
           move      w-let-arc-pdx-arc    to   rf-pdx-cod-arc         .
           move      w-let-arc-pdx-lng    to   rf-pdx-cod-lng         .
           move      w-let-arc-pdx-pro    to   rf-pdx-cod-num         .
           move      w-let-arc-pdx-fmt    to   rf-pdx-for-mat         .
           move      zero                 to   rf-pdx-num-prg         .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to let-arc-pdx-800.
       let-arc-pdx-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [pdx]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
      *                  *---------------------------------------------*
      *                  * Test se 'at end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to let-arc-pdx-800.
       let-arc-pdx-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-pdx-tip-rec       not  = w-let-arc-pdx-rec or
                     rf-pdx-cod-arc       not  = w-let-arc-pdx-arc or
                     rf-pdx-cod-lng       not  = w-let-arc-pdx-lng or
                     rf-pdx-cod-num       not  = w-let-arc-pdx-pro or
                     rf-pdx-for-mat       not  = w-let-arc-pdx-fmt
                     go to let-arc-pdx-800.
       let-arc-pdx-400.
      *              *-------------------------------------------------*
      *              * Incremento contatore                            *
      *              *-------------------------------------------------*
           add       1                    to   w-let-arc-pdx-ctr      .
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-pdx-des-pro       to   w-let-arc-pdx-rig
                                              (w-let-arc-pdx-ctr)     .
       let-arc-pdx-600.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura                              *
      *              *-------------------------------------------------*
           go to     let-arc-pdx-200.
       let-arc-pdx-800.
      *              *-------------------------------------------------*
      *              * Test su contatore elementi letti                *
      *              *-------------------------------------------------*
           if        w-let-arc-pdx-ctr    =    zero
                     go to let-arc-pdx-820
           else      go to let-arc-pdx-900.
       let-arc-pdx-820.
      *                  *---------------------------------------------*
      *                  * Se nessun elemento rilevato                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di nessun elemento rilevato        *
      *                      *-----------------------------------------*
           move      "#"                  to   w-let-arc-pdx-flg      .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     let-arc-pdx-900.
       let-arc-pdx-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-pdx-999.
       let-arc-pdx-999.
           exit.

      *    *===========================================================*
      *    * Routine lettura tabella [zp1]                             *
      *    *-----------------------------------------------------------*
       let-arc-zp1-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-zp1-flg      .
      *              *-------------------------------------------------*
      *              * Test se codice classe a zero                    *
      *              *-------------------------------------------------*
           if        w-let-arc-zp1-cla    =    zero
                     go to let-arc-zp1-500.
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLA    "         to   f-key                  .
           move      w-let-arc-zp1-cla    to   rf-zp1-cod-cla         .
           move      "pgm/dcp/fls/ioc/obj/iofzp1"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zp1                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-zp1-400.
       let-arc-zp1-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-zp1-des-cla       to   w-let-arc-zp1-des      .
           move      rf-zp1-mne-cla       to   w-let-arc-zp1-mne      .
           move      rf-zp1-ult-sud       to   w-let-arc-zp1-sud      .
           move      rf-zp1-sqz-num       to   w-let-arc-zp1-sqz      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-zp1-999.
       let-arc-zp1-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-zp1-flg      .
           move      all   "."            to   w-let-arc-zp1-des      .
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      05                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      w-let-arc-zp1-cla    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-let-arc-zp1-mne      .
           go to     let-arc-zp1-600.
       let-arc-zp1-500.
      *              *-------------------------------------------------*
