                                              (w-tbl-zls-num-lst)     .
      *                  *---------------------------------------------*
      *                  * Descrizione listino                         *
      *                  *---------------------------------------------*
           move      rf-zls-des-lst       to   w-tbl-zls-des-lst
                                              (w-tbl-zls-num-lst)     .
      *                  *---------------------------------------------*
      *                  * Codice valuta                               *
      *                  *---------------------------------------------*
           move      w-let-arc-zvl-cod    to   w-tbl-zls-cod-vlt
                                              (w-tbl-zls-num-lst)     .
      *                  *---------------------------------------------*
      *                  * Descrizione valuta                          *
      *                  *---------------------------------------------*
           move      w-let-arc-zvl-des    to   w-tbl-zls-des-vlt
                                              (w-tbl-zls-num-lst)     .
       loa-tbl-zls-700.
      *              *-------------------------------------------------*
      *              * Se non ancora raggiunto il massimo numero di    *
      *              * listini memorizzabili si ricicla alla lettura   *
      *              * del listino successivo                          *
      *              *-------------------------------------------------*
           if        w-tbl-zls-num-lst    <    w-tbl-zls-max-lst
                     go to loa-tbl-zls-300.
       loa-tbl-zls-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     loa-tbl-zls-999.
       loa-tbl-zls-999.
           exit.

      *    *===========================================================*
      *    * Controllo su validita' richieste                          *
      *    *-----------------------------------------------------------*
       ctl-val-ric-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita a Ok             *
      *              *-------------------------------------------------*
           move      spaces               to   w-ctl-val-ric-flg      .
       ctl-val-ric-100.
      *              *-------------------------------------------------*
      *              * Determinazione degli indici in tabella listini  *
      *              * relativi al primo e all'ultimo codice listino   *
      *              * da sottoporre a storicizzazione                 *
      *              *-------------------------------------------------*
       ctl-val-ric-110.
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      zero                 to   w-sto-lst-inx-min      .
           move      zero                 to   w-sto-lst-inx-max      .
       ctl-val-ric-120.
      *                  *---------------------------------------------*
      *                  * Se storicizzazione per tutti i listini : si *
      *                  * pone l'indice minimo a 1, e l'indice massi- *
      *                  * mo pari al numero di listini memorizzati    *
      *                  *---------------------------------------------*
           if        rr-tip-sto           =    "T"
                     move  1              to   w-sto-lst-inx-min
                     move  w-tbl-zls-num-lst
                                          to   w-sto-lst-inx-max
                     go to ctl-val-ric-200.
       ctl-val-ric-130.
      *                  *---------------------------------------------*
      *                  * Se storicizzazione per un solo listino : si *
      *                  * determina l'indice relativo a quel listino  *
      *                  * e si pongono l'indice minimo e massimo pari *
      *                  * ad esso                                     *
      *                  *---------------------------------------------*
       ctl-val-ric-132.
           move      zero                 to   w-sto-lst-inx-att      .
       ctl-val-ric-134.
           add       1                    to   w-sto-lst-inx-att      .
           if        w-sto-lst-inx-att    >    w-tbl-zls-num-lst
                     go to ctl-val-ric-140.
           if        rr-lst-das-cod       =    w-tbl-zls-cod-lst
                                              (w-sto-lst-inx-att)
                     move  w-sto-lst-inx-att
                                          to   w-sto-lst-inx-min
                     move  w-sto-lst-inx-att
                                          to   w-sto-lst-inx-max
                     go to ctl-val-ric-140
           else      go to ctl-val-ric-134.
       ctl-val-ric-140.
      *                  *---------------------------------------------*
      *                  * Se non e' stato determinato l'indice minimo *
      *                  * e massimo : si emette un messaggio di erro- *
      *                  * re e si esce con flag ad errore             *
      *                  *---------------------------------------------*
           if        w-sto-lst-inx-min    not  = zero and
                     w-sto-lst-inx-max    not  = zero
                     go to ctl-val-ric-200.
           move      "Codice listini non presente in tabella listini !  
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           move      "#"                  to   w-ctl-val-ric-flg      .
           go to     ctl-val-ric-900.
       ctl-val-ric-200.
      *              *-------------------------------------------------*
      *              * Si controlla, per ogni listino da sottoporre a  *
      *              * storicizzazione, che non esistano prezzi stori- *
      *              * cizzati con data di validita' finale incompati- *
      *              * bile con la data di validita' finale dichiarata *
      *              *-------------------------------------------------*
       ctl-val-ric-300.
      *                  *---------------------------------------------*
      *                  * Inizializzazione indice su tabella          *
      *                  *---------------------------------------------*
           move      w-sto-lst-inx-min    to   w-sto-lst-inx-att      .
           subtract  1                    from w-sto-lst-inx-att      .
       ctl-val-ric-400.
      *                  *---------------------------------------------*
      *                  * Incremento indice su tabella                *
      *                  *---------------------------------------------*
           add       1                    to   w-sto-lst-inx-att      .
      *                  *---------------------------------------------*
      *                  * Se oltre il limite massimo : controllo su-  *
      *                  * perato                                      *
      *                  *---------------------------------------------*
           if        w-sto-lst-inx-att    >    w-sto-lst-inx-max
                     go to ctl-val-ric-900.
       ctl-val-ric-500.
      *                  *---------------------------------------------*
      *                  * Controllo che, per il listino in esame, non *
      *                  * esistano prezzi storicizzati con data di    *
      *                  * validita' finale incompatibile con la data  *
      *                  * validita' finale dichiarata                 *
      *                  *---------------------------------------------*
       ctl-val-ric-510.
      *                      *-----------------------------------------*
      *                      * Start per data finale in formato 're-   *
      *                      * verse'                                  *
      *                      *-----------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "LSTPRODFR "         to   f-key                  .
           move      01                   to   rf-lsd-tip-rec         .
           move      w-tbl-zls-cod-lst
                    (w-sto-lst-inx-att)   to   rf-lsd-cod-lst         .
           move      zero                 to   rf-lsd-cod-cli         .
           move      spaces               to   rf-lsd-sgl-vlt         .
           move      zero                 to   rf-lsd-num-pro         .
           move      zero                 to   rf-lsd-dvf-rev         .
           move      "pgm/dcp/fls/ioc/obj/ioflsd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lsd                 .
      *                      *-----------------------------------------*
      *                      * Se Start errata : controllo superato    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to ctl-val-ric-600.
       ctl-val-ric-520.
      *                      *-----------------------------------------*
      *                      * Read next per data finale in formato    *
      *                      * 'reverse'                               *
      *                      *-----------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflsd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lsd                 .
      *                      *-----------------------------------------*
      *                      * Se At end : controllo superato          *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to ctl-val-ric-600.
       ctl-val-ric-530.
      *                      *-----------------------------------------*
      *                      * Test max                                *
      *                      *-----------------------------------------*
           if        rf-lsd-tip-rec       not  = 01                 or
                     rf-lsd-cod-lst       not  = w-tbl-zls-cod-lst
                                                (w-sto-lst-inx-att)
                     go to ctl-val-ric-600.
       ctl-val-ric-540.
      *                      *-----------------------------------------*
      *                      * Controllo che la data di validita' fi-  *
      *                      * nale del prezzo in esame non sia supe-  *
      *                      * riore alla data di validita' finale di- *
      *                      * chiarata.                               *
      *                      *                                         *
      *                      * Nota : E' ammessa la data uguale, per-  *
      *                      *        che' cosi' e' possibile riese-   *
      *                      *        guire una storicizzazione con    *
      *                      *        la stessa data in caso di sto-   *
      *                      *        ricizzazione erroneamente ese-   *
      *                      *        guita.                           *
      *                      *-----------------------------------------*
           if        rf-lsd-dva-fin       >    rr-dva-fin
                     go to ctl-val-ric-550
           else      go to ctl-val-ric-600.
       ctl-val-ric-550.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
       ctl-val-ric-551.
      *                          *-------------------------------------*
      *                          * Editing data di validita' finale    *
      *                          * dichiarata                          *
      *                          *-------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      rr-dva-fin           to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-sto-lst-dfd-edt      .
      *                          *-------------------------------------*
      *                          * Editing data di validita' finale    *
      *                          * trovata                             *
      *                          *-------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      rf-lsd-dva-fin       to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-sto-lst-dft-edt      .
       ctl-val-ric-552.
      *                          *-------------------------------------*
      *                          * Deviazione a seconda del codice li- *
      *                          * stino                               *
      *                          *-------------------------------------*
           if        w-tbl-zls-cod-lst
                    (w-sto-lst-inx-att)   =    spaces
                     go to ctl-val-ric-553
           else      go to ctl-val-ric-554.
       ctl-val-ric-553.
      *                          *-------------------------------------*
      *                          * Se listino base                     *
      *                          *-------------------------------------*
           move      spaces               to   w-err-box-err-msg      .
           string    "Il Listino Base non e' storicizzabile con data "
                                delimited by   size
                     w-sto-lst-dfd-edt
                                delimited by   size
                     ","
                                delimited by   size
                                          into w-err-box-err-msg      .
      *
           move      spaces               to   w-err-box-err-m02      .
           string    "perche' esistono prezzi storicizzati con data "
                                delimited by   size
                     w-sto-lst-dft-edt
                                delimited by   size
                     " !"
                                delimited by   size
                                          into w-err-box-err-m02      .
      *
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           go to     ctl-val-ric-560.
       ctl-val-ric-554.
      *                          *-------------------------------------*
      *                          * Se altro listino                    *
      *                          *-------------------------------------*
           move      spaces               to   w-err-box-err-msg      .
           string    "Il Listino "
                                delimited by   size
                     "rf-lsd-cod-lst"
                                delimited by   spaces
                     " non e' storicizzabile con data "
                                delimited by   size
                     w-sto-lst-dfd-edt
                                delimited by   size
                     ","
                                delimited by   size
                                          into w-err-box-err-msg      .
      *
           move      spaces               to   w-err-box-err-m02      .
           string    "perche' esistono prezzi storicizzati con data "
                                delimited by   size
                     w-sto-lst-dft-edt
                                delimited by   size
                     " !"
                                delimited by   size
                                          into w-err-box-err-m02      .
      *
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           go to     ctl-val-ric-560.
       ctl-val-ric-560.
      *                      *-----------------------------------------*
      *                      * Flag di controllo ad errore             *
      *                      *-----------------------------------------*
           move      "#"                  to   w-ctl-val-ric-flg      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     ctl-val-ric-900.
       ctl-val-ric-600.
      *                  *---------------------------------------------*
      *                  * Riciclo su listino successivo               *
      *                  *---------------------------------------------*
           go to     ctl-val-ric-400.
       ctl-val-ric-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     ctl-val-ric-999.
       ctl-val-ric-999.
           exit.

      *    *===========================================================*
      *    * Esecuzione della storicizzazione                          *
      *    *-----------------------------------------------------------*
       exe-sub-pgm-000.
      *              *-------------------------------------------------*
      *              * Pre-storicizzazione listini                     *
      *              *-------------------------------------------------*
           perform   pre-sto-lst-000      thru pre-sto-lst-999        .
      *              *-------------------------------------------------*
      *              * Se uscita con errore : ad uscita                *
      *              *-------------------------------------------------*
           if        w-sto-lst-flg-exs    not  = spaces
                     go to exe-sub-pgm-900.
       exe-sub-pgm-100.
      *              *-------------------------------------------------*
      *              * Inizializzazione numero listino attualmente     *
      *              * trattato                                        *
      *              *-------------------------------------------------*
           move      zero                 to   w-sto-lst-num-att      .
      *              *-------------------------------------------------*
      *              * Inizializzazione indice per listino attualmente *
      *              * trattato, su tabella listini                    *
      *              *-------------------------------------------------*
           move      w-sto-lst-inx-min    to   w-sto-lst-inx-att      .
           subtract  1                    from w-sto-lst-inx-att      .
       exe-sub-pgm-200.
      *              *-------------------------------------------------*
      *              * Incremento indice per listino attualmente trat- *
      *              * tato, su tabella listini                        *
      *              *-------------------------------------------------*
           add       1                    to   w-sto-lst-inx-att      .
      *              *-------------------------------------------------*
      *              * Se oltre l'indice massimo da trattare : a fine  *
      *              * storicizzazione                                 *
      *              *-------------------------------------------------*
           if        w-sto-lst-inx-att    >    w-sto-lst-inx-max
                     go to exe-sub-pgm-800.
       exe-sub-pgm-300.
      *              *-------------------------------------------------*
      *              * Incremento numero listino attualmente trattato  *
      *              *-------------------------------------------------*
           add       1                    to   w-sto-lst-num-att      .
      *              *-------------------------------------------------*
      *              * Storicizzazione del listino corrispondente al-  *
      *              * l'indice 'w-sto-lst-inx-att'                    *
      *              *-------------------------------------------------*
           perform   sto-prz-lst-000      thru sto-prz-lst-999        .
      *              *-------------------------------------------------*
      *              * Se uscita con errore : ad uscita                *
      *              *-------------------------------------------------*
           if        w-sto-lst-flg-exs    not  = spaces
                     go to exe-sub-pgm-900.
       exe-sub-pgm-400.
      *              *-------------------------------------------------*
      *              * Riciclo al listino successivo da storicizzare   *
      *              *-------------------------------------------------*
           go to     exe-sub-pgm-200.
       exe-sub-pgm-800.
      *              *-------------------------------------------------*
      *              * Post-storicizzazione listini                    *
      *              *-------------------------------------------------*
           perform   pos-sto-lst-000      thru pos-sto-lst-999        .
      *              *-------------------------------------------------*
      *              * Se uscita con errore : ad uscita                *
      *              *-------------------------------------------------*
           if        w-sto-lst-flg-exs    not  = spaces
                     go to exe-sub-pgm-900.
       exe-sub-pgm-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-sub-pgm-999.
       exe-sub-pgm-999.
           exit.

      *    *===========================================================*
      *    * Esecuzione procedura pre-storicizzazione listini          *
      *    *-----------------------------------------------------------*
       pre-sto-lst-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
