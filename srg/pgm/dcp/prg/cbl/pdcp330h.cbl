           move      "N"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-sto-lst-ctt-apd    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
