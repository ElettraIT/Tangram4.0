      *                      *-----------------------------------------*
           move      "DE"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflsd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lsd                 .
      *                      *-----------------------------------------*
      *                      * Set del flag sull'esito dell'operazione *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     move  "E"            to   w-sto-lst-flg-del
           else      move  "S"            to   w-sto-lst-flg-del      .
