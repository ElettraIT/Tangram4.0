      *    *===========================================================*
      *    * Accettazione : Tipo di storicizzazione                    *
      *    *-----------------------------------------------------------*
       acc-tip-sto-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-tip-sto-025.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      rr-tip-sto           to   w-sav-tip-sto          .
       acc-tip-sto-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-sto-lun    to   v-car                  .
           move      w-exp-tip-sto-num    to   v-ldt                  .
           move      "TU#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-tip-sto-tbl    to   v-txt                  .
           if        rr-tip-sto           =    "T"
                     move  01             to   v-num
           else if   rr-tip-sto           =    "U"
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-tip-sto-999.
       acc-tip-sto-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    01
                     move  "T"            to   rr-tip-sto
           else if   v-num                =    02
                     move  "U"            to   rr-tip-sto
           else      move  spaces         to   rr-tip-sto             .
       acc-tip-sto-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
           if        rr-tip-sto           not  = "U" and
                     rr-tip-sto           not  = "T"
                     go to acc-tip-sto-100.
       acc-tip-sto-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-tip-sto-625.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda se variato o no ri-    *
      *                  * spetto al valore precedente                 *
      *                  *---------------------------------------------*
           if        rr-tip-sto           =    w-sav-tip-sto
                     go to acc-tip-sto-650
           else      go to acc-tip-sto-700.
       acc-tip-sto-650.
      *                  *---------------------------------------------*
      *                  * Se valore inalterato                        *
      *                  *---------------------------------------------*
       acc-tip-sto-655.
      *                      *-----------------------------------------*
      *                      * Nessuna azione : a controllo tasto Do   *
      *                      *-----------------------------------------*
           go to     acc-tip-sto-800.
       acc-tip-sto-700.
      *                  *---------------------------------------------*
      *                  * Se valore variato rispetto al precedente    *
      *                  *---------------------------------------------*
       acc-tip-sto-710.
