           move      "WR"                 to   m-ope                  .
           move      spaces               to   m-msg                  .
           string    "Numero prezzi invariati ..........................
      -              "............... : "
                                delimited by   size
                     w-sto-lst-cdl-n9s
                                delimited by   size
                                          into m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       pos-sto-lst-135.
      *                  *---------------------------------------------*
      *                  * Linea bianca di separazione                 *
      *                  *---------------------------------------------*
