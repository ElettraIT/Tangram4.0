      *    *===========================================================*
      *    * Subroutines per l'accettazione codice listino             *
      *    *-----------------------------------------------------------*
           copy      "pgm/dcp/prg/cpy/acodzls0.acs"                   .

      *    *===========================================================*
      *    * Caricamento in memoria tabella listini                    *
      *    *-----------------------------------------------------------*
       loa-tbl-zls-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione iniziale totale tabella         *
      *              *-------------------------------------------------*
           move      spaces               to   w-tbl-zls-tbl-lst      .
      *              *-------------------------------------------------*
      *              * Numero elementi caricati in tabella             *
      *              *-------------------------------------------------*
           move      zero                 to   w-tbl-zls-num-lst      .
       loa-tbl-zls-100.
      *              *-------------------------------------------------*
      *              * Pre-caricamento del listino base                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Incremento numero di listini presenti in    *
      *                  * tabella                                     *
      *                  *---------------------------------------------*
           add       1                    to   w-tbl-zls-num-lst      .
      *                  *---------------------------------------------*
      *                  * Memorizzazione listino in tabella           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice listino                          *
      *                      *-----------------------------------------*
           move      spaces               to   w-tbl-zls-cod-lst
                                              (w-tbl-zls-num-lst)     .
      *                      *-----------------------------------------*
      *                      * Descrizione listino                     *
      *                      *-----------------------------------------*
           move      "Listino Base        "
                                          to   w-tbl-zls-des-lst
                                              (w-tbl-zls-num-lst)     .
      *                      *-----------------------------------------*
      *                      * Codice valuta                           *
      *                      *-----------------------------------------*
           move      c-sgl                to   w-tbl-zls-cod-vlt
                                              (w-tbl-zls-num-lst)     .
      *                      *-----------------------------------------*
      *                      * Descrizione valuta                      *
      *                      *-----------------------------------------*
           move      c-des                to   w-tbl-zls-des-vlt
                                              (w-tbl-zls-num-lst)     .
       loa-tbl-zls-200.
