      *    *===========================================================*
      *    * Scrittura movimento su file                               *
      *    *-----------------------------------------------------------*
       scr-mov-fil-000.
      *              *-------------------------------------------------*
      *              * Se listino Base                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-tes-cod-lst        not  = spaces
                     go to scr-mov-fil-500.
      *                  *---------------------------------------------*
      *                  * Update record [dcp]                         *
      *                  *---------------------------------------------*
           perform   upd-rec-dcp-000      thru upd-rec-dcp-999        .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     scr-mov-fil-999.
       scr-mov-fil-500.
      *              *-------------------------------------------------*
      *              * Se listino alternativo                          *
      *              *-------------------------------------------------*
       scr-mov-fil-600.
      *                  *---------------------------------------------*
      *                  * Se Inserimento                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to scr-mov-fil-700.
      *                      *-----------------------------------------*
      *                      * Write record [lst]                      *
      *                      *-----------------------------------------*
           perform   wrt-rec-lst-000      thru wrt-rec-lst-999        .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     scr-mov-fil-999.
       scr-mov-fil-700.
      *                  *---------------------------------------------*
      *                  * Se modifica                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Rewrite record [lst]                    *
      *                      *-----------------------------------------*
           perform   rew-rec-lst-000      thru rew-rec-lst-999        .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     scr-mov-fil-999.
       scr-mov-fil-999.
           exit.

      *    *===========================================================*
      *    * Delete movimento da file                                  *
      *    *-----------------------------------------------------------*
       del-mov-fil-000.
      *              *-------------------------------------------------*
      *              * Se listino Base                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-tes-cod-lst        not  = spaces
                     go to del-mov-fil-500.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     del-mov-fil-999.
       del-mov-fil-500.
      *              *-------------------------------------------------*
      *              * Se listino alternativo                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Delete record [lst]                         *
      *                  *---------------------------------------------*
           perform   del-rec-lst-000      thru del-rec-lst-999        .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     del-mov-fil-999.
       del-mov-fil-999.
           exit.

      *    *===========================================================*
      *    * Composizione record [lst]                                 *
      *    *-----------------------------------------------------------*
       cmp-rec-lst-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
       cmp-rec-lst-200.
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
       cmp-rec-lst-300.
      *                  *---------------------------------------------*
      *                  * Campi chiave                                *
      *                  *---------------------------------------------*
           move      w-tes-tip-rec        to   rf-lst-tip-rec         .
           move      w-tes-cod-lst        to   rf-lst-cod-lst         .
           move      w-tes-cod-cli        to   rf-lst-cod-cli         .
           move      w-tes-cod-lst-vlt    to   rf-lst-sgl-vlt         .
           move      w-tes-num-pro        to   rf-lst-num-pro         .
       cmp-rec-lst-400.
      *                  *---------------------------------------------*
      *                  * Campi non chiave                            *
      *                  *---------------------------------------------*
           move      w-tes-cod-lst-dec    to   rf-lst-dec-vlt         .
           move      w-tes-prz-lst (1)    to   rf-lst-prz-lst         .
           move      w-tes-per-pvg (1, 1) to   rf-lst-per-pvg (1)     .
           move      w-tes-per-pvg (1, 2) to   rf-lst-per-pvg (2)     .
           move      w-tes-per-pvg (1, 3) to   rf-lst-per-pvg (3)     .
           move      w-tes-per-sco (1, 1) to   rf-lst-per-sco (1)     .
           move      w-tes-per-sco (1, 2) to   rf-lst-per-sco (2)     .
           move      w-tes-per-sco (1, 3) to   rf-lst-per-sco (3)     .
           move      w-tes-per-sco (1, 4) to   rf-lst-per-sco (4)     .
           move      w-tes-per-sco (1, 5) to   rf-lst-per-sco (5)     .
           move      w-tes-snx-prz (1)    to   rf-lst-snx-prz         .
           move      w-tes-snx-pvg (1)    to   rf-lst-snx-pvg         .
           move      w-tes-snx-sco (1)    to   rf-lst-snx-sco         .
           move      w-tes-dva-ini (1)    to   rf-lst-dva-ini         .
           move      w-tes-dva-fin (1)    to   rf-lst-dva-fin         .
           move      w-tes-alx-exp (1)    to   rf-lst-alx-exp         .
       cmp-rec-lst-999.
           exit.

      *    *===========================================================*
      *    * Scrittura record [lst]                                    *
      *    *-----------------------------------------------------------*
       wrt-rec-lst-000.
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           perform   cmp-rec-lst-000      thru cmp-rec-lst-999        .
      *              *-------------------------------------------------*
      *              * Put record                                      *
      *              *-------------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
       wrt-rec-lst-999.
           exit.

      *    *===========================================================*
      *    * Riscrittura record [lst]                                  *
      *    *-----------------------------------------------------------*
       rew-rec-lst-000.
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           perform   cmp-rec-lst-000      thru cmp-rec-lst-999        .
      *              *-------------------------------------------------*
      *              * Forced put record                               *
      *              *-------------------------------------------------*
           move      "FP"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
       rew-rec-lst-999.
           exit.

      *    *===========================================================*
      *    * Riscrittura record [dcp]                                  *
      *    *-----------------------------------------------------------*
       upd-rec-dcp-000.
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      w-tes-num-pro        to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
           if        f-sts                not  = e-not-err
                     go to upd-rec-dcp-500.
      *              *-------------------------------------------------*
      *              * Composizione nuovo prezzo di listino            *
      *              *-------------------------------------------------*
           move      w-tes-prz-lst (1)    to   rf-dcp-prz-lst         .
      *              *-------------------------------------------------*
      *              * Provvigioni e sconti solo se gestiti            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su personalizzazione                   *
      *                  *---------------------------------------------*
           if        w-prs-tfu-pnc-tip    =    zero
                     go to upd-rec-dcp-400.
      *                  *---------------------------------------------*
      *                  * Provvigioni e sconti solo se gestiti        *
      *                  *---------------------------------------------*
           move      w-tes-per-pvg (1, 1) to   rf-dcp-per-pvg (1)     .
           move      w-tes-per-pvg (1, 2) to   rf-dcp-per-pvg (2)     .
           move      w-tes-per-pvg (1, 3) to   rf-dcp-per-pvg (3)     .
           move      w-tes-per-sco (1, 1) to   rf-dcp-per-scr (1)     .
           move      w-tes-per-sco (1, 2) to   rf-dcp-per-scr (2)     .
           move      w-tes-per-sco (1, 3) to   rf-dcp-per-scr (3)     .
           move      w-tes-per-sco (1, 4) to   rf-dcp-per-scr (4)     .
           move      w-tes-per-sco (1, 5) to   rf-dcp-per-scr (5)     .
       upd-rec-dcp-400.
      *              *-------------------------------------------------*
      *              * Aggiornamento record file [dcp]                 *
      *              *-------------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
       upd-rec-dcp-500.
      *              *-------------------------------------------------*
      *              * Rilascio del record                             *
      *              *-------------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
       upd-rec-dcp-999.
           exit.

      *    *===========================================================*
      *    * Cancellazione record [lst]                                *
      *    *-----------------------------------------------------------*
       del-rec-lst-000.
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           perform   cmp-rec-lst-000      thru cmp-rec-lst-999        .
      *              *-------------------------------------------------*
      *              * Delete record                                   *
      *              *-------------------------------------------------*
           move      "DE"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
       del-rec-lst-999.
           exit.

      *    *===========================================================*
      *    * Determinazione prezzo su listino base e su storico dei    *
      *    * listini                                                   *
      *    *-----------------------------------------------------------*
       det-pbs-lst-000.
      *              *-------------------------------------------------*
      *              * Determinazione prezzo su listino base           *
      *              *-------------------------------------------------*
       det-pbs-lst-050.
      *                  *---------------------------------------------*
      *                  * Se record gia' in memoria si devia a se-    *
      *                  * conda se esisteva oppure no, controllando   *
      *                  * il codice prodotto alfanumerico             *
      *                  *---------------------------------------------*
           if        w-det-pbs-dcp-mem    not  = "S"
                     go to det-pbs-lst-100
           else if   rf-dcp-alf-pro       =    all "." or
                     rf-dcp-alf-pro       =    spaces
                     go to det-pbs-lst-160
           else      go to det-pbs-lst-200.
       det-pbs-lst-100.
      *                  *---------------------------------------------*
      *                  * Lettura record da [dcp]                     *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      w-det-pbs-num-pro    to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
       det-pbs-lst-150.
      *                  *---------------------------------------------*
      *                  * Se record non esistente                     *
      *                  *---------------------------------------------*
       det-pbs-lst-155.
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        f-sts                =    e-not-err
                     go to det-pbs-lst-200.
       det-pbs-lst-160.
      *                      *-----------------------------------------*
      *                      * Flag di esistenza a No                  *
      *                      *-----------------------------------------*
           move      "N"                  to   w-det-pbs-bas-flg      .
      *                      *-----------------------------------------*
      *                      * Sigla valuta a spaces                   *
      *                      *-----------------------------------------*
           move      spaces               to   w-det-pbs-bas-vlt      .
      *                      *-----------------------------------------*
      *                      * Decimali valuta a zero                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-pbs-bas-dcv      .
      *                      *-----------------------------------------*
      *                      * Prezzo a zero                           *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-pbs-bas-prz      .
      *                      *-----------------------------------------*
      *                      * Provvigioni a zero                      *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-pbs-bas-pvg (1)  .
           move      zero                 to   w-det-pbs-bas-pvg (2)  .
           move      zero                 to   w-det-pbs-bas-pvg (3)  .
      *                      *-----------------------------------------*
      *                      * Sconti a zero                           *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-pbs-bas-sco (1)  .
           move      zero                 to   w-det-pbs-bas-sco (2)  .
           move      zero                 to   w-det-pbs-bas-sco (3)  .
           move      zero                 to   w-det-pbs-bas-sco (4)  .
           move      zero                 to   w-det-pbs-bas-sco (5)  .
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     det-pbs-lst-300.
       det-pbs-lst-200.
      *                  *---------------------------------------------*
      *                  * Se record esistente                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di esistenza a Si                  *
      *                      *-----------------------------------------*
           move      "S"                  to   w-det-pbs-bas-flg      .
      *                      *-----------------------------------------*
      *                      * Sigla valuta                            *
      *                      *-----------------------------------------*
           move      rf-dcp-sgl-vlt       to   w-det-pbs-bas-vlt      .
      *                      *-----------------------------------------*
      *                      * Decimali valuta                         *
      *                      *-----------------------------------------*
           move      rf-dcp-dec-vlt       to   w-det-pbs-bas-dcv      .
      *                      *-----------------------------------------*
      *                      * Prezzo                                  *
      *                      *-----------------------------------------*
           move      rf-dcp-prz-lst       to   w-det-pbs-bas-prz      .
      *                      *-----------------------------------------*
      *                      * % provvigioni                           *
      *                      *-----------------------------------------*
           move      rf-dcp-per-pvg (1)   to   w-det-pbs-bas-pvg (1)  .
           move      rf-dcp-per-pvg (2)   to   w-det-pbs-bas-pvg (2)  .
           move      rf-dcp-per-pvg (3)   to   w-det-pbs-bas-pvg (3)  .
      *                      *-----------------------------------------*
      *                      * % sconto                                *
      *                      *-----------------------------------------*
           move      rf-dcp-per-scr (1)   to   w-det-pbs-bas-sco (1)  .
           move      rf-dcp-per-scr (2)   to   w-det-pbs-bas-sco (2)  .
           move      rf-dcp-per-scr (3)   to   w-det-pbs-bas-sco (3)  .
           move      rf-dcp-per-scr (4)   to   w-det-pbs-bas-sco (4)  .
           move      rf-dcp-per-scr (5)   to   w-det-pbs-bas-sco (5)  .
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     det-pbs-lst-300.
       det-pbs-lst-300.
      *              *-------------------------------------------------*
      *              * Determinazione prezzi su storico listini        *
      *              *-------------------------------------------------*
       det-pbs-lst-350.
      *                  *---------------------------------------------*
      *                  * Numero prezzi storici trovati : zero        *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-pbs-sto-num      .
      *                  *---------------------------------------------*
      *                  * Se max numero di prezzi storici da ricerca- *
      *                  * re a zero : uscita                          *
      *                  *---------------------------------------------*
           if        w-det-pbs-max-sto    =    zero
                     go to det-pbs-lst-900.
       det-pbs-lst-400.
      *                  *---------------------------------------------*
      *                  * Start su storico listini                    *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "LSTPRODFR "         to   f-key                  .
           move      w-det-pbs-tip-rec    to   rf-lsd-tip-rec         .
           move      w-det-pbs-cod-lst    to   rf-lsd-cod-lst         .
           move      w-det-pbs-cod-cli    to   rf-lsd-cod-cli         .
           move      w-det-pbs-sgl-vlt    to   rf-lsd-sgl-vlt         .
           move      w-det-pbs-num-pro    to   rf-lsd-num-pro         .
           move      zero                 to   rf-lsd-dvf-rev         .
           move      "pgm/dcp/fls/ioc/obj/ioflsd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lsd                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-pbs-lst-900.
       det-pbs-lst-450.
      *                  *---------------------------------------------*
      *                  * Read next su storico listini                *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflsd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lsd                 .
      *                  *---------------------------------------------*
      *                  * Se At end : uscita                          *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-pbs-lst-900.
       det-pbs-lst-500.
      *                  *---------------------------------------------*
      *                  * Test max su storico listini                 *
      *                  *---------------------------------------------*
           if        rf-lsd-tip-rec       not  = w-det-pbs-tip-rec or
                     rf-lsd-cod-lst       not  = w-det-pbs-cod-lst or
                     rf-lsd-cod-cli       not  = w-det-pbs-cod-cli or
                     rf-lsd-sgl-vlt       not  = w-det-pbs-sgl-vlt or
                     rf-lsd-num-pro       not  = w-det-pbs-num-pro
                     go to det-pbs-lst-900.
       det-pbs-lst-550.
      *                  *---------------------------------------------*
      *                  * Se sigla valuta a spaces si ignora l'ele-   *
      *                  * mento                                       *
      *                  *---------------------------------------------*
           if        rf-lsd-sgl-vlt       =    spaces
                     go to det-pbs-lst-450.
      *                  *---------------------------------------------*
      *                  * Se si tratta del primo elemento trovato ed  *
      *                  * il prezzo e' pari a quello del listino ba-  *
      *                  * se lo si ignora, a meno che la sua data di  *
      *                  * validita' finale non sia superiore alla da- *
      *                  * ta di sistema attuale                       *
      *                  *---------------------------------------------*
           if        w-det-pbs-sto-num    >    zero
                     go to det-pbs-lst-600.
           if        w-det-pbs-bas-flg    =    "N"
                     go to det-pbs-lst-600.
           if        w-det-pbs-bas-vlt    =    spaces
                     go to det-pbs-lst-600.
           if        w-det-pbs-bas-vlt    not  = rf-lsd-sgl-vlt
                     go to det-pbs-lst-600.
           if        w-det-pbs-bas-dcv    not  = rf-lsd-dec-vlt
                     go to det-pbs-lst-600.
           if        w-det-pbs-bas-prz    not  = rf-lsd-prz-lst
                     go to det-pbs-lst-600.
           if        w-det-pbs-dat-sys    <    rf-lsd-dva-fin
                     go to det-pbs-lst-600.
           go to     det-pbs-lst-450.
       det-pbs-lst-600.
      *                  *---------------------------------------------*
      *                  * Incremento numero prezzi storici trovati    *
      *                  *---------------------------------------------*
           add       1                    to   w-det-pbs-sto-num      .
       det-pbs-lst-650.
      *                  *---------------------------------------------*
      *                  * Memorizzazione prezzo storico trovato       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Sigla valuta                            *
      *                      *-----------------------------------------*
           move      rf-lsd-sgl-vlt       to   w-det-pbs-sto-vlt
                                              (w-det-pbs-sto-num)     .
      *                      *-----------------------------------------*
      *                      * Decimali valuta                         *
      *                      *-----------------------------------------*
           move      rf-lsd-dec-vlt       to   w-det-pbs-sto-dcv
                                              (w-det-pbs-sto-num)     .
      *                      *-----------------------------------------*
      *                      * Prezzo                                  *
      *                      *-----------------------------------------*
           move      rf-lsd-prz-lst       to   w-det-pbs-sto-prz
                                              (w-det-pbs-sto-num)     .
      *                      *-----------------------------------------*
      *                      * Data di validita' finale                *
      *                      *-----------------------------------------*
           move      rf-lsd-dva-fin       to   w-det-pbs-sto-dvf
                                              (w-det-pbs-sto-num)     .
       det-pbs-lst-700.
      *                  *---------------------------------------------*
      *                  * Se raggiunto il max numero di prezzi stori- *
      *                  * ci da ricercare si esce, altrimenti si ri-  *
      *                  * cerca il prezzo storico successivo          *
      *                  *---------------------------------------------*
           if        w-det-pbs-sto-num    =    w-det-pbs-max-sto
                     go to det-pbs-lst-900
           else      go to det-pbs-lst-450.
       det-pbs-lst-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-pbs-lst-999.
       det-pbs-lst-999.
           exit.

      *    *===========================================================*
      *    * Routine lettura tabella [zls]                             *
      *    *-----------------------------------------------------------*
       let-arc-zls-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-zls-flg      .
      *              *-------------------------------------------------*
      *              * Test se codice listino a Spaces                 *
      *              *-------------------------------------------------*
           if        w-let-arc-zls-cod    not  = spaces
                     go to let-arc-zls-400.
       let-arc-zls-200.
      *              *-------------------------------------------------*
      *              * Se codice listino a Spaces                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Descrizione listino                         *
      *                  *---------------------------------------------*
           move      "Listino Base        "
                                          to   w-let-arc-zls-des      .
      *                  *---------------------------------------------*
      *                  * Valuta per il listino, valuta base          *
      *                  *---------------------------------------------*
           move      c-sgl                to   w-let-arc-zls-vlt      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     let-arc-zls-999.
       let-arc-zls-400.
      *              *-------------------------------------------------*
      *              * Se codice listino a non Spaces                  *
      *              *-------------------------------------------------*
       let-arc-zls-450.
      *                  *---------------------------------------------*
      *                  * Lettura per codice                          *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODLST    "         to   f-key                  .
           move      w-let-arc-zls-cod    to   rf-zls-cod-lst         .
           move      "pgm/dcp/fls/ioc/obj/iofzls"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zls                 .
      *                  *---------------------------------------------*
      *                  * Deviazione secondo l'esito della lettura    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to let-arc-zls-550.
       let-arc-zls-500.
      *                  *---------------------------------------------*
      *                  * Se record esistente                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Descrizione listino                     *
      *                      *-----------------------------------------*
           move      rf-zls-des-lst       to   w-let-arc-zls-des      .
      *                      *-----------------------------------------*
      *                      * Valuta per il listino                   *
      *                      *-----------------------------------------*
           move      rf-zls-cod-vlt       to   w-let-arc-zls-vlt      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     let-arc-zls-999.
       let-arc-zls-550.
      *                  *---------------------------------------------*
      *                  * Se record non esistente                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di uscita ad errore                *
      *                      *-----------------------------------------*
           move      "#"                  to   w-let-arc-zls-flg      .
      *                      *-----------------------------------------*
      *                      * Descrizione listino                     *
      *                      *-----------------------------------------*
           move      all   "."            to   w-let-arc-zls-des      .
      *                      *-----------------------------------------*
      *                      * Valuta per il listino                   *
      *                      *-----------------------------------------*
           move      spaces               to   w-let-arc-zls-vlt      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     let-arc-zls-999.
       let-arc-zls-999.
           exit.

      *    *===========================================================*
      *    * Routine lettura tabella [zvl]                             *
      *    *-----------------------------------------------------------*
       let-arc-zvl-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-zvl-flg      .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del valore della sigla va- *
      *              * luta                                            *
      *              *-------------------------------------------------*
           if        w-let-arc-zvl-cod    =    c-sgl
                     go to let-arc-zvl-200
           else if   w-let-arc-zvl-cod    =    spaces
                     go to let-arc-zvl-400
           else      go to let-arc-zvl-600.
       let-arc-zvl-200.
      *              *-------------------------------------------------*
      *              * Se sigla valuta pari alla valuta base           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Descrizione valuta in lingua italiana       *
      *                  *---------------------------------------------*
           move      c-des                to   w-let-arc-zvl-des      .
      *                  *---------------------------------------------*
      *                  * Descrizione valuta internazionale           *
      *                  *---------------------------------------------*
           move      c-din                to   w-let-arc-zvl-din      .
      *                  *---------------------------------------------*
      *                  * Numero decimali valuta                      *
      *                  *---------------------------------------------*
           move      c-dec                to   w-let-arc-zvl-dec      .
      *                  *---------------------------------------------*
      *                  * Tipo di coefficiente per cambio valuta      *
      *                  *---------------------------------------------*
           move      c-tdc                to   w-let-arc-zvl-tdc      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     let-arc-zvl-999.
       let-arc-zvl-400.
      *              *-------------------------------------------------*
      *              * Se sigla valuta a Spaces                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Descrizione valuta in lingua italiana       *
      *                  *---------------------------------------------*
           move      spaces               to   w-let-arc-zvl-des      .
      *                  *---------------------------------------------*
      *                  * Descrizione valuta internazionale           *
      *                  *---------------------------------------------*
           move      spaces               to   w-let-arc-zvl-din      .
      *                  *---------------------------------------------*
      *                  * Numero decimali valuta                      *
      *                  *---------------------------------------------*
           move      zero                 to   w-let-arc-zvl-dec      .
      *                  *---------------------------------------------*
      *                  * Tipo di coefficiente per cambio valuta      *
      *                  *---------------------------------------------*
           move      spaces               to   w-let-arc-zvl-tdc      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     let-arc-zvl-999.
       let-arc-zvl-600.
      *              *-------------------------------------------------*
      *              * Se sigla valuta diversa dalla valuta base ed    *
      *              * anche diversa da Spaces                         *
      *              *-------------------------------------------------*
       let-arc-zvl-650.
      *                  *---------------------------------------------*
      *                  * Lettura per sigla valuta                    *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODVLT    "         to   f-key                  .
           move      w-let-arc-zvl-cod    to   rf-zvl-sgl-vlt         .
           move      "pgm/dcc/fls/ioc/obj/iofzvl"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zvl                 .
      *                  *---------------------------------------------*
      *                  * Deviazione secondo l'esito della lettura    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to let-arc-zvl-750.
       let-arc-zvl-700.
      *                  *---------------------------------------------*
      *                  * Se record esistente                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Descrizione valuta in lingua italiana   *
      *                      *-----------------------------------------*
           move      rf-zvl-des-ita       to   w-let-arc-zvl-des      .
      *                      *-----------------------------------------*
      *                      * Descrizione valuta internazionale       *
      *                      *-----------------------------------------*
           move      rf-zvl-des-int       to   w-let-arc-zvl-din      .
      *                      *-----------------------------------------*
      *                      * Numero decimali valuta                  *
      *                      *-----------------------------------------*
           move      rf-zvl-num-dec       to   w-let-arc-zvl-dec      .
      *                      *-----------------------------------------*
      *                      * Tipo di coefficiente per cambio valuta  *
      *                      *-----------------------------------------*
           move      rf-zvl-def-tdc       to   w-let-arc-zvl-tdc      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     let-arc-zvl-999.
       let-arc-zvl-750.
      *                  *---------------------------------------------*
      *                  * Se record non esistente                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di uscita ad errore                *
      *                      *-----------------------------------------*
           move      "#"                  to   w-let-arc-zvl-flg      .
      *                      *-----------------------------------------*
      *                      * Descrizione valuta in lingua italiana   *
      *                      *-----------------------------------------*
           move      all   "."            to   w-let-arc-zvl-des      .
      *                      *-----------------------------------------*
      *                      * Descrizione valuta internazionale       *
      *                      *-----------------------------------------*
           move      all   "."            to   w-let-arc-zvl-din      .
      *                      *-----------------------------------------*
      *                      * Numero decimali valuta                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-let-arc-zvl-dec      .
      *                      *-----------------------------------------*
      *                      * Tipo di coefficiente per cambio valuta  *
      *                      *-----------------------------------------*
           move      spaces               to   w-let-arc-zvl-tdc      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     let-arc-zvl-999.
       let-arc-zvl-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [dcp]                         *
      *    *-----------------------------------------------------------*
       let-arc-dcp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-dcp-flg      .
      *              *-------------------------------------------------*
      *              * Test se codice a zero                           *
      *              *-------------------------------------------------*
           if        w-let-arc-dcp-cod    =    zero  
                     go to let-arc-dcp-500.
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      w-let-arc-dcp-cod    to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-dcp-400.
       let-arc-dcp-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-dcp-des-pro       to   w-let-arc-dcp-des      .
           move      rf-dcp-alf-pro       to   w-let-arc-dcp-alf      .
           move      rf-dcp-sgl-vlt       to   w-let-arc-dcp-sgv      .
           move      rf-dcp-dec-vlt       to   w-let-arc-dcp-dcv      .
           move      rf-dcp-dec-prz       to   w-let-arc-dcp-dpr      .
           move      rf-dcp-prz-lst       to   w-let-arc-dcp-prz      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-dcp-999.
       let-arc-dcp-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-dcp-flg      .
           move      all   "."            to   w-let-arc-dcp-des      .
           go to     let-arc-dcp-600.
       let-arc-dcp-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-dcp-des      .
       let-arc-dcp-600.
           move      spaces               to   w-let-arc-dcp-alf      .
           move      spaces               to   w-let-arc-dcp-sgv      .
           move      zero                 to   w-let-arc-dcp-dcv      .
           move      zero                 to   w-let-arc-dcp-dpr      .
           move      zero                 to   w-let-arc-dcp-prz      .
       let-arc-dcp-999.
           exit.

      *    *===========================================================*
      *    * Box per messaggio di errore                               *
      *    *-----------------------------------------------------------*
       box-msg-err-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      12                   to   v-lin                  .
           move      04                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      77                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Messaggio nel box                               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-msg    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Parentesi quadre di delimitazione               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      13                   to   v-lin                  .
           move      74                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-msg-err-999.
           exit.

