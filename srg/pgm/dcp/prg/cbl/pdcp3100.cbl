      *                  * storico listini, max 9                      *
      *                  *---------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *
           move      w-tes-tip-rec        to   w-det-pbs-tip-rec      .
           move      w-tes-cod-lst        to   w-det-pbs-cod-lst      .
           move      w-tes-cod-cli        to   w-det-pbs-cod-cli      .
           move      w-tes-cod-lst-vlt    to   w-det-pbs-sgl-vlt      .
           move      w-tes-num-pro        to   w-det-pbs-num-pro      .
           move      5                    to   w-det-pbs-max-sto      .
           move      "S"                  to   w-det-pbs-dcp-mem      .
           move      s-dat                to   w-det-pbs-dat-sys      .
