      *                      *-----------------------------------------*
           if        rf-lsd-tip-rec       not  = 01            or
                     rf-lsd-cod-lst       not  = spaces        or
                     rf-lsd-cod-cli       not  = zero          or
                     rf-lsd-sgl-vlt       not  = c-sgl         or
                     rf-lsd-num-pro       not  = w-tes-num-pro
                     go to acc-dat-sto-600.
      *                      *-----------------------------------------*
      *                      * Confronto fra data richiesta e data     *
      *                      * ultima storicizzata                     *
      *                      *-----------------------------------------*
           if        rf-lsd-dva-fin       <    w-tes-prz-lst-dts (1)
                     go to acc-dat-sto-600.
      *                          *-------------------------------------*
      *                          * Messaggio di errore                 *
      *                          *-------------------------------------*
           move      "La data di storicizzazione richiesta deve essere s
      -              "uperiore a     "    to   w-err-box-err-msg      .
           move      "quella dell'ultimo prezzo di listino storicizzato 
      -              "!              "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                          *-------------------------------------*
      *                          * A reimpostazione                    *
      *                          *-------------------------------------*
           go to     acc-dat-sto-100.
       acc-dat-sto-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione segnale di storicizzazione  *
      *                  * da effettuare                               *
      *                  *---------------------------------------------*
           if        w-tes-prz-lst-dts (1)
                                          not  = zero and
                     w-prs-sns-vpl        =    "S"
                     move  "#"            to   w-tes-prz-lst-sto (1)  .
      *                  *---------------------------------------------*
      *                  * Rivisualizzazione prompt                    *
      *                  *---------------------------------------------*
           perform   pmt-dat-sto-000      thru pmt-dat-sto-999        .
       acc-dat-sto-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-dat-sto-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-dat-sto-100.
       acc-dat-sto-999.
           exit.

