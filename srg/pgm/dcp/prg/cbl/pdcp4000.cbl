      *    *-----------------------------------------------------------*
       wrt-rec-lsd-000.
      *              *-------------------------------------------------*
      *              * Test su personalizzazione                       *
      *              *-------------------------------------------------*
           if        w-prs-sns-vpl        not  = "S"
                     go to wrt-rec-lsd-900.
      *              *-------------------------------------------------*
      *              * Se non e' stata richiesta la storicizzazione :  *
      *              * uscita senza alcuna azione                      *
      *              *-------------------------------------------------*
           if        w-tes-prz-lst-sto (1)
                                          =    spaces
                     go to wrt-rec-lsd-900.
      *              *-------------------------------------------------*
      *              * Test su data di storicizzazione                 *
      *              *-------------------------------------------------*
           if        w-tes-prz-lst-dts (1)
                                          =    zero
                     go to wrt-rec-lsd-900.
       wrt-rec-lsd-100.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflsd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lsd                 .
       wrt-rec-lsd-200.
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo record                                 *
      *                  *---------------------------------------------*
           move      01                   to   rf-lsd-tip-rec         .
      *                  *---------------------------------------------*
      *                  * Codice listino alternativo                  *
      *                  *---------------------------------------------*
           move      spaces               to   rf-lsd-cod-lst         .
      *                  *---------------------------------------------*
      *                  * Sigla della valuta                          *
      *                  *---------------------------------------------*
           move      c-sgl                to   rf-lsd-sgl-vlt         .
      *                  *---------------------------------------------*
      *                  * Numero decimali della valuta                *
      *                  *---------------------------------------------*
           move      c-dec                to   rf-lsd-dec-vlt         .
      *                  *---------------------------------------------*
      *                  * Codice prodotto numerico                    *
      *                  *---------------------------------------------*
           move      w-tes-num-pro        to   rf-lsd-num-pro         .
      *                  *---------------------------------------------*
      *                  * Prezzo                                      *
      *                  *---------------------------------------------*
           move      w-tes-prz-lst (2)    to   rf-lsd-prz-lst         .
      *                  *---------------------------------------------*
      *                  * Data di validita' iniziale                  *
      *                  *---------------------------------------------*
           move      zero                 to   rf-lsd-dva-ini         .
      *                  *---------------------------------------------*
      *                  * Data di validita' finale                    *
      *                  *---------------------------------------------*
           move      w-tes-prz-lst-dts (1)
                                          to   rf-lsd-dva-fin         .
      *                  *---------------------------------------------*
      *                  * Data di validita' finale in formato 're-    *
      *                  * verse'                                      *
      *                  *---------------------------------------------*
           move      99999999             to   rf-lsd-dvf-rev         .
           if        rf-lsd-dva-fin       not  = zero
                     subtract   19000000  from rf-lsd-dvf-rev
                     subtract   rf-lsd-dva-fin
                                          from rf-lsd-dvf-rev         .
      *                  *---------------------------------------------*
      *                  * Area libera per espansioni speciali         *
      *                  *---------------------------------------------*
           move      spaces               to   rf-lsd-alx-exp         .
       wrt-rec-lsd-300.
      *              *-------------------------------------------------*
      *              * Put record                                      *
      *              *-------------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflsd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lsd                 .
       wrt-rec-lsd-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     wrt-rec-lsd-999.
       wrt-rec-lsd-999.
           exit.

      *    *===========================================================*
      *    * Scrittura record [lfd], solo se richiesta la storicizza-  *
      *    * zione del prezzo di acquisto                              *
      *    *-----------------------------------------------------------*
       wrt-rec-lfd-000.
      *              *-------------------------------------------------*
      *              * Se non e' stata richiesta la storicizzazione :  *
      *              * uscita senza alcuna azione                      *
      *              *-------------------------------------------------*
           if        w-tes-prz-pes-sto (1)
                                          =    spaces
                     go to wrt-rec-lfd-900.
      *              *-------------------------------------------------*
      *              * Normalizzazione cautelare flag                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-tes-prz-pes-sto (1)  .
      *              *-------------------------------------------------*
      *              * Data di storicizzazione : data di sistema -1    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione data di sistema              *
      *                  *---------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Determinazione del giorno precedente        *
      *                  *---------------------------------------------*
           move      s-dat                to   w-det-nrg-dat-dtb      .
           move      1                    to   w-det-nrg-dat-ngd      .
           perform   det-nrg-dat-000      thru det-nrg-dat-999        .
           move      w-det-nrg-dat-dtd    to   s-dat                  .
       wrt-rec-lfd-100.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcf/fls/ioc/obj/ioflfd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lfd                 .
       wrt-rec-lfd-200.
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo record                                 *
      *                  *---------------------------------------------*
           move      01                   to   rf-lfd-tip-rec         .
      *                  *---------------------------------------------*
      *                  * Codice fornitore                            *
      *                  *---------------------------------------------*
           move      w-tes-dcf-pfz (1)    to   rf-lfd-cod-dcf         .
      *                  *---------------------------------------------*
      *                  * Sigla della valuta per l'acquisto           *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vlt (1)    to   rf-lfd-sgl-vlt         .
      *                  *---------------------------------------------*
      *                  * Numero decimali della valuta                *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vlt-dec (1)
                                          to   rf-lfd-dec-vlt         .
           add       w-tes-dpr-acq (1)    to   rf-lfd-dec-vlt         .
      *                  *---------------------------------------------*
      *                  * Tipo magazzino                              *
      *                  *---------------------------------------------*
           move      01                   to   rf-lfd-tip-mag         .
      *                  *---------------------------------------------*
      *                  * Codice prodotto numerico                    *
      *                  *---------------------------------------------*
           move      w-tes-num-pro        to   rf-lfd-num-mag         .
      *                  *---------------------------------------------*
      *                  * Formato di acquisto                         *
      *                  *---------------------------------------------*
           move      spaces               to   rf-lfd-fda-pif         .
      *                  *---------------------------------------------*
      *                  * Prezzo                                      *
      *                  *---------------------------------------------*
           move      w-tes-prz-pes (2)    to   rf-lfd-prz-pes (1)     .
      *                  *---------------------------------------------*
      *                  * Data di validita' iniziale                  *
      *                  *---------------------------------------------*
           move      zero                 to   rf-lfd-dva-ini         .
      *                  *---------------------------------------------*
      *                  * Data di validita' finale                    *
      *                  *---------------------------------------------*
           move      s-dat                to   rf-lfd-dva-fin         .
      *                  *---------------------------------------------*
      *                  * Data di validita' finale in formato 're-    *
      *                  * verse'                                      *
      *                  *---------------------------------------------*
           move      99999999             to   rf-lfd-dvf-rev         .
           if        rf-lfd-dva-fin       not  = zero
                     subtract   19000000  from rf-lfd-dvf-rev
                     subtract   rf-lfd-dva-fin
                                          from rf-lfd-dvf-rev         .
      *                  *---------------------------------------------*
      *                  * Area libera per espansioni speciali         *
      *                  *---------------------------------------------*
           move      spaces               to   rf-lfd-alx-exp         .
       wrt-rec-lfd-300.
      *              *-------------------------------------------------*
      *              * Put record                                      *
      *              *-------------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/dcf/fls/ioc/obj/ioflfd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lfd                 .
       wrt-rec-lfd-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     wrt-rec-lfd-999.
       wrt-rec-lfd-999.
           exit.

      *    *===========================================================*
      *    * Cancellazione record [pdx]                                *
      *    *-----------------------------------------------------------*
       del-rec-pdx-dcf-000.
      *              *-------------------------------------------------*
      *              * Test se record da trattare                      *
      *              *-------------------------------------------------*
           if        w-prs-sna-igs-aaf    not  = "S"
                     go to del-rec-pdx-dcf-999.
      *              *-------------------------------------------------*
      *              * Ciclo per cancellazione fino a 10 righe di de-  *
      *              * scrizione prodotto                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-cix-ctr-001          .
       del-rec-pdx-dcf-100.
           add       1                    to   w-cix-ctr-001          .
           if        w-cix-ctr-001        >    10
                     go to del-rec-pdx-dcf-999.
      *                  *---------------------------------------------*
      *                  * Composizione record [pdx]                   *
      *                  *---------------------------------------------*
           perform   cmp-rec-pdx-dcf-000      thru cmp-rec-pdx-dcf-999
      *                  *---------------------------------------------*
      *                  * Delete record                               *
      *                  *---------------------------------------------*
           move      "DE"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     del-rec-pdx-dcf-100.
       del-rec-pdx-dcf-999.
           exit.

      *    *===========================================================*
      *    * Box per messaggio di prodotto con status non 'normale'    *
      *    *-----------------------------------------------------------*
       box-msg-sts-000.
      *              *-------------------------------------------------*
      *              * Test se messaggio da visualizzare               *
      *              *-------------------------------------------------*
           if        w-tes-sta-tus (1)    =    01
                     move  01             to   w-wrk-sta-tus-pnt
           else if   w-tes-sta-tus (1)    =    11
                     move  02             to   w-wrk-sta-tus-pnt
           else if   w-tes-sta-tus (1)    =    21
                     move  03             to   w-wrk-sta-tus-pnt
           else if   w-tes-sta-tus (1)    =    51
                     move  04             to   w-wrk-sta-tus-pnt
           else if   w-tes-sta-tus (1)    =    52
                     move  05             to   w-wrk-sta-tus-pnt
           else if   w-tes-sta-tus (1)    =    71
                     move  06             to   w-wrk-sta-tus-pnt
           else if   w-tes-sta-tus (1)    =    72
                     move  07             to   w-wrk-sta-tus-pnt
           else      move  zero           to   w-wrk-sta-tus-pnt      .
           if        w-wrk-sta-tus-pnt    <    02
                     go to box-msg-sts-900.
           if        w-wrk-sta-tus-pnt    >    07
                     go to box-msg-sts-900.
       box-msg-sts-100.
      *              *-------------------------------------------------*
      *              * Preparazione messaggio - riga 1                 *
      *              *-------------------------------------------------*
           move      w-exp-sta-tus-tbl    to   w-wrk-sta-tus-tbl      .
      *
           move      "Attenzione : lo status commerciale del prodotto ri
      -              "chiamato e' :  "    to   w-err-box-err-msg      .
      *              *-------------------------------------------------*
      *              * Preparazione messaggio - riga 2                 *
      *              *-------------------------------------------------*
           move      65                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
           move      w-wrk-sta-tus-ele
                    (w-wrk-sta-tus-pnt)   to   w-all-str-cat (1)      .
           if        w-tes-sta-tuc-alf (1)
                                          =    spaces
                     move  spaces         to   w-all-str-cat (2)
                     move  spaces         to   w-all-str-cat (3)
                     move  spaces         to   w-all-str-cat (4)
           else      move  "'"            to   w-all-str-cat (2)
                     move  w-tes-sta-tuc-alf (1)
                                          to   w-all-str-cat (3)
                     move  "'"            to   w-all-str-cat (4)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
           move      w-all-str-alf        to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       box-msg-sts-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     box-msg-sts-999.
       box-msg-sts-999.
           exit.

      *    *===========================================================*
      *    * Routine di compattamento righe di descrizione             *
      *    *-----------------------------------------------------------*
       cmp-rig-des-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di rivisualizzazione de-   *
      *              * scrizione                                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-cmp-rig-des-flg      .
      *              *-------------------------------------------------*
      *              * Determinazione numero righe attuale             *
      *              *-------------------------------------------------*
           move      11                   to   w-cmp-rig-des-nri      .
       cmp-rig-des-100.
           subtract  1                    from w-cmp-rig-des-nri      .
           if        w-cmp-rig-des-rig
                    (w-cmp-rig-des-nri)   =    spaces
                     go to cmp-rig-des-100.
      *              *-------------------------------------------------*
      *              * Inizializzazione numero righe descrizione       *
      *              *-------------------------------------------------*
           move      zero                 to   w-cmp-rig-des-nrd      .
      *              *-------------------------------------------------*
      *              * Ciclo per compattamento                         *
      *              *-------------------------------------------------*
           move      zero                 to   w-cmp-rig-des-ctr      .
       cmp-rig-des-200.
           add       1                    to   w-cmp-rig-des-ctr      .
           if        w-cmp-rig-des-ctr    >    w-cmp-rig-des-nri
                     go to cmp-rig-des-300.
      *                  *---------------------------------------------*
      *                  * Se riga di descrizione a spazi : riciclo    *
      *                  *---------------------------------------------*
           if        w-cmp-rig-des-rig
                    (w-cmp-rig-des-ctr)   =    spaces
                     go to cmp-rig-des-200.
      *                  *---------------------------------------------*
      *                  * Incremento contatore numero righe           *
      *                  *---------------------------------------------*
           add       1                    to   w-cmp-rig-des-nrd      .
      *                  *---------------------------------------------*
      *                  * Spostamento riga di descrizione             *
      *                  *---------------------------------------------*
           move      w-cmp-rig-des-rig
                    (w-cmp-rig-des-ctr)   to   w-cmp-rig-des-rig
                                              (w-cmp-rig-des-nrd)     .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     cmp-rig-des-200.
       cmp-rig-des-300.
      *              *-------------------------------------------------*
      *              * Abblencamento righe residue                     *
      *              *-------------------------------------------------*
           move      w-cmp-rig-des-nrd    to   w-cmp-rig-des-ctr      .
       cmp-rig-des-320.
           add       1                    to   w-cmp-rig-des-ctr      .
           if        w-cmp-rig-des-ctr    >    w-cmp-rig-des-nri
                     go to cmp-rig-des-900.
           move      spaces               to   w-cmp-rig-des-rig
                                              (w-cmp-rig-des-ctr)     .
           go to     cmp-rig-des-320.
       cmp-rig-des-900.
      *              *-------------------------------------------------*
      *              * Determinazione del flag di rivisualizzazione    *
      *              *-------------------------------------------------*
           if        w-cmp-rig-des-nri    not  = w-cmp-rig-des-nrd
                     move  "#"            to   w-cmp-rig-des-flg      .
       cmp-rig-des-999.
           exit.

      *    *===========================================================*
      *    * Determinazione prezzo su listino base e su storico dei    *
      *    * listini                                                   *
      *    *-----------------------------------------------------------*
       det-pbs-lst-000.
      *              *-------------------------------------------------*
      *              * Determinazione prezzo su listino base           *
      *              *-------------------------------------------------*
       det-pbs-lst-050.
      *                  *---------------------------------------------*
      *                  * Se record gia' in memoria si devia a se-    *
      *                  * conda se esisteva oppure no, controllando   *
      *                  * il codice prodotto alfanumerico             *
      *                  *---------------------------------------------*
           if        w-det-pbs-dcp-mem    not  = "S"
                     go to det-pbs-lst-100
           else if   rf-dcp-alf-pro       =    all "." or
                     rf-dcp-alf-pro       =    spaces
                     go to det-pbs-lst-160
           else      go to det-pbs-lst-200.
       det-pbs-lst-100.
      *                  *---------------------------------------------*
      *                  * Lettura record da [dcp]                     *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      w-det-pbs-num-pro    to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
       det-pbs-lst-150.
      *                  *---------------------------------------------*
      *                  * Se record non esistente                     *
      *                  *---------------------------------------------*
       det-pbs-lst-155.
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        f-sts                =    e-not-err
                     go to det-pbs-lst-200.
       det-pbs-lst-160.
      *                      *-----------------------------------------*
      *                      * Flag di esistenza a No                  *
      *                      *-----------------------------------------*
           move      "N"                  to   w-det-pbs-bas-flg      .
      *                      *-----------------------------------------*
      *                      * Sigla valuta a spaces                   *
      *                      *-----------------------------------------*
           move      spaces               to   w-det-pbs-bas-vlt      .
      *                      *-----------------------------------------*
      *                      * Decimali valuta a zero                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-pbs-bas-dcv      .
      *                      *-----------------------------------------*
      *                      * Prezzo a zero                           *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-pbs-bas-prz      .
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     det-pbs-lst-300.
       det-pbs-lst-200.
      *                  *---------------------------------------------*
      *                  * Se record esistente                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di esistenza a Si                  *
      *                      *-----------------------------------------*
           move      "S"                  to   w-det-pbs-bas-flg      .
      *                      *-----------------------------------------*
      *                      * Sigla valuta                            *
      *                      *-----------------------------------------*
           move      rf-dcp-sgl-vlt       to   w-det-pbs-bas-vlt      .
      *                      *-----------------------------------------*
      *                      * Decimali valuta                         *
      *                      *-----------------------------------------*
           move      rf-dcp-dec-vlt       to   w-det-pbs-bas-dcv      .
      *                      *-----------------------------------------*
      *                      * Prezzo                                  *
      *                      *-----------------------------------------*
           move      rf-dcp-prz-lst       to   w-det-pbs-bas-prz      .
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     det-pbs-lst-300.
       det-pbs-lst-300.
      *              *-------------------------------------------------*
      *              * Determinazione prezzi su storico listini        *
      *              *-------------------------------------------------*
       det-pbs-lst-350.
      *                  *---------------------------------------------*
      *                  * Numero prezzi storici trovati : zero        *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-pbs-sto-num      .
      *                  *---------------------------------------------*
      *                  * Se max numero di prezzi storici da ricerca- *
      *                  * re a zero : uscita                          *
      *                  *---------------------------------------------*
           if        w-det-pbs-max-sto    =    zero
                     go to det-pbs-lst-900.
       det-pbs-lst-400.
      *                  *---------------------------------------------*
      *                  * Start su storico listini                    *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "LSTPRODFR "         to   f-key                  .
           move      w-det-pbs-tip-rec    to   rf-lsd-tip-rec         .
           move      w-det-pbs-cod-lst    to   rf-lsd-cod-lst         .
           move      w-det-pbs-cod-cli    to   rf-lsd-cod-cli         .
           move      w-det-pbs-sgl-vlt    to   rf-lsd-sgl-vlt         .
           move      w-det-pbs-num-pro    to   rf-lsd-num-pro         .
