      *              * di gestione                                     *
      *              *-------------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "num-pro"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "N"                  to   s-tip                  .
           move      07                   to   s-car                  .
           move      zero                 to   s-dec                  .
           move      spaces               to   s-sgn                  .
           move      w-tes-num-pro        to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
