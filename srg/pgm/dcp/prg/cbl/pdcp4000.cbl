      *    *===========================================================*
      *    * Visualizzazione campo : Prezzo su listino storicizzato    *
      *    *-----------------------------------------------------------*
       vis-prz-sto-000.
      *              *-------------------------------------------------*
      *              * Campi da visualizzare solo in modifica e solo   *
      *              * se rilevati prezzi storici                      *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "I"
                     go to vis-prz-sto-999.
           if        w-det-pbs-sto-num    =    zero
                     go to vis-prz-sto-999.
      *              *-------------------------------------------------*
      *              * Indice su prezzi storici determinati : a zero   *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-pbs-sto-inx      .
      *              *-------------------------------------------------*
      *              * Prezzo di listino base in comodo di confronto   *
      *              *-------------------------------------------------*
           move      w-det-pbs-bas-prz    to   w-det-pbs-sto-cmp      .
       vis-prz-sto-100.
      *              *-------------------------------------------------*
      *              * Incremento indice su prezzi storici determinati *
      *              *-------------------------------------------------*
           add       1                    to   w-det-pbs-sto-inx      .
      *              *-------------------------------------------------*
      *              * Se maggiore del numero prezzi determinati : u-  *
      *              * scita                                           *
      *              *-------------------------------------------------*
           if        w-det-pbs-sto-inx    >    w-det-pbs-sto-num
                     go to vis-prz-sto-900.
       vis-prz-sto-150.
      *              *-------------------------------------------------*
      *              * Se il prezzo storicizzato e' uguale al prece-   *
      *              * dente : a riciclo                               *
      *              *-------------------------------------------------*
           if        w-det-pbs-sto-prz
                    (w-det-pbs-sto-inx)   =    w-det-pbs-sto-cmp
                     go to vis-prz-sto-100.
       vis-prz-sto-200.
      *              *-------------------------------------------------*
      *              * Visualizzazione sigla valuta                    *
      *              *-------------------------------------------------*
           if        w-det-pbs-sto-vlt
                    (w-det-pbs-sto-inx)   =    c-sgl  or
                     w-det-pbs-sto-vlt
                    (w-det-pbs-sto-inx)   =    spaces
                     go to vis-prz-sto-300.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      12                   to   v-lin                  .
           add       w-det-pbs-sto-inx    to   v-lin                  .
           subtract  1                    from v-lin                  .
           move      32                   to   v-pos                  .
           move      w-det-pbs-sto-vlt
                    (w-det-pbs-sto-inx)   to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-prz-sto-300.
      *              *-------------------------------------------------*
      *              * Visualizzazione prezzo                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-det-pbs-sto-dcv
                    (w-det-pbs-sto-inx)   to   v-dec                  .
           add       w-tes-dec-prz (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      12                   to   v-lin                  .
           add       w-det-pbs-sto-inx    to   v-lin                  .
           subtract  1                    from v-lin                  .
           if        w-det-pbs-sto-vlt
                    (w-det-pbs-sto-inx)   =    c-sgl  or
                     w-det-pbs-sto-vlt
                    (w-det-pbs-sto-inx)   =    spaces
                     move  30             to   v-pos
           else      move  34             to   v-pos                  .
           move      w-det-pbs-sto-prz
                    (w-det-pbs-sto-inx)   to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Prezzo storicizzato in comodo di confronto      *
      *              *-------------------------------------------------*
           move      w-det-pbs-sto-prz
                    (w-det-pbs-sto-inx)   to   w-det-pbs-sto-cmp      .
       vis-prz-sto-400.
      *              *-------------------------------------------------*
      *              * Visualizzazione data di validita' finale        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se a zero : no visualizzazione              *
      *                  *---------------------------------------------*
           if        w-det-pbs-sto-dvf
                    (w-det-pbs-sto-inx)   =    zero
                     go to vis-prz-sto-500.
      *                  *---------------------------------------------*
      *                  * Editing data di validita' finale            *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      w-det-pbs-sto-dvf
                    (w-det-pbs-sto-inx)   to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      27                   to   v-car                  .
           move      12                   to   v-lin                  .
           add       w-det-pbs-sto-inx    to   v-lin                  .
           subtract  1                    from v-lin                  .
           move      54                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           string    "In vigore fino al: "
                                delimited by   size
                     v-edt      delimited by   spaces
                                          into v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Eventuale segnale di prezzo in vigore       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * System date da segreteria               *
      *                      *-----------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-dat                >    w-det-pbs-sto-dvf
                                              (w-det-pbs-sto-inx)
                     go to vis-prz-sto-500.
      *                      *-----------------------------------------*
      *                      * Visualizzazione segnale                 *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      12                   to   v-lin                  .
           add       w-det-pbs-sto-inx    to   v-lin                  .
           subtract  1                    from v-lin                  .
           move      52                   to   v-pos                  .
           move      "*"                  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-prz-sto-500.
      *              *-------------------------------------------------*
      *              * Riciclo su prezzo storico successivo            *
      *              *-------------------------------------------------*
           go to     vis-prz-sto-100.
       vis-prz-sto-900.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     vis-prz-sto-999.
       vis-prz-sto-999.
           exit.

