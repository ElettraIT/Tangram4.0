      *    *                                                           *
      *    * Subroutine di assemblaggio per codici EAN                 *
      *    *-----------------------------------------------------------*
       acc-klb-pro-ean-000.
      *              *-------------------------------------------------*
      *              * Assemblaggio con prefisso                       *
      *              *-------------------------------------------------*
           move      "AP"                 to   d-bar-cod-tip-ope      .
           move      w-ref-spc-bcd-bcd    to   d-bar-cod-tip-cod      .
           move      w-ref-spc-bcd-aon    to   d-bar-cod-tip-cdp      .
           move      w-tes-num-pro        to   d-bar-cod-num-cod      .
           move      w-tes-alf-pro (1)    to   d-bar-cod-alf-cod      .
           perform   det-bar-cod-cll-000  thru det-bar-cod-cll-999    .
           move      d-bar-cod-bar-cod    to   w-tes-klb-pro (1)      .
       acc-klb-pro-ean-200.
      *              *-------------------------------------------------*
      *              * Determinazione del chek digit                   *
      *              *-------------------------------------------------*
           move      "CD"                 to   d-bar-cod-tip-ope      .
           move      w-ref-spc-bcd-bcd    to   d-bar-cod-tip-cod      .
           move      w-tes-klb-pro (1)    to   d-bar-cod-bar-cod      .
           perform   det-bar-cod-cll-000  thru det-bar-cod-cll-999    .
           move      d-bar-cod-bar-cod    to   w-tes-klb-pro (1)      .
       acc-klb-pro-ean-300.
      *              *-------------------------------------------------*
      *              * Eventuale scrittura file                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su personalizzazione                   *
      *                  *---------------------------------------------*
           if        w-prs-snx-gbc-sni    not  = "S"
                     go to acc-klb-pro-ean-900.
      *                  *---------------------------------------------*
      *                  * Chiamata al modulo specializzato            *
      *                  *---------------------------------------------*
           move      "MF"                 to   d-bar-cod-tip-ope      .
           move      w-ref-spc-bcd-bcd    to   d-bar-cod-tip-cod      .
           move      w-ref-spc-bcd-aon    to   d-bar-cod-tip-cdp      .
           move      w-tes-num-pro        to   d-bar-cod-num-cod      .
           move      w-tes-alf-pro (1)    to   d-bar-cod-alf-cod      .
           move      w-tes-klb-pro (1)    to   d-bar-cod-bar-cod      .
           perform   det-bar-cod-cll-000  thru det-bar-cod-cll-999    .
       acc-klb-pro-ean-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-klb-pro-ean-999.
       acc-klb-pro-ean-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Chiave libera                     *
      *    *-----------------------------------------------------------*
       vis-klb-pro-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da visualizzare               *
      *                  *---------------------------------------------*
           if        w-prs-snx-gbc-sng    not  = "S"
                     go to vis-klb-pro-999.
       vis-klb-pro-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      68                   to   v-pos                  .
           move      w-tes-klb-pro (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-klb-pro-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Descrizione interna          *
      *    *-----------------------------------------------------------*
       acc-des-int-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-des-int (1)    to   w-sav-des-int          .
       acc-des-int-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "NXSC"               to   v-pfk (08)             .
           move      w-tes-des-int (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-des-int-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-des-int-999.
       acc-des-int-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-des-int (1)      .
       acc-des-int-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a spaces : reimpostazione, a meno *
      *                  * che non sia su tasto Up                     *
      *                  *---------------------------------------------*
           if        w-tes-des-int (1)    not  = spaces
                     go to acc-des-int-450.
           if        v-key                =    "UP  "
                     go to acc-des-int-600
           else      go to acc-des-int-100.
       acc-des-int-450.
      *                  *---------------------------------------------*
      *                  * Se valore a non spaces il primo carattere   *
      *                  * della prima riga non deve essere a spaces   *
      *                  *---------------------------------------------*
           if        w-tes-des-int (1)
                    (01 : 01)             =    spaces
                     go to acc-des-int-100.
       acc-des-int-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione riga descrizione in uppercase  *
      *                  *---------------------------------------------*
           move      w-tes-des-int (1)    to   w-all-str-alf          .
           move      40                   to   w-all-str-lun          .
           perform   all-str-upp-000      thru all-str-upp-999        .
           move      w-all-str-alf        to   w-tes-des-key (1)      .
       acc-des-int-650.
      *                  *---------------------------------------------*
      *                  * Preparazione descrizione per documenti      *
      *                  *---------------------------------------------*
       acc-des-int-655.
      *                      *-----------------------------------------*
      *                      * Se descrizione ad uso interno a spaces, *
      *                      * si pone a spaces anche quella per docu- *
      *                      * menti                                   *
      *                      *-----------------------------------------*
           if        w-tes-des-int (1)    =    spaces
                     move  spaces         to   w-tes-des-doc (1)
                     go to acc-des-int-660.
      *                      *-----------------------------------------*
      *                      * Se descrizione per documenti a spaces,  *
      *                      * la si pone comunque pari a quella per   *
      *                      * uso interno                             *
      *                      *-----------------------------------------*
           if        w-tes-des-doc (1)    =    spaces
                     move  w-tes-des-int (1)
                                          to   w-tes-des-doc (1)
                     go to acc-des-int-660.
      *                      *-----------------------------------------*
      *                      * Se descrizione per documenti e' diversa *
      *                      * da spaces la si pone pari a quella per  *
      *                      * uso interno solamente se prima dell'im- *
      *                      * postazione era pari a quella per uso    *
      *                      * interno                                 *
      *                      *-----------------------------------------*
           if        w-tes-des-doc (1)    =    w-sav-des-int
                     move  w-tes-des-int (1)
                                          to   w-tes-des-doc (1)
                     go to acc-des-int-660.
      *                      *-----------------------------------------*
      *                      * Altrimenti si lascia la descrizione per *
      *                      * documenti inalterata                    *
      *                      *-----------------------------------------*
           go to     acc-des-int-665.
       acc-des-int-660.
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione per docu-   *
      *                      * menti                                   *
      *                      *-----------------------------------------*
           perform   vis-des-doc-000      thru vis-des-doc-999        .
       acc-des-int-665.
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     acc-des-int-700.
       acc-des-int-700.
      *                  *---------------------------------------------*
      *                  * Eventuale variazione descrizione per il     *
      *                  * fornitore preferenziale                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se descrizione variata             *
      *                      *-----------------------------------------*
           if        w-tes-des-int (1)    =    w-sav-des-int
                     go to acc-des-int-800.
      *                      *-----------------------------------------*
      *                      * Solo se personalizzazioni lo consentono *
      *                      *-----------------------------------------*
           if        w-prs-sna-igs-aaf    not  = "S"
                     go to acc-des-int-800.
      *                      *-----------------------------------------*
      *                      * Solo se fornitore preferenziale esiste  *
      *                      *-----------------------------------------*
           if        w-tes-dcf-pfz (1)    =    zero
                     go to acc-des-int-800.
      *                      *-----------------------------------------*
      *                      * Solo se descrizione fornitore preferen- *
      *                      * ziale esiste                            *
      *                      *-----------------------------------------*
           if        w-acc-opz-des-acc    =    01
                     go to acc-des-int-800.
           if        w-tes-dep-sfn (1)    =    spaces
                     go to acc-des-int-800.
      *                      *-----------------------------------------*
      *                      * Solo se descrizione fornitore uguale a  *
      *                      * descrizione ad uso interno prima della  *
      *                      * variazione                              *
      *                      *-----------------------------------------*
           if        w-tes-dep-sfn (1)    not  = w-sav-des-int
                     go to acc-des-int-800.
      *                      *-----------------------------------------*
      *                      * Descrizione per i documenti in descri-  *
      *                      * zione per il fornitore preferenziale    *
      *                      *-----------------------------------------*
           move      w-tes-des-doc (1)    to   w-tes-dep-sfn (1)      .
       acc-des-int-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-des-int-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-des-int-100.
       acc-des-int-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione interna       *
      *    *-----------------------------------------------------------*
       vis-des-int-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-des-int (1)    to   v-alf                  .
