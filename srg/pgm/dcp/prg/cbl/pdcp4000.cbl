      *                  *---------------------------------------------*
           if        w-tes-tip-ubi-pdu (1)
                                          =    01
                     go to cnt-tdo-nok-mau-310
           else if   w-tes-tip-ubi-pdu (1)
                                          =    02
                     go to cnt-tdo-nok-mau-320
           else if   w-tes-tip-ubi-pdu (1)
                                          =    03
