      *    *===========================================================*
      *    * Determinazione eventuali azioni da compiere in caso di    *
      *    * modifica della descrizione del prodotto                   *
      *    *                                                           *
      *    * N.B.: Il test attualmente agisce sulla descrizione ad uso *
      *    *       interno                                             *
      *    *-----------------------------------------------------------*
       det-mdf-des-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-mdf-des-ele      .
      *              *-------------------------------------------------*
      *              * Test preliminari                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se la descrizione e' invariata : ad uscita  *
      *                  *---------------------------------------------*
           if        w-tes-des-int (1)    =    w-tes-des-int (2)
                     go to det-mdf-des-900.
       det-mdf-des-100.
      *              *-------------------------------------------------*
      *              * Start su file [aaf]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "PRFMFN    "         to   f-key                  .
           move      01                   to   rf-aaf-tip-mag         .
           move      w-tes-num-pro        to   rf-aaf-num-pro         .
           move      spaces               to   rf-aaf-fda-pif         .
           move      zero                 to   rf-aaf-cod-dcf         .
           move      "pgm/dcf/fls/ioc/obj/iofaaf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-aaf                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-mdf-des-900.
       det-mdf-des-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [aaf]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcf/fls/ioc/obj/iofaaf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-aaf                 .
      *                  *---------------------------------------------*
      *                  * Test se 'at end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-mdf-des-600.
       det-mdf-des-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-aaf-tip-mag       not  = 01            or
                     rf-aaf-num-pro       not  = w-tes-num-pro
                     go to det-mdf-des-600.
       det-mdf-des-400.
      *              *-------------------------------------------------*
      *              * Selezioni sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se si sta trattando il fornitore preferen-  *
      *                  * ziale : selezione non superata              *
      *                  *---------------------------------------------*
           if        w-prs-sna-igs-aaf    =    "S"  and
                     rf-aaf-cod-dcf       =    w-tes-dcf-pfz (1)
                     go to det-mdf-des-200.
       det-mdf-des-420.
      *                  *---------------------------------------------*
      *                  * Se la descrizione per il fornitore e' a     *
      *                  * spazi : selezione non superata              *
      *                  *---------------------------------------------*
           if        rf-aaf-dep-sfn       =    spaces
                     go to det-mdf-des-200.
       det-mdf-des-440.
      *                  *---------------------------------------------*
      *                  * Se la descrizione per il fornitore esubera  *
      *                  * i 40 caratteri : selezione non superata     *
      *                  *---------------------------------------------*
           if        rf-aaf-xdp-sfn       not  = zero
                     go to det-mdf-des-200.
       det-mdf-des-460.
      *                  *---------------------------------------------*
      *                  * Lettura record anagrafica commerciale del   *
      *                  * fornitore per il codice lingua              *
      *                  *---------------------------------------------*
           move      rf-aaf-cod-dcf       to   w-let-arc-dcf-fnt      .
           move      spaces               to   w-let-arc-dcf-dpz      .
           perform   let-arc-dcf-000      thru let-arc-dcf-999        .
           if        w-let-arc-dcf-flg    not  = spaces
                     go to det-mdf-des-200.
           if        w-let-arc-dcf-lng    not  = "I  "
                     go to det-mdf-des-200.
       det-mdf-des-500.
      *              *-------------------------------------------------*
      *              * Incremento contatore elementi letti             *
      *              *-------------------------------------------------*
           add       1                    to   w-det-mdf-des-ele      .
           if        w-det-mdf-des-ele    >    w-det-mdf-des-max
                     subtract 1           from w-det-mdf-des-ele
                     go to det-mdf-des-600.
      *              *-------------------------------------------------*
      *              * Bufferizzazione elemento letto                  *
      *              *-------------------------------------------------*
           move      rf-aaf-tip-mag       to   w-det-mdf-des-tip
                                              (w-det-mdf-des-ele)     .
           move      rf-aaf-num-pro       to   w-det-mdf-des-pro
                                              (w-det-mdf-des-ele)     .
           move      rf-aaf-cod-dcf       to   w-det-mdf-des-dcf
                                              (w-det-mdf-des-ele)     .
           move      rf-aaf-fda-pif       to   w-det-mdf-des-fda
                                              (w-det-mdf-des-ele)     .
      *              *-------------------------------------------------*
      *              * A riciclo                                       *
      *              *-------------------------------------------------*
           go to     det-mdf-des-200.
       det-mdf-des-600.
      *              *-------------------------------------------------*
      *              * Test su contatore elementi letti                *
      *              *-------------------------------------------------*
           if        w-det-mdf-des-ele    =    zero
                     go to det-mdf-des-900.
       det-mdf-des-650.
      *              *-------------------------------------------------*
      *              * Box per richiesta di variazione                 *
      *              *-------------------------------------------------*
           perform   box-mdf-des-000      thru box-mdf-des-999        .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda della risposta         *
      *                  *---------------------------------------------*
           if        w-exp-mdf-des-sce    not  = 01
                     go to det-mdf-des-900.
       det-mdf-des-800.
      *              *-------------------------------------------------*
      *              * Se richiesta la variazione                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ciclo di update elementi bufferizzati       *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-mdf-des-ctr      .
       det-mdf-des-820.
           add       1                    to   w-det-mdf-des-ctr      .
           if        w-det-mdf-des-ctr    >    w-det-mdf-des-ele
                     go to det-mdf-des-900.
           if        w-det-mdf-des-ctr    >    w-det-mdf-des-max
                     go to det-mdf-des-900.
      *                  *---------------------------------------------*
      *                  * Lettura, con lock, del record               *
      *                  *---------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "PRFNFM    "         to   f-key                  .
           move      w-det-mdf-des-tip
                    (w-det-mdf-des-ctr)   to   rf-aaf-tip-mag         .
           move      w-det-mdf-des-pro
                    (w-det-mdf-des-ctr)   to   rf-aaf-num-pro         .
           move      w-det-mdf-des-dcf
                    (w-det-mdf-des-ctr)   to   rf-aaf-cod-dcf         .
           move      w-det-mdf-des-fda
                    (w-det-mdf-des-ctr)   to   rf-aaf-fda-pif         .
           move      "pgm/dcf/fls/ioc/obj/iofaaf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-aaf                 .
      *                      *-----------------------------------------*
      *                      * Test su esito della lettura             *
      *                      *-----------------------------------------*
           if        f-sts                =    e-not-err
                     go to det-mdf-des-860.
       det-mdf-des-840.
      *                  *---------------------------------------------*
      *                  * Se record [aaf] non esistente               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * A riciclo                               *
      *                      *-----------------------------------------*
           go to     det-mdf-des-820.
       det-mdf-des-860.
      *                  *---------------------------------------------*
      *                  * Se record [aaf] esistente                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Aggiornamento dati nel record           *
      *                      *-----------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rf-aaf-ide-dat         .
           move      s-ute                to   rf-aaf-ide-ute         .
           move      s-fas                to   rf-aaf-ide-fas         .
           move      w-tes-des-int (1)    to   rf-aaf-dep-sfn         .
      *                      *-----------------------------------------*
      *                      * Update record                           *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/dcf/fls/ioc/obj/iofaaf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-aaf                 .
      *                      *-----------------------------------------*
      *                      * Release                                 *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/dcf/fls/ioc/obj/iofaaf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-aaf                 .
      *                      *-----------------------------------------*
      *                      * A riciclo                               *
      *                      *-----------------------------------------*
           go to     det-mdf-des-820.
       det-mdf-des-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-mdf-des-999.
       det-mdf-des-999.
           exit.

