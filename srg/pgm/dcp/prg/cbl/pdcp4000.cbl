           if        f-sts                not  = e-not-err
                     move  all "."        to   rf-zls-des-lst         .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione e valuta    *
      *                      *-----------------------------------------*
           move      rf-zls-des-lst       to   w-ref-acc-lst-des
                                              (w-ref-acc-lst-c01)     .
           move      rf-zls-cod-vlt       to   w-ref-acc-lst-vlt
                                              (w-ref-acc-lst-c01)     .
       rou-acc-lst-230.
      *                  *---------------------------------------------*
      *                  * Prezzo listino da aggiornare                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione                         *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
      *                      *-----------------------------------------*
      *                      * Lettura listino                         *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "LSTPRO    "         to   f-key                  .
           move      01                   to   rf-lst-tip-rec         .
           move      w-ref-acc-lst-cod
                    (w-ref-acc-lst-c01)   to   rf-lst-cod-lst         .
           move      zero                 to   rf-lst-cod-cli         .
           move      w-ref-acc-lst-vlt
                    (w-ref-acc-lst-c01)   to   rf-lst-sgl-vlt         .
           move      w-tes-num-pro        to   rf-lst-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione prezzo                  *
      *                      *-----------------------------------------*
           move      rf-lst-prz-lst       to   w-ref-acc-lst-pra
                                              (w-ref-acc-lst-c01)     .
       rou-acc-lst-240.
      *                  *---------------------------------------------*
      *                  * Calcolo eventuale nuovo prezzo              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Prezzo attuale in prezzo nuovo          *
      *                      *-----------------------------------------*
           move      w-ref-acc-lst-pra
                    (w-ref-acc-lst-c01)   to   w-ref-acc-lst-prn
                                              (w-ref-acc-lst-c01)     .
      *                      *-----------------------------------------*
      *                      * Eventuale default                       *
      *                      *                                         *
      *                      * N.B.: Il default deve essere relativo   *
      *                      *       al codice listino di riferimento  *
      *                      *       indicato dalla referenza. Per     *
      *                      *       convenzione, attualmente su usa   *
      *                      *       solo il listino base, anche se    *
      *                      *       indicato diversamente             *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se listino base variato        *
      *                          *-------------------------------------*
           if        w-tes-prz-lst (1)    not  = w-tes-prz-lst (2)
                     go to rou-acc-lst-245.
      *                          *-------------------------------------*
      *                          * Test se inserimento                 *
      *                          *-------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to rou-acc-lst-280.
       rou-acc-lst-245.
      *                          *-------------------------------------*
      *                          * Test su tipo aggiornamento          *
      *                          *-------------------------------------*
           if        w-ref-acc-lst-spr
                    (w-ref-acc-lst-c01)   =    "+"
                     go to rou-acc-lst-250
           else if   w-ref-acc-lst-spr
                    (w-ref-acc-lst-c01)   =    "-"
                     go to rou-acc-lst-260
           else      go to rou-acc-lst-280.
       rou-acc-lst-250.
      *                          *-------------------------------------*
      *                          * Se aumento                          *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Listino base in comodo          *
      *                              *---------------------------------*
           move      w-tes-prz-lst (1)    to   w-det-new-prz-new      .
      *                              *---------------------------------*
      *                              * Calcolo                         *
      *                              *---------------------------------*
           move      100,0                to   w-det-new-prz-coe      .
           add       w-ref-acc-lst-per
                    (w-ref-acc-lst-c01)   to   w-det-new-prz-coe      .
           multiply  w-det-new-prz-coe    by   w-det-new-prz-new      .
           divide    100                  into w-det-new-prz-new      .
           move      w-det-new-prz-new    to   w-ref-acc-lst-prn
                                              (w-ref-acc-lst-c01)     .
      *                              *---------------------------------*
      *                              * A riciclo                       *
      *                              *---------------------------------*
