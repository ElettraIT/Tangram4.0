      *    *===========================================================*
      *    * Accettazione campo : Chiave libera                        *
      *    *-----------------------------------------------------------*
       acc-klb-pro-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-snx-gbc-sng    not  = "S"
                     go to acc-klb-pro-999.
       acc-klb-pro-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      68                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "NXSC"               to   v-pfk (08)             .
           if        w-tes-klb-pro (1)    =    spaces
                     move  "[1] "         to   v-pfk (14)             .
           move      w-tes-klb-pro (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-klb-pro-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-klb-pro-999.
       acc-klb-pro-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-klb-pro (1)      .
       acc-klb-pro-300.
      *              *-------------------------------------------------*
      *              * Se Pf1                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale forzatura creazione barcode, se   *
      *                  * previsto da apposita personalizzazione      *
      *                  *---------------------------------------------*
           if        w-prs-snx-gbc-sng    not  = "S"
                     go to acc-klb-pro-400.
           if        w-prs-snx-gbc-sni    not  = "S"
                     go to acc-klb-pro-320.
      *                  *---------------------------------------------*
      *                  * Solo se inserimento                         *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-klb-pro-320.
      *                  *---------------------------------------------*
      *                  * Solo se valore a spaces                     *
      *                  *---------------------------------------------*
           if        w-tes-klb-pro (1)    not  = spaces
                     go to acc-klb-pro-320.
      *                  *---------------------------------------------*
      *                  * A generazione automatica barcode            *
      *                  *---------------------------------------------*
           go to     acc-klb-pro-340.
       acc-klb-pro-320.
      *                  *---------------------------------------------*
      *                  * Test se Pf1                                 *
      *                  *---------------------------------------------*
           if        v-key                not  = "[1] "
                     go to acc-klb-pro-400.
       acc-klb-pro-340.
      *                  *---------------------------------------------*
      *                  * Assemblaggio del codice prodotto con il     *
      *                  * prefisso per codici EAN ed aggiunta del     *
      *                  * check digit                                 *
      *                  *---------------------------------------------*
           perform   acc-klb-pro-ean-000  thru acc-klb-pro-ean-999    .
      *                  *---------------------------------------------*
      *                  * Visualizzazione codice ottenuto             *
      *                  *---------------------------------------------*
           perform   vis-klb-pro-000      thru vis-klb-pro-999        .
       acc-klb-pro-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se a spaces                            *
      *                  *---------------------------------------------*
           if        w-tes-klb-pro (1)    =    spaces
                     go to acc-klb-pro-600.
      *                  *---------------------------------------------*
      *                  * Test che non ci siano blanks embedded       *
      *                  *---------------------------------------------*
           move      w-tes-klb-pro (1)    to   w-all-str-alf          .
           move      13                   to   w-all-str-lun          .
           perform   all-str-ble-000      thru all-str-ble-999        .
           if        w-all-str-flg        not  = spaces
                     go to acc-klb-pro-100.
      *                  *---------------------------------------------*
      *                  * Controllo che il valore impostato sia uni-  *
      *                  * co in archivio                              *
      *                  *---------------------------------------------*
           move      w-tes-num-pro        to   w-ctl-uni-klb-num      .
           move      w-tes-klb-pro (1)    to   w-ctl-uni-klb-alf      .
           perform   ctl-uni-klb-000      thru ctl-uni-klb-999        .
           if        w-ctl-uni-klb-flg    =    spaces
                     go to acc-klb-pro-600.
      *                  *---------------------------------------------*
      *                  * Se controllo non superato                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Codice a barre gia' utilizzato !"
                                          to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Si prosegue comunque                    *
      *                      *-----------------------------------------*
           go to     acc-klb-pro-600.
       acc-klb-pro-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-klb-pro-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-klb-pro-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-klb-pro-100.
       acc-klb-pro-999.
           exit.

