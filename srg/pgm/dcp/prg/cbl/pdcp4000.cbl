           else if   w-tes-tip-ubi-pdu (1)
                                          =    04
                     go to cnt-tdo-nok-mau-340
           else      go to cnt-tdo-nok-mau-500.
       cnt-tdo-nok-mau-310.
           if        w-tes-prm-ubi (1, 1) not  = spaces
                     go to cnt-tdo-nok-mau-500.
           move      "Manca il parametro 1 per l'ubicazione !           
