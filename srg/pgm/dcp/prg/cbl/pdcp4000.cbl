           move      "Tipo di acquisizione non modificabile !"
                                          to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-300.
      *                  *---------------------------------------------*
      *                  * Data rilevamento status                     *
      *                  *---------------------------------------------*
           if        w-tes-sta-tus (1)    =    01 or
                     w-tes-sta-tus (1)    =    99
                     go to cnt-tdo-nok-305.
           if        w-tes-sta-tud (1)    not  = zero
                     go to cnt-tdo-nok-305.
           move      "Manca la data di rilevamento dello status !       
      -              "          "         to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-305.
      *                  *---------------------------------------------*
      *                  * Codice prodotto di riferimento              *
      *                  *---------------------------------------------*
           if        w-tes-sta-tus (1)    not  = 21  and
                     w-tes-sta-tus (1)    not  = 52  and
                     w-tes-sta-tus (1)    not  = 72
                     go to cnt-tdo-nok-320.
           if        w-tes-sta-tuc (1)    =    zero
                     go to cnt-tdo-nok-310.
           move      w-tes-sta-tuc (1)    to   w-let-arc-dcp-num      .
           perform   let-arc-dcp-000      thru let-arc-dcp-999        .
           if        w-let-arc-dcp-flg    =    spaces
                     go to cnt-tdo-nok-320.
           move      "Codice Prodotto di riferimento non esistente !    
      -              "          "         to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-310.
           move      "Manca il codice Prodotto di riferimento !         
      -              "          "         to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-320.
      *              *-------------------------------------------------*
      *              * Controllo su Codice marketing                   *
      *              *-------------------------------------------------*
           if        w-tes-cod-mkt (1)    =    zero
                     go to cnt-tdo-nok-340.
           move      03                   to   w-let-arc-zkc-tip      .
           move      w-tes-cod-mkt (1)    to   w-let-arc-zkc-cod      .
           perform   let-arc-zkc-000      thru let-arc-zkc-999        .
           if        w-let-arc-zkc-flg    =    spaces
                     go to cnt-tdo-nok-340.
           move      "Codice Marketing non esistente !                  
      -              "          "         to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-340.
      *              *-------------------------------------------------*
      *              * Controllo su '...'                              *
      *              *-------------------------------------------------*
       cnt-tdo-nok-500.
      *              *-------------------------------------------------*
      *              * Normalizzazioni                                 *
      *              *-------------------------------------------------*
       cnt-tdo-nok-505.
