      *                      *-----------------------------------------*
           if        w-tes-des-lst (1)    not  = w-tes-des-doc (1)
                     go to cnt-tdo-nok-lst-500.
           move      "Descrizione per listini uguale a quella per i docu
      -              "menti "             to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-lst-900.
