      *    *===========================================================*
      *    * Ricerca su buffer prodotti inseriti o modificati          *
      *    *-----------------------------------------------------------*
       buf-pro-iom-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valori di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-buf-pro-iom-fds      .
           move      zero                 to   w-buf-pro-iom-pro      .
      *              *-------------------------------------------------*
      *              * Normalizzazioni iniziali                        *
      *              *-------------------------------------------------*
           move      zero                 to   w-buf-pro-iom-crb      .
       buf-pro-iom-100.
      *              *-------------------------------------------------*
      *              * Start su [dcp]                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start                                       *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "DATSYS    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      w-buf-pro-iom-drc    to   rf-dcp-ide-dat         .
           move      zero                 to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *                  *---------------------------------------------*
      *                  * Se errore di start : uscita                 *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     move  "#"            to   w-buf-pro-iom-fds
                     go to  buf-pro-iom-999.
       buf-pro-iom-200.
      *              *-------------------------------------------------*
      *              * Lettura [dcp]                                   *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *                  *---------------------------------------------*
      *                  * Se at end : a controllo contatore           *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to buf-pro-iom-500.
       buf-pro-iom-300.
      *              *-------------------------------------------------*
      *              * Se oltre il massimo : a controllo contatore     *
      *              *-------------------------------------------------*
           if        rf-dcp-ide-dat       not  = w-buf-pro-iom-drc
                     go to buf-pro-iom-500.
       buf-pro-iom-400.
      *              *-------------------------------------------------*
      *              * Selezioni su [dcp]                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice utente                       *
      *                  *---------------------------------------------*
           if        rf-dcp-ide-ute       not  = w-buf-pro-iom-ute
                     go to buf-pro-iom-200.
       buf-pro-iom-410.
      *              *-------------------------------------------------*
      *              * Incremento numero records nel buffer            *
      *              *-------------------------------------------------*
           add       1                    to   w-buf-pro-iom-crb      .
      *              *-------------------------------------------------*
      *              * Test se buffer oltre il numero previsto         *
      *              *-------------------------------------------------*
           if        w-buf-pro-iom-crb    >    w-buf-pro-iom-max
                     move  w-buf-pro-iom-max
                                          to   w-buf-pro-iom-crb
                     go to buf-pro-iom-500.
       buf-pro-iom-420.
      *              *-------------------------------------------------*
      *              * Bufferizzazione                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Codice alfanumerico prodotto                *
      *                  *---------------------------------------------*
           move      rf-dcp-alf-pro       to   w-buf-pro-iom-bal
                                              (w-buf-pro-iom-crb)     .
      *                  *---------------------------------------------*
      *                  * Codice numerico prodotto                    *
      *                  *---------------------------------------------*
           move      rf-dcp-num-pro       to   w-buf-pro-iom-bnu
                                              (w-buf-pro-iom-crb)     .
      *                  *---------------------------------------------*
      *                  * Descrizione prodotto                        *
      *                  *---------------------------------------------*
           move      rf-dcp-des-pro       to   w-buf-pro-iom-bde
                                              (w-buf-pro-iom-crb)     .
      *                  *---------------------------------------------*
      *                  * Riciclo a lettura                           *
      *                  *---------------------------------------------*
           go to     buf-pro-iom-200.
       buf-pro-iom-500.
      *                  *---------------------------------------------*
      *                  * Controllo numero records letti con lo stes- *
      *                  * so valore                                   *
      *                  *---------------------------------------------*
           if        w-buf-pro-iom-crb    =    zero
                     go to buf-pro-iom-999.
      *                      *-----------------------------------------*
      *                      * Determinazione numero pagine nel buffer *
      *                      *-----------------------------------------*
           move      w-buf-pro-iom-crb    to   w-buf-pro-iom-cpb      .
           subtract  1                    from w-buf-pro-iom-cpb      .
           divide    6                    into w-buf-pro-iom-cpb      .
           add       1                    to   w-buf-pro-iom-cpb      .
      *                      *-----------------------------------------*
      *                      * Inizializzazione numero record nel buf- *
      *                      * fer attualmente trattato                *
      *                      *-----------------------------------------*
           move      1                    to   w-buf-pro-iom-c01      .
      *                      *-----------------------------------------*
      *                      * Salvataggio immagine video              *
      *                      *-----------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Video in Off                            *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione box vuoto               *
      *                      *-----------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      04                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      15                   to   v-lto                  .
           move      72                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Editing data                            *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      w-buf-pro-iom-drc    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Preparazione fincatura                  *
      *                      *-----------------------------------------*
           move      60                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
           move      "PRODOTTI INSERITI O MODIFICATI"
                                          to   w-all-str-cat (1)      .
      *
           move      w-buf-pro-iom-drc    to   s-dat                  .
           if        s-gio                =    01 or
                     s-gio                =    08 or
                     s-gio                =    11
                     move  "L'"           to   w-all-str-cat (2)
           else      move  "IL"           to   w-all-str-cat (2)      .
      *
           move      v-edt                to   w-all-str-cat (3)      .
           move      "DA ["               to   w-all-str-cat (4)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *
           move      03                   to   w-all-str-num          .
           move      w-all-str-alf        to   w-all-str-cat (1)      .
           move      w-buf-pro-iom-ute    to   w-all-str-cat (2)      .
           move      "]"                  to   w-all-str-cat (3)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *
           perform   all-str-cen-000      thru all-str-cen-999        .
      *                      *-----------------------------------------*
      *                      * Fincatura                               *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      11                   to   v-pos                  .
           move      w-all-str-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Sottolineatura fincatura                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      11                   to   v-pos                  .
           move      all   "-"            to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Sottolineatura di chiusura              *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      11                   to   v-pos                  .
           move      all   "-"            to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione pagina video contenente *
      *                      * il record attualmente trattato          *
      *                      *-----------------------------------------*
           perform   buf-pro-iom-950      thru buf-pro-iom-959        .
      *                      *-----------------------------------------*
      *                      * Video in On                             *
      *                      *-----------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       buf-pro-iom-550.
      *                      *-----------------------------------------*
      *                      * Determinazione numero linea a video     *
      *                      *-----------------------------------------*
           move      w-buf-pro-iom-c01    to   w-buf-pro-iom-nli      .
       buf-pro-iom-555.
           if        w-buf-pro-iom-nli    >    6
                     subtract  6          from w-buf-pro-iom-nli
                     go to buf-pro-iom-555.
      *                          *-------------------------------------*
      *                          * Incremento numero linea a video     *
      *                          * per posizionamento verticale        *
      *                          *-------------------------------------*
           add       06                   to   w-buf-pro-iom-nli      .
       buf-pro-iom-560.
      *                      *-----------------------------------------*
      *                      * Espansione record attualmente trattato  *
      *                      *-----------------------------------------*
       buf-pro-iom-575.
      *                      *-----------------------------------------*
      *                      * Accettazione del mark-point             *
      *                      *-----------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      spaces               to   v-ufk                  .
           if        w-buf-pro-iom-c01    >    1
                     move  "UP  "         to   v-pfk (01)             .
           if        w-buf-pro-iom-c01    <    w-buf-pro-iom-crb
                     move  "DOWN"         to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           if        w-buf-pro-iom-cpa    >    1
                     move  "PRSC"         to   v-pfk (07)             .
           if        w-buf-pro-iom-cpa    <    w-buf-pro-iom-cpb
                     move  "NXSC"         to   v-pfk (08)             .
           move      "SLCT"               to   v-pfk (10)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-buf-pro-iom-nli    to   v-lin                  .
           move      11                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       buf-pro-iom-580.
           if        v-key                =    spaces or
                     v-key                =    "DO  " or
                     v-key                =    "SLCT"
                     go to buf-pro-iom-582
           else if   v-key                =    "UP  "
                     go to buf-pro-iom-584
           else if   v-key                =    "DOWN"
                     go to buf-pro-iom-586
           else if   v-key                =    "EXIT"
                     go to buf-pro-iom-598
           else if   v-key                =    "NXSC"
                     go to buf-pro-iom-592
           else if   v-key                =    "PRSC"
                     go to buf-pro-iom-594
           else      go to buf-pro-iom-575.
       buf-pro-iom-582.
      *              *-------------------------------------------------*
      *              * Se spaces, Do o select                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Restore video                               *
      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Memorizzazione valori selezionati           *
      *                  *---------------------------------------------*
           move      w-buf-pro-iom-bnu
                    (w-buf-pro-iom-c01)   to   w-buf-pro-iom-pro      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     buf-pro-iom-999.
       buf-pro-iom-584.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           subtract  1                    from w-buf-pro-iom-c01      .
           if        w-buf-pro-iom-nli    =    07
                     go to buf-pro-iom-590
           else      go to buf-pro-iom-550.
       buf-pro-iom-586.
      *              *-------------------------------------------------*
      *              * Se Down                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Trattamento contatore linee                 *
      *                  *---------------------------------------------*
           if        w-buf-pro-iom-c01    <    w-buf-pro-iom-crb
                     add   1              to   w-buf-pro-iom-c01
                     go to buf-pro-iom-588
           else      go to buf-pro-iom-575.
       buf-pro-iom-588.
      *                  *---------------------------------------------*
      *                  * Test se ultima linea                        *
      *                  *---------------------------------------------*
           if        w-buf-pro-iom-nli    =    12
                     go to buf-pro-iom-590
           else      go to buf-pro-iom-550.
       buf-pro-iom-590.
      *                  *---------------------------------------------*
      *                  * Se dall'ultima linea : pagina successiva    *
      *                  *---------------------------------------------*
           perform   buf-pro-iom-950      thru buf-pro-iom-959        .
      *                  *---------------------------------------------*
      *                  * A riaccettazione                            *
      *                  *---------------------------------------------*
           go to     buf-pro-iom-550.
       buf-pro-iom-592.
      *              *-------------------------------------------------*
      *              * Se Next screen                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Trattamento contatore pagine                *
      *                  *---------------------------------------------*
           add       1                    to   w-buf-pro-iom-cpa      .
      *                  *---------------------------------------------*
      *                  * A gestione cambiamento pagina               *
      *                  *---------------------------------------------*
           go to     buf-pro-iom-596.
       buf-pro-iom-594.
      *              *-------------------------------------------------*
      *              * Se Previous screen                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Trattamento contatore pagine                *
      *                  *---------------------------------------------*
           subtract  1                    from w-buf-pro-iom-cpa      .
       buf-pro-iom-596.
      *                  *---------------------------------------------*
      *                  * Gestione cambiamento pagina                 *
      *                  *---------------------------------------------*
           move      w-buf-pro-iom-cpa    to   w-buf-pro-iom-c01      .
           multiply  6                    by   w-buf-pro-iom-c01      .
           subtract  5                    from w-buf-pro-iom-c01      .
      *                  *---------------------------------------------*
      *                  * A cambiamento pagina                        *
      *                  *---------------------------------------------*
           go to     buf-pro-iom-590.
       buf-pro-iom-598.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di selezione                           *
      *                  *---------------------------------------------*
           move      "#"                  to   w-buf-pro-iom-fds      .
      *                  *---------------------------------------------*
      *                  * Restore video                               *
      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     buf-pro-iom-800.
       buf-pro-iom-800.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     buf-pro-iom-999.
       buf-pro-iom-950.
      *              *=================================================*
      *              * Visualizzazione pagina video contenente il re-  *
      *              * cord attualmente trattato                       *
      *              *-------------------------------------------------*
           move      w-buf-pro-iom-c01    to   w-buf-pro-iom-c02      .
           add       5                    to   w-buf-pro-iom-c02      .
           divide    6                    into w-buf-pro-iom-c02      .
           move      w-buf-pro-iom-c02    to   w-buf-pro-iom-cpa      .
           subtract  1                    from w-buf-pro-iom-c02      .
           multiply  6                    by   w-buf-pro-iom-c02      .
           add       1                    to   w-buf-pro-iom-c02      .
           add       5
                     w-buf-pro-iom-c02  giving w-buf-pro-iom-c03      .
           move      w-buf-pro-iom-c03    to   w-buf-pro-iom-c04      .
           if        w-buf-pro-iom-c03    >    w-buf-pro-iom-crb
                     move  w-buf-pro-iom-crb
                                          to   w-buf-pro-iom-c03      .
           move      07                   to   w-buf-pro-iom-c05      .
       buf-pro-iom-951.
      *                  *---------------------------------------------*
      *                  * Codice prodotto                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      w-buf-pro-iom-c05    to   v-lin                  .
           move      11                   to   v-pos                  .
           move      w-buf-pro-iom-bal
                    (w-buf-pro-iom-c02)   to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Descrizione prodotto                        *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      w-buf-pro-iom-c05    to   v-lin                  .
           move      28                   to   v-pos                  .
           move      w-buf-pro-iom-bde
                    (w-buf-pro-iom-c02)   to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Incremento contatori                        *
      *                  *---------------------------------------------*
           add       1                    to   w-buf-pro-iom-c02      .
           add       1                    to   w-buf-pro-iom-c05      .
           if        w-buf-pro-iom-c02    not  > w-buf-pro-iom-c03
                     go to buf-pro-iom-951.
       buf-pro-iom-952.
           if        w-buf-pro-iom-c02    >    w-buf-pro-iom-c04
                     go to buf-pro-iom-955.
           if        w-buf-pro-iom-crb    not  > 6
                     go to buf-pro-iom-955.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      w-buf-pro-iom-c05    to   v-lin                  .
           move      11                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           add       1                    to   w-buf-pro-iom-c02      .
           add       1                    to   w-buf-pro-iom-c05      .
           go to     buf-pro-iom-952.
       buf-pro-iom-955.
      *                  *---------------------------------------------*
      *                  * Literal 'pagina'                            *
      *                  *---------------------------------------------*
           move      w-buf-pro-iom-cpa    to   w-buf-pro-iom-lt1      .
           move      w-buf-pro-iom-cpb    to   w-buf-pro-iom-lt2      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      34                   to   v-pos                  .
           move      w-buf-pro-iom-ltp    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       buf-pro-iom-959.
           exit.
       buf-pro-iom-999.
           exit.

