      *    *===========================================================*
      *    * Composizione file sequenziale in output : Record del pro- *
      *    * dotto                                                     *
      *    *-----------------------------------------------------------*
       cmp-fso-rdp-000.
      *              *-------------------------------------------------*
      *              * Composizione dati a valore variabile            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Codice prodotto per il fornitore            *
      *                  *---------------------------------------------*
           move      rf-dcp-alf-pro       to   w-rdp-cod-pro          .
      *                  *---------------------------------------------*
      *                  * Codice EAN 13                               *
      *                  *---------------------------------------------*
           move      zero                 to   w-rdp-cod-ean          .
      *                  *---------------------------------------------*
      *                  * Descrizione prodotto per il fornitore       *
      *                  *---------------------------------------------*
           move      rf-dcp-des-pro       to   w-rdp-des-pro          .
      *                  *---------------------------------------------*
      *                  * Quantita' cartone                           *
      *                  *---------------------------------------------*
           move      1                    to   w-rdp-qta-crt          .
      *                  *---------------------------------------------*
      *                  * Quantita' interna                           *
      *                  *---------------------------------------------*
           if        rf-dcp-qta-cfz       =    zero
                     move  1              to   w-rdp-qta-int
           else      move  rf-dcp-qta-cfz to   w-rdp-qta-int          .
      *                  *---------------------------------------------*
      *                  * Quantita' minima ordinazione                *
      *                  *---------------------------------------------*
           move      zero                 to   w-rdp-qta-ord          .
      *                  *---------------------------------------------*
      *                  * Quantita' massima ordinazione               *
      *                  *---------------------------------------------*
           move      zero                 to   w-rdp-qta-max          .
      *                  *---------------------------------------------*
      *                  * Lead time                                   *
      *                  * ___ da implementare ___                     *
      *                  *---------------------------------------------*
           move      spaces               to   w-rdp-lea-tim          .
      *                  *---------------------------------------------*
      *                  * Prezzo grossista                            *
      *                  *---------------------------------------------*
           move      w-det-prz-vgr-prz    to   w-rdp-prz-grs          .
      *                  *---------------------------------------------*
      *                  * Prezzo pubblico                             *
      *                  *---------------------------------------------*
           move      w-det-prz-vgr-prz    to   w-rdp-prz-pub          .
      *                  *---------------------------------------------*
      *                  * Unita' di misura                            *
      *                  *---------------------------------------------*
           move      rf-dcp-umi-ven       to   w-rdp-uni-mis          .
      *                  *---------------------------------------------*
      *                  * Prodotto composto                           *
      *                  * ___ da implementare ___                     *
      *                  *---------------------------------------------*
           move      spaces               to   w-rdp-pro-com          .
      *                  *---------------------------------------------*
      *                  * Stato del prodotto                          *
      *                  *---------------------------------------------*
           if        rf-dcp-sta-tus       =    01
                     move  03             to   w-rdp-sts-pro
           else if   rf-dcp-sta-tus       =    11
                     move  02             to   w-rdp-sts-pro
           else if   rf-dcp-sta-tus       =    21
                     move  99             to   w-rdp-sts-pro
           else if   rf-dcp-sta-tus       =    51
                     move  99             to   w-rdp-sts-pro
           else if   rf-dcp-sta-tus       =    52
                     move  99             to   w-rdp-sts-pro
           else if   rf-dcp-sta-tus       =    71
                     move  99             to   w-rdp-sts-pro
           else if   rf-dcp-sta-tus       =    72
                     move  99             to   w-rdp-sts-pro
           else      move  zero           to   w-rdp-sts-pro          .
      *                  *---------------------------------------------*
      *                  * Codice famiglia di sconto                   *
      *                  * ___ da implementare ___                     *
      *                  *---------------------------------------------*
           move      spaces               to   w-rdp-cod-fsc          .
      *                  *---------------------------------------------*
      *                  * Codice famiglia statistica                  *
      *                  * ___ da implementare ___                     *
      *                  *---------------------------------------------*
           move      spaces               to   w-rdp-cod-fst          .
      *                  *---------------------------------------------*
      *                  * Carattere di fine record                    *
      *                  *---------------------------------------------*
           move      spaces               to   w-rdp-chr-end          .
       cmp-fso-rdp-999.
           exit.

