           if        w-cix-ctr-001        >    10
                     go to wrt-rec-pdx-lst-999.
           if        w-rig-del-rig
                    (w-cix-ctr-001)       =    spaces
                     go to wrt-rec-pdx-lst-900.
      *                  *---------------------------------------------*
