           move      w-lpt-gru-pro-pos    to   w-cod-mne-zp2-pos      .
           move      w-lpt-gru-pro-lin    to   w-cod-mne-zp2-dln      .
           move      w-lpt-gru-pro-pos    to   w-cod-mne-zp2-dps      .
           add       11                   to   w-cod-mne-zp2-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
