      *    *===========================================================*
      *    * Accettazione campo testata : Classe merceologica          *
      *    *-----------------------------------------------------------*
       acc-cla-pro-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cla-pro        to   w-sav-cla-pro          .
      *                  *---------------------------------------------*
      *                  * Test se richiesta sostituzione              *
      *                  *---------------------------------------------*
           if        w-tes-cla-pro-sns    =    zero
                     go to acc-cla-pro-100.
      *                  *---------------------------------------------*
      *                  * Forzatura del tasto Pf1                     *
      *                  *---------------------------------------------*
           move      "[1] "               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * A test su Pf1                               *
      *                  *---------------------------------------------*
           go to     acc-cla-pro-300.
       acc-cla-pro-100.
      *              *-------------------------------------------------*
      *              * Note operative                                  *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           move      "[F1] per sostituzione"
                                          to   v-not                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zp1-ope      .
           move      w-tes-cla-pro        to   w-cod-mne-zp1-cla      .
           move      zero                 to   w-cod-mne-zp1-gru      .
           move      zero                 to   w-cod-mne-zp1-sgr      .
           move      w-lpt-cla-pro-lin    to   w-cod-mne-zp1-lin      .
           move      w-lpt-cla-pro-pos    to   w-cod-mne-zp1-pos      .
           move      w-lpt-cla-pro-lin    to   w-cod-mne-zp1-dln      .
           move      w-lpt-cla-pro-pos    to   w-cod-mne-zp1-dps      .
           add       11                   to   w-cod-mne-zp1-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "[1] "               to   v-pfk (14)             .
           perform   cod-mne-zp1-cll-000  thru cod-mne-zp1-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zp1-foi-000  thru cod-mne-zp1-foi-999    .
       acc-cla-pro-110.
           perform   cod-mne-zp1-cll-000  thru cod-mne-zp1-cll-999    .
           if        w-cod-mne-zp1-ope    =    "F+"
                     go to acc-cla-pro-115.
           if        w-cod-mne-zp1-ope    =    "AC"
                     go to acc-cla-pro-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cla-pro-115.
           perform   cod-mne-zp1-foi-000  thru cod-mne-zp1-foi-999    .
           go to     acc-cla-pro-110.
       acc-cla-pro-120.
           move      w-cod-mne-zp1-cla    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Cancellazione eventuali note operative          *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-cla-pro-999.
       acc-cla-pro-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cla-pro          .
       acc-cla-pro-300.
      *              *-------------------------------------------------*
      *              * Se Pf1                                          *
      *              *-------------------------------------------------*
           if        v-key                not  = "[1] "
                     go to acc-cla-pro-400.
      *                  *---------------------------------------------*
      *                  * Subroutine di accettazione valore sostitu-  *
      *                  * tivo                                        *
      *                  *---------------------------------------------*
           perform   acc-cla-pro-sos-000  thru acc-cla-pro-sos-999    .
           if        w-cnt-tus-acc-key    not  = spaces
                     go to acc-cla-pro-999.
      *                  *---------------------------------------------*
      *                  * Visualizzazione sostituzione effettuata     *
      *                  *---------------------------------------------*
           perform   vis-cla-pro-sos-000  thru vis-cla-pro-sos-999    .
      *                  *---------------------------------------------*
      *                  * Se sostituzione non effettuata ma impostati *
      *                  * valori : rivisualizzazione valori impostati *
      *                  *---------------------------------------------*
           if        w-tes-cla-pro-sns    not  = zero
                     go to acc-cla-pro-800.
      *                  *---------------------------------------------*
      *                  * Visualizzazione codice impostato            *
      *                  *---------------------------------------------*
           perform   vis-cla-pro-000      thru vis-cla-pro-999        .
       acc-cla-pro-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [zp1]                      *
      *                  *---------------------------------------------*
           move      w-tes-cla-pro        to   w-let-arc-zp1-cla      .
           perform   let-arc-zp1-000      thru let-arc-zp1-999        .
      *                   *--------------------------------------------*
      *                   * Bufferizzazione di :                       *
      *                   * - Descrizione                              *
      *                   * - Ulteriore suddivisione                   *
      *                   * - Unita' di misura da proporre             *
      *                   *--------------------------------------------*
           if        w-tes-cla-pro        =    zero
                     move  "Tutte"        to   w-tes-cla-pro-des
           else      move  w-let-arc-zp1-des
                                          to   w-tes-cla-pro-des      .
           move      w-let-arc-zp1-sud    to   w-tes-cla-pro-sud      .
           move      w-let-arc-zp1-mne    to   w-tes-cla-pro-mne      .
      *                   *--------------------------------------------*
      *                   * Visualizzazione descrizione                *
      *                   *--------------------------------------------*
           perform   vis-cla-pro-des-000  thru vis-cla-pro-des-999    .
       acc-cla-pro-450.
      *                  *---------------------------------------------*
      *                  * Controllo con valori letti da filtro        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se codice a zero : nessun controllo     *
      *                      *-----------------------------------------*
           if        w-tes-cla-pro        =    zero
                     go to acc-cla-pro-600.
      *                      *-----------------------------------------*
      *                      * Controllo con codice min                *
      *                      *-----------------------------------------*
           if        w-zos-dcp-cla-min    =    zero
                     go to acc-cla-pro-500.
           if        w-tes-cla-pro        <    w-zos-dcp-cla-min
                     go to acc-cla-pro-550.
       acc-cla-pro-500.
      *                      *-----------------------------------------*
      *                      * Controllo con codice max                *
      *                      *-----------------------------------------*
           if        w-zos-dcp-cla-max    =    zero
                     go to acc-cla-pro-600.
           if        w-tes-cla-pro        >    w-zos-dcp-cla-max
                     go to acc-cla-pro-550.
           go to     acc-cla-pro-600.
       acc-cla-pro-550.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Incompatibilita' con il filtro di selezione !   "
                                          to   w-err-box-err-msg      .
      *                      *-----------------------------------------*
      *                      * Box di errore                           *
      *                      *-----------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
       acc-cla-pro-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore impostato uguale a precedente :   *
      *                  * oltre                                       *
      *                  *---------------------------------------------*
           if        w-tes-cla-pro        =    w-sav-cla-pro
                     go to acc-cla-pro-800.
      *                      *-----------------------------------------*
      *                      * Normalizzazione e visualizzazione dati  *
      *                      * gruppo merceologico                     *
      *                      *-----------------------------------------*
           if        w-tes-gru-pro        =    zero
                     go to acc-cla-pro-620.
           move      zero                 to   w-tes-gru-pro          .
           move      spaces               to   w-tes-gru-pro-des      .
           move      zero                 to   w-tes-gru-pro-sud      .
           perform   vis-gru-pro-000      thru vis-gru-pro-999        .
           perform   vis-gru-pro-des-000  thru vis-gru-pro-des-999    .
       acc-cla-pro-620.
      *                      *-----------------------------------------*
      *                      * Normalizzazione e visualizzazione dati  *
      *                      * sottogruppo merceologico                *
      *                      *-----------------------------------------*
           if        w-tes-sgr-pro        =    zero
                     go to acc-cla-pro-640.
           move      zero                 to   w-tes-sgr-pro          .
           move      spaces               to   w-tes-sgr-pro-des      .
           perform   vis-sgr-pro-000      thru vis-sgr-pro-999        .
           perform   vis-sgr-pro-des-000  thru vis-sgr-pro-des-999    .
       acc-cla-pro-640.
       acc-cla-pro-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-cla-pro-999.
           perform   cnt-key-vuo-000      thru cnt-key-vuo-999        .
           if        w-cnt-key-vuo-flg    not  = spaces
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-cla-pro-999.
           perform   cnt-tdo-key-000      thru cnt-tdo-key-999        .
           if        w-cnt-tdo-key-flg    not  = spaces
                     go to acc-cla-pro-100
           else      move  "S"            to   w-cnt-tus-acc-key
                     go to acc-cla-pro-999.
       acc-cla-pro-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Classe merceologica       *
      *    *-----------------------------------------------------------*
       vis-cla-pro-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-lpt-cla-pro-lin    to   v-lin                  .
           move      w-lpt-cla-pro-pos    to   v-pos                  .
           move      w-tes-cla-pro        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cla-pro-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione classe        *
      *    *-----------------------------------------------------------*
       vis-cla-pro-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      w-lpt-cla-pro-lin    to   v-lin                  .
           move      w-lpt-cla-pro-pos    to   v-pos                  .
           add       11                   to   v-pos                  .
           move      w-tes-cla-pro-des    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cla-pro-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice classe                        *
      *    *                                                           *
      *    * Subroutine di sostituzione                                *
      *    *-----------------------------------------------------------*
       acc-cla-pro-sos-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione segnale di sostituzione     *
      *                  *---------------------------------------------*
           move      zero                 to   w-tes-cla-pro-sns      .
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      w-lpt-cla-pro-lin    to   v-lin                  .
           subtract  1                    from v-lin                  .
           move      w-lpt-cla-pro-pos    to   v-pos                  .
           subtract  1                    from v-pos                  .
           move      w-lpt-cla-pro-lin    to   v-lto                  .
           add       1                    to   v-lto                  .
           move      w-lpt-cla-pro-pos    to   v-pto                  .
           add       50                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cla-pro-sos-010.
      *                  *---------------------------------------------*
      *                  * Prompts per il box                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Valore da sostituire                    *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      15                   to   v-car                  .
           move      w-lpt-cla-pro-lin    to   v-lin                  .
           move      w-lpt-cla-pro-pos    to   v-pos                  .
           move      "Da sostituire :"    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Con                                     *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      w-lpt-cla-pro-lin    to   v-lin                  .
           move      w-lpt-cla-pro-pos    to   v-pos                  .
           add       29                   to   v-pos                  .
           move      "Con :"              to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in 'ON'                               *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cla-pro-sos-100.
      *              *-------------------------------------------------*
      *              * Visualizzazioni                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione valore da sostituire        *
      *                  *---------------------------------------------*
           perform   vis-cla-pro-so1-000  thru vis-cla-pro-so1-999    .
      *                  *---------------------------------------------*
      *                  * Visualizzazione valore sostitutivo          *
      *                  *---------------------------------------------*
           perform   vis-cla-pro-so2-000  thru vis-cla-pro-so2-999    .
       acc-cla-pro-sos-200.
      *              *-------------------------------------------------*
      *              * Accettazioni                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore da sostituire                        *
      *                  *---------------------------------------------*
           perform   acc-cla-pro-so1-000  thru acc-cla-pro-so1-999    .
           if        w-cnt-tus-acc-key    not  = spaces
                     go to acc-cla-pro-sos-600.
           if        v-key                =    "UP  "
                     go to acc-cla-pro-sos-600.
           if        v-key                =    "DOWN"
                     go to acc-cla-pro-sos-600.
       acc-cla-pro-sos-300.
      *                  *---------------------------------------------*
      *                  * Valore sostitutivo                          *
      *                  *---------------------------------------------*
           perform   acc-cla-pro-so2-000  thru acc-cla-pro-so2-999    .
           if        w-cnt-tus-acc-key    not  = spaces
                     go to acc-cla-pro-sos-600.
           if        v-key                =    "UP  "
                     go to acc-cla-pro-sos-200.
       acc-cla-pro-sos-600.
      *              *-------------------------------------------------*
      *              * Controlli su valori accettati                   *
      *              *-------------------------------------------------*
       acc-cla-pro-sos-800.
      *              *-------------------------------------------------*
      *              * Dipendenza dalle impostazioni                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Segnale di sostituzione effettuata          *
      *                  *---------------------------------------------*
           if        w-tes-cla-pro        not  = zero or
                     w-tes-cla-sos        not  = zero
                     move  1              to   w-tes-cla-pro-sns      .
       acc-cla-pro-sos-900.
      *              *-------------------------------------------------*
      *              * Normalizzazione stato di uscita                 *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-key      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-cla-pro-sos-999.
       acc-cla-pro-sos-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice classe                        *
      *    *                                                           *
      *    * Subroutine di visualizzazione sostituzione                *
      *    *-----------------------------------------------------------*
       vis-cla-pro-sos-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del segnale di sostitu-  *
      *              * zione effettuata                                *
      *              *-------------------------------------------------*
           if        w-tes-cla-pro-sns    =    zero
                     go to vis-cla-pro-sos-100
           else      go to vis-cla-pro-sos-500.
       vis-cla-pro-sos-100.
      *              *-------------------------------------------------*
      *              * Se sostituzione non effettuata                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      50                   to   v-car                  .
           move      w-lpt-cla-pro-lin    to   v-lin                  .
           move      w-lpt-cla-pro-pos    to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     vis-cla-pro-sos-900.
       vis-cla-pro-sos-500.
      *              *-------------------------------------------------*
      *              * Se sostituzione effettuata                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing codice da sostituire                *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-tes-cla-pro        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Concatenamento prima parte                  *
      *                  *---------------------------------------------*
           move      spaces               to   w-vis-lit-sos          .
           move      50                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      "( Sostituzione di :"
                                          to   w-all-str-cat (1)      .
           move      v-edt                to   w-all-str-cat (2)      .
           move      "- con :"            to   w-all-str-cat (3)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
           move      w-all-str-alf        to   w-vis-lit-sos          .
      *                  *---------------------------------------------*
      *                  * Editing codice sostitutivo                  *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-tes-cla-sos        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Concatenamento seconda parte                *
      *                  *---------------------------------------------*
           move      50                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      w-vis-lit-sos        to   w-all-str-cat (1)      .
           move      v-edt                to   w-all-str-cat (2)      .
           move      ")"                  to   w-all-str-cat (3)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
           move      w-all-str-alf        to   w-vis-lit-sos          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      50                   to   v-car                  .
           move      w-lpt-cla-pro-lin    to   v-lin                  .
           move      w-lpt-cla-pro-pos    to   v-pos                  .
           move      w-vis-lit-sos        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     vis-cla-pro-sos-900.
       vis-cla-pro-sos-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     vis-cla-pro-sos-999.
       vis-cla-pro-sos-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice classe                        *
      *    *                                                           *
      *    * Subroutine di accettazione valore da sostituire           *
      *    *-----------------------------------------------------------*
       acc-cla-pro-so1-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
