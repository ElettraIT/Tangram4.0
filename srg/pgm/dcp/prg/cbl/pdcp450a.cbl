      *    *===========================================================*
      *    * Routine per invio singolo documento                       *
      *    *                                                           *
      *    * Per reinviare un singolo documento in caso di errata      *
      *    * ricezione da parte del server di posta                    *
      *    *-----------------------------------------------------------*
       rou-swc-srt-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tasto funzione       *
      *              *-------------------------------------------------*
           if        v-key                =   "[1] "
                     go to rou-swc-srt-100
           else if   v-key                =   "[2] "
                     go to rou-swc-srt-200
           else if   v-key                =   "[3] "
                     go to rou-swc-srt-300
           else if   v-key                =   "[4] "
                     go to rou-swc-srt-400
           else      go to rou-swc-srt-900.
       rou-swc-srt-100.
      *              *-------------------------------------------------*
      *              * Tasto funzione [1] - Progressivo filtro         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su switch attuale                      *
      *                  *---------------------------------------------*
           if        w-cnt-acc-flg-sws    =   "P"
                     go to rou-swc-srt-600.
      *                  *---------------------------------------------*
      *                  * Indicatore tipo ordinamento                 *
      *                  *---------------------------------------------*
           move      "P"                  to  w-cnt-acc-flg-sws       .
      *                  *---------------------------------------------*
      *                  * Indicatore ordinamento                      *
      *                  *---------------------------------------------*
           move      "A"                  to  w-cnt-acc-flg-swo       .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     rou-swc-srt-900.
       rou-swc-srt-200.
      *              *-------------------------------------------------*
      *              * Tasto funzione [2] - Codice alfanumerico        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su switch attuale                      *
      *                  *---------------------------------------------*
           if        w-cnt-acc-flg-sws    =   "C"
                     go to rou-swc-srt-600.
      *                  *---------------------------------------------*
      *                  * Indicatore tipo ordinamento                 *
      *                  *---------------------------------------------*
           move      "C"                  to  w-cnt-acc-flg-sws       .
      *                  *---------------------------------------------*
      *                  * Indicatore ordinamento                      *
      *                  *---------------------------------------------*
           move      "A"                  to  w-cnt-acc-flg-swo       .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     rou-swc-srt-900.
       rou-swc-srt-300.
      *              *-------------------------------------------------*
      *              * Tasto funzione [3] - Descrizione                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su switch attuale                      *
      *                  *---------------------------------------------*
           if        w-cnt-acc-flg-sws    =   "D"
                     go to rou-swc-srt-600.
      *                  *---------------------------------------------*
      *                  * Indicatore tipo ordinamento                 *
      *                  *---------------------------------------------*
           move      "D"                  to  w-cnt-acc-flg-sws       .
      *                  *---------------------------------------------*
      *                  * Indicatore ordinamento                      *
      *                  *---------------------------------------------*
           move      "A"                  to  w-cnt-acc-flg-swo       .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     rou-swc-srt-900.
       rou-swc-srt-400.
      *              *-------------------------------------------------*
      *              * Tasto funzione [4] - Merceologia                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su switch attuale                      *
      *                  *---------------------------------------------*
           if        w-cnt-acc-flg-sws    =   "M"
                     go to rou-swc-srt-600.
      *                  *---------------------------------------------*
      *                  * Indicatore tipo ordinamento                 *
      *                  *---------------------------------------------*
           move      "M"                  to  w-cnt-acc-flg-sws       .
      *                  *---------------------------------------------*
      *                  * Indicatore ordinamento                      *
      *                  *---------------------------------------------*
           move      "A"                  to  w-cnt-acc-flg-swo       .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     rou-swc-srt-900.
       rou-swc-srt-600.
      *              *-------------------------------------------------*
      *              * Eventuale inversione ordinamento                *
      *              *-------------------------------------------------*
           if        w-cnt-acc-flg-swo    =    "D"
                     move  "A"            to   w-cnt-acc-flg-swo
           else      move  "D"            to   w-cnt-acc-flg-swo      .
       rou-swc-srt-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     rou-swc-srt-999.
       rou-swc-srt-999.
           exit.

