           move      w-tes-gru-pro        to   w-cod-mne-zp3-gru      .
           move      w-tes-gru-pro-des    to   w-cod-mne-zp3-dgr      .
           move      w-tes-sgr-pro        to   w-cod-mne-zp3-sgr      .
           move      w-lpt-sgr-pro-lin    to   w-cod-mne-zp3-lin      .
           move      w-lpt-sgr-pro-pos    to   w-cod-mne-zp3-pos      .
           move      w-lpt-sgr-pro-lin    to   w-cod-mne-zp3-dln      .
           move      w-lpt-sgr-pro-pos    to   w-cod-mne-zp3-dps      .
           add       11                   to   w-cod-mne-zp3-dps      .
