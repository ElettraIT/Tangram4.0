      *    *===========================================================*
      *    * Accettazione campo selezione : Classe merceologica        *
      *    *-----------------------------------------------------------*
       acc-cla-pro-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio codice classe                   *
      *                  *---------------------------------------------*
           move      rr-cla-pro           to   w-sav-cod-cla          .
       acc-cla-pro-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zp1-ope      .
           move      rr-cla-pro           to   w-cod-mne-zp1-cla      .
           move      zero                 to   w-cod-mne-zp1-gru      .
           move      zero                 to   w-cod-mne-zp1-sgr      .
           move      05                   to   w-cod-mne-zp1-lin      .
           move      30                   to   w-cod-mne-zp1-pos      .
           move      05                   to   w-cod-mne-zp1-dln      .
           move      37                   to   w-cod-mne-zp1-dps      .
           move      "<B"                 to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   cod-mne-zp1-cll-000  thru cod-mne-zp1-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zp1-foi-000  thru cod-mne-zp1-foi-999    .
       acc-cla-pro-110.
           perform   cod-mne-zp1-cll-000  thru cod-mne-zp1-cll-999    .
           if        w-cod-mne-zp1-ope    =    "F+"
                     go to acc-cla-pro-115.
           if        w-cod-mne-zp1-ope    =    "AC"
                     go to acc-cla-pro-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cla-pro-115.
           perform   cod-mne-zp1-foi-000  thru cod-mne-zp1-foi-999    .
           go to     acc-cla-pro-110.
       acc-cla-pro-120.
           move      w-cod-mne-zp1-cla    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-cla-pro-999.
       acc-cla-pro-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   rr-cla-pro             .
       acc-cla-pro-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [zp1]                      *
      *                  *---------------------------------------------*
           move      rr-cla-pro           to   w-let-arc-zp1-cla      .
           perform   let-arc-zp1-000      thru let-arc-zp1-999        .
      *                   *--------------------------------------------*
      *                   * Bufferizzazione di :                       *
      *                   * - Descrizione                              *
      *                   * - Ulteriore suddivisione                   *
      *                   * - Numero di sequenza                       *
      *                   *--------------------------------------------*
           move      w-let-arc-zp1-des    to   rr-cla-pro-des         .
           move      w-let-arc-zp1-sud    to   rr-cla-pro-sud         .
           move      w-let-arc-zp1-sqz    to   rr-cla-pro-sqz         .
      *                   *--------------------------------------------*
      *                   * Visualizzazione descrizione                *
      *                   *--------------------------------------------*
           perform   vis-des-cla-000      thru vis-des-cla-999        .
      *                  *---------------------------------------------*
      *                  * Se lettura errata : reimpostazione          *
      *                  *---------------------------------------------*
           if        w-let-arc-zp1-flg    not  = spaces
                     go to acc-cla-pro-100.
       acc-cla-pro-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del valore           *
      *                  *---------------------------------------------*
           if        rr-cla-pro           =    zero
                     go to acc-cla-pro-625
           else      go to acc-cla-pro-650.
       acc-cla-pro-625.
      *                  *---------------------------------------------*
      *                  * Se codice classe a zero                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione e visualizzazione se    *
      *                      * necessario del gruppo e del sottogruppo *
      *                      *-----------------------------------------*
           if        rr-gru-pro           =    zero
                     go to acc-cla-pro-630.
           move      zero                 to   rr-gru-pro             .
           move      spaces               to   rr-gru-pro-des         .
           move      zero                 to   rr-gru-pro-sud         .
           move      zero                 to   rr-gru-pro-sqz         .
           perform   vis-gru-pro-000      thru vis-gru-pro-999        .
           perform   vis-des-gru-000      thru vis-des-gru-999        .
       acc-cla-pro-630.
           if        rr-sgr-pro           =    zero
                     go to acc-cla-pro-635.
           move      zero                 to   rr-sgr-pro             .
           move      spaces               to   rr-sgr-pro-des         .
           move      zero                 to   rr-sgr-pro-sud         .
           move      zero                 to   rr-sgr-pro-sqz         .
           perform   vis-sgr-pro-000      thru vis-sgr-pro-999        .
           perform   vis-des-sgr-000      thru vis-des-sgr-999        .
       acc-cla-pro-635.
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     acc-cla-pro-800.
       acc-cla-pro-650.
      *                  *---------------------------------------------*
      *                  * Se codice classe a non zero                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se il codice classe e' variato rispetto *
      *                      * al valore precedente si normalizzano e  *
      *                      * visualizzano, se necessario, il gruppo  *
      *                      * ed il sottogruppo                       *
      *                      *-----------------------------------------*
           if        rr-cla-pro           not  = w-sav-cod-cla
                     go to acc-cla-pro-625.
      *                      *-----------------------------------------*
      *                      * Se il codice classe non e' ulteriormen- *
      *                      * te suddiviso in gruppi si normalizzano  *
      *                      * e visualizzano, se necessario, il grup- *
      *                      * po ed il sottogruppo                    *
      *                      *-----------------------------------------*
           if        rr-cla-pro-sud       not  = 02
                     go to acc-cla-pro-625.
      *                      *-----------------------------------------*
      *                      * Altrimenti nessuna azione e continua-   *
      *                      * zione                                   *
      *                      *-----------------------------------------*
           go to     acc-cla-pro-800.
       acc-cla-pro-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-cla-pro-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-cla-pro-100.
       acc-cla-pro-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo selezione : Classe merceologica     *
      *    *-----------------------------------------------------------*
       vis-cla-pro-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      rr-cla-pro           to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cla-pro-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo selezione : Descrizione classe      *
      *    *-----------------------------------------------------------*
       vis-des-cla-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      rr-cla-pro-des       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-cla-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo selezione : Gruppo merceologico        *
      *    *-----------------------------------------------------------*
       acc-gru-pro-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-gru-pro-025.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se codice classe a zero : no accetta-   *
      *                      * zione                                   *
      *                      *-----------------------------------------*
           if        rr-cla-pro           =    zero
                     go to acc-gru-pro-999.
      *                      *-----------------------------------------*
      *                      * Se classe non suddivisa : no accetta-   *
      *                      * zione                                   *
      *                      *-----------------------------------------*
           if        rr-cla-pro-sud       not  = 02
                     go to acc-gru-pro-999.
       acc-gru-pro-050.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      rr-gru-pro           to   w-sav-cod-gru          .
       acc-gru-pro-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zp2-ope      .
           move      rr-cla-pro           to   w-cod-mne-zp2-cla      .
           move      rr-cla-pro-des       to   w-cod-mne-zp2-dcl      .
           move      rr-gru-pro           to   w-cod-mne-zp2-gru      .
           move      zero                 to   w-cod-mne-zp2-sgr      .
           move      07                   to   w-cod-mne-zp2-lin      .
           move      30                   to   w-cod-mne-zp2-pos      .
