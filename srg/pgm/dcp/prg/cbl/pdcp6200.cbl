           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      w-lin-pri-lin-vid    to   v-lin                  .
           add       w-lin-num-lin-vis    to   v-lin                  .
           add       1                    to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-rig-des-pro (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
