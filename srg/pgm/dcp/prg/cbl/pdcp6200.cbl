      *                  * Numero decimali della valuta                *
      *                  *---------------------------------------------*
           move      c-dec                to   rf-lsd-dec-vlt         .
      *                  *---------------------------------------------*
      *                  * Codice prodotto numerico                    *
      *                  *---------------------------------------------*
           move      w-rig-num-pro (2)    to   rf-lsd-num-pro         .
      *                  *---------------------------------------------*
      *                  * Prezzo                                      *
      *                  *---------------------------------------------*
           move      w-rig-prz-lst (2)    to   rf-lsd-prz-lst         .
      *                  *---------------------------------------------*
      *                  * Categoria provvigioni                       *
      *                  *---------------------------------------------*
           move      w-rig-cat-pvg (1)    to   rf-lsd-cat-pvg         .
      *                  *---------------------------------------------*
      *                  * % di provvigione associate direttamente al  *
      *                  * listino                                     *
      *                  *---------------------------------------------*
           move      w-rig-per-pvg (2, 1) to   rf-lsd-per-pvg (1)     .
           move      w-rig-per-pvg (2, 2) to   rf-lsd-per-pvg (2)     .
           move      w-rig-per-pvg (2, 3) to   rf-lsd-per-pvg (3)     .
      *                  *---------------------------------------------*
      *                  * Categoria sconto                            *
      *                  *---------------------------------------------*
           move      w-rig-cat-sco (1)    to   rf-lsd-cat-sco         .
      *                  *---------------------------------------------*
      *                  * % di sconto associate direttamente al li-   *
      *                  * stino                                       *
      *                  *---------------------------------------------*
           move      w-rig-per-sco (2, 1) to   rf-lsd-per-sco (1)     .
           move      w-rig-per-sco (2, 2) to   rf-lsd-per-sco (2)     .
           move      w-rig-per-sco (2, 3) to   rf-lsd-per-sco (3)     .
           move      w-rig-per-sco (2, 4) to   rf-lsd-per-sco (4)     .
           move      w-rig-per-sco (2, 5) to   rf-lsd-per-sco (5)     .
      *                  *---------------------------------------------*
      *                  * Si/no utilizzo del prezzo                   *
      *                  *---------------------------------------------*
           move      w-rig-snx-prz (2)    to   rf-lsd-snx-prz         .
      *                  *---------------------------------------------*
      *                  * Si/no utilizzo delle % di provvigione       *
      *                  *---------------------------------------------*
