      *                  *---------------------------------------------*
      *                  * Visualizzazione campo                       *
      *                  *---------------------------------------------*
           move      spaces               to   w-edt-per-pvg          .
           move      zero                 to   w-cix-ctr-001          .
       vis-per-pvg-200.
           add       1                    to   w-cix-ctr-001          .
           if        w-cix-ctr-001        >    03
                     go to vis-per-pvg-500.
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      w-rig-per-pvg 
                    (1, w-cix-ctr-001)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-edt-ppv-ele
                                              (w-cix-ctr-001)         .
           go to     vis-per-pvg-200.
       vis-per-pvg-500.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      14                   to   v-car                  .
      *
           move      w-lin-pri-lin-vid    to   v-lin                  .
           add       w-lin-num-lin-vis    to   v-lin                  .
           if        w-prs-tfu-pcp        =    zero
                     add   5              to   v-lin
           else      add   6              to   v-lin                  .
      *
           move      57                   to   v-pos                  .
           move      w-edt-per-pvg        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       vis-per-pvg-999.
           exit.

      *    *===========================================================*
      *    * Determinazione significativita' del campo 'Si/No stori-   *
      *    * cizzazione valori precedenti', e sua visualizzazione se   *
      *    * variato                                                   *
      *    *-----------------------------------------------------------*
       det-snx-sto-000.
      *              *-------------------------------------------------*
      *              * Salvataggio valore attuale del campo            *
      *              *-------------------------------------------------*
           move      w-rig-snx-sto (1)    to   w-sav-det-snx-sto      .
       det-snx-sto-100.
      *              *-------------------------------------------------*
      *              * Se non si e' in modifica : ad uscita senza al-  *
      *              * cuna azione                                     *
      *              *-------------------------------------------------*
           if        w-rig-dva-ini (2)    =    zero and
                     w-rig-dva-fin (2)    =    zero and
                     w-rig-tip-fnz (2)    =    zero and
                     w-rig-prz-lst (2)    =    zero and
                     w-rig-cat-sco (2)    =    zero and
                     w-rig-per-sco (2, 1) =    zero and
                     w-rig-per-sco (2, 2) =    zero and
                     w-rig-per-sco (2, 3) =    zero and
                     w-rig-per-sco (2, 4) =    zero and
                     w-rig-per-sco (2, 5) =    zero and
                     w-rig-cat-pvg (2)    =    zero and
                     w-rig-per-pvg (2, 1) =    zero and
                     w-rig-per-pvg (2, 2) =    zero and
                     w-rig-per-pvg (2, 3) =    zero
                     go to det-snx-sto-900.
       det-snx-sto-200.
      *              *-------------------------------------------------*
      *              * Test se il campo puo' essere significativo, e   *
      *              * deviazione secondo l'esito                      *
      *              *-------------------------------------------------*
       det-snx-sto-210.
      *                  *---------------------------------------------*
      *                  * Test su data di validita' iniziale          *
      *                  *---------------------------------------------*
           if        w-rig-dva-ini (1)    not  = w-rig-dva-ini (2)
                     go to det-snx-sto-600.
       det-snx-sto-500.
      *              *-------------------------------------------------*
      *              * Se il valore non puo' essere significativo      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Forzatura del valore a spaces               *
      *                  *---------------------------------------------*
           move      spaces               to   w-rig-snx-sto (1)      .
      *                  *---------------------------------------------*
      *                  * Ad eventuale ri-visualizzazione             *
      *                  *---------------------------------------------*
           go to     det-snx-sto-700.
       det-snx-sto-600.
      *              *-------------------------------------------------*
      *              * Se il valore puo' essere significativo          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se il valore attuale e' indefinito si forza *
      *                  * il valore a 'No'                            *
      *                  *---------------------------------------------*
           if        w-rig-snx-sto (1)    not  = "S" and
                     w-rig-snx-sto (1)    not  = "N"
                     move  "N"            to   w-rig-snx-sto (1)      .
      *                  *---------------------------------------------*
      *                  * Ad eventuale ri-visualizzazione             *
      *                  *---------------------------------------------*
           go to     det-snx-sto-700.
       det-snx-sto-700.
      *              *-------------------------------------------------*
      *              * Se il valore e' inalterato rispetto al valore   *
      *              * salvato all'inizio : ad  uscita                 *
      *              *-------------------------------------------------*
           if        w-rig-snx-sto (1)    =    w-sav-det-snx-sto
                     go to det-snx-sto-900.
       det-snx-sto-800.
      *              *-------------------------------------------------*
      *              * Ri-visualizzazione campo                        *
      *              *-------------------------------------------------*
           perform   vis-snx-sto-000      thru vis-snx-sto-999        .
       det-snx-sto-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-snx-sto-999.
       det-snx-sto-999.
           exit.

      *    *===========================================================*
      *    * Accettazione : Si/No storicizzazione valori precedenti    *
      *    *-----------------------------------------------------------*
       acc-snx-sto-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-snx-sto-025.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se il valore attuale del campo e' inde- *
      *                      * terminato : uscita                      *
      *                      *-----------------------------------------*
           if        w-rig-snx-sto (1)    not  = "S" and
                     w-rig-snx-sto (1)    not  = "N"
                     go to acc-snx-sto-999.
       acc-snx-sto-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-snx-sto-lun    to   v-car                  .
           move      w-exp-snx-sto-num    to   v-ldt                  .
           move      "X"                  to   v-edm                  .
      *
           move      w-lin-pri-lin-vid    to   v-lin                  .
           add       w-lin-num-lin-vis    to   v-lin                  .
           if        w-prs-tfu-pcp        =    zero
                     add   6              to   v-lin
           else      add   7              to   v-lin                  .
      *
           move      25                   to   v-pos                  .
           move      w-exp-snx-sto-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           if        w-rig-snx-sto (1)    =    "N"
                     move  01             to   v-num
           else if   w-rig-snx-sto (1)    =    "S"
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-snx-sto-999.
       acc-snx-sto-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    01
                     move  "N"            to   w-rig-snx-sto (1)
           else if   v-num                =    02
                     move  "S"            to   w-rig-snx-sto (1)
           else      move  spaces         to   w-rig-snx-sto (1)      .
       acc-snx-sto-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
           if        w-rig-snx-sto (1)    not  = "S" and
                     w-rig-snx-sto (1)    not  = "N"
                     go to acc-snx-sto-100.
       acc-snx-sto-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-snx-sto-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-snx-sto-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-snx-sto-100.
       acc-snx-sto-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione : Si/No storicizzazione valori precedenti *
      *    *-----------------------------------------------------------*
       vis-snx-sto-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-snx-sto-lun    to   v-car                  .
           move      w-exp-snx-sto-num    to   v-ldt                  .
           move      "X"                  to   v-edm                  .
      *
           move      w-lin-pri-lin-vid    to   v-lin                  .
           add       w-lin-num-lin-vis    to   v-lin                  .
           if        w-prs-tfu-pcp        =    zero
                     add   6              to   v-lin
           else      add   7              to   v-lin                  .
      *
           move      25                   to   v-pos                  .
           move      w-exp-snx-sto-tbl    to   v-txt                  .
           if        w-rig-snx-sto (1)    =    "N"
                     move  01             to   v-num
           else if   w-rig-snx-sto (1)    =    "S"
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-snx-sto-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazione tasto Do campi chiave           *
      *    *-----------------------------------------------------------*
       cnt-tdo-key-000.
