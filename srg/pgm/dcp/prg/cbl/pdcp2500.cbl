      *    *===========================================================*
      *    * Subroutines per accettazione codice prodotto 'dcp'        *
      *    *-----------------------------------------------------------*
       cod-cod-dcp-opn-000.
           move      "pgm/dcp/prg/obj/acoddcp0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           move      s-pat                to   w-cod-cod-dcp-pth      .
           move      "OP"                 to   w-cod-cod-dcp-ope      .
           perform   cod-cod-dcp-cll-000  thru cod-cod-dcp-cll-999    .
       cod-cod-dcp-opn-999.
           exit.
       cod-cod-dcp-cls-000.
           move      "CL"                 to   w-cod-cod-dcp-ope      .
           perform   cod-cod-dcp-cll-000  thru cod-cod-dcp-cll-999    .
           move      "C?"                 to   w-cod-cod-dcp-ope      .
           perform   cod-cod-dcp-cll-000  thru cod-cod-dcp-cll-999    .
           if        w-cod-cod-dcp-ope    not  = spaces
                     go to cod-cod-dcp-cls-999.
           cancel    w-cod-cod-dcp-pth                                .
       cod-cod-dcp-cls-999.
           exit.
       cod-cod-dcp-foi-000.
           if        v-key                not  = "INSR"
                     go to cod-cod-dcp-foi-500.
      *              *-------------------------------------------------*
      *              * Modifica per permettere l'Insr sulle righe      *
      *              * ----                                            *
      *              * Se Insr : nessuna azione. L'inserimento potra'  *
      *              *           essere effettuato tramite la ricerca  *
      *              * ----                                            *
      *              * Le istruzioni che seguono sono state inibite    *
      *              *-------------------------------------------------*
      *    move      "P?"                 to   s-ope                  .
      *    move      "pdcp4000"           to   s-pro                  .
      *    call      "swd/mod/prg/obj/msegrt"
      *                                  using s                      .
      *    if        s-liv                not  = zero
      *              go to cod-cod-dcp-foi-999.
      *    move      "pgm/dcp/prg/obj/pdcp4000"
      *                                   to   s-pat                  .
      *    call      "swd/mod/prg/obj/mfiltp"
      *                                  using s                      .
      *    call      s-pat                                            .
      *    cancel    s-pat                                            .
      *    move      "I+"                 to   w-cod-cod-dcp-ope      .
           go to     cod-cod-dcp-foi-999.
       cod-cod-dcp-foi-500.
           if        v-key                not  = "FIND"
                     go to cod-cod-dcp-foi-999.
           move      "P?"                 to   s-ope                  .
           move      "pdcp4010"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to cod-cod-dcp-foi-999.
           move      "PV"                 to   s-ope                  .
           move      "fkselect"           to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      04                   to   s-car                  .
           move      "SLCT"               to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      "pgm/dcp/prg/obj/pdcp4010"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
           move      "F+"                 to   w-cod-cod-dcp-ope      .
           go to     cod-cod-dcp-foi-999.
       cod-cod-dcp-foi-999.
           exit.
       cod-cod-dcp-cll-000.
           call      w-cod-cod-dcp-pth   using w-cod-cod-dcp
                                               v
                                               s                      .
       cod-cod-dcp-cll-999.
           exit.

