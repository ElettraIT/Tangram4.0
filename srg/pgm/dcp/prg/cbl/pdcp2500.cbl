      *                  *---------------------------------------------*
      *                  * Composizione chiave                         *
      *                  *---------------------------------------------*
           move      01                   to   rf-cpv-tip-rec         .
           move      w-tes-cod-cpv        to   rf-cpv-cod-cpv         .
           move      w-rig-num-pro (1)    to   rf-cpv-num-pro         .
           move      w-cix-ctr-prg        to   rf-cpv-num-prg         .
      *                  *---------------------------------------------*
      *                  * Composizione dati                           *
      *                  *---------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rf-cpv-ide-dat         .
           move      s-ute                to   rf-cpv-ide-ute         .
           move      s-fas                to   rf-cpv-ide-fas         .
           move      w-rig-pag-cpv (1)    to   rf-cpv-pag-cpv         .
           move      w-rig-alx-exp (1)    to   rf-cpv-alx-exp         .
       cmp-rec-cpv-999.
           exit.

      *    *===========================================================*
