      *              *-------------------------------------------------*
           move      zero                 to   w-cix-ctr-prg
      *              *-------------------------------------------------*
      *              * Esecuzione sort per ordinamento richiesto       *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   car-fil-rap-000
                                          thru car-fil-rap-999        .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del numero di records ca-  *
      *              * ricati nel file relative di appoggio            *
      *              *-------------------------------------------------*
           if        w-cix-ctr-prg        =    zero
                     go to rou-let-reg-200
           else      go to rou-let-reg-300.
       rou-let-reg-200.
      *              *-------------------------------------------------*
      *              * Se numero di records caricati : zero            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo funzionamento : Inserimento            *
      *                  *---------------------------------------------*
           move      "I"                  to   w-cnt-mfu-tip-fun      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     rou-let-reg-999.
       rou-let-reg-300.
      *              *-------------------------------------------------*
      *              * Se numero di records caricati maggiore di zero  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Modifica                                    *
      *                  *---------------------------------------------*
           move      "M"                  to   w-cnt-mfu-tip-fun      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     rou-let-reg-999.
       rou-let-reg-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Start su file [cpv]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "CPVPRO    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      01                   to   rf-cpv-tip-rec         .
           move      w-tes-cod-cpv        to   rf-cpv-cod-cpv         .
           move      zero                 to   rf-cpv-num-pro         .
           move      zero                 to   rf-cpv-num-prg         .
           move      "pgm/dcp/fls/ioc/obj/iofcpv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cpv                 .
      *                  *---------------------------------------------*
      *                  * Se errore di start : uscita                 *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [cpv]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofcpv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cpv                 .
      *                  *---------------------------------------------*
      *                  * Se at end : uscita                          *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo : uscita                       *
      *              *-------------------------------------------------*
           if        rf-cpv-tip-rec       not  = 01            or
                     rf-cpv-cod-cpv       not  = w-tes-cod-cpv
                     go to stp-srt-inp-999.
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni sul record [cpv]                      *
      *              *-------------------------------------------------*
       stp-srt-inp-600.
      *              *-------------------------------------------------*
      *              * Aggiornamento progressivo righe                 *
      *              *-------------------------------------------------*
           add       00100                to   w-cix-ctr-prg          .
      *              *-------------------------------------------------*
      *              * Composizione record di sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record di sort              *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Composizione chiave                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Progressivo inserimento attuale         *
      *                      *-----------------------------------------*
           move      rf-cpv-num-prg       to   srt-key-prg            .
      *                  *---------------------------------------------*
      *                  * Composizione dati                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice alfanumerico prodotto            *
      *                      *-----------------------------------------*
           move      rf-cpv-num-pro       to   w-let-arc-dcp-cod      .
           perform   let-arc-dcp-000      thru let-arc-dcp-999        .
           move      w-let-arc-dcp-alf    to   srt-alf-pro            .
      *                      *-----------------------------------------*
      *                      * Progressivo righe nuovo                 *
      *                      *-----------------------------------------*
           move      w-cix-ctr-prg        to   srt-num-prg            .
      *                      *-----------------------------------------*
      *                      * Progressivo righe precedente            *
      *                      *-----------------------------------------*
           move      rf-cpv-num-prg       to   srt-old-prg            .
      *                      *-----------------------------------------*
      *                      * Codice prodotto                         *
      *                      *-----------------------------------------*
           move      rf-cpv-num-pro       to   srt-num-pro            .
      *                      *-----------------------------------------*
      *                      * Pagina catalogo                         *
      *                      *-----------------------------------------*
           move      rf-cpv-pag-cpv       to   srt-pag-cpv            .
      *                      *-----------------------------------------*
      *                      * Area di espansione                      *
      *                      *-----------------------------------------*
           move      rf-cpv-alx-exp       to   srt-alx-exp            .
       stp-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Riciclo a record successivo                     *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Esecuzione caricamento file relative di appoggio          *
      *    *-----------------------------------------------------------*
       car-fil-rap-000.
      *              *-------------------------------------------------*
      *              * La preparazione della catena avviene dai record *
      *              * rilasciati dalla routine in input di sort       *
      *              *-------------------------------------------------*
       car-fil-rap-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale archivio sortato [srt]      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se At End : uscita                          *
      *                  *---------------------------------------------*
           return    srt    at end
                            go to car-fil-rap-999                     .
       car-fil-rap-200.
      *              *-------------------------------------------------*
      *              * Composizione area 'w-rig'                       *
      *              *-------------------------------------------------*
           move      srt-num-prg          to   w-rig-num-prg (1)      .
           move      srt-num-pro          to   w-rig-num-pro (1)      .
           move      srt-pag-cpv          to   w-rig-pag-cpv (1)      .
           move      srt-alx-exp          to   w-rig-alx-exp (1)      .
      *                  *---------------------------------------------*
      *                  * Valori contenuti indirettamente in record   *
      *                  * [cpv]                                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Descrizione prodotto [dcp]              *
      *                      *-----------------------------------------*
           move      w-rig-num-pro (1)    to   w-let-arc-dcp-cod      .
           perform   let-arc-dcp-000      thru let-arc-dcp-999        .
           move      w-let-arc-dcp-alf    to   w-rig-alf-pro (1)      .
           move      w-let-arc-dcp-des    to   w-rig-alf-pro-des (1)  .
           move      w-let-arc-dcp-udm    to   w-rig-alf-pro-udm (1)  .
      *                          *-------------------------------------*
      *                          * Se prodotto non trovato             *
      *                          *-------------------------------------*
           if        w-let-arc-dcp-flg    =    spaces
                     go to car-fil-rap-400.
      *                          *-------------------------------------*
      *                          * Editing codice numerico             *
      *                          *-------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-rig-num-pro (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Assemblaggio                        *
      *                          *-------------------------------------*
           move      14                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      "("                  to   w-all-str-cat (1)      .
           move      v-edt                to   w-all-str-cat (2)      .
           move      ")"                  to   w-all-str-cat (3)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
           move      w-all-str-alf        to   w-rig-alf-pro-des (1)  .
      *
           go to     car-fil-rap-420.
       car-fil-rap-400.
           move      w-let-arc-dcp-des    to   w-rig-alf-pro-des (1)  .
       car-fil-rap-420.
       car-fil-rap-600.
       car-fil-rap-900.
      *                  *---------------------------------------------*
      *                  * Valori precedenti                           *
      *                  *---------------------------------------------*
           move      w-rig-val-aep (1)    to   w-rig-val-aep (2)      .
      *                  *---------------------------------------------*
      *                  * Progressivo riga precedente                 *
      *                  *---------------------------------------------*
           move      srt-old-prg          to   w-rig-num-prg (2)      .
      *                  *---------------------------------------------*
      *                  * Put su catena movimenti [rig]               *
      *                  *---------------------------------------------*
           move      "PT"                 to   w-cat-rig-ope          .
           move      srt-num-prg          to   w-cat-rig-prg          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo a lettura record di sort            *
      *                  *---------------------------------------------*
           go to     car-fil-rap-100.
       car-fil-rap-999.
           exit.

