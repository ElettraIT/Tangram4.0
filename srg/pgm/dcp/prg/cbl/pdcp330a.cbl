      *    *===========================================================*
      *    * Duplicazione di : Listino Base --> Listino alternativo    *
      *    *-----------------------------------------------------------*
       dup-bas-alt-000.
      *              *-------------------------------------------------*
      *              * Azzeramento preliminare del listino alternativo *
      *              * di destinazione                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se azzeramento da effettuare           *
      *                  *---------------------------------------------*
           if        rr-fso-dcp           not  = zero
                     go to dup-bas-alt-100.
       dup-bas-alt-010.
      *                  *---------------------------------------------*
      *                  * Start su file [lst]                         *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "LSTPRO    "         to   f-key                  .
           move      01                   to   rf-lst-tip-rec         .
           move      rr-lde-cod-lst       to   rf-lst-cod-lst         .
           move      zero                 to   rf-lst-cod-cli         .
           move      rr-lde-cod-vlt       to   rf-lst-sgl-vlt         .
           move      zero                 to   rf-lst-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : a duplicazione            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to dup-bas-alt-050.
       dup-bas-alt-020.
      *                  *---------------------------------------------*
      *                  * Get Next su file [lst]                      *
      *                  *---------------------------------------------*
           move      "GN"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
      *                  *---------------------------------------------*
      *                  * Se At End : a duplicazione                  *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to dup-bas-alt-050.
       dup-bas-alt-030.
      *                  *---------------------------------------------*
      *                  * Test Max su [lst] ; se fine : ad unlock e a *
      *                  * duplicazione                                *
      *                  *---------------------------------------------*
           if        rf-lst-tip-rec       not  = 01             or
                     rf-lst-cod-lst       not  = rr-lde-cod-lst or
                     rf-lst-cod-cli       not  = zero           or
                     rf-lst-sgl-vlt       not  = rr-lde-cod-vlt
                     go to dup-bas-alt-040.
       dup-bas-alt-032.
      *                  *---------------------------------------------*
      *                  * Selezione sul codice prodotto determinata   *
      *                  * dal filtro di selezione                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura record [dcp]                    *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      rf-lst-num-pro       to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *                          *-------------------------------------*
      *                          * Se record non trovato : a riciclo   *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to dup-bas-alt-038.
       dup-bas-alt-034.
      *                      *-----------------------------------------*
      *                      * Selezione                               *
      *                      *-----------------------------------------*
           move      "SE"                 to   f-ope                  .
           move      "pgm/dcp/prg/obj/bzosdcp0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *                      *-----------------------------------------*
      *                      * Se selezione non superata : a riciclo   *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to dup-bas-alt-038.
       dup-bas-alt-036.
      *                  *---------------------------------------------*
      *                  * Azzeramento prezzo di listino               *
      *                  *---------------------------------------------*
           move      zero                 to   rf-lst-prz-lst         .
      *                  *---------------------------------------------*
      *                  * Azzeramento provvigioni associate           *
      *                  *---------------------------------------------*
           move      zero                 to   rf-lst-per-pvg (1)     .
           move      zero                 to   rf-lst-per-pvg (2)     .
           move      zero                 to   rf-lst-per-pvg (3)     .
