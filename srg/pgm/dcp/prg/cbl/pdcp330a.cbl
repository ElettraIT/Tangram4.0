      *    *===========================================================*
      *    * Esecuzione sub-program : Duplicazione di un listino       *
      *    *-----------------------------------------------------------*
       exe-sub-pgm-000.
      *              *-------------------------------------------------*
      *              * Messaggio di programma in esecuzione            *
      *              *-------------------------------------------------*
           move      "PE"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-sub-pgm-100.
      *              *-------------------------------------------------*
      *              * Open files                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * [dcp]                                       *
      *                  *---------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *                  *---------------------------------------------*
      *                  * [lst]                                       *
      *                  *---------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
       exe-sub-pgm-150.
      *              *-------------------------------------------------*
      *              * Richiesta tipo ordinamento per il filtro [dcp]  *
      *              *-------------------------------------------------*
           move      "TO"                 to   f-ope                  .
           move      rr-fso-dcp-alf       to   f-key                  .
           move      "pgm/dcp/prg/obj/bzosdcp0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
       exe-sub-pgm-200.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda delle combinazioni fra i   *
      *              * tipi di listino                                 *
      *              *-------------------------------------------------*
           if        rr-lor-cod-lst       =    spaces   and
                     rr-lde-cod-lst       not  = spaces
                     go to exe-sub-pgm-300
           else if   rr-lor-cod-lst       not  = spaces and
                     rr-lde-cod-lst       =    spaces
                     go to exe-sub-pgm-400
           else if   rr-lor-cod-lst       not  = spaces and
                     rr-lde-cod-lst       not  = spaces
                     go to exe-sub-pgm-500
           else      go to exe-sub-pgm-800.
       exe-sub-pgm-300.
      *              *-------------------------------------------------*
      *              * Listino Base --> Listino alternativo            *
      *              *-------------------------------------------------*
           perform   dup-bas-alt-000      thru dup-bas-alt-999        .
           go to     exe-sub-pgm-800.
       exe-sub-pgm-400.
      *              *-------------------------------------------------*
      *              * Listino alternativo --> Listino Base            *
      *              *-------------------------------------------------*
           perform   dup-alt-bas-000      thru dup-alt-bas-999        .
           go to     exe-sub-pgm-800.
       exe-sub-pgm-500.
      *              *-------------------------------------------------*
      *              * Listino alternativo --> Listino alternativo     *
      *              *-------------------------------------------------*
           perform   dup-alt-alt-000      thru dup-alt-alt-999        .
           go to     exe-sub-pgm-800.
       exe-sub-pgm-800.
