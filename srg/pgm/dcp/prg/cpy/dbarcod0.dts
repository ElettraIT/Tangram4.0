      *    *===========================================================*
      *    * Subroutines per determinazione barcode prodotti           *
      *    *-----------------------------------------------------------*
       det-bar-cod-opn-000.
      *              *=================================================*
      *              * Open modulo                                     *
      *              *-------------------------------------------------*
           move      "OP"                 to   d-bar-cod-tip-ope      .
           perform   det-bar-cod-cll-000  thru det-bar-cod-cll-999    .
       det-bar-cod-opn-999.
           exit.

       det-bar-cod-cls-000.
      *              *=================================================*
      *              * Close modulo                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Chiusura                                    *
      *                  *---------------------------------------------*
           move      "CL"                 to   d-bar-cod-tip-ope      .
           perform   det-bar-cod-cll-000  thru det-bar-cod-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test se cancellabile                        *
      *                  *---------------------------------------------*
           move      "C?"                 to   d-bar-cod-tip-ope      .
           perform   det-bar-cod-cll-000  thru det-bar-cod-cll-999    .
           if        d-bar-cod-exi-sts    not  = spaces
                     go to det-bar-cod-cls-999.
      *                  *---------------------------------------------*
      *                  * Cancellazione modulo                        *
      *                  *---------------------------------------------*
           move      "pgm/dcp/prg/obj/dbarcod0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-bar-cod              .
       det-bar-cod-cls-999.
           exit.

       det-bar-cod-cll-000.
      *              *=================================================*
      *              * Chiamata generica modulo                        *
      *              *-------------------------------------------------*
           move      "pgm/dcp/prg/obj/dbarcod0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-bar-cod              .
       det-bar-cod-cll-999.
           exit.

