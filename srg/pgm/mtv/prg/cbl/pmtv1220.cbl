                     go to acc-sgr-pro-115.
           if        w-cod-mne-zv3-ope    =    "AC"
                     go to acc-sgr-pro-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-sgr-pro-115.
           perform   cod-mne-zv3-foi-000  thru cod-mne-zv3-foi-999    .
           go to     acc-sgr-pro-110.
       acc-sgr-pro-120.
           move      w-cod-mne-zv3-sgr    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-sgr-pro-999.
       acc-sgr-pro-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   rr-sgr-map             .
       acc-sgr-pro-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [zv3]                      *
      *                  *---------------------------------------------*
           move      rr-cla-map           to   w-let-arc-zv3-cla      .
           move      rr-gru-map           to   w-let-arc-zv3-gru      .
           move      rr-sgr-map           to   w-let-arc-zv3-sgr      .
           perform   let-arc-zv3-000      thru let-arc-zv3-999        .
      *                   *--------------------------------------------*
      *                   * Bufferizzazione di :                       *
      *                   * - Descrizione                              *
      *                   * - Ulteriore suddivisione                   *
      *                   * - Numero di sequenza                       *
      *                   *--------------------------------------------*
           move      w-let-arc-zv3-des    to   rr-sgr-map-des         .
           move      w-let-arc-zv3-sud    to   rr-sgr-map-sud         .
           move      w-let-arc-zv3-sqz    to   rr-sgr-map-sqz         .
      *                   *--------------------------------------------*
      *                   * Visualizzazione descrizione                *
      *                   *--------------------------------------------*
           perform   vis-des-sgr-000      thru vis-des-sgr-999        .
      *                  *---------------------------------------------*
      *                  * Se lettura errata : reimpostazione          *
      *                  *---------------------------------------------*
           if        w-let-arc-zv3-flg    not  = spaces
                     go to acc-sgr-pro-100.
       acc-sgr-pro-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-sgr-pro-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-sgr-pro-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-sgr-pro-100.
       acc-sgr-pro-999.
           exit.

