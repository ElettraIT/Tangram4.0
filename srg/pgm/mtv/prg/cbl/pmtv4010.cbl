      *              * Lettura sequenziale archivio [mtv]              *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/mtv/fls/ioc/obj/iofmtv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mtv                 .
      *                  *---------------------------------------------*
      *                  * Test se fine file                           *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exp-rec-mtv-990.
           go to     exp-rec-mtv-999.
       exp-rec-mtv-990.
      *              *-------------------------------------------------*
      *              * Se Start errata o Read Next at-end              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
