                     go to tdo-ric-sel-005.
           move      "Tipo ordinamento errato !"
                                          to   w-err-tdo-ric-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-005.
      *              *-------------------------------------------------*
      *              * Controllo su classe merceologica                *
      *              *-------------------------------------------------*
           if        rr-tip-ord           not  = 4
                     go to tdo-ric-sel-010.
           if        rr-cla-mtv           not  = zero
                     go to tdo-ric-sel-010.
           move      "Manca il codice classe merceologica"
                                          to   w-err-tdo-ric-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-010.
      *              *-------------------------------------------------*
      *              * Controllo su gruppo merceologico                *
      *              *-------------------------------------------------*
           if        rr-tip-ord           not  = 4
                     go to tdo-ric-sel-020.
           if        rr-cla-mtv-sud       =    01
                     go to tdo-ric-sel-020.
           if        rr-gru-mtv           not  = zero
                     go to tdo-ric-sel-020.
           move      "Manca il codice gruppo merceologico"
                                          to   w-err-tdo-ric-msg      .
           go to     tdo-ric-sel-900.
