      *    *===========================================================*
      *    * Lettura i.p.c. da livello precedente per tipo di interro- *
      *    * gazione e parametro relativo                              *
      *    *-----------------------------------------------------------*
       ipc-dlp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-ipc-dlp-flg-exi      .
      *              *-------------------------------------------------*
      *              * Normalizzazione work-area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-ipc-dlp-flg-exi      .
           move      spaces               to   w-ipc-dlp-tip-int      .
           move      spaces               to   w-ipc-dlp-sin-min      .
           move      spaces               to   w-ipc-dlp-sin-max      .
           move      spaces               to   w-ipc-dlp-des-min      .
           move      spaces               to   w-ipc-dlp-des-max      .
      *              *-------------------------------------------------*
      *              * Estrazione della eventuale variabile di i.p.c.  *
      *              * "tip-int" per tipo interrogazione               *
      *              *-------------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "tip-int"            to   s-var                  .
           move      "-"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Se variabile non esistente : uscita ad errore   *
      *              *-------------------------------------------------*
           if        s-ves                not  = spaces
                     go to ipc-dlp-900.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valore                          *
      *              *-------------------------------------------------*
           move      s-alf                to   w-ipc-dlp-tip-int      .
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo interrogazione  *
      *              *-------------------------------------------------*
           if        w-ipc-dlp-tip-int    =    "S"
                     go to ipc-dlp-300
           else if   w-ipc-dlp-tip-int    =    "D"
                     go to ipc-dlp-600
           else      go to ipc-dlp-900.
       ipc-dlp-300.
      *              *-------------------------------------------------*
      *              * Se tipo interrogazione per Sinonimo             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Estrazione variabile di i.p.c. "syn-min"    *
      *                  *---------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "syn-min"            to   s-var                  .
           move      "-"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                not  = spaces
                     go to ipc-dlp-900.
           if        s-alf                =    spaces
                     go to ipc-dlp-900.
           move      s-alf                to   w-ipc-dlp-sin-min      .
      *                  *---------------------------------------------*
      *                  * Estrazione variabile di i.p.c. "syn-max"    *
      *                  *---------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "syn-max"            to   s-var                  .
           move      "-"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                not  = spaces
                     go to ipc-dlp-900.
           if        s-alf                =    spaces
                     go to ipc-dlp-900.
           move      s-alf                to   w-ipc-dlp-sin-max      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     ipc-dlp-999.
       ipc-dlp-600.
      *              *-------------------------------------------------*
      *              * Se tipo interrogazione per Descrizione          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Estrazione variabile di i.p.c. "des-min"    *
      *                  *---------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "des-min"            to   s-var                  .
           move      "-"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                not  = spaces
                     go to ipc-dlp-900.
           if        s-alf                =    spaces
                     go to ipc-dlp-900.
           move      s-alf                to   w-ipc-dlp-des-min      .
      *                  *---------------------------------------------*
      *                  * Estrazione variabile di i.p.c. "syn-max"    *
      *                  *---------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "des-max"            to   s-var                  .
           move      "-"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-ves                not  = spaces
                     go to ipc-dlp-900.
           if        s-alf                =    spaces
                     go to ipc-dlp-900.
           move      s-alf                to   w-ipc-dlp-des-max      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     ipc-dlp-999.
       ipc-dlp-900.
      *              *-------------------------------------------------*
      *              * Uscita con flag ad errore                       *
      *              *-------------------------------------------------*
           move      "#"                  to   w-ipc-dlp-flg-exi      .
       ipc-dlp-999.
           exit.

