      *    *===========================================================*
      *    * Subroutines per accettazione codice materia varia         *
      *    *-----------------------------------------------------------*
       cod-cod-mtv-opn-000.
           move      "pgm/mtv/prg/obj/acodmtv0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           move      s-pat                to   w-cod-cod-mtv-pth      .
           move      "OP"                 to   w-cod-cod-mtv-ope      .
           perform   cod-cod-mtv-cll-000  thru cod-cod-mtv-cll-999    .
       cod-cod-mtv-opn-999.
           exit.
       cod-cod-mtv-cls-000.
           move      "CL"                 to   w-cod-cod-mtv-ope      .
           perform   cod-cod-mtv-cll-000  thru cod-cod-mtv-cll-999    .
           move      "C?"                 to   w-cod-cod-mtv-ope      .
           perform   cod-cod-mtv-cll-000  thru cod-cod-mtv-cll-999    .
           if        w-cod-cod-mtv-ope    not  = spaces
                     go to cod-cod-mtv-cls-999.
           cancel    w-cod-cod-mtv-pth                                .
       cod-cod-mtv-cls-999.
           exit.
       cod-cod-mtv-foi-000.
           if        v-key                not  = "INSR"
                     go to cod-cod-mtv-foi-500.
           move      "P?"                 to   s-ope                  .
           move      "pmtv4000"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to cod-cod-mtv-foi-999.
           move      "pgm/mtv/prg/obj/pmtv4000"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
           move      "I+"                 to   w-cod-cod-mtv-ope      .
           go to     cod-cod-mtv-foi-999.
       cod-cod-mtv-foi-500.
           if        v-key                not  = "FIND"
                     go to cod-cod-mtv-foi-750.
           move      "P?"                 to   s-ope                  .
           move      "pmtv4010"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to cod-cod-mtv-foi-999.
           move      "PV"                 to   s-ope                  .
           move      "fkselect"           to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      04                   to   s-car                  .
           move      "SLCT"               to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      "pgm/mtv/prg/obj/pmtv4010"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
           move      "F+"                 to   w-cod-cod-mtv-ope      .
           go to     cod-cod-mtv-foi-999.
       cod-cod-mtv-foi-750.
           if        v-key                =    "[2] "
                     move  "#"            to   w-cod-cod-mtv-pf2
                     go to cod-cod-mtv-foi-999.
           if        w-cod-cod-mtv-ope    not  = "F+" or
                     w-cod-cod-mtv-pf2    =    spaces
                     go to cod-cod-mtv-foi-999.
           move      "PV"                 to   s-ope                  .
           move      "acomtv0.[2]"        to   s-var                  .
           move      "G"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      01                   to   s-car                  .
           move      "#"                  to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      "pgm/mtv/prg/obj/acodmtv1"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using w-cod-cod-mtv
                                               v
                                               s                      .
           cancel    s-pat                                            .
           move      "CV"                 to   s-ope                  .
           move      "acomtv0.[2]"        to   s-var                  .
           move      "G"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      "I+"                 to   w-cod-cod-mtv-ope      .
           move      spaces               to   w-cod-cod-mtv-pf2      .
           go to     cod-cod-mtv-foi-999.
       cod-cod-mtv-foi-999.
           exit.
       cod-cod-mtv-cll-000.
           call      w-cod-cod-mtv-pth   using w-cod-cod-mtv
                                               v
                                               s                      .
       cod-cod-mtv-cll-999.
           exit.

