      *    *===========================================================*
      *    * Subroutines per modulo di determinazione, relativamente   *
      *    * ad un archivio, dei numeri di utenza per i contatti       *
      *    *-----------------------------------------------------------*
       con-arc-tip-opn-000.
      *              *=================================================*
      *              * Open modulo                                     *
      *              *-------------------------------------------------*
           move      "OP"                 to   d-con-arc-tip-ope      .
           perform   con-arc-tip-cll-000  thru con-arc-tip-cll-999    .
       con-arc-tip-opn-999.
           exit.

       con-arc-tip-cls-000.
      *              *=================================================*
      *              * Close modulo                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Chiusura                                    *
      *                  *---------------------------------------------*
           move      "CL"                 to   d-con-arc-tip-ope      .
           perform   con-arc-tip-cll-000  thru con-arc-tip-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test se cancellabile                        *
      *                  *---------------------------------------------*
           move      "C?"                 to   d-con-arc-tip-ope      .
           perform   con-arc-tip-cll-000  thru con-arc-tip-cll-999    .
           if        d-con-arc-exi-sts    not  = spaces
                     go to con-arc-tip-cls-999.
      *                  *---------------------------------------------*
      *                  * Cancellazione modulo                        *
      *                  *---------------------------------------------*
           move      "pgm/azi/prg/obj/dconarc0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           cancel    s-pat                                            .
       con-arc-tip-cls-999.
           exit.

       con-arc-tip-cll-000.
      *              *=================================================*
      *              * Chiamata generica modulo                        *
      *              *-------------------------------------------------*
           move      "pgm/azi/prg/obj/dconarc0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-con-arc              .
       con-arc-tip-cll-999.
           exit.

