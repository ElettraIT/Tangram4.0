      *                      * Abblencamento immagine linea di corpo   *
      *                      *-----------------------------------------*
           move      spaces               to   w-lin-imm              .
      *                      *-----------------------------------------*
      *                      * Editing Numero progressivo riga         *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      spaces               to   v-edm                  .
           move      w-dpz-cod-dpz (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-lin-imm-num-lin      .
      *                      *-----------------------------------------*
      *                      * Se riga di tipo New : fine editing      *
      *                      *-----------------------------------------*
           if        w-sub-rel-new        not  = spaces
                     go to vis-lin-cor-800.
      *                      *-----------------------------------------*
      *                      * Denominazione dipendenza                *
      *                      *-----------------------------------------*
           move      w-dpz-mne-dpz (1)    to   w-lin-imm-den-dpz      .
      *                          *-------------------------------------*
      *                          * Concatenamento con stato dipendenza *
      *                          *-------------------------------------*
           move      20                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
           move      w-dpz-mne-dpz (1)    to   w-all-str-cat (1)      .
      *
           if        w-dpz-sta-tus (1)    =    spaces
                     move  spaces         to   w-all-str-cat (2)
           else if   w-dpz-sta-tus (1)    =    "#"
                     move  "[INATTIVA]"   to   w-all-str-cat (2)
           else      move  spaces         to   w-all-str-cat (2)      .
      *
           perform   all-str-csb-000      thru all-str-csb-999        .
      *
           move      w-all-str-alf        to   w-lin-imm-den-dpz      .
      *                      *-----------------------------------------*
      *                      * Indirizzo dipendenza                    *
      *                      *-----------------------------------------*
           move      w-dpz-via-dpz (1)    to   w-lin-imm-via-dpz      .
      *                      *-----------------------------------------*
      *                      * Localita' dipendenza                    *
      *                      *-----------------------------------------*
           move      w-dpz-loc-dpz (1)    to   w-lin-imm-loc-dpz      .
       vis-lin-cor-800.
      *                      *-----------------------------------------*
      *                      * Parametri per visualizzazione           *
      *                      *-----------------------------------------*
           move      80                   to   v-car                  .
       vis-lin-cor-900.
      *              *-------------------------------------------------*
      *              * Esecuzione visualizzazione                      *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      01                   to   v-pos                  .
           move      w-lin-imm            to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-lin-cor-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts area linee di corpo               *
      *    *-----------------------------------------------------------*
       pmt-cor-reg-000.
      *              *-------------------------------------------------*
      *              * Erase linee impegnate                           *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      04                   to   v-lin                  .
           move      16                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Fincatura per area di scroll                    *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Nr"                 to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      08                   to   v-pos                  .
           move      "Denominazione"      to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      35                   to   v-pos                  .
           move      "Indirizzo"          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      64                   to   v-pos                  .
           move      "Localita'"          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Sottolineatura fincatura per area di scroll     *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "-- -------------------- --------------------------
      -              "---- -------------------------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Linea di trattini                               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      all "-"              to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cor-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione riga corpo di accettazione in w-dpz       *
      *    *-----------------------------------------------------------*
       vis-rig-cor-000.
      *              *-------------------------------------------------*
      *              * Se riga di tipo New : nessuna visualizzazione   *
      *              *-------------------------------------------------*
           if        w-sub-rel-new        not  = spaces
                     go to vis-rig-cor-999.
      *              *-------------------------------------------------*
      *              * Codice dipendenza                               *
      *              *-------------------------------------------------*
           perform   vis-cod-dpz-000      thru vis-cod-dpz-999        .
      *              *-------------------------------------------------*
      *              * Stato dipendenza                                *
      *              *-------------------------------------------------*
           perform   vis-sta-tus-000      thru vis-sta-tus-999        .
      *              *-------------------------------------------------*
      *              * Denominazione dipendenza                        *
      *              *-------------------------------------------------*
           perform   vis-den-dpz-000      thru vis-den-dpz-999        .
      *              *-------------------------------------------------*
      *              * Ragione sociale dipendenza                      *
      *              *-------------------------------------------------*
           perform   vis-rag-dpz-000      thru vis-rag-dpz-999        .
      *              *-------------------------------------------------*
      *              * Indirizzo dipendenza                            *
      *              *-------------------------------------------------*
           perform   vis-via-dpz-000      thru vis-via-dpz-999        .
      *              *-------------------------------------------------*
      *              * Localita' dipendenza                            *
      *              *-------------------------------------------------*
           perform   vis-loc-dpz-000      thru vis-loc-dpz-999        .
       vis-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riga di accettazione          *
      *    *-----------------------------------------------------------*
       pmt-rig-cor-000.
      *              *-------------------------------------------------*
      *              * Erase linee impegnate dall'area di impostazione *
      *              * della singola riga corpo espansa a piede        *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      17                   to   v-lin                  .
           move      21                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Codice dipendenza                               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Codice           :" to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Denominazione dipendenza                        *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Denominazione    :" to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Ragione sociale dipendenza                      *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Ragione sociale  :" to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Indirizzo dipendenza                            *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Indirizzo        :" to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Localita' dipendenza                            *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Localita'        :" to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice dipendenza                    *
      *    *-----------------------------------------------------------*
       acc-cod-dpz-000.
      *              *-------------------------------------------------*
      *              * Salvataggio numero progressivo pre-modifica     *
      *              *-------------------------------------------------*
           move      w-sub-rel-prg        to   w-sub-rel-ppm          .
       acc-cod-dpz-010.
      *              *-------------------------------------------------*
      *              * Determinazione del valore minimo e massimo im-  *
      *              * postabili                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se record non New il valore minimo e massi- *
      *                  * mo impostabili sono fissati pari al valore  *
      *                  * precedente stesso                           *
      *                  *---------------------------------------------*
           if        w-sub-rel-new        =    spaces
                     move  w-sub-rel-ppm  to   w-cod-dpz-val-min
                     move  w-sub-rel-ppm  to   w-cod-dpz-val-max
                     go to acc-cod-dpz-020.
      *                  *---------------------------------------------*
      *                  * Altrimenti essi sono impostati in funzione  *
      *                  * dello stato del subfile [rel]               *
      *                  *---------------------------------------------*
           if        w-sub-rel-npp        =    zero
                     move  001            to   w-cod-dpz-val-min
           else      move  w-sub-rel-npp  to   w-cod-dpz-val-min
                     add   1              to   w-cod-dpz-val-min      .
           if        w-sub-rel-nps        =    zero
                     move  w-sub-rel-meg  to   w-cod-dpz-val-max
           else      move  w-sub-rel-nps  to   w-cod-dpz-val-max
                     subtract  1          from w-cod-dpz-val-max      .
       acc-cod-dpz-020.
      *              *-------------------------------------------------*
      *              * Preparazione valore di default                  *
      *              *-------------------------------------------------*
           move      w-sub-rel-ppm        to   w-cod-dpz-val-def      .
       acc-cod-dpz-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
       acc-cod-dpz-110.
      *                  *---------------------------------------------*
      *                  * Parametri generici                          *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      17                   to   v-lin                  .
           move      20                   to   v-pos                  .
           move      "<B"                 to   v-edm                  .
       acc-cod-dpz-120.
      *                  *---------------------------------------------*
      *                  * Tasti funzione                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Up   : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "UP  "               to   v-pfk (01)             .
      *                      *-----------------------------------------*
      *                      * Down : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "DOWN"         to   v-pfk (02)             .
      *                      *-----------------------------------------*
      *                      * Insr : sempre ammesso, a meno che non   *
      *                      *        si sia in un record New oppure   *
      *                      *        manchi spazio per l'inserimento  *
      *                      *-----------------------------------------*
           if        w-sub-rel-new        =    spaces and
                     w-sub-rel-ins        =    spaces
                     move  "INSR"         to   v-pfk (04)             .
      *                      *-----------------------------------------*
      *                      * Do   : sempre ammesso, purche' sia con- *
      *                      *        cesso dallo status delle impo-   *
      *                      *        stazioni; eventualmente disat-   *
      *                      *        tivato dal richiamo della sub-   *
      *                      *        routine di accettazione          *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
       acc-cod-dpz-140.
      *                      *-----------------------------------------*
      *                      * Remv : sempre ammesso, a meno che non   *
      *                      *        sia prevista le gestione delle   *
      *                      *        dipendenze parallele e si sia    *
      *                      *        su di un codice dipendenza mi-   *
      *                      *        nore di 50, che abbia una cor-   *
      *                      *        rispondente dipendenza maggio-   *
      *                      *        re di 50                         *
      *                      *-----------------------------------------*
           if        w-prs-snx-gdp-snx    not  = "S"
                     move  "REMV"         to   v-pfk (06)
                     go to acc-cod-dpz-150.
           move      w-cod-dpz-val-def    to   w-lst-dpz-inx          .
           if        w-lst-dpz-inx        =    zero or
                     w-lst-dpz-inx        >    50
                     move  "REMV"         to   v-pfk (06)
                     go to acc-cod-dpz-150.
           add       50                   to   w-lst-dpz-inx          .
           if        w-lst-dpz-ele-flg
                    (w-lst-dpz-inx)       =    spaces
                     move  "REMV"         to   v-pfk (06)
                     go to acc-cod-dpz-150.
       acc-cod-dpz-150.
      *                      *-----------------------------------------*
      *                      * Prsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "PRSC"               to   v-pfk (07)             .
      *                      *-----------------------------------------*
      *                      * Nxsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "NXSC"               to   v-pfk (08)             .
      *                      *-----------------------------------------*
      *                      * Back : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sulla prima riga     *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    not  = 1
                     move  "BACK"         to   v-pfk (09)             .
      *                      *-----------------------------------------*
      *                      * Tab  : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'ultima riga e   *
      *                      *        che questa sia in Append         *
      *                      *-----------------------------------------*
           if        w-sub-rel-new        =    spaces or
                     w-sub-rel-lst        =    spaces
                     move  "TAB "         to   v-pfk (10)             .
      *                      *-----------------------------------------*
      *                      * Slct : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'unica riga      *
      *                      *-----------------------------------------*
           if        w-sub-rel-max        not  = 1
                     move  "SLCT"         to   v-pfk (11)             .
       acc-cod-dpz-200.
      *                      *-----------------------------------------*
      *                      * Valore di default in accettazione       *
      *                      *-----------------------------------------*
           move      w-cod-dpz-val-def    to   v-num                  .
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine di accettazione     *
      *                      *-----------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Return                                       *
      *              *-------------------------------------------------*
           if        v-key                =    spaces
                     go to acc-cod-dpz-400.
      *              *-------------------------------------------------*
      *              * Se Slct                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "SLCT"
                     go to acc-cod-dpz-300
           else      go to acc-cod-dpz-350.
       acc-cod-dpz-300.
      *                  *---------------------------------------------*
      *                  * Se record non esistente in subfile : reim-  *
      *                  * postazione                                  *
      *                  *---------------------------------------------*
           move      "P?"                 to   w-sub-rel-ope          .
           move      v-num                to   w-sub-rel-prw          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
           if        w-sub-rel-exs        not  = spaces
                     go to acc-cod-dpz-100.
      *                  *---------------------------------------------*
      *                  * Se codice dipendenza impostato pari a codi- *
      *                  * ce dipendenza attuale : reimpostazione      *
      *                  *---------------------------------------------*
           if        v-num                =    w-sub-rel-ppm
                     go to acc-cod-dpz-100.
      *                  *---------------------------------------------*
      *                  * Estrazione numero d'ordine record dal nume- *
      *                  * ro progressivo                              *
      *                  *---------------------------------------------*
           move      "O<"                 to   w-sub-rel-ope          .
           move      v-num                to   w-sub-rel-prw          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Preparazione parametri e uscita             *
      *                  *---------------------------------------------*
           move      w-sub-rel-prw        to   w-cnt-slc-num-rig      .
           move      "."                  to   w-cnt-tus-acc-rig      .
           go to     acc-cod-dpz-999.
       acc-cod-dpz-350.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dpz-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dpz-375.
      *              *-------------------------------------------------*
      *              * Se premuto un altro tasto funzione non deve es- *
      *              * sere avvenuta variazione del campo d'impostaz.  *
      *              *-------------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-cod-dpz-100.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     move  "U"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dpz-375.
      *              *-------------------------------------------------*
      *              * Se Down                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DOWN"
                     move  "D"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dpz-375.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cod-dpz-375
                     else    go to acc-cod-dpz-100.
      *              *-------------------------------------------------*
      *              * Se Insr                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "INSR"
                     move  "I"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dpz-375.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dpz-375.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "TAB "
                     move  "T"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dpz-375.
      *              *-------------------------------------------------*
      *              * Se Back                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "BACK"
                     move  "B"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dpz-375.
      *              *-------------------------------------------------*
      *              * Se Nxsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     move  "N"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dpz-375.
      *              *-------------------------------------------------*
      *              * Se Prsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "PRSC"
                     move  "P"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dpz-375.
       acc-cod-dpz-375.
      *              *-------------------------------------------------*
      *              * Se Remv si elimina il codice dipendenza dalla   *
      *              * lista dipendenze esistenti                      *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV" and
                     w-dpz-cod-dpz (1)    not  = zero
                     move  w-dpz-cod-dpz (1)
                                          to   w-lst-dpz-inx
                     move  spaces         to   w-lst-dpz-ele-flg
                                              (w-lst-dpz-inx)         .
      *              *-------------------------------------------------*
      *              * Se riga new                                     *
      *              *-------------------------------------------------*
           if        w-sub-rel-new        =    spaces
                     go to acc-cod-dpz-999.
      *                  *---------------------------------------------*
      *                  * Visualizzazione valore normalizzato         *
      *                  *---------------------------------------------*
           move      zero                 to   w-dpz-cod-dpz (1)      .
           perform   vis-cod-dpz-000      thru vis-cod-dpz-999        .
           go to     acc-cod-dpz-999.
       acc-cod-dpz-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se riga non new                             *
      *                  *---------------------------------------------*
           if        w-sub-rel-new        not  = spaces
                     go to acc-cod-dpz-450.
      *                      *-----------------------------------------*
      *                      * Il valore non deve essere modificato    *
      *                      *-----------------------------------------*
           if        v-num                not  = w-sub-rel-ppm
                     go to acc-cod-dpz-100.
           go to     acc-cod-dpz-500.
       acc-cod-dpz-450.
      *                  *---------------------------------------------*
      *                  * Se riga new                                 *
      *                  *---------------------------------------------*
       acc-cod-dpz-460.
      *                      *-----------------------------------------*
      *                      * Il valore deve essere compreso tra il   *
      *                      * minimo e il massimo impostabili         *
      *                      *-----------------------------------------*
           if        v-num                <    w-cod-dpz-val-min or
                     v-num                >    w-cod-dpz-val-max
                     go to acc-cod-dpz-100.
       acc-cod-dpz-470.
      *                      *-----------------------------------------*
      *                      * Se non sono previste le dipendenze pa-  *
      *                      * rallele : continuazione senza ulterio-  *
      *                      * ri controlli sul valore impostato       *
      *                      *-----------------------------------------*
           if        w-prs-snx-gdp-snx    not  = "S"
                     go to acc-cod-dpz-500.
       acc-cod-dpz-480.
      *                      *-----------------------------------------*
      *                      * In caso di dipendenze parallele         *
      *                      *-----------------------------------------*
       acc-cod-dpz-485.
      *                          *-------------------------------------*
