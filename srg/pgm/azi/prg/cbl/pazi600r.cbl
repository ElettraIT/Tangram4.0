      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Start su [osd]                                  *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "DATRSM    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      rr-dat-min           to   rf-osd-ide-dat         .
           move      rr-cod-rsm           to   rf-osd-cod-rsm         .
           move      zero                 to   rf-osd-num-prt         .
           move      zero                 to   rf-osd-num-prg         .
           move      "pgm/ods/fls/ioc/obj/iofosd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osd                 .
      *                  *---------------------------------------------*
      *                  * Se start errata : ad uscita                 *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Read Next da [osd]                              *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/ods/fls/ioc/obj/iofosd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osd                 .
      *                  *---------------------------------------------*
      *                  * Se fine file : ad uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Su data documento                           *
      *                  *---------------------------------------------*
           if        rf-osd-ide-dat       >    rr-dat-max
                     go to stp-srt-inp-900.
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Selezione su codice responsabile            *
      *                  *---------------------------------------------*
           if        rr-cod-rsm-sns       =    zero
                     go to stp-srt-inp-432
           else      go to stp-srt-inp-434.
       stp-srt-inp-432.
           if        rr-cod-rsm           not  = zero   and
                     rf-osd-cod-rsm       not  = rr-cod-rsm
                     go to stp-srt-inp-200
           else      go to stp-srt-inp-500.
       stp-srt-inp-434.
           move      zero                 to   w-stp-ctr-ctr-001      .
       stp-srt-inp-436.
           add       1                    to   w-stp-ctr-ctr-001      .
           if        w-stp-ctr-ctr-001    >    36
                     go to stp-srt-inp-200.
           if        rr-cod-rsm-eco
                    (w-stp-ctr-ctr-001)   =    zero
                     go to stp-srt-inp-200.
           if        rr-cod-rsm-eco
                    (w-stp-ctr-ctr-001)   =    rf-osd-cod-rsm
                     go to stp-srt-inp-500
           else      go to stp-srt-inp-436.
       stp-srt-inp-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione [osr]                           *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/ods/fls/ioc/obj/iofosr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osr                 .
      *              *-------------------------------------------------*
      *              * Lettura [osr]                                   *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-osd-num-prt       to   rf-osr-num-prt         .
           move      rf-osd-num-prg       to   rf-osr-num-prg         .
           move      "pgm/ods/fls/ioc/obj/iofosr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osr                 .
       stp-srt-inp-600.
