           perform   acc-tip-doc-000      thru acc-tip-doc-999        .
           if        w-cnt-tus-acc-key    not  = spaces
                     go to acc-key-reg-999.
           if        v-key                =    "UP  "
                     go to acc-key-reg-100.
       acc-key-reg-300.
      *                  *---------------------------------------------*
      *                  * Anno                                        *
      *                  *---------------------------------------------*
           perform   acc-ann-doc-000      thru acc-ann-doc-999        .
           if        w-cnt-tus-acc-key    not  = spaces
                     go to acc-key-reg-999.
           if        v-key                =    "UP  "
                     go to acc-key-reg-200.
       acc-key-reg-800.
      *                  *---------------------------------------------*
