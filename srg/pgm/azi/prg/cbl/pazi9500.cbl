           perform   vis-tip-doc-des-000  thru vis-tip-doc-des-999    .
       acc-are-ges-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-are-ges-999.
           perform   cnt-key-vuo-000      thru cnt-key-vuo-999        .
           if        w-cnt-key-vuo-flg    not  = spaces
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-are-ges-999.
           perform   cnt-tdo-key-000      thru cnt-tdo-key-999        .
           if        w-cnt-tdo-key-flg    not  = spaces
                     go to acc-are-ges-100
           else      move  "S"            to   w-cnt-tus-acc-key
                     go to acc-are-ges-999.
       acc-are-ges-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Area gestionale                   *
      *    *-----------------------------------------------------------*
       vis-are-ges-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-are-ges-lun    to   v-car                  .
           move      w-exp-are-ges-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-are-ges-tbl    to   v-txt                  .
           move      w-tes-are-ges        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-are-ges-999.
           exit.

