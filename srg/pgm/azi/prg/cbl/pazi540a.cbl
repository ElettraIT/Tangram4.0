      *              *-------------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rf-dea-ide-dat         .
           move      s-ute                to   rf-dea-ide-ute         .
           move      s-fas                to   rf-dea-ide-fas         .
           move      rr-num-dst           to   rf-dea-num-dst         .
           move      w-cix-num-ele        to   rf-dea-num-prg         .
           move      s-dat                to   rf-dea-dat-reg         .
           move      zero                 to   rf-dea-tip-dst         .
           move      "C"                  to   rf-dea-tip-arc         .
           move      srt-cod-cli          to   rf-dea-cod-arc         .
           move      srt-dpz-cli          to   rf-dea-dpz-arc         .
           move      zero                 to   rf-dea-tip-ids         .
           move      rr-eml-mit           to   rf-dea-eml-mit         .
           move      srt-eml-ind          to   rf-dea-eml-ind         .
      *        *-------------------------------------------------------*
