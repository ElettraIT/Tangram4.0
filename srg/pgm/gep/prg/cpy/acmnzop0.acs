      *    *===========================================================*
      *    * Subroutines per l'accettazione codice operazione per sca- *
      *    * denze clienti                                             *
      *    *-----------------------------------------------------------*
       cod-mne-zop-opn-000.
           move      "pgm/gep/prg/obj/acmnzop0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           move      s-pat                to   w-cod-mne-zop-pth      .
           move      "OP"                 to   w-cod-mne-zop-ope      .
           perform   cod-mne-zop-cll-000  thru cod-mne-zop-cll-999    .
       cod-mne-zop-opn-999.
           exit.
       cod-mne-zop-cls-000.
           move      "CL"                 to   w-cod-mne-zop-ope      .
           perform   cod-mne-zop-cll-000  thru cod-mne-zop-cll-999    .
           move      "C?"                 to   w-cod-mne-zop-ope      .
           perform   cod-mne-zop-cll-000  thru cod-mne-zop-cll-999    .
           if        w-cod-mne-zop-ope    not  = spaces
                     go to cod-mne-zop-cls-999.
           cancel    w-cod-mne-zop-pth                                .
       cod-mne-zop-cls-999.
           exit.
       cod-mne-zop-foi-000.
           if        v-key                not  = "INSR"
                     go to cod-mne-zop-foi-500.
           move      "P?"                 to   s-ope                  .
           move      "pgep0300"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to cod-mne-zop-foi-999.
           move      "pgm/gep/prg/obj/pgep0300"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
           move      "I+"                 to   w-cod-mne-zop-ope      .
           go to     cod-mne-zop-foi-999.
       cod-mne-zop-foi-500.
           if        v-key                not  = "FIND"
                     go to cod-mne-zop-foi-999.
           move      "P?"                 to   s-ope                  .
           move      "pgep0310"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to cod-mne-zop-foi-999.
           move      "PV"                 to   s-ope                  .
           move      "fkselect"           to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      04                   to   s-car                  .
           move      "SLCT"               to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      "pgm/gep/prg/obj/pgep0310"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
           move      "F+"                 to   w-cod-mne-zop-ope      .
           go to     cod-mne-zop-foi-999.
       cod-mne-zop-foi-999.
           exit.
       cod-mne-zop-cll-000.
           call      w-cod-mne-zop-pth   using w-cod-mne-zop
                                               v
                                               s                      .
       cod-mne-zop-cll-999.
           exit.

