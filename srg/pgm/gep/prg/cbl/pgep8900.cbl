      *    *===========================================================*
      *    * Aggiornamento record [sdb]                                *
      *    *-----------------------------------------------------------*
       agg-rec-sdb-000.
      *              *-------------------------------------------------*
      *              * Test se aggiornamento da effettuare             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su si/no aggiornamento livelli         *
      *                  *---------------------------------------------*
           if        w-num-snx-alv        =    "N"
                     go to agg-rec-sdb-999.
      *                  *---------------------------------------------*
      *                  * Test su livello sollecito                   *
      *                  *---------------------------------------------*
           if        rf-sct-liv-slc       =    zero
                     go to agg-rec-sdb-999.
       agg-rec-sdb-050.
      *              *-------------------------------------------------*
      *              * Ottenimento record [sdb]                        *
      *              *-------------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMSDB    "         to   f-key                  .
           move      rf-scr-num-sdb       to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-rec-sdb-999.
       agg-rec-sdb-100.
      *              *-------------------------------------------------*
      *              * Aggiornamento ultimo livello di sollecito cui   *
      *              * e' stata sottoposta la scadenza                 *
      *              *-------------------------------------------------*
           move      rf-sct-liv-slc       to   rf-sdb-liv-slc         .
      *              *-------------------------------------------------*
      *              * Aggiornamento data ultimo sollecito             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ricerca della prima data libera             *
      *                  *---------------------------------------------*
           if        rf-sdb-dso-l01       =    zero
                     move  w-num-dat-rif  to   rf-sdb-dso-l01
                     go to agg-rec-sdb-200.
           if        rf-sdb-dso-l02       =    zero
                     move  w-num-dat-rif  to   rf-sdb-dso-l02
                     go to agg-rec-sdb-200.
           if        rf-sdb-dso-l03       =    zero
                     move  w-num-dat-rif  to   rf-sdb-dso-l03
                     go to agg-rec-sdb-200.
      *                  *---------------------------------------------*
      *                  * Se non trovata : shift delle date a sini-   *
      *                  * stra e memorizzazione nella terza           *
      *                  *---------------------------------------------*
           move      rf-sdb-dso-l02       to   rf-sdb-dso-l01         .
           move      rf-sdb-dso-l03       to   rf-sdb-dso-l02         .
           move      w-num-dat-rif        to   rf-sdb-dso-l03         .
       agg-rec-sdb-200.
      *              *-------------------------------------------------*
      *              * Update record [sdb]                             *
      *              *-------------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *              *-------------------------------------------------*
