       agg-lot-slc-000.
      *              *-------------------------------------------------*
      *              * Ottenimento record [lotslc]                     *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/inlotslc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-lot-slc             .
      *              *-------------------------------------------------*
      *              * Se record non esistente                         *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to agg-lot-slc-100.
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [lotslc]             *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/inlotslc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-lot-slc             .
      *                  *---------------------------------------------*
      *                  * Scrittura record [lotslc]                   *
      *                  *---------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/inlotslc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-lot-slc             .
      *                  *---------------------------------------------*
      *                  * Riciclo a inizio operazione                 *
      *                  *---------------------------------------------*
           go to     agg-lot-slc-000.
       agg-lot-slc-100.
