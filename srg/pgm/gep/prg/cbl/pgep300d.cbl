           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-tav-ric-999.
      *                      *-----------------------------------------*
      *                      * Se le impostazioni di testata sono gia' *
      *                      * state tutte completate: no accettazione *
      *                      *-----------------------------------------*
           if        w-acc-tes-dis-flg    not  = spaces
                     go to acc-tav-ric-999.
       acc-tav-ric-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tav-ric-lun    to   v-car                  .
           move      w-exp-tav-ric-num    to   v-ldt                  .
           move      spaces               to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      w-exp-tav-ric-tbl    to   v-txt                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      08                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-tav-ric (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
