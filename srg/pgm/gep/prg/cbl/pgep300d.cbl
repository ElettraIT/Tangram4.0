      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-ddp             .
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [numddp]                                  *
      *              *-------------------------------------------------*
           move      w-num-dis-scl-ann    to   rn-num-ddp-scl-ann     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [numddp]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-ddp             .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-num-dis-400.
       att-num-dis-200.
      *              *-------------------------------------------------*
      *              * Se record non esistente                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Scrittura record normalizzato               *
      *                  *---------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-ddp             .
      *                  *---------------------------------------------*
      *                  * Unlock record                               *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-ddp             .
      *                  *---------------------------------------------*
      *                  * Ripetizione dell'intera operazione          *
      *                  *---------------------------------------------*
           go to     att-num-dis-000.
       att-num-dis-400.
      *              *-------------------------------------------------*
      *              * Se record esistente                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore pre-incremento           *
      *                  *---------------------------------------------*
           move      rn-num-ddp-num-ddp   to   w-num-dis-num-dis      .
           move      w-num-dis-r01-num    to   w-num-dis-val-pre      .
      *                  *---------------------------------------------*
      *                  * Preparazione valore post-incremento         *
      *                  *---------------------------------------------*
           move      w-num-dis-val-pre    to   w-num-dis-val-pos      .
           add       1                    to   w-num-dis-val-pos      .
           if        w-num-dis-val-pos    =    zero
                     move  1              to   w-num-dis-val-pos      .
           if        w-num-dis-val-pos    >    9999
                     move  1              to   w-num-dis-val-pos      .
      *                  *---------------------------------------------*
      *                  * Preparazione numero distinta completo       *
      *                  *---------------------------------------------*
           move      w-num-dis-scl-ann    to   w-num-dis-r01-saa      .
           move      w-num-dis-val-pos    to   w-num-dis-r01-num      .
      *                  *---------------------------------------------*
      *                  * Aggiornamento numero distinta               *
      *                  *---------------------------------------------*
           move      w-num-dis-num-dis    to   rn-num-ddp-num-ddp     .
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-ddp             .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'esito dell'opera- *
      *                  * zione di update                             *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-num-dis-600.
       att-num-dis-500.
      *                  *---------------------------------------------*
      *                  * Se errore in operazione di update           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-ddp             .
      *                      *-----------------------------------------*
      *                      * Ripetizione dell'intera operazione      *
      *                      *-----------------------------------------*
           go to     att-num-dis-000.
       att-num-dis-600.
      *                  *---------------------------------------------*
      *                  * Se nessun errore in operazione di update    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-ddp             .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     att-num-dis-999.
       att-num-dis-999.
           exit.

      *    *===========================================================*
      *    * Routine di ripristino numero distinta di presentazione    *
      *    *-----------------------------------------------------------*
       rip-num-dis-000.
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [numddp]                                  *
      *              *-------------------------------------------------*
           move      w-num-dis-scl-ann    to   rn-num-ddp-scl-ann     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [numddp]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-ddp             .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to rip-num-dis-400.
       rip-num-dis-200.
      *              *-------------------------------------------------*
      *              * Se record non esistente                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Unlock record                               *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-ddp             .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     rip-num-dis-999.
       rip-num-dis-400.
      *              *-------------------------------------------------*
      *              * Se record esistente                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Confronto tra il numero distinta attuale    *
      *                  * contenuto nel record numerazioni ed il va-  *
      *                  * lore post-incremento, e deviazione in fun-  *
      *                  * zione dell'esito del test                   *
      *                  *---------------------------------------------*
           move      rn-num-ddp-num-ddp   to   w-num-dis-num-dis      .
           if        w-num-dis-r01-num    =    w-num-dis-val-pos
                     go to rip-num-dis-600.
       rip-num-dis-500.
      *                  *---------------------------------------------*
      *                  * Se numero distinta attuale contenuto nel    *
      *                  * record numerazioni diverso dal valore post- *
      *                  * incremento                                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-ddp             .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rip-num-dis-999.
       rip-num-dis-600.
      *                  *---------------------------------------------*
      *                  * Se numero distinta attuale contenuto nel    *
      *                  * record numerazioni uguale al valore post-   *
      *                  * incremento                                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controaggiornamento del valore attuale  *
      *                      * contenuto nel record numerazioni, ri-   *
      *                      * portandolo al valore pre-incremento     *
      *                      *-----------------------------------------*
           move      w-num-dis-val-pre    to   w-num-dis-r01-num      .
           if        w-num-dis-val-pre    =    zero
                     move  zero           to   w-num-dis-num-dis      .
           move      w-num-dis-num-dis    to   rn-num-ddp-num-ddp     .
      *                      *-----------------------------------------*
      *                      * Update record numerazioni               *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-ddp             .
      *                      *-----------------------------------------*
      *                      * Unlock record numerazioni               *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-ddp             .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rip-num-dis-999.
       rip-num-dis-999.
           exit.

