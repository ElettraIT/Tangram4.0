      *                      *-----------------------------------------*
           if        w-tes-tip-ope        =    0401
                     move  01             to   w-tes-tip-ddp (1)
           else if   w-tes-tip-ope        =    0402
                     move  02             to   w-tes-tip-ddp (1)
           else if   w-tes-tip-ope        =    0403
                     move  03             to   w-tes-tip-ddp (1)
           else if   w-tes-tip-ope        =    0404
                     move  04             to   w-tes-tip-ddp (1)
           else      move  zero           to   w-tes-tip-ddp (1)      .
       rou-let-reg-250.
