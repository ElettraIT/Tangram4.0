      *    *===========================================================*
      *    * Routine post-conferma di annullamento                     *
      *    *-----------------------------------------------------------*
       pos-cnf-ann-000.
      *              *-------------------------------------------------*
      *              * Eliminazione del numero distinta di presenta-   *
      *              * zione da tutte le scadenze appartenenti alla    *
      *              * distinta                                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su scadenze appartenenti alla distin- *
      *                  * ta di presentazione                         *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "DDPNRS    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      w-tes-num-dis        to   rf-sdb-num-ddp         .
           move      zero                 to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Se start errata : a cancellazione record    *
      *                  * della distinta da [ddp]                     *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  pos-cnf-ann-500.
       pos-cnf-ann-100.
      *                  *---------------------------------------------*
      *                  * Next su scadenze appartenenti alla distinta *
      *                  * di presentazione, con lock sul record       *
      *                  *---------------------------------------------*
           move      "GN"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Se at end : a cancellazione record della    *
      *                  * distinta da [ddp]                           *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to pos-cnf-ann-500.
       pos-cnf-ann-150.
      *                  *---------------------------------------------*
      *                  * Test max su su scadenze appartenenti alla   *
      *                  * distinta, se non superato : ad unlock fi-   *
      *                  * nale su [sdb] seguito dalla cancellazione   *
      *                  * record della distinta da [ddp]              *
      *                  *---------------------------------------------*
           if        rf-sdb-num-ddp       not  = w-tes-num-dis
                     go to pos-cnf-ann-400.
       pos-cnf-ann-200.
      *                  *---------------------------------------------*
      *                  * Numero distinta di presentazione in record  *
      *                  * [sdb] a zero                                *
      *                  *---------------------------------------------*
           move      zero                 to   rf-sdb-num-ddp         .
      *                  *---------------------------------------------*
      *                  * Aggiornamento data chiusura scadenza        *
      *                  *---------------------------------------------*
           perform   det-dat-chs-000      thru det-dat-chs-999        .
       pos-cnf-ann-250.
      *                  *---------------------------------------------*
      *                  * Update record [sdb]                         *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
       pos-cnf-ann-300.
      *                  *---------------------------------------------*
      *                  * Unlock [sdb]                                *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
       pos-cnf-ann-350.
      *                  *---------------------------------------------*
      *                  * Riciclo a next su scadenze appartenenti al- *
      *                  * la distinta                                 *
      *                  *---------------------------------------------*
           go to     pos-cnf-ann-100.
       pos-cnf-ann-400.
      *                  *---------------------------------------------*
      *                  * Unlock finale di [sdb]                      *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
       pos-cnf-ann-500.
      *              *-------------------------------------------------*
      *              * Cancellazione record della distinta da [ddp]    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura distinta da [ddp], con lock         *
      *                  *---------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMDDP    "         to   f-key                  .
           move      w-tes-num-dis        to   rf-ddp-num-ddp         .
           move      "pgm/gep/fls/ioc/obj/iofddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddp                 .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'esito della let-  *
      *                  * tura                                        *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to pos-cnf-ann-600.
       pos-cnf-ann-550.
      *                  *---------------------------------------------*
      *                  * Se distinta di presentazione non trovata    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     pos-cnf-ann-999.
       pos-cnf-ann-600.
      *                  *---------------------------------------------*
      *                  * Se distinta di presentazione esistente      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Delete su [ddp]                         *
      *                      *-----------------------------------------*
           move      "DE"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddp                 .
      *                      *-----------------------------------------*
      *                      * Unlock di [ddp]                         *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddp                 .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     pos-cnf-ann-999.
       pos-cnf-ann-999.
           exit.

