      *              *-------------------------------------------------*
           if        w-cat-rig-max        not  = zero
                     go to cnt-tdo-nok-100.
           move      "Non e' stata selezionata nessuna scadenza per la d
      -              "istinta !      "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-100.
      *              *-------------------------------------------------*
      *              * Controllo su tipo avviso richiesto              *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        not  = 0401
                     go to cnt-tdo-nok-125.
           if        w-tes-tav-ric (1)    not  = zero
                     go to cnt-tdo-nok-102.
           move      "Manca il tipo avviso richiesto per le scadenze del
      -              "la distinta !  "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-102.
           if        w-tes-tav-ric (1)    not  > w-exp-tav-ric-num
                     go to cnt-tdo-nok-125.
           move      "Tipo avviso richiesto per le scadenze della distin
      -              "ta errato !    "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-125.
      *              *-------------------------------------------------*
      *              * Controllo su tipi scadenza da includere in di-  *
      *              * stinta                                          *
      *              *-------------------------------------------------*
