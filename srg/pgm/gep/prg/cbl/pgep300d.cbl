       vis-dsc-max-900.
      *              *-------------------------------------------------*
      *              * Per tutti gli altri tipi operazione             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     vis-dsc-max-999.
       vis-dsc-max-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Anche scadenze a vista               *
      *    *-----------------------------------------------------------*
       acc-dsc-vis-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-dsc-vis-025.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se tipo operazione diverso da 0402 e da *
      *                      * 0403 e da 0404 : no accettazione        *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        not  = 0402 and
                     w-tes-tip-ope        not  = 0403 and
                     w-tes-tip-ope        not  = 0404
                     go to acc-dsc-vis-999.
      *                      *-----------------------------------------*
      *                      * Se non si e' in Inserimento : no accet- *
      *                      * tazione                                 *
      *                      *-----------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-dsc-vis-999.
      *                      *-----------------------------------------*
      *                      * Se le impostazioni di testata sono gia' *
      *                      * state tutte completate: no accettazione *
      *                      *-----------------------------------------*
           if        w-acc-tes-dis-flg    not  = spaces
                     go to acc-dsc-vis-999.
       acc-dsc-vis-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-dsc-vis-lun    to   v-car                  .
           move      w-exp-dsc-vis-num    to   v-ldt                  .
           move      "SN#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      w-exp-dsc-vis-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      16                   to   v-lin                  .
           move      30                   to   v-pos                  .
           if        w-tes-dsc-vis (1)    =    "S"
                     move  01             to   v-num
           else if   w-tes-dsc-vis (1)    =    "N"
                     move  01             to   v-num
           else      move  zero           to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-dsc-vis-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-dsc-vis-999.
       acc-dsc-vis-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    01
                     move  "S"            to   w-tes-dsc-vis (1)
           else if   v-num                =    02
                     move  "N"            to   w-tes-dsc-vis (1)
           else      move  zero           to   w-tes-dsc-vis (1)      .
       acc-dsc-vis-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-dsc-vis-425.
      *                  *---------------------------------------------*
      *                  * Test che sia un valore accettabile          *
      *                  *---------------------------------------------*
           if        w-tes-dsc-vis (1)    not  = "S"    and
                     w-tes-dsc-vis (1)    not  = "N"    and
                     w-tes-dsc-vis (1)    not  = spaces
                     go to acc-dsc-vis-100.
       acc-dsc-vis-450.
      *                  *---------------------------------------------*
      *                  * Test che il valore non sia a spaces, a meno *
      *                  * che non si sia in Up                        *
      *                  *---------------------------------------------*
           if        w-tes-dsc-vis (1)    not  = spaces
                     go to acc-dsc-vis-600.
           if        v-key                =    "UP  "
                     go to acc-dsc-vis-600
           else      go to acc-dsc-vis-100.
       acc-dsc-vis-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-dsc-vis-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-dsc-vis-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-dsc-vis-100.
       acc-dsc-vis-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Anche scadenze a vista            *
      *    *-----------------------------------------------------------*
       vis-dsc-vis-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo operazione      *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        =    0402 or
                     w-tes-tip-ope        =    0403 or
                     w-tes-tip-ope        =    0404
                     go to vis-dsc-vis-100
           else      go to vis-dsc-vis-900.
       vis-dsc-vis-100.
      *              *-------------------------------------------------*
      *              * Se tipo operazione : 0402..0404                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-dsc-vis-lun    to   v-car                  .
           move      w-exp-dsc-vis-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-dsc-vis-tbl    to   v-txt                  .
           move      16                   to   v-lin                  .
           move      30                   to   v-pos                  .
           if        w-tes-dsc-vis (1)    =    "S"
                     move  01             to   v-num
           else if   w-tes-dsc-vis (1)    =    "N"
                     move  01             to   v-num
           else      move  zero           to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     vis-dsc-vis-999.
       vis-dsc-vis-900.
      *              *-------------------------------------------------*
      *              * Per tutti gli altri tipi operazione             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     vis-dsc-vis-999.
       vis-dsc-vis-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Circuiti interbancari                *
      *    *                                                           *
      *    * Inibita (01/06/98) - NdK                                  *
      *    *-----------------------------------------------------------*
       acc-cir-itb-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
           go to     acc-cir-itb-999.
       acc-cir-itb-025.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se tipo operazione diverso da 0401 : no *
      *                      * accettazione                            *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        not  = 0401
                     go to acc-cir-itb-999.
      *                      *-----------------------------------------*
      *                      * Se non si e' in Inserimento : no accet- *
      *                      * tazione                                 *
      *                      *-----------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-cir-itb-999.
      *                      *-----------------------------------------*
      *                      * Se le impostazioni di testata sono gia' *
      *                      * state tutte completate: no accettazione *
      *                      *-----------------------------------------*
           if        w-acc-tes-dis-flg    not  = spaces
                     go to acc-cir-itb-999.
       acc-cir-itb-075.
      *                  *---------------------------------------------*
      *                  * Inizializzazione indice 1..5 per scansione  *
      *                  * sui 5 elementi                              *
      *                  *---------------------------------------------*
           move      01                   to   w-acc-cir-itb-inx      .
       acc-cir-itb-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-des-axc-ope      .
           move      w-tes-cod-cib
                    (1, w-acc-cir-itb-inx)
                                          to   w-cod-des-axc-cod      .
           move      17                   to   w-cod-des-axc-lin      .
           move      w-acc-cir-itb-inx    to   w-cod-des-axc-pos      .
           subtract  1                    from w-cod-des-axc-pos      .
           multiply  4                    by   w-cod-des-axc-pos      .
           add       30                   to   w-cod-des-axc-pos      .
           move      zero                 to   w-cod-des-axc-dln      .
           move      zero                 to   w-cod-des-axc-dps      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   cod-des-axc-cll-000  thru cod-des-axc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-des-axc-foi-000  thru cod-des-axc-foi-999    .
       acc-cod-cib-110.
           perform   cod-des-axc-cll-000  thru cod-des-axc-cll-999    .
           if        w-cod-des-axc-ope    =    "F+"
                     go to acc-cod-cib-115.
           if        w-cod-des-axc-ope    =    "AC"
                     go to acc-cod-cib-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-cib-115.
           perform   cod-des-axc-foi-000  thru cod-des-axc-foi-999    .
           go to     acc-cod-cib-110.
       acc-cod-cib-120.
           move      w-cod-des-axc-cod    to   v-alf                  .
       acc-cod-cib-125.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cir-itb-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cir-itb-999.
       acc-cir-itb-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-cod-cib
                                              (1, w-acc-cir-itb-inx)  .
       acc-cir-itb-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-cir-itb-410.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [axc]                      *
      *                  *---------------------------------------------*
           move      w-tes-cod-cib
                    (1, w-acc-cir-itb-inx)
                                          to   w-let-arc-axc-cod      .
           perform   let-arc-axc-000      thru let-arc-axc-999        .
       acc-cir-itb-420.
      *                  *---------------------------------------------*
      *                  * Se record non esistente : a reimpostazione  *
      *                  *---------------------------------------------*
           if        w-let-arc-axc-flg    not  = spaces
                     go to acc-cir-itb-100.
       acc-cir-itb-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cir-itb-610.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tasto di funzio- *
      *                  * ne impostato                                *
      *                  *---------------------------------------------*
           if        v-key                =    spaces
                     go to acc-cir-itb-620
           else if   v-key                =    "DOWN"
                     go to acc-cir-itb-630
           else if   v-key                =    "UP  "
                     go to acc-cir-itb-640
           else      go to acc-cir-itb-690.
       acc-cir-itb-620.
      *                  *---------------------------------------------*
      *                  * Se terminazione con Return                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Compattazione dei cinque circuiti       *
      *                      *-----------------------------------------*
           perform   cpx-cir-itb-000      thru cpx-cir-itb-999        .
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda se la compattazio- *
      *                      * ne ha avuto luogo o no                  *
      *                      *-----------------------------------------*
           if        w-acc-cir-itb-fce    =    spaces
                     go to acc-cir-itb-622
           else      go to acc-cir-itb-624.
       acc-cir-itb-622.
      *                      *-----------------------------------------*
      *                      * Se la compattazione non ha avuto luogo  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se il valore corrispondente all'in- *
      *                          * dice e' a Spaces : uscita con Re-   *
      *                          * turn                                *
      *                          *-------------------------------------*
           if        w-tes-cod-cib
                    (1, w-acc-cir-itb-inx)
                                          =    spaces
                     move  spaces         to   v-key
                     go to acc-cir-itb-800.
      *                          *-------------------------------------*
      *                          * Altrimenti si ricicla all'imposta-  *
      *                          * zione sull' indice successivo, o si *
      *                          * va' alla fine se oltre il massimo   *
      *                          *-------------------------------------*
           add       1                    to   w-acc-cir-itb-inx      .
           if        w-acc-cir-itb-inx    >    5
                     go to acc-cir-itb-800
           else      go to acc-cir-itb-100.
       acc-cir-itb-624.
      *                      *-----------------------------------------*
      *                      * Se la compattazione ha avuto luogo      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Rivisualizzazione                   *
      *                          *-------------------------------------*
           perform   vis-cir-itb-000      thru vis-cir-itb-999        .
      *                          *-------------------------------------*
      *                          * Si ricicla all'impostazione sullo   *
      *                          * stesso indice                       *
      *                          *-------------------------------------*
           go to     acc-cir-itb-100.
       acc-cir-itb-630.
      *                  *---------------------------------------------*
      *                  * Se terminazione con Down                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Compattazione dei cinque circuiti       *
      *                      *-----------------------------------------*
           perform   cpx-cir-itb-000      thru cpx-cir-itb-999        .
      *                      *-----------------------------------------*
      *                      * Eventuale rivisualizzazione, se il com- *
      *                      * pattamento ha avuto luogo               *
      *                      *-----------------------------------------*
           if        w-acc-cir-itb-fce    =    spaces
                     go to acc-cir-itb-632.
           perform   vis-cir-itb-000      thru vis-cir-itb-999        .
       acc-cir-itb-632.
      *                      *-----------------------------------------*
      *                      * Uscita con Down                         *
      *                      *-----------------------------------------*
           move      "DOWN"               to   v-key                  .
           go to     acc-cir-itb-800.
       acc-cir-itb-640.
      *                  *---------------------------------------------*
      *                  * Se terminazione con Up                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Compattazione dei cinque circuiti       *
      *                      *-----------------------------------------*
           perform   cpx-cir-itb-000      thru cpx-cir-itb-999        .
      *                      *-----------------------------------------*
      *                      * Eventuale rivisualizzazione, se il com- *
      *                      * pattamento ha avuto luogo               *
      *                      *-----------------------------------------*
           if        w-acc-cir-itb-fce    =    spaces
                     go to acc-cir-itb-642.
           perform   vis-cir-itb-000      thru vis-cir-itb-999        .
       acc-cir-itb-642.
      *                      *-----------------------------------------*
      *                      * Se indice di scansione a 1 : si esce    *
      *                      * con Up                                  *
      *                      *-----------------------------------------*
           if        w-acc-cir-itb-inx    =    1
                     move  "UP  "         to   v-key
                     go to acc-cir-itb-800.
      *                      *-----------------------------------------*
      *                      * Altrimenti si decrementa l'indice di    *
      *                      * scansione e si ricicla all'impostazione *
      *                      *-----------------------------------------*
           subtract  1                    from w-acc-cir-itb-inx      .
           go to     acc-cir-itb-100.
       acc-cir-itb-690.
      *                  *---------------------------------------------*
      *                  * Se terminazione con altri tasti             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     acc-cir-itb-800.
       acc-cir-itb-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cir-itb-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cir-itb-100.
       acc-cir-itb-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Circuiti interbancari             *
      *    *-----------------------------------------------------------*
       vis-cir-itb-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo operazione      *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        =    0401
                     go to vis-cir-itb-100
           else      go to vis-cir-itb-900.
       vis-cir-itb-100.
      *              *-------------------------------------------------*
      *              * Se tipo operazione : 0401                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione campo da visualizzare          *
      *                  *---------------------------------------------*
       vis-cir-itb-110.
           move      spaces               to   w-vis-cir-itb-edt      .
           move      zero                 to   w-vis-cir-itb-inx      .
       vis-cir-itb-120.
           add       1                    to   w-vis-cir-itb-inx      .
           if        w-vis-cir-itb-inx    >    5
                     go to vis-cir-itb-130.
           move      w-tes-cod-cib
                    (1, w-vis-cir-itb-inx)
                                          to   w-vis-cir-itb-edx
                                              (w-vis-cir-itb-inx)     .
           go to     vis-cir-itb-120.
       vis-cir-itb-130.
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-vis-cir-itb-edt    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     vis-cir-itb-999.
       vis-cir-itb-900.
      *              *-------------------------------------------------*
      *              * Per tutti gli altri tipi operazione             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     vis-cir-itb-999.
       vis-cir-itb-999.
           exit.

      *    *===========================================================*
      *    * Compattazione dei cinque elementi costituenti i circuiti  *
      *    * interbancari                                              *
      *    *-----------------------------------------------------------*
       cpx-cir-itb-000.
      *              *-------------------------------------------------*
      *              * Flag di compattazione eseguita in Off           *
      *              *-------------------------------------------------*
           move      spaces               to   w-acc-cir-itb-fce      .
      *              *-------------------------------------------------*
      *              * Se tutto a Spaces : uscita                      *
      *              *-------------------------------------------------*
           if        w-tes-cir-itb (1)    =    spaces
                     go to cpx-cir-itb-999.
       cpx-cir-itb-100.
      *              *-------------------------------------------------*
      *              * Eventuale compattamento e conseguente set in On *
      *              * del flag di compattazione eseguita              *
      *              *-------------------------------------------------*
           move      zero                 to   w-acc-cir-itb-i01      .
       cpx-cir-itb-200.
           add       1                    to   w-acc-cir-itb-i01      .
           if        w-acc-cir-itb-i01    not < 5
                     go to cpx-cir-itb-999.
           if        w-tes-cod-cib
                    (1, w-acc-cir-itb-i01)
                                          not  = spaces
                     go to cpx-cir-itb-200.
           move      w-acc-cir-itb-i01    to   w-acc-cir-itb-i02      .
       cpx-cir-itb-300.
           add       1                    to   w-acc-cir-itb-i02      .
           if        w-acc-cir-itb-i02    >    5
                     go to cpx-cir-itb-999.
           if        w-tes-cod-cib
                    (1, w-acc-cir-itb-i02)
                                          =    spaces
                     go to cpx-cir-itb-300.
           move      "#"                  to   w-acc-cir-itb-fce      .
           move      w-acc-cir-itb-i01    to   w-acc-cir-itb-i03      .
       cpx-cir-itb-400.
           move      w-tes-cod-cib
                    (1, w-acc-cir-itb-i02)
                                          to   w-tes-cod-cib
                                              (1, w-acc-cir-itb-i03)  .
           add       1                    to   w-acc-cir-itb-i02      .
           add       1                    to   w-acc-cir-itb-i03      .
           if        w-acc-cir-itb-i02    >    5
                     go to cpx-cir-itb-500
           else      go to cpx-cir-itb-400.
       cpx-cir-itb-500.
           move      spaces               to   w-tes-cod-cib
                                              (1, w-acc-cir-itb-i03)  .
           add       1                    to   w-acc-cir-itb-i03      .
           if        w-acc-cir-itb-i02    >    5
                     go to cpx-cir-itb-200
           else      go to cpx-cir-itb-500.
       cpx-cir-itb-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice nostra cassa, nostra banca,   *
      *    *                      nostro c/c postale, per la selezione *
      *    *                      su anagrafiche clienti               *
      *    *-----------------------------------------------------------*
       acc-cod-bpe-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-cod-bpe-025.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se tipo operazione diverso da 0401 : no *
      *                      * accettazione                            *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        not  = 0401
                     go to acc-cod-bpe-999.
      *                      *-----------------------------------------*
      *                      * Se non si e' in Inserimento : no accet- *
      *                      * tazione                                 *
      *                      *-----------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-cod-bpe-999.
      *                      *-----------------------------------------*
      *                      * Se le impostazioni di testata sono gia' *
      *                      * state tutte completate: no accettazione *
      *                      *-----------------------------------------*
           if        w-acc-tes-dis-flg    not  = spaces
                     go to acc-cod-bpe-999.
       acc-cod-bpe-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-des-cbp-ope      .
           move      02                   to   w-cod-des-cbp-tip      .
           move      w-tes-cod-bpe (1)    to   w-cod-des-cbp-cod      .
           move      17                   to   w-cod-des-cbp-lin      .
           move      30                   to   w-cod-des-cbp-pos      .
           move      17                   to   w-cod-des-cbp-dln      .
           move      41                   to   w-cod-des-cbp-dps      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   cod-des-cbp-cll-000  thru cod-des-cbp-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-des-cbp-foi-000  thru cod-des-cbp-foi-999    .
       acc-cod-bpe-110.
           perform   cod-des-cbp-cll-000  thru cod-des-cbp-cll-999    .
           if        w-cod-des-cbp-ope    =    "F+"
                     go to acc-cod-bpe-115.
           if        w-cod-des-cbp-ope    =    "AC"
                     go to acc-cod-bpe-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-bpe-115.
           perform   cod-des-cbp-foi-000  thru cod-des-cbp-foi-999    .
           go to     acc-cod-bpe-110.
       acc-cod-bpe-120.
           move      w-cod-des-cbp-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-bpe-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-bpe-999.
       acc-cod-bpe-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-cod-bpe (1)      .
       acc-cod-bpe-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-cod-bpe-410.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [cbp]                      *
      *                  *---------------------------------------------*
           move      02                   to   w-let-arc-cbp-tip      .
           move      w-tes-cod-bpe (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           if        w-tes-cod-bpe (1)    =    spaces
                     move  "Tutte"        to   w-tes-cod-bpe-des (1)
           else      move  w-let-arc-cbp-des
                                          to   w-tes-cod-bpe-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-cod-bpe-des-000  thru vis-cod-bpe-des-999    .
       acc-cod-bpe-430.
      *                  *---------------------------------------------*
      *                  * Se record non esistente : reimpostazione    *
      *                  * ne                                          *
      *                  *---------------------------------------------*
           if        w-let-arc-cbp-flg    not  = spaces
                     go to acc-cod-bpe-100.
       acc-cod-bpe-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-bpe-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-bpe-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-bpe-100.
       acc-cod-bpe-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice banca per la presentazio-  *
      *    *                         ne, descrizione                   *
      *    *-----------------------------------------------------------*
       vis-cod-bpe-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-bpe (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-bpe-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice banca per la presentazio-  *
      *    *                         ne, descrizione                   *
      *    *-----------------------------------------------------------*
       vis-cod-bpe-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-bpe-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-bpe-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Importo massimo per la distinta      *
      *    *-----------------------------------------------------------*
       acc-imp-max-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-imp-max-025.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se tipo operazione non riconosciuto :   *
      *                      * no accettazione                         *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        not  = 0401 and
                     w-tes-tip-ope        not  = 0402 and
                     w-tes-tip-ope        not  = 0403 and
                     w-tes-tip-ope        not  = 0404
                     go to acc-imp-max-999.
      *                      *-----------------------------------------*
      *                      * Se non si e' in Inserimento : no accet- *
      *                      * tazione                                 *
      *                      *-----------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-imp-max-999.
      *                      *-----------------------------------------*
      *                      * Se le impostazioni di testata sono gia' *
      *                      * state tutte completate: no accettazione *
      *                      *-----------------------------------------*
           if        w-acc-tes-dis-flg    not  = spaces
                     go to acc-imp-max-999.
       acc-imp-max-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<GB"                to   v-edm                  .
           move      20                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      w-tes-imp-max (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-imp-max-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-imp-max-999.
       acc-imp-max-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-imp-max (1)      .
       acc-imp-max-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-imp-max-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-imp-max-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-imp-max-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-imp-max-100.
       acc-imp-max-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Importo massimo per la distinta   *
      *    *-----------------------------------------------------------*
       vis-imp-max-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo operazione      *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        =    0401 or
                     w-tes-tip-ope        =    0402 or
                     w-tes-tip-ope        =    0403 or
                     w-tes-tip-ope        =    0404
                     go to vis-imp-max-100
           else      go to vis-imp-max-900.
       vis-imp-max-100.
      *              *-------------------------------------------------*
      *              * Se tipo operazione : 0401..0404                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<GB"                to   v-edm                  .
           move      20                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-imp-max (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     vis-imp-max-999.
       vis-imp-max-900.
      *              *-------------------------------------------------*
      *              * Per tutti gli altri tipi operazione             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     vis-imp-max-999.
       vis-imp-max-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Presa visione per pagina     *
      *    *-----------------------------------------------------------*
       acc-pre-vpg-000.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del tipo funzionamento     *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "I"
                     go to acc-pre-vpg-100
           else      go to acc-pre-vpg-300.
       acc-pre-vpg-100.
      *              *-------------------------------------------------*
      *              * Se in Inserimento                               *
      *              *-------------------------------------------------*
       acc-pre-vpg-125.
      *                  *---------------------------------------------*
      *                  * Test se il caricamento delle righe della    *
      *                  * distinta e' gia' stato effettuato, e con-   *
      *                  * seguente deviazione                         *
      *                  *---------------------------------------------*
           if        w-acc-tes-dis-flg    =    spaces
                     go to acc-pre-vpg-150
           else      go to acc-pre-vpg-225.
       acc-pre-vpg-150.
      *                  *---------------------------------------------*
      *                  * Se il caricamento delle righe della distin- *
      *                  * ta non e' ancora stato effettuato           *
      *                  *---------------------------------------------*
       acc-pre-vpg-155.
      *                     *------------------------------------------*
      *                     * Caricamento righe della distinta tramite *
      *                     * selezione sui parametri impostati        *
      *                     *------------------------------------------*
       acc-pre-vpg-156.
      *                         *--------------------------------------*
      *                         * Preparazione routine                 *
      *                         *--------------------------------------*
      *                             *----------------------------------*
      *                             * Data composizione distinta       *
      *                             *----------------------------------*
           move      w-tes-dat-reg        to   w-loa-sdb-inp-dcd      .
      *                             *----------------------------------*
      *                             * Tipo distinta                    *
      *                             *----------------------------------*
           if        w-tes-tip-ope        =    0401
                     move  01             to   w-loa-sdb-inp-tdd
           else if   w-tes-tip-ope        =    0402
                     move  02             to   w-loa-sdb-inp-tdd
           else if   w-tes-tip-ope        =    0403
                     move  03             to   w-loa-sdb-inp-tdd
           else if   w-tes-tip-ope        =    0404
                     move  04             to   w-loa-sdb-inp-tdd
           else      move  zero           to   w-loa-sdb-inp-tdd      .
      *                             *----------------------------------*
      *                             * Tipo avviso richiesto se distin- *
      *                             * ta per incassi elettronici       *
      *                             *----------------------------------*
           if        w-loa-sdb-inp-tdd    =    01
                     move  w-tes-tav-ric (1)
                                          to   w-loa-sdb-inp-tar
           else      move  zero           to   w-loa-sdb-inp-tar      .
      *                             *----------------------------------*
      *                             * Tipi di scadenza da includere in *
      *                             * distinta                         *
      *                             *----------------------------------*
           move      w-tes-tsc-das (1)    to   w-loa-sdb-inp-tsd      .
      *                             *----------------------------------*
      *                             * Data scadenza minima da selezio- *
      *                             * nare                             *
      *                             *----------------------------------*
           move      w-tes-dsc-min (1)    to   w-loa-sdb-inp-smi      .
      *                             *----------------------------------*
      *                             * Data scadenza massima da sele-   *
      *                             * zionare                          *
      *                             *----------------------------------*
           move      w-tes-dsc-max (1)    to   w-loa-sdb-inp-sma      .
      *                             *----------------------------------*
      *                             * Anche scadenze a vista da sele-  *
      *                             * zionare                          *
      *                             *----------------------------------*
           move      w-tes-dsc-vis (1)    to   w-loa-sdb-inp-asv      .
      *                             *----------------------------------*
      *                             * Codice nostra banca              *
      *                             *----------------------------------*
           move      w-tes-cod-bpe (1)    to   w-loa-sdb-inp-cbp      .
      *                             *----------------------------------*
      *                             * Numero di scadenze massimo da    *
      *                             * selezionare                      *
      *                             *----------------------------------*
           move      900                  to   w-loa-sdb-inp-nsm      .
      *                             *----------------------------------*
      *                             * Importo massimo da selezionare   *
      *                             *----------------------------------*
           move      w-tes-imp-max (1)    to   w-loa-sdb-inp-igm      .
       acc-pre-vpg-157.
      *                         *--------------------------------------*
      *                         * Richiamo routine di caricamento      *
      *                         *--------------------------------------*
           perform   loa-sdb-sel-000      thru loa-sdb-sel-999        .
       acc-pre-vpg-160.
      *                     *------------------------------------------*
      *                     * Deviazione a seconda dell'esito del ca-  *
      *                     * ricamento                                *
      *                     *------------------------------------------*
           if        w-loa-sdb-out-flg    =    zero
                     go to acc-pre-vpg-175
           else      go to acc-pre-vpg-200.
       acc-pre-vpg-175.
      *                     *------------------------------------------*
      *                     * Se caricamento completato con selezione  *
      *                     *------------------------------------------*
      *                         *--------------------------------------*
      *                         * Flag di completamento accettazione   *
      *                         * testata e conseguente precaricamento *
      *                         * delle righe della distinta di pre-   *
      *                         * sentazione in On                     *
      *                         *--------------------------------------*
           move      "#"                  to   w-acc-tes-dis-flg      .
      *                         *--------------------------------------*
      *                         * Preparazione importo effettivo della *
      *                         * distinta da importo globale selezio- *
      *                         * nato                                 *
      *                         *--------------------------------------*
           move      w-loa-sdb-out-igs    to   w-tes-imp-ddp (1)      .
      *                         *--------------------------------------*
      *                         * Preparazione uscita per Ok           *
      *                         *--------------------------------------*
           move      spaces               to   v-key                  .
      *                         *--------------------------------------*
      *                         * Uscita                               *
      *                         *--------------------------------------*
           go to     acc-pre-vpg-999.
       acc-pre-vpg-200.
      *                     *------------------------------------------*
      *                     * Se caricamento completato con errori o   *
      *                     * senza selezione                          *
      *                     *------------------------------------------*
      *                         *--------------------------------------*
      *                         * Flag di completamento accettazione   *
      *                         * testata e conseguente precaricamento *
      *                         * delle righe della distinta di pre-   *
      *                         * sentazione in On                     *
      *                         *--------------------------------------*
           move      "#"                  to   w-acc-tes-dis-flg      .
      *                         *--------------------------------------*
      *                         * Preparazione importo effettivo della *
      *                         * distinta a zero                      *
      *                         * nato                                 *
      *                         *--------------------------------------*
           move      zero                 to   w-tes-imp-ddp (1)      .
      *                         *--------------------------------------*
      *                         * Preparazione uscita per Ok           *
      *                         *--------------------------------------*
           move      spaces               to   v-key                  .
      *                         *--------------------------------------*
      *                         * Uscita                               *
      *                         *--------------------------------------*
           go to     acc-pre-vpg-999.
       acc-pre-vpg-225.
      *                  *---------------------------------------------*
      *                  * Se il caricamento delle righe della distin- *
      *                  * ta e' gia' stato effettuato                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ad accettazione                         *
      *                      *-----------------------------------------*
           go to     acc-pre-vpg-600.
       acc-pre-vpg-300.
      *              *-------------------------------------------------*
      *              * Se in Modifica o Visualizzazione                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ad accettazione                             *
      *                  *---------------------------------------------*
           go to     acc-pre-vpg-600.
       acc-pre-vpg-600.
      *              *-------------------------------------------------*
      *              * Accettazione valore per presa visione           *
      *              *-------------------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      spaces               to   v-msk                  .
           move      spaces               to   v-alf                  .
           move      spaces               to   v-not                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           if        w-cnt-sts-imp-npt    >    1
                     move  "PRSC"         to   v-pfk (07)             .
           move      "NXSC"               to   v-pfk (08)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vpg-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vpg-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pre-vpg-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pre-vpg-000.
       acc-pre-vpg-999.
           exit.

      *    *===========================================================*
      *    * Accettazione corpo a partire dalla riga con numero d'or-  *
      *    * dine : w-cnt-cor-nrg-dac                                  *
      *    *-----------------------------------------------------------*
       acc-cor-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione tipo uscita da corpo            *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-cor      .
      *              *-------------------------------------------------*
      *              * Confronto tra numero d'ordine riga da accettare *
      *              * e numero d'ordine dell'ultima riga              *
      *              *-------------------------------------------------*
           if        w-cnt-cor-nrg-dac    not  > w-cat-rig-max
                     go to acc-cor-reg-025.
      *              *-------------------------------------------------*
      *              * Se oltre numero riga massimo e Append non pos-  *
      *              * sibile si esce con status di uscita "+"         *
      *              *-------------------------------------------------*
           if        w-cat-rig-app        not  = spaces
                     move  "+"            to   w-cnt-tus-acc-cor
                     go to acc-cor-reg-990.
      *              *-------------------------------------------------*
      *              * Se oltre numero riga massimo e Append possibile *
      *              * si esegue l'operazione di Append                *
      *              *-------------------------------------------------*
           move      w-cat-rig-max        to   w-cnt-cor-nrg-dac      .
           add       1                    to   w-cnt-cor-nrg-dac      .
           move      "AP"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       acc-cor-reg-025.
      *              *-------------------------------------------------*
      *              * Video in 'OFF'                                  *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Prompts per corpo                               *
      *              *-------------------------------------------------*
           if        w-cnt-sts-pmt-cor    =    spaces
                     perform pmt-cor-reg-000
                                          thru pmt-cor-reg-999
                     move    "#"          to   w-cnt-sts-pmt-cor      .
      *              *-------------------------------------------------*
      *              * Visualizzazione dati corpo                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione nr pagina da visualizzare    *
      *                  *---------------------------------------------*
           move      w-cnt-cor-nrg-dac    to   w-cnt-cor-nrp-dav      .
           add       w-lin-num-lin-vis    to   w-cnt-cor-nrp-dav      .
           subtract  1                    from w-cnt-cor-nrp-dav      .
           divide    w-lin-num-lin-vis    into w-cnt-cor-nrp-dav      .
      *                  *---------------------------------------------*
      *                  * Se non e' visualizzata nessuna pagina corpo *
      *                  * o una pagina corpo diversa da quella da vi- *
      *                  * sualizzare si procede alla visualizzazione  *
      *                  *---------------------------------------------*
           if        w-cnt-sts-vis-cor    =    spaces           or
                     w-cnt-cor-nrp-vis    not  = w-cnt-cor-nrp-dav
                     perform vis-cor-reg-000
                                          thru vis-cor-reg-999
                     move    "#"          to   w-cnt-sts-vis-cor
                     move    w-cnt-cor-nrp-dav
                                          to   w-cnt-cor-nrp-vis      .
      *              *-------------------------------------------------*
      *              * Lettura riga da catena                          *
      *              *-------------------------------------------------*
           move      "RD"                 to   w-cat-rig-ope          .
           move      w-cnt-cor-nrg-dac    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se riga nuova si normalizza il corpo            *
      *              *-------------------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to acc-cor-reg-050.
           perform   nor-nok-rig-000      thru nor-nok-rig-999        .
           move      w-rig-val-aep (1)    to   w-rig-val-aep (2)      .
       acc-cor-reg-050.
      *              *-------------------------------------------------*
      *              * Routine pre-accettazione riga corpo             *
      *              *-------------------------------------------------*
           perform   pre-rig-cor-000      thru pre-rig-cor-999        .
      *              *-------------------------------------------------*
