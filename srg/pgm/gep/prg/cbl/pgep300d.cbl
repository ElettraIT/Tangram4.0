      *                      * modifica, utente, fase                  *
      *                      *-----------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-tes-ide-dat (1)      .
           move      s-ute                to   w-tes-ide-ute (1)      .
           move      s-fas                to   w-tes-ide-fas (1)      .
      *                      *-----------------------------------------*
      *                      * Duplicazione dei valori attuali nei va- *
      *                      * lori precedenti per la testata          *
      *                      *-----------------------------------------*
           move      w-tes-val-aep (1)    to   w-tes-val-aep (2)      .
       rou-let-reg-500.
      *                      *-----------------------------------------*
      *                      * Controlli per forzare eventualmente la  *
      *                      * sola visualizzazione, e segnalazioni    *
      *                      * conseguenti                             *
      *                      *-----------------------------------------*
       rou-let-reg-505.
      *                          *-------------------------------------*
      *                          * Su operazione di composizione di-   *
      *                          * stinta                              *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Controllo di congruenza tra il  *
      *                              * tipo operazione ed il tipo di   *
      *                              * distinta; se errore : messaggio *
      *                              * di errore ed uscita             *
      *                              *---------------------------------*
           if        w-tes-tip-ope        =    0401 and
                     w-tes-tip-ddp (1)    =    01
                     go to rou-let-reg-550
           else if   w-tes-tip-ope        =    0402 and
                     w-tes-tip-ddp (1)    =    02
                     go to rou-let-reg-550
           else if   w-tes-tip-ope        =    0403 and
                     w-tes-tip-ddp (1)    =    03
                     go to rou-let-reg-550
           else if   w-tes-tip-ope        =    0404 and
                     w-tes-tip-ddp (1)    =    04
                     go to rou-let-reg-550
           else      go to rou-let-reg-510.
       rou-let-reg-510.
           if        w-tes-tip-ddp (1)    =    01
                     go to rou-let-reg-511
           else if   w-tes-tip-ddp (1)    =    02
                     go to rou-let-reg-512
           else if   w-tes-tip-ddp (1)    =    03
                     go to rou-let-reg-513
           else if   w-tes-tip-ddp (1)    =    04
                     go to rou-let-reg-514
           else      go to rou-let-reg-515.
       rou-let-reg-511.
           move      "Tipo operazione non congruente con il tipo di dist
      -              "inta.          "    to   w-err-box-err-msg      .
           move      "La distinta richiamata e' una Distinta Incassi Ele
      -              "ttronici.      "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           move      "#"                  to   w-cnt-rou-let-reg      .
           go to     rou-let-reg-999.
       rou-let-reg-512.
           move      "Tipo operazione non congruente con il tipo di dist
      -              "inta.          "    to   w-err-box-err-msg      .
           move      "La distinta richiamata e' una Distinta Effetti.   
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           move      "#"                  to   w-cnt-rou-let-reg      .
           go to     rou-let-reg-999.
       rou-let-reg-513.
           move      "Tipo operazione non congruente con il tipo di dist
      -              "inta.          "    to   w-err-box-err-msg      .
           move      "La distinta richiamata e' una Distinta Paghero' Ca
      -              "mbiari.        "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           move      "#"                  to   w-cnt-rou-let-reg      .
           go to     rou-let-reg-999.
       rou-let-reg-514.
           move      "Tipo operazione non congruente con il tipo di dist
      -              "inta.          "    to   w-err-box-err-msg      .
           move      "La distinta richiamata e' una Distinta Cessioni.  
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           move      "#"                  to   w-cnt-rou-let-reg      .
           go to     rou-let-reg-999.
       rou-let-reg-515.
           move      "Tipo operazione non congruente con il tipo di dist
      -              "inta.          "    to   w-err-box-err-msg      .
           move      "La distinta richiamata e' di tipo sconosciuto.    
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           move      "#"                  to   w-cnt-rou-let-reg      .
           go to     rou-let-reg-999.
       rou-let-reg-550.
      *                          *-------------------------------------*
