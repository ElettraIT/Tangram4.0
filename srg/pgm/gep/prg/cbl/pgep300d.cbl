           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       esp-arc-sdb-200.
      *              *-------------------------------------------------*
      *              * Scrittura variabile di i.p.c. 'snx-slc' per il  *
      *              * livello successivo per l'ammissibilita' del ta- *
      *              * sto Slct                                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se non ammesso : no scrittura               *
      *                  *---------------------------------------------*
           if        w-esp-arc-sdb-sns    not  = "S"
                     go to esp-arc-sdb-250.
      *                  *---------------------------------------------*
      *                  * Scrittura effettiva                         *
      *                  *---------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "snx-slc"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      01                   to   s-car                  .
           move      "S"                  to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       esp-arc-sdb-250.
      *              *-------------------------------------------------*
      *              * Richiamo del programma di interrogazione        *
      *              *-------------------------------------------------*
           move      "pgm/gep/prg/obj/pgep3010"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
       esp-arc-sdb-300.
      *              *-------------------------------------------------*
      *              * Cancellazione del programma di interrogazione   *
      *              *-------------------------------------------------*
           cancel    s-pat                                            .
       esp-arc-sdb-350.
      *              *-------------------------------------------------*
      *              * Determinazione selezione avvenuta               *
      *              *-------------------------------------------------*
       esp-arc-sdb-355.
      *                  *---------------------------------------------*
      *                  * Se non era ammessa la selezioone : uscita   *
      *                  *---------------------------------------------*
           if        w-esp-arc-sdb-sns    not  = "S"
                     go to esp-arc-sdb-999.
       esp-arc-sdb-360.
      *                  *---------------------------------------------*
      *                  * Lettura variabile di i.p.c. 'num-sdb' dal   *
      *                  * livello successivo per numero scadenza se-  *
      *                  * lezionato                                   *
      *                  *---------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "num-sdb"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'esito della let-  *
      *                  * tura                                        *
      *                  *---------------------------------------------*
           if        s-ves                =    spaces
                     go to esp-arc-sdb-365
           else      go to esp-arc-sdb-370.
       esp-arc-sdb-365.
      *                  *---------------------------------------------*
      *                  * Se variabile esistente                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di selezione avvenuta              *
      *                      *-----------------------------------------*
           move      spaces               to   w-esp-arc-sdb-sel      .
      *                      *-----------------------------------------*
      *                      * Numero scadenza selezionata             *
      *                      *-----------------------------------------*
           move      s-num                to   w-esp-arc-sdb-num      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     esp-arc-sdb-999.
       esp-arc-sdb-370.
      *                  *---------------------------------------------*
      *                  * Se variabile non esistente                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     esp-arc-sdb-999.
       esp-arc-sdb-999.
           exit.

      *    *===========================================================*
      *    * Determinazione status scadenza                            *
      *    *-----------------------------------------------------------*
       det-dat-chs-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione data scadenza chiusa a : Aper- *
      *              * ta                                              *
      *              *-------------------------------------------------*
           move      9999999              to   rf-sdb-dat-chs         .
       det-dat-chs-020.
      *              *-------------------------------------------------*
      *              * Controllo su : Insoluto                         *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-isp       =    zero
                     go to det-dat-chs-040.
      *                  *---------------------------------------------*
      *                  * Se la scadenza e' stata riscossa : oltre    *
      *                  *---------------------------------------------*
           if        rf-sdb-num-ris       not  = zero
                     go to det-dat-chs-040.
      *                  *---------------------------------------------*
      *                  * Se a fronte dell'insoluto non e' stata e-   *
      *                  * messa una nuova scadenza, essa e' da inten- *
      *                  * dersi ancora aperta                         *
      *                  *---------------------------------------------*
           if        rf-sdb-ens-isp       =    02   and
                     rf-sdb-nns-isp       =    zero
                     go to det-dat-chs-999.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-isp       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-040.
      *              *-------------------------------------------------*
      *              * Controllo su : Presunto buon esito              *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-pbe       =     zero
                     go to det-dat-chs-060.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-pbe       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-060.
      *              *-------------------------------------------------*
      *              * Controllo su : Presunto buon esito              *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-nbe       =     zero
                     go to det-dat-chs-080.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-nbe       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-080.
      *              *-------------------------------------------------*
      *              * Controllo su : Accredito scadenza al dopo in-   *
      *              *                casso                            *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-acs       =     zero
                     go to det-dat-chs-100.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-acs       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-100.
      *              *-------------------------------------------------*
      *              * Controllo su : Richiamo della scadenza presen-  *
      *              *                tata                             *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-rsp       =     zero
                     go to det-dat-chs-120.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-rsp       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-120.
      *              *-------------------------------------------------*
      *              * Controllo su : Inclusione in distinta           *
      *              *-------------------------------------------------*
           if        rf-sdb-num-ddp       =     zero
                     go to det-dat-chs-140.
      *                  *---------------------------------------------*
      *                  * Nessuna azione                              *
      *                  *---------------------------------------------*
           go to     det-dat-chs-140.
       det-dat-chs-140.
      *              *-------------------------------------------------*
      *              * Controllo su : Riscossione                      *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-ris       =     zero
                     go to det-dat-chs-160.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-ris       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-160.
      *              *-------------------------------------------------*
      *              * Controllo su : Storno                           *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-sto       =     zero
                     go to det-dat-chs-180.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-sto       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-180.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-999.
           exit.

      *    *===========================================================*
      *    * Caricamento iniziale scadenze per distinta per mezzo del- *
      *    * la selezione sui parametri di selezione                   *
      *    *-----------------------------------------------------------*
       loa-sdb-sel-000.
      *              *-------------------------------------------------*
      *              * Esecuzione mediante sort, per fare in modo di   *
      *              * ottenere le scadenze sempre con lo stesso or-   *
      *              * dinamento, sia in inserimento che in modifica   *
      *              *-------------------------------------------------*
           sort      so1                  on   ascending so1-key
                     input  procedure     is   loa-sdb-ipr-000
                                          thru loa-sdb-ipr-999
                     output procedure     is   loa-sdb-opr-000
                                          thru loa-sdb-opr-999        .
       loa-sdb-sel-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per il caricamento iniziale scadenze per  *
      *    * distinta per mezzo della selezione sui parametri di sele- *
      *    * zione                                                     *
      *    *-----------------------------------------------------------*
       loa-sdb-ipr-000.
      *              *-------------------------------------------------*
      *              * Preparazioni preliminari                        *
      *              *-------------------------------------------------*
       loa-sdb-ipr-010.
      *                  *---------------------------------------------*
      *                  * Messaggio di caricamento in esecuzione      *
      *                  *---------------------------------------------*
           move      "  Selezione scadenze da includere nella distinta i
      -              "n esecuzione   "
                                          to   w-err-box-err-msg      .
           perform   msg-cnt-box-000      thru msg-cnt-box-999        .
       loa-sdb-ipr-020.
      *                  *---------------------------------------------*
      *                  * Normalizzazione parametri in uscita         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag fondamentale di uscita a Ok        *
      *                      *-----------------------------------------*
           move      zero                 to   w-loa-sdb-out-flg      .
      *                      *-----------------------------------------*
      *                      * Flag di interruzione forzata da parte   *
      *                      * dell'operatore in risposta ad un mes-   *
      *                      * saggio di errore o anomalia : a No      *
      *                      *-----------------------------------------*
           move      spaces               to   w-loa-sdb-out-fin      .
      *                      *-----------------------------------------*
      *                      * Numero di scadenze selezionate : a zero *
      *                      *-----------------------------------------*
           move      zero                 to   w-loa-sdb-out-nss      .
      *                      *-----------------------------------------*
      *                      * Importo globale selezionato : a zero    *
      *                      *-----------------------------------------*
           move      zero                 to   w-loa-sdb-out-igs      .
       loa-sdb-ipr-030.
      *                  *---------------------------------------------*
      *                  * Preparazione parametri di selezione per le  *
      *                  * routines di selezione sulle scadenze lette  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Data composizione distinta              *
      *                      *-----------------------------------------*
           move      w-loa-sdb-inp-dcd    to   w-sel-sdb-inp-dcd      .
      *                      *-----------------------------------------*
      *                      * Tipo di distinta                        *
      *                      *-----------------------------------------*
           move      w-loa-sdb-inp-tdd    to   w-sel-sdb-inp-tdd      .
      *                      *-----------------------------------------*
      *                      * Tipo di avviso richiesto se distinta    *
      *                      * per incassi elettronici                 *
      *                      *-----------------------------------------*
           move      w-loa-sdb-inp-tar    to   w-sel-sdb-inp-tar      .
      *                      *-----------------------------------------*
      *                      * Tipi di scadenza da includere in di-    *
      *                      * stinta                                  *
      *                      *-----------------------------------------*
           move      w-loa-sdb-inp-tsd    to   w-sel-sdb-inp-tsd      .
      *                      *-----------------------------------------*
      *                      * Data scadenza minima da selezionare     *
      *                      *-----------------------------------------*
           move      w-loa-sdb-inp-smi    to   w-sel-sdb-inp-smi      .
      *                      *-----------------------------------------*
      *                      * Data scadenza massima da selezionare    *
      *                      *-----------------------------------------*
           move      w-loa-sdb-inp-sma    to   w-sel-sdb-inp-sma      .
      *                      *-----------------------------------------*
      *                      * Anche scadenze a vista da selezionare   *
      *                      *-----------------------------------------*
           move      w-loa-sdb-inp-asv    to   w-sel-sdb-inp-asv      .
      *                      *-----------------------------------------*
      *                      * Codice nostra banca                     *
      *                      *-----------------------------------------*
           move      w-loa-sdb-inp-cbp    to   w-sel-sdb-inp-cbp      .
       loa-sdb-ipr-200.
      *              *-------------------------------------------------*
      *              * Selezione scadenze con data scadenza a vista    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se tipo distinta diverso da 02 e da 03 e da *
      *                  * 04 : no scadenze a vista, a caricamento     *
      *                  * scadenze non a vista                        *
      *                  *---------------------------------------------*
           if        w-loa-sdb-inp-tdd    not  = 02 and
                     w-loa-sdb-inp-tdd    not  = 03 and
                     w-loa-sdb-inp-tdd    not  = 04
                     go to loa-sdb-ipr-500.
      *                  *---------------------------------------------*
      *                  * Se non e' stata scelta l'inclusione anche   *
      *                  * delle scadenze a vista : no scadenze a vi-  *
      *                  * sta, a caricamento scadenze non a vista     *
      *                  *---------------------------------------------*
           if        w-loa-sdb-inp-asv    not  = "S"
                     go to loa-sdb-ipr-500.
       loa-sdb-ipr-225.
      *                  *---------------------------------------------*
      *                  * Se flag di interruzione forzata da parte    *
      *                  * dell'operatore : a fine caricamento         *
      *                  *---------------------------------------------*
           if        w-loa-sdb-out-fin    not  = spaces
                     go to loa-sdb-ipr-800.
      *                  *---------------------------------------------*
      *                  * Start su scadenze a vista                   *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "DTSNRS    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      zero                 to   rf-sdb-dts-sdb         .
           move      zero                 to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Se start errata si va' alla fine del cari-  *
      *                  * camento scadenze a vista e non a vista      *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to loa-sdb-ipr-800.
       loa-sdb-ipr-250.
      *                  *---------------------------------------------*
      *                  * Se flag di interruzione forzata da parte    *
      *                  * dell'operatore : a fine caricamento         *
      *                  *---------------------------------------------*
           if        w-loa-sdb-out-fin    not  = spaces
                     go to loa-sdb-ipr-800.
      *                  *---------------------------------------------*
      *                  * Next su scadenze a vista                    *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Se at end si va' alla fine del caricamento  *
      *                  * scadenze a vista e non a vista              *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to loa-sdb-ipr-800.
       loa-sdb-ipr-275.
      *                  *---------------------------------------------*
      *                  * Max su scadenze a vista : se la data sca-   *
      *                  * denza della scadenza letta non e' a vista   *
      *                  * si va' al caricamento scadenze non a vista  *
      *                  *---------------------------------------------*
           if        rf-sdb-dts-sdb       not  = zero
                     go to loa-sdb-ipr-500.
       loa-sdb-ipr-300.
      *                  *---------------------------------------------*
      *                  * Selezioni su scadenza letta, se non supera- *
      *                  * te si va' a Next su scadenze a vista        *
      *                  *---------------------------------------------*
       loa-sdb-ipr-305.
      *                      *-----------------------------------------*
      *                      * Inizializzazione subroutines di sele-   *
      *                      * zione sulle scadenze                    *
      *                      *-----------------------------------------*
           perform   sel-000-sdb-000      thru sel-000-sdb-999        .
      *                      *-----------------------------------------*
      *                      * Selezione su :                          *
      *                      * - Tipo di scadenza, che sia riconosciu- *
      *                      *   to                                    *
      *                      * - Tipo di distinta, che sia riconosciu- *
      *                      *   to                                    *
      *                      * - Tipo di avviso richiesto, che sia ri- *
      *                      *   conosciuto                            *
      *                      * - Tipo di scadenza, che sia ammissibile *
      *                      *   per il tipo di distinta               *
      *                      * - Tipo di scadenza, che sia ammissibile *
      *                      *   per il tipo di avviso richiesto       *
      *                      * - Tipo di acquisizione della scadenza,  *
      *                      *   che sia ammissibile per il tipo di    *
      *                      *   distinta                              *
      *                      * - Data di registrazione movimento di    *
      *                      *   emissione scadenza, che non sia su-   *
      *                      *   periore alla data di composizione     *
      *                      *   della distinta                        *
      *                      * - Importo della scadenza, che sia mag-  *
      *                      *   giore di zero                         *
      *                      * - Status della scadenza, che non abbia  *
      *                      *   avuto movimenti successivi a quello   *
      *                      *   di emissione                          *
      *                      *-----------------------------------------*
           perform   sel-100-sdb-000      thru sel-100-sdb-999        .
      *                      *-----------------------------------------*
      *                      * Selezione su :                          *
      *                      * - Tipo di scadenza, che sia nell'elenco *
      *                      *   dei tipi scadenza da includere        *
      *                      * - Data di scadenza, diversa da scadenza *
      *                      *   a vista, che sia compresa tra la data *
      *                      *   di scadenza minima e la data di sca-  *
      *                      *   denza massima da selezionare          *
      *                      * - Data di scadenza, se a vista, che sia *
      *                      *   prevista come data scadenza da sele-  *
      *                      *   zionare                               *
      *                      *-----------------------------------------*
           perform   sel-300-sdb-000      thru sel-300-sdb-999        .
      *                      *-----------------------------------------*
      *                      * Selezione su :                          *
      *                      * - Codice ABI, che sia presente se ne-   *
      *                      *   cessario, e che trovi corrispondenza  *
      *                      *   nell'archivio istituti di credito     *
      *                      * - Codice CAB, che sia presente se ne-   *
      *                      *   cessario, e che trovi corrispondenza  *
      *                      *   nell'archivio sportelli istituti di   *
      *                      *   credito                               *
      *                      * - Codice c/c di presentazione, che sia  *
      *                      *   presente se necessario                *
      *                      *-----------------------------------------*
           perform   sel-500-sdb-000      thru sel-500-sdb-999        .
      *                      *-----------------------------------------*
      *                      * Selezione su :                          *
      *                      * - Circuiti interbancari, se necessario  *
      *                      *-----------------------------------------*
           perform   sel-700-sdb-000      thru sel-700-sdb-999        .
       loa-sdb-ipr-310.
      *                      *-----------------------------------------*
      *                      * Se selezione non superata per mancata   *
      *                      * selezione o errore su selezione : si    *
      *                      * ignora la scadenza. In caso di errore   *
      *                      * si emette anche un messaggio.           *
      *                      *-----------------------------------------*
           if        w-sel-sdb-out-fer    not  = zero or
                     w-sel-sdb-out-fse    not  = zero
                     go to loa-sdb-ipr-311
           else      go to loa-sdb-ipr-325.
       loa-sdb-ipr-311.
           if        w-sel-sdb-out-fer    =    zero
                     go to loa-sdb-ipr-312.
           perform   loa-sdb-vea-000      thru loa-sdb-vea-999        .
       loa-sdb-ipr-312.
           go to     loa-sdb-ipr-250.
       loa-sdb-ipr-325.
      *                  *---------------------------------------------*
      *                  * Selezioni sulla globalita' della distinta   *
      *                  *---------------------------------------------*
       loa-sdb-ipr-330.
      *                      *-----------------------------------------*
      *                      * Selezione su numero massimo di scadenze *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Simulazione numero di scadenze se-  *
      *                          * lezionate                           *
      *                          *-------------------------------------*
           move      w-loa-sdb-out-nss    to   w-loa-sdb-wrk-nss      .
           add       1                    to   w-loa-sdb-wrk-nss      .
      *                          *-------------------------------------*
      *                          * Se oltre il numero massimo di sca-  *
      *                          * denze massimo consentito : a fine   *
      *                          * caricamento, dopo aver emesso un    *
      *                          * messaggio di errore                 *
      *                          *-------------------------------------*
           if        w-loa-sdb-wrk-nss    not  > w-loa-sdb-inp-nsm
                     go to loa-sdb-ipr-335.
           perform   loa-sdb-max-000      thru loa-sdb-max-999        .
           go to     loa-sdb-ipr-800.
       loa-sdb-ipr-335.
      *                      *-----------------------------------------*
      *                      * Selezione su importo massimo per la     *
      *                      * distinta                                *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se importo massimo a zero : nessuna *
      *                          * selezione                           *
      *                          *-------------------------------------*
           if        w-loa-sdb-inp-igm    =    zero
                     go to loa-sdb-ipr-350.
      *                          *-------------------------------------*
      *                          * Simulazione di accumulo per l'im-   *
      *                          * porto della scadenza letta          *
      *                          *-------------------------------------*
           move      w-loa-sdb-out-igs    to   w-loa-sdb-wrk-igs      .
           add       rf-sdb-imp-sdb       to   w-loa-sdb-wrk-igs      .
      *                          *-------------------------------------*
      *                          * Se oltre l'importo massimo da sele- *
      *                          * zionare : a Next su scadenze a vi-  *
      *                          * sta                                 *
      *                          *-------------------------------------*
           if        w-loa-sdb-wrk-igs    >    w-loa-sdb-inp-igm
                     go to loa-sdb-ipr-250.
       loa-sdb-ipr-350.
      *                  *---------------------------------------------*
      *                  * Inclusione scadenza in distinta             *
      *                  *---------------------------------------------*
       loa-sdb-ipr-355.
      *                      *-----------------------------------------*
      *                      * Aggiornamento numero di scadenze sele-  *
      *                      * zionate                                 *
      *                      *-----------------------------------------*
           add       1                    to   w-loa-sdb-out-nss      .
       loa-sdb-ipr-360.
      *                      *-----------------------------------------*
      *                      * Aggiornamento importo globale selezio-  *
      *                      * nato                                    *
      *                      *-----------------------------------------*
           add       rf-sdb-imp-sdb       to   w-loa-sdb-out-igs      .
       loa-sdb-ipr-365.
      *                      *-----------------------------------------*
      *                      * Composizione della riga per il rilascio *
      *                      * al sort e rilascio al sort stesso       *
      *                      *-----------------------------------------*
