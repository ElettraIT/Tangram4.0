      *              *-------------------------------------------------*
           if        w-tes-dsc-min (1)    =    zero or
                     w-tes-dsc-max (1)    =    zero
                     go to cnt-tdo-nok-175.
           if        w-tes-dsc-max (1)    not  < w-tes-dsc-min (1)
                     go to cnt-tdo-nok-175.
           move      "Data scadenza minima da selezionare superiore a qu
      -              "ella massima ! "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-175.
      *              *-------------------------------------------------*
      *              * Controllo su selezione per scadenze a vista     *
      *              *-------------------------------------------------*
