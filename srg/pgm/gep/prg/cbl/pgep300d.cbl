           if        w-srt-sdb-out-nsn    =    zero and
                     w-srt-sdb-out-nsa    =    zero
                     go to rou-let-reg-735.
           if        w-cnt-mfu-tip-fun    =    "I"
                     move  "#"            to   w-cnt-rou-let-reg
                     go to rou-let-reg-999
           else      move  "V"            to   w-cnt-mfu-tip-fun      .
       rou-let-reg-735.
      *                          *-------------------------------------*
      *                          * Importo effettivo della distinta,   *
      *                          * da sommatoria righe caricate        *
      *                          *-------------------------------------*
           move      w-srt-sdb-out-igc    to   w-tes-imp-ddp (1)      .
       rou-let-reg-750.
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rou-let-reg-999.
       rou-let-reg-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort scadenze della distinta per :    *
      *    *                                                           *
      *    * -  Data di scadenza                                       *
      *    * -  Ragione sociale del debitore                           *
      *    * -  Tipo debitore                                          *
      *    * -  Codice debitore                                        *
      *    * -  Numero scadenza                                        *
      *    *-----------------------------------------------------------*
       srt-inp-prc-000.
      *              *-------------------------------------------------*
      *              * Start su scadenze appartenenti alla distinta di *
      *              * presentazione                                   *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "DDPNRS    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      w-tes-num-dis        to   rf-sdb-num-ddp         .
           move      zero                 to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *              *-------------------------------------------------*
      *              * Se start errata : fine input procedure          *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  srt-inp-prc-999.
       srt-inp-prc-200.
      *              *-------------------------------------------------*
      *              * Next su scadenze appartenenti alla distinta di  *
      *              * presentazione                                   *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *              *-------------------------------------------------*
      *              * Se at end : fine input procedure                *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  srt-inp-prc-999.
       srt-inp-prc-300.
      *              *-------------------------------------------------*
      *              * Test max su su scadenze appartenenti alla di-   *
      *              * stinta di presentazione, se non superato : fi-  *
      *              * ne input procedure                              *
      *              *-------------------------------------------------*
           if        rf-sdb-num-ddp       not  = w-tes-num-dis
                     go to  srt-inp-prc-999.
       srt-inp-prc-400.
      *              *-------------------------------------------------*
      *              * Composizione sort-record                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Data di scadenza                            *
      *                  *---------------------------------------------*
           move      rf-sdb-dts-sdb       to   srt-dts-sdb            .
      *                  *---------------------------------------------*
      *                  * Ragione sociale del debitore                *
      *                  *---------------------------------------------*
           move      rf-sdb-tip-dbt       to   w-let-arc-dbt-tip      .
           move      rf-sdb-cod-dbt       to   w-let-arc-dbt-cod      .
           perform   let-arc-dbt-000      thru let-arc-dbt-999        .
           move      w-let-arc-dbt-rag    to   srt-rag-soc            .
      *                  *---------------------------------------------*
      *                  * Tipo debitore                               *
      *                  *---------------------------------------------*
           move      rf-sdb-tip-dbt       to   srt-tip-dbt            .
      *                  *---------------------------------------------*
      *                  * Codice debitore                             *
      *                  *---------------------------------------------*
           move      rf-sdb-cod-dbt       to   srt-cod-dbt            .
      *                  *---------------------------------------------*
      *                  * Numero scadenza                             *
      *                  *---------------------------------------------*
           move      rf-sdb-num-sdb       to   srt-num-sdb            .
      *                  *---------------------------------------------*
      *                  * Tipo acquisizione scadenza                  *
      *                  *---------------------------------------------*
           move      rf-sdb-tac-sdb       to   srt-tac-sdb            .
      *                  *---------------------------------------------*
      *                  * Importo scadenza                            *
      *                  *---------------------------------------------*
           move      rf-sdb-imp-sdb       to   srt-imp-sdb            .
       srt-inp-prc-500.
      *              *-------------------------------------------------*
      *              * Rilascio record al sort                         *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       srt-inp-prc-600.
      *              *-------------------------------------------------*
      *              * Riciclo a  Next su scadenze appartenenti alla   *
      *              * distinta                                        *
      *              *-------------------------------------------------*
           go to     srt-inp-prc-200.
       srt-inp-prc-999.
           exit.

      *    *===========================================================*
      *    * Output procedure per sort scadenze della distinta per :   *
      *    *                                                           *
      *    * -  Data di scadenza                                       *
      *    * -  Ragione sociale del debitore                           *
      *    * -  Tipo debitore                                          *
      *    * -  Codice debitore                                        *
      *    * -  Numero scadenza                                        *
      *    *-----------------------------------------------------------*
       srt-out-prc-000.
      *              *-------------------------------------------------*
      *              * Preparazioni iniziali                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione parametri in output per il  *
      *                  * caricamento iniziale scadenze per distinta  *
      *                  * per mezzo della rilettura della distinta    *
      *                  * pre-esistente                               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Numero di scadenze caricate             *
      *                      *-----------------------------------------*
           move      zero                 to   w-srt-sdb-out-nsc      .
      *                      *-----------------------------------------*
      *                      * Importo globale caricato                *
      *                      *-----------------------------------------*
           move      zero                 to   w-srt-sdb-out-igc      .
      *                      *-----------------------------------------*
      *                      * Numero di scadenze non esistenti nella  *
      *                      * rilettura dopo il sort                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-srt-sdb-out-nsn      .
      *                      *-----------------------------------------*
      *                      * Numero di scadenze con anomalie nella   *
      *                      * rilettura dopo il sort                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-srt-sdb-out-nsa      .
       srt-out-prc-200.
      *              *-------------------------------------------------*
      *              * Reperimento record dal sort, se fine lettura :  *
      *              * a fine output procedure                         *
      *              *-------------------------------------------------*
           return    srt    at end
                            go to srt-out-prc-999.
       srt-out-prc-300.
      *              *-------------------------------------------------*
      *              * Lettura scadenza da [sdb]                       *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMSDB    "         to   f-key                  .
           move      srt-num-sdb          to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to srt-out-prc-500.
       srt-out-prc-400.
      *              *-------------------------------------------------*
      *              * Se scadenza non trovata in [sdb]                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Incremento numero scadenze non esistenti    *
      *                  *---------------------------------------------*
           add       1                    to   w-srt-sdb-out-nsn      .
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      srt-num-sdb          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      spaces               to   w-err-box-err-msg      .
           string    "Attenzione : Scadenza nr. "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " non esistente in archivio!"
                                delimited by   size
                                          into w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo a reperimento record dal sort       *
      *                  *---------------------------------------------*
           go to     srt-out-prc-200.
       srt-out-prc-500.
      *              *-------------------------------------------------*
      *              * Se scadenza esistente in [sdb]                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Incremento numero scadenze caricate         *
      *                  *---------------------------------------------*
           add       1                    to   w-srt-sdb-out-nsc      .
      *                  *---------------------------------------------*
      *                  * Incremento importo globale caricato         *
      *                  *---------------------------------------------*
           add       rf-sdb-imp-sdb       to   w-srt-sdb-out-igc      .
      *                  *---------------------------------------------*
      *                  * Put su catena movimenti [rig]               *
      *                  *---------------------------------------------*
           perform   srt-put-wri-000      thru srt-put-wri-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo a reperimento record dal sort       *
      *                  *---------------------------------------------*
           go to     srt-out-prc-200.
       srt-out-prc-999.
           exit.

      *    *===========================================================*
