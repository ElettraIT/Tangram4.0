      *                      * - Tipi scadenza da includere            *
      *                      * solo se valore incompatibile            *
      *                      *-----------------------------------------*
           if        w-tes-tsc-das (1)    =    zero
                     go to acc-tav-ric-635.
           if        w-tes-tsc-das (1)    =    0003 or
                     w-tes-tsc-das (1)    =    0203
                     go to acc-tav-ric-635.
           move      zero                 to   w-tes-tsc-das (1)      .
           perform   vis-tsc-das-000      thru vis-tsc-das-999        .
       acc-tav-ric-635.
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     acc-tav-ric-800.
       acc-tav-ric-640.
      *                  *---------------------------------------------*
      *                  * Se valore : 04                              *
      *                  *---------------------------------------------*
       acc-tav-ric-641.
      *                      *-----------------------------------------*
      *                      * Normalizzazione e visualizzazione di :  *
      *                      * - Tipi scadenza da includere            *
      *                      * solo se valore incompatibile            *
      *                      *-----------------------------------------*
           if        w-tes-tsc-das (1)    =    zero
                     go to acc-tav-ric-642.
           if        w-tes-tsc-das (1)    =    0005 or
                     w-tes-tsc-das (1)    =    0205
                     go to acc-tav-ric-642.
           move      zero                 to   w-tes-tsc-das (1)      .
           perform   vis-tsc-das-000      thru vis-tsc-das-999        .
       acc-tav-ric-642.
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     acc-tav-ric-800.
       acc-tav-ric-650.
      *                  *---------------------------------------------*
      *                  * Se valore : 05                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Forzatura di :                          *
      *                      * - Tipi scadenza da includere            *
      *                      * solo se necessario                      *
      *                      *-----------------------------------------*
           if        w-tes-tsc-das (1)    =    0006
                     go to acc-tav-ric-655.
           move      0006                 to   w-tes-tsc-das (1)      .
           perform   vis-tsc-das-000      thru vis-tsc-das-999        .
       acc-tav-ric-655.
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     acc-tav-ric-800.
       acc-tav-ric-690.
      *                  *---------------------------------------------*
      *                  * Se valore : 00 o non riconosciuto           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione e visualizzazione di :  *
      *                      * - Tipi scadenza da includere            *
      *                      *-----------------------------------------*
           if        w-tes-tsc-das (1)    =    zero
                     go to acc-tav-ric-695.
           move      zero                 to   w-tes-tsc-das (1)      .
           perform   vis-tsc-das-000      thru vis-tsc-das-999        .
       acc-tav-ric-695.
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     acc-tav-ric-800.
       acc-tav-ric-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-tav-ric-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-tav-ric-100.
