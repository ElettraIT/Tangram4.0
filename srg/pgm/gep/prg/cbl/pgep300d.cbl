           else if   w-tes-tav-ric (1)    =    02
                     go to acc-tav-ric-620
           else if   w-tes-tav-ric (1)    =    03
                     go to acc-tav-ric-630
           else if   w-tes-tav-ric (1)    =    04
                     go to acc-tav-ric-640
           else if   w-tes-tav-ric (1)    =    05
                     go to acc-tav-ric-650
           else      go to acc-tav-ric-690.
       acc-tav-ric-610.
      *                  *---------------------------------------------*
