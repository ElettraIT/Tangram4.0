                     w-tes-tip-ope        not  = 0403 and
                     w-tes-tip-ope        not  = 0404
                     go to cnt-tdo-nok-200.
           if        w-tes-dsc-vis (1)    not  = spaces
                     go to cnt-tdo-nok-177.
           move      "Manca la voce per la selezione delle scadenze a vi
      -              "sta !          "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-177.
           if        w-tes-dsc-vis (1)    =    "S" or
                     w-tes-dsc-vis (1)    =    "N"
                     go to cnt-tdo-nok-200.
           move      "La voce per la selezione delle scadenze a vista e'
      -              " errata !      "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-200.
