           move      zero                 to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [sdb]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-sdb-dat-chs       not  = 9999999
                     go to stp-srt-inp-999.
      *              *-------------------------------------------------*
      *              * Selezione sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo debitore                       *
      *                  *---------------------------------------------*
           if        rf-sdb-tip-dbt       not  = 01
                     go to stp-srt-inp-100.
      *                  *---------------------------------------------*
      *                  * Selezione sulla data di registrazione movi- *
      *                  * mento di emissione scadenza, che non sia    *
      *                  * superiore alla data di registrazione in     *
      *                  * corso                                       *
      *                  *---------------------------------------------*
           if        rf-sdb-dtr-emi       >    w-key-dat-reg
                     go to stp-srt-inp-100.
      *                  *---------------------------------------------*
      *                  * Selezione su status della scadenza          *
      *                  *---------------------------------------------*
           perform   det-sts-sdb-000      thru det-sts-sdb-999        .
           if       (w-det-sts-sdb-sts    =    "A"    ) and
                    (w-det-sts-sdb-suo    =    "EMI" or
                     w-det-sts-sdb-suo    =    "ISP"  )
                     go to stp-srt-inp-200
           else      go to stp-srt-inp-100.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Lettura record [dcc]                            *
      *              *-------------------------------------------------*
           move      rf-sdb-cod-dbt       to   w-let-arc-dcc-cli      .
           if        rf-sdb-dpz-dbt       not  = spaces and
                     rf-sdb-inl-sdb       =    03
                     move  rf-sdb-dpz-dbt to   w-let-arc-dcc-dpz
           else      move  spaces         to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                  *---------------------------------------------*
      *                  * Selezione su si/no raggruppamento           *
      *                  *---------------------------------------------*
           if        rr-snx-sdr           not  = "S"
                     go to stp-srt-inp-300.
           if        w-let-arc-dcc-snr    not  = 02
                     go to stp-srt-inp-100.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Composizione sort-record                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Chiave del sort                             *
      *                  *---------------------------------------------*
           move      w-let-arc-dcc-rsu    to   srt-rag-key            .
           move      rf-sdb-cod-dbt       to   srt-cod-cli            .
           if        rf-sdb-dpz-dbt       not  = spaces and
                     rf-sdb-inl-sdb       =    03
                     move  rf-sdb-dpz-dbt to   srt-dpz-cli
           else      move  spaces         to   srt-dpz-cli            .
           if        rf-sdb-dts-sdb       =    zero
                     move  w-key-dat-reg  to   srt-dts-eff
           else      move  rf-sdb-dts-sdb to   srt-dts-eff            .
           if        rf-sdb-tip-ddr       =    01 or
                     rf-sdb-tip-ddr       =    02
                     move  03             to   srt-ord-tdr
           else if   rf-sdb-tip-ddr       =    11
                     move  02             to   srt-ord-tdr
           else if   rf-sdb-tip-ddr       =    21
                     move  01             to   srt-ord-tdr
           else if   rf-sdb-tip-ddr       =    99
                     move  03             to   srt-ord-tdr
           else      move  03             to   srt-ord-tdr            .
           move      rf-sdb-tip-sdb       to   srt-tip-sdb            .
           move      rf-sdb-num-sdb       to   srt-num-sdb            .
      *                  *---------------------------------------------*
      *                  * Dati del sort                               *
      *                  *---------------------------------------------*
           move      w-let-arc-dcc-rag    to   srt-rag-soc            .
           move      rf-sdb-snx-dlc       to   srt-snx-dlc            .
           if        w-det-sts-sdb-suo    =    "ISP"
                     move  "#"            to   srt-flg-isp
           else      move  spaces         to   srt-flg-isp            .
           move      rf-sdb-tac-sdb       to   srt-tac-sdb            .
           move      rf-sdb-dts-sdb       to   srt-dts-sdb            .
           if        rf-sdb-tvl-sdb       =    02
                     move  rf-sdb-iiv-sdb to   srt-imp-sdb
           else      move  rf-sdb-imp-sdb to   srt-imp-sdb            .
           move      rf-sdb-dat-ddr       to   srt-dat-ddr            .
           move      rf-sdb-num-ddr       to   srt-num-ddr            .
           move      rf-sdb-tip-ddr       to   srt-tip-ddr            .
           move      rf-sdb-imp-ddr       to   srt-imp-ddr            .
           move      rf-sdb-nra-ddr       to   srt-nra-ddr            .
           move      spaces               to   srt-flg-cpz            .
      *              *-------------------------------------------------*
      *              * Rilascio record al sort                         *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale record [sdb]     *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-100.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Generazione file sequenziale di appoggio #1               *
      *    *-----------------------------------------------------------*
       gen-fil-sq1-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione area rottura chiave di ordina-  *
      *              * mento per cliente                               *
      *              *-------------------------------------------------*
           move      spaces               to   w-gen-sq1-key-cli      .
      *              *-------------------------------------------------*
      *              * Attivazione flag di primo passaggio             *
      *              *-------------------------------------------------*
           move      "#"                  to   w-gen-sq1-flg-uno      .
       gen-fil-sq1-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale archivio sortato [srt]      *
      *              *-------------------------------------------------*
           return    srt    at end
                            go to gen-fil-sq1-400.
       gen-fil-sq1-200.
      *              *-------------------------------------------------*
      *              * Se rottura cliente                              *
      *              *-------------------------------------------------*
           if        srt-key-cli          =    w-gen-sq1-key-cli
                     go to gen-fil-sq1-300.
      *                  *---------------------------------------------*
      *                  * Esecuzione subroutine per fine cliente      *
      *                  *---------------------------------------------*
           perform   gen-fil-sq1-700      thru gen-fil-sq1-799        .
      *                  *---------------------------------------------*
      *                  * Esecuzione subroutine per inizio cliente    *
      *                  *---------------------------------------------*
           perform   gen-fil-sq1-800      thru gen-fil-sq1-899        .
       gen-fil-sq1-300.
      *              *-------------------------------------------------*
      *              * Aggiornamento progressivi cliente               *
      *              *-------------------------------------------------*
       gen-fil-sq1-310.
      *                  *---------------------------------------------*
      *                  * Numero scadenze negative o positive         *
      *                  *---------------------------------------------*
           if        srt-tip-ddr          =    11 or
                     srt-tip-ddr          =    21
                     add   1              to   ky1-num-scn
                     move  "N"            to   srt-flg-cpz
           else      add   1              to   ky1-num-scp            .
       gen-fil-sq1-320.
      *                  *---------------------------------------------*
      *                  * Importo minore scadenza negativa            *
      *                  *---------------------------------------------*
           if        srt-tip-ddr          not  = 11 and
                     srt-tip-ddr          not  = 21
                     go to gen-fil-sq1-340.
           move      srt-imp-sdb          to   w-gen-sq1-imp-sdb      .
           multiply  -1                   by   w-gen-sq1-imp-sdb      .
           if        ky1-min-scn          =    zero
                     move  w-gen-sq1-imp-sdb
                                          to   ky1-min-scn            .
           if        w-gen-sq1-imp-sdb    <    ky1-min-scn
                     move  w-gen-sq1-imp-sdb
                                          to   ky1-min-scn            .
       gen-fil-sq1-340.
      *                  *---------------------------------------------*
      *                  * Importo maggiore scadenza positiva          *
      *                  *---------------------------------------------*
           if        srt-tip-ddr          =    11 or
                     srt-tip-ddr          =    21
                     go to gen-fil-sq1-350.
           if        srt-imp-sdb          >    ky1-max-scp
                     move  srt-imp-sdb    to   ky1-max-scp            .
       gen-fil-sq1-350.
      *                  *---------------------------------------------*
      *                  * Numero scadenze con la stessa data scadenza *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se data scadenza diversa da quella pre- *
      *                      * cedente : aggiornamento data ultima     *
      *                      * scadenza presa in esame e oltre         *
      *                      *-----------------------------------------*
           if        srt-dts-sdb          not  = w-gen-sq1-dts-sdb
                     move  srt-dts-sdb    to   w-gen-sq1-dts-sdb
                     go to gen-fil-sq1-360.
      *                      *-----------------------------------------*
      *                      * Se scadenza non presentabile : oltre    *
      *                      *-----------------------------------------*
           if        srt-tip-sdb          not  = 02 and
                     srt-tip-sdb          not  = 03 and
                     srt-tip-sdb          not  = 04 and
                     srt-tip-sdb          not  = 05 and
                     srt-tip-sdb          not  = 06 and
                     srt-tip-sdb          not  = 09 and
                     srt-tip-sdb          not  = 10 and
                     srt-tip-sdb          not  = 11
                     go to gen-fil-sq1-360.
      *                      *-----------------------------------------*
      *                      * Se scadenza ceduta da terzi : oltre     *
      *                      *-----------------------------------------*
           if        srt-tac-sdb          not  = 01
                     go to gen-fil-sq1-360.
      *                      *-----------------------------------------*
      *                      * Se scadenza insoluta : oltre            *
      *                      *-----------------------------------------*
           if        srt-flg-isp          not  = spaces
                     go to gen-fil-sq1-360.
      *                      *-----------------------------------------*
      *                      * Se data scadenza a vista : oltre        *
      *                      *-----------------------------------------*
           if        srt-dts-sdb          =    zero
                     go to gen-fil-sq1-360.
      *                      *-----------------------------------------*
      *                      * Aggiornamento progressivo scadenze con  *
      *                      * data pari alla scadenza precedente      *
      *                      *-----------------------------------------*
           add       1                    to   ky1-num-ssd            .
           move      "C"                  to   srt-flg-cpz            .
       gen-fil-sq1-360.
      *              *-------------------------------------------------*
      *              * Composizione record [sq1]                       *
      *              *-------------------------------------------------*
           move      srt-rec              to   sq1-rec                .
      *              *-------------------------------------------------*
      *              * Scrittura record [sq1]                          *
      *              *-------------------------------------------------*
           write     sq1-rec                                          .
      *              *-------------------------------------------------*
      *              * Riciclo su Lettura sequenziale archivio sortato *
      *              * [srt]                                           *
      *              *-------------------------------------------------*
           go to     gen-fil-sq1-100.
       gen-fil-sq1-400.
      *              *-------------------------------------------------*
      *              * Esecuzione subroutine per fine cliente          *
      *              *-------------------------------------------------*
           perform   gen-fil-sq1-700      thru gen-fil-sq1-799        .
      *              *-------------------------------------------------*
      *              * Close file sequenziale di appoggio #1           *
      *              *-------------------------------------------------*
           close     sq1                                              .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     gen-fil-sq1-999.
       gen-fil-sq1-700.
      *              *=================================================*
      *              * Subroutine interna per fine cliente             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se primo passaggio : uscita                 *
      *                  *---------------------------------------------*
           if        w-gen-sq1-flg-uno    not  = spaces
                     move  spaces         to   w-gen-sq1-flg-uno
                     go to gen-fil-sq1-799.
      *                  *---------------------------------------------*
      *                  * Scrittura record [ky1]                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su scadenze negative               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se numero scadenze negative a zero, *
      *                          * prossimo test                       *
      *                          *-------------------------------------*
           if        ky1-num-scn          =    zero
                     go to gen-fil-sq1-720.
      *                          *-------------------------------------*
      *                          * Se numero scadenze positive a zero, *
      *                          * prossimo test                       *
      *                          *-------------------------------------*
           if        ky1-num-scp          =    zero
                     go to gen-fil-sq1-720.
      *                          *-------------------------------------*
      *                          * Se importo scadenza negativa minore *
      *                          * superiore a importo scadenza posi-  *
      *                          * tiva maggiore, prossimo test        *
      *                          *-------------------------------------*
           if        ky1-min-scn          >    ky1-max-scp
                     go to gen-fil-sq1-720.
      *                          *-------------------------------------*
      *                          * A scrittura record                  *
      *                          *-------------------------------------*
           go to     gen-fil-sq1-760.
       gen-fil-sq1-720.
      *                      *-----------------------------------------*
      *                      * Test su numero scadenze con data pari   *
      *                      * a quella della scadenza precedente      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se a zero, prossimo test            *
      *                          *-------------------------------------*
           if        ky1-num-ssd          =    zero
                     go to gen-fil-sq1-740.
      *                          *-------------------------------------*
      *                          * A scrittura record                  *
      *                          *-------------------------------------*
           go to     gen-fil-sq1-760.
       gen-fil-sq1-740.
      *                      *-----------------------------------------*
      *                      * Nessun ulteriore test, record [ky1] da  *
      *                      * non scrivere, uscita                    *
      *                      *-----------------------------------------*
           go to     gen-fil-sq1-799.
       gen-fil-sq1-760.
      *                      *-----------------------------------------*
      *                      * Scrittura effettiva record [ky1]        *
      *                      *-----------------------------------------*
           write     ky1-rec                                          .
       gen-fil-sq1-799.
           exit.
       gen-fil-sq1-800.
      *              *=================================================*
      *              * Subroutine interna per inizio cliente           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione area rottura per data ulti- *
      *                  * ma scadenza considerata                     *
      *                  *---------------------------------------------*
           move      zero                 to   w-gen-sq1-dts-sdb      .
      *                  *---------------------------------------------*
      *                  * Aggiornamento area rottura chiave di ordi-  *
      *                  * namento per cliente                         *
      *                  *---------------------------------------------*
           move      srt-key-cli          to   w-gen-sq1-key-cli      .
      *                  *---------------------------------------------*
      *                  * Inizializzazione record [ky1]               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Composizione chiave                     *
      *                      *-----------------------------------------*
           move      srt-key-cli          to   ky1-key                .
      *                      *-----------------------------------------*
      *                      * Normalizzazione dati                    *
      *                      *-----------------------------------------*
           move      zero                 to   ky1-num-scn            .
           move      zero                 to   ky1-num-scp            .
           move      zero                 to   ky1-min-scn            .
           move      zero                 to   ky1-max-scp            .
           move      zero                 to   ky1-num-ssd            .
       gen-fil-sq1-899.
           exit.
       gen-fil-sq1-999.
           exit.

