           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-cau-cge-999.
       acc-cau-cge-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   rr-cau-cge             .
       acc-cau-cge-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [zcc]                      *
      *                  *---------------------------------------------*
           move      rr-cau-cge           to   w-let-arc-zcc-cod      .
           perform   let-arc-zcc-000      thru let-arc-zcc-999        .
           move      w-let-arc-zcc-des    to   rr-cau-cge-des         .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione causale         *
      *                  *---------------------------------------------*
           perform   vis-cau-cge-des-000  thru vis-cau-cge-des-999    .
      *                  *---------------------------------------------*
      *                  * Se lettura errata : reimpostazione          *
      *                  *---------------------------------------------*
           if        w-let-arc-zcc-flg    not  = spaces
                     go to acc-cau-cge-100.
      *                  *---------------------------------------------*
      *                  * Se valore a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        rr-cau-cge           =    zero
                     go to acc-cau-cge-100.
      *                  *---------------------------------------------*
      *                  * Se causale di bilancio : messaggio di erro- *
      *                  * re e reimpostazione                         *
      *                  *---------------------------------------------*
           if        w-let-arc-zcc-snb    =    "N"
                     go to acc-cau-cge-420.
           move      "La causale contabile di ripresa saldo deve essere 
      -              "di contabilita'"    to   w-err-box-err-msg      .
           move      "ordinaria.                                        
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           go to     acc-cau-cge-100.
       acc-cau-cge-420.
      *                  *---------------------------------------------*
      *                  * Se causale iva : messaggio di errore e re-  *
      *                  * impostazione                                *
      *                  *---------------------------------------------*
           if        w-let-arc-zcc-tmi    =    "0" or
                     w-let-arc-zcc-tmi    =    spaces
                     go to acc-cau-cge-600.
           move      "La causale contabile di ripresa saldo non puo' ess
      -              "ere una causale"    to   w-err-box-err-msg      .
           move      "iva.                                              
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           go to     acc-cau-cge-100.
       acc-cau-cge-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cau-cge-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-cau-cge-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-cau-cge-100.
       acc-cau-cge-999.
           exit.

