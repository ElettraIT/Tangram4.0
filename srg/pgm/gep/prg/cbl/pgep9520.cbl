      *    *===========================================================*
      *    * Esecuzione ripresa saldi clienti da scadenze              *
      *    *-----------------------------------------------------------*
       exe-rip-sdi-000.
      *              *-------------------------------------------------*
      *              * Open files e moduli                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Apertura file [sdb]                         *
      *                  *---------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Open modulo aggiornamento contabilita' ge-  *
      *                  * nerale, clienti, fornitori, iva             *
      *                  *---------------------------------------------*
           perform   mdl-agg-cge-opn-000  thru mdl-agg-cge-opn-999    .
       exe-rip-sdi-100.
      *              *-------------------------------------------------*
      *              * Normalizzazione contatore numero righe di movi- *
      *              * mento scritte                                   *
      *              *-------------------------------------------------*
           move      zero                 to   w-exe-rip-sdi-ctr      .
      *              *-------------------------------------------------*
      *              * Start su file [sdb]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DBTDTS    "         to   f-key                  .
           move      01                   to   rf-sdb-tip-dbt         .
           move      zero                 to   rf-sdb-cod-dbt         .
           move      zero                 to   rf-sdb-dts-sdb         .
           move      zero                 to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Test su esito  operazione                   *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exe-rip-sdi-900.
       exe-rip-sdi-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [sdb]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exe-rip-sdi-900.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-sdb-tip-dbt       not  = 01
                     go to exe-rip-sdi-900.
      *              *-------------------------------------------------*
      *              * Selezione sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su data emissione                      *
      *                  *---------------------------------------------*
           if        rf-sdb-dtr-emi       >    rr-dat-ems
                     go to exe-rip-sdi-200.
      *                  *---------------------------------------------*
      *                  * Se tipo scadenza presentabile in banca,     *
      *                  * test su tipo aggiornamento eseguito : se    *
      *                  * gia' eseguito non si considera la scadenza  *
      *                  * in esame                                    *
      *                  *---------------------------------------------*
           if       (rf-sdb-tip-sdb       =    02 or
                     rf-sdb-tip-sdb       =    03 or
                     rf-sdb-tip-sdb       =    04 or
                     rf-sdb-tip-sdb       =    05 or
                     rf-sdb-tip-sdb       =    06 or
                     rf-sdb-tip-sdb       =    09 or
                     rf-sdb-tip-sdb       =    10 or
                     rf-sdb-tip-sdb       =    11  ) and
                    (rr-tip-agg           =    01  )
                     go to exe-rip-sdi-200.
       exe-rip-sdi-300.
      *              *-------------------------------------------------*
      *              * Incremento contatore numero righe di movimento  *
      *              * scritte                                         *
      *              *-------------------------------------------------*
           add       1                    to   w-exe-rip-sdi-ctr      .
           if        w-exe-rip-sdi-ctr    >    w-exe-rip-sdi-max
                     move  1              to   w-exe-rip-sdi-ctr      .
       exe-rip-sdi-400.
      *              *-------------------------------------------------*
      *              * Se contatore numero righe di movimento scritte  *
      *              * a 1 : scrittura testata movimento di generale   *
      *              *-------------------------------------------------*
           if        w-exe-rip-sdi-ctr    not  = 1
                     go to exe-rip-sdi-500.
      *                  *---------------------------------------------*
      *                  * Normalizzazione work per scrittura testata  *
      *                  * e prima riga movimento di CGE               *
      *                  *---------------------------------------------*
           move      "NO"                 to   l-cge-300-tip-ope      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                  *---------------------------------------------*
      *                  * Valori per testata registrazione            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo operazione                         *
      *                      *-----------------------------------------*
           move      "WR"                 to   l-cge-300-tip-ope      .
      *                      *-----------------------------------------*
      *                      * Data registrazione                      *
      *                      *-----------------------------------------*
           move      rr-dtr-cge           to   l-cge-300-dat-reg      .
      *                      *-----------------------------------------*
      *                      * Numero protocollo                       *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-num-prt      .
      *                      *-----------------------------------------*
      *                      * Causale                                 *
      *                      *-----------------------------------------*
           move      rr-cau-cge           to   l-cge-300-cod-cau      .
      *                      *-----------------------------------------*
      *                      * Descrizione causale                     *
      *                      *-----------------------------------------*
           move      rr-cau-cge-des       to   l-cge-300-des-cau      .
      *                      *-----------------------------------------*
      *                      * Si/No data scadenza                     *
      *                      *-----------------------------------------*
           move      "N"                  to   l-cge-300-snx-dts      .
      *                      *-----------------------------------------*
      *                      * Data scadenza                           *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-dat-sca      .
      *                      *-----------------------------------------*
      *                      * Data documento                          *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-dat-doc      .
      *                      *-----------------------------------------*
      *                      * Numero documento                        *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-num-doc      .
      *                      *-----------------------------------------*
      *                      * Codice numerazione giornale iva         *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-cod-num      .
       exe-rip-sdi-500.
      *              *-------------------------------------------------*
      *              * Scrittura riga di registrazione                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Codice piano dei conti                      *
      *                  *---------------------------------------------*
           move      zero                 to   l-cge-300-cod-pdc      .
      *                      *-----------------------------------------*
      *                      * Tipo archivio                           *
      *                      *-----------------------------------------*
           move      "C"                  to   l-cge-300-tip-arc      .
      *                      *-----------------------------------------*
      *                      * Codice archivio                         *
      *                      *-----------------------------------------*
           move      rf-sdb-cod-dbt       to   l-cge-300-cod-arc      .
      *                      *-----------------------------------------*
      *                      * Commento in riga                        *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-com-rig      .
      *                      *-----------------------------------------*
      *                      * Data riferimento                        *
      *                      *-----------------------------------------*
           move      rf-sdb-dat-ddr       to   l-cge-300-dat-rif      .
      *                      *-----------------------------------------*
      *                      * Numero riferimento                      *
      *                      *-----------------------------------------*
           move      rf-sdb-num-ddr       to   l-cge-300-num-rif      .
      *                      *-----------------------------------------*
      *                      * Dare/Avere                              *
      *                      *-----------------------------------------*
           if        rf-sdb-tip-ddr       =    11 or
                     rf-sdb-tip-ddr       =    21
                     move  "A"            to   l-cge-300-dar-ave
           else      move  "D"            to   l-cge-300-dar-ave      .
      *                      *-----------------------------------------*
      *                      * Importo movimento                       *
      *                      *-----------------------------------------*
           move      rf-sdb-imp-sdb       to   l-cge-300-imp-mov      .
           if        rf-sdb-tip-ddr       =    11 or
                     rf-sdb-tip-ddr       =    21
                     multiply -1          by   l-cge-300-imp-mov      .
      *                  *---------------------------------------------*
      *                  * Richiamo modulo scrittura CGE               *
      *                  *---------------------------------------------*
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *              *-------------------------------------------------*
      *              * Normalizzazione work per scrittura singola riga *
      *              * movimento di CGE                                *
      *              *-------------------------------------------------*
           move      "N+"                 to   l-cge-300-tip-ope      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *              *-------------------------------------------------*
      *              * Tipo operazione per prossima riga               *
      *              *-------------------------------------------------*
           move      "W+"                 to   l-cge-300-tip-ope      .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale record [sdb]     *
      *              *-------------------------------------------------*
           go to     exe-rip-sdi-200.
       exe-rip-sdi-900.
      *              *-------------------------------------------------*
      *              * Close files e moduli                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Chiusura file [sdb]                         *
      *                  *---------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Close modulo aggiornamento contabilita' ge- *
      *                  * nerale, clienti, fornitori, iva             *
      *                  *---------------------------------------------*
           perform   mdl-agg-cge-cls-000  thru mdl-agg-cge-cls-999    .
       exe-rip-sdi-999.
           exit.

      *    *===========================================================*
      *    * Routine lettura tabella [zcc]                             *
      *    *-----------------------------------------------------------*
       let-arc-zcc-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-zcc-flg      .
      *              *-------------------------------------------------*
      *              * Test se codice causale a zero                   *
      *              *-------------------------------------------------*
           if        w-let-arc-zcc-cod    =    zero
                     go to let-arc-zcc-500.
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCAU    "         to   f-key                  .
           move      w-let-arc-zcc-cod    to   rf-zcc-cod-cau         .
           move      "pgm/cge/fls/ioc/obj/iofzcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zcc                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-zcc-400.
       let-arc-zcc-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-zcc-des-cau       to   w-let-arc-zcc-des      .
           move      rf-zcc-tip-moi       to   w-let-arc-zcc-tmi      .
           move      rf-zcc-snx-bil       to   w-let-arc-zcc-snb      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-zcc-999.
       let-arc-zcc-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-zcc-flg      .
           move      all   "."            to   w-let-arc-zcc-des      .
           go to     let-arc-zcc-600.
       let-arc-zcc-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-zcc-des      .
       let-arc-zcc-600.
           move      spaces               to   w-let-arc-zcc-tmi      .
           move      spaces               to   w-let-arc-zcc-snb      .
       let-arc-zcc-999.
           exit.

