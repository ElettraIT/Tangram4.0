           if       (rf-sdb-tip-sdb       not  = 01 or
                     rf-sdb-snx-dlc       not  = "N" ) and
                     rf-sdb-tip-sdb       not  = 07    and
                     rf-sdb-tip-sdb       not  = 08
                     go to sel-rec-sdb-900.
           go to     sel-rec-sdb-200.
       sel-rec-sdb-103.
