      *              *-------------------------------------------------*
           move      rr-dat-rfa           to   w-det-srd-sdb-drd      .
           perform   det-srd-sdb-000      thru det-srd-sdb-999        .
      *              *-------------------------------------------------*
      *              * Test se scadenza ancora aperta                  *
      *              *-------------------------------------------------*
           if        w-det-srd-sdb-sts    not  = "A"
                     go to sel-rec-sdb-900.
      *              *-------------------------------------------------*
      *              * Test se sigla ultima operazione eseguita e' a   *
      *              * spazi                                           *
      *              *-------------------------------------------------*
           if        w-det-srd-sdb-suo    =    spaces
                     go to sel-rec-sdb-900.
       sel-rec-sdb-300.
      *              *-------------------------------------------------*
      *              * Selezione su status scadenza                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Rimesse Dirette, Bonifici o C/C Postali  *
      *                  *---------------------------------------------*
           if        rf-sdb-tip-sdb       not  = 01 and
                     rf-sdb-tip-sdb       not  = 07 and
                     rf-sdb-tip-sdb       not  = 08
                     go to sel-rec-sdb-350.
      *                  *---------------------------------------------*
      *                  * Test se richiesti effetti in portafoglio,   *
      *                  * in circolazione o insoluti                  *
      *                  *---------------------------------------------*
           if        rr-sts-eff           not  = 01
                     go to sel-rec-sdb-900.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione della selezione su   *
      *                  * status scadenze                             *
      *                  *---------------------------------------------*
           go to     sel-rec-sdb-301
                     sel-rec-sdb-302
                     sel-rec-sdb-303
                     depending            on   rr-sts-scd             .
       sel-rec-sdb-301.
      *                  *---------------------------------------------*
      *                  * Scadenze sia a scadere che scadute          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Nessuna selezione                       *
      *                      *-----------------------------------------*
           go to     sel-rec-sdb-400.
       sel-rec-sdb-302.
      *                  *---------------------------------------------*
      *                  * Solo quelle a scadere                       *
      *                  *---------------------------------------------*
           if        rf-sdb-dts-sdb       not  >  rr-dat-rfa
                     go to sel-rec-sdb-900.
           go to     sel-rec-sdb-400.
       sel-rec-sdb-303.
      *                  *---------------------------------------------*
      *                  * Solo quelle scadute                         *
      *                  *---------------------------------------------*
           if        rf-sdb-dts-sdb       >    rr-dat-rfa
                     go to sel-rec-sdb-900.
           go to     sel-rec-sdb-400.
       sel-rec-sdb-350.
      *              *-------------------------------------------------*
      *              * Selezione su status effetti                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione della selezione su   *
      *                  * status effetti                              *
      *                  *---------------------------------------------*
           go to     sel-rec-sdb-351
                     sel-rec-sdb-352
                     sel-rec-sdb-353
                     sel-rec-sdb-354
                     depending            on   rr-sts-eff             .
       sel-rec-sdb-351.
      *                  *---------------------------------------------*
      *                  * Effetti sia in portafoglio che in circola-  *
      *                  * zione                                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Nessuna selezione                       *
      *                      *-----------------------------------------*
           go to     sel-rec-sdb-400.
       sel-rec-sdb-352.
      *                  *---------------------------------------------*
      *                  * Solo effetti in portafoglio                 *
      *                  *---------------------------------------------*
           if        w-det-srd-sdb-suo    =    "PRE" or
                     w-det-srd-sdb-suo    =    "ACT" or
                     w-det-srd-sdb-suo    =    "ACD"
                     go to sel-rec-sdb-900.
           go to     sel-rec-sdb-400.
       sel-rec-sdb-353.
      *                  *---------------------------------------------*
      *                  * Solo effetti in circolazione                *
      *                  *---------------------------------------------*
           if        w-det-srd-sdb-suo    not  = "PRE" and
                     w-det-srd-sdb-suo    not  = "ACT" and
                     w-det-srd-sdb-suo    not  = "ACD"
                     go to sel-rec-sdb-900.
           go to     sel-rec-sdb-400.
       sel-rec-sdb-354.
      *                  *---------------------------------------------*
      *                  * Solo effetti insoluti                       *
      *                  *---------------------------------------------*
           if        w-det-srd-sdb-suo    not  = "ISP"
                     go to sel-rec-sdb-900.
           go to     sel-rec-sdb-400.
       sel-rec-sdb-400.
      *              *-------------------------------------------------*
      *              * Selezione su data di riferimento min e max      *
      *              *-------------------------------------------------*
           if        rf-sdb-dat-ddr       =    zero
                     go to sel-rec-sdb-800.
           if        rr-ddr-min           =    zero
                     go to sel-rec-sdb-450.
           if        rf-sdb-dat-ddr       <    rr-ddr-min 
                     go to sel-rec-sdb-900.
       sel-rec-sdb-450.
           if        rr-ddr-max           =    zero
                     go to sel-rec-sdb-800.
           if        rf-sdb-dat-ddr       >    rr-ddr-max 
                     go to sel-rec-sdb-900.
       sel-rec-sdb-800.
      *              *-------------------------------------------------*
      *              * Uscita per selezione superata                   *
      *              *-------------------------------------------------*
           go to     sel-rec-sdb-999.
       sel-rec-sdb-900.
      *              *-------------------------------------------------*
      *              * Uscita per selezione non superata               *
      *              *-------------------------------------------------*
           move      "#"                  to   w-sel-rec-sdb-flg      .
       sel-rec-sdb-999.
           exit.

