      *              * Normalizzazione tipo aggiornamento effettuato   *
      *              *-------------------------------------------------*
           move      zero                 to   w-agg-tot-cli-tae      .
      *              *-------------------------------------------------*
      *              * Determinazione indice per tabella tipi scadenza *
      *              *-------------------------------------------------*
           if        srt-tip-sdb          =    01 and
                     srt-snx-dlc          =    "N"
                     move  01             to   w-agg-tot-cli-its
           else if   srt-tip-sdb          =    01 and
                     srt-snx-dlc          =    "S"
                     move  02             to   w-agg-tot-cli-its
           else if   srt-tip-sdb          =    02
                     move  03             to   w-agg-tot-cli-its
           else if   srt-tip-sdb          =    03
                     move  04             to   w-agg-tot-cli-its
           else if   srt-tip-sdb          =    04
                     move  05             to   w-agg-tot-cli-its
           else if   srt-tip-sdb          =    05
                     move  06             to   w-agg-tot-cli-its
           else if   srt-tip-sdb          =    06
                     move  07             to   w-agg-tot-cli-its
           else if   srt-tip-sdb          =    07
                     move  08             to   w-agg-tot-cli-its
           else if   srt-tip-sdb          =    08
                     move  09             to   w-agg-tot-cli-its
           else if   srt-tip-sdb          =    09
                     move  10             to   w-agg-tot-cli-its
           else if   srt-tip-sdb          =    10
                     move  11             to   w-agg-tot-cli-its
           else if   srt-tip-sdb          =    11
                     move  12             to   w-agg-tot-cli-its      .
      *              *-------------------------------------------------*
      *              * Aggiornamento totale esposizione globale        *
      *              *-------------------------------------------------*
           add       srt-imp-sdb          to   w-tot-cli-teg          .
      *              *-------------------------------------------------*
      *              * Aggiornamento totale numero scadenze            *
      *              *-------------------------------------------------*
           add       1                    to   w-tot-cli-num
                                              (w-agg-tot-cli-its)     .
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo scadenza        *
      *              *-------------------------------------------------*
           if        srt-tip-sdb          =    01 or
                     srt-tip-sdb          =    07 or
                     srt-tip-sdb          =    08
                     go to agg-tot-cli-100
           else      go to agg-tot-cli-200.
       agg-tot-cli-100.
      *              *-------------------------------------------------*
      *              * Se Rimesse dirette, Bonfici o C/C postali       *
      *              *-------------------------------------------------*
      *                   *--------------------------------------------*
      *                   * Deviazione a seconda della data scadenza   *
      *                   *--------------------------------------------*
           if        srt-dts-eff          >    rr-dat-rfa
                     go to agg-tot-cli-110
           else      go to agg-tot-cli-120.
       agg-tot-cli-110.
      *                   *--------------------------------------------*
      *                   * Se data scadenza maggiore della data rife- *
      *                   * rimento analisi                            *
      *                   *--------------------------------------------*
      *                       *----------------------------------------*
      *                       * Aggiornamento totale a scadere         *
      *                       *----------------------------------------*
           add       srt-imp-sdb          to    w-tot-cli-asc
                                               (w-agg-tot-cli-its)    .
           add       srt-imp-sdb          to    w-tot-cli-tas         .
      *                       *----------------------------------------*
      *                       * Determinazione tipo aggiornamento      *
      *                       *----------------------------------------*
           move      03                   to   w-agg-tot-cli-tae      .
      *                       *----------------------------------------*
      *                       * Uscita                                 *
      *                       *----------------------------------------*
           go to     agg-tot-cli-999.
       agg-tot-cli-120.
      *                   *--------------------------------------------*
      *                   * Se data scadenza minore o uguale alla data *
      *                   * riferimento analisi                        *
      *                   *--------------------------------------------*
      *                       *----------------------------------------*
      *                       * Aggiornamento totale scaduto           *
      *                       *----------------------------------------*
           add       srt-imp-sdb          to    w-tot-cli-sca
                                               (w-agg-tot-cli-its)    .
           add       srt-imp-sdb          to    w-tot-cli-tsc         .
      *                       *----------------------------------------*
      *                       * Determinazione tipo aggiornamento      *
      *                       *----------------------------------------*
           move      01                   to   w-agg-tot-cli-tae      .
      *                       *----------------------------------------*
      *                       * Uscita                                 *
      *                       *----------------------------------------*
