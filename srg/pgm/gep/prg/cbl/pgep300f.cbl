      *              * Se start errata : uscita                        *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to tav-ott-zer-999.
       tav-ott-zer-200.
      *              *-------------------------------------------------*
      *              * Next su scadenze appartenenti alla distinta di  *
      *              * presentazione, con lock                         *
      *              *-------------------------------------------------*
           move      "GN"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *              *-------------------------------------------------*
      *              * Se at end : uscita                              *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to tav-ott-zer-999.
       tav-ott-zer-300.
      *              *-------------------------------------------------*
      *              * Test max su su scadenze appartenenti alla di-   *
      *              * stinta di presentazione, se non superato : ad   *
      *              * unlock ed uscita                                *
      *              *-------------------------------------------------*
           if        rf-sdb-num-ddp       not  = w-tes-num-ddp (1)
                     go to tav-ott-zer-900.
       tav-ott-zer-400.
      *              *-------------------------------------------------*
      *              * Se il 'Tipo avviso ottenuto' per la scadenza e' *
      *              * gia' a zero : ad unlock e riciclo su scadenze   *
      *              *-------------------------------------------------*
           if        rf-sdb-tav-ott       =    zero
                     go to tav-ott-zer-600.
       tav-ott-zer-500.
      *              *-------------------------------------------------*
      *              * Se il 'Tipo avviso ottenuto' per la scadenza e' *
      *              * diverso da zero                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * 'Tipo avviso ottenuto' a zero               *
      *                  *---------------------------------------------*
           move      zero                 to   rf-sdb-tav-ott         .
      *                  *---------------------------------------------*
      *                  * Aggiornamento data chiusura scadenza        *
      *                  *---------------------------------------------*
           perform   det-dat-chs-000      thru det-dat-chs-999        .
      *                  *---------------------------------------------*
      *                  * Update record [sdb]                         *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
       tav-ott-zer-600.
      *              *-------------------------------------------------*
      *              * Unlock record [sdb]                             *
      *              *-------------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *              *-------------------------------------------------*
      *              * Riciclo a scadenza successiva della distinta    *
      *              *-------------------------------------------------*
           go to     tav-ott-zer-200.
       tav-ott-zer-900.
      *              *-------------------------------------------------*
      *              * Unlock record [sdb]                             *
      *              *-------------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
       tav-ott-zer-999.
           exit.

      *    *===========================================================*
      *    * Cancellazione del file di supporto per la trasmissione    *
      *    * della distinta alla banca eventualmente gia' creato       *
      *    *-----------------------------------------------------------*
       can-fil-sup-000.
      *              *-------------------------------------------------*
      *              * Se il file di supporto non era stato creato non *
      *              * si esegue alcuna azione                         *
      *              *-------------------------------------------------*
           if        w-tes-snx-ads (2)    not  = "S"
                     go to can-fil-sup-999.
           if        w-tes-flc-ads (2)    =    zero
                     go to can-fil-sup-999.
       can-fil-sup-100.
      *              *-------------------------------------------------*
      *              * Determinazione pathname completo per il file di *
      *              * supporto per trasmissione distinta alla banca   *
      *              *-------------------------------------------------*
           move      w-tes-cod-cbp (2)    to   w-ads-tab-inp-ban      .
           move      w-tes-num-ddp (2)    to   w-ads-tab-inp-ndi      .
           perform   det-pat-ads-000      thru det-pat-ads-999        .
       can-fil-sup-200.
      *              *-------------------------------------------------*
      *              * Posizionamento del cursore in Safe-Mode         *
      *              *-------------------------------------------------*
           move      "CS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       can-fil-sup-300.
      *              *-------------------------------------------------*
      *              * Cancellazione effettiva del file                *
      *              *-------------------------------------------------*
           move      "PD"                 to   s-ope                  .
           move      w-ads-tab-ndf-pat    to   s-pat                  .
           move      "S"                  to   s-sts                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       can-fil-sup-999.
           exit.

      *    *===========================================================*
      *    * Determinazione pathname completo per il file di supporto  *
      *    * per trasmissione distinta alla banca                      *
      *    *-----------------------------------------------------------*
       det-pat-ads-000.
      *              *-------------------------------------------------*
      *              * Richiesta alla segreteria delle informazioni    *
      *              * relative al formato di un filename, e memo-     *
      *              * rizzazione di :                                 *
      *              *  - Max numero di caratteri per il nome del file *
      *              *  - Max numero di caratteri per l'estensione     *
      *              *  - Carattere di separazione per l'estensione    *
      *              *-------------------------------------------------*
           move      "EX"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-alf                to   w-ads-tab-ndf-fxt      .
       det-pat-ads-200.
      *              *-------------------------------------------------*
      *              * Preparazioni per determinazione nome del file   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Estrazione sigla azienda in uso per ri-     *
      *                  * chiesta al modulo di segreteria             *
      *                  *---------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Memorizzazione della sigla azienda in uso   *
      *                  *---------------------------------------------*
           move      s-azi                to   w-ads-tab-ndf-azi      .
      *                  *---------------------------------------------*
      *                  * Memorizzazione della sigla azienda in uso   *
      *                  * eventualmente troncata ai tre caratteri     *
      *                  *---------------------------------------------*
           move      s-azi                to   w-ads-tab-ndf-az3      .
      *                  *---------------------------------------------*
      *                  * Memorizzazione della sigla della nostra     *
      *                  * banca di presentazione                      *
      *                  *---------------------------------------------*
           move      w-ads-tab-inp-ban    to   w-ads-tab-ndf-ban      .
      *                  *---------------------------------------------*
      *                  * Sigla della nostra banca di presentazione   *
      *                  * in lowercase                                *
      *                  *---------------------------------------------*
           move      w-ads-tab-ndf-ban    to   w-all-str-alf          .
           move      10                   to   w-all-str-lun          .
           perform   all-str-low-000      thru all-str-low-999        .
           move      w-all-str-alf        to   w-ads-tab-ndf-ban      .
      *                  *---------------------------------------------*
      *                  * Editing del numero distinta di quattro ca-  *
      *                  * ratteri con zeri in testa                   *
      *                  *---------------------------------------------*
           move      w-ads-tab-inp-nnn    to   w-ads-tab-ndf-n01      .
      *                  *---------------------------------------------*
      *                  * Editing dell'anno della distinta di quattro *
      *                  * caratteri                                   *
      *                  *---------------------------------------------*
           move      w-ads-tab-inp-saa    to   w-ads-tab-ndf-n02      .
           add       1900                 to   w-ads-tab-ndf-n02      .
      *                  *---------------------------------------------*
      *                  * Editing dell'anno della distinta di due     *
      *                  * caratteri                                   *
      *                  *---------------------------------------------*
           move      w-ads-tab-inp-saa    to   w-ads-tab-ndf-n03      .
       det-pat-ads-300.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del massimo numero di ca-  *
      *              * ratteri per un filename                         *
      *              *-------------------------------------------------*
           if        w-ads-tab-ndf-mxf    <    40
                     go to det-pat-ads-500.
       det-pat-ads-400.
      *              *-------------------------------------------------*
      *              * Se il massimo numero di caratteri per un nome   *
      *              * di file puo' raggiungere i 40 caratteri         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Composizione di una stringa composta come   *
      *                  * segue :                                     *
      *                  *                                             *
      *                  *        aa_bbbb_cccc_dddd_eeeeeeeeee         *
      *                  *                                             *
      *                  * dove : aa         = valore fisso 'dp'       *
      *                  *        bbbb       = anno di quattro cifre   *
      *                  *        cccc       = numero della distinta   *
      *                  *                     di quattro cifre        *
      *                  *        dddd       = sigla azienda           *
      *                  *        eeeeeeeeee = codice banca            *
      *                  *                                             *
      *                  *---------------------------------------------*
           move      spaces               to   w-ads-tab-ndf-nam      .
           string    "dp"
                                delimited by   size
                     "_"
                                delimited by   size
                     w-ads-tab-ndf-n02
                                delimited by   size
                     "_"
                                delimited by   size
                     w-ads-tab-ndf-azi
                                delimited by   spaces
                     "_"
                                delimited by   size
                     w-ads-tab-ndf-n01
                                delimited by   size
                     "_"
                                delimited by   size
                     w-ads-tab-ndf-ban
                                delimited by   spaces
                                          into w-ads-tab-ndf-nam      .
      *                  *---------------------------------------------*
      *                  * A composizione pathname completo            *
      *                  *---------------------------------------------*
           go to     det-pat-ads-600.
       det-pat-ads-500.
      *              *-------------------------------------------------*
      *              * Se il massimo numero di caratteri per un nome   *
      *              * di file non puo' raggiungere i 40 caratteri     *
      *              *-------------------------------------------------*
       det-pat-ads-510.
      *                  *---------------------------------------------*
      *                  * Composizione di una stringa composta come   *
      *                  * segue :                                     *
      *                  *                                             *
      *                  *        aabbcccc.ddd                         *
      *                  *                                             *
      *                  * dove : aa         = valore fisso 'dp'       *
      *                  *        bb         = anno di due cifre       *
      *                  *        cccc       = numero della distinta   *
      *                  *                     di quattro cifre        *
      *                  *        .          = carattere di separa-    *
      *                  *                     zione per l'estensione  *
      *                  *        ddd        = sigla azienda eventual- *
      *                  *                     mente troncata a tre    *
      *                  *                     caratteri               *
      *                  *                                             *
      *                  * nota : l'estensione viene espressa sola-    *
      *                  *        mente se consentita                  *
      *                  *                                             *
      *                  *---------------------------------------------*
           if        w-ads-tab-ndf-mxe    >    zero
                     go to det-pat-ads-520
           else      go to det-pat-ads-530.
       det-pat-ads-520.
           move      spaces               to   w-ads-tab-ndf-nam      .
           string    "dp"
                                delimited by   size
                     w-ads-tab-ndf-n03
                                delimited by   size
                     w-ads-tab-ndf-n01
                                delimited by   size
                     w-ads-tab-ndf-che
                                delimited by   size
                     w-ads-tab-ndf-az3
                                delimited by   spaces
                                          into w-ads-tab-ndf-nam      .
           go to     det-pat-ads-540.
       det-pat-ads-530.
           move      spaces               to   w-ads-tab-ndf-nam      .
           string    "dp"
                                delimited by   size
                     w-ads-tab-ndf-n03
                                delimited by   size
                     w-ads-tab-ndf-n01
                                delimited by   size
                                          into w-ads-tab-ndf-nam      .
           go to     det-pat-ads-540.
       det-pat-ads-540.
      *                  *---------------------------------------------*
      *                  * A composizione pathname completo            *
      *                  *---------------------------------------------*
           go to     det-pat-ads-600.
       det-pat-ads-600.
      *              *-------------------------------------------------*
      *              * Determinazione pathname completo del file       *
      *              *-------------------------------------------------*
           move      "AS"                 to   s-ope                  .
           move      w-ads-tab-ndf-nam    to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-pat                to   w-ads-tab-ndf-pat      .
       det-pat-ads-999.
           exit.

      *    *===========================================================*
      *    * Determinazione status scadenza                            *
      *    *-----------------------------------------------------------*
       det-dat-chs-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione data scadenza chiusa a : Aper- *
      *              * ta                                              *
      *              *-------------------------------------------------*
           move      9999999              to   rf-sdb-dat-chs         .
       det-dat-chs-020.
      *              *-------------------------------------------------*
      *              * Controllo su : Insoluto                         *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-isp       =    zero
                     go to det-dat-chs-040.
      *                  *---------------------------------------------*
      *                  * Se la scadenza e' stata riscossa : oltre    *
      *                  *---------------------------------------------*
           if        rf-sdb-num-ris       not  = zero
                     go to det-dat-chs-040.
      *                  *---------------------------------------------*
      *                  * Se a fronte dell'insoluto non e' stata e-   *
      *                  * messa una nuova scadenza, essa e' da inten- *
      *                  * dersi ancora aperta                         *
      *                  *---------------------------------------------*
           if        rf-sdb-ens-isp       =    02   and
                     rf-sdb-nns-isp       =    zero
                     go to det-dat-chs-999.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-isp       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-040.
      *              *-------------------------------------------------*
      *              * Controllo su : Presunto buon esito              *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-pbe       =     zero
                     go to det-dat-chs-060.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-pbe       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-060.
      *              *-------------------------------------------------*
      *              * Controllo su : Presunto buon esito              *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-nbe       =     zero
                     go to det-dat-chs-080.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-nbe       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-080.
      *              *-------------------------------------------------*
      *              * Controllo su : Accredito scadenza al dopo in-   *
      *              *                casso                            *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-acs       =     zero
                     go to det-dat-chs-100.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-acs       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-100.
      *              *-------------------------------------------------*
      *              * Controllo su : Richiamo della scadenza presen-  *
      *              *                tata                             *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-rsp       =     zero
                     go to det-dat-chs-120.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-rsp       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-120.
      *              *-------------------------------------------------*
      *              * Controllo su : Inclusione in distinta           *
      *              *-------------------------------------------------*
           if        rf-sdb-num-ddp       =     zero
                     go to det-dat-chs-140.
      *                  *---------------------------------------------*
      *                  * Nessuna azione                              *
      *                  *---------------------------------------------*
           go to     det-dat-chs-140.
       det-dat-chs-140.
      *              *-------------------------------------------------*
      *              * Controllo su : Riscossione                      *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-ris       =     zero
                     go to det-dat-chs-160.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-ris       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-160.
      *              *-------------------------------------------------*
      *              * Controllo su : Storno                           *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-sto       =     zero
                     go to det-dat-chs-180.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-sto       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-180.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-999.
           exit.

