           exit.

      *    *===========================================================*
      *    * Routine post-conferma di modifica                         *
      *    *-----------------------------------------------------------*
       pos-cnf-mod-000.
      *              *-------------------------------------------------*
      *              * Determinazione del tipo di modifica intervenuta *
      *              * nell'operazione di presentazione distinta e dei *
      *              * relativi flags indicatori                       *
      *              *-------------------------------------------------*
           perform   det-mod-pre-000      thru det-mod-pre-999        .
      *              *-------------------------------------------------*
      *              * Se il tipo di modifica non comporta alcuna va-  *
      *              * riazione : uscita                               *
      *              *-------------------------------------------------*
           if        w-mod-pre-rec-ddp    =    spaces and
                     w-mod-pre-cge-gep    =    spaces
                     go to pos-cnf-mod-999.
       pos-cnf-mod-050.
      *              *-------------------------------------------------*
      *              * Lettura record [ddp] con lock                   *
      *              *-------------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMDDP    "         to   f-key                  .
           move      w-tes-num-ddp (1)    to   rf-ddp-num-ddp         .
           move      "pgm/gep/fls/ioc/obj/iofddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddp                 .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to pos-cnf-mod-200.
       pos-cnf-mod-100.
      *              *-------------------------------------------------*
      *              * Se record [ddp] non esistente                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   e01-cnf-mod-000      thru e01-cnf-mod-999        .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     pos-cnf-mod-999.
       pos-cnf-mod-200.
      *              *-------------------------------------------------*
      *              * Se record [ddp] esistente                       *
      *              *-------------------------------------------------*
       pos-cnf-mod-250.
      *                  *---------------------------------------------*
      *                  * Controllo che la distinta di presentazione  *
      *                  * non sia nel frattempo stata variata         *
      *                  *---------------------------------------------*
           if        rf-ddp-cod-cbp       =    w-tes-cod-cbp (2) and
                     rf-ddp-snx-stp       =    w-tes-snx-stp (2) and
                     rf-ddp-flc-stp       =    w-tes-flc-stp (2) and
                     rf-ddp-snx-ads       =    w-tes-snx-ads (2) and
                     rf-ddp-flc-ads       =    w-tes-flc-ads (2) and
                     rf-ddp-tip-ias       =    w-tes-tip-ias (2) and
                     rf-ddp-flc-ias       =    w-tes-flc-ias (2)
                     go to pos-cnf-mod-300.
       pos-cnf-mod-275.
      *                  *---------------------------------------------*
      *                  * Se la distinta di presentazione e' stata    *
      *                  * nel frattempo variata                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Unlock record [ddp]                     *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddp                 .
      *                      *-----------------------------------------*
      *                      * Emissione messaggio di errore           *
      *                      *-----------------------------------------*
           perform   e11-cnf-mod-000      thru e11-cnf-mod-999        .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     pos-cnf-mod-999.
       pos-cnf-mod-300.
      *                  *---------------------------------------------*
      *                  * Annullamento del movimento di contabilita'  *
      *                  * generale che era stato a suo tempo genera-  *
      *                  * to a fronte del movimento di portafoglio di *
      *                  * presentazione distinta                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se il tipo di modifica non comporta va- *
      *                      * riazione all'eventuale registrazione    *
      *                      * contabile : nessuna azione              *
      *                      *-----------------------------------------*
           if        w-mod-pre-cge-gep    =    spaces
                     go to pos-cnf-mod-350.
      *                      *-----------------------------------------*
      *                      * Altrimenti : esecuzione                 *
      *                      *-----------------------------------------*
           move      w-tes-drc-pre (2)    to    w-cge-gep-drc-del     .
           move      w-tes-npc-pre (2)    to    w-cge-gep-npc-del     .
           perform   del-cge-gep-000      thru del-cge-gep-999        .
       pos-cnf-mod-350.
      *                  *---------------------------------------------*
      *                  * Aggiornamenti contabili generati dalla ge-  *
      *                  * stione portafoglio a fronte del movimento   *
      *                  * di riscossione                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se il tipo di modifica non comporta va- *
      *                      * riazione all'eventuale registrazione    *
      *                      * contabile : nessuna azione              *
      *                      *-----------------------------------------*
           if        w-mod-pre-cge-gep    =    spaces
                     go to pos-cnf-mod-400.
      *                      *-----------------------------------------*
      *                      * Altrimenti : esecuzione                 *
      *                      *-----------------------------------------*
           perform   cge-gep-pre-000      thru cge-gep-pre-999        .
       pos-cnf-mod-400.
      *                  *---------------------------------------------*
      *                  * Completamento del record distinte con i da- *
      *                  * ti relativi alla presentazione              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Data di sistema di ultimo inserimento o *
      *                      * modifica, utente, fase                  *
      *                      *-----------------------------------------*
           move      w-tes-ide-dat (1)    to   rf-ddp-ide-dat         .
           move      w-tes-ide-ute (1)    to   rf-ddp-ide-ute         .
           move      w-tes-ide-fas (1)    to   rf-ddp-ide-fas         .
      *                      *-----------------------------------------*
      *                      * Data registrazione movimento di presen- *
      *                      * tazione distinta                        *
      *                      *-----------------------------------------*
           move      w-tes-dat-reg        to   rf-ddp-dtr-pre         .
      *                      *-----------------------------------------*
      *                      * Se il tipo di modifica non comporta va- *
      *                      * riazione all'eventuale registrazione    *
      *                      * contabile : si lasciano inalterati la   *
      *                      * data di registrazione ed il numero pro- *
      *                      * tocollo di contabilita'                 *
      *                      *-----------------------------------------*
           if        w-mod-pre-cge-gep    =    spaces
                     go to pos-cnf-mod-450.
      *                      *-----------------------------------------*
      *                      * Data registrazione movimento di conta-  *
      *                      * bilita' a fronte del movimento di pre-  *
      *                      * sentazione distinta                     *
      *                      *-----------------------------------------*
           move      l-cge-300-dat-reg    to   rf-ddp-drc-pre         .
      *                      *-----------------------------------------*
      *                      * Numero protocollo movimento di conta-   *
      *                      * bilita' a fronte del movimento di pre-  *
      *                      * sentazione distinta                     *
      *                      *-----------------------------------------*
           move      l-cge-300-num-prt    to   rf-ddp-npc-pre         .
       pos-cnf-mod-450.
      *                      *-----------------------------------------*
      *                      * Tipo di presentazione distinta          *
      *                      *-----------------------------------------*
           move      w-tes-tip-pre (1)    to   rf-ddp-tip-pre         .
      *                      *-----------------------------------------*
      *                      * Codice nostra banca per la presentazio- *
      *                      * ne                                      *
      *                      *-----------------------------------------*
           move      w-tes-cod-cbp (1)    to   rf-ddp-cod-cbp         .
      *                      *-----------------------------------------*
      *                      * Stampa cartacea distinta                *
      *                      *-----------------------------------------*
           move      w-tes-snx-stp (1)    to   rf-ddp-snx-stp         .
      *                      *-----------------------------------------*
      *                      * Flag/contatore di stampa su carta ese-  *
      *                      * guita                                   *
      *                      *-----------------------------------------*
           move      w-tes-flc-stp (1)    to   rf-ddp-flc-stp         .
      *                      *-----------------------------------------*
      *                      * Preparazione archivio di supporto per   *
      *                      * trasmissione distinta alla banca        *
      *                      *-----------------------------------------*
           move      w-tes-snx-ads (1)    to   rf-ddp-snx-ads         .
      *                      *-----------------------------------------*
      *                      * Flag/contatore di preparazione archivio *
      *                      * di supporto per trasmissione distinta   *
      *                      * alla banca                              *
      *                      *-----------------------------------------*
           move      w-tes-flc-ads (1)    to   rf-ddp-flc-ads         .
      *                      *-----------------------------------------*
      *                      * Tipo di invio dell'archivio di supporto *
      *                      * alla banca                              *
      *                      *-----------------------------------------*
           move      w-tes-tip-ias (1)    to   rf-ddp-tip-ias         .
      *                      *-----------------------------------------*
      *                      * Flag/contatore di invio dell'archivio   *
      *                      * di supporto alla banca eseguito         *
      *                      *-----------------------------------------*
           move      w-tes-flc-ias (1)    to   rf-ddp-flc-ias         .
       pos-cnf-mod-500.
      *                  *---------------------------------------------*
      *                  * Update record [ddp]                         *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddp                 .
       pos-cnf-mod-600.
      *                  *---------------------------------------------*
      *                  * Unlock record [ddp]                         *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddp                 .
       pos-cnf-mod-900.
      *                  *---------------------------------------------*
      *                  * Forzatura del 'Tipo avviso ottenuto' a zero *
      *                  * per le scadenze appartenenti alla distinta  *
      *                  * che avessero tale valore diverso da zero    *
      *                  *---------------------------------------------*
           perform   tav-ott-zer-000      thru tav-ott-zer-999        .
      *                  *---------------------------------------------*
      *                  * Cancellazione del file di supporto per la   *
      *                  * trasmissione della distinta alla banca e-   *
      *                  * ventualmente gia' creato                    *
      *                  *---------------------------------------------*
           perform   can-fil-sup-000      thru can-fil-sup-999        .
       pos-cnf-mod-999.
           exit.

