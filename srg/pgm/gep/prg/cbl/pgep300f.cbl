           if        w-tes-cod-cbp-cge (1)
                                          not  = zero
                     go to acc-cod-cbp-475.
           if        w-tes-cod-cbp (1)    =    spaces
                     go to acc-cod-cbp-475.
           move      "Attenzione : nell'anagrafica banca manca il sottoc
      -              "onto per la    "    to   w-err-box-err-msg      .
           move      "             presentazione al SBF a maturazione di
      -              " valuta  "          to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           go to     acc-cod-cbp-100.
       acc-cod-cbp-460.
      *                      *-----------------------------------------*
