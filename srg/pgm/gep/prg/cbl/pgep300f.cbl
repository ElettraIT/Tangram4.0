      *    *===========================================================*
      *    * Determinazione default per numero distinta                *
      *    *-----------------------------------------------------------*
       det-def-num-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione preliminare                     *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-def-num-num      .
       det-def-num-100.
      *              *-------------------------------------------------*
      *              * Start su distinte di presentazione              *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "DATSYS    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      w-det-def-num-dat    to   rf-ddp-ide-dat         .
           move      zero                 to   rf-ddp-num-ddp         .
           move      "pgm/gep/fls/ioc/obj/iofddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddp                 .
      *                  *---------------------------------------------*
      *                  * Se start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-def-num-900.
       det-def-num-200.
      *              *-------------------------------------------------*
      *              * Next su distinte di presentazione               *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddp                 .
      *                  *---------------------------------------------*
      *                  * Se at end : uscita                          *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-def-num-900.
       det-def-num-300.
      *              *-------------------------------------------------*
      *              * Test max                                        *
      *              *-------------------------------------------------*
           if        rf-ddp-ide-dat       not  = w-det-def-num-dat
                     go to det-def-num-900.
       det-def-num-400.
      *              *-------------------------------------------------*
      *              * Selezioni su status distinta                    *
      *              *-------------------------------------------------*
           if        rf-ddp-dtr-pre       not  = zero
                     go to det-def-num-200.
       det-def-num-600.
      *              *-------------------------------------------------*
      *              * Bufferizzazione                                 *
      *              *-------------------------------------------------*
           move      rf-ddp-num-ddp       to   w-det-def-num-num      .
       det-def-num-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-def-num-999.
       det-def-num-999.
           exit.

