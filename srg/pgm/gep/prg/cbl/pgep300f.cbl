           else if   w-tes-tip-ope        =    0502
                     go to acc-cod-cbp-460
           else if   w-tes-tip-ope        =    0503
                     go to acc-cod-cbp-465
           else if   w-tes-tip-ope        =    0504
                     go to acc-cod-cbp-470.
       acc-cod-cbp-455.
