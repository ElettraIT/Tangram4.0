           move      rf-ddp-npc-act       to   w-tes-npc-act (1)      .
           move      rf-ddp-dcb-act       to   w-tes-dcb-act (1)      .
           move      rf-ddp-ncb-act       to   w-tes-ncb-act (1)      .
           move      rf-ddp-spe-act       to   w-tes-spe-act (1)      .
           move      rf-ddp-int-act       to   w-tes-int-act (1)      .
           move      rf-ddp-dtr-acd       to   w-tes-dtr-acd (1)      .
           move      rf-ddp-drc-acd       to   w-tes-drc-acd (1)      .
           move      rf-ddp-npc-acd       to   w-tes-npc-acd (1)      .
           move      rf-ddp-dcb-acd       to   w-tes-dcb-acd (1)      .
           move      rf-ddp-ncb-acd       to   w-tes-ncb-acd (1)      .
           move      rf-ddp-spe-acd       to   w-tes-spe-acd (1)      .
           move      rf-ddp-int-acd       to   w-tes-int-acd (1)      .
           move      rf-ddp-flg-ela       to   w-tes-flg-ela (1)      .
           move      rf-ddp-flg-pul       to   w-tes-flg-pul (1)      .
           move      rf-ddp-alx-exp       to   w-tes-alx-exp (1)      .
       dda-ddp-wte-500.
      *              *-------------------------------------------------*
      *              * Valori indirettamente ottenuti da [ddp]         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Da codice banca di presentazione            *
      *                  *---------------------------------------------*
           move      02                   to   w-let-arc-cbp-tip      .
           move      w-tes-cod-cbp (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
           move      w-let-arc-cbp-des    to   w-tes-cod-cbp-des (1)  .
           if        w-tes-tip-pre (1)    =    01
                     move  w-let-arc-cbp-psm
                                          to   w-tes-cod-cbp-cge (1)
           else if   w-tes-tip-pre (1)    =    02
                     move  w-let-arc-cbp-psi
                                          to   w-tes-cod-cbp-cge (1)
           else if   w-tes-tip-pre (1)    =    03
                     move  w-let-arc-cbp-pdi
                                          to   w-tes-cod-cbp-cge (1)
           else if   w-tes-tip-pre (1)    =    04
                     move  w-let-arc-cbp-psc
                                          to   w-tes-cod-cbp-cge (1)
           else      move  zero           to   w-tes-cod-cbp-cge (1)  .
      *                  *---------------------------------------------*
      *                  * Da codice banca di presentazione per la     *
      *                  * selezioni su clienti                        *
      *                  *---------------------------------------------*
           move      02                   to   w-let-arc-cbp-tip      .
           move      w-tes-cod-bpe (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
           move      w-let-arc-cbp-des    to   w-tes-cod-bpe-des (1)  .
       dda-ddp-wte-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione work per riga corpo, ad esclusione del    *
      *    * numero progressivo                                        *
      *    *-----------------------------------------------------------*
       nor-war-wri-000.
           move      zero                 to   w-rig-num-sdb (1)      .
           move      zero                 to   w-rig-tip-sdb (1)      .
           move      zero                 to   w-rig-dts-sdb (1)      .
           move      zero                 to   w-rig-tip-dbt (1)      .
           move      zero                 to   w-rig-cod-dbt (1)      .
           move      spaces               to   w-rig-cod-dbt-rag (1)  .
           move      spaces               to   w-rig-dpz-dbt (1)      .
           move      spaces               to   w-rig-dpz-dbt-rag (1)  .
           move      zero                 to   w-rig-inl-sdb (1)      .
           move      zero                 to   w-rig-imp-sdb (1)      .
       nor-war-wri-999.
           exit.

      *    *===========================================================*
      *    * Test Si/No aggiornamenti contabili da gestione portafo-   *
      *    * glio per i movimenti di presentazione distinta            *
      *    *-----------------------------------------------------------*
       cge-gep-pre-snx-000.
      *              *-------------------------------------------------*
      *              * Se le personalizzazioni indicano che in ogni    *
      *              * caso gli aggiornamenti contabili non devono     *
      *              * essere eseguiti : uscita con 'N'                *
      *              *-------------------------------------------------*
           if        w-prs-gep-snx-cge    =    "N"
                     move  "N"            to   w-cge-gep-pre-snx
                     go to cge-gep-pre-snx-999.
      *              *-------------------------------------------------*
      *              * Se il codice causale contabile per il tipo ope- *
      *              * razione di presentazione e' a zero : uscita con *
      *              * 'N'                                             *
      *              *-------------------------------------------------*
           if        w-top-cau-cge
                    (w-top-ele-inx)       =    zero
                     move  "N"            to   w-cge-gep-pre-snx
                     go to cge-gep-pre-snx-999.
      *              *-------------------------------------------------*
      *              * Altrimenti si esce con 'S'                      *
      *              *-------------------------------------------------*
           move      "S"                  to   w-cge-gep-pre-snx      .
       cge-gep-pre-snx-999.
           exit.

      *    *===========================================================*
      *    * Aggiornamenti contabili generati dalla gestione  portafo- *
      *    * glio a fronte del movimento di presentazione distinta     *
      *    *                                                           *
      *    * Nota : Vedere i commenti per il modulo 'pgep3000' per le  *
      *    *        generalita' sugli aggiornamenti contabili riguar-  *
      *    *        danti la gestione portafoglio.                     *
      *    *-----------------------------------------------------------*
       cge-gep-pre-000.
      *              *-------------------------------------------------*
      *              * Se si e' in modifica di una registrazione che   *
      *              * non aveva generato nessun movimento contabile,  *
      *              * non si genera il movimento contabile            *
      *              *-------------------------------------------------*
           if       (w-cnt-mfu-tip-fun    =    "M"   ) and
                    (w-tes-drc-pre (1)    =    zero or
                     w-tes-npc-pre (1)    =    zero  )
                     go to cge-gep-pre-100.
       cge-gep-pre-025.
      *              *-------------------------------------------------*
      *              * Test se aggiornamento da eseguire               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se in assoluto l'aggiornamento e' da   *
      *                  * eseguire                                    *
      *                  *---------------------------------------------*
           perform   cge-gep-pre-snx-000  thru cge-gep-pre-snx-999    .
      *                  *---------------------------------------------*
      *                  * Se No' : a no aggiornamento                 *
      *                  *---------------------------------------------*
           if        w-cge-gep-pre-snx    not  = "S"
                     go to cge-gep-pre-100.
       cge-gep-pre-050.
      *                  *---------------------------------------------*
      *                  * Se la routine di totalizzazioni per il mo-  *
      *                  * vimento di contabilita' generale ha posto   *
      *                  * in On il flag di 'No aggiornamenti contabi- *
      *                  * li' : a No aggiornamento                    *
      *                  *---------------------------------------------*
           if        w-mov-cge-flg-nag    not  = spaces
                     go to cge-gep-pre-100.
       cge-gep-pre-060.
      *                  *---------------------------------------------*
      *                  * Se l'accumulo per l'importo in Dare e' a    *
      *                  * zero : a No aggiornamento                   *
      *                  *---------------------------------------------*
           if        w-mov-cge-acc-sdp    =    zero
                     go to cge-gep-pre-100.
       cge-gep-pre-075.
      *                  *---------------------------------------------*
      *                  * Test se esiste almeno una riga per la re-   *
      *                  * gistrazione contabile con importo diverso   *
      *                  * da zero.                                    *
      *                  *                                             *
      *                  * Se si' : ad aggiornamento                   *
      *                  * Se no  : a no aggiornamento                 *
      *                  *                                             *
      *                  * Nota : Se si', l'indice per la scansione    *
      *                  *        sulle righe del movimento di con-    *
      *                  *        tabilita' generale punta gia' al     *
      *                  *        primo elemento utile                 *
      *                  *---------------------------------------------*
           if        w-mov-cge-ctr-sdb    not  > zero
                     go to cge-gep-pre-100.
           move      zero                 to   w-mov-cge-inx-001      .
       cge-gep-pre-080.
           add       1                    to   w-mov-cge-inx-001      .
           if        w-mov-cge-inx-001    >    w-mov-cge-ctr-rig
                     go to cge-gep-pre-100.
           if        w-mov-cge-cod-stc
                    (w-mov-cge-inx-001)   not  = zero and
                     w-mov-cge-imp-rig
                    (w-mov-cge-inx-001)   not  = zero
                     go to cge-gep-pre-200
           else      go to cge-gep-pre-080.
       cge-gep-pre-100.
      *              *-------------------------------------------------*
      *              * Se No aggiornamento                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Data registrazione movimento contabile : a  *
      *                  * zero                                        *
      *                  *---------------------------------------------*
           move      zero                 to   l-cge-300-dat-reg      .
      *                  *---------------------------------------------*
      *                  * Numero protocollo movimento contabile : a   *
      *                  * zero                                        *
      *                  *---------------------------------------------*
           move      zero                 to   l-cge-300-num-prt      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     cge-gep-pre-999.
       cge-gep-pre-200.
      *              *-------------------------------------------------*
      *              * Esecuzione aggiornamento contabile : viene ese- *
      *              * guita una registrazione in base alla tabella    *
      *              * righe movimento di contabilita' generale pre-   *
      *              * parata durante la lettura della distinta nel-   *
      *              * la routine rou-let-reg-000/999.                 *
      *              *-------------------------------------------------*
       cge-gep-pre-300.
      *                  *---------------------------------------------*
      *                  * Normalizzazione work-area testata e prima   *
      *                  * riga movimento per aggiornamenti contabili  *
      *                  *---------------------------------------------*
           move      "NO"                 to   l-cge-300-tip-ope      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                  *---------------------------------------------*
      *                  * Preparazione link-area per testata e riga   *
      *                  * movimento per il Dare                       *
      *                  *                                             *
      *                  * Nota : i seguenti campi non vengono prepa-  *
      *                  *        rati in quanto gia' normalizzati :   *
      *                  *                                             *
      *                  *        - Numero protocollo                  *
      *                  *        - Descrizione per codice causale     *
      *                  *        - Codice numerazione                 *
      *                  *        - Numero protocollo Iva              *
      *                  *        - Commento in riga                   *
      *                  *        - Castelletto Iva                    *
      *                  *        - Totale documento Iva               *
      *                  *                                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo operazione                         *
      *                      *-----------------------------------------*
           move      "WR"                 to   l-cge-300-tip-ope      .
      *                      *-----------------------------------------*
      *                      * Data di registrazione                   *
      *                      *                                         *
      *                      * Nota : Se pre-esiste una data registra- *
      *                      *        zione contabile la si conserva   *
      *                      *        comunque.                        *
      *                      *                                         *
      *                      *        Cio' per salvaguardare eventua-  *
      *                      *        li date di registrazione conta-  *
      *                      *        bile diverse dalla data di regi- *
      *                      *        strazione movimento, come ad e-  *
      *                      *        sempio in caso di movimento in-  *
      *                      *        dotto da altre procedure che am- *
      *                      *        mettessero la forzatura della    *
      *                      *        data contabile.                  *
      *                      *-----------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "I"
                     move  w-tes-dat-reg  to   l-cge-300-dat-reg
           else if   w-tes-drc-pre (2)    not  = zero
                     move  w-tes-drc-pre (2)
                                          to   l-cge-300-dat-reg
           else      move  w-tes-dat-reg  to   l-cge-300-dat-reg      .
      *                      *-----------------------------------------*
      *                      * Codice causale contabile                *
      *                      *-----------------------------------------*
           move      w-top-cau-cge
                    (w-top-ele-inx)       to   l-cge-300-cod-cau      .
      *                      *-----------------------------------------*
      *                      * Descrizione causale                     *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-des-cau      .
      *                      *-----------------------------------------*
      *                      * Si/No data scadenza                     *
      *                      *-----------------------------------------*
           move      "N"                  to   l-cge-300-snx-dts      .
      *                      *-----------------------------------------*
      *                      * Data scadenza                           *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-dat-sca      .
      *                      *-----------------------------------------*
      *                      * Data documento                          *
      *                      *-----------------------------------------*
           move      w-tes-dtr-com (1)    to   l-cge-300-dat-doc      .
      *                      *-----------------------------------------*
      *                      * Numero documento                        *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      w-tes-num-ddp (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   l-cge-300-num-doc      .
      *                      *-----------------------------------------*
      *                      * Codice sottoconto                       *
      *                      *-----------------------------------------*
           move      w-tes-cod-cbp-cge (1)
                                          to   l-cge-300-cod-pdc      .
      *                      *-----------------------------------------*
      *                      * Tipo archivio                           *
      *                      *-----------------------------------------*
           move      "G"                  to   l-cge-300-tip-arc      .
      *                      *-----------------------------------------*
      *                      * Codice archivio                         *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-cod-arc      .
      *                      *-----------------------------------------*
      *                      * Data riferimento                        *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-dat-rif      .
      *                      *-----------------------------------------*
      *                      * Numero riferimento                      *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-num-rif      .
      *                      *-----------------------------------------*
      *                      * Dare/Avere                              *
      *                      *-----------------------------------------*
           move      "D"                  to   l-cge-300-dar-ave      .
      *                      *-----------------------------------------*
      *                      * Importo movimento                       *
      *                      *-----------------------------------------*
           move      w-mov-cge-acc-sdp    to   l-cge-300-imp-mov      .
      *                      *-----------------------------------------*
      *                      * Flag di regime fiscale particolare      *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-flg-rfp      .
      *                      *-----------------------------------------*
      *                      * Sigla numerazione                       *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-sgl-num      .
      *                      *-----------------------------------------*
      *                      * Data acquisizione                       *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-dat-acq      .
      *                  *---------------------------------------------*
      *                  * Richiamo sottoprogramma per aggiornamenti   *
      *                  * contabili                                   *
      *                  *---------------------------------------------*
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                  *---------------------------------------------*
      *                  * Alle righe in Avere                         *
      *                  *---------------------------------------------*
           go to     cge-gep-pre-500.
       cge-gep-pre-400.
      *                  *---------------------------------------------*
      *                  * Incremento indice per puntamento alla riga  *
      *                  * di contabilita' generale successiva         *
      *                  *---------------------------------------------*
           add       1                    to   w-mov-cge-inx-001      .
      *                  *---------------------------------------------*
      *                  * Se oltre il massimo : fine aggiornamenti    *
      *                  *---------------------------------------------*
           if        w-mov-cge-inx-001    >    w-mov-cge-ctr-rig
                     go to cge-gep-pre-999.
      *                  *---------------------------------------------*
      *                  * Se riga non significativa : riciclo alla    *
      *                  * riga successiva                             *
      *                  *---------------------------------------------*
           if        w-mov-cge-cod-stc
                    (w-mov-cge-inx-001)   =    zero or
                     w-mov-cge-imp-rig
                    (w-mov-cge-inx-001)   =    zero
                     go to cge-gep-pre-400.
       cge-gep-pre-500.
      *                  *---------------------------------------------*
      *                  * Normalizzazione work-area riga movimento    *
      *                  * per aggiornamenti contabili                 *
      *                  *---------------------------------------------*
           move      "N+"                 to   l-cge-300-tip-ope      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                  *---------------------------------------------*
      *                  * Preparazione link-area per riga movimento   *
      *                  * successiva alla prima                       *
      *                  *                                             *
      *                  * Nota : i seguenti campi non vengono prepa-  *
      *                  *        rati in quanto gia' normalizzati :   *
      *                  *                                             *
      *                  *        - Commento in riga                   *
      *                  *                                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo operazione                         *
      *                      *-----------------------------------------*
           move      "W+"                 to   l-cge-300-tip-ope      .
      *                      *-----------------------------------------*
      *                      * Codice sottoconto                       *
      *                      *-----------------------------------------*
           move      w-mov-cge-cod-stc
                    (w-mov-cge-inx-001)   to   l-cge-300-cod-pdc      .
      *                      *-----------------------------------------*
      *                      * Tipo archivio                           *
      *                      *-----------------------------------------*
           move      "G"                  to   l-cge-300-tip-arc      .
      *                      *-----------------------------------------*
      *                      * Codice archivio                         *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-cod-arc      .
      *                      *-----------------------------------------*
      *                      * Data riferimento                        *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-dat-rif      .
      *                      *-----------------------------------------*
      *                      * Numero riferimento                      *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-num-rif      .
      *                      *-----------------------------------------*
      *                      * Dare/Avere                              *
      *                      *-----------------------------------------*
           move      "A"                  to   l-cge-300-dar-ave      .
      *                      *-----------------------------------------*
      *                      * Importo movimento                       *
      *                      *-----------------------------------------*
           move      w-mov-cge-imp-rig
                    (w-mov-cge-inx-001)   to   l-cge-300-imp-mov      .
      *                      *-----------------------------------------*
      *                      * Flag di regime fiscale particolare      *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-flg-rfp      .
      *                      *-----------------------------------------*
      *                      * Sigla numerazione                       *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-sgl-num      .
      *                      *-----------------------------------------*
      *                      * Data acquisizione                       *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-dat-acq      .
      *                  *---------------------------------------------*
      *                  * Richiamo sottoprogramma per aggiornamenti   *
      *                  * contabili                                   *
      *                  *---------------------------------------------*
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
       cge-gep-pre-600.
      *                  *---------------------------------------------*
      *                  * Riciclo a riga successiva                   *
      *                  *---------------------------------------------*
           go to     cge-gep-pre-400.
       cge-gep-pre-999.
           exit.

      *    *===========================================================*
      *    * Annullamento del movimento di contabilita' generale che   *
      *    * era stato a suo tempo generato a fronte del movimento di  *
      *    * portafoglio                                               *
      *    *-----------------------------------------------------------*
       del-cge-gep-000.
      *              *-------------------------------------------------*
      *              * Se data registrazione o numero protocollo della *
      *              * registrazione contabile da annullare a zero :   *
      *              * uscita senza alcuna azione                      *
      *              *-------------------------------------------------*
           if        w-cge-gep-drc-del    =    zero or
                     w-cge-gep-npc-del    =    zero
                     go to del-cge-gep-999.
      *              *-------------------------------------------------*
      *              * Preparazione link-area per annullamento regi-   *
      *              * strazione di contabilita'                       *
      *              *-------------------------------------------------*
           move      "DE"                 to   l-cge-300-tip-ope      .
           move      w-cge-gep-drc-del    to   l-cge-300-dat-reg      .
           move      w-cge-gep-npc-del    to   l-cge-300-num-prt      .
      *              *-------------------------------------------------*
      *              * Richiamo sottoprogramma per aggiornamenti con-  *
      *              * tabili                                          *
      *              *-------------------------------------------------*
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
       del-cge-gep-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [sdb]                         *
      *    *-----------------------------------------------------------*
       let-arc-sdb-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-sdb-flg      .
      *              *-------------------------------------------------*
      *              * Test se numero scadenza a zero                  *
      *              *-------------------------------------------------*
           if        w-let-arc-sdb-num    =    zero
                     go to let-arc-sdb-500.
      *              *-------------------------------------------------*
      *              * Lettura per numero scadenza                     *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMSDB    "         to   f-key                  .
           move      w-let-arc-sdb-num    to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-sdb-400.
       let-arc-sdb-200.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-sdb-999.
       let-arc-sdb-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-sdb-flg      .
       let-arc-sdb-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione area record                     *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
           move      w-let-arc-sdb-num    to   rf-sdb-num-sdb         .
       let-arc-sdb-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [obp]                         *
      *    *-----------------------------------------------------------*
       let-arc-obp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-obp-flg      .
      *              *-------------------------------------------------*
      *              * Test se tipo record a zero                      *
      *              *-------------------------------------------------*
           if        w-let-arc-obp-tip    =    zero
                     go to let-arc-obp-500.
      *              *-------------------------------------------------*
      *              * Test se numero scadenza a zero                  *
      *              *-------------------------------------------------*
           if        w-let-arc-obp-num    =    zero
                     go to let-arc-obp-500.
      *              *-------------------------------------------------*
      *              * Lettura per numero scadenza                     *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMOBP    "         to   f-key                  .
           move      w-let-arc-obp-tip    to   rf-obp-tip-obp         .
           move      w-let-arc-obp-num    to   rf-obp-num-obp         .
           move      "pgm/gep/fls/ioc/obj/iofobp"
