           exit.

      *    *===========================================================*
      *    * Routine post-conferma di inserimento                      *
      *    *-----------------------------------------------------------*
       pos-cnf-ins-000.
      *              *-------------------------------------------------*
      *              * Aggiornamento default per data registrazione    *
      *              *-------------------------------------------------*
           move      w-key-dat-reg        to   w-def-dat-reg          .
      *              *-------------------------------------------------*
      *              * Aggiornamento default per tipo operazione       *
      *              *-------------------------------------------------*
           move      w-key-tip-ope        to   w-def-tip-ope          .
       pos-cnf-ins-050.
      *              *-------------------------------------------------*
      *              * Lettura record [ddp] con lock                   *
      *              *-------------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMDDP    "         to   f-key                  .
           move      w-tes-num-ddp (1)    to   rf-ddp-num-ddp         .
           move      "pgm/gep/fls/ioc/obj/iofddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddp                 .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to pos-cnf-ins-200.
       pos-cnf-ins-100.
      *              *-------------------------------------------------*
      *              * Se record [ddp] non esistente                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   e01-cnf-ins-000      thru e01-cnf-ins-999        .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     pos-cnf-ins-999.
       pos-cnf-ins-200.
      *              *-------------------------------------------------*
      *              * Se record [ddp] esistente                       *
      *              *-------------------------------------------------*
       pos-cnf-ins-250.
      *                  *---------------------------------------------*
      *                  * Controllo che la distinta di presentazione  *
      *                  * non sia nel frattempo stata variata         *
      *                  *---------------------------------------------*
           if        rf-ddp-dtr-pre       =    zero              and
                     rf-ddp-drc-pre       =    zero              and
                     rf-ddp-npc-pre       =    zero              and
                     rf-ddp-cod-cbp       =    spaces            and
                     rf-ddp-snx-stp       =    spaces            and
                     rf-ddp-flc-stp       =    w-tes-flc-stp (1) and
                     rf-ddp-snx-ads       =    spaces            and
                     rf-ddp-flc-ads       =    zero              and
                     rf-ddp-tip-ias       =    zero              and
                     rf-ddp-flc-ias       =    zero
                     go to pos-cnf-ins-300.
       pos-cnf-ins-275.
      *                  *---------------------------------------------*
      *                  * Se la distinta di presentazione e' stata    *
      *                  * nel frattempo variata                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Unlock record [ddp]                     *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddp                 .
      *                      *-----------------------------------------*
      *                      * Emissione messaggio di errore           *
      *                      *-----------------------------------------*
           perform   e11-cnf-ins-000      thru e11-cnf-ins-999        .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     pos-cnf-ins-999.
       pos-cnf-ins-300.
      *                  *---------------------------------------------*
      *                  * Aggiornamenti contabili generati dalla ge-  *
      *                  * stione portafoglio a fronte del movimento   *
      *                  * di presentazione distinta                   *
      *                  *---------------------------------------------*
           perform   cge-gep-pre-000      thru cge-gep-pre-999        .
       pos-cnf-ins-350.
      *                  *---------------------------------------------*
      *                  * Completamento del record distinte con i da- *
      *                  * ti relativi alla presentazione              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Data di sistema di ultimo inserimento o *
      *                      * modifica, utente, fase                  *
      *                      *-----------------------------------------*
           move      w-tes-ide-dat (1)    to   rf-ddp-ide-dat         .
           move      w-tes-ide-ute (1)    to   rf-ddp-ide-ute         .
           move      w-tes-ide-fas (1)    to   rf-ddp-ide-fas         .
      *                      *-----------------------------------------*
      *                      * Data registrazione movimento di presen- *
      *                      * tazione distinta                        *
      *                      *-----------------------------------------*
           move      w-tes-dat-reg        to   rf-ddp-dtr-pre         .
      *                      *-----------------------------------------*
      *                      * Data registrazione movimento di conta-  *
      *                      * bilita' a fronte del movimento di pre-  *
      *                      * sentazione distinta                     *
      *                      *-----------------------------------------*
           move      l-cge-300-dat-reg    to   rf-ddp-drc-pre         .
      *                      *-----------------------------------------*
      *                      * Numero protocollo movimento di conta-   *
      *                      * bilita' a fronte del movimento di pre-  *
      *                      * sentazione distinta                     *
      *                      *-----------------------------------------*
           move      l-cge-300-num-prt    to   rf-ddp-npc-pre         .
      *                      *-----------------------------------------*
      *                      * Tipo di presentazione distinta          *
      *                      *-----------------------------------------*
           move      w-tes-tip-pre (1)    to   rf-ddp-tip-pre         .
      *                      *-----------------------------------------*
      *                      * Codice nostra banca per la presentazio- *
      *                      * ne                                      *
      *                      *-----------------------------------------*
           move      w-tes-cod-cbp (1)    to   rf-ddp-cod-cbp         .
      *                      *-----------------------------------------*
      *                      * Stampa cartacea distinta                *
      *                      *-----------------------------------------*
           move      w-tes-snx-stp (1)    to   rf-ddp-snx-stp         .
      *                      *-----------------------------------------*
      *                      * Flag/contatore di stampa su carta ese-  *
      *                      * guita                                   *
      *                      *-----------------------------------------*
           move      w-tes-flc-stp (1)    to   rf-ddp-flc-stp         .
      *                      *-----------------------------------------*
      *                      * Preparazione archivio di supporto per   *
      *                      * trasmissione distinta alla banca        *
      *                      *-----------------------------------------*
           move      w-tes-snx-ads (1)    to   rf-ddp-snx-ads         .
      *                      *-----------------------------------------*
      *                      * Flag/contatore di preparazione archivio *
      *                      * di supporto per trasmissione distinta   *
      *                      * alla banca                              *
      *                      *-----------------------------------------*
           move      w-tes-flc-ads (1)    to   rf-ddp-flc-ads         .
      *                      *-----------------------------------------*
      *                      * Tipo di invio dell'archivio di supporto *
      *                      * alla banca                              *
      *                      *-----------------------------------------*
           move      w-tes-tip-ias (1)    to   rf-ddp-tip-ias         .
      *                      *-----------------------------------------*
      *                      * Flag/contatore di invio dell'archivio   *
      *                      * di supporto alla banca eseguito         *
      *                      *-----------------------------------------*
           move      w-tes-flc-ias (1)    to   rf-ddp-flc-ias         .
       pos-cnf-ins-400.
      *                  *---------------------------------------------*
      *                  * Update record [ddp]                         *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddp                 .
       pos-cnf-ins-500.
      *                  *---------------------------------------------*
      *                  * Unlock record [ddp]                         *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddp                 .
       pos-cnf-ins-900.
      *                  *---------------------------------------------*
      *                  * Forzatura del 'Tipo avviso ottenuto' a zero *
      *                  * per le scadenze appartenenti alla distinta  *
      *                  * che avessero tale valore diverso da zero    *
      *                  *---------------------------------------------*
           perform   tav-ott-zer-000      thru tav-ott-zer-999        .
       pos-cnf-ins-999.
           exit.

      *    *===========================================================*
      *    * Messaggio di errore di tipo 01 su conferma impostazioni   *
      *    * per inserimento                                           *
      *    *                                                           *
      *    * Distinta di presentazione non piu' esistente              *
      *    *-----------------------------------------------------------*
       e01-cnf-ins-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      07                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      80                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Literal per 'Attenzione'                        *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      03                   to   v-pos                  .
           move      "Attenzione :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Contenuto per il literal di 'Attenzione'        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione numero distinta editato        *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      w-tes-num-ddp (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione contenuto literal di 'At-   *
      *                  * tenzione'                                   *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      63                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      16                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           string    "Non esiste piu' la distinta numero "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " !"       delimited by   size
                                          into v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Literal per 'Messaggio'                         *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      03                   to   v-pos                  .
           move      "Messaggio  :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Contenuto per il literal di 'Messaggio'         *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      63                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      16                   to   v-pos                  .
           move      "La presentazione distinta non viene pertanto esegu
      -              "ita.         "      to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Literal per 'Presa visione'                     *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      38                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      "Premere un tasto per presa visione [ ]"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
