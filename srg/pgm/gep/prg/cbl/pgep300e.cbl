      *    *===========================================================*
      *    * Estrazione voce successiva da stampere, gia' editata, per *
      *    * la colonna per l'appoggio bancario                        *
      *    *-----------------------------------------------------------*
       ext-are-wcc-000.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'indice dell'ultima    *
      *              * voce gia' stampata                              *
      *              *-------------------------------------------------*
           if        w-sta-dis-wcc-iuv    =    zero
                     go to ext-are-wcc-100
           else if   w-sta-dis-wcc-iuv    =    01
                     go to ext-are-wcc-200
           else if   w-sta-dis-wcc-iuv    =    02
                     go to ext-are-wcc-300
           else if   w-sta-dis-wcc-iuv    =    03
                     go to ext-are-wcc-400
           else if   w-sta-dis-wcc-iuv    =    04
                     go to ext-are-wcc-500
           else      go to ext-are-wcc-600.
       ext-are-wcc-100.
      *              *-------------------------------------------------*
      *              * Se non ancora stampata alcuna voce              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Codice ABI, se esiste, altrimenti a voce    *
      *                  * successiva                                  *
      *                  *---------------------------------------------*
           if        w-sta-dis-ecc-e01    =    spaces
                     go to ext-are-wcc-200.
           move      01                   to   w-sta-dis-wcc-iuv      .
           move      w-sta-dis-ecc-e01    to   w-sta-dis-wcc-edt      .
           go to     ext-are-wcc-999.
       ext-are-wcc-200.
      *              *-------------------------------------------------*
      *              * Se ultima voce stampata : codice ABI            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Codice CAB denominazione, se esiste, altri- *
      *                  * menti a voce successiva                     *
      *                  *---------------------------------------------*
           if        w-sta-dis-ecc-e02    =    spaces
                     go to ext-are-wcc-300.
           move      02                   to   w-sta-dis-wcc-iuv      .
           move      w-sta-dis-ecc-e02    to   w-sta-dis-wcc-edt      .
           go to     ext-are-wcc-999.
       ext-are-wcc-300.
      *              *-------------------------------------------------*
      *              * Se ultima voce stampata : codice CAB denomina-  *
      *              * zione                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Codice CAB localita', se esiste, altrimenti *
      *                  * a voce successiva                           *
      *                  *---------------------------------------------*
           if        w-sta-dis-ecc-e03    =    spaces
                     go to ext-are-wcc-400.
           move      03                   to   w-sta-dis-wcc-iuv      .
           move      w-sta-dis-ecc-e03    to   w-sta-dis-wcc-edt      .
           go to     ext-are-wcc-999.
       ext-are-wcc-400.
      *              *-------------------------------------------------*
      *              * Se ultima voce stampata : codice CAB localita'  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Codice C/C, se esiste, altrimenti a voce    *
      *                  * successiva                                  *
      *                  *---------------------------------------------*
           if        w-sta-dis-ecc-e04    =    spaces
                     go to ext-are-wcc-500.
           move      04                   to   w-sta-dis-wcc-iuv      .
           move      w-sta-dis-ecc-e04    to   w-sta-dis-wcc-edt      .
           go to     ext-are-wcc-999.
       ext-are-wcc-500.
      *              *-------------------------------------------------*
      *              * Se ultima voce stampata : codice C/C            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Causale della scadenza, se esiste, altri-   *
      *                  * menti a voce successiva                     *
      *                  *---------------------------------------------*
           if        w-sta-dis-ecc-e05    =    spaces
                     go to ext-are-wcc-600.
           move      05                   to   w-sta-dis-wcc-iuv      .
           move      w-sta-dis-ecc-e05    to   w-sta-dis-wcc-edt      .
           go to     ext-are-wcc-999.
       ext-are-wcc-600.
      *              *-------------------------------------------------*
      *              * Se ultima voce stampata : causale della scaden- *
      *              * za                                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita per non piu' voci da stampare        *
      *                  * successiva                                  *
      *                  *---------------------------------------------*
           move      99                   to   w-sta-dis-wcc-iuv      .
           move      spaces               to   w-sta-dis-wcc-edt      .
       ext-are-wcc-999.
           exit.

      *    *===========================================================*
      *    * Stampa piede della distinta                               *
      *    *-----------------------------------------------------------*
       sta-pie-dis-000.
      *              *-------------------------------------------------*
      *              * Determinazione numero righe necessarie per la   *
      *              * stampa dell'elemento del corpo                  *
      *              *-------------------------------------------------*
           move      4                    to   w-sta-dis-num-rnp      .
      *              *-------------------------------------------------*
      *              * Test se linee residue sufficienti               *
      *              *-------------------------------------------------*
           if        p-res                >    w-sta-dis-num-rnp
                     go to sta-pie-dis-100.
       sta-pie-dis-050.
      *              *-------------------------------------------------*
      *              * Se linee residue non sufficienti                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Intestazione foglio                         *
      *                  *---------------------------------------------*
           perform   int-pag-sta-000      thru int-pag-sta-999        .
      *                  *---------------------------------------------*
      *                  * Se flag di interruzione stampa in On : u-   *
      *                  * scita                                       *
      *                  *---------------------------------------------*
           if        w-stp-prn-flg-int    not  = spaces
                     go to sta-pie-dis-999.
      *                  *---------------------------------------------*
      *                  * Se c'e' stata reintestazione non si esegue  *
      *                  * la sottolineatura fincatura finale          *
      *                  *---------------------------------------------*
           go to     sta-pie-dis-200.
       sta-pie-dis-100.
      *              *-------------------------------------------------*
      *              * Sottolineatura fincatura finale                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * 2 interlinee                                *
      *                  *---------------------------------------------*
           move      "L+"                 to   p-ope                  .
           move      2                    to   p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Stampa                                      *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      132                  to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      "---  -------- -------------  ---------------------
      -              "------------------- ------------------------------
      -              "-------------------- -----------"
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       sta-pie-dis-200.
      *              *-------------------------------------------------*
      *              * Totale distinta                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * 2 interlinee                                *
      *                  *---------------------------------------------*
           move      "L+"                 to   p-ope                  .
           move      2                    to   p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Literal                                     *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      08                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      006                  to   p-pos                  .
           move      "Totale :"           to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Totale                                      *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           move      10                   to   p-car                  .
           move      c-dec                to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "G"                  to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      015                  to   p-pos                  .
           move      w-sta-dis-tot-dis    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       sta-pie-dis-999.
           exit.

