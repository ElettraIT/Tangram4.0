       pre-are-wcc-600.
      *              *-------------------------------------------------*
      *              * Preparazioni finali                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Numero totale voci da stampare              *
      *                  *---------------------------------------------*
           move      zero                 to   w-sta-dis-wcc-ntv      .
           if        w-sta-dis-ecc-e01    not  = spaces
                     add   1              to   w-sta-dis-wcc-ntv      .
           if        w-sta-dis-ecc-e02    not  = spaces
                     add   1              to   w-sta-dis-wcc-ntv      .
           if        w-sta-dis-ecc-e03    not  = spaces
                     add   1              to   w-sta-dis-wcc-ntv      .
           if        w-sta-dis-ecc-e04    not  = spaces
                     add   1              to   w-sta-dis-wcc-ntv      .
           if        w-sta-dis-ecc-e05    not  = spaces
                     add   1              to   w-sta-dis-wcc-ntv      .
      *                  *---------------------------------------------*
