                     go to sta-cor-dis-430.
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      50                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      071                  to   p-pos                  .
           move      w-sta-dis-wcc-edt    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       sta-cor-dis-430.
      *                  *---------------------------------------------*
      *                  * A linea 5.                                  *
      *                  *---------------------------------------------*
           go to     sta-cor-dis-500.
       sta-cor-dis-500.
      *              *-------------------------------------------------*
      *              * Linea 5.                                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Estrazione voce per colonne per appoggio    *
      *                  * bancario                                    *
      *                  *---------------------------------------------*
           perform   ext-are-wcc-000      thru ext-are-wcc-999        .
      *                  *---------------------------------------------*
      *                  * Se voce a Spaces : no linea 5               *
      *                  *---------------------------------------------*
           if        w-sta-dis-wcc-edt    =    spaces
                     go to sta-cor-dis-530.
       sta-cor-dis-510.
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       sta-cor-dis-520.
      *                  *---------------------------------------------*
      *                  * Voce per colonna per appoggio bancario      *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      50                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      071                  to   p-pos                  .
           move      w-sta-dis-wcc-edt    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       sta-cor-dis-530.
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     sta-cor-dis-800.
       sta-cor-dis-800.
      *              *-------------------------------------------------*
      *              * Eventuale upgrade scadenza                      *
      *              *-------------------------------------------------*
           perform   sta-cor-dis-agg-000  thru sta-cor-dis-agg-999    .
       sta-cor-dis-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     sta-cor-dis-999.
       sta-cor-dis-999.
           exit.

      *    *===========================================================*
      *    * Stampa elemento del corpo distinta                        *
      *    *                                                           *
      *    * Subroutine per eventuale upgrade distinta                 *
      *    *-----------------------------------------------------------*
       sta-cor-dis-agg-000.
      *              *-------------------------------------------------*
      *              * Test preliminare se variato ABI o CAB           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura record [sdb]                        *
      *                  *---------------------------------------------*
           move      w-rig-num-sdb (1)    to   w-let-arc-sdb-num      .
           perform   let-arc-sdb-000      thru let-arc-sdb-999        .
      *                      *-----------------------------------------*
      *                      * Test su esito lettura                   *
      *                      *-----------------------------------------*
           if        w-let-arc-sdb-flg    not  = spaces
                     go to sta-cor-dis-agg-900.
       sta-cor-dis-agg-100.
      *                  *---------------------------------------------*
      *                  * Confronto ABI e CAB                         *
      *                  *---------------------------------------------*
           if        w-let-arc-sdb-abi    =    w-rig-abi-app (1) and
                     w-let-arc-sdb-cab    =    w-rig-cab-app (1)
                     go to sta-cor-dis-agg-900.
       sta-cor-dis-agg-200.
      *              *-------------------------------------------------*
      *              * Aggiornamento scadenza                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione area record                 *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Lettura con lock                            *
      *                  *---------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMSDB    "         to   f-key                  .
           move      w-rig-num-sdb (1)    to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                      *-----------------------------------------*
      *                      * Test su esito della lettura             *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to sta-cor-dis-agg-900.
       sta-cor-dis-agg-300.
      *                  *---------------------------------------------*
      *                  * Aggiornamento ABI e CAB                     *
      *                  *---------------------------------------------*
           move      w-rig-abi-app (1)    to   rf-sdb-abi-app         .
           move      w-rig-cab-app (1)    to   rf-sdb-cab-app         .
       sta-cor-dis-agg-400.
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Unlock record                               *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
       sta-cor-dis-agg-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     sta-cor-dis-agg-999.
       sta-cor-dis-agg-999.
           exit.

      *    *===========================================================*
      *    * Determinazione e bufferizzazione generalita' del trassato *
      *    * per l'inoltro                                             *
      *    *-----------------------------------------------------------*
       det-gdt-inl-000.
      *              *-------------------------------------------------*
      *              * Se si tratta di un paghero' avuto in cessione   *
      *              * si va' alla lettura dell'obbligato principale   *
      *              *-------------------------------------------------*
           if        w-rig-tip-sdb (1)    =    11 and
                     w-rig-tac-sdb (1)    =    02
                     go to det-gdt-inl-800.
       det-gdt-inl-100.
      *              *-------------------------------------------------*
      *              * Altrimenti si devia a seconda del tipo di inol- *
      *              * tro per la scadenza                             *
      *              *-------------------------------------------------*
           if        w-rig-inl-sdb (1)    =    01
                     go to det-gdt-inl-200
           else if   w-rig-inl-sdb (1)    =    02
                     go to det-gdt-inl-400
           else if   w-rig-inl-sdb (1)    =    03
                     go to det-gdt-inl-600
           else      go to det-gdt-inl-400.
       det-gdt-inl-200.
      *              *-------------------------------------------------*
      *              * Se inoltro alla sede commerciale                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se il tipo debitore indica che non si trat- *
      *                  * ta di un cliente : a lettura da anagrafica  *
      *                  * cliente contabile                           *
      *                  *---------------------------------------------*
           if        w-rig-tip-dbt (1)    >    01
                     go to det-gdt-inl-400.
      *                  *---------------------------------------------*
      *                  * Se codice debitore a zero : a lettura da    *
      *                  * anagrafica cliente contabile                *
      *                  *---------------------------------------------*
           if        w-rig-cod-dbt (1)    =    zero
                     go to det-gdt-inl-400.
      *                  *---------------------------------------------*
      *                  * Lettura da anagrafica cliente commerciale   *
      *                  * per la sede                                 *
      *                  *---------------------------------------------*
           move      "C"                  to   w-let-arc-dcc-tle      .
           move      w-rig-cod-dbt (1)    to   w-let-arc-dcc-cod      .
           move      spaces               to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                  *---------------------------------------------*
      *                  * Se record non trovato : a lettura da ana-   *
      *                  * grafica cliente contabile                   *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-flg    not  = spaces
                     go to det-gdt-inl-400.
      *                  *---------------------------------------------*
      *                  * Se record trovato                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Spostamento dati                        *
      *                      *-----------------------------------------*
           move      w-let-arc-dcc-rag    to   w-sta-dis-trs-rag      .
           move      w-let-arc-dcc-via    to   w-sta-dis-trs-via      .
           move      w-let-arc-dcc-loc    to   w-sta-dis-trs-loc      .
      *                      *-----------------------------------------*
      *                      * A codice debitore                       *
      *                      *-----------------------------------------*
           go to     det-gdt-inl-900.
       det-gdt-inl-400.
      *              *-------------------------------------------------*
      *              * Se inoltro alla sede legale                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura da anagrafica cliente contabile     *
      *                  *---------------------------------------------*
           move      w-rig-tip-dbt (1)    to   w-let-arc-dbt-tip      .
           move      w-rig-cod-dbt (1)    to   w-let-arc-dbt-cod      .
           perform   let-arc-dbt-000      thru let-arc-dbt-999        .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda se record trovato op-  *
      *                  * pure no                                     *
      *                  *---------------------------------------------*
           if        w-let-arc-dbt-flg    =    spaces
                     go to det-gdt-inl-420
           else      go to det-gdt-inl-440.
       det-gdt-inl-420.
      *                  *---------------------------------------------*
      *                  * Se record trovato                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Spostamento dati                        *
      *                      *-----------------------------------------*
           move      w-let-arc-dbt-rag    to   w-sta-dis-trs-rag      .
           move      w-let-arc-dbt-via    to   w-sta-dis-trs-via      .
           move      w-let-arc-dbt-loc    to   w-sta-dis-trs-loc      .
      *                      *-----------------------------------------*
      *                      * A codice debitore                       *
      *                      *-----------------------------------------*
           go to     det-gdt-inl-900.
       det-gdt-inl-440.
      *                  *---------------------------------------------*
      *                  * Se record non trovato                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Riempimento con puntini                 *
      *                      *-----------------------------------------*
           move      all   "."            to   w-sta-dis-trs-rag      .
           move      all   "."            to   w-sta-dis-trs-via      .
           move      all   "."            to   w-sta-dis-trs-loc      .
      *                      *-----------------------------------------*
      *                      * A codice debitore                       *
      *                      *-----------------------------------------*
           go to     det-gdt-inl-900.
       det-gdt-inl-600.
      *              *-------------------------------------------------*
      *              * Se inoltro alla dipendenza                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se il tipo debitore indica che non si trat- *
      *                  * ta di un cliente : a lettura da anagrafica  *
      *                  * cliente contabile                           *
      *                  *---------------------------------------------*
           if        w-rig-tip-dbt (1)    >    01
                     go to det-gdt-inl-400.
      *                  *---------------------------------------------*
      *                  * Se codice debitore a zero : a lettura da    *
      *                  * anagrafica cliente commerciale              *
      *                  *---------------------------------------------*
           if        w-rig-cod-dbt (1)    =    zero
                     go to det-gdt-inl-200.
      *                  *---------------------------------------------*
      *                  * Se codice dipendenza a spaces : a lettura   *
      *                  * anagrafica cliente commerciale              *
      *                  *---------------------------------------------*
           if        w-rig-dpz-dbt (1)    =    spaces
                     go to det-gdt-inl-200.
      *                  *---------------------------------------------*
      *                  * Lettura da anagrafica cliente commerciale   *
      *                  * per la dipendenza                           *
      *                  *---------------------------------------------*
           move      "D"                  to   w-let-arc-dcc-tle      .
           move      w-rig-cod-dbt (1)    to   w-let-arc-dcc-cod      .
           move      w-rig-dpz-dbt (1)    to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                  *---------------------------------------------*
      *                  * Se record non trovato : a lettura da ana-   *
      *                  * grafica cliente commerciale                 *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-flg    not  = spaces
                     go to det-gdt-inl-200.
      *                  *---------------------------------------------*
      *                  * Se record trovato                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Spostamento dati                        *
      *                      *-----------------------------------------*
           move      w-let-arc-dcc-rag    to   w-sta-dis-trs-rag      .
           move      w-let-arc-dcc-via    to   w-sta-dis-trs-via      .
           move      w-let-arc-dcc-loc    to   w-sta-dis-trs-loc      .
      *                      *-----------------------------------------*
      *                      * A codice debitore                       *
      *                      *-----------------------------------------*
           go to     det-gdt-inl-900.
       det-gdt-inl-800.
      *              *-------------------------------------------------*
      *              * Se paghero' avuto in cessione                   *
      *              *-------------------------------------------------*
       det-gdt-inl-820.
      *                  *---------------------------------------------*
      *                  * Lettura obbligato principale                *
      *                  *---------------------------------------------*
           move      01                   to   w-let-arc-obp-tip      .
           move      w-rig-num-sdb (1)    to   w-let-arc-obp-num      .
           perform   let-arc-obp-000      thru let-arc-obp-999        .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda se record trovato op-  *
      *                  * pure no                                     *
      *                  *---------------------------------------------*
           if        w-let-arc-obp-flg    =    spaces
                     go to det-gdt-inl-840
           else      go to det-gdt-inl-860.
       det-gdt-inl-840.
      *                  *---------------------------------------------*
      *                  * Se record trovato                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Spostamento dati                        *
      *                      *-----------------------------------------*
           move      w-let-arc-obp-rag    to   w-sta-dis-trs-rag      .
           move      w-let-arc-obp-via    to   w-sta-dis-trs-via      .
           move      w-let-arc-obp-loc    to   w-sta-dis-trs-loc      .
      *                      *-----------------------------------------*
      *                      * A codice debitore                       *
      *                      *-----------------------------------------*
           go to     det-gdt-inl-900.
       det-gdt-inl-860.
      *                  *---------------------------------------------*
      *                  * Se record non trovato                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Riempimento con puntini                 *
      *                      *-----------------------------------------*
           move      all   "."            to   w-sta-dis-trs-rag      .
           move      all   "."            to   w-sta-dis-trs-via      .
           move      all   "."            to   w-sta-dis-trs-loc      .
      *                      *-----------------------------------------*
      *                      * A codice debitore                       *
      *                      *-----------------------------------------*
           go to     det-gdt-inl-900.
       det-gdt-inl-900.
      *              *-------------------------------------------------*
      *              * Codice del debitore                             *
      *              *-------------------------------------------------*
       det-gdt-inl-910.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del tipo di scadenza   *
      *                  *---------------------------------------------*
           if        w-rig-tip-sdb (1)    =    06
                     go to det-gdt-inl-930.
       det-gdt-inl-920.
      *                  *---------------------------------------------*
      *                  * Se la scadenza non e' un R.I.D.             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice debitore a spaces                *
      *                      *-----------------------------------------*
           move      spaces               to   w-sta-dis-trs-cdd      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     det-gdt-inl-940.
       det-gdt-inl-930.
      *                  *---------------------------------------------*
      *                  * Se la scadenza e' un R.I.D.                 *
      *                  *---------------------------------------------*
       det-gdt-inl-931.
      *                      *-----------------------------------------*
      *                      * Normalizzazione codice debitore         *
      *                      *-----------------------------------------*
           move      spaces               to   w-sta-dis-trs-cdd      .
       det-gdt-inl-932.
      *                      *-----------------------------------------*
      *                      * Codice del debitore per il creditore,   *
      *                      * con il seguente formato :               *
      *                      *                                         *
      *                      * Codice debitore : X/NNNNNNN/DDDD        *
      *                      *                                         *
      *                      * dove :                                  *
      *                      *                                         *
      *                      * X       : C = Cliente                   *
      *                      *           D = Debitore diverso          *
      *                      *                                         *
      *                      * NNNNNNN : Codice cliente o debitore     *
      *                      *                                         *
      *                      * DDDD    : Sigla della dipendenza        *
      *                      *                                         *
      *                      *-----------------------------------------*
       det-gdt-inl-933.
      *                          *-------------------------------------*
      *                          * Editing preliminare codice debitore *
      *                          *-------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      07                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      w-rig-cod-dbt (1)    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * Deviazione in funzione del tipo di  *
      *                          * debitore                            *
      *                          *-------------------------------------*
           if        w-rig-tip-dbt (1)    =    02
                     go to det-gdt-inl-937.
       det-gdt-inl-934.
      *                          *-------------------------------------*
      *                          * Se tipo di debitore 01 : Cliente    *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Deviazione a seconda se c'e' o  *
      *                              * no la dipendenza                *
      *                              *---------------------------------*
           if        w-rig-dpz-dbt (1)    not  = spaces
                     go to det-gdt-inl-936.
       det-gdt-inl-935.
      *                              *---------------------------------*
      *                              * Se non c'e' dipendenza          *
      *                              *---------------------------------*
           string    " - Codice debitore : C/"
                                delimited by   size
                     p-edt      delimited by   spaces
                                          into w-sta-dis-trs-cdd      .
           go to     det-gdt-inl-940.
       det-gdt-inl-936.
      *                              *---------------------------------*
      *                              * Se c'e' dipendenza              *
      *                              *---------------------------------*
           string    " - Codice debitore : C/"
                                delimited by   size
                     p-edt      delimited by   spaces
                     "-"        delimited by   size
                     w-rig-dpz-dbt (1)
                                delimited by   spaces
                                          into w-sta-dis-trs-cdd      .
           go to     det-gdt-inl-940.
       det-gdt-inl-937.
      *                          *-------------------------------------*
      *                          * Se tipo di debitore 02 : Debitori   *
      *                          * diversi                             *
      *                          *-------------------------------------*
           string    " - Codice debitore : D/"
                                delimited by   size
                     p-edt      delimited by   spaces
                                          into w-sta-dis-trs-cdd      .
           go to     det-gdt-inl-940.
       det-gdt-inl-940.
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     det-gdt-inl-999.
       det-gdt-inl-999.
           exit.

      *    *===========================================================*
      *    * Determinazione numero voci da stampare per la colonna per *
      *    * l'appoggio bancario, con preparazione delle aree gia' e-  *
      *    * ditate                                                    *
      *    *-----------------------------------------------------------*
       pre-are-wcc-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione aree gia' editate              *
      *              *-------------------------------------------------*
      *                   *--------------------------------------------*
      *                   * Per codice ABI                             *
      *                   *--------------------------------------------*
           move      spaces               to   w-sta-dis-ecc-e01      .
      *                   *--------------------------------------------*
      *                   * Per codice CAB, denominazione              *
      *                   *--------------------------------------------*
           move      spaces               to   w-sta-dis-ecc-e02      .
      *                   *--------------------------------------------*
      *                   * Per codice CAB, localita'                  *
      *                   *--------------------------------------------*
           move      spaces               to   w-sta-dis-ecc-e03      .
      *                   *--------------------------------------------*
      *                   * Per C/C                                    *
      *                   *--------------------------------------------*
           move      spaces               to   w-sta-dis-ecc-e04      .
      *                   *--------------------------------------------*
      *                   * Per causale della scadenza                 *
      *                   *--------------------------------------------*
           move      spaces               to   w-sta-dis-ecc-e05      .
       pre-are-wcc-100.
      *              *-------------------------------------------------*
      *              * Preparazione area editata per codice ABI        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Codice ABI per l'appoggio a zero : nes-  *
      *                  * sun editing, e si omette anche la prepara-  *
      *                  * zione per il codice CAB, sia per la deno-   *
      *                  * minazione che per la localita'              *
      *                  *---------------------------------------------*
           if        w-rig-abi-app (1)    =    zero
                     go to pre-are-wcc-400.
      *                  *---------------------------------------------*
      *                  * Lettura codice ABI banca d'appoggio         *
      *                  *---------------------------------------------*
           move      w-rig-abi-app (1)    to   w-let-arc-axi-cod      .
           perform   let-arc-axi-000      thru let-arc-axi-999        .
      *                  *---------------------------------------------*
      *                  * Se record non esistente : nessun editing, e *
      *                  * si omette anche la preparazione per il co-  *
      *                  * dice CAB, sia per la denominazione che per  *
      *                  * la localita'                                *
      *                  *---------------------------------------------*
           if        w-let-arc-axi-flg    not  = spaces
                     go to pre-are-wcc-400.
      *                  *---------------------------------------------*
      *                  * Se denominazione a Spaces : nessun editing, *
      *                  * e si omette anche la preparazione per il    *
      *                  * codice CAB, sia per la denominazione che    *
      *                  * per la localita'                            *
      *                  *---------------------------------------------*
           if        w-let-arc-axi-den    =    spaces
                     go to pre-are-wcc-400.
       pre-are-wcc-120.
      *                  *---------------------------------------------*
      *                  * Editing                                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Literal                                 *
      *                      *-----------------------------------------*
           move      "ABI"                to   w-sta-dis-ecc-l01      .
      *                      *-----------------------------------------*
      *                      * Codice                                  *
      *                      *-----------------------------------------*
           move      w-rig-abi-app (1)    to   w-sta-dis-ecc-c01      .
      *                      *-----------------------------------------*
      *                      * Denominazione                           *
      *                      *-----------------------------------------*
           move      w-let-arc-axi-den    to   w-sta-dis-ecc-d01      .
       pre-are-wcc-200.
      *              *-------------------------------------------------*
      *              * Preparazione area editata per codice CAB, deno- *
      *              * minazione                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Codice CAB per l'appoggio a zero : nes-  *
      *                  * sun editing                                 *
      *                  *---------------------------------------------*
           if        w-rig-cab-app (1)    =    zero
                     go to pre-are-wcc-300.
      *                  *---------------------------------------------*
      *                  * Lettura sportello CAB per d'appoggio        *
      *                  *---------------------------------------------*
           move      w-rig-abi-app (1)    to   w-let-arc-axs-abi      .
           move      w-rig-cab-app (1)    to   w-let-arc-axs-cab      .
           perform   let-arc-axs-000      thru let-arc-axs-999        .
      *                  *---------------------------------------------*
      *                  * Se record non esistente : nessun editing, e *
      *                  * si omette la preparazione per il codice CAB *
      *                  * sia per la denominazione che per la locali- *
      *                  * ta'                                         *
      *                  *---------------------------------------------*
           if        w-let-arc-axs-flg    not  = spaces
                     go to pre-are-wcc-400.
      *                  *---------------------------------------------*
      *                  * Se denominazione a Spaces : nessun editing, *
      *                  * e si omette la preparazione per il codice   *
      *                  * CAB, sia per la denominazione che per la    *
      *                  * localita'                                   *
      *                  *---------------------------------------------*
           if        w-let-arc-axs-den    =    spaces
                     go to pre-are-wcc-400.
       pre-are-wcc-220.
      *                  *---------------------------------------------*
      *                  * Editing                                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Literal                                 *
      *                      *-----------------------------------------*
           move      "CAB"                to   w-sta-dis-ecc-l02      .
      *                      *-----------------------------------------*
      *                      * Codice                                  *
      *                      *-----------------------------------------*
           move      w-rig-cab-app (1)    to   w-sta-dis-ecc-c02      .
      *                      *-----------------------------------------*
      *                      * Denominazione                           *
      *                      *-----------------------------------------*
           move      w-let-arc-axs-den    to   w-sta-dis-ecc-d02      .
       pre-are-wcc-300.
