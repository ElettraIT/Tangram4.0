      *                              * Deviazione a seconda se esiste  *
      *                              * anche il numero fattura         *
      *                              *---------------------------------*
           if        w-rig-num-ddr (1)    =    spaces
                     go to pre-are-wcc-554.
       pre-are-wcc-552.
      *                              *---------------------------------*
      *                              * Se esiste il numero fattura     *
      *                              *---------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "D"                  to   p-tip                  .
           move      w-rig-dat-ddr (1)    to   p-dat                  .
           call      "swd/mod/prg/obj/mprint"
                                        using  p                      .
           string    "Fattura nr. "
                                delimited by   size
                     w-rig-num-ddr (1)
                                delimited by   spaces
                     " del "
                                delimited by   size
                     p-edt  
                                delimited by   spaces
                                          into w-sta-dis-ecc-v05      .
           go to     pre-are-wcc-600.
       pre-are-wcc-554.
      *                              *---------------------------------*
      *                              * Se non esiste il numero fattura *
      *                              *---------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "D"                  to   p-tip                  .
           move      w-rig-dat-ddr (1)    to   p-dat                  .
           call      "swd/mod/prg/obj/mprint"
                                        using  p                      .
           string    "Fattura del "
                                delimited by   size
                     p-edt  
                                delimited by   spaces
                                          into w-sta-dis-ecc-v05      .
           go to     pre-are-wcc-600.
       pre-are-wcc-560.
      *                          *-------------------------------------*
      *                          * Se tipo documento 02 : Nota di ad-  *
      *                          * debito                              *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Deviazione a seconda se esiste  *
      *                              * anche il numero fattura         *
      *                              *---------------------------------*
           if        w-rig-num-ddr (1)    =    spaces
                     go to pre-are-wcc-564.
       pre-are-wcc-562.
      *                              *---------------------------------*
      *                              * Se esiste il numero fattura     *
      *                              *---------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "D"                  to   p-tip                  .
           move      w-rig-dat-ddr (1)    to   p-dat                  .
           call      "swd/mod/prg/obj/mprint"
                                        using  p                      .
           string    "Nota di debito nr. "
                                delimited by   size
                     w-rig-num-ddr (1)
                                delimited by   spaces
                     " del "
                                delimited by   size
                     p-edt  
                                delimited by   spaces
                                          into w-sta-dis-ecc-v05      .
           go to     pre-are-wcc-600.
       pre-are-wcc-564.
      *                              *---------------------------------*
      *                              * Se non esiste il numero fattura *
      *                              *---------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "D"                  to   p-tip                  .
           move      w-rig-dat-ddr (1)    to   p-dat                  .
           call      "swd/mod/prg/obj/mprint"
                                        using  p                      .
           string    "Nota di debito del "
                                delimited by   size
                     p-edt  
                                delimited by   spaces
                                          into w-sta-dis-ecc-v05      .
           go to     pre-are-wcc-600.
       pre-are-wcc-570.
      *                          *-------------------------------------*
      *                          * Se tipo documento non classificato  *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Deviazione a seconda se esiste  *
      *                              * anche il numero fattura         *
      *                              *---------------------------------*
           if        w-rig-num-ddr (1)    =    spaces
                     go to pre-are-wcc-574.
       pre-are-wcc-572.
      *                              *---------------------------------*
      *                              * Se esiste il numero fattura     *
      *                              *---------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "D"                  to   p-tip                  .
           move      w-rig-dat-ddr (1)    to   p-dat                  .
           call      "swd/mod/prg/obj/mprint"
                                        using  p                      .
           string    "Documento nr. "
                                delimited by   size
                     w-rig-num-ddr (1)
                                delimited by   spaces
                     " del "
                                delimited by   size
                     p-edt  
                                delimited by   spaces
                                          into w-sta-dis-ecc-v05      .
           go to     pre-are-wcc-600.
       pre-are-wcc-574.
      *                              *---------------------------------*
      *                              * Se non esiste il numero fattura *
      *                              *---------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "D"                  to   p-tip                  .
           move      w-rig-dat-ddr (1)    to   p-dat                  .
           call      "swd/mod/prg/obj/mprint"
                                        using  p                      .
           string    "Documento del "
                                delimited by   size
                     p-edt  
                                delimited by   spaces
                                          into w-sta-dis-ecc-v05      .
