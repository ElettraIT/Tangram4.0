       pos-cnf-ins-000.
      *              *-------------------------------------------------*
      *              * Lettura record [ddp] senza lock                 *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMDDP    "         to   f-key                  .
           move      w-tes-num-ddp (1)    to   rf-ddp-num-ddp         .
           move      "pgm/gep/fls/ioc/obj/iofddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddp                 .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to pos-cnf-ins-200.
       pos-cnf-ins-100.
      *              *-------------------------------------------------*
      *              * Se record [ddp] non esistente                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   e01-cnf-ins-000      thru e01-cnf-ins-999        .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     pos-cnf-ins-999.
       pos-cnf-ins-200.
      *              *-------------------------------------------------*
      *              * Se record [ddp] esistente                       *
      *              *-------------------------------------------------*
       pos-cnf-ins-250.
      *                  *---------------------------------------------*
      *                  * Controllo che la distinta di presentazione  *
      *                  * non sia nel frattempo stata variata         *
      *                  *---------------------------------------------*
           if        rf-ddp-dtr-com       not  = w-tes-dtr-com (1) or
                     rf-ddp-dtr-pre       not  = w-tes-dtr-pre (1) or
                     rf-ddp-drc-pre       not  = w-tes-drc-pre (1) or
                     rf-ddp-npc-pre       not  = w-tes-npc-pre (1) or
                     rf-ddp-cod-cbp       not  = w-tes-cod-cbp (1) or
                     rf-ddp-snx-stp       not  = w-tes-snx-stp (1) or
                     rf-ddp-flc-stp       not  = w-tes-flc-stp (1) or
                     rf-ddp-snx-ads       not  = w-tes-snx-ads (1) or
                     rf-ddp-flc-ads       not  = w-tes-flc-ads (1) or
                     rf-ddp-tip-ias       not  = w-tes-tip-ias (1) or
                     rf-ddp-flc-ias       not  = w-tes-flc-ias (1) or
                     rf-ddp-dtr-act       not  = w-tes-dtr-act (1) or
                     rf-ddp-drc-act       not  = w-tes-drc-act (1) or
                     rf-ddp-npc-act       not  = w-tes-npc-act (1) or
                     rf-ddp-dtr-acd       not  = w-tes-dtr-acd (1) or
                     rf-ddp-drc-acd       not  = w-tes-drc-acd (1) or
                     rf-ddp-npc-acd       not  = w-tes-npc-acd (1) or
                     rf-ddp-flg-ela       not  = w-tes-flg-ela (1) or
                     rf-ddp-flg-pul       not  = w-tes-flg-pul (1)
                     go to pos-cnf-ins-275.
           go to     pos-cnf-ins-300.
       pos-cnf-ins-275.
