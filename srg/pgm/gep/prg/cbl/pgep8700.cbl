      *                      *-----------------------------------------*
           move      zero                 to   w-all-str-inx          .
           inspect   w-rig-ind-eml  tallying   w-all-str-inx
                                          for  all "@"                .
           if        w-all-str-inx        =    1
                     go to acc-ind-eml-460
           else if   w-all-str-inx        =    0
                     go to acc-ind-eml-420
           else      go to acc-ind-eml-440.
       acc-ind-eml-420.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Indirizzo e-mail formalmente non corretto (senza @
      -              ") !       "         to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-ind-eml-100.
       acc-ind-eml-440.
      *                      *-----------------------------------------*
      *                      * Verifica se doppio                      *
      *                      *-----------------------------------------*
           move      zero                 to   w-all-str-inx          .
           inspect   w-rig-ind-eml  tallying   w-all-str-inx
                                          for  all "#"                .
           if        w-all-str-inx        =    1
                     go to acc-ind-eml-460.
      *
           move      "Indirizzo e-mail formalmente non corretto (troppi 
      -              "@) !      "         to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-ind-eml-100.
       acc-ind-eml-460.
      *                  *---------------------------------------------*
      *                  * Che contenga almeno 1 '.'                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           move      zero                 to   w-all-str-inx          .
           inspect   w-rig-ind-eml  tallying   w-all-str-inx
                                          for  all "."                .
           if        w-all-str-inx        >    zero
                     go to acc-ind-eml-490.
       acc-ind-eml-480.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
