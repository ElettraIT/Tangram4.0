      *                          * Continuazione a completamenti e     *
      *                          * controlli comuni sia in caso di     *
      *                          * Inserimento che di Modifica         *
      *                          *-------------------------------------*
           go to     rou-let-reg-400.
       rou-let-reg-300.
      *                      *-----------------------------------------*
      *                      * Se il record della scadenza contiene    *
      *                      * gia' l'operazione di presentazione di-  *
      *                      * stinta                                  *
      *                      *-----------------------------------------*
       rou-let-reg-310.
      *                          *-------------------------------------*
      *                          * Se l'archivio di supporto e' gia'   *
      *                          * stato preparato ci si pone in Mo-   *
      *                          * difica, altrimenti ci si pone in    *
      *                          * Inserimento                         *
      *                          *-------------------------------------*
           if        w-tes-flc-ads (1)    not  = zero
                     move  "M"            to   w-cnt-mfu-tip-fun
           else      move  "I"            to   w-cnt-mfu-tip-fun      .
       rou-let-reg-320.
      *                          *-------------------------------------*
      *                          * Duplicazione dei valori attuali nei *
      *                          * valori precedenti per la testata    *
      *                          *-------------------------------------*
           move      w-tes-val-aep (1)    to   w-tes-val-aep (2)      .
       rou-let-reg-350.
      *                          *-------------------------------------*
      *                          * Controllo che il codice nostra ban- *
      *                          * ca di presentazione sia diverso da  *
      *                          * Spaces                              *
      *                          *-------------------------------------*
           if        w-tes-cod-cbp (1)    not  = spaces
                     go to rou-let-reg-400.
           move      "Attenzione : Manca il codice della banca per la pr
      -              "esentazione.   "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           move      "V"                  to   w-cnt-mfu-tip-fun      .
       rou-let-reg-400.
      *                      *-----------------------------------------*
      *                      * Completamenti e controlli comuni sia    *
      *                      * al caso di Inserimento che di Modifica  *
      *                      *-----------------------------------------*
       rou-let-reg-500.
      *                          *-------------------------------------*
      *                          * Controllo che non siano stati ese-  *
      *                          * guiti sulla distinta altri movimen- *
      *                          * ti successivi alla presentazione,   *
      *                          * In caso di incompatibilita' si e-   *
      *                          * mette un messaggio di errore e si   *
      *                          * pone la sola visualizzazione        *
      *                          *-------------------------------------*
       rou-let-reg-510.
      *                              *---------------------------------*
      *                              * Test su invio dell' archivio    *
      *                              * di supporto per trasmissione    *
      *                              * distinta alla banca             *
      *                              *---------------------------------*
           if        w-tes-dtr-pre (1)    =    zero
                     go to rou-let-reg-520.
           if        w-tes-snx-ads (1)    not  = "S"
                     go to rou-let-reg-520.
           if        w-tes-flc-ias (1)    =    zero
                     go to rou-let-reg-520.
           move      "Attenzione : L'archivio di supporto per la trasmis
      -              "sione della    "    to   w-err-box-err-msg      .
           move      "             distinta alla banca e' gia stato inol
      -              "trato.         "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           move      "V"                  to   w-cnt-mfu-tip-fun      .
       rou-let-reg-520.
      *                              *---------------------------------*
      *                              * Test su accettazione distinta   *
      *                              * da parte della banca            *
      *                              *---------------------------------*
           if        w-tes-dtr-act (1)    =    zero
                     go to rou-let-reg-530.
           move      "Attenzione : la distinta e' gia' stata accettata d
      -              "alla banca     "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           move      "V"                  to   w-cnt-mfu-tip-fun      .
       rou-let-reg-530.
      *                              *---------------------------------*
      *                              * Test su accredito distinta      *
      *                              * da parte della banca            *
      *                              *---------------------------------*
           if        w-tes-dtr-acd (1)    =    zero
                     go to rou-let-reg-540.
           move      "Attenzione : la distinta e' gia' stata accreditata
      -              " dalla banca   "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           move      "V"                  to   w-cnt-mfu-tip-fun      .
       rou-let-reg-540.
      *                              *---------------------------------*
      *                              * Su flags di elaborazione bloc-  *
      *                              * canti                           *
      *                              *---------------------------------*
           if        w-tes-flg-blo (1)    =    spaces
                     go to rou-let-reg-550.
           move      "Attenzione : la distinta e' stata sottoposta ad el
      -              "aborazioni     "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           move      "V"                  to   w-cnt-mfu-tip-fun      .
       rou-let-reg-550.
      *                              *---------------------------------*
      *                              * Su flags di sottoponibilita' a  *
      *                              * pulizia                         *
      *                              *---------------------------------*
           if        w-tes-flg-pul (1)    =    spaces
                     go to rou-let-reg-560.
           move      "Attenzione : la distinta e' in corso di eliminazio
      -              "ne             "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           move      "V"                  to   w-cnt-mfu-tip-fun      .
       rou-let-reg-560.
      *                              *---------------------------------*
      *                              * Fine controlli su movimenti     *
      *                              * successivi a quello di pre-     *
      *                              * sentazione distinta             *
      *                              *---------------------------------*
           go to     rou-let-reg-700.
       rou-let-reg-700.
      *                      *-----------------------------------------*
      *                      * Caricamento righe, con ordinamento per  *
      *                      * data di scadenza                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Messaggio di caricamento in esecu-  *
      *                          * zione                               *
      *                          *-------------------------------------*
           move      "               Caricamento distinta in esecuzione 
      -              "               "    to   w-err-box-err-msg      .
           perform   msg-cnt-box-000      thru msg-cnt-box-999        .
      *                          *-------------------------------------*
      *                          * Sort                                *
      *                          *-------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   srt-inp-prc-000
                                          thru srt-inp-prc-999
                     output procedure     is   srt-out-prc-000
                                          thru srt-out-prc-999        .
      *                          *-------------------------------------*
      *                          * Messaggio di fine caricamento       *
      *                          * zione                               *
      *                          *-------------------------------------*
           move      spaces               to   w-err-box-err-msg      .
           perform   msg-cnt-box-000      thru msg-cnt-box-999        .
       rou-let-reg-725.
      *                      *-----------------------------------------*
      *                      * Assestamenti post-caricamento righe di- *
      *                      * stinta                                  *
      *                      *-----------------------------------------*
       rou-let-reg-735.
      *                          *-------------------------------------*
      *                          * Controllo che l'importo effettivo   *
      *                          * della distinta sia pari alla som-   *
      *                          * matoria delle righe caricate        *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se si' : continuazione          *
      *                              *---------------------------------*
           if        w-srt-sdb-out-igc    =    w-tes-imp-ddp (1)
                     go to rou-let-reg-740.
      *                              *---------------------------------*
      *                              * Se no                           *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Emissione messaggio di er-  *
      *                                  * rore                        *
      *                                  *-----------------------------*
           move      "Attenzione : L'importo totale della distinta risul
      -              "ta diverso da  "    to   w-err-box-err-msg      .
           move      "             quello determinato nella composizione
      -              " distinta !    "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                                  *-----------------------------*
      *                                  * Se si e' in Inserimento :   *
      *                                  * flag di errore ed uscita    *
      *                                  *-----------------------------*
           if        w-cnt-mfu-tip-fun    =    "I"
                     move  "#"            to   w-cnt-rou-let-reg
                     go to rou-let-reg-999.
      *                                  *-----------------------------*
      *                                  * Altrimenti si pone la sola  *
      *                                  * Visualizzazione             *
      *                                  *-----------------------------*
           move      "V"                  to   w-cnt-mfu-tip-fun      .
       rou-let-reg-740.
      *                          *-------------------------------------*
      *                          * Importo effettivo della distinta,   *
      *                          * da sommatoria righe caricate        *
      *                          *-------------------------------------*
           move      w-srt-sdb-out-igc    to   w-tes-imp-ddp (1)      .
       rou-let-reg-750.
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rou-let-reg-999.
       rou-let-reg-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort scadenze della distinta per :    *
      *    *                                                           *
      *    * -  Data di scadenza                                       *
      *    * -  Ragione sociale per l'inoltro della scadenza           *
      *    * -  Tipo debitore                                          *
      *    * -  Codice debitore                                        *
      *    * -  Numero scadenza                                        *
      *    *-----------------------------------------------------------*
       srt-inp-prc-000.
      *              *-------------------------------------------------*
      *              * Start su scadenze appartenenti alla distinta di *
      *              * presentazione                                   *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "DDPNRS    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      w-tes-num-dis        to   rf-sdb-num-ddp         .
           move      zero                 to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *              *-------------------------------------------------*
      *              * Se start errata : fine input procedure          *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  srt-inp-prc-999.
       srt-inp-prc-200.
      *              *-------------------------------------------------*
      *              * Next su scadenze appartenenti alla distinta di  *
      *              * presentazione                                   *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *              *-------------------------------------------------*
      *              * Se at end : fine input procedure                *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  srt-inp-prc-999.
       srt-inp-prc-300.
      *              *-------------------------------------------------*
      *              * Test max su su scadenze appartenenti alla di-   *
      *              * stinta di presentazione, se non superato : fi-  *
      *              * ne input procedure                              *
      *              *-------------------------------------------------*
           if        rf-sdb-num-ddp       not  = w-tes-num-dis
                     go to  srt-inp-prc-999.
       srt-inp-prc-400.
      *              *-------------------------------------------------*
      *              * Composizione sort-record                        *
      *              *-------------------------------------------------*
       srt-inp-prc-425.
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
       srt-inp-prc-450.
      *                  *---------------------------------------------*
      *                  * Data di scadenza                            *
      *                  *---------------------------------------------*
           move      rf-sdb-dts-sdb       to   srt-dts-sdb            .
       srt-inp-prc-475.
      *                  *---------------------------------------------*
      *                  * Ragione sociale, indirizzo, e localita' per *
      *                  * l'inoltro della scadenza                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo inoltro *
      *                      * scadenza                                *
      *                      *-----------------------------------------*
           if        rf-sdb-inl-sdb       =    01
                     go to srt-inp-prc-480
           else if   rf-sdb-inl-sdb       =    02
                     go to srt-inp-prc-485
           else if   rf-sdb-inl-sdb       =    03
                     go to srt-inp-prc-490
           else      go to srt-inp-prc-480.
       srt-inp-prc-480.
      *                      *-----------------------------------------*
      *                      * Se inoltro : alla sede commerciale      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se il tipo debitore indica che non  *
      *                          * si tratta di un cliente : a lettura *
      *                          * da anagrafica cliente contabile     *
      *                          *-------------------------------------*
           if        rf-sdb-tip-dbt       >    01
                     go to srt-inp-prc-485.
      *                          *-------------------------------------*
      *                          * Se codice debitore a zero : a let-  *
      *                          * tura da anagrafica cliente conta-   *
      *                          * bile                                *
      *                          *-------------------------------------*
           if        rf-sdb-cod-dbt       =    zero
                     go to srt-inp-prc-485.
      *                          *-------------------------------------*
      *                          * Lettura da anagrafica cliente com-  *
      *                          * merciale per la sede                *
      *                          *-------------------------------------*
           move      "C"                  to   w-let-arc-dcc-tle      .
           move      rf-sdb-cod-dbt       to   w-let-arc-dcc-cod      .
           move      spaces               to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                          *-------------------------------------*
      *                          * Se record non trovato : a lettura   *
      *                          * da anagrafica cliente contabile     *
      *                          *-------------------------------------*
           if        w-let-arc-dcc-flg    not  = spaces
                     go to srt-inp-prc-485.
      *                          *-------------------------------------*
      *                          * Altrimenti : spostamento dati       *
      *                          *-------------------------------------*
           move      w-let-arc-dcc-rag    to   srt-rag-inl            .
           move      w-let-arc-dcc-via    to   srt-via-inl            .
           move      w-let-arc-dcc-loc    to   srt-loc-inl            .
      *                          *-------------------------------------*
      *                          * Continuazione                       *
      *                          *-------------------------------------*
           go to     srt-inp-prc-500.
       srt-inp-prc-485.
      *                      *-----------------------------------------*
      *                      * Se inoltro : alla sede legale           *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Lettura da anagrafica cliente con-  *
      *                          * tabile                              *
      *                          *-------------------------------------*
           move      rf-sdb-tip-dbt       to   w-let-arc-dbt-tip      .
           move      rf-sdb-cod-dbt       to   w-let-arc-dbt-cod      .
           perform   let-arc-dbt-000      thru let-arc-dbt-999        .
           move      w-let-arc-dbt-rag    to   srt-rag-inl            .
           move      w-let-arc-dbt-via    to   srt-via-inl            .
           move      w-let-arc-dbt-loc    to   srt-loc-inl            .
      *                          *-------------------------------------*
      *                          * Continuazione                       *
      *                          *-------------------------------------*
           go to     srt-inp-prc-500.
       srt-inp-prc-490.
      *                      *-----------------------------------------*
      *                      * Se inoltro : alla dipendenza            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se il tipo debitore indica che non  *
      *                          * si tratta di un cliente : a lettura *
      *                          * da anagrafica cliente commerciale   *
      *                          *-------------------------------------*
           if        rf-sdb-tip-dbt       >    01
                     go to srt-inp-prc-480.
      *                          *-------------------------------------*
      *                          * Se codice debitore a zero o codice  *
      *                          * dipendenza a spaces : a lettura da  *
      *                          * anagrafica cliente commerciale      *
      *                          *-------------------------------------*
           if        rf-sdb-cod-dbt       =    zero   or
                     rf-sdb-dpz-dbt       =    spaces
                     go to srt-inp-prc-480.
      *                          *-------------------------------------*
      *                          * Lettura da anagrafica cliente com-  *
      *                          * merciale per la dipendenza          *
      *                          *-------------------------------------*
           move      "D"                  to   w-let-arc-dcc-tle      .
           move      rf-sdb-cod-dbt       to   w-let-arc-dcc-cod      .
           move      rf-sdb-dpz-dbt       to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                          *-------------------------------------*
      *                          * Se record non trovato : a lettura   *
      *                          * da anagrafica cliente commerciale   *
      *                          *-------------------------------------*
           if        w-let-arc-dcc-flg    not  = spaces
                     go to srt-inp-prc-480.
      *                          *-------------------------------------*
      *                          * Altrimenti : spostamento dati       *
      *                          *-------------------------------------*
           move      w-let-arc-dcc-rag    to   srt-rag-inl            .
           move      w-let-arc-dcc-via    to   srt-via-inl            .
           move      w-let-arc-dcc-loc    to   srt-loc-inl            .
      *                          *-------------------------------------*
      *                          * Continuazione                       *
      *                          *-------------------------------------*
           go to     srt-inp-prc-500.
       srt-inp-prc-500.
      *                  *---------------------------------------------*
      *                  * Tipo debitore                               *
      *                  *---------------------------------------------*
           move      rf-sdb-tip-dbt       to   srt-tip-dbt            .
       srt-inp-prc-525.
      *                  *---------------------------------------------*
      *                  * Codice debitore                             *
      *                  *---------------------------------------------*
           move      rf-sdb-cod-dbt       to   srt-cod-dbt            .
       srt-inp-prc-550.
      *                  *---------------------------------------------*
      *                  * Codice dipendenza del debitore              *
      *                  *---------------------------------------------*
           move      rf-sdb-dpz-dbt       to   srt-dpz-dbt            .
       srt-inp-prc-575.
      *                  *---------------------------------------------*
      *                  * Numero scadenza                             *
      *                  *---------------------------------------------*
           move      rf-sdb-num-sdb       to   srt-num-sdb            .
       srt-inp-prc-600.
      *                  *---------------------------------------------*
      *                  * Inoltro scadenza al debitore                *
      *                  *---------------------------------------------*
           move      rf-sdb-inl-sdb       to   srt-inl-sdb            .
       srt-inp-prc-625.
      *                  *---------------------------------------------*
      *                  * Tipo di scadenza                            *
      *                  *---------------------------------------------*
           move      rf-sdb-tip-sdb       to   srt-tip-sdb            .
       srt-inp-prc-650.
      *                  *---------------------------------------------*
      *                  * Tipo di acquisizione scadenza               *
      *                  *---------------------------------------------*
           move      rf-sdb-tac-sdb       to   srt-tac-sdb            .
       srt-inp-prc-675.
      *                  *---------------------------------------------*
      *                  * Importo scadenza                            *
      *                  *---------------------------------------------*
           move      rf-sdb-imp-sdb       to   srt-imp-sdb            .
       srt-inp-prc-700.
      *                  *---------------------------------------------*
      *                  * Riferimenti al documento                    *
      *                  * - Data documento di riferimento             *
      *                  * - Numero documento di riferimento           *
      *                  * - Tipo documento di riferimento             *
      *                  * - Importo documento di riferimento          *
      *                  * - Nr. rata documento di riferimento         *
      *                  *---------------------------------------------*
           move      rf-sdb-dat-ddr       to   srt-dat-ddr            .
           move      rf-sdb-num-ddr       to   srt-num-ddr            .
           move      rf-sdb-prt-fcl       to   srt-prt-fcl            .
           move      rf-sdb-tip-ddr       to   srt-tip-ddr            .
           move      rf-sdb-imp-ddr       to   srt-imp-ddr            .
           move      rf-sdb-nra-ddr       to   srt-nra-ddr            .
       srt-inp-prc-725.
      *                  *---------------------------------------------*
      *                  * Coordinate banca d'appoggio per la presen-  *
      *                  * tazione                                     *
      *                  * - Codice ABI                                *
      *                  * - Codice ABI                                *
      *                  * - Codice c/c                                *
      *                  *---------------------------------------------*
           move      rf-sdb-abi-app       to   srt-abi-app            .
           move      rf-sdb-cab-app       to   srt-cab-app            .
           move      rf-sdb-ccc-app       to   srt-ccc-app            .
       srt-inp-prc-750.
      *                  *---------------------------------------------*
      *                  * Codice fiscale del debitore da anagrafica   *
      *                  * contabile                                   *
      *                  *---------------------------------------------*
           move      rf-sdb-cod-dbt       to   w-let-arc-cli-cod      .
           perform   let-arc-cli-000      thru let-arc-cli-999        .
           move      w-let-arc-cli-cfi    to   srt-cod-fis            .
      *                  *---------------------------------------------*
      *                  * Partita Iva del debitore da anagrafica      *
      *                  * contabile : in sua assenza, Codice fiscale  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se a zero                          *
      *                      *-----------------------------------------*
           if        w-let-arc-cli-piv    =    zero
                     move  w-let-arc-cli-cfi
                                          to   srt-prt-iva
                     go to srt-inp-prc-780.
      *                      *-----------------------------------------*
      *                      * Editing partita Iva                     *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      w-let-arc-cli-piv    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * In campo di destinazione                *
      *                      *-----------------------------------------*
           move      v-edt                to   srt-prt-iva            .
       srt-inp-prc-780.
      *                  *---------------------------------------------*
      *                  * Test se esiste un corrispondente per il     *
      *                  * debitore in corso di trattamento            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione [cei]                   *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofcei"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cei                 .
      *                      *-----------------------------------------*
      *                      * Lettura [cei]                           *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CLICOR    "         to   f-key                  .
           move      rf-sdb-cod-dbt       to   rf-cei-cod-cli         .
           move      100                  to   rf-cei-num-prg         .
           move      "pgm/gep/fls/ioc/obj/iofcei"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cei                 .
      *                      *-----------------------------------------*
      *                      * Test su esito della lettura             *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to srt-inp-prc-800.
       srt-inp-prc-790.
      *                      *-----------------------------------------*
      *                      * Lettura dei dati del corrispondente     *
      *                      *-----------------------------------------*
           move      rf-cei-cor-cli       to   w-let-arc-cli-cod      .
           perform   let-arc-cli-000      thru let-arc-cli-999        .
           move      w-let-arc-cli-cfi    to   srt-cod-fis            .
      *                      *-----------------------------------------*
      *                      * Test se a zero                          *
      *                      *-----------------------------------------*
