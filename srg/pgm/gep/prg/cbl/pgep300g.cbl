      *    *===========================================================*
      *    * Routines per il trattamento del file [ouf] per la compo-  *
      *    * sizione del file di supporto in formato MS-DOS            *
      *    *                                                           *
      *    * FORMATO STANDARD                                          *
      *    *-----------------------------------------------------------*
       ouf-fil-det-000.
      *              *=================================================*
      *              * Determinazione name e pathname completo per il  *
      *              * file [ouf]                                      *
      *              *-------------------------------------------------*
       ouf-fil-det-100.
      *                  *---------------------------------------------*
      *                  * File name                                   *
      *                  *---------------------------------------------*
           move      "ouf "               to   f-ouf-nam              .
       ouf-fil-det-200.
      *                  *---------------------------------------------*
      *                  * File pathname                               *
      *                  *---------------------------------------------*
       ouf-fil-det-210.
      *                      *-----------------------------------------*
      *                      * Composizione di una stringa composta    *
      *                      * come segue :                            *
      *                      *                                         *
      *                      * aabbbbcc.nnn                            *
      *                      *                                         *
      *                      * dove : aa   = valore fisso 'DP'         *
      *                      *                                         *
      *                      *        bbbb = sigla azienda             *
      *                      *                                         *
      *                      *        cc   = anno di due cifre         *
      *                      *                                         *
      *                      *        nnn  = numero distinta           *
      *                      *                                         *
      *                      *-----------------------------------------*
           move      spaces               to   w-ads-tab-ndf-dos      .
           string    "dp"       delimited by   size
                     w-ads-tab-ndf-azi
                                delimited by   spaces
                     w-ads-tab-ndf-n02-a34
                                delimited by   size
                     "."        delimited by   size
                     w-ads-tab-ndf-n05
                                delimited by   size
                                          into w-ads-tab-ndf-dos      .
       ouf-fil-det-220.
      *                      *-----------------------------------------*
      *                      * Trasformazione in lowercase             *
      *                      *-----------------------------------------*
           move      w-ads-tab-ndf-dos    to   w-all-str-alf          .
           move      12                   to   w-all-str-lun          .
           perform   all-str-low-000      thru all-str-low-999        .
           move      w-all-str-alf        to   w-ads-tab-ndf-dos      .
       ouf-fil-det-230.
      *                      *-----------------------------------------*
      *                      * Concatenamento preliminare con /cbi     *
      *                      *-----------------------------------------*
           move      16                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
           move      "cbi/"               to   w-all-str-cat (1)      .
           move      w-ads-tab-ndf-dos    to   w-all-str-cat (2)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *                      *-----------------------------------------*
      *                      * Concatenamento eventuale con '.TXT'     *
      *                      *-----------------------------------------*
           if        w-prs-tip-fsm        not  = "T"
                     go to ouf-fil-det-280.
      *                      *-----------------------------------------*
      *                      * Concatenamento                          *
      *                      *-----------------------------------------*
           move      40                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
           move      w-all-str-alf        to   w-all-str-cat (1)      .
           move      ".TXT"               to   w-all-str-cat (2)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
       ouf-fil-det-280.
      *                      *-----------------------------------------*
      *                      * Pathname completo sotto /abd/asc        *
      *                      *-----------------------------------------*
           move      "AS"                 to   s-ope                  .
           move      w-all-str-alf        to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-pat                to   f-ouf-pat              .
       ouf-fil-det-300.
      *                  *---------------------------------------------*
      *                  * File status                                 *
      *                  *---------------------------------------------*
           move      "00"                 to   f-ouf-sts              .
       ouf-fil-det-999.
           exit.
       ouf-fil-opo-000.
      *              *-------------------------------------------------*
      *              * Open output file [ouf]                          *
      *              *-------------------------------------------------*
           open      output ouf                                       .
       ouf-fil-opo-999.
           exit.
       ouf-fil-cls-000.
      *              *=================================================*
      *              * Close file [ouf]                                *
      *              *-------------------------------------------------*
           close     ouf                                              .
       ouf-fil-cls-100.
      *              *-------------------------------------------------*
      *              * Completamento del file [ouf] con il carattere   *
      *              * di fine-file x'1A'                              *
      *              *-------------------------------------------------*
       ouf-fil-cls-110.
      *                  *---------------------------------------------*
      *                  * File name per [0u2]                         *
      *                  *---------------------------------------------*
           move      "0u2 "               to   f-ou2-nam              .
      *                  *---------------------------------------------*
      *                  * File pathname per [0u2]                     *
      *                  *---------------------------------------------*
           move      f-ouf-pat            to   f-ou2-pat              .
      *                  *---------------------------------------------*
      *                  * File status per [0u2]                       *
      *                  *---------------------------------------------*
           move      "00"                 to   f-ou2-sts              .
       ouf-fil-cls-120.
      *                  *---------------------------------------------*
      *                  * Open Extend file [ou2]                      *
      *                  *---------------------------------------------*
           open      extend ou2                                       .
       ouf-fil-cls-130.
      *                  *---------------------------------------------*
      *                  * Soppressione carattere di 'EOF'             *
      *                  *---------------------------------------------*
           go to     ouf-fil-cls-140.
      *                  *---------------------------------------------*
      *                  * Scrittura file [ou2]                        *
      *                  *---------------------------------------------*
           move      x'1A'                to   ou2-chr                .
           write     ou2-rec                                          .
       ouf-fil-cls-140.
      *                  *---------------------------------------------*
      *                  * Close file [ou2]                            *
      *                  *---------------------------------------------*
           close     ou2                                              .
       ouf-fil-cls-999.
           exit.
       ouf-fil-wrt-000.
      *              *=================================================*
      *              * Write file [ouf]                                *
      *              *-------------------------------------------------*
       ouf-fil-wrt-100.
      *                  *---------------------------------------------*
      *                  * Incremento progressivo record emessi        *
      *                  *---------------------------------------------*
           add       1                    to   w-ads-sia-gen-rpt      .
       ouf-fil-wrt-200.
      *                  *---------------------------------------------*
      *                  * Completamento con carattere CR              *
      *                  *---------------------------------------------*
           move      x'0D'                to   ouf-crx                .
       ouf-fil-wrt-200.
      *                  *---------------------------------------------*
      *                  * Completamento con carattere LF              *
      *                  *---------------------------------------------*
           move      x'0A'                to   ouf-lfx                .
       ouf-fil-wrt-300.
      *                  *---------------------------------------------*
      *                  * Scrittura effettiva                         *
      *                  *---------------------------------------------*
           write     ouf-rec                                          .
       ouf-fil-wrt-999.
           exit.

      *    *===========================================================*
      *    * Routine per la scrittura record in file Line-Sequential   *
      *    *                                                           *
      *    * Tipo : UNIX                                               *
      *    *-----------------------------------------------------------*
       put-nxt-seq-000.
      *              *-------------------------------------------------*
      *              * Test su personalizzazione relativa al tipo di   *
      *              * file da emettere : UNIX o MS-DOS                *
      *              *-------------------------------------------------*
           if        w-prs-tip-fsm        not  = "U"
                     go to put-nxt-seq-999.
      *              *-------------------------------------------------*
      *              * Incremento progressivo record emessi            *
      *              *-------------------------------------------------*
           add       1                    to   w-ads-sia-gen-rpt      .
       put-nxt-seq-200.
      *              *-------------------------------------------------*
      *              * Scrittura record in file Line-Sequential        *
      *              *-------------------------------------------------*
           move      "PN"                 to   g-ope                  .
           call      "swd/mod/prg/obj/mlsfil"
                                         using g                      .
       put-nxt-seq-999.
           exit.

      *    *===========================================================*
      *    * Routine per il controllo di errore in scrittura record in *
      *    * file Line-Sequential                                      *
      *    *-----------------------------------------------------------*
       tst-err-wrt-000.
      *              *-------------------------------------------------*
      *              * Se errori : messaggio ed uscita con flag di er- *
      *              * rore                                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se controllo da effettuare             *
      *                  *---------------------------------------------*
           if        w-prs-tip-fsm        not  = "U"
                     go to tst-err-wrt-999.
      *                  *---------------------------------------------*
      *                  * Controllo                                   *
      *                  *---------------------------------------------*
           if        g-sts                =    e-not-err
                     go to tst-err-wrt-999.
      *                  *---------------------------------------------*
      *                  * Messaggio                                   *
      *                  *---------------------------------------------*
           move      "Attenzione : Errore nella generazione dell'archivi
      -              "o di supporto. "    to   w-err-box-err-msg      .
           move      "             Operazione non eseguita (Write error)
      -              " !             "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                  *---------------------------------------------*
      *                  * Flag ad errore                              *
      *                  *---------------------------------------------*
           move      "#"                  to   w-ads-tab-out-flg      .
       tst-err-wrt-999.
           exit.

