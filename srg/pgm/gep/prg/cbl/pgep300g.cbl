      *                  *---------------------------------------------*
           move      spaces               to   w-rid-sia-999-fpu      .
           move      "EF"                 to   w-rid-sia-999-tre      .
       rid-999-sia-150.
      *                  *---------------------------------------------*
      *                  * Mittente, ovvero il codice con cui la SIA   *
      *                  * ha censito il creditore presentante la di-  *
      *                  * stinta                                      *
      *                  *---------------------------------------------*
           move      w-prs-sia-cda-sia    to   w-rid-sia-999-mtn      .
       rid-999-sia-175.
      *                  *---------------------------------------------*
      *                  * Ordinante, ovvero il codice ABI della banca *
      *                  * di presentazione                            *
      *                  *---------------------------------------------*
           move      w-tes-cod-cbp-abi (1)
                                          to   w-rid-sia-999-odt      .
       rid-999-sia-200.
      *                  *---------------------------------------------*
      *                  * Data di creazione supporto                  *
      *                  *---------------------------------------------*
           move      w-tes-dtr-pre (1)    to   s-dat                  .
           move      s-gio                to   w-rid-sia-999-dcg      .
           move      s-mes                to   w-rid-sia-999-dcm      .
           move      s-ann                to   w-rid-sia-999-dca      .
       rid-999-sia-225.
      *                  *---------------------------------------------*
      *                  * Nome del supporto                           *
      *                  *---------------------------------------------*
       rid-999-sia-250.
      *                      *-----------------------------------------*
      *                      * Normalizzazione preliminare             *
      *                      *-----------------------------------------*
           move      spaces               to   w-rid-sia-999-nds      .
       rid-999-sia-275.
      *                      *-----------------------------------------*
      *                      * Primi quattro caratteri della descri-   *
      *                      * zione azienda SIA, parte 1, posti in    *
      *                      * uppercase                               *
      *                      *-----------------------------------------*
           move      w-prs-sia-daz-001    to   w-all-str-alf          .
           move      04                   to   w-all-str-lun          .
           perform   all-str-upp-000      thru all-str-upp-999        .
           move      w-all-str-alf        to   w-rid-sia-999-x10      .
       rid-999-sia-300.
      *                      *-----------------------------------------*
      *                      * Numero progressivo di spedizione, che   *
      *                      * viene posto pari alle ultime tre cifre  *
      *                      * del numero distinta nell'ambito dell'-  *
      *                      * anno                                    *
      *                      *-----------------------------------------*
           move      w-tes-num-ddp (1)    to   w-rid-sia-999-x20      .
       rid-999-sia-300.
      *                      *-----------------------------------------*
      *                      * Data di creazione del supporto          *
      *                      *-----------------------------------------*
           move      w-tes-dtr-pre (1)    to   s-dat                  .
           move      s-gio                to   w-rid-sia-999-x31      .
           move      s-mes                to   w-rid-sia-999-x32      .
           move      s-ann                to   w-rid-sia-999-x33      .
       rid-999-sia-325.
      *                      *-----------------------------------------*
      *                      * Valore fisso a spaces                   *
      *                      *-----------------------------------------*
           move      spaces               to   w-rid-sia-999-x40      .
       rid-999-sia-350.
      *                      *-----------------------------------------*
      *                      * Codice ABI della banca di presentazione *
      *                      *-----------------------------------------*
           move      w-tes-cod-cbp-abi (1)
                                          to   w-rid-sia-999-x50      .
       rid-999-sia-375.
      *                  *---------------------------------------------*
      *                  * Data di elaborazione supporto, pari alla    *
      *                  * data di creazione del supporto              *
      *                  *---------------------------------------------*
           move      w-tes-dtr-pre (1)    to   s-dat                  .
           move      s-gio                to   w-rid-sia-999-deg      .
           move      s-mes                to   w-rid-sia-999-dem      .
           move      s-ann                to   w-rid-sia-999-dea      .
       rid-999-sia-400.
      *                  *---------------------------------------------*
      *                  * Numero di disposizioni contenute nel flusso *
      *                  *---------------------------------------------*
           move      w-ads-sia-gen-pro    to   w-rid-sia-999-nrv      .
       rid-999-sia-425.
      *                  *---------------------------------------------*
      *                  * Importo totale delle disposizioni contenute *
      *                  * nel flusso                                  *
      *                  *---------------------------------------------*
           move      w-tes-imp-ddp (1)    to   w-rid-sia-999-itr      .
       rid-999-sia-450.
      *                  *---------------------------------------------*
      *                  * Filler di 15 numeri a zero                  *
      *                  *---------------------------------------------*
           move      "000000000000000"    to   w-rid-sia-999-f15      .
       rid-999-sia-475.
      *                  *---------------------------------------------*
      *                  * Numero dei record contenuti nel flusso com- *
      *                  * prensivo di testa e coda                    *
      *                  *---------------------------------------------*
           move      w-ads-sia-gen-rpt    to   w-rid-sia-999-nrc      .
           add       1                    to   w-rid-sia-999-nrc      .
       rid-999-sia-500.
      *                  *---------------------------------------------*
      *                  * Filler a spaces                             *
      *                  *---------------------------------------------*
           move      spaces               to   w-rid-sia-999-f23      .
       rid-999-sia-525.
      *                  *---------------------------------------------*
      *                  * Tipo incasso R.I.D., fisso al valore ' '    *
      *                  *---------------------------------------------*
           move      " "                  to   w-rid-sia-999-tir      .
       rid-999-sia-550.
      *                  *---------------------------------------------*
      *                  * Codice divisa (I=ITL - E=EUR)               *
      *                  *---------------------------------------------*
           if        c-sgl                =    "EUR"
                     move  "E"            to   w-rid-sia-999-cdv
           else      move  "I"            to   w-rid-sia-999-cdv      .
       rid-999-sia-575.
      *                  *---------------------------------------------*
      *                  * Filler a spaces                             *
      *                  *---------------------------------------------*
           move      spaces               to   w-rid-sia-999-f06      .
       rid-999-sia-900.
      *              *-------------------------------------------------*
