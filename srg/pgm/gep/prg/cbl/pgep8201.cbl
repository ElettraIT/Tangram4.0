      *                          * Rilettura archivio [age]            *
      *                          *-------------------------------------*
           move      w-rot-l03-cod-age    to   w-let-arc-age-cod      .
           perform   let-arc-age-000      thru let-arc-age-999        .
       int-pag-sta-200.
      *                          *-------------------------------------*
      *                          * String                              *
      *                          *-------------------------------------*
           string    " "
                                delimited by   size
                     w-let-arc-age-nom
                                delimited by   size
                                          into w-int-pag-sta-x40
                                  with pointer w-int-pag-sta-pnt      .
      *                  *---------------------------------------------*
      *                  * Stampa stringa                              *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      40                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      w-int-pag-sta-x40    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Sottolinetura intestazione agente               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Riposizionamento puntatore                  *
      *                  *---------------------------------------------*
           move      zero                 to   w-int-pag-sta-pnt      .
           inspect   w-int-pag-sta-x40
                                      tallying w-int-pag-sta-pnt
                                  for trailing spaces                 .
           subtract  40                   from w-int-pag-sta-pnt      .
      *                  *---------------------------------------------*
      *                  * Stampa                                      *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      w-int-pag-sta-pnt    to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      all "-"              to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-pag-sta-900.
      *              *-------------------------------------------------*
      *              * Vertical Position                               *
      *              *-------------------------------------------------*
           move      "VP"                 to   p-ope                  .
           add       01
                     p-lnr              giving p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-pag-sta-999.
           exit.

