      *              * Preparazione parametri intestazione standard    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing data riferimento                    *
      *                  *---------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "D"                  to   p-tip                  .
           move      "<"                  to   p-edm                  .
           move      w-num-dat-rif        to   p-dat                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Composizione titolo                         *
      *                  *---------------------------------------------*
           string    "LISTA DI CONTROLLO SCADENZE DA SOLLECITARE PER IL 
      -              "CICLO DEL "
                                delimited by   size
                     p-edt      delimited by   spaces
                                          into w-cnt-tit-des-tit      .
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-cnt-tit-dat-stp      .
           move      p-pag                to   w-cnt-tit-num-pag      .
           add       1                    to   w-cnt-tit-num-pag      .
      *              *-------------------------------------------------*
      *              * Intestazione standard                           *
      *              *-------------------------------------------------*
           perform   int-pag-std-000      thru int-pag-std-999        .
      *                  *---------------------------------------------*
      *                  * Se uscita per interruzione forzata          *
      *                  *---------------------------------------------*
           if        w-cnt-prn-flg-int    not  = spaces
                     go to  int-pag-sta-999.
       int-pag-sta-100.
      *              *-------------------------------------------------*
      *              * Intestazione agente                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da effettuare                       *
      *                  *---------------------------------------------*
           if        rr-tip-ord           not  = 01
                     go to int-pag-sta-900.
      *                  *---------------------------------------------*
      *                  * Composizione stringa                        *
      *                  *---------------------------------------------*
           move      spaces               to   w-int-pag-sta-x40      .
           move      1                    to   w-int-pag-sta-pnt      .
      *                      *-----------------------------------------*
      *                      * Prompt                                  *
      *                      *-----------------------------------------*
           string    "Agente : "
                                delimited by   size
                                          into w-int-pag-sta-x40
                                  with pointer w-int-pag-sta-pnt      .
      *                      *-----------------------------------------*
      *                      * Codice                                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Editing                             *
      *                          *-------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      07                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "B<"                 to   p-edm                  .
      *
           if        w-rot-l03-cod-age    =    9999999
                     move  zero           to   p-num
           else      move w-rot-l03-cod-age
                                          to   p-num                  .
      *
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * String                              *
      *                          *-------------------------------------*
           string    p-edt
                                delimited by   spaces
                                          into w-int-pag-sta-x40
                                  with pointer w-int-pag-sta-pnt      .
      *                      *-----------------------------------------*
      *                      * Nominativo                              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test su codice agente               *
      *                          *-------------------------------------*
           if        w-rot-l03-cod-age    =    9999999
                     move "(Senza agente)"
                                          to   w-let-arc-age-nom
                     go to int-pag-sta-200.
