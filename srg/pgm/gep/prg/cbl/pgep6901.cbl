       prn-opn-fls-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Close files                        *
      *    *-----------------------------------------------------------*
       prn-cls-fls-000.
      *              *-------------------------------------------------*
      *              * [sdb]                                           *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *              *-------------------------------------------------*
      *              * [ddp]                                           *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddp                 .
      *              *-------------------------------------------------*
      *              * [dcc]                                           *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
      *              *-------------------------------------------------*
      *              * [fit]                                           *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/fat/fls/ioc/obj/ioffit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fit                 .
       prn-cls-fls-999.
           exit.

      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Start su file [sdb] per debitore data chiusura  *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "GT"                 to   f-cfr                  .
           move      "DBTDTS    "         to   f-key                  .
           move      01                   to   rf-sdb-tip-dbt         .
           move      rr-cod-cli           to   rf-sdb-cod-dbt         .
           move      zero                 to   rf-sdb-dts-sdb         .
           move      zero                 to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Read Next su file [sdb]                         *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Max sul record                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo debitore                       *
      *                  *---------------------------------------------*
           if        rf-sdb-tip-dbt       not  = 01
                     go to stp-srt-inp-900.
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice debitore                     *
      *                  *---------------------------------------------*
           if        rr-cod-cli           =    zero
                     go to stp-srt-inp-420.
           if        rf-sdb-cod-dbt       not  = rr-cod-cli
                     go to stp-srt-inp-200.
       stp-srt-inp-420.
      *                  *---------------------------------------------*
      *                  * Test se tipo scadenza compreso tra quelli   *
      *                  * richiesti                                   *
      *                  *---------------------------------------------*
           if       (rf-sdb-tip-sdb       =    01   and
                     rf-sdb-snx-dlc       =    "N"    ) and
                     rr-snx-tsc (01)      =    "S"
                     go to stp-srt-inp-440
           else if  (rf-sdb-tip-sdb       =    01   and
                     rf-sdb-snx-dlc       =    "S"    ) and
                     rr-snx-tsc (02)      =    "S"
                     go to stp-srt-inp-440
           else if   rf-sdb-tip-sdb       =    02 and
                     rr-snx-tsc (03)      =    "S"
                     go to stp-srt-inp-440
           else if   rf-sdb-tip-sdb       =    03 and
                     rr-snx-tsc (04)      =    "S"
                     go to stp-srt-inp-440
           else if   rf-sdb-tip-sdb       =    04 and
                     rr-snx-tsc (05)      =    "S"
                     go to stp-srt-inp-440
           else if   rf-sdb-tip-sdb       =    05 and
                     rr-snx-tsc (06)      =    "S"
                     go to stp-srt-inp-440
           else if   rf-sdb-tip-sdb       =    06 and
                     rr-snx-tsc (07)      =    "S"
                     go to stp-srt-inp-440
           else if   rf-sdb-tip-sdb       =    07 and
                     rr-snx-tsc (08)      =    "S"
                     go to stp-srt-inp-440
           else if   rf-sdb-tip-sdb       =    08 and
                     rr-snx-tsc (09)      =    "S"
                     go to stp-srt-inp-440
           else if   rf-sdb-tip-sdb       =    09 and
                     rr-snx-tsc (10)      =    "S"
                     go to stp-srt-inp-440
           else if   rf-sdb-tip-sdb       =    10 and
                     rr-snx-tsc (11)      =    "S"
                     go to stp-srt-inp-440
           else if   rf-sdb-tip-sdb       =    11 and
                     rr-snx-tsc (12)      =    "S"
                     go to stp-srt-inp-440
           else      go to stp-srt-inp-200.
       stp-srt-inp-440.
      *                  *---------------------------------------------*
      *                  * Test su data scadenza                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda che sia scadenza a *
      *                      * vista o no                              *
      *                      *-----------------------------------------*
           if        rf-sdb-dts-sdb       =    zero
                     go to stp-srt-inp-442
           else      go to stp-srt-inp-444.
       stp-srt-inp-442.
      *                      *-----------------------------------------*
      *                      * Se scadenza a vista                     *
      *                      *-----------------------------------------*
           if        rr-snx-scv           not  = "S"
                     go to stp-srt-inp-200.
           go to     stp-srt-inp-450.
       stp-srt-inp-444.
      *                      *-----------------------------------------*
      *                      * Se scadenza non a vista                 *
      *                      *-----------------------------------------*
           if        rf-sdb-dts-sdb       <    rr-dat-sci or
                     rf-sdb-dts-sdb       >    rr-dat-scf
                     go to stp-srt-inp-200.
           go to     stp-srt-inp-450.
       stp-srt-inp-450.
      *                  *---------------------------------------------*
      *                  * Selezione su status della scadenza          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione status scadenza          *
      *                      *-----------------------------------------*
           move      rr-dat-bcm           to   w-det-srd-sdb-drd      .
           perform   det-srd-sdb-000      thru det-srd-sdb-999        .
      *                      *-----------------------------------------*
      *                      * Test su ultima operazione eseguita sul- *
      *                      * la scadenza                             *
      *                      *-----------------------------------------*
           if        w-det-srd-sdb-suo    not  = "RIS" and
                     w-det-srd-sdb-suo    not  = "ACD" and
                     w-det-srd-sdb-suo    not  = "ACS" and
                     w-det-srd-sdb-suo    not  = "NBE" and
                     w-det-srd-sdb-suo    not  = "PBE"
                     go to stp-srt-inp-200.
      *                      *-----------------------------------------*
      *                      * Test su data riscossione                *
      *                      *-----------------------------------------*
           if        w-det-srd-sdb-drs    =    zero
                     go to stp-srt-inp-200.
       stp-srt-inp-460.
      *                  *---------------------------------------------*
      *                  * Test su modalita' di riscossione            *
      *                  *---------------------------------------------*
           if        rr-mod-rsd           =    zero
                     go to stp-srt-inp-470.
           if        rr-mod-rsd           =    rf-sdb-mod-ris
                     go to stp-srt-inp-470
           else      go to stp-srt-inp-200.
       stp-srt-inp-470.
      *                  *---------------------------------------------*
      *                  * Test su data di riscossione                 *
      *                  *---------------------------------------------*
           if        rf-sdb-dtr-ris       <    rr-drg-min or
                     rf-sdb-dtr-ris       >    rr-drg-max
                     go to stp-srt-inp-200.
       stp-srt-inp-480.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dcc]                      *
      *                  *---------------------------------------------*
           move      rf-sdb-cod-dbt       to   w-let-arc-dcc-cli      .
           move      spaces               to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
       stp-srt-inp-600.
      *                  *---------------------------------------------*
      *                  * Composizione record di Sort                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Composizione chiave                     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione scadenza effettiva   *
      *                          *-------------------------------------*
           move      rf-sdb-dts-sdb       to   srt-dts-eff            .
      *
           if        srt-dts-eff          =    zero
                     move  rf-sdb-dat-ddr to   srt-dts-eff            .
      *
           if        srt-dts-eff          =    zero
                     move  rf-sdb-dtr-emi to   srt-dts-eff            .
      *                          *-------------------------------------*
      *                          * Determinazione data riscossione     *
      *                          *-------------------------------------*
           if        w-det-srd-sdb-drs    <    rf-sdb-dts-sdb
                     move  rf-sdb-dts-sdb to   w-det-srd-sdb-drs      .
      *
           move      w-det-srd-sdb-drs    to   srt-dat-ris            .
      *                          *-------------------------------------*
      *                          * Determinazione giorni di ritardo    *
      *                          *-------------------------------------*
           move      srt-dts-eff          to   w-clc-dat-min          .
           move      srt-dat-ris          to   w-clc-dat-max          .
           perform   clc-ope-dat-000      thru clc-ope-dat-999        .
           move      w-clc-dat-nrg        to   srt-grn-rit            .
      *                          *-------------------------------------*
      *                          * Giorni di ritardo in chiave         *
      *                          *-------------------------------------*
           move      9999999              to   srt-key-rit            .
           if        rr-tip-ord           =    03
                     subtract  w-clc-dat-nrg
                                          from srt-key-rit            .
      *                          *-------------------------------------*
      *                          * Ragione sociale in chiave           *
      *                          *-------------------------------------*
           if        rr-tip-ord           not  = 02
                     move  spaces         to   srt-key-rag
           else      move  w-let-arc-dcc-rsu
                                          to   srt-key-rag            .
      *                          *-------------------------------------*
      *                          * Data documento in chiave            *
      *                          *-------------------------------------*
           move      rf-sdb-dat-ddr       to   srt-key-ddr            .
      *                      *-----------------------------------------*
      *                      * Composizione dati                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Data scadenza per sort              *
      *                          *-------------------------------------*
           if        rf-sdb-dts-sdb       =    zero
                     move  rr-dat-bcm     to   srt-dts-srt
           else      move  rf-sdb-dts-sdb to   srt-dts-srt            .
      *                          *-------------------------------------*
      *                          * Status scadenza                     *
      *                          *-------------------------------------*
           if        rf-sdb-dts-sdb       =    zero
                     move  02             to   srt-sts-srt
           else if   rf-sdb-dts-sdb       not  > rr-dat-bcm
                     move  01             to   srt-sts-srt
           else      move  03             to   srt-sts-srt            .
      *                          *-------------------------------------*
      *                          * Dati cliente                        *
      *                          *-------------------------------------*
           move      rf-sdb-cod-dbt       to   srt-cod-cli            .
           move      rf-sdb-dpz-dbt       to   srt-dpz-cli            .
           move      w-let-arc-dcc-rsu    to   srt-rag-key            .
           move      w-let-arc-dcc-rag    to   srt-rag-soc            .
      *                          *-------------------------------------*
      *                          * Numero scadenza                     *
      *                          *-------------------------------------*
           move      rf-sdb-num-sdb       to   srt-num-sdb            .
      *                          *-------------------------------------*
      *                          * Tipo scadenza                       *
      *                          *-------------------------------------*
           move      rf-sdb-tip-sdb       to   srt-tip-sdb            .
      *                          *-------------------------------------*
      *                          * Si/No dilazione concordata          *
      *                          *-------------------------------------*
           move      rf-sdb-snx-dlc       to   srt-snx-dlc            .
      *                          *-------------------------------------*
      *                          * Si/No contrassegno                  *
      *                          *-------------------------------------*
           move      rf-sdb-snx-cts       to   srt-snx-cts            .
      *                          *-------------------------------------*
      *                          * Flag di scadenza insoluta           *
      *                          *-------------------------------------*
           if        w-det-srd-sdb-suo    =    "ISP"
                     move  "#"            to   srt-flg-isp
           else      move  spaces         to   srt-flg-isp            .
      *                          *-------------------------------------*
      *                          * Importo scadenza                    *
      *                          *-------------------------------------*
           move      rf-sdb-imp-sdb       to   srt-imp-sdb            .
      *                          *-------------------------------------*
      *                          * Documento di riferimento            *
      *                          *-------------------------------------*
           move      rf-sdb-tip-ddr       to   srt-tip-ddr            .
           move      rf-sdb-dat-ddr       to   srt-dat-ddr            .
           move      rf-sdb-num-ddr       to   srt-num-ddr            .
           move      rf-sdb-imp-ddr       to   srt-imp-ddr            .
           move      rf-sdb-nra-ddr       to   srt-nra-ddr            .
           move      rf-sdb-nsc-org       to   srt-nsc-org            .
      *                          *-------------------------------------*
      *                          * Importo riscossione                 *
      *                          *-------------------------------------*
           move      rf-sdb-imp-ris       to   srt-imp-ris            .
      *                          *-------------------------------------*
      *                          * Giorni di ritardo                   *
      *                          *-------------------------------------*
           move      w-clc-dat-nrg        to   srt-grn-rit            .
       stp-srt-inp-680.
      *                  *---------------------------------------------*
      *                  * Rilascio del record al Sort                 *
      *                  *---------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-700.
      *                  *---------------------------------------------*
      *                  * Riciclo su Read Next [sdb]                  *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Start iniziale                     *
      *    *-----------------------------------------------------------*
       prn-str-ini-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
       prn-str-ini-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Messaggio per nessuna registraz.   *
      *    *-----------------------------------------------------------*
       prn-nes-ela-000.
           move      "WR"                 to   m-ope                  .
           move      "Nessuna registrazione entro i limiti assegnati !"
                                          to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       prn-nes-ela-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Lettura sequenziale                *
      *    *-----------------------------------------------------------*
       prn-let-seq-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale archivio sortato [srt]      *
      *              *-------------------------------------------------*
           return    srt    at end
                            move  "#"     to   w-cnt-prn-flg-sub
                            go to prn-let-seq-999.
       prn-let-seq-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Test se superamento limiti massimi *
      *    *-----------------------------------------------------------*
       prn-tst-max-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
       prn-tst-max-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Selezione su record letto          *
      *    *-----------------------------------------------------------*
       prn-sel-rec-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
       prn-sel-rec-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Composizione area per rotture      *
      *    *-----------------------------------------------------------*
       prn-cmp-rot-000.
      *              *-------------------------------------------------*
      *              * Rottura su cliente                              *
      *              *-------------------------------------------------*
           if        rr-tip-ord           not  = 02
                     move  spaces         to   w-rot-l02-key-rag
           else      move  srt-key-rag    to   w-rot-l02-key-rag      .
      *              *-------------------------------------------------*
      *              * Mese e anno scadenza                            *
      *              *-------------------------------------------------*
           move      srt-dts-srt          to   s-dat                  .
           move      s-saa                to   w-rot-l01-saa-sdb      .
           move      s-mes                to   w-rot-l01-mes-sdb      .
      *              *-------------------------------------------------*
      *              * Flag per rottura                                *
      *              *-------------------------------------------------*
           move      srt-sts-srt          to   w-rot-l01-sts-scd      .
       prn-cmp-rot-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Esecuzione per inizio ciclo        *
      *    *-----------------------------------------------------------*
       prn-ini-cic-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
      *              *-------------------------------------------------*
      *              * Flag di intestazione pagina                     *
      *              *-------------------------------------------------*
           move      spaces               to   w-int-pag-sta-flg      .
      *              *-------------------------------------------------*
      *              * Azzeramento totali riepilogo                    *
      *              *-------------------------------------------------*
      *              *-------------------------------------------------*
      *              * Intestazione foglio                             *
      *              *-------------------------------------------------*
           perform   int-pag-sta-000      thru int-pag-sta-999        .
       prn-ini-cic-200.
      *              *-------------------------------------------------*
      *              * Apertura file di esportazione                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su si/no esportazione archivio         *
      *                  *---------------------------------------------*
           if        rr-snx-exp           not  = 2 and
                     rr-snx-exp           not  = 3
                     go to prn-ini-cic-999.
      *                  *---------------------------------------------*
      *                  * Subroutine di inizializzazione              *
      *                  *---------------------------------------------*
           perform   prn-ini-cic-exp-000  thru prn-ini-cic-exp-999    .
       prn-ini-cic-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Esecuzione per inizio ciclo        *
      *    *                                                           *
      *    * Subroutine per inizio emissione file sequenziale          *
      *    *-----------------------------------------------------------*
       prn-ini-cic-exp-000.
      *              *-------------------------------------------------*
      *              * Open file di export                             *
      *              *-------------------------------------------------*
           move      "OP"                 to   x-ope                  .
           move      spaces               to   x-pat                  .
           move      spaces               to   x-nam                  .
           move      02                   to   x-tex                  .
           move      ";"                  to   x-sep                  .
           call      "swd/mod/prg/obj/mxport"
                                        using  x                      .
           move      x-pat                to   w-det-pth-fso-pat      .
       prn-ini-cic-exp-200.
      *              *-------------------------------------------------*
      *              * Intestazioni colonne                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Codice cliente                              *
      *                  *---------------------------------------------*
           move      "PF"                 to   x-ope                  .
           move      "H"                  to   x-tip                  .
           move      06                   to   x-car                  .
           move      "CODICE"             to   x-alf                  .
           call      "swd/mod/prg/obj/mxport"
                                         using x                      .
      *                  *---------------------------------------------*
      *                  * Codice dipendenza cliente                   *
      *                  *---------------------------------------------*
           move      "PF"                 to   x-ope                  .
           move      "A"                  to   x-tip                  .
           move      04                   to   x-car                  .
           move      "DPZ"                to   x-alf                  .
           call      "swd/mod/prg/obj/mxport"
                                         using x                      .
      *                  *---------------------------------------------*
      *                  * Ragione sociale cliente                     *
      *                  *---------------------------------------------*
           move      "PF"                 to   x-ope                  .
           move      "A"                  to   x-tip                  .
           move      15                   to   x-car                  .
           move      "RAGIONE SOCIALE"    to   x-alf                  .
           call      "swd/mod/prg/obj/mxport"
                                         using x                      .
      *                  *---------------------------------------------*
      *                  * Tipo documento                              *
      *                  *---------------------------------------------*
           move      "PF"                 to   x-ope                  .
           move      "A"                  to   x-tip                  .
           move      03                   to   x-car                  .
           move      "DOC"                to   x-alf                  .
           call      "swd/mod/prg/obj/mxport"
                                         using x                      .
      *                  *---------------------------------------------*
      *                  * Numero documento                            *
      *                  *---------------------------------------------*
           move      "PF"                 to   x-ope                  .
           move      "A"                  to   x-tip                  .
           move      03                   to   x-car                  .
           move      "NR."                to   x-alf                  .
           call      "swd/mod/prg/obj/mxport"
                                         using x                      .
      *                  *---------------------------------------------*
