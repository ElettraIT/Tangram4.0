           move      08                   to   p-car                  .
           move      spaces               to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      079                  to   p-pos                  .
           move      rf-sdb-num-sdb       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
