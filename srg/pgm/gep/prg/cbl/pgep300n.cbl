       acc-tav-ott-225.
      *              *-------------------------------------------------*
      *              * Se Expd                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "EXPD"
                     go to acc-tav-ott-250.
      *                  *---------------------------------------------*
      *                  * Espansione su scadenze debitori             *
      *                  *---------------------------------------------*
           move      "N"                  to   w-esp-arc-sdb-sns      .
           move      w-rig-num-sdb (1)    to   w-esp-arc-sdb-num      .
           perform   esp-arc-sdb-000      thru esp-arc-sdb-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo ad accettazione                     *
      *                  *---------------------------------------------*
           go to     acc-tav-ott-100.
       acc-tav-ott-250.
      *              *-------------------------------------------------*
      *              * Se Return  o Pf1 o Pf2 o Pf3 o Pf4               *
      *              *-------------------------------------------------*
           if        v-key                =    spaces or
                     v-key                =    "[1] " or
                     v-key                =    "[2] " or
                     v-key                =    "[3] " or
                     v-key                =    "[4] "
                     go to acc-tav-ott-400.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-tav-ott-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-rig
                     go to acc-tav-ott-999.
