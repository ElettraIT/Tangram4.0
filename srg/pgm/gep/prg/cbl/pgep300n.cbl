      *    *===========================================================*
      *    * Routine post-conferma di modifica                         *
      *    *-----------------------------------------------------------*
       pos-cnf-mod-000.
      *              *-------------------------------------------------*
      *              * Determinazione del tipo di modifica intervenuta *
      *              * nell'operazione di accredito distinta in c/c e  *
      *              * dei relativi flags indicatori                   *
      *              *-------------------------------------------------*
           perform   det-mod-acd-000      thru det-mod-acd-999        .
      *              *-------------------------------------------------*
      *              * Se il tipo di modifica non comporta alcuna va-  *
      *              * riazione : alla sola riscrittura dei tipi avvi- *
      *              * so ottenuti                                     *
      *              *-------------------------------------------------*
           if        w-mod-acd-rec-ddp    =    spaces and
                     w-mod-acd-cge-gep    =    spaces
                     go to pos-cnf-mod-900.
       pos-cnf-mod-050.
      *              *-------------------------------------------------*
      *              * Lettura record [ddp] con lock                   *
      *              *-------------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMDDP    "         to   f-key                  .
           move      w-tes-num-ddp (1)    to   rf-ddp-num-ddp         .
           move      "pgm/gep/fls/ioc/obj/iofddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddp                 .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to pos-cnf-mod-200.
       pos-cnf-mod-100.
      *              *-------------------------------------------------*
      *              * Se record [ddp] non esistente                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   e01-cnf-mod-000      thru e01-cnf-mod-999        .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     pos-cnf-mod-999.
       pos-cnf-mod-200.
      *              *-------------------------------------------------*
      *              * Se record [ddp] esistente                       *
      *              *-------------------------------------------------*
       pos-cnf-mod-250.
      *                  *---------------------------------------------*
      *                  * Controllo che la distinta di presentazione  *
      *                  * non sia nel frattempo stata variata         *
      *                  *---------------------------------------------*
           if        rf-ddp-dtr-com       not  = w-tes-dtr-com (1) or
                     rf-ddp-dtr-pre       not  = w-tes-dtr-pre (1) or
                     rf-ddp-drc-pre       not  = w-tes-drc-pre (1) or
                     rf-ddp-npc-pre       not  = w-tes-npc-pre (1) or
                     rf-ddp-cod-cbp       not  = w-tes-cod-cbp (1) or
                     rf-ddp-snx-stp       not  = w-tes-snx-stp (1) or
                     rf-ddp-flc-stp       not  = w-tes-flc-stp (1) or
                     rf-ddp-snx-ads       not  = w-tes-snx-ads (1) or
                     rf-ddp-flc-ads       not  = w-tes-flc-ads (1) or
                     rf-ddp-tip-ias       not  = w-tes-tip-ias (1) or
                     rf-ddp-flc-ias       not  = w-tes-flc-ias (1) or
                     rf-ddp-drc-act       not  = w-tes-drc-act (2) or
                     rf-ddp-npc-act       not  = w-tes-npc-act (2) or
                     rf-ddp-dcb-act       not  = w-tes-dcb-act (2) or
                     rf-ddp-drc-acd       not  = w-tes-drc-acd (2) or
                     rf-ddp-npc-acd       not  = w-tes-npc-acd (2) or
                     rf-ddp-dcb-acd       not  = w-tes-dcb-acd (2) or
                     rf-ddp-ncb-acd       not  = w-tes-ncb-acd (2) or
                     rf-ddp-spe-acd       not  = w-tes-spe-acd (2) or
                     rf-ddp-int-acd       not  = w-tes-int-acd (2) or
                     rf-ddp-flg-ela       not  = spaces            or
                     rf-ddp-flg-pul       not  = spaces
                     go to pos-cnf-mod-275.
           go to     pos-cnf-mod-300.
       pos-cnf-mod-275.
      *                  *---------------------------------------------*
      *                  * Se la distinta di presentazione e' stata    *
      *                  * nel frattempo variata                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Unlock record [ddp]                     *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddp                 .
      *                      *-----------------------------------------*
