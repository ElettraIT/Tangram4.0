      *    *===========================================================*
      *    * Routine post-conferma di inserimento                      *
      *    *-----------------------------------------------------------*
       pos-cnf-ins-000.
      *              *-------------------------------------------------*
      *              * Aggiornamento default per data registrazione    *
      *              *-------------------------------------------------*
           move      w-key-dat-reg        to   w-def-dat-reg          .
      *              *-------------------------------------------------*
      *              * Aggiornamento default per tipo operazione       *
      *              *-------------------------------------------------*
           move      w-key-tip-ope        to   w-def-tip-ope          .
       pos-cnf-ins-050.
      *              *-------------------------------------------------*
      *              * Lettura record [ddp] con lock                   *
      *              *-------------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMDDP    "         to   f-key                  .
           move      w-tes-num-ddp (1)    to   rf-ddp-num-ddp         .
           move      "pgm/gep/fls/ioc/obj/iofddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddp                 .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to pos-cnf-ins-200.
       pos-cnf-ins-100.
      *              *-------------------------------------------------*
      *              * Se record [ddp] non esistente                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   e01-cnf-ins-000      thru e01-cnf-ins-999        .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     pos-cnf-ins-999.
       pos-cnf-ins-200.
      *              *-------------------------------------------------*
      *              * Se record [ddp] esistente                       *
      *              *-------------------------------------------------*
       pos-cnf-ins-250.
      *                  *---------------------------------------------*
      *                  * Controllo che la distinta di presentazione  *
      *                  * non sia nel frattempo stata variata         *
      *                  *---------------------------------------------*
           if        rf-ddp-dtr-com       not  = w-tes-dtr-com (1) or
                     rf-ddp-dtr-pre       not  = w-tes-dtr-pre (1) or
                     rf-ddp-drc-pre       not  = w-tes-drc-pre (1) or
                     rf-ddp-npc-pre       not  = w-tes-npc-pre (1) or
                     rf-ddp-cod-cbp       not  = w-tes-cod-cbp (1) or
                     rf-ddp-snx-stp       not  = w-tes-snx-stp (1) or
                     rf-ddp-flc-stp       not  = w-tes-flc-stp (1) or
                     rf-ddp-snx-ads       not  = w-tes-snx-ads (1) or
                     rf-ddp-flc-ads       not  = w-tes-flc-ads (1) or
                     rf-ddp-tip-ias       not  = w-tes-tip-ias (1) or
                     rf-ddp-flc-ias       not  = w-tes-flc-ias (1) or
                     rf-ddp-dtr-act       not  = w-tes-dtr-act (1) or
                     rf-ddp-drc-act       not  = w-tes-drc-act (1) or
                     rf-ddp-npc-act       not  = w-tes-npc-act (1) or
                     rf-ddp-dtr-acd       not  = zero              or
                     rf-ddp-drc-acd       not  = zero              or
                     rf-ddp-npc-acd       not  = zero              or
                     rf-ddp-flg-ela       not  = spaces            or
                     rf-ddp-flg-pul       not  = spaces
                     go to pos-cnf-ins-275.
           go to     pos-cnf-ins-300.
       pos-cnf-ins-275.
      *                  *---------------------------------------------*
      *                  * Se la distinta di presentazione e' stata    *
      *                  * nel frattempo variata                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Unlock record [ddp]                     *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddp                 .
      *                      *-----------------------------------------*
      *                      * Emissione messaggio di errore           *
      *                      *-----------------------------------------*
           perform   e11-cnf-ins-000      thru e11-cnf-ins-999        .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     pos-cnf-ins-999.
       pos-cnf-ins-300.
      *                  *---------------------------------------------*
      *                  * Aggiornamenti contabili generati dalla ge-  *
      *                  * stione portafoglio a fronte del movimento   *
      *                  * di accredito distinta in c/c                *
      *                  *---------------------------------------------*
           perform   cge-gep-acd-000      thru cge-gep-acd-999        .
       pos-cnf-ins-350.
      *                  *---------------------------------------------*
      *                  * Completamento del record distinte con i da- *
      *                  * ti relativi all'accredito distinta in c/c   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Data di sistema di ultimo inserimento o *
      *                      * modifica, utente, fase                  *
      *                      *-----------------------------------------*
           move      w-tes-ide-dat (1)    to   rf-ddp-ide-dat         .
           move      w-tes-ide-ute (1)    to   rf-ddp-ide-ute         .
           move      w-tes-ide-fas (1)    to   rf-ddp-ide-fas         .
      *                      *-----------------------------------------*
      *                      * Data registrazione movimento di accre-  *
      *                      * dito distinta in c/c                    *
      *                      *-----------------------------------------*
           move      w-tes-dat-reg        to   rf-ddp-dtr-acd         .
      *                      *-----------------------------------------*
      *                      * Data registrazione movimento di conta-  *
      *                      * bilita' a fronte del movimento di ac-   *
      *                      * credito distinta in c/c                 *
      *                      *-----------------------------------------*
           move      l-cge-300-dat-reg    to   rf-ddp-drc-acd         .
      *                      *-----------------------------------------*
      *                      * Numero protocollo movimento di conta-   *
      *                      * bilita' a fronte del movimento di ac-   *
      *                      * credito distinta in c/c                 *
      *                      *-----------------------------------------*
           move      l-cge-300-num-prt    to   rf-ddp-npc-acd         .
      *                      *-----------------------------------------*
      *                      * Data contabile bancaria per il movi-    *
      *                      * mento di accettazione distinta          *
      *                      *-----------------------------------------*
           move      w-tes-dcb-acd (1)    to   rf-ddp-dcb-acd         .
      *                      *-----------------------------------------*
      *                      * Numero contabile bancaria per il movi-  *
      *                      * mento di accredito distinta in c/c      *
      *                      *-----------------------------------------*
           move      w-tes-ncb-acd (1)    to   rf-ddp-ncb-acd         .
      *                      *-----------------------------------------*
      *                      * Importo spese addebitate dalla banca    *
      *                      * al momento dell'accredito distinta in   *
      *                      * c/c                                     *
      *                      *-----------------------------------------*
           move      w-tes-spe-acd (1)    to   rf-ddp-spe-acd         .
      *                      *-----------------------------------------*
      *                      * Importo interessi addebitati dalla ban- *
      *                      * ca al momento dell'accredito distinta   *
      *                      * in c/c                                  *
      *                      *-----------------------------------------*
           move      w-tes-int-acd (1)    to   rf-ddp-int-acd         .
       pos-cnf-ins-400.
      *                  *---------------------------------------------*
      *                  * Update record [ddp]                         *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddp                 .
       pos-cnf-ins-500.
      *                  *---------------------------------------------*
      *                  * Unlock record [ddp]                         *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddp                 .
       pos-cnf-ins-900.
      *                  *---------------------------------------------*
