      *    *===========================================================*
      *    * Accettazione presa visione per riga corpo espansa         *
      *    *-----------------------------------------------------------*
       acc-pvi-cor-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione prompt locale per l'accet-  *
      *                  * tazione                                     *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      78                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-pvi-cor-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *                                                 *
      *              * N.B. : Il tasto Remv e' stato qui inibito, in   *
      *              *        quanto il programma non ammette ne' in-  *
      *              *        serimenti di nuove righe, ne' cancella-  *
      *              *        zione di righe pre-esistenti             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      21                   to   v-lin                  .
           move      79                   to   v-pos                  .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      spaces               to   v-pfk (06)             .
           move      "EXPD"               to   v-pfk (12)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-pvi-cor-200.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-pvi-cor-999.
       acc-pvi-cor-250.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-pvi-cor-999.
       acc-pvi-cor-300.
      *              *-------------------------------------------------*
      *              * Se Expd                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "EXPD"
                     go to acc-pvi-cor-400.
      *                  *---------------------------------------------*
      *                  * Espansione su scadenze debitori             *
      *                  *---------------------------------------------*
           move      "N"                  to   w-esp-arc-sdb-sns      .
           move      w-rig-num-sdb (1)    to   w-esp-arc-sdb-num      .
           perform   esp-arc-sdb-000      thru esp-arc-sdb-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo ad accettazione                     *
      *                  *---------------------------------------------*
           go to     acc-pvi-cor-100.
       acc-pvi-cor-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-pvi-cor-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-pvi-cor-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
