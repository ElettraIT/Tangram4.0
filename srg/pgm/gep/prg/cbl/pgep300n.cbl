      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-nok-flg      .
       cnt-tdo-nok-100.
      *              *-------------------------------------------------*
      *              * Controlli                                       *
      *              *-------------------------------------------------*
       cnt-tdo-nok-150.
      *                  *---------------------------------------------*
      *                  * Controllo che l'importo accreditato non sia *
      *                  * negativo                                    *
      *                  *---------------------------------------------*
           move      w-tes-imp-ddp (1)    to   w-det-tot-acd          .
           subtract  w-tes-spe-acd (1)    from w-det-tot-acd          .
           subtract  w-tes-int-acd (1)    from w-det-tot-acd          .
           if        w-det-tot-acd        =    zero
                     go to cnt-tdo-nok-170
           else if   w-det-tot-acd        <    zero
                     go to cnt-tdo-nok-180
           else      go to cnt-tdo-nok-200.
       cnt-tdo-nok-170.
           move      "Importo accreditato pari a zero non ammesso !     
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-180.
           move      "Importo accreditato negativo non ammesso !        
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-200.
      *                  *---------------------------------------------*
      *                  * Controllo che non manchi il numero della    *
      *                  * contabile bancaria                          *
      *                  *---------------------------------------------*
