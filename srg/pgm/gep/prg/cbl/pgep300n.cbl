                     w-rig-sts-sca (1)    =    zero
                     move  "[2] "         to   v-pfk (16)
           else      move  spaces         to   v-pfk (16)             .
      *                      *-----------------------------------------*
      *                      * Pf3  : sempre ammesso, a meno che non   *
      *                      *        si sia in sola Visualizzazione,  *
      *                      *        o che lo status della scadenza   *
      *                      *        non indichi qualche anomalia     *
      *                      *-----------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "V" and
                     w-rig-sts-sca (1)    =    zero
                     move  "[3] "         to   v-pfk (17)
           else      move  spaces         to   v-pfk (17)             .
      *                      *-----------------------------------------*
      *                      * Pf4  : sempre ammesso, a meno che non   *
      *                      *        si sia in sola Visualizzazione,  *
      *                      *        o che lo status della scadenza   *
      *                      *        non indichi qualche anomalia     *
