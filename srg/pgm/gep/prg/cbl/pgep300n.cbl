                     go to cnt-tdo-nok-250.
           if        w-tes-ncb-acd (1)    not  = spaces
                     go to cnt-tdo-nok-250.
           move      "Manca il numero della contabile bancaria !        
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-250.
