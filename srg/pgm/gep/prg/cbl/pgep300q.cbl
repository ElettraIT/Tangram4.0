       cnt-tdo-key-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-key-flg      .
       cnt-tdo-key-999.
           exit.
           
      *    *===========================================================*
      *    * Controllo se chiave vuota                                 *
      *    *-----------------------------------------------------------*
       cnt-key-vuo-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-key-vuo-flg      .
       cnt-key-vuo-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazione tasto Do campi non chiave       *
      *    *-----------------------------------------------------------*
       cnt-tdo-nok-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-nok-flg      .
       cnt-tdo-nok-100.
      *              *-------------------------------------------------*
      *              * Controllo che non manchi il numero della conta- *
      *              * bile bancaria                                   *
      *              *-------------------------------------------------*
           if        w-tes-dcb-rsp (1)    =    zero
                     go to cnt-tdo-nok-200.
           if        w-tes-ncb-rsp (1)    not  = spaces
                     go to cnt-tdo-nok-200.
           move      "Manca il numero della contabile bancaria !        
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-200.
      *              *-------------------------------------------------*
      *              * Controllo su : Tipo nuova scadenza a fronte     *
      *              *                del richiamo                     *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to cnt-tdo-nok-400.
           if        w-prs-rie-mod-rie    =    02
                     go to cnt-tdo-nok-202.
           if        w-prs-rie-mod-rie    =    03 or
                     w-prs-rie-mod-rie    =    04
                     go to cnt-tdo-nok-400
           else if   w-tes-ens-rsp (1)    =    01
                     go to cnt-tdo-nok-202
           else      go to cnt-tdo-nok-400.
       cnt-tdo-nok-202.
           if        w-tes-tns-rsp (1)    not  = zero
                     go to cnt-tdo-nok-400.
           move      "Manca il tipo della nuova scadenza a fronte del ri
      -              "chiamo         "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-400.
      *              *-------------------------------------------------*
      *              * Fine controlli, normalizzazioni                 *
      *              *-------------------------------------------------*
       cnt-tdo-nok-500.
      *                  *---------------------------------------------*
      *                  * Numero contabile bancaria                   *
      *                  *---------------------------------------------*
           if        w-tes-dcb-rsp (1)    not  = zero
                     go to cnt-tdo-nok-525.
           move      spaces               to   w-tes-ncb-rsp (1)      .
       cnt-tdo-nok-525.
      *                  *---------------------------------------------*
      *                  * Si/No emissione nuova scadenza, e tipo sca- *
      *                  * denza a fronte del richiamo                 *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to cnt-tdo-nok-800.
       cnt-tdo-nok-550.
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda delle modalita' di *
      *                      * riemissione                             *
      *                      *-----------------------------------------*
           if        w-prs-rie-mod-rie    =    zero
                     go to cnt-tdo-nok-600
           else if   w-prs-rie-mod-rie    =    01
                     go to cnt-tdo-nok-610
           else if   w-prs-rie-mod-rie    =    02
                     go to cnt-tdo-nok-620
           else if   w-prs-rie-mod-rie    =    03
                     go to cnt-tdo-nok-630
           else if   w-prs-rie-mod-rie    =    04
                     go to cnt-tdo-nok-640
           else if   w-prs-rie-mod-rie    =    99
                     go to cnt-tdo-nok-690.
       cnt-tdo-nok-600.
      *                      *-----------------------------------------*
      *                      * Modalita' di riemissione : 00           *
      *                      *-----------------------------------------*
           if        w-tes-ens-rsp (1)    not  = 01
                     move  02             to   w-tes-ens-rsp (1)      .
           if        w-tes-ens-rsp (1)    not  = 01
                     move  zero           to   w-tes-tns-rsp (1)      .
           go to     cnt-tdo-nok-800.
       cnt-tdo-nok-610.
      *                      *-----------------------------------------*
      *                      * Modalita' di riemissione : 01           *
      *                      *-----------------------------------------*
           if        w-tes-ens-rsp (1)    =    01
                     go to cnt-tdo-nok-800.
           move      01                   to   w-tes-ens-rsp (1)      .
           move      01                   to   w-tes-tns-rsp (1)      .
           go to     cnt-tdo-nok-800.
       cnt-tdo-nok-620.
      *                      *-----------------------------------------*
      *                      * Modalita' di riemissione : 02           *
      *                      *-----------------------------------------*
           move      01                   to   w-tes-ens-rsp (1)      .
           go to     cnt-tdo-nok-800.
       cnt-tdo-nok-630.
      *                      *-----------------------------------------*
      *                      * Modalita' di riemissione : 03           *
      *                      *-----------------------------------------*
           move      01                   to   w-tes-ens-rsp (1)      .
           move      w-prs-rie-tip-sca    to   w-tes-tns-rsp (1)      .
           go to     cnt-tdo-nok-800.
       cnt-tdo-nok-640.
      *                      *-----------------------------------------*
      *                      * Modalita' di riemissione : 04           *
      *                      *-----------------------------------------*
           move      01                   to   w-tes-ens-rsp (1)      .
           move      w-prs-rie-tip-sca    to   w-tes-tns-rsp (1)      .
           go to     cnt-tdo-nok-800.
       cnt-tdo-nok-690.
      *                      *-----------------------------------------*
      *                      * Modalita' di riemissione : 99           *
      *                      *-----------------------------------------*
           move      02                   to   w-tes-ens-rsp (1)      .
           move      zero                 to   w-tes-tns-rsp (1)      .
           go to     cnt-tdo-nok-800.
       cnt-tdo-nok-800.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     cnt-tdo-nok-999.
       cnt-tdo-nok-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore                              *
      *              *-------------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *              *-------------------------------------------------*
      *              * Flag di uscita ad errore                        *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-tdo-nok-flg      .
       cnt-tdo-nok-999.
           exit.
           
      *    *===========================================================*
      *    * Normalizzazione dati chiave e non chiave                  *
      *    *-----------------------------------------------------------*
       nor-key-nok-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione dati chiave                     *
