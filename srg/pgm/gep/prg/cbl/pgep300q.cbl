      *    *===========================================================*
      *    * Lettura registrazione pre-esistente                       *
      *    *-----------------------------------------------------------*
       rou-let-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-rou-let-reg      .
      *              *-------------------------------------------------*
      *              * Normalizzazione work-area per appoggio a routi- *
      *              * ne di lettura registrazione                     *
      *              *-------------------------------------------------*
           move      spaces               to   w-app-rlr-xin-flg      .
           move      spaces               to   w-app-rlr-xin-msg      .
           move      spaces               to   w-app-rlr-xin-m02      .
           move      spaces               to   w-app-rlr-xin-m03      .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del valore del numero sca- *
      *              * denza                                           *
      *              *-------------------------------------------------*
           if        w-tes-num-sca        =    zero
                     go to rou-let-reg-025
           else      go to rou-let-reg-050.
       rou-let-reg-025.
      *              *-------------------------------------------------*
      *              * Se numero scadenza a zero                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "Manca il numero scadenza da richiamare            
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Status di uscita ad errore                  *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-rou-let-reg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     rou-let-reg-999.
       rou-let-reg-050.
      *              *-------------------------------------------------*
      *              * Se numero scadenza diverso da zero              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura scadenza da [sdb]                   *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMSDB    "         to   f-key                  .
           move      w-tes-num-sca        to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'esito della let-  *
      *                  * tura                                        *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to rou-let-reg-100.
       rou-let-reg-075.
      *                  *---------------------------------------------*
      *                  * Se record non esistente                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Scadenza non esistente in archivio                
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Status di uscita ad errore              *
      *                      *-----------------------------------------*
           move      "#"                  to   w-cnt-rou-let-reg      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rou-let-reg-999.
       rou-let-reg-100.
      *                  *---------------------------------------------*
      *                  * Se record esistente                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Distribuzione dati da record [sdb] a    *
      *                      * work per testata                        *
      *                      *-----------------------------------------*
           perform   dda-sdb-wte-000      thru dda-sdb-wte-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione se la scadenza trattata  *
      *                      * aveva prodotto oppure no un aggiorna-   *
      *                      * mento contabile al momento dell'emis-   *
      *                      * sione                                   *
      *                      *-----------------------------------------*
           move      w-tes-tip-sdb (1)    to   w-det-agg-emi-tsc      .
           move      w-tes-tac-sdb (1)    to   w-det-agg-emi-tas      .
           move      w-tes-drc-emi (1)    to   w-det-agg-emi-drc
           move      w-tes-npc-emi (1)    to   w-det-agg-emi-npc
           perform   det-agg-emi-000      thru det-agg-emi-999        .
       rou-let-reg-150.
      *                      *-----------------------------------------*
      *                      * Controllo che la scadenza non abbia a-  *
      *                      * vuto movimenti precedenti a quello di   *
      *                      * inclusione in distinta di presentazione *
      *                      * che impediscano l'operazione in atto.   *
      *                      * Se anomalie : preparazione del flag e   *
      *                      * del messaggio per 'Inserimento non pos- *
      *                      * sibile                                  *
      *                      *-----------------------------------------*
       rou-let-reg-155.
      *                          *-------------------------------------*
      *                          * Test su storno scadenza             *
      *                          *-------------------------------------*
           if        w-tes-dtr-sto (1)    =    zero
                     go to rou-let-reg-160.
           if        w-app-rlr-xin-flg    not  = spaces
                     go to rou-let-reg-160.
           move      "#"                  to   w-app-rlr-xin-flg      .
           move      "Attenzione : La scadenza e' gia' stata stornata.  
      -              "               "    to   w-app-rlr-xin-msg      .
           move      "             Pertanto l'operazione di richiamo non
      -              " e' ammessa.   "    to   w-app-rlr-xin-m02      .
       rou-let-reg-160.
      *                          *-------------------------------------*
      *                          * Test su riscossione scadenza        *
      *                          *-------------------------------------*
           if        w-tes-dtr-ris (1)    =    zero
                     go to rou-let-reg-200.
           if        w-app-rlr-xin-flg    not  = spaces
                     go to rou-let-reg-200.
           move      "#"                  to   w-app-rlr-xin-flg      .
      *                              *---------------------------------*
      *                              * Deviazione a seconda della mo-  *
      *                              * dalita' di riscossione          *
      *                              *---------------------------------*
           if        w-tes-mod-ris (1)    =    01 or
                     w-tes-mod-ris (1)    =    02 or
                     w-tes-mod-ris (1)    =    03 or
                     w-tes-mod-ris (1)    =    04
                     go to rou-let-reg-162
           else if   w-tes-mod-ris (1)    =    21 or
                     w-tes-mod-ris (1)    =    22 or
                     w-tes-mod-ris (1)    =    23 or
                     w-tes-mod-ris (1)    =    24
                     go to rou-let-reg-164
           else if   w-tes-mod-ris (1)    =    50
                     go to rou-let-reg-166.
       rou-let-reg-162.
      *                              *---------------------------------*
      *                              * Modalita' di riscossione : Ri-  *
      *                              * scossione                       *
      *                              *---------------------------------*
           move      "Attenzione : La scadenza e' gia' stata riscossa.  
      -              "               "    to   w-app-rlr-xin-msg      .
           move      "             Pertanto l'operazione di richiamo non
      -              " e' ammessa.   "    to   w-app-rlr-xin-m02      .
           go to     rou-let-reg-200.
       rou-let-reg-164.
      *                              *---------------------------------*
      *                              * Modalita' di riscossione : Pa-  *
      *                              * gamento                         *
      *                              *---------------------------------*
           move      "Attenzione : La scadenza e' gia' stata pagata.    
      -              "               "    to   w-app-rlr-xin-msg      .
           move      "             Pertanto l'operazione di richiamo non
      -              " e' ammessa.   "    to   w-app-rlr-xin-m02      .
           go to     rou-let-reg-200.
       rou-let-reg-166.
      *                              *---------------------------------*
      *                              * Modalita' di riscossione : Com- *
      *                              * pensazione                      *
      *                              *---------------------------------*
           move      "Attenzione : La scadenza e' gia' stata compensata.
      -              "               "    to   w-app-rlr-xin-msg      .
           move      "             Pertanto l'operazione di richiamo non
      -              " e' ammessa.   "    to   w-app-rlr-xin-m02      .
           go to     rou-let-reg-200.
       rou-let-reg-200.
      *                      *-----------------------------------------*
      *                      * Controllo che la scadenza sia gia' sta- *
      *                      * ta inclusa in una distinta di presenta- *
      *                      * zione                                   *
      *                      *-----------------------------------------*
       rou-let-reg-202.
      *                          *-------------------------------------*
      *                          * Controllo                           *
      *                          *-------------------------------------*
           if        w-tes-num-ddp (1)    not  = zero
                     go to rou-let-reg-210.
       rou-let-reg-204.
      *                          *-------------------------------------*
      *                          * Se la scadenza non e' mai stata in- *
      *                          * clusa in una distinta               *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Preparazione del flag e del     *
      *                              * messaggio per 'Inserimento non  *
      *                              * possibile'                      *
      *                              *---------------------------------*
           if        w-app-rlr-xin-flg    not  = spaces
                     go to rou-let-reg-206.
           move      "#"                  to   w-app-rlr-xin-flg      .
           move      "Attenzione : La scadenza non e' mai stata inclusa 
      -              "in una         "    to   w-app-rlr-xin-msg      .
           move      "             distinta di presentazione.           
      -              "               "    to   w-app-rlr-xin-m02      .
           move      "             Pertanto l'operazione di richiamo non
      -              " e' ammessa.   "    to   w-app-rlr-xin-m03      .
       rou-let-reg-206.
      *                              *---------------------------------*
      *                              * Normalizzazione work area per   *
      *                              * bufferizzazione distinta        *
      *                              *---------------------------------*
           perform   nor-war-ddp-000      thru nor-war-ddp-999        .
      *                              *---------------------------------*
      *                              * Continuazione a dopo lettura    *
      *                              * e bufferizzazione distinta      *
      *                              *---------------------------------*
           go to     rou-let-reg-250.
       rou-let-reg-210.
      *                      *-----------------------------------------*
      *                      * Lettura della distinta di presentazione *
      *                      * in cui la scadenza e' stata inclusa.    *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMDDP    "         to   f-key                  .
           move      w-tes-num-ddp (1)    to   rf-ddp-num-ddp         .
           move      "pgm/gep/fls/ioc/obj/iofddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddp                 .
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda dell'esito della   *
      *                      * lettura                                 *
