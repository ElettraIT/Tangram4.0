      *                      * mento di richiamo                       *
      *                      *-----------------------------------------*
           move      w-tes-ncb-rsp (1)    to   rf-sdb-ncb-rsp         .
      *                      *-----------------------------------------*
      *                      * Importo spese addebitate dalla banca al *
      *                      * momento del richiamo                    *
      *                      *-----------------------------------------*
           move      w-tes-spe-rsp (1)    to   rf-sdb-spe-rsp         .
      *                      *-----------------------------------------*
      *                      * Segnale di si/no emissione nuova sca-   *
      *                      * denza a fronte del richiamo provviso-   *
      *                      * riamente a No, aggiornato eventualmente *
      *                      * dall'emissione semi-automatica          *
      *                      *-----------------------------------------*
           move      02                   to   rf-sdb-ens-rsp         .
      *                      *-----------------------------------------*
      *                      * Numero nuova scadenza a fronte del ri-  *
      *                      * chiamo                                  *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sdb-nns-rsp         .
      *                      *-----------------------------------------*
      *                      * Tipo nuova scadenza a fronte del ri-    *
      *                      * chiamo                                  *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sdb-tns-rsp         .
      *                      *-----------------------------------------*
      *                      * Data chiusura scadenza                  *
      *                      *-----------------------------------------*
           perform   det-dat-chs-000      thru det-dat-chs-999        .
       pos-cnf-ins-500.
      *                  *---------------------------------------------*
      *                  * Update record [sdb]                         *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
       pos-cnf-ins-600.
      *                  *---------------------------------------------*
      *                  * Unlock record [sdb]                         *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
       pos-cnf-ins-700.
      *                  *---------------------------------------------*
      *                  * Preparazione del tipo uscita adeguato per   *
      *                  * il caso di richiesta di emissione di nuova  *
      *                  * scadenza a fronte del richiamo              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se non richiesta emissione nuova sca-   *
      *                      * denza : nessuna preparazione            *
      *                      *-----------------------------------------*
           if        w-tes-ens-rsp (1)    not  = 01
                     go to pos-cnf-ins-999.
      *                      *-----------------------------------------*
      *                      * Se richiesta emissione nuova scadenza   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Flag di richiesta emissione nuova   *
      *                          * scadenza a fronte dell'operazione   *
      *                          * appena completata                   *
      *                          *-------------------------------------*
           move      "#"                  to   w-key-ric-ens          .
      *                          *-------------------------------------*
      *                          * Data registrazione per nuova sca-   *
      *                          * denza da emettere                   *
      *                          *-------------------------------------*
           move      w-key-dat-reg        to   w-key-dtr-ens          .
      *                          *-------------------------------------*
      *                          * Tipo nuova scadenza da emettere     *
      *                          *-------------------------------------*
           move      w-tes-tns-rsp (1)    to   w-key-tns-ens          .
      *                          *-------------------------------------*
      *                          * Importo della nuova scadenza        *
      *                          *-------------------------------------*
           move      w-tes-imp-sdb (1)    to   w-key-imp-ens          .
      *                          *-------------------------------------*
      *                          * Si/No data scadenza forzata e data  *
      *                          * scadenza stessa da forzare          *
      *                          *-------------------------------------*
           perform   fds-dts-ens-000      thru fds-dts-ens-999        .
      *                          *-------------------------------------*
      *                          * Si/No forzatura riemissione         *
      *                          *-------------------------------------*
           perform   snx-frz-ens-000      thru snx-frz-ens-999        .
      *                          *-------------------------------------*
      *                          * Numero della scadenza a fronte del- *
      *                          * la quale deve essere emessa la nuo- *
      *                          * va scadenza                         *
      *                          *-------------------------------------*
           move      w-tes-num-sdb (1)    to   w-key-nvs-ens          .
      *                          *-------------------------------------*
      *                          * Tipo operazione che ha causato la   *
      *                          * richiesta di emissione della nuova  *
      *                          * scadenza                            *
      *                          *-------------------------------------*
           move      0620                 to   w-key-tvo-ens          .
       pos-cnf-ins-999.
           exit.

      *    *===========================================================*
      *    * Determinazione Si/No forzatura movimento di riemissione   *
      *    *-----------------------------------------------------------*
       snx-frz-ens-000.
      *              *-------------------------------------------------*
      *              * Se modalita' di riemissione pari a :            *
      *              *  - 01                                           *
      *              *  - 02                                           *
      *              *  - 03                                           *
      *              *  - 04                                           *
      *              * si forza la riemissione, altrimenti no          *
      *              *-------------------------------------------------*
           if        w-prs-rie-mod-rie    =    01 or
                     w-prs-rie-mod-rie    =    02 or
                     w-prs-rie-mod-rie    =    03 or
                     w-prs-rie-mod-rie    =    04
                     move  "#"            to   w-key-frz-ens
           else      move  spaces         to   w-key-frz-ens          .
       snx-frz-ens-999.
           exit.

      *    *===========================================================*
      *    * Determinazione Si/No data scadenza forzata e data scaden- *
      *    * za stessa da forzare in caso di riemissione a fronte      *
      *    *-----------------------------------------------------------*
       fds-dts-ens-000.
      *              *-------------------------------------------------*
      *              * Se le personalizzazioni sulle modalita' di rie- *
      *              * missione non indicano la forzatura della data   *
      *              * di scadenza si esce con No                      *
      *              *-------------------------------------------------*
           if        w-prs-rie-mod-rie    not  = 04
                     move  "N"            to   w-key-fds-ens
                     move  zero           to   w-key-dts-ens
                     go to fds-dts-ens-999.
       fds-dts-ens-100.
      *              *-------------------------------------------------*
      *              * Si/No data scadenza forzata : Si                *
      *              * missione non indicano la forzatura della data   *
      *              * di scadenza si esce con No                      *
      *              *-------------------------------------------------*
           move      "S"                  to   w-key-fds-ens          .
       fds-dts-ens-200.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda della personalizzazione    *
      *              * sulla data scadenza forzata per la riemissione  *
      *              *-------------------------------------------------*
           if        w-prs-rie-ind-sds    =    "AV"
                     go to fds-dts-ens-300
           else if   w-prs-rie-ind-sds    =    "SD"
                     go to fds-dts-ens-400
           else if   w-prs-rie-ind-sds    =    "FM"
                     go to fds-dts-ens-500
           else if   w-prs-rie-ind-sds    =    "+1"
                     go to fds-dts-ens-600
           else      go to fds-dts-ens-400.
       fds-dts-ens-300.
      *              *-------------------------------------------------*
      *              * Se : A vista                                    *
      *              *-------------------------------------------------*
           move      zero                 to   w-key-dts-ens          .
           go to     fds-dts-ens-999.
       fds-dts-ens-400.
      *              *-------------------------------------------------*
      *              * Se : Stessa data                                *
      *              *-------------------------------------------------*
           move      w-tes-dts-sdb (1)    to   w-key-dts-ens          .
           go to     fds-dts-ens-999.
       fds-dts-ens-500.
      *              *-------------------------------------------------*
      *              * Se : Stessa data ma a fine mese                 *
      *              *-------------------------------------------------*
           move      "CD"                 to   s-ope                  .
           move      w-tes-dts-sdb (1)    to   s-dat                  .
           add       1                    to   s-gio                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                =    spaces
                     go to fds-dts-ens-510
           else      go to fds-dts-ens-600.
       fds-dts-ens-510.
           move      "CD"                 to   s-ope                  .
           move      w-tes-dts-sdb (1)    to   s-dat                  .
           move      31                   to   s-gio                  .
       fds-dts-ens-520.
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                =    spaces
                     go to fds-dts-ens-530.
           move      "CD"                 to   s-ope                  .
           subtract  1                    from s-gio                  .
           go to     fds-dts-ens-520.
       fds-dts-ens-530.
           move      s-dat                to   w-key-dts-ens          .
           go to     fds-dts-ens-999.
       fds-dts-ens-600.
      *              *-------------------------------------------------*
      *              * Se : Un mese dopo la data di scadenza           *
      *              *-------------------------------------------------*
           move      "CD"                 to   s-ope                  .
           move      w-tes-dts-sdb (1)    to   s-dat                  .
           if        s-mes                =    12
                     move  01             to   s-mes
                     add   01             to   s-ann
           else      add   01             to   s-mes                  .
       fds-dts-ens-610.
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                =    spaces
                     go to fds-dts-ens-620.
           move      "CD"                 to   s-ope                  .
           subtract  1                    from s-gio                  .
           go to     fds-dts-ens-610.
       fds-dts-ens-620.
           move      s-dat                to   w-key-dts-ens          .
           go to     fds-dts-ens-999.
       fds-dts-ens-999.
           exit.

