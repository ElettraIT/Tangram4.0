      *    *===========================================================*
      *    * Routine post-conferma di modifica                         *
      *    *-----------------------------------------------------------*
       pos-cnf-mod-000.
      *              *-------------------------------------------------*
      *              * Determinazione del tipo di modifica intervenuta *
      *              * nell'operazione di richiamo e dei relativi      *
      *              * flags indicatori                                *
      *              *-------------------------------------------------*
           perform   det-mod-rsp-000      thru det-mod-rsp-999        .
      *              *-------------------------------------------------*
      *              * Se il tipo di modifica non comporta alcuna va-  *
      *              * riazione : uscita                               *
      *              *-------------------------------------------------*
           if        w-mod-rsp-rec-sdb    =    spaces and
                     w-mod-rsp-cge-gep    =    spaces
                     go to pos-cnf-mod-999.
       pos-cnf-mod-100.
      *              *-------------------------------------------------*
      *              * Lettura record [sdb] con lock                   *
      *              *-------------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMSDB    "         to   f-key                  .
           move      w-tes-num-sdb (1)    to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to pos-cnf-mod-300.
       pos-cnf-mod-200.
      *              *-------------------------------------------------*
      *              * Se record [sdb] non esistente                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   e01-cnf-mod-000      thru e01-cnf-mod-999        .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     pos-cnf-mod-999.
       pos-cnf-mod-300.
      *              *-------------------------------------------------*
      *              * Se record [sdb] esistente                       *
      *              *-------------------------------------------------*
       pos-cnf-mod-350.
      *                  *---------------------------------------------*
      *                  * Controllo che la scadenza non sia nel frat- *
      *                  * tempo stata variata                         *
      *                  *---------------------------------------------*
           if        rf-sdb-dtr-emi       not  = w-tes-dtr-emi (1) or
                     rf-sdb-drc-emi       not  = w-tes-drc-emi (1) or
                     rf-sdb-npc-emi       not  = w-tes-npc-emi (1) or
                     rf-sdb-prt-fcl       not  = w-tes-prt-fcl (1) or
                     rf-sdb-nsc-org       not  = w-tes-nsc-org (1) or
                     rf-sdb-cod-age       not  = w-tes-cod-age (1) or
                     rf-sdb-tip-sdb       not  = w-tes-tip-sdb (1) or
                     rf-sdb-snx-dlc       not  = w-tes-snx-dlc (1) or
                     rf-sdb-tac-sdb       not  = w-tes-tac-sdb (1) or
                     rf-sdb-tvl-sdb       not  = w-tes-tvl-sdb (1) or
                     rf-sdb-dts-sdb       not  = w-tes-dts-sdb (1) or
                     rf-sdb-tip-dbt       not  = w-tes-tip-dbt (1) or
                     rf-sdb-cod-dbt       not  = w-tes-cod-dbt (1) or
                     rf-sdb-dpz-dbt       not  = w-tes-dpz-dbt (1) or
                     rf-sdb-inl-sdb       not  = w-tes-inl-sdb (1) or
                     rf-sdb-sgl-vlt       not  = w-tes-sgl-vlt (1) or
                     rf-sdb-dec-vlt       not  = w-tes-dec-vlt (1) or
                     rf-sdb-tdc-vlt       not  = w-tes-tdc-vlt (1) or
                     rf-sdb-cdc-sdb       not  = w-tes-cdc-sdb (1) or
                     rf-sdb-iiv-sdb       not  = w-tes-iiv-sdb (1) or
                     rf-sdb-imp-sdb       not  = w-tes-imp-sdb (1) or
                     rf-sdb-dat-ddr       not  = w-tes-dat-ddr (1) or
                     rf-sdb-num-ddr       not  = w-tes-num-ddr (1) or
