      *                  * Deviazione a seconda delle personalizzazio- *
      *                  * zioni sulle modalita' di riemissione        *
      *                  *---------------------------------------------*
           if        w-prs-rie-mod-rie    =    02
                     go to vis-tns-rsp-650
           else if   w-prs-rie-mod-rie    =    03 or
                     w-prs-rie-mod-rie    =    04 or
                     w-prs-rie-mod-rie    =    99
                     go to vis-tns-rsp-700
           else      go to vis-tns-rsp-600.
       vis-tns-rsp-600.
      *                  *---------------------------------------------*
      *                  * Se trattamento standard                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-sdb-lun    to   v-car                  .
           move      w-exp-tip-sdb-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-tip-sdb-tbl    to   v-txt                  .
           move      19                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-tns-rsp (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     vis-tns-rsp-999.
       vis-tns-rsp-650.
      *                  *---------------------------------------------*
      *                  * Se trattamento solo del tipo scadenza, sen- *
      *                  * za richiesta di si/no riemissione           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-sdb-lun    to   v-car                  .
           move      w-exp-tip-sdb-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-tip-sdb-tbl    to   v-txt                  .
           move      16                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-tns-rsp (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     vis-tns-rsp-999.
       vis-tns-rsp-700.
