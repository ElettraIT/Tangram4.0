                     move  0502           to   w-det-agg-pre-wop
           else if   w-det-agg-pre-tdp    =    03
                     move  0503           to   w-det-agg-pre-wop
           else if   w-det-agg-pre-tdp    =    04
                     move  0504           to   w-det-agg-pre-wop
