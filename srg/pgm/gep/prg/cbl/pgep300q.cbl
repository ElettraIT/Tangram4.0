      *    *===========================================================*
      *    * Accettazione campo : Tipo nuova scadenza a fronte del     *
      *    *                      richiamo                             *
      *    *-----------------------------------------------------------*
       acc-tns-rsp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-tns-rsp-010.
      *                  *---------------------------------------------*
      *                  * Se non si e' in Inserimento : non si esegue *
      *                  * l'accettazione                              *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-tns-rsp-999.
       acc-tns-rsp-020.
      *                  *---------------------------------------------*
      *                  * Se le personalizzazioni sulle modalita' di  *
      *                  * riemissione indicano un automatismo relati- *
      *                  * vo a questo campo, e si e' in Inserimento,  *
      *                  * si esegue l'automatismo e si esce           *
      *                  *---------------------------------------------*
           if        w-prs-rie-mod-rie    =    03 or
                     w-prs-rie-mod-rie    =    04
                     move  w-prs-rie-tip-sca
                                          to   w-tes-tns-rsp (1)
                     go to acc-tns-rsp-999.
           if        w-prs-rie-mod-rie    =    99
                     move  zero           to   w-tes-tns-rsp (1)
                     go to acc-tns-rsp-999.
       acc-tns-rsp-030.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-rie-mod-rie    =    03 or
                     w-prs-rie-mod-rie    =    04 or
                     w-prs-rie-mod-rie    =    99
                     go to acc-tns-rsp-999.
           if        w-tes-ens-rsp (1)    not  = 01
                     go to acc-tns-rsp-999.
       acc-tns-rsp-040.
      *                  *---------------------------------------------*
      *                  * Eventuale preparazione del valore di de-    *
      *                  * fault                                       *
      *                  *---------------------------------------------*
           if        w-prs-rie-tip-sca    not  = zero
                     move  w-prs-rie-tip-sca
                                          to   w-tes-tns-rsp (1)      .
       acc-tns-rsp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-sdb-lun    to   v-car                  .
           move      w-exp-tip-sdb-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-tip-sdb-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           if        w-prs-rie-mod-rie    =    02
                     move  16             to   v-lin
           else      move  19             to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-tns-rsp (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-tns-rsp-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-tns-rsp-999.
       acc-tns-rsp-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-tns-rsp (1)      .
       acc-tns-rsp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-tns-rsp-425.
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-tes-tns-rsp (1)    >    w-exp-tip-sdb-num
                     go to acc-tns-rsp-100.
       acc-tns-rsp-450.
      *                  *---------------------------------------------*
      *                  * Se valore mancante : reimpostazione, a meno *
      *                  * che non si sia in Up                        *
      *                  *---------------------------------------------*
           if        w-tes-tns-rsp (1)    not  = zero
                     go to acc-tns-rsp-475.
           if        v-key                not  = "UP  "
                     go to acc-tns-rsp-100.
       acc-tns-rsp-475.
      *                  *---------------------------------------------*
      *                  * Se non esiste il tipo operazione di emis-   *
      *                  * sione corrispondente al tipo della scaden-  *
      *                  * za : reimpostazione                         *
      *                  *---------------------------------------------*
           if        w-tes-tns-rsp (1)    =    01
                     move  0101           to   w-acc-tns-rsp-v01
           else if   w-tes-tns-rsp (1)    =    02
                     move  0102           to   w-acc-tns-rsp-v01
           else if   w-tes-tns-rsp (1)    =    03
                     move  0103           to   w-acc-tns-rsp-v01
           else if   w-tes-tns-rsp (1)    =    04
                     move  0104           to   w-acc-tns-rsp-v01
           else if   w-tes-tns-rsp (1)    =    05
                     move  0105           to   w-acc-tns-rsp-v01
           else if   w-tes-tns-rsp (1)    =    06
                     move  0106           to   w-acc-tns-rsp-v01
           else if   w-tes-tns-rsp (1)    =    07
                     move  0107           to   w-acc-tns-rsp-v01
           else if   w-tes-tns-rsp (1)    =    08
                     move  0108           to   w-acc-tns-rsp-v01
           else if   w-tes-tns-rsp (1)    =    09
                     move  0109           to   w-acc-tns-rsp-v01
           else if   w-tes-tns-rsp (1)    =    10
                     move  0110           to   w-acc-tns-rsp-v01
           else if   w-tes-tns-rsp (1)    =    11
                     move  0111           to   w-acc-tns-rsp-v01
           else      go to acc-tns-rsp-100.
           move      zero                 to   w-acc-tns-rsp-i01      .
       acc-tns-rsp-477.
           add       1                    to   w-acc-tns-rsp-i01      .
           if        w-acc-tns-rsp-i01    >    w-top-ele-num
                     go to acc-tns-rsp-100.
           if        w-top-cod-top
                    (w-acc-tns-rsp-i01)   not  = w-acc-tns-rsp-v01
                     go to acc-tns-rsp-477.
       acc-tns-rsp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-tns-rsp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-tns-rsp-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-tns-rsp-100.
       acc-tns-rsp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Tipo nuova scadenza a fronte del- *
      *    *                         l'insoluto                        *
      *    *-----------------------------------------------------------*
       vis-tns-rsp-000.
      *              *-------------------------------------------------*
