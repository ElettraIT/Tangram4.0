           move      w-tes-npc-rsd (1)    to   rf-rsd-npc-rsd         .
           move      w-tes-num-rsd        to   rf-rsd-num-rsd         .
           move      w-tes-tip-rsd (1)    to   rf-rsd-tip-rsd         .
           move      w-tes-mod-rsd (1)    to   rf-rsd-mod-rsd         .
           move      w-tes-tvl-rsd (1)    to   rf-rsd-tvl-rsd         .
