      *    *-----------------------------------------------------------*
       pos-rig-cor-000.
      *              *-------------------------------------------------*
      *              * Trattamento totale scadenze selezionate         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Controaggiornamento                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo opera-  *
      *                      * zione                                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        =    0301 or
                     w-tes-tip-ope        =    0302 or
                     w-tes-tip-ope        =    0303 or
                     w-tes-tip-ope        =    0304
                     go to pos-rig-cor-020
           else if   w-tes-tip-ope        =    0321 or
                     w-tes-tip-ope        =    0322 or
                     w-tes-tip-ope        =    0323 or
                     w-tes-tip-ope        =    0324
                     go to pos-rig-cor-040
           else if   w-tes-tip-ope        =    0350
                     go to pos-rig-cor-060.
       pos-rig-cor-020.
      *                      *-----------------------------------------*
      *                      * Tipo operazione : Riscossione           *
      *                      *-----------------------------------------*
           subtract  w-srp-imp-ris        from w-tes-tot-scs (1)      .
           go to     pos-rig-cor-100.
       pos-rig-cor-040.
      *                      *-----------------------------------------*
      *                      * Tipo operazione : Pagamento             *
      *                      *-----------------------------------------*
           add       w-srp-imp-ris        to   w-tes-tot-scs (1)      .
           go to     pos-rig-cor-100.
       pos-rig-cor-060.
      *                      *-----------------------------------------*
      *                      * Tipo operazione : Compensazione         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se riga New : nessun controaggior-  *
      *                          * namento                             *
      *                          *-------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to pos-rig-cor-100.
      *                          *-------------------------------------*
      *                          * Esecuzione controaggiornamento      *
      *                          *-------------------------------------*
           add       w-rig-imp-sdb (1)    to   w-tes-tot-scs (1)      .
           subtract  w-srp-imp-ris        from w-tes-tot-scs (1)      .
           go to     pos-rig-cor-100.
       pos-rig-cor-100.
      *                  *---------------------------------------------*
      *                  * Aggiornamento, se necessario                *
      *                  *---------------------------------------------*
           if        w-cnt-cor-tip-agg    not  = "+"
                     go to pos-rig-cor-200.
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo opera-  *
      *                      * zione                                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        =    0301 or
                     w-tes-tip-ope        =    0302 or
                     w-tes-tip-ope        =    0303 or
                     w-tes-tip-ope        =    0304
                     go to pos-rig-cor-120
           else if   w-tes-tip-ope        =    0321 or
                     w-tes-tip-ope        =    0322 or
                     w-tes-tip-ope        =    0323 or
                     w-tes-tip-ope        =    0324
                     go to pos-rig-cor-140
           else if   w-tes-tip-ope        =    0350
                     go to pos-rig-cor-160.
       pos-rig-cor-120.
      *                      *-----------------------------------------*
      *                      * Tipo operazione : Riscossione           *
      *                      *-----------------------------------------*
           add       w-rig-imp-ris (1)    to   w-tes-tot-scs (1)      .
           go to     pos-rig-cor-200.
       pos-rig-cor-140.
      *                      *-----------------------------------------*
      *                      * Tipo operazione : Pagamento             *
      *                      *-----------------------------------------*
           subtract  w-rig-imp-ris (1)    from w-tes-tot-scs (1)      .
           go to     pos-rig-cor-200.
       pos-rig-cor-160.
      *                      *-----------------------------------------*
      *                      * Tipo operazione : Compensazione         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se riga New : nessun aggiornamento  *
      *                          *-------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to pos-rig-cor-200.
      *                          *-------------------------------------*
      *                          * Esecuzione aggiornamento            *
      *                          *-------------------------------------*
           subtract  w-rig-imp-sdb (1)    from w-tes-tot-scs (1)      .
           add       w-rig-imp-ris (1)    to   w-tes-tot-scs (1)      .
           go to     pos-rig-cor-200.
       pos-rig-cor-200.
      *                  *---------------------------------------------*
