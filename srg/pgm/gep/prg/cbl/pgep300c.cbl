           move      w-tes-ddo-rsd (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dat-ass-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Numero assegno                       *
      *    *-----------------------------------------------------------*
       acc-num-ass-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Next Screen da campi precedenti          *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-num-ass-400.
       acc-num-ass-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      20                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-ndo-rsd (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-num-ass-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-num-ass-999.
       acc-num-ass-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-ndo-rsd (1)      .
       acc-num-ass-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se valore obbligatorio                 *
      *                  *---------------------------------------------*
           if        w-tes-ndo-rsd (1)    not  = spaces
                     go to acc-num-ass-600.
           if        v-key                =    "UP  "
                     go to acc-num-ass-600.
           if        w-tes-ddo-rsd (1)    not  = zero
                     go to acc-num-ass-100.
       acc-num-ass-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Trattamento data documento                  *
      *                  *---------------------------------------------*
           if        w-tes-ndo-rsd (1)    not  = spaces and
                     w-tes-ddo-rsd (1)    =    zero
                     move  w-tes-dat-reg  to   w-tes-ddo-rsd (1)
                     perform vis-dat-ass-000
                                          thru vis-dat-ass-999        .
       acc-num-ass-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-num-ass-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-num-ass-100.
       acc-num-ass-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Numero assegno                    *
      *    *-----------------------------------------------------------*
       vis-num-ass-000.
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-ndo-rsd (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-num-ass-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Presa visione per pagina 1   *
      *    *-----------------------------------------------------------*
       acc-pre-vp1-000.
      *              *-------------------------------------------------*
      *              * Controllo su impostazioni pagina testata nr. 1  *
      *              *-------------------------------------------------*
           perform   cnt-imp-pt1-000      thru cnt-imp-pt1-999        .
      *              *-------------------------------------------------*
      *              * Se controllo non superato : si esce forzando il *
      *              * tasto Up                                        *
      *              *-------------------------------------------------*
           if        w-cnt-imp-pt1-flg    not  = spaces
                     move  "UP  "         to   v-key
                     go to acc-pre-vp1-999.
      *              *-------------------------------------------------*
      *              * Se tipo riscossione Anticipo : oltre            *
      *              *-------------------------------------------------*
           if        w-tes-tip-rsd (1)    =    02
                     go to acc-pre-vp1-300.
      *              *-------------------------------------------------*
      *              * Se Next Screen si salta l'accettazione caratte- *
      *              * re di presa visione                             *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-pre-vp1-200.
       acc-pre-vp1-100.
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      spaces               to   v-msk                  .
           move      spaces               to   v-alf                  .
           move      spaces               to   v-not                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           if        w-cnt-sts-imp-npt    >    1
                     move  "PRSC"         to   v-pfk (07)             .
           move      "NXSC"               to   v-pfk (08)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vp1-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vp1-999.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-pre-vp1-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pre-vp1-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pre-vp1-000.
       acc-pre-vp1-200.
      *              *-------------------------------------------------*
      *              * Se tipo funzionamento diverso da Inserimento,   *
      *              * oltre                                           *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-pre-vp1-300.
      *              *-------------------------------------------------*
      *              * Se pagina di testata gia' impostata : oltre     *
      *              *-------------------------------------------------*
           if        w-tes-fda-pt1 (1)    not  = spaces
                     go to acc-pre-vp1-300.
      *              *-------------------------------------------------*
      *              * Caricamento dei buffer scadenze debitori        *
      *              *-------------------------------------------------*
           perform   car-buf-sdb-000      thru car-buf-sdb-999        .
      *              *-------------------------------------------------*
      *              * Se esito caricamento negativo : si esce forzan- *
      *              * do il tasto Up                                  *
      *              *-------------------------------------------------*
           if        w-car-buf-sdb-flg    not  = spaces
                     move  "UP  "         to   v-key
                     go to acc-pre-vp1-999.
      *              *-------------------------------------------------*
      *              * Se zero elementi nel buffer : uscita            *
      *              *-------------------------------------------------*
           if        w-bsu-num-ele        =    zero and
                     w-bst-num-ele        =    zero
                     move  "UP  "         to   v-key
                     go to acc-pre-vp1-999.
      *              *-------------------------------------------------*
      *              * Se tipo operazione NON di Compensazione : oltre *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        not  = 0350
                     go to acc-pre-vp1-300.
      *              *-------------------------------------------------*
      *              * Determinazione buffer scadenze debitore di la-  *
      *              * voro                                            *
      *              *-------------------------------------------------*
           perform   det-buf-sdb-000      thru det-buf-sdb-999        .
      *              *-------------------------------------------------*
      *              * Se esito determinazione negativo : si esce for- *
      *              * zando il tasto Up                               *
      *              *-------------------------------------------------*
           if        w-det-buf-sdb-flg    not  = spaces
                     move  "UP  "         to   v-key
                     go to acc-pre-vp1-999.
      *              *-------------------------------------------------*
      *              * Caricamento catena scadenze debitori            *
      *              *-------------------------------------------------*
           perform   car-cat-sdb-000      thru car-cat-sdb-999        .
      *              *-------------------------------------------------*
      *              * Se esito caricamento negativo : si esce forzan- *
      *              * do il tasto Up                                  *
      *              *-------------------------------------------------*
           if        w-car-cat-sdb-flg    not  = spaces
                     move  "UP  "         to   v-key
                     go to acc-pre-vp1-999.
       acc-pre-vp1-300.
      *              *-------------------------------------------------*
      *              * Attivazione flag di impostazione pagina testata *
      *              *-------------------------------------------------*
           move      "#"                  to   w-tes-fda-pt1 (1)      .
      *              *-------------------------------------------------*
      *              * Se non esiste alcuna pagina attiva successiva   *
      *              * alla pagina attuale : uscita                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio numero pagina attuale           *
      *                  *---------------------------------------------*
           move      w-cnt-sts-imp-npt    to   w-cnt-sts-imp-svp      .
       acc-pre-vp1-400.
      *                  *---------------------------------------------*
      *                  * Se all'ultima pagina : ripristino pagina    *
      *                  * salvata ed uscita                           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-npt    not  < w-cnt-sts-imp-mpt
                     move  w-cnt-sts-imp-svp
                                          to   w-cnt-sts-imp-npt
                     go to acc-pre-vp1-999.
      *                  *---------------------------------------------*
      *                  * Incremento numero pagina                    *
      *                  *---------------------------------------------*
           add       1                    to   w-cnt-sts-imp-npt      .
      *                  *---------------------------------------------*
      *                  * Test se pagina da trattare                  *
      *                  *---------------------------------------------*
           perform   snp-tes-reg-000      thru snp-tes-reg-999        .
      *                  *---------------------------------------------*
      *                  * Se no : a re-incremento                     *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-snp    not  = spaces
                     go to acc-pre-vp1-400.
      *                  *---------------------------------------------*
      *                  * Se si : ripristino pagina salvata           *
      *                  *---------------------------------------------*
           move      w-cnt-sts-imp-svp    to   w-cnt-sts-imp-npt      .
       acc-pre-vp1-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazioni pagina testata nr. 1            *
      *    *-----------------------------------------------------------*
       cnt-imp-pt1-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-imp-pt1-flg      .
      *              *-------------------------------------------------*
      *              * Test se la pagina e' da trattare                *
      *              *                                                 *
      *              * N.B.: Il test seguente deve essere pari a quel- *
      *              *       lo contenuto in snp-tes-reg-000/999       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * La pagina e' sempre da trattare             *
      *                  *---------------------------------------------*
           go to     cnt-imp-pt1-100.
       cnt-imp-pt1-100.
      *              *-------------------------------------------------*
      *              * Codice debitore                                 *
      *              *-------------------------------------------------*
           if        w-tes-cod-dbt (1)    not  = zero
                     go to cnt-imp-pt1-120.
           move      "Manca il codice del cliente debitore              
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-120.
      *              *-------------------------------------------------*
      *              * Dipendenza del debitore                         *
      *              *-------------------------------------------------*
       cnt-imp-pt1-140.
      *              *-------------------------------------------------*
      *              * Tipo riscossione                                *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        not  = 0301 and
                     w-tes-tip-ope        not  = 0302 and
                     w-tes-tip-ope        not  = 0303 and
                     w-tes-tip-ope        not  = 0304
                     go to cnt-imp-pt1-160.
           if        w-tes-tip-rsd (1)    not  = zero and
                     w-tes-tip-rsd (1)    not  > w-exp-tip-rsd-num
                     go to cnt-imp-pt1-160.
           move      "Manca la definizione del tipo riscossione !       
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-160.
      *              *-------------------------------------------------*
      *              * Codice ns. cassa, banca o c/c postale           *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        =    0350
                     go to cnt-imp-pt1-180.
           if        w-tes-cbp-rsd (1)    not  = spaces
                     go to cnt-imp-pt1-180.
           if        w-tes-tip-ope        =    0301 or
                     w-tes-tip-ope        =    0302
                     go to cnt-imp-pt1-162
           else if   w-tes-tip-ope        =    0303
                     go to cnt-imp-pt1-164
           else if   w-tes-tip-ope        =    0304
                     go to cnt-imp-pt1-166
           else if   w-tes-tip-ope        =    0321
                     go to cnt-imp-pt1-162
           else if   w-tes-tip-ope        =    0322 or
                     w-tes-tip-ope        =    0323
                     go to cnt-imp-pt1-164
           else if   w-tes-tip-ope        =    0324
                     go to cnt-imp-pt1-166.
       cnt-imp-pt1-162.
           move      "Manca il codice nostra cassa !                    
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-164.
           move      "Manca il codice nostra banca !                    
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-166.
           move      "Manca il codice nostro c/c postale !              
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-180.
      *              *-------------------------------------------------*
      *              * Data documento per la riscossione               *
      *              *-------------------------------------------------*
           if        w-tes-ndo-rsd (1)    =    spaces
                     go to cnt-imp-pt1-200.
           if        w-tes-ddo-rsd (1)    not  = zero
                     go to cnt-imp-pt1-200.
           move      "Manca la data documento per la riscossione !      
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-200.
      *              *-------------------------------------------------*
      *              * Numero documento per la riscossione             *
      *              *-------------------------------------------------*
           if        w-tes-ddo-rsd (1)    =    zero
                     go to cnt-imp-pt1-220.
           if        w-tes-ndo-rsd (1)    not  = spaces
                     go to cnt-imp-pt1-220.
           move      "Manca il numero documento per la riscossione !    
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-220.
      *              *-------------------------------------------------*
      *              * Importo riscossione                             *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        =    0350
                     go to cnt-imp-pt1-240.
           if        w-tes-imp-rsd (1)    not  = zero
                     go to cnt-imp-pt1-240.
           if       (w-tes-tip-ope        =    0301 or
                     w-tes-tip-ope        =    0302 or
                     w-tes-tip-ope        =    0303 or
                     w-tes-tip-ope        =    0304  ) and
                    (w-tes-tip-rsd (1)    =    01    )
                     go to cnt-imp-pt1-240
           else if  (w-tes-tip-ope        =    0321 or
                     w-tes-tip-ope        =    0322 or
                     w-tes-tip-ope        =    0323 or
                     w-tes-tip-ope        =    0324  )
                     go to cnt-imp-pt1-240.
           move      "Manca l'importo riscosso !                        
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-240.
      *              *-------------------------------------------------*
      *              * Spese addebitate per la riscossione             *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        not  = 0303 and
                     w-tes-tip-ope        not  = 0304 and
                     w-tes-tip-ope        not  = 0323 and
                     w-tes-tip-ope        not  = 0324
                     go to cnt-imp-pt1-300.
           if        w-tes-spe-rsd (1)    =    zero
                     go to cnt-imp-pt1-300.
           if        w-tes-imp-rsd (1)    =    zero
                     go to cnt-imp-pt1-300.
           if        w-tes-spe-rsd (1)    <    w-tes-imp-rsd (1)
                     go to cnt-imp-pt1-300.
           if        w-tes-tip-ope        =    0303 or
                     w-tes-tip-ope        =    0304
                     go to cnt-imp-pt1-242
           else if   w-tes-tip-ope        =    0323 or
                     w-tes-tip-ope        =    0324
                     go to cnt-imp-pt1-244.
       cnt-imp-pt1-242.
           move      "Spese addebitate non inferiori all'importo riscoss
      -              "o !            "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-244.
           move      "Spese addebitate non inferiori all'importo pagamen
      -              "to !           "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt1-900.
       cnt-imp-pt1-300.
      *              *-------------------------------------------------*
      *              * Fine controlli                                  *
      *              *-------------------------------------------------*
           go to     cnt-imp-pt1-999.
       cnt-imp-pt1-900.
      *              *-------------------------------------------------*
      *              * Se controllo non superato                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di errore in uscita                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-imp-pt1-flg      .
       cnt-imp-pt1-999.
           exit.
           
      *    *===========================================================*
      *    * Caricamento dei buffer scadenze debitore                  *
      *    *-----------------------------------------------------------*
       car-buf-sdb-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-car-buf-sdb-flg      .
      *              *-------------------------------------------------*
      *              * Azzeramento contatori scadenze scartate durante *
      *              * il caricamento dei buffer                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-car-buf-sdb-css (01) .
           move      zero                 to   w-car-buf-sdb-css (02) .
           move      zero                 to   w-car-buf-sdb-css (03) .
           move      zero                 to   w-car-buf-sdb-css (04) .
           move      zero                 to   w-car-buf-sdb-css (05) .
           move      zero                 to   w-car-buf-sdb-css (06) .
           move      zero                 to   w-car-buf-sdb-css (07) .
           move      zero                 to   w-car-buf-sdb-css (08) .
           move      zero                 to   w-car-buf-sdb-css (09) .
      *              *-------------------------------------------------*
      *              * Azzeramento contatori numero elementi nei buf-  *
      *              * fer                                             *
      *              *-------------------------------------------------*
           move      zero                 to   w-bsu-num-ele          .
           move      zero                 to   w-bst-num-ele          .
      *              *-------------------------------------------------*
      *              * Azzeramento totale scadenze debitore nei buffer *
      *              *-------------------------------------------------*
           move      zero                 to   w-bsu-tot-sdb          .
           move      zero                 to   w-bst-tot-sdb          .
      *              *-------------------------------------------------*
      *              * Messaggio di caricamento in esecuzione          *
      *              *-------------------------------------------------*
           move      " Selezione scadenze da includere nell'operazione i
      -              "n esecuzione   "    to   w-err-box-err-msg      .
           perform   msg-cnt-box-000      thru msg-cnt-box-999        .
       car-buf-sdb-100.
      *              *-------------------------------------------------*
      *              * Sort scadenze debitore                          *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   car-buf-sdb-inp-000
                                          thru car-buf-sdb-inp-999
                     output procedure     is   car-buf-sdb-out-000
                                          thru car-buf-sdb-out-999    .
       car-buf-sdb-200.
      *              *-------------------------------------------------*
      *              * Cancellazione messaggio di caricamento in ese-  *
      *              * cuzione                                         *
      *              *-------------------------------------------------*
           move      spaces               to   w-err-box-err-msg      .
           perform   msg-cnt-box-000      thru msg-cnt-box-999        .
      *              *-------------------------------------------------*
      *              * Test se contatori scadenze scartate tutti a ze- *
      *              * ro e nessun elemento nei buffer                 *
      *              *-------------------------------------------------*
           if       (w-car-buf-sdb-css (01)
                                          =    zero and
                     w-car-buf-sdb-css (02)
                                          =    zero and
                     w-car-buf-sdb-css (03)
                                          =    zero and
                     w-car-buf-sdb-css (04)
                                          =    zero and
                     w-car-buf-sdb-css (05)
                                          =    zero and
                     w-car-buf-sdb-css (06)
                                          =    zero and
                     w-car-buf-sdb-css (07)
                                          =    zero   ) and
                    (w-bsu-num-ele        =    zero   ) and
                    (w-bst-num-ele        =    zero   )
                     go to car-buf-sdb-210
           else      go to car-buf-sdb-300.
       car-buf-sdb-210.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "Nessuna scadenza aperta per il cliente !          
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di uscita ad errore                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-car-buf-sdb-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     car-buf-sdb-999.
       car-buf-sdb-300.
      *              *-------------------------------------------------*
      *              * Se contatori scadenze scartate tutti a zero :   *
      *              * uscita                                          *
      *              *-------------------------------------------------*
           if        w-car-buf-sdb-css (01)
                                          =    zero and
                     w-car-buf-sdb-css (02)
                                          =    zero and
                     w-car-buf-sdb-css (03)
                                          =    zero and
                     w-car-buf-sdb-css (04)
                                          =    zero and
                     w-car-buf-sdb-css (05)
                                          =    zero and
                     w-car-buf-sdb-css (06)
                                          =    zero and
                     w-car-buf-sdb-css (07)
                     go to car-buf-sdb-999.
      *              *-------------------------------------------------*
      *              * Altrimenti, box di avviso per scadenze scartate *
      *              *-------------------------------------------------*
           perform   car-buf-sdb-box-000  thru car-buf-sdb-box-999    .
       car-buf-sdb-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort in fase di caricamento scadenze  *
      *    * debitore                                                  *
      *    *-----------------------------------------------------------*
       car-buf-sdb-inp-000.
      *              *-------------------------------------------------*
      *              * Start su file [sdb]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DBTRIS    "         to   f-key                  .
           move      w-tes-tip-dbt (1)    to   rf-sdb-tip-dbt         .
           move      w-tes-cod-dbt (1)    to   rf-sdb-cod-dbt         .
           move      zero                 to   rf-sdb-num-ris         .
           move      zero                 to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to car-buf-sdb-inp-900.
       car-buf-sdb-inp-100.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [sdb]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to car-buf-sdb-inp-900.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-sdb-tip-dbt       not  = w-tes-tip-dbt (1) or
                     rf-sdb-cod-dbt       not  = w-tes-cod-dbt (1) or
                     rf-sdb-num-ris       not  = zero
                     go to car-buf-sdb-inp-900.
      *              *-------------------------------------------------*
      *              * Selezioni su record [sdb] bloccanti             *
      *              *-------------------------------------------------*
           perform   sel-sdb-blo-000      thru sel-sdb-blo-999        .
      *              *-------------------------------------------------*
      *              * Se selezione superata : oltre                   *
      *              *-------------------------------------------------*
           if        w-sel-sdb-blo-flg    =    zero
                     go to car-buf-sdb-inp-120.
      *                  *---------------------------------------------*
      *                  * Determinazione indice contatore di errori   *
      *                  *                                             *
      *                  * N.B.: Solo se incompatibilita' nella sigla  *
      *                  *       valuta                                *
      *                  *---------------------------------------------*
           if        w-sel-sdb-blo-flg    =    13
                     move  06             to   w-car-buf-sdb-inx
           else      go to car-buf-sdb-inp-110.
      *                  *---------------------------------------------*
      *                  * Incremento contatore di errori              *
      *                  *---------------------------------------------*
           if        w-car-buf-sdb-css
                    (w-car-buf-sdb-inx)   <    9999
                     add   1              to   w-car-buf-sdb-css
                                              (w-car-buf-sdb-inx)     .
       car-buf-sdb-inp-110.
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     car-buf-sdb-inp-100.
       car-buf-sdb-inp-120.
      *              *-------------------------------------------------*
      *              * Selezioni su record [sdb] non bloccanti         *
      *              *-------------------------------------------------*
           perform   sel-sdb-nbl-000      thru sel-sdb-nbl-999        .
      *              *-------------------------------------------------*
      *              * Se selezione superata : oltre                   *
      *              *-------------------------------------------------*
           if        w-sel-sdb-nbl-flg    =    zero
                     go to car-buf-sdb-inp-140.
      *                  *---------------------------------------------*
      *                  * Determinazione indice contatore di errori   *
      *                  *---------------------------------------------*
           if        w-sel-sdb-nbl-flg    =    11
                     move  01             to   w-car-buf-sdb-inx
           else if   w-sel-sdb-nbl-flg    =    13
                     move  03             to   w-car-buf-sdb-inx
           else if   w-sel-sdb-nbl-flg    =    15
                     move  05             to   w-car-buf-sdb-inx
           else      go to car-buf-sdb-inp-130.
      *                  *---------------------------------------------*
      *                  * Incremento contatore di errori              *
      *                  *---------------------------------------------*
           if        w-car-buf-sdb-css
                    (w-car-buf-sdb-inx)   <    9999
                     add   1              to   w-car-buf-sdb-css
                                              (w-car-buf-sdb-inx)     .
       car-buf-sdb-inp-130.
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     car-buf-sdb-inp-100.
       car-buf-sdb-inp-140.
      *              *-------------------------------------------------*
      *              * Fine selezioni sul record                       *
      *              *-------------------------------------------------*
       car-buf-sdb-inp-300.
      *              *-------------------------------------------------*
      *              * Composizione sort-record                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Chiave del sort                             *
      *                  *---------------------------------------------*
           if        rf-sdb-dts-sdb       =    zero
                     move  w-tes-dat-reg  to   srt-dts-eff
           else      move  rf-sdb-dts-sdb to   srt-dts-eff            .
           if        rf-sdb-tip-ddr       =    01 or
                     rf-sdb-tip-ddr       =    02
                     move  03             to   srt-ord-tdr
           else if   rf-sdb-tip-ddr       =    11
                     move  02             to   srt-ord-tdr
           else if   rf-sdb-tip-ddr       =    21
                     move  01             to   srt-ord-tdr
           else if   rf-sdb-tip-ddr       =    99
                     move  03             to   srt-ord-tdr
           else      move  03             to   srt-ord-tdr            .
           move      rf-sdb-num-sdb       to   srt-num-sdb            .
      *                  *---------------------------------------------*
      *                  * Dati del sort                               *
      *                  *---------------------------------------------*
           move      rf-sdb-drc-emi       to   srt-drc-emi            .
           move      rf-sdb-npc-emi       to   srt-npc-emi            .
           move      rf-sdb-prt-fcl       to   srt-prt-fcl            .
           move      rf-sdb-cod-age       to   srt-cod-age            .
           move      rf-sdb-tip-sdb       to   srt-tip-sdb            .
           move      rf-sdb-snx-dlc       to   srt-snx-dlc            .
           move      rf-sdb-snx-cts       to   srt-snx-cts            .
           if        rf-sdb-dtr-isp       =    zero
                     move  "N"            to   srt-snx-ins
           else      move  "S"            to   srt-snx-ins            .
           move      rf-sdb-tac-sdb       to   srt-tac-sdb            .
           move      rf-sdb-tvl-sdb       to   srt-tvl-sdb            .
           move      rf-sdb-dts-sdb       to   srt-dts-sdb            .
           move      rf-sdb-dpz-dbt       to   srt-dpz-dbt            .
           move      rf-sdb-inl-sdb       to   srt-inl-sdb            .
           if        rf-sdb-tvl-sdb       =    02
                     move  rf-sdb-iiv-sdb to   srt-imp-sdb
           else      move  rf-sdb-imp-sdb to   srt-imp-sdb            .
           move      rf-sdb-nsc-org       to   srt-nsc-org            .
           move      rf-sdb-dat-ddr       to   srt-dat-ddr            .
           move      rf-sdb-num-ddr       to   srt-num-ddr            .
           move      rf-sdb-tip-ddr       to   srt-tip-ddr            .
           move      rf-sdb-imp-ddr       to   srt-imp-ddr            .
           move      rf-sdb-nra-ddr       to   srt-nra-ddr            .
           move      rf-sdb-abi-app       to   srt-abi-app            .
           move      rf-sdb-cab-app       to   srt-cab-app            .
           move      rf-sdb-ccc-app       to   srt-ccc-app            .
           move      rf-sdb-cod-cbp       to   srt-cod-cbp            .
       car-buf-sdb-inp-310.
      *                      *-----------------------------------------*
      *                      * Importo riscosso                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Deviazione in funzione del tipo o-  *
      *                          * perazione                           *
      *                          *-------------------------------------*
           if        w-tes-tip-ope        =    0301 or
                     w-tes-tip-ope        =    0302 or
                     w-tes-tip-ope        =    0303 or
                     w-tes-tip-ope        =    0304
                     go to car-buf-sdb-inp-311
           else if   w-tes-tip-ope        =    0321 or
                     w-tes-tip-ope        =    0322 or
                     w-tes-tip-ope        =    0323 or
                     w-tes-tip-ope        =    0324
                     go to car-buf-sdb-inp-311
           else if   w-tes-tip-ope        =    0350
                     go to car-buf-sdb-inp-312.
       car-buf-sdb-inp-311.
      *                          *-------------------------------------*
      *                          * Tipo operazione : Riscossione o Pa- *
      *                          * gamento                             *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Determinazione                  *
      *                              *---------------------------------*
           move      rf-sdb-imp-ris       to   srt-imp-ris            .
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     car-buf-sdb-inp-315.
       car-buf-sdb-inp-312.
      *                          *-------------------------------------*
      *                          * Tipo operazione : Compensazione     *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Determinazione                  *
      *                              *---------------------------------*
           subtract  rf-sdb-imp-ris       from rf-sdb-imp-sdb
                                        giving srt-imp-ris            .
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     car-buf-sdb-inp-315.
       car-buf-sdb-inp-315.
           move      rf-sdb-aos-ris       to   srt-aos-ris            .
           move      rf-sdb-dtr-isp       to   srt-dtr-isp            .
           move      rf-sdb-liv-slc       to   srt-liv-slc            .
           move      rf-sdb-dso-l01       to   srt-dso-l01            .
           move      rf-sdb-dso-l02       to   srt-dso-l02            .
           move      rf-sdb-dso-l03       to   srt-dso-l03            .
       car-buf-sdb-inp-400.
      *              *-------------------------------------------------*
      *              * Rilascio record al sort                         *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       car-buf-sdb-inp-500.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale record [sdb]     *
      *              *-------------------------------------------------*
           go to     car-buf-sdb-inp-100.
       car-buf-sdb-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     car-buf-sdb-inp-999.
       car-buf-sdb-inp-999.
           exit.

      *    *===========================================================*
      *    * Output procedure per sort in fase di caricamento scadenze *
      *    * debitore                                                  *
      *    *-----------------------------------------------------------*
       car-buf-sdb-out-000.
      *              *-------------------------------------------------*
