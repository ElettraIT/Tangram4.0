      *    *===========================================================*
      *    * Selezioni bloccanti su record [sdb]                       *
      *    *                                                           *
      *    * Input  :                                                  *
      *    *                                                           *
      *    *  - Area w-tes e record [sdb] da esaminare                 *
      *    *                                                           *
      *    * Output :                                                  *
      *    *                                                           *
      *    *  - w-sel-sdb-blo-flg : Flag fondamentale di uscita        *
      *    *    - 00 : Selezione superata                              *
      *    *    - nn : Selezione non superata, con causa codice nn     *
      *    *           - 11 : Tipo scadenza non riconosciuto           *
      *    *           - 12 : Tipo valuta della scadenza non ammissi-  *
      *    *                  bile per la riscossione in atto          *
      *    *           - 13 : Codice valuta della scadenza diverso da  *
      *    *                  quello della riscossione in atto         *
      *    *           - 14 : Status scadenza indicante scadenza non   *
      *    *                  aperta                                   *
      *    *           - 15 : Data di registrazione del movimento di   *
      *    *                  emissione scadenza superiore alla data   *
      *    *                  registrazione dell'operazione in corso   *
      *    *           - 16 : Segno scadenza errato                    *
      *    *           - 17 : La scadenza e' bloccata                  *
      *    *           - 18 : La scadenza e' in fase di pulizia        *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       sel-sdb-blo-000.
      *              *-------------------------------------------------*
      *              * Selezione su tipo scadenza, che sia riconosciu- *
      *              * to                                              *
      *              *-------------------------------------------------*
           if        rf-sdb-tip-sdb       =    01 or
                     rf-sdb-tip-sdb       =    02 or
                     rf-sdb-tip-sdb       =    03 or
                     rf-sdb-tip-sdb       =    04 or
                     rf-sdb-tip-sdb       =    05 or
                     rf-sdb-tip-sdb       =    06 or
                     rf-sdb-tip-sdb       =    07 or
                     rf-sdb-tip-sdb       =    08 or
                     rf-sdb-tip-sdb       =    09 or
                     rf-sdb-tip-sdb       =    10 or
                     rf-sdb-tip-sdb       =    11
                     go to sel-sdb-blo-100.
           move      11                   to   w-sel-sdb-blo-flg      .
           move      "Tipo scadenza non riconosciuto                    
      -              "               "    to   w-sel-sdb-blo-err      .
           go to     sel-sdb-blo-999.
       sel-sdb-blo-100.
      *              *-------------------------------------------------*
      *              * Selezione su tipo valuta, che sia compatibile   *
      *              *-------------------------------------------------*
           if        rf-sdb-tvl-sdb       =    w-tes-tvl-rsd (1)
                     go to sel-sdb-blo-200.
           move      12                   to   w-sel-sdb-blo-flg      .
           move      "Tipo valuta per la scadenza incompatibile         
      -              "               "    to   w-sel-sdb-blo-err      .
           go to     sel-sdb-blo-999.
       sel-sdb-blo-200.
      *              *-------------------------------------------------*
      *              * Selezione su sigla valuta, che sia compatibile  *
      *              *-------------------------------------------------*
           if        rf-sdb-sgl-vlt       =    w-tes-sgl-vlt (1) and
                     rf-sdb-dec-vlt       =    w-tes-dec-vlt (1) and
                     rf-sdb-tdc-vlt       =    w-tes-tdc-vlt (1)
                     go to sel-sdb-blo-300.
           move      13                   to   w-sel-sdb-blo-flg      .
           move      "Sigla valuta della scadenza incompatibile         
      -              "               "    to   w-sel-sdb-blo-err      .
           go to     sel-sdb-blo-999.
       sel-sdb-blo-300.
      *              *-------------------------------------------------*
      *              * Selezione su status della scadenza              *
      *              *-------------------------------------------------*
           perform   det-sts-sdb-000      thru det-sts-sdb-999        .
           if       (w-det-sts-sdb-sts    =    "A"    ) and
                    (w-det-sts-sdb-suo    =    "EMI" or
                     w-det-sts-sdb-suo    =    "ISP"  )
                     go to sel-sdb-blo-400.
           move      14                   to   w-sel-sdb-blo-flg      .
           move      "Scadenza con movimenti successivi all'emissione   
      -              "               "    to   w-sel-sdb-blo-err      .
           go to     sel-sdb-blo-999.
       sel-sdb-blo-400.
      *              *-------------------------------------------------*
      *              * Selezione sulla data di registrazione movimento *
      *              * di emissione scadenza, che non sia superiore    *
      *              * alla data di registrazione in corso             *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-emi       not > w-tes-dat-reg
                     go to sel-sdb-blo-500.
           move      15                   to   w-sel-sdb-blo-flg      .
           move      "Data registrazione scadenza superiore alla data de
      -              "ll'operazione  "    to   w-sel-sdb-blo-err      .
           go to     sel-sdb-blo-999.
       sel-sdb-blo-500.
      *              *-------------------------------------------------*
      *              * Selezione sul segno dell'importo scadenza       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del tipo valuta        *
      *                  *---------------------------------------------*
           if        rf-sdb-tvl-sdb       =    02
                     go to sel-sdb-blo-505
           else      go to sel-sdb-blo-510.
       sel-sdb-blo-505.
      *                  *---------------------------------------------*
      *                  * Tipo valuta : diverso da quello base        *
      *                  *---------------------------------------------*
           if        rf-sdb-tip-ddr       =    11 or
                     rf-sdb-tip-ddr       =    21
                     if    rf-sdb-iiv-sdb <    zero
                           go to sel-sdb-blo-600
                     else  go to sel-sdb-blo-520
           else      if    rf-sdb-iiv-sdb >    zero
                           go to sel-sdb-blo-600
                     else  go to sel-sdb-blo-520.
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     sel-sdb-blo-600.
       sel-sdb-blo-510.
      *                  *---------------------------------------------*
      *                  * Tipo valuta : base                          *
      *                  *---------------------------------------------*
           if        rf-sdb-tip-ddr       =    11 or
                     rf-sdb-tip-ddr       =    21
                     if    rf-sdb-imp-sdb <    zero
                           go to sel-sdb-blo-600
                     else  go to sel-sdb-blo-520
           else      if    rf-sdb-imp-sdb >    zero
                           go to sel-sdb-blo-600
                     else  go to sel-sdb-blo-520.
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     sel-sdb-blo-600.
       sel-sdb-blo-520.
           move      16                   to   w-sel-sdb-blo-flg      .
           move      "Segno dell'importo scadenza errato                
      -              "               "    to   w-sel-sdb-blo-err      .
           go to     sel-sdb-blo-999.
       sel-sdb-blo-600.
      *              *-------------------------------------------------*
      *              * Selezione su flag bloccanti                     *
      *              *-------------------------------------------------*
           if        rf-sdb-flg-blo       =    spaces
                     go to sel-sdb-blo-700.
           move      17                   to   w-sel-sdb-blo-flg      .
           move      "La scadenza e' stata sottoposta ad elaborazioni   
      -              "               "    to   w-sel-sdb-blo-err      .
           go to     sel-sdb-blo-999.
       sel-sdb-blo-700.
      *              *-------------------------------------------------*
      *              * Selezione su flag di pulizia                    *
      *              *-------------------------------------------------*
           if        rf-sdb-flg-pul       =    spaces
                     go to sel-sdb-blo-800.
           move      18                   to   w-sel-sdb-blo-flg      .
           move      "La scadenza e' in corso di eliminazione           
      -              "               "    to   w-sel-sdb-blo-err      .
           go to     sel-sdb-blo-999.
       sel-sdb-blo-800.
      *              *-------------------------------------------------*
      *              * Selezione superata                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-sel-sdb-blo-flg      .
           move      spaces               to   w-sel-sdb-blo-err      .
       sel-sdb-blo-999.
           exit.

      *    *===========================================================*
      *    * Selezioni non bloccanti su record [sdb]                   *
      *    *                                                           *
      *    * Input  :                                                  *
      *    *                                                           *
      *    *  - Area w-tes e record [sdb] da esaminare                 *
      *    *                                                           *
      *    * Output :                                                  *
      *    *                                                           *
      *    *  - w-sel-sdb-nbl-flg : Flag fondamentale di uscita        *
      *    *    - 00 : Selezione superata                              *
      *    *    - nn : Selezione non superata, con causa codice nn     *
      *    *           - 11 : Codice dipendenza del cliente            *
      *    *           - 13 : Nostra banca d'appoggio                  *
      *    *           - 15 : Codice C/C postale                       *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       sel-sdb-nbl-000.
      *              *-------------------------------------------------*
      *              * Codice dipendenza del debitore                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test di selezione                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se stesso codice dipendenza : oltre     *
      *                      *-----------------------------------------*
           if        rf-sdb-dpz-dbt       =    w-tes-dpz-dbt (1)
                     go to sel-sdb-nbl-100.
      *                      *-----------------------------------------*
      *                      * Se riscossione intestata ad una dipen-  *
      *                      * denza : a trattamento errore            *
      *                      *-----------------------------------------*
           if        w-tes-dpz-dbt (1)    not  = spaces
                     go to sel-sdb-nbl-050.
      *                      *-----------------------------------------*
      *                      * Se scadenza intestata ad una dipendenza *
      *                      * ma inoltro scadenza alla Sede o alla    *
      *                      * Sede Legale : oltre                     *
      *                      *-----------------------------------------*
           if       (rf-sdb-dpz-dbt       not  = spaces ) and
                    (rf-sdb-inl-sdb       =    01      or
                     rf-sdb-inl-sdb       =    02       )
                     go to sel-sdb-nbl-100.
       sel-sdb-nbl-050.
      *                  *---------------------------------------------*
      *                  * Trattamento errore                          *
      *                  *---------------------------------------------*
           move      11                   to   w-sel-sdb-nbl-flg      .
           move      "Diverso codice dipendenza del cliente             
      -              "               "    to   w-sel-sdb-nbl-err      .
           go to     sel-sdb-nbl-999.
       sel-sdb-nbl-100.
      *              *-------------------------------------------------*
      *              * Codice c/c postale per il riscossione           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo scadenza                       *
      *                  *---------------------------------------------*
           if        rf-sdb-tip-sdb       not  = 08
                     go to sel-sdb-nbl-500.
      *                  *---------------------------------------------*
      *                  * Test su tipo operazione di riscossione      *
      *                  *---------------------------------------------*
           if        w-tes-tip-ope        not  = 0304
                     go to sel-sdb-nbl-500.
      *                  *---------------------------------------------*
      *                  * Test se c/c postale d'appoggio memorizzato  *
      *                  *---------------------------------------------*
           if        rf-sdb-cod-cbp       =    spaces
                     go to sel-sdb-nbl-500.
      *                  *---------------------------------------------*
      *                  * Test di selezione                           *
      *                  *---------------------------------------------*
           if        rf-sdb-cod-cbp       =    w-tes-cbp-rsd (1)
                     go to sel-sdb-nbl-500.
      *                  *---------------------------------------------*
      *                  * Trattamento errore                          *
      *                  *---------------------------------------------*
           move      15                   to   w-sel-sdb-nbl-flg      .
           move      "Diverso codice C/C postale                        
      -              "               "    to   w-sel-sdb-nbl-err      .
           go to     sel-sdb-nbl-999.
       sel-sdb-nbl-500.
      *              *-------------------------------------------------*
      *              * Selezioni superate                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-sel-sdb-nbl-flg      .
           move      spaces               to   w-sel-sdb-nbl-err      .
       sel-sdb-nbl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Selezione su tipi scadenza           *
      *    *-----------------------------------------------------------*
       acc-sel-tsc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-fda-pt2 (1)    not  = spaces
                     go to acc-sel-tsc-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-sel-tsc (1)    to   w-sav-sel-tsc          .
      *                  *---------------------------------------------*
      *                  * Preparazione work per l'accettazione del    *
      *                  * campo espanso selezione su tipi scadenza    *
      *                  *---------------------------------------------*
           perform   pex-sel-tsc-000      thru pex-sel-tsc-999        .
       acc-sel-tsc-075.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del numero di ele-   *
      *                  * menti che compongono la tabella delle pos-  *
      *                  * sibili scelte alternative                   *
      *                  *---------------------------------------------*
           if        w-exp-sel-tsc-num    =    zero
                     go to acc-sel-tsc-080
           else if   w-exp-sel-tsc-num    =    1
                     go to acc-sel-tsc-085
           else      go to acc-sel-tsc-090.
       acc-sel-tsc-080.
      *                  *---------------------------------------------*
      *                  * Se zero scelte possibili                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione del valore da accettare *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-sel-tsc (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione del valore              *
      *                      *-----------------------------------------*
           perform   vis-sel-tsc-000      thru vis-sel-tsc-999        .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     acc-sel-tsc-999.
       acc-sel-tsc-085.
      *                  *---------------------------------------------*
      *                  * Se una sola scelta possibile                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Forzatura del valore da accettare       *
      *                      *-----------------------------------------*
           move      w-exp-sel-tsc-vel (1)
                                          to   w-tes-sel-tsc (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione del valore              *
      *                      *-----------------------------------------*
           perform   vis-sel-tsc-000      thru vis-sel-tsc-999        .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     acc-sel-tsc-999.
       acc-sel-tsc-090.
      *                  *---------------------------------------------*
      *                  * Se piu' di una scelta possibile             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se Next Screen da campi precedenti      *
      *                      *-----------------------------------------*
           if        v-key                =    "NXSC"
                     perform vis-sel-tsc-000
                                          thru vis-sel-tsc-999
                     go to acc-sel-tsc-400.
      *                      *-----------------------------------------*
      *                      * Ad accettazione                         *
      *                      *-----------------------------------------*
           go to     acc-sel-tsc-100.
       acc-sel-tsc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazioni generali                       *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-sel-tsc-lun    to   v-car                  .
           move      w-exp-sel-tsc-num    to   v-ldt                  .
           move      "ST#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      w-exp-sel-tsc-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      09                   to   v-lin                  .
           move      30                   to   v-pos                  .
       acc-sel-tsc-105.
      *                  *---------------------------------------------*
      *                  * Preparazione indice corrispondente al valo- *
      *                  * re attuale                                  *
      *                  *---------------------------------------------*
           if        w-tes-sel-tsc (1)    =    zero
                     move  zero           to   v-num
                     go to acc-sel-tsc-125.
       acc-sel-tsc-110.
           move      zero                 to   w-exp-sel-tsc-inx      .
       acc-sel-tsc-115.
           add       1                    to   w-exp-sel-tsc-inx      .
           if        w-exp-sel-tsc-inx    >    w-exp-sel-tsc-num
                     move  zero           to   v-num
                     go to acc-sel-tsc-125.
           if        w-exp-sel-tsc-vel
                    (w-exp-sel-tsc-inx)   =    w-tes-sel-tsc (1)
                     move  w-exp-sel-tsc-inx
                                          to   v-num
                     go to acc-sel-tsc-125
           else      go to acc-sel-tsc-115.
       acc-sel-tsc-125.
      *                  *---------------------------------------------*
      *                  * Accettazione                                *
      *                  *---------------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-sel-tsc-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-sel-tsc-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-sel-tsc-999.
       acc-sel-tsc-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-exp-sel-tsc-inx      .
           if        w-exp-sel-tsc-inx    =    zero           or
                     w-exp-sel-tsc-inx    >    w-exp-sel-tsc-num
                     move  zero           to   w-tes-sel-tsc (1)
                     go to acc-sel-tsc-400.
           move      w-exp-sel-tsc-vel
                    (w-exp-sel-tsc-inx)   to   w-tes-sel-tsc (1)      .
       acc-sel-tsc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-sel-tsc-425.
      *                  *---------------------------------------------*
      *                  * Test che il valore non sia a zero, a meno   *
      *                  * che non si sia in Up                        *
      *                  *---------------------------------------------*
           if        w-tes-sel-tsc (1)    not  = zero
                     go to acc-sel-tsc-500.
           if        v-key                =    "UP  "
                     go to acc-sel-tsc-600
           else      go to acc-sel-tsc-100.
       acc-sel-tsc-500.
      *                  *---------------------------------------------*
      *                  * Test se valore ammissibile                  *
      *                  *---------------------------------------------*
           if        w-tes-sel-tsc (1)    >    w-exp-sel-tsc-num
                     go to acc-sel-tsc-100.
       acc-sel-tsc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-sel-tsc (1)    =    w-sav-sel-tsc
                     go to acc-sel-tsc-800.
      *                  *---------------------------------------------*
      *                  * Visualizzazione tabella progressivi mensili *
      *                  *---------------------------------------------*
           perform   vis-sel-tpm-000      thru vis-sel-tpm-999        .
       acc-sel-tsc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-sel-tsc-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-sel-tsc-100.
       acc-sel-tsc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Selezione su tipi scadenza        *
      *    *-----------------------------------------------------------*
       vis-sel-tsc-000.
      *              *-------------------------------------------------*
      *              * Preparazione work per l'accettazione del campo  *
      *              * espanso : Selezione su tipi scadenza            *
      *              *-------------------------------------------------*
           perform   pex-sel-tsc-000      thru pex-sel-tsc-999        .
       vis-sel-tsc-200.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del numero di elementi   *
      *              * che compongono la tabella delle possibili scel- *
      *              * te alternative                                  *
      *              *-------------------------------------------------*
           if        w-exp-sel-tsc-num    =    zero
                     go to vis-sel-tsc-250
           else      go to vis-sel-tsc-300.
       vis-sel-tsc-250.
      *              *-------------------------------------------------*
      *              * Se zero scelte possibili                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione a spaces                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-sel-tsc-lun    to   v-car                  .
           move      w-exp-sel-tsc-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-sel-tsc-tbl    to   v-txt                  .
           move      09                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      zero                 to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     vis-sel-tsc-999.
       vis-sel-tsc-300.
      *              *-------------------------------------------------*
      *              * Se almeno una scelta possibile                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione valore                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Preparazioni generali                   *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-sel-tsc-lun    to   v-car                  .
           move      w-exp-sel-tsc-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-sel-tsc-tbl    to   v-txt                  .
           move      09                   to   v-lin                  .
           move      30                   to   v-pos                  .
       vis-sel-tsc-350.
      *                      *-----------------------------------------*
      *                      * Preparazioni indice corrispondente al   *
      *                      * valore attuale                          *
      *                      *-----------------------------------------*
           if        w-tes-sel-tsc (1)    =    zero
                     move  zero           to   v-num
                     go to vis-sel-tsc-375.
           move      zero                 to   w-exp-sel-tsc-inx      .
       vis-sel-tsc-355.
           add       1                    to   w-exp-sel-tsc-inx      .
           if        w-exp-sel-tsc-inx    >    w-exp-sel-tsc-num
                     move  zero           to   v-num
                     go to vis-sel-tsc-375.
           if        w-exp-sel-tsc-vel
                    (w-exp-sel-tsc-inx)   =    w-tes-sel-tsc (1)
                     move  w-exp-sel-tsc-inx
                                          to   v-num
                     go to vis-sel-tsc-375
           else      go to vis-sel-tsc-355.
       vis-sel-tsc-375.
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     vis-sel-tsc-999.
       vis-sel-tsc-999.
           exit.

      *    *===========================================================*
      *    * Preparazione work per l'accettazione del campo espanso :  *
      *    * Selezione su tipi scadenza                                *
      *    *-----------------------------------------------------------*
       pex-sel-tsc-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo operazione      *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        =    0301 or
                     w-tes-tip-ope        =    0302
                     go to pex-sel-tsc-100
           else if   w-tes-tip-ope        =    0303
                     go to pex-sel-tsc-150
           else if   w-tes-tip-ope        =    0304
                     go to pex-sel-tsc-200
           else if   w-tes-tip-ope        =    0321 or
                     w-tes-tip-ope        =    0322 or
                     w-tes-tip-ope        =    0323 or
                     w-tes-tip-ope        =    0324
                     go to pex-sel-tsc-250
           else      go to pex-sel-tsc-900.
       pex-sel-tsc-100.
      *              *-------------------------------------------------*
      *              * Se tipo operazione : 0301 o 0302                *
      *              *-------------------------------------------------*
           move      w-exp-sel-tsc-n01    to   w-exp-sel-tsc-num      .
           move      w-exp-sel-tsc-t01    to   w-exp-sel-tsc-tbl      .
           move      w-exp-sel-tsc-v01    to   w-exp-sel-tsc-val      .
           go to     pex-sel-tsc-999.
       pex-sel-tsc-150.
      *              *-------------------------------------------------*
      *              * Se tipo operazione : 0303                       *
      *              *-------------------------------------------------*
           move      w-exp-sel-tsc-n02    to   w-exp-sel-tsc-num      .
           move      w-exp-sel-tsc-t02    to   w-exp-sel-tsc-tbl      .
           move      w-exp-sel-tsc-v02    to   w-exp-sel-tsc-val      .
           go to     pex-sel-tsc-999.
       pex-sel-tsc-200.
      *              *-------------------------------------------------*
      *              * Se tipo operazione : 0304                       *
      *              *-------------------------------------------------*
           move      w-exp-sel-tsc-n03    to   w-exp-sel-tsc-num      .
           move      w-exp-sel-tsc-t03    to   w-exp-sel-tsc-tbl      .
           move      w-exp-sel-tsc-v03    to   w-exp-sel-tsc-val      .
           go to     pex-sel-tsc-999.
       pex-sel-tsc-250.
      *              *-------------------------------------------------*
      *              * Se tipo operazione : 0321 o 0322 o 0323 o 0324  *
      *              *-------------------------------------------------*
           move      w-exp-sel-tsc-n04    to   w-exp-sel-tsc-num      .
           move      w-exp-sel-tsc-t04    to   w-exp-sel-tsc-tbl      .
           move      w-exp-sel-tsc-v04    to   w-exp-sel-tsc-val      .
           go to     pex-sel-tsc-999.
       pex-sel-tsc-900.
      *              *-------------------------------------------------*
      *              * Se tipo operazione non riconosciuto             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione work per accettazione       *
      *                  *---------------------------------------------*
           move      zero                 to   w-exp-sel-tsc-num      .
           move      spaces               to   w-exp-sel-tsc-tbl      .
           move      all   zero           to   w-exp-sel-tsc-val      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     pex-sel-tsc-999.
       pex-sel-tsc-999.
           exit.

      *    *===========================================================*
