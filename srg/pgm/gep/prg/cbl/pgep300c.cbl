      *                          * Test se da effettuare               *
      *                          *-------------------------------------*
           if       (w-tes-tip-ope        =    0301 or
                     w-tes-tip-ope        =    0302 or
                     w-tes-tip-ope        =    0303 or
                     w-tes-tip-ope        =    0304  ) and
                    (w-tes-tip-rsd (1)    not  = 01  )
                     go to rou-let-reg-999.
      *                          *-------------------------------------*
      *                          * Messaggio di caricamento in esecu-  *
      *                          * zione                               *
      *                          *-------------------------------------*
           move      "              Caricamento operazione in esecuzione
      -              "               "    to   w-err-box-err-msg      .
           perform   msg-cnt-box-000      thru msg-cnt-box-999        .
      *                          *-------------------------------------*
      *                          * Sort                                *
      *                          *-------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   rou-let-reg-inp-000
                                          thru rou-let-reg-inp-999
                     output procedure     is   rou-let-reg-out-000
                                          thru rou-let-reg-out-999    .
      *                          *-------------------------------------*
      *                          * Messaggio di fine caricamento       *
      *                          *-------------------------------------*
           move      spaces               to   w-err-box-err-msg      .
           perform   msg-cnt-box-000      thru msg-cnt-box-999        .
      *                          *-------------------------------------*
      *                          * Se scadenze non esistenti in rilet- *
      *                          * tura scadenze della riscossione,    *
      *                          * oppure se anomalia nelle scadenze:  *
      *                          * sola visualizzazione                *
      *                          *-------------------------------------*
           if        w-rou-let-reg-nsn    =    zero and
                     w-rou-let-reg-nsa    =    zero   
                     go to rou-let-reg-820.
           if        w-cnt-mfu-tip-fun    =    "I"
                     move  "#"            to   w-cnt-rou-let-reg
                     go to rou-let-reg-999
           else      move  "V"            to   w-cnt-mfu-tip-fun      .
       rou-let-reg-820.
      *                          *-------------------------------------*
      *                          * Valore testata : totale righe sca-  *
      *                          * denze selezionate                   *
      *                          *-------------------------------------*
           move      w-rou-let-reg-igc    to   w-tes-tot-scs (1)      .
       rou-let-reg-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort in fase di caricamento righe     *
      *    * scadenze debitore relative ad un operazione               *
      *    *-----------------------------------------------------------*
       rou-let-reg-inp-000.
      *              *-------------------------------------------------*
      *              * Start su file [sdb]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "RISSDB    "         to   f-key                  .
           move      w-tes-num-rsd        to   rf-sdb-num-ris         .
           move      zero                 to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rou-let-reg-inp-999.
       rou-let-reg-inp-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [sdb]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rou-let-reg-inp-999.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-sdb-num-ris       not  = w-tes-num-rsd
                     go to rou-let-reg-inp-999.
       rou-let-reg-inp-300.
      *              *-------------------------------------------------*
      *              * Composizione sort-record                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
