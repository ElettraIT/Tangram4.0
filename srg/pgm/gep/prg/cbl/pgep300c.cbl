      *              *-------------------------------------------------*
           if        w-cnt-imp-pt2-flg    not  = spaces
                     move  "UP  "         to   v-key
                     go to acc-pre-vp2-999.
      *              *-------------------------------------------------*
      *              * Se Next Screen si salta l'accettazione caratte- *
      *              * re di presa visione                             *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     go to acc-pre-vp2-200.
       acc-pre-vp2-100.
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      spaces               to   v-msk                  .
           move      spaces               to   v-alf                  .
           move      spaces               to   v-not                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           if        w-cnt-sts-imp-npt    >    1
                     move  "PRSC"         to   v-pfk (07)             .
           move      "NXSC"               to   v-pfk (08)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vp2-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vp2-999.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-pre-vp2-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pre-vp2-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pre-vp2-000.
       acc-pre-vp2-200.
      *              *-------------------------------------------------*
      *              * Se tipo funzionamento diverso da Inserimento,   *
      *              * oltre                                           *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-pre-vp2-300.
      *              *-------------------------------------------------*
      *              * Se pagina testata gia' impostata : oltre        *
      *              *-------------------------------------------------*
           if        w-tes-fda-pt2 (1)    not  = spaces
                     go to acc-pre-vp2-300.
      *              *-------------------------------------------------*
      *              * Determinazione buffer scadenze debitore di la-  *
      *              * voro                                            *
      *              *-------------------------------------------------*
           perform   det-buf-sdb-000      thru det-buf-sdb-999        .
      *              *-------------------------------------------------*
      *              * Se esito determinazione negativo : si esce for- *
      *              * zando il tasto Up                               *
      *              *-------------------------------------------------*
           if        w-det-buf-sdb-flg    not  = spaces
                     move  "UP  "         to   v-key
                     go to acc-pre-vp2-999.
      *              *-------------------------------------------------*
      *              * Selezione preliminare su scadenze debitore      *
      *              *-------------------------------------------------*
           perform   sel-pre-sdb-000      thru sel-pre-sdb-999        .
      *              *-------------------------------------------------*
      *              * Caricamento catena scadenze debitori            *
      *              *-------------------------------------------------*
           perform   car-cat-sdb-000      thru car-cat-sdb-999        .
      *              *-------------------------------------------------*
      *              * Se esito caricamento negativo : si esce forzan- *
      *              * do il tasto Up                                  *
      *              *-------------------------------------------------*
           if        w-car-cat-sdb-flg    not  = spaces
                     move  "UP  "         to   v-key
                     go to acc-pre-vp2-999.
      *              *-------------------------------------------------*
      *              * Attivazione flag di impostazione pagina testata *
      *              *-------------------------------------------------*
           move      "#"                  to   w-tes-fda-pt2 (1)      .
       acc-pre-vp2-300.
      *              *-------------------------------------------------*
      *              * Se non esiste alcuna pagina attiva successiva   *
      *              * alla pagina attuale : uscita                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio numero pagina attuale           *
      *                  *---------------------------------------------*
           move      w-cnt-sts-imp-npt    to   w-cnt-sts-imp-svp      .
       acc-pre-vp2-400.
      *                  *---------------------------------------------*
      *                  * Se all'ultima pagina : ripristino pagina    *
      *                  * salvata ed uscita                           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-npt    not  < w-cnt-sts-imp-mpt
                     move  w-cnt-sts-imp-svp
                                          to   w-cnt-sts-imp-npt
                     go to acc-pre-vp2-999.
      *                  *---------------------------------------------*
      *                  * Incremento numero pagina                    *
      *                  *---------------------------------------------*
           add       1                    to   w-cnt-sts-imp-npt      .
      *                  *---------------------------------------------*
      *                  * Test se pagina da trattare                  *
      *                  *---------------------------------------------*
           perform   snp-tes-reg-000      thru snp-tes-reg-999        .
      *                  *---------------------------------------------*
      *                  * Se no : a re-incremento                     *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-snp    not  = spaces
                     go to acc-pre-vp2-400.
      *                  *---------------------------------------------*
      *                  * Se si : ripristino pagina salvata           *
      *                  *---------------------------------------------*
           move      w-cnt-sts-imp-svp    to   w-cnt-sts-imp-npt      .
       acc-pre-vp2-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazioni pagina testata nr. 2            *
      *    *-----------------------------------------------------------*
       cnt-imp-pt2-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-imp-pt2-flg      .
      *              *-------------------------------------------------*
      *              * Test se la pagina e' da trattare                *
      *              *                                                 *
      *              * N.B.: Il test seguente deve essere pari a quel- *
      *              *       lo contenuto in snp-tes-reg-000/999       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se non in Inserimento : no                  *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to cnt-imp-pt2-999.
      *                  *---------------------------------------------*
      *                  * Se tipo riscossione Anticipo : no           *
      *                  *---------------------------------------------*
           if        w-tes-tip-rsd (1)    =    02
                     go to cnt-imp-pt2-999.
      *                  *---------------------------------------------*
      *                  * Se tipo operazione Compensazione : no       *
      *                  *---------------------------------------------*
           if        w-tes-tip-ope        =    0350
                     go to cnt-imp-pt2-999.
      *                  *---------------------------------------------*
      *                  * Se il buffer scadenze debitori di un solo   *
      *                  * tipo e quello di tutti i tipi,  non conten- *
      *                  * gono elementi, la pagina non e' da trattare *
      *                  *---------------------------------------------*
           if        w-bsu-num-ele        =    zero and
                     w-bst-num-ele        =    zero
                     go to cnt-imp-pt2-999.
      *                  *---------------------------------------------*
      *                  * Altrimenti, la pagina e' da trattare        *
      *                  *---------------------------------------------*
           go to     cnt-imp-pt2-100.
       cnt-imp-pt2-100.
      *              *-------------------------------------------------*
      *              * Selezione su tipo scadenza debitore             *
      *              *-------------------------------------------------*
           if        w-tes-sel-tsc (1)    not  = zero and
                     w-tes-sel-tsc (1)    not  > w-exp-sel-tsc-num
                     go to cnt-imp-pt2-120.
           move      "Manca la definizione del tipo scadenza da selezion
      -              "are !          "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt2-900.
       cnt-imp-pt2-120.
      *              *-------------------------------------------------*
      *              * Selezione scadenze debitore                     *
      *              *-------------------------------------------------*
           if        w-tes-sel-sdb (1)    not  = zero and
                     w-tes-sel-sdb (1)    not  > w-exp-sel-sdb-num
                     go to cnt-imp-pt2-160.
           move      "Manca la definizione delle scadenze da selezionare
      -              " !             "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt2-900.
       cnt-imp-pt2-160.
      *              *-------------------------------------------------*
      *              * Data scadenza iniziale e finale                 *
      *              *-------------------------------------------------*
           if        w-tes-sel-sdb (1)    not  = 03
                     go to cnt-imp-pt2-180.
           if        w-tes-sel-dsi (1)    =    zero or
                     w-tes-sel-dsf (1)    =    zero
                     go to cnt-imp-pt2-180.
           if        w-tes-sel-dsf (1)    not  < w-tes-sel-dsi (1)
                     go to cnt-imp-pt2-180.
           move      "Data periodo iniziale superiore a quella finale ! 
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt2-900.
       cnt-imp-pt2-180.
      *              *-------------------------------------------------*
      *              * Mese da selezionare                             *
      *              *-------------------------------------------------*
           if        w-tes-sel-sdb (1)    not  = 04
                     go to cnt-imp-pt2-200.
           if        w-tes-sel-mes (1)    not  = zero and
                     w-tes-sel-mes (1)    not  > w-exp-sel-mes-num
                     go to cnt-imp-pt2-200.
           move      "Manca il mese da selezionare !                    
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-imp-pt2-900.
       cnt-imp-pt2-200.
      *              *-------------------------------------------------*
      *              * Fine controlli                                  *
      *              *-------------------------------------------------*
       cnt-imp-pt2-800.
      *              *-------------------------------------------------*
      *              * Normalizzazioni                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Data scadenza finale                        *
      *                  *---------------------------------------------*
           if        w-tes-sel-sdb (1)    not  = 03
                     go to cnt-imp-pt2-820.
           if        w-tes-sel-dsf (1)    not  = zero
                     go to cnt-imp-pt2-820.
           if        w-tes-sel-dsi (1)    =    zero
                     move  w-tes-sel-dsi (1)
                                          to   w-tes-sel-dsf (1)
           else      move  9999999        to   w-tes-sel-dsf (1)      .
       cnt-imp-pt2-820.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     cnt-imp-pt2-999.
       cnt-imp-pt2-900.
      *              *-------------------------------------------------*
      *              * Se controllo non superato                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di errore in uscita                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-imp-pt2-flg      .
       cnt-imp-pt2-999.
           exit.
           
      *    *===========================================================*
      *    * Determinazione del buffer scadenze debitore di lavoro     *
      *    *-----------------------------------------------------------*
       det-buf-sdb-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-buf-sdb-flg      .
      *              *-------------------------------------------------*
      *              * Se tipo operazione, Compensazione, si seleziona *
      *              * il buffer scadenze di tutti i tipi              *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        =    0350
                     go to det-buf-sdb-200.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo scadenze debi-  *
      *              * tore selezionato                                *
      *              *-------------------------------------------------*
           go to     det-buf-sdb-100
                     det-buf-sdb-200
                     depending            on  w-tes-sel-tsc (1)       .
       det-buf-sdb-100.
      *              *-------------------------------------------------*
      *              * Se selezionato buffer scadenze di un tipo       *
      *              *-------------------------------------------------*
           move      w-bsu                to   w-bsd                  .
      *              *-------------------------------------------------*
      *              * A controlli finali                              *
      *              *-------------------------------------------------*
           go to     det-buf-sdb-700.
       det-buf-sdb-200.
      *              *-------------------------------------------------*
      *              * Se selezionato buffer scadenze di tutti i tipi  *
      *              *-------------------------------------------------*
           move      w-bst                to   w-bsd                  .
      *              *-------------------------------------------------*
      *              * A controlli finali                              *
      *              *-------------------------------------------------*
           go to     det-buf-sdb-700.
       det-buf-sdb-700.
      *              *-------------------------------------------------*
      *              * Controlli finali                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se numero scadenze nel buffer maggiore di   *
      *                  * zero : controllo superato, e ad uscita      *
      *                  *---------------------------------------------*
           if        w-bsd-num-ele        >    zero
                     go to det-buf-sdb-900.
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           move      "Non e' stata selezionata alcuna scadenza su cui op
      -              "erare !        "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di uscita ad errore                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-det-buf-sdb-flg      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     det-buf-sdb-900.
       det-buf-sdb-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-buf-sdb-999.
       det-buf-sdb-999.
           exit.

      *    *===========================================================*
      *    * Selezione preliminare scadenze debitore                   *
      *    *-----------------------------------------------------------*
       sel-pre-sdb-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione totale scadenze selezionate     *
      *              *-------------------------------------------------*
           move      zero                 to   w-tes-tot-scs (1)      .
      *              *-------------------------------------------------*
      *              * Normalizzazione prima scadenza selezionata      *
      *              *-------------------------------------------------*
           move      zero                 to   w-sel-pre-sdb-pss      .
      *              *-------------------------------------------------*
      *              * Determinazione data scadenza iniziale e finale  *
      *              * in funzione della selezione scadenze debitore   *
      *              *-------------------------------------------------*
           go to     sel-pre-sdb-100
                     sel-pre-sdb-200
                     sel-pre-sdb-300
                     sel-pre-sdb-400
                     depending            on   w-tes-sel-sdb (1)      .
       sel-pre-sdb-100.
      *              *-------------------------------------------------*
      *              * Selezione scadenze : manuale                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     sel-pre-sdb-999.
       sel-pre-sdb-200.
      *              *-------------------------------------------------*
      *              * Selezione scadenze : Piu' vecchie               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se importo riscosso a zero : uscita         *
      *                  *---------------------------------------------*
           if        w-tes-imp-rsd (1)    =    zero
                     go to sel-pre-sdb-999.
      *                  *---------------------------------------------*
      *                  * Data iniziale                               *
      *                  *---------------------------------------------*
           move      zero                 to   w-sel-pre-sdb-wdi      .
      *                  *---------------------------------------------*
      *                  * Data finale                                 *
      *                  *---------------------------------------------*
           move      9999999              to   w-sel-pre-sdb-wdf      .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     sel-pre-sdb-500.
       sel-pre-sdb-300.
      *              *-------------------------------------------------*
      *              * Selezione scadenze : Per periodo                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Data iniziale                               *
      *                  *---------------------------------------------*
           move      w-tes-sel-dsi (1)    to   w-sel-pre-sdb-wdi      .
      *                  *---------------------------------------------*
      *                  * Data finale                                 *
      *                  *---------------------------------------------*
           move      w-tes-sel-dsf (1)    to   w-sel-pre-sdb-wdf      .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     sel-pre-sdb-500.
       sel-pre-sdb-400.
      *              *-------------------------------------------------*
      *              * Selezione scadenze : Mensile                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione indice per mese                *
      *                  *---------------------------------------------*
           move      w-tes-sel-mes (1)    to   w-sel-pre-sdb-inx      .
      *                  *---------------------------------------------*
      *                  * Data iniziale                               *
      *                  *---------------------------------------------*
           move      w-tes-sel-tpm-saa
                    (1, w-sel-pre-sdb-inx)
                                          to   s-saa                  .
           move      w-tes-sel-tpm-mes
                    (1, w-sel-pre-sdb-inx)
                                          to   s-mes                  .
           move      01                   to   s-gio                  .
           move      s-dat                to   w-sel-pre-sdb-wdi      .
      *                  *---------------------------------------------*
      *                  * Data finale                                 *
      *                  *---------------------------------------------*
           move      w-sel-pre-sdb-wdi    to   s-dat                  .
           move      31                   to   s-gio                  .
       sel-pre-sdb-405.
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                not  = spaces
                     subtract 1           from s-gio
                     go to sel-pre-sdb-405.
           move      s-dat                to   w-sel-pre-sdb-wdf      .
      *                  *---------------------------------------------*
      *                  * Eventuali aggiustamenti                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Eventuale correzione data iniziale, se  *
      *                      * selezionato 'Anteriori'                 *
      *                      *-----------------------------------------*
           if        w-tes-sel-mes (1)    =    01
                     move  zero           to   w-sel-pre-sdb-wdi      .
      *                      *-----------------------------------------*
      *                      * Eventuale correzione data finale, se    *
      *                      * selezionato 'Successivi'                *
      *                      *-----------------------------------------*
           if        w-tes-sel-mes (1)    =    07
                     move  9999999        to   w-sel-pre-sdb-wdf      .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     sel-pre-sdb-500.
       sel-pre-sdb-500.
      *              *-------------------------------------------------*
      *              * Ciclo di preselezione su buffer scadenze debi-  *
      *              * tore                                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione work per accumulo           *
      *                  *---------------------------------------------*
           move      zero                 to   w-tes-tot-scs (1)      .
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione buffer elementi          *
      *                  *---------------------------------------------*
           move      zero                 to   w-sel-pre-sdb-ctr      .
       sel-pre-sdb-510.
           add       1                    to   w-sel-pre-sdb-ctr      .
           if        w-sel-pre-sdb-ctr    >    w-bsd-num-ele
                     move  w-bsd-num-ele  to   w-sel-pre-sdb-ctr
                     go to sel-pre-sdb-600.
      *                      *-----------------------------------------*
      *                      * Ricerca della prima scadenza utile      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se scadenza a vista                 *
      *                          *-------------------------------------*
           if        w-bsd-dts-sdb
                    (w-sel-pre-sdb-ctr)   not  = zero
                     go to sel-pre-sdb-512.
           if        w-tes-dat-reg        <    w-sel-pre-sdb-wdi
                     go to sel-pre-sdb-510.
           go to     sel-pre-sdb-520.
       sel-pre-sdb-512.
      *                          *-------------------------------------*
      *                          * Se scadenza normale                 *
      *                          *-------------------------------------*
           if        w-bsd-dts-sdb
                    (w-sel-pre-sdb-ctr)   <    w-sel-pre-sdb-wdi
                     go to sel-pre-sdb-510.
           go to     sel-pre-sdb-520.
       sel-pre-sdb-520.
      *                      *-----------------------------------------*
      *                      * Memorizzazione prima scadenza selezio-  *
      *                      * nabile                                  *
      *                      *-----------------------------------------*
           move      w-sel-pre-sdb-ctr    to   w-sel-pre-sdb-pss      .
      *                      *-----------------------------------------*
      *                      * Test su data scadenza finale            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se scadenza a vista                 *
      *                          *-------------------------------------*
           if        w-bsd-dts-sdb
                    (w-sel-pre-sdb-ctr)   not  = zero
                     go to sel-pre-sdb-522.
           if        w-tes-dat-reg        >    w-sel-pre-sdb-wdf
                     subtract 1           from w-sel-pre-sdb-ctr
                     go to sel-pre-sdb-600.
           go to     sel-pre-sdb-530.
       sel-pre-sdb-522.
      *                          *-------------------------------------*
      *                          * Se scadenza normale                 *
      *                          *-------------------------------------*
           if        w-bsd-dts-sdb
                    (w-sel-pre-sdb-ctr)   >    w-sel-pre-sdb-wdf
                     subtract 1           from w-sel-pre-sdb-ctr
                     go to sel-pre-sdb-600.
           go to     sel-pre-sdb-530.
       sel-pre-sdb-530.
      *                      *-----------------------------------------*
      *                      * Aggiornamento elemento del buffer       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Importo riscosso                    *
      *                          *-------------------------------------*
           move      w-bsd-imp-sdb
                    (w-sel-pre-sdb-ctr)   to   w-bsd-imp-ris
                                              (w-sel-pre-sdb-ctr)     .
      *                          *-------------------------------------*
      *                          * Segnale acconto/saldo               *
      *                          *-------------------------------------*
           move      01                   to   w-bsd-aos-ris
                                              (w-sel-pre-sdb-ctr)     .
      *                      *-----------------------------------------*
      *                      * Aggiornamento totale scadenze selezio-  *
      *                      * nate                                    *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        =    0301 or
                     w-tes-tip-ope        =    0302 or
                     w-tes-tip-ope        =    0303 or
                     w-tes-tip-ope        =    0304
                     add      w-bsd-imp-sdb
                             (w-sel-pre-sdb-ctr)
                                          to   w-tes-tot-scs (1)
           else if   w-tes-tip-ope        =    0321 or
                     w-tes-tip-ope        =    0322 or
                     w-tes-tip-ope        =    0323 or
                     w-tes-tip-ope        =    0324
                     subtract w-bsd-imp-sdb
                             (w-sel-pre-sdb-ctr)
                                          from w-tes-tot-scs (1)      .
      *                      *-----------------------------------------*
      *                      * Se importo riscosso a zero : riciclo    *
      *                      *-----------------------------------------*
           if        w-tes-imp-rsd (1)    =    zero
                     go to sel-pre-sdb-510.
      *                      *-----------------------------------------*
      *                      * Se totale scadenze selezionate pari al- *
      *                      * l'importo riscosso dichiarato : uscita  *
      *                      *-----------------------------------------*
           if        w-tes-tot-scs (1)    =    w-tes-imp-rsd (1)
                     go to sel-pre-sdb-999.
      *                      *-----------------------------------------*
      *                      * Se totale scadenze selezionate superio- *
      *                      * re all'importo riscosso dichiarato, ol- *
      *                      * tre                                     *
      *                      *-----------------------------------------*
           if        w-tes-tot-scs (1)    >    w-tes-imp-rsd (1)
                     go to sel-pre-sdb-600.
      *                      *-----------------------------------------*
      *                      * Altrimenti, riciclo su scansione        *
      *                      *-----------------------------------------*
           go to     sel-pre-sdb-510.
       sel-pre-sdb-600.
      *              *-------------------------------------------------*
      *              * Eventuale aggiustamento ultimo elemento sele-   *
      *              * zionato                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se importo riscosso a zero : uscita         *
      *                  *---------------------------------------------*
           if        w-tes-imp-rsd (1)    =    zero
                     go to sel-pre-sdb-999.
      *                  *---------------------------------------------*
      *                  * Se contatore a zero : uscita                *
      *                  *---------------------------------------------*
           if        w-sel-pre-sdb-ctr    =    zero
                     go to sel-pre-sdb-999.
      *                  *---------------------------------------------*
      *                  * Aggiustamento                               *
      *                  *---------------------------------------------*
           subtract  w-tes-tot-scs (1)    from w-tes-imp-rsd (1)
                                        giving w-sel-pre-sdb-s11      .
           add       w-sel-pre-sdb-s11    to   w-bsd-imp-ris
                                              (w-sel-pre-sdb-ctr)     .
           move      02                   to   w-bsd-aos-ris
                                              (w-sel-pre-sdb-ctr)     .
           add       w-sel-pre-sdb-s11    to   w-tes-tot-scs (1)      .
       sel-pre-sdb-999.
           exit.

      *    *===========================================================*
      *    * Caricamento catena scadenze debitore                      *
      *    *-----------------------------------------------------------*
       car-cat-sdb-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-car-cat-sdb-flg      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione buffer scadenze debitore     *
      *              *-------------------------------------------------*
           move      zero                 to   w-car-cat-sdb-ctr      .
       car-cat-sdb-100.
           add       1                    to   w-car-cat-sdb-ctr      .
           if        w-car-cat-sdb-ctr    >    w-bsd-num-ele
                     go to car-cat-sdb-999.
      *                  *---------------------------------------------*
      *                  * Append in catena                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se Append non possibile : uscita con    *
      *                      * errore                                  *
      *                      *-----------------------------------------*
           if        w-cat-rig-app        not  = spaces
                     go to car-cat-sdb-900.
      *                      *-----------------------------------------*
      *                      * Append                                  *
      *                      *-----------------------------------------*
           move      "AP"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       car-cat-sdb-200.
      *                  *---------------------------------------------*
      *                  * Normalizzazione riga                        *
      *                  *---------------------------------------------*
           perform   nor-nok-rig-000      thru nor-nok-rig-999        .
      *                  *---------------------------------------------*
      *                  * Composizione riga                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Aggiornamento del numero progressivo    *
      *                      *-----------------------------------------*
           perform   prg-rig-cor-000      thru prg-rig-cor-999        .
      *                      *-----------------------------------------*
      *                      * Data registrazione contabilita' per     *
      *                      * l'emissione                             *
      *                      *-----------------------------------------*
           move      w-bsd-drc-emi
                    (w-car-cat-sdb-ctr)   to   w-rig-drc-emi (1)      .
      *                      *-----------------------------------------*
      *                      * Numero protocollo contabilita' per l'e- *
      *                      * missione                                *
      *                      *-----------------------------------------*
           move      w-bsd-npc-emi
                    (w-car-cat-sdb-ctr)   to   w-rig-npc-emi (1)      .
      *                      *-----------------------------------------*
      *                      * Numero protocollo fattura cliente       *
      *                      *-----------------------------------------*
           move      w-bsd-prt-fcl
                    (w-car-cat-sdb-ctr)   to   w-rig-prt-fcl (1)      .
      *                      *-----------------------------------------*
      *                      * Codice agente                           *
      *                      *-----------------------------------------*
           move      w-bsd-cod-age
                    (w-car-cat-sdb-ctr)   to   w-rig-cod-age (1)      .
      *                      *-----------------------------------------*
      *                      * Numero scadenza debitore                *
      *                      *-----------------------------------------*
           move      w-bsd-num-sdb
                    (w-car-cat-sdb-ctr)   to   w-rig-num-sdb (1)      .
      *                      *-----------------------------------------*
      *                      * Tipo scadenza debitore                  *
      *                      *-----------------------------------------*
           move      w-bsd-tip-sdb
                    (w-car-cat-sdb-ctr)   to   w-rig-tip-sdb (1)      .
      *                      *-----------------------------------------*
      *                      * Si/No dilazione concordata              *
      *                      *-----------------------------------------*
           move      w-bsd-snx-dlc
                    (w-car-cat-sdb-ctr)   to   w-rig-snx-dlc (1)      .
      *                      *-----------------------------------------*
      *                      * Si/No contrassegno                      *
      *                      *-----------------------------------------*
           move      w-bsd-snx-cts
                    (w-car-cat-sdb-ctr)   to   w-rig-snx-cts (1)      .
      *                      *-----------------------------------------*
      *                      * Si/No scadenza ritornata insoluta       *
      *                      *-----------------------------------------*
           move      w-bsd-snx-ins
                    (w-car-cat-sdb-ctr)   to   w-rig-snx-ins (1)      .
      *                      *-----------------------------------------*
      *                      * Tipo acquisizione scadenza debitore     *
      *                      *-----------------------------------------*
           move      w-bsd-tac-sdb
                    (w-car-cat-sdb-ctr)   to   w-rig-tac-sdb (1)      .
      *                      *-----------------------------------------*
      *                      * Tipo valuta scadenza debitore           *
      *                      *-----------------------------------------*
           move      w-bsd-tvl-sdb
                    (w-car-cat-sdb-ctr)   to   w-rig-tvl-sdb (1)      .
      *                      *-----------------------------------------*
      *                      * Data scadenza                           *
      *                      *-----------------------------------------*
           move      w-bsd-dts-sdb
                    (w-car-cat-sdb-ctr)   to   w-rig-dts-sdb (1)      .
      *                      *-----------------------------------------*
      *                      * Codice dipendenza del debitore          *
      *                      *-----------------------------------------*
           move      w-bsd-dpz-dbt
                    (w-car-cat-sdb-ctr)   to   w-rig-dpz-dbt (1)      .
      *                      *-----------------------------------------*
      *                      * Inoltro scadenza al debitore            *
      *                      *-----------------------------------------*
           move      w-bsd-inl-sdb
                    (w-car-cat-sdb-ctr)   to   w-rig-inl-sdb (1)      .
      *                      *-----------------------------------------*
      *                      * Importo scadenza                        *
      *                      *-----------------------------------------*
           move      w-bsd-imp-sdb
                    (w-car-cat-sdb-ctr)   to   w-rig-imp-sdb (1)      .
      *                      *-----------------------------------------*
      *                      * Numero scadenza di origine              *
      *                      *-----------------------------------------*
           move      w-bsd-nsc-org
                    (w-car-cat-sdb-ctr)   to   w-rig-nsc-org (1)      .
      *                      *-----------------------------------------*
      *                      * Data documento di riferimento           *
      *                      *-----------------------------------------*
           move      w-bsd-dat-ddr
                    (w-car-cat-sdb-ctr)   to   w-rig-dat-ddr (1)      .
      *                      *-----------------------------------------*
      *                      * Numero documento di riferimento         *
      *                      *-----------------------------------------*
           move      w-bsd-num-ddr
                    (w-car-cat-sdb-ctr)   to   w-rig-num-ddr (1)      .
      *                      *-----------------------------------------*
      *                      * Tipo documento di riferimento           *
      *                      *-----------------------------------------*
           move      w-bsd-tip-ddr
                    (w-car-cat-sdb-ctr)   to   w-rig-tip-ddr (1)      .
      *                      *-----------------------------------------*
      *                      * Importo documento di riferimento        *
      *                      *-----------------------------------------*
           move      w-bsd-imp-ddr
                    (w-car-cat-sdb-ctr)   to   w-rig-imp-ddr (1)      .
      *                      *-----------------------------------------*
      *                      * Numero rata documento di riferimento    *
      *                      *-----------------------------------------*
           move      w-bsd-nra-ddr
                    (w-car-cat-sdb-ctr)   to   w-rig-nra-ddr (1)      .
      *                      *-----------------------------------------*
      *                      * Codice ABI per la presentazione         *
      *                      *-----------------------------------------*
           move      w-bsd-abi-app
                    (w-car-cat-sdb-ctr)   to   w-rig-abi-app (1)      .
      *                      *-----------------------------------------*
      *                      * Codice CAB per la presentazione         *
      *                      *-----------------------------------------*
           move      w-bsd-cab-app
                    (w-car-cat-sdb-ctr)   to   w-rig-cab-app (1)      .
      *                      *-----------------------------------------*
      *                      * Codice c/c per la presentazione         *
      *                      *-----------------------------------------*
           move      w-bsd-ccc-app
                    (w-car-cat-sdb-ctr)   to   w-rig-ccc-app (1)      .
      *                      *-----------------------------------------*
      *                      * Codice nostra banca o c/c postale       *
      *                      *-----------------------------------------*
           move      w-bsd-cod-cbp
                    (w-car-cat-sdb-ctr)   to   w-rig-cod-cbp (1)      .
      *                      *-----------------------------------------*
      *                      * Importo riscosso : se operazione di     *
      *                      * Compensazione, importo scadenza; se al- *
      *                      * tro tipo operazione, importo riscosso   *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        =    0350
                     move  w-bsd-imp-sdb
                          (w-car-cat-sdb-ctr)
                                          to   w-rig-imp-ris (1)
           else      move  w-bsd-imp-ris
                          (w-car-cat-sdb-ctr)
                                          to   w-rig-imp-ris (1)      .
      *                      *-----------------------------------------*
      *                      * Segnale Acconto/Saldo : se operazione   *
      *                      * di Compensazione, zero; se altro tipo   *
      *                      * operazione, il valore contenuto nel     *
      *                      * buffer                                  *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        =    0350
                     move  zero           to   w-rig-aos-ris (1)
           else      move  w-bsd-aos-ris
                          (w-car-cat-sdb-ctr)
                                          to   w-rig-aos-ris (1)      .
      *                      *-----------------------------------------*
      *                      * Data registrazione movimento di insolu- *
      *                      * to                                      *
      *                      *-----------------------------------------*
           move      w-bsd-dtr-isp
                    (w-car-cat-sdb-ctr)   to   w-rig-dtr-isp (1)      .
      *                      *-----------------------------------------*
      *                      * Ultimo livello di sollecito cui e' sta- *
      *                      * ta sottoposta la scadenza               *
      *                      *-----------------------------------------*
           move      w-bsd-liv-slc
                    (w-car-cat-sdb-ctr)   to   w-rig-liv-slc (1)      .
      *                      *-----------------------------------------*
      *                      * Data sollecito 1                        *
      *                      *-----------------------------------------*
           move      w-bsd-dso-l01
                    (w-car-cat-sdb-ctr)   to   w-rig-dso-l01 (1)      .
      *                      *-----------------------------------------*
      *                      * Data sollecito 2                        *
      *                      *-----------------------------------------*
           move      w-bsd-dso-l02
                    (w-car-cat-sdb-ctr)   to   w-rig-dso-l02 (1)      .
      *                      *-----------------------------------------*
      *                      * Data sollecito 3                        *
      *                      *-----------------------------------------*
           move      w-bsd-dso-l03
                    (w-car-cat-sdb-ctr)   to   w-rig-dso-l03 (1)      .
      *                      *-----------------------------------------*
      *                      * Se la scadenza proviene da un'altra,    *
      *                      * determinazione dello status della sca-  *
      *                      * denza di origine                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test su numero scadenza di origine  *
      *                          *-------------------------------------*
           if        w-rig-nsc-org (1)    =    zero
                     go to car-cat-sdb-700.
      *                          *-------------------------------------*
      *                          * Normalizzazione record [sdb]        *
      *                          *-------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                          *-------------------------------------*
      *                          * Lettura record [sdb]                *
      *                          *-------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMSDB    "         to   f-key                  .
           move      w-rig-nsc-org (1)    to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                          *-------------------------------------*
      *                          * Status scadenza di origine          *
      *                          *-------------------------------------*
           perform   det-sts-sdb-000      thru det-sts-sdb-999        .
      *                          *-------------------------------------*
      *                          * Evenuale segnale di scadenza prove- *
      *                          * niente da compensazione             *
      *                          *-------------------------------------*
           if        w-det-sts-sdb-suo    =    "CMP"
                     move  "*"            to   w-rig-flg-snc (1)
           else      move  spaces         to   w-rig-flg-snc (1)      .
       car-cat-sdb-700.
      *                  *---------------------------------------------*
      *                  * Update catena                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-max        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       car-cat-sdb-800.
      *              *-------------------------------------------------*
      *              * Riciclo scansione buffer scadenze debitore      *
      *              *-------------------------------------------------*
           go to     car-cat-sdb-100.
       car-cat-sdb-900.
      *              *-------------------------------------------------*
      *              * Messaggio di errore per esubero numero righe    *
      *              *-------------------------------------------------*
           move      "Numero scadenze da trattare oltre il massimo previ
      -              "sto !          "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *              *-------------------------------------------------*
      *              * Flag di uscita ad errore                        *
      *              *-------------------------------------------------*
           move      "#"                  to   w-car-cat-sdb-flg      .
       car-cat-sdb-999.
           exit.

      *    *===========================================================*
      *    * Determinazione si/no corpo da trattare                    *
      *    *-----------------------------------------------------------*
       snp-cor-reg-000.
      *              *-------------------------------------------------*
      *              * Flag di uscita a Si                             *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-sts-imp-snc      .
      *              *-------------------------------------------------*
      *              * Se tipo riscossione : Anticipo                  *
      *              *-------------------------------------------------*
           if        w-tes-tip-rsd (1)    not  = 02
                     go to snp-cor-reg-999.
      *                  *---------------------------------------------*
      *                  * Flag di uscita a No                         *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-sts-imp-snc      .
      *                  *---------------------------------------------*
      *                  * Assestamento status di impostazione corpo   *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-sts-imp-cor      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     snp-cor-reg-999.
       snp-cor-reg-999.
           exit.

      *    *===========================================================*
      *    * Accettazione corpo a partire dalla riga con numero d'or-  *
      *    * dine : w-cnt-cor-nrg-dac                                  *
      *    *-----------------------------------------------------------*
       acc-cor-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione tipo uscita da corpo            *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-cor      .
      *              *-------------------------------------------------*
      *              * Confronto tra numero d'ordine riga da accettare *
      *              * e numero d'ordine dell'ultima riga              *
      *              *-------------------------------------------------*
           if        w-cnt-cor-nrg-dac    not  > w-cat-rig-max
                     go to acc-cor-reg-025.
      *              *-------------------------------------------------*
      *              * Se oltre numero riga massimo si esce con status *
      *              * di uscita "+", dopo aver rivisualizzato la pa-  *
      *              * gina se si proviene da un Remv                  *
      *              *-------------------------------------------------*
           if        w-cnt-tus-acc-rig    =    "R"
                     perform vis-cor-reg-000
                                          thru vis-cor-reg-999        .
           move      "+"                  to   w-cnt-tus-acc-cor      .
           go to     acc-cor-reg-990.
       acc-cor-reg-025.
      *              *-------------------------------------------------*
      *              * Video in 'OFF'                                  *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Prompts per corpo                               *
      *              *-------------------------------------------------*
           if        w-cnt-sts-pmt-cor    =    spaces
                     perform pmt-cor-reg-000
                                          thru pmt-cor-reg-999
                     move    "#"          to   w-cnt-sts-pmt-cor      .
      *              *-------------------------------------------------*
      *              * Visualizzazione dati corpo                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione nr pagina da visualizzare    *
      *                  *---------------------------------------------*
           move      w-cnt-cor-nrg-dac    to   w-cnt-cor-nrp-dav      .
           add       w-lin-num-lin-vis    to   w-cnt-cor-nrp-dav      .
           subtract  1                    from w-cnt-cor-nrp-dav      .
           divide    w-lin-num-lin-vis    into w-cnt-cor-nrp-dav      .
      *                  *---------------------------------------------*
      *                  * Se non e' visualizzata nessuna pagina corpo *
      *                  * o una pagina corpo diversa da quella da vi- *
      *                  * sualizzare si procede alla visualizzazione  *
      *                  *---------------------------------------------*
           if        w-cnt-sts-vis-cor    =    spaces           or
                     w-cnt-cor-nrp-vis    not  = w-cnt-cor-nrp-dav
                     perform vis-cor-reg-000
                                          thru vis-cor-reg-999
                     move    "#"          to   w-cnt-sts-vis-cor
                     move    w-cnt-cor-nrp-dav
                                          to   w-cnt-cor-nrp-vis      .
      *              *-------------------------------------------------*
      *              * Lettura riga da catena                          *
      *              *-------------------------------------------------*
           move      "RD"                 to   w-cat-rig-ope          .
           move      w-cnt-cor-nrg-dac    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se riga nuova si normalizza il corpo            *
      *              *-------------------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to acc-cor-reg-050.
           perform   nor-nok-rig-000      thru nor-nok-rig-999        .
           move      w-rig-val-aep (1)    to   w-rig-val-aep (2)      .
       acc-cor-reg-050.
      *              *-------------------------------------------------*
      *              * Routine pre-accettazione riga corpo             *
      *              *-------------------------------------------------*
           perform   pre-rig-cor-000      thru pre-rig-cor-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts per riga d'accettazione *
      *              *-------------------------------------------------*
           perform   pmt-rig-cor-000      thru pmt-rig-cor-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione dati per riga di accettazione   *
      *              *-------------------------------------------------*
           perform   vis-rig-cor-000      thru vis-rig-cor-999        .
      *              *-------------------------------------------------*
      *              * Video in 'ON'                                   *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Flag di status impostazione corpo               *
      *              *-------------------------------------------------*
           if        w-cat-rig-max        =    zero
                     move  spaces         to   w-cnt-sts-imp-cor
           else      move  "#"            to   w-cnt-sts-imp-cor      .
           if        w-cat-rig-max        =    1        and
                     w-cat-rig-new        not  = spaces and
                     w-cat-rig-lst        not  = spaces
                     move  spaces         to   w-cnt-sts-imp-cor      .
      *              *-------------------------------------------------*
      *              * Flag di status impostione riga attuale          *
      *              *-------------------------------------------------*
           if        w-cat-rig-new        =    spaces
                     move  "#"            to   w-cnt-sts-imp-rig
           else      move  spaces         to   w-cnt-sts-imp-rig      .
      *              *-------------------------------------------------*
      *              * Indicatore linea in corso di trattamento        *
      *              *-------------------------------------------------*
           move      "I"                  to   w-cnt-cor-tvi-rig      .
           move      w-cnt-cor-nrg-dac    to   w-cnt-cor-nrg-dav      .
           perform   vis-lin-cor-000      thru vis-lin-cor-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazione tipo uscita da riga corpo       *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-rig      .
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di non-incremento numero   *
      *              * riga da accettare                               *
      *              *-------------------------------------------------*
           move      spaces               to   w-acc-cor-reg-fni      .
       acc-cor-reg-100.
      *              *-------------------------------------------------*
      *              * Accettazioni                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo impostazione : primo campo riga corpo  *
      *                  *---------------------------------------------*
           move      "C"                  to   w-cnt-mfu-tip-imp      .
      *                  *---------------------------------------------*
      *                  * Accettazione importo riscosso               *
      *                  *---------------------------------------------*
           perform   acc-imp-ris-000      thru acc-imp-ris-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-925.
      *                  *---------------------------------------------*
      *                  * Tipo impostazione : altri campi riga corpo  *
      *                  *---------------------------------------------*
           move      "R"                  to   w-cnt-mfu-tip-imp      .
       acc-cor-reg-200.
      *                  *---------------------------------------------*
      *                  * Normalizzazione func-key di impostazione    *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Accettazione numero scadenza per Inserimen- *
      *                  * to                                          *
      *                  *---------------------------------------------*
           perform   acc-num-sdb-000      thru acc-num-sdb-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
       acc-cor-reg-800.
      *              *-------------------------------------------------*
      *              * Controllo finale su riga impostata              *
      *              *-------------------------------------------------*
           perform   cnt-tdo-rig-000      thru cnt-tdo-rig-999        .
           if        w-cnt-tdo-rig-flg    not  = spaces
                     move  spaces         to   w-cnt-tdo-rig-flg
                     move  "UP  "         to   v-key
                     go to acc-cor-reg-200.
       acc-cor-reg-900.
      *              *-------------------------------------------------*
      *              * Tests per uscita significativa da interno riga  *
      *              *-------------------------------------------------*
           if        w-cnt-tus-acc-rig    =    spaces or
                     w-cnt-tus-acc-rig    =    "S"
                     go to acc-cor-reg-905
           else if   w-cnt-tus-acc-rig    =    "R"
                     go to acc-cor-reg-910.
      *                  *---------------------------------------------*
      *                  * Se Exit da interno riga                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga New funzionamento come per Remv *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to acc-cor-reg-915.
      *                      *-----------------------------------------*
      *                      * Se riga non New                         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Visualizzazione numero riga         *
      *                          *-------------------------------------*
           move      "N"                  to   w-cnt-cor-tvi-rig      .
           move      w-cnt-cor-nrg-dac    to   w-cnt-cor-nrg-dav      .
           perform   vis-lin-cor-000      thru vis-lin-cor-999        .
           go to     acc-cor-reg-000.
       acc-cor-reg-905.
      *                  *---------------------------------------------*
      *                  * Se Do da interno riga                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se record di tipo New attribuzione del  *
      *                      * numero progressivo per la riga          *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to acc-cor-reg-907.
           perform   prg-rig-cor-000      thru prg-rig-cor-999        .
       acc-cor-reg-907.
      *                      *-----------------------------------------*
      *                      * Routine post-accettazione riga          *
      *                      *-----------------------------------------*
           move      "+"                  to   w-cnt-cor-tip-agg      .
           perform   pos-rig-cor-000      thru pos-rig-cor-999        .
      *                      *-----------------------------------------*
      *                      * Update riga in catena movimenti         *
