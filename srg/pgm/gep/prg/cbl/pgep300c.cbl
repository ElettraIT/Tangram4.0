      *    *===========================================================*
      *    * Routine post-conferma di annullamento                     *
      *    *-----------------------------------------------------------*
       pos-cnf-ann-000.
      *              *-------------------------------------------------*
      *              * Trattamento scadenza a fronte della riscossione *
      *              * di tipo anticipato                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da effettuare                       *
      *                  *---------------------------------------------*
           if        w-tes-tip-ope        not  = 0301 and
                     w-tes-tip-ope        not  = 0302 and
                     w-tes-tip-ope        not  = 0303 and
                     w-tes-tip-ope        not  = 0304
                     go to pos-cnf-ann-100.
           if        w-tes-tip-rsd (1)    not  = 02
                     go to pos-cnf-ann-100.
      *                  *---------------------------------------------*
      *                  * Cancellazione record nuova scadenza genera- *
      *                  * ta a fronte della riscossione di tipo anti- *
      *                  * cipato                                      *
      *                  *---------------------------------------------*
           perform   del-sdb-rsa-000      thru del-sdb-rsa-999        .
       pos-cnf-ann-100.
      *              *-------------------------------------------------*
      *              * Trattamento aggiornamento contabile per il mo-  *
      *              * vimento di riscossione                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Annullamento del movimento di contabilita'  *
      *                  * generale che era stato a suo tempo genera-  *
      *                  * to a fronte del movimento di riscossione    *
      *                  *---------------------------------------------*
           move      "DE"                 to   l-cge-300-tip-ope      .
           move      w-tes-drc-rsd (2)    to   l-cge-300-dat-reg      .
           move      w-tes-npc-rsd (2)    to   l-cge-300-num-prt      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
       pos-cnf-ann-150.
      *              *-------------------------------------------------*
      *              * Testata riscossione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Annullamento record [rsd]                   *
      *                  *---------------------------------------------*
           move      "DE"                 to   f-ope                  .
           move      w-tes-num-rsd        to   rf-rsd-num-rsd         .
           move      "pgm/gep/fls/ioc/obj/iofrsd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-rsd                 .
       pos-cnf-ann-400.
      *              *-------------------------------------------------*
      *              * Righe riscossione                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da effettuare                       *
      *                  *---------------------------------------------*
           if       (w-tes-tip-ope        =    0301 or
                     w-tes-tip-ope        =    0302 or
                     w-tes-tip-ope        =    0303 or
                     w-tes-tip-ope        =    0304  ) and
                    (w-tes-tip-rsd (1)    not  = 01  )
                     go to pos-cnf-ann-600.
      *                  *---------------------------------------------*
      *                  * Normalizzazione di tutte le righe attuali   *
      *                  * relative alla riscossione.                  *
      *                  * Viene utilizzato il buffer w-bsd per memo-  *
      *                  * rizzare i numeri delle nuove scadenze ge-   *
      *                  * nerate a fronte della riscossione           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione numero elementi nel     *
      *                      * buffer                                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-bsd-num-ele          .
      *                      *-----------------------------------------*
      *                      * Start su file [sdb]                     *
      *                      *-----------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "RISSDB    "         to   f-key                  .
           move      w-tes-num-rsd        to   rf-sdb-num-ris         .
           move      zero                 to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                          *-------------------------------------*
      *                          * Test su esito operazione            *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to pos-cnf-ann-500.
       pos-cnf-ann-420.
      *                      *-----------------------------------------*
      *                      * Ottenimento sequenziale record [sdb]    *
      *                      *-----------------------------------------*
           move      "GN"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                          *-------------------------------------*
      *                          * Test se 'At end'                    *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to pos-cnf-ann-480.
      *                      *-----------------------------------------*
      *                      * Test sul massimo                        *
      *                      *-----------------------------------------*
           if        rf-sdb-num-ris       not  = w-tes-num-rsd
                     go to pos-cnf-ann-480.
      *                      *-----------------------------------------*
      *                      * Memorizzazione numero nuova scadenza e- *
      *                      * messa a fronte della riscossione nel    *
      *                      * buffer                                  *
      *                      *-----------------------------------------*
           if        rf-sdb-nns-ris       not  = zero
                     add   1              to   w-bsd-num-ele
                     move  rf-sdb-nns-ris to   w-bsd-num-sdb
                                              (w-bsd-num-ele)         .
      *                      *-----------------------------------------*
      *                      * Azzeramento dati riscossione            *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sdb-dtr-ris         .
           move      zero                 to   rf-sdb-mod-ris         .
           move      zero                 to   rf-sdb-num-ris         .
           move      zero                 to   rf-sdb-imp-ris         .
           move      zero                 to   rf-sdb-aos-ris         .
           move      zero                 to   rf-sdb-nns-ris         .
      *                      *-----------------------------------------*
      *                      * Determinazione data chiusura scadenza   *
      *                      *-----------------------------------------*
           perform   det-dat-chs-000      thru det-dat-chs-999        .
      *                      *-----------------------------------------*
      *                      * Update record [sdb]                     *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                      *-----------------------------------------*
      *                      * Unlock [sdb]                            *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                      *-----------------------------------------*
      *                      * Riciclo su ottenimento sequenziale re-  *
      *                      * cord [sdb]                              *
      *                      *-----------------------------------------*
           go to     pos-cnf-ann-420.
       pos-cnf-ann-480.
      *                      *-----------------------------------------*
      *                      * Unlock finale di [sdb]                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
       pos-cnf-ann-500.
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione buffer appena creato     *
      *                  * per annullamento scadenze e movimenti con-  *
      *                  * tabili da esse generati emesse a fronte     *
      *                  * della riscossione                           *
      *                  *---------------------------------------------*
           move      zero                 to   w-pos-cnf-ann-ctr      .
       pos-cnf-ann-520.
           add       1                    to   w-pos-cnf-ann-ctr      .
           if        w-pos-cnf-ann-ctr    >    w-bsd-num-ele
                     go to pos-cnf-ann-600.
      *                      *-----------------------------------------*
      *                      * Ottenimento record [sdb]                *
      *                      *-----------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMSDB    "         to   f-key                  .
           move      w-bsd-num-sdb
                    (w-pos-cnf-ann-ctr)   to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                      *-----------------------------------------*
      *                      * Se record non esistente : riciclo       *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to pos-cnf-ann-520.
      *                      *-----------------------------------------*
      *                      * Controlli su scadenza, che non abbia    *
      *                      * nel frattempo avuto modifiche sullo     *
      *                      * status, ricontrollando che lo status    *
      *                      * non indichi movimenti successivi a      *
      *                      * quello di emissione                     *
      *                      *-----------------------------------------*
           perform   det-sts-sdb-000      thru det-sts-sdb-999        .
           if       (w-det-sts-sdb-sts    =    "A"    ) and
                    (w-det-sts-sdb-suo    =    "EMI" or
                     w-det-sts-sdb-suo    =    "ISP"  )
                     go to pos-cnf-ann-540.
      *                      *-----------------------------------------*
      *                      * Se controllo non superato               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Unlock [sdb]                        *
      *                          *-------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                          *-------------------------------------*
      *                          * Emissione messaggio di errore       *
      *                          *-------------------------------------*
           perform   pos-cnf-ann-m01-000  thru pos-cnf-ann-m01-999    .
      *                          *-------------------------------------*
      *                          * Riciclo                             *
      *                          *-------------------------------------*
           go to     pos-cnf-ann-520.
       pos-cnf-ann-540.
      *                      *-----------------------------------------*
      *                      * Annullamento del movimento di contabi-  *
      *                      * lita' generale che era stato a suo tem- *
      *                      * po generato a fronte del movimento di   *
      *                      * emissione                               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se necessario                  *
      *                          *-------------------------------------*
           if        rf-sdb-drc-emi       =    zero or
                     rf-sdb-npc-emi       =    zero
                     go to pos-cnf-ann-560.
      *                          *-------------------------------------*
      *                          * Annullamento                        *
      *                          *-------------------------------------*
           move      "DE"                 to   l-cge-300-tip-ope      .
           move      rf-sdb-drc-emi       to   l-cge-300-dat-reg      .
           move      rf-sdb-npc-emi       to   l-cge-300-num-prt      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                          *-------------------------------------*
      *                          * Test su esito operazione            *
      *                          *-------------------------------------*
           if        l-cge-300-exi-sts    =    spaces
                     go to pos-cnf-ann-560.
      *                          *-------------------------------------*
      *                          * Unlock [sdb]                        *
      *                          *-------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                          *-------------------------------------*
      *                          * Emissione messaggio di errore       *
      *                          *-------------------------------------*
           perform   pos-cnf-ann-m02-000  thru pos-cnf-ann-m02-999    .
      *                          *-------------------------------------*
      *                          * Riciclo                             *
      *                          *-------------------------------------*
           go to     pos-cnf-ann-520.
       pos-cnf-ann-560.
      *                      *-----------------------------------------*
      *                      * Cancellazione del record [sdb]          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Delete [sdb]                        *
      *                          *-------------------------------------*
           move      "DE"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                          *-------------------------------------*
      *                          * Unlock [sdb]                        *
      *                          *-------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
       pos-cnf-ann-580.
      *                      *-----------------------------------------*
      *                      * Riciclo su scansione buffer             *
      *                      *-----------------------------------------*
           go to     pos-cnf-ann-520.
       pos-cnf-ann-600.
      *              *-------------------------------------------------*
      *              * Delete record [rsa]                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su modalita' di riscossione            *
      *                  *---------------------------------------------*
           if        w-tes-mod-rsd (1)    not  = 02
                     go to pos-cnf-ann-900.
      *                  *---------------------------------------------*
      *                  * Esecuzione delete record                    *
      *                  *---------------------------------------------*
           move      "DE"                 to   f-ope                  .
