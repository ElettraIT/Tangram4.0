      *                          * Riciclo                             *
      *                          *-------------------------------------*
           go to     pos-cnf-mod-520.
       pos-cnf-mod-560.
      *                      *-----------------------------------------*
      *                      * Cancellazione del record [sdb]          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Delete [sdb]                        *
      *                          *-------------------------------------*
           move      "DE"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                          *-------------------------------------*
      *                          * Unlock [sdb]                        *
      *                          *-------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
       pos-cnf-mod-580.
      *                      *-----------------------------------------*
