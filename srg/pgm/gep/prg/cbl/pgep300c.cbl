           if        w-rig-num-sdb (1)    =    zero
                     go to cnt-tdo-nok-320.
      *                  *---------------------------------------------*
      *                  * Test su importo riscosso                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo opera-  *
      *                      * zione                                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        =    0301 or
                     w-tes-tip-ope        =    0302 or
                     w-tes-tip-ope        =    0303 or
                     w-tes-tip-ope        =    0304
                     go to cnt-tdo-nok-322
           else if   w-tes-tip-ope        =    0321 or
                     w-tes-tip-ope        =    0322 or
                     w-tes-tip-ope        =    0323 or
                     w-tes-tip-ope        =    0324
                     go to cnt-tdo-nok-322
           else if   w-tes-tip-ope        =    0350
                     go to cnt-tdo-nok-324.
       cnt-tdo-nok-322.
      *                      *-----------------------------------------*
      *                      * Tipo operazione : Riscossione o Paga-   *
      *                      * mento                                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se importo riscosso diverso da ze-  *
      *                          * ro : uscita dal ciclo               *
      *                          *-------------------------------------*
           if        w-rig-imp-ris (1)    not  = zero
                     go to cnt-tdo-nok-330.
           go to     cnt-tdo-nok-328.
       cnt-tdo-nok-324.
      *                      *-----------------------------------------*
      *                      * Tipo operazione : Compensazione         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se importo riscosso diverso da im-  *
      *                          * porto scadenza : uscita dal ciclo   *
      *                          *-------------------------------------*
           if        w-rig-imp-ris (1)    not  = w-rig-imp-sdb (1)
                     go to cnt-tdo-nok-330.
           go to     cnt-tdo-nok-328.
       cnt-tdo-nok-328.
      *                      *-----------------------------------------*
