                     w-tes-tip-ope        =    0322 or
                     w-tes-tip-ope        =    0323 or
                     w-tes-tip-ope        =    0324
                     go to car-buf-sdb-out-125
           else if   w-tes-tip-ope        =    0350
                     go to car-buf-sdb-out-130
           else      go to car-buf-sdb-out-100.
       car-buf-sdb-out-110.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : 0301 o 0302               *
      *                  *---------------------------------------------*
           if        srt-tip-sdb          =    01
                     go to car-buf-sdb-out-180
           else      go to car-buf-sdb-out-200.
       car-buf-sdb-out-115.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : 0303                      *
      *                  *---------------------------------------------*
           if        srt-tip-sdb          =    07
                     go to car-buf-sdb-out-180
           else      go to car-buf-sdb-out-200.
       car-buf-sdb-out-120.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : 0304                      *
      *                  *---------------------------------------------*
           if        srt-tip-sdb          =    08
                     go to car-buf-sdb-out-180
           else      go to car-buf-sdb-out-200.
       car-buf-sdb-out-125.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : 0321 o 0322 o 0323 o 0324 *
      *                  *---------------------------------------------*
           if        srt-tip-ddr          =    11 or
                     srt-tip-ddr          =    21
                     go to car-buf-sdb-out-180
           else      go to car-buf-sdb-out-200.
       car-buf-sdb-out-130.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : 0350                      *
      *                  *---------------------------------------------*
           go to     car-buf-sdb-out-180.
       car-buf-sdb-out-180.
      *                  *---------------------------------------------*
      *                  * Memorizzazione elemento nel buffer          *
      *                  *---------------------------------------------*
