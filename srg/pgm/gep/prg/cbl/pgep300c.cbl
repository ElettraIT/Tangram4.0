           if        w-cnt-imp-pt1-flg    not  = spaces
                     go to cnt-tdo-nok-950.
       cnt-tdo-nok-200.
      *              *-------------------------------------------------*
      *              * Controllo su impostazione pagina testata nr. 2  *
      *              *-------------------------------------------------*
           perform   cnt-imp-pt2-000      thru cnt-imp-pt2-999        .
      *              *-------------------------------------------------*
      *              * Se controllo non superato, il messaggio e' sta- *
      *              * to gia' emesso                                  *
      *              *-------------------------------------------------*
           if        w-cnt-imp-pt2-flg    not  = spaces
                     go to cnt-tdo-nok-950.
       cnt-tdo-nok-300.
      *              *-------------------------------------------------*
      *              * Controllo su impostazione corpo                 *
      *              *-------------------------------------------------*
           if       (w-tes-tip-ope        =    0301 or
                     w-tes-tip-ope        =    0302 or
                     w-tes-tip-ope        =    0303 or
                     w-tes-tip-ope        =    0304  ) and
                    (w-tes-tip-rsd (1)    not  = 01  )
