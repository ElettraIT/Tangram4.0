      *    *===========================================================*
      *    * Scrittura record [sdb] per nuova scadenza da generare se  *
      *    * riscossione di tipo : Anticipo su scadenze future         *
      *    *-----------------------------------------------------------*
       wrt-sdb-rsa-000.
      *              *-------------------------------------------------*
      *              * Scrittura record [sdb]                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [sdb]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Composizione record [sdb]                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Informazioni generali                   *
      *                      *-----------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rf-sdb-ide-dat         .
           move      s-ute                to   rf-sdb-ide-ute         .
           move      s-fas                to   rf-sdb-ide-fas         .
      *                      *-----------------------------------------*
      *                      * Data registrazione                      *
      *                      *-----------------------------------------*
           move      w-tes-dat-reg        to   rf-sdb-dtr-emi         .
      *                      *-----------------------------------------*
      *                      * Data registrazione contabilita'         *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sdb-drc-emi         .
      *                      *-----------------------------------------*
      *                      * Numero protocollo contabilita'          *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sdb-npc-emi         .
      *                      *-----------------------------------------*
      *                      * Numero protocollo fattura cliente       *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sdb-prt-fcl         .
      *                      *-----------------------------------------*
      *                      * Numero scadenza di origine              *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sdb-nsc-org         .
      *                      *-----------------------------------------*
      *                      * Codice agente                           *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sdb-cod-age         .
      *                      *-----------------------------------------*
      *                      * Numero scadenza                         *
      *                      *-----------------------------------------*
           move      w-tes-nsc-rsd (1)    to   rf-sdb-num-sdb         .
      *                      *-----------------------------------------*
      *                      * Tipo scadenza                           *
      *                      *-----------------------------------------*
           move      01                   to   rf-sdb-tip-sdb         .
      *                      *-----------------------------------------*
      *                      * Si/No dilazione concordata              *
      *                      *-----------------------------------------*
           move      "N"                  to   rf-sdb-snx-dlc         .
      *                      *-----------------------------------------*
      *                      * Si/No contrassegno                      *
      *                      *-----------------------------------------*
           move      "N"                  to   rf-sdb-snx-cts         .
      *                      *-----------------------------------------*
      *                      * Tipo acquisizione scadenza              *
      *                      *-----------------------------------------*
           move      01                   to   rf-sdb-tac-sdb         .
      *                      *-----------------------------------------*
      *                      * Tipo valuta per la scadenza             *
      *                      *-----------------------------------------*
           move      w-tes-tvl-rsd (1)    to   rf-sdb-tvl-sdb         .
      *                      *-----------------------------------------*
      *                      * Data scadenza                           *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sdb-dts-sdb         .
      *                      *-----------------------------------------*
      *                      * Tipo debitore                           *
      *                      *-----------------------------------------*
           move      w-tes-tip-dbt (1)    to   rf-sdb-tip-dbt         .
      *                      *-----------------------------------------*
      *                      * Codice debitore                         *
      *                      *-----------------------------------------*
           move      w-tes-cod-dbt (1)    to   rf-sdb-cod-dbt         .
      *                      *-----------------------------------------*
      *                      * Dipendenza debitore                     *
      *                      *-----------------------------------------*
           move      w-tes-dpz-dbt (1)    to   rf-sdb-dpz-dbt         .
      *                      *-----------------------------------------*
      *                      * Inoltro scadenza al debitore            *
      *                      *-----------------------------------------*
           move      01                   to   rf-sdb-inl-sdb         .
      *                      *-----------------------------------------*
      *                      * Sigla valuta                            *
      *                      *-----------------------------------------*
           move      w-tes-sgl-vlt (1)    to   rf-sdb-sgl-vlt         .
      *                      *-----------------------------------------*
      *                      * Decimali valuta                         *
      *                      *-----------------------------------------*
           move      w-tes-dec-vlt (1)    to   rf-sdb-dec-vlt         .
      *                      *-----------------------------------------*
      *                      * Tipo di cambio                          *
      *                      *-----------------------------------------*
           move      w-tes-tdc-vlt (1)    to   rf-sdb-tdc-vlt         .
      *                      *-----------------------------------------*
      *                      * Coefficiente di cambio                  *
      *                      *-----------------------------------------*
           move      w-tes-cdc-rsd (1)    to   rf-sdb-cdc-sdb         .
      *                      *-----------------------------------------*
      *                      * Importo scadenza in valuta              *
      *                      *-----------------------------------------*
           move      w-tes-iiv-rsd (1)    to   rf-sdb-iiv-sdb         .
           multiply  -1                   by   rf-sdb-iiv-sdb         .
      *                      *-----------------------------------------*
      *                      * Importo scadenza                        *
      *                      *-----------------------------------------*
           move      w-tes-imp-rsd (1)    to   rf-sdb-imp-sdb         .
           multiply  -1                   by   rf-sdb-imp-sdb         .
      *                      *-----------------------------------------*
      *                      * Data documento di riferimento           *
      *                      *-----------------------------------------*
           if        w-tes-ddo-rsd (1)    not  = zero
                     move  w-tes-ddo-rsd (1)
                                          to   rf-sdb-dat-ddr
           else      move  w-tes-dat-reg  to   rf-sdb-dat-ddr         .
      *                      *-----------------------------------------*
      *                      * Numero documento di riferimento         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Editing numero riscossione          *
      *                          *-------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      w-tes-num-rsd        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Determinazione                      *
      *                          *-------------------------------------*
           if        w-tes-ddo-rsd (1)    not  = zero
                     move  w-tes-ndo-rsd (1)
                                          to   rf-sdb-num-ddr
           else      move  v-edt          to   rf-sdb-num-ddr         .
      *                      *-----------------------------------------*
      *                      * Tipo documento di riferimento           *
      *                      *-----------------------------------------*
           move      21                   to   rf-sdb-tip-ddr         .
      *                      *-----------------------------------------*
      *                      * Importo documento di riferimento        *
      *                      *-----------------------------------------*
           move      w-tes-imp-rsd (1)    to   rf-sdb-imp-ddr         .
           multiply  -1                   by   rf-sdb-imp-ddr         .
      *                      *-----------------------------------------*
      *                      * Numero rata documento di riferimento    *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sdb-nra-ddr         .
      *                      *-----------------------------------------*
      *                      * Codice ABI per l'appoggio in presenta-  *
      *                      * zione                                   *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sdb-abi-app         .
      *                      *-----------------------------------------*
      *                      * Codice CAB per l'appoggio in presenta-  *
      *                      * zione                                   *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sdb-cab-app         .
      *                      *-----------------------------------------*
      *                      * Codice conto corrente per l'appoggio in *
      *                      * presentazione                           *
      *                      *-----------------------------------------*
           move      spaces               to   rf-sdb-ccc-app         .
      *                      *-----------------------------------------*
      *                      * Codice nostra banca o c/c postale       *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sdb-cod-cbp         .
      *                      *-----------------------------------------*
      *                      * Determinazione data chiusura scadenza   *
      *                      *-----------------------------------------*
           perform   det-dat-chs-000      thru det-dat-chs-999        .
      *                  *---------------------------------------------*
      *                  * Scrittura record [sdb]                      *
      *                  *---------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
       wrt-sdb-rsa-999.
           exit.

      *    *===========================================================*
      *    * Cancellazione record nuova scadenza generata a fronte     *
      *    * della riscossione di tipo anticipato                      *
      *    *-----------------------------------------------------------*
       del-sdb-rsa-000.
      *              *-------------------------------------------------*
      *              * Cancellazione record [sdb]                      *
      *              *-------------------------------------------------*
           move      "DE"                 to   f-ope                  .
           move      w-tes-nsc-rsd (2)    to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
       del-sdb-rsa-999.
           exit.

      *    *===========================================================*
      *    * Scrittura nuova scadenza a fronte della riga di riscos-   *
      *    * sione                                                     *
      *    *-----------------------------------------------------------*
       wrt-sdb-rss-000.
      *              *-------------------------------------------------*
      *              * Aggiornamento contabile per nuova scadenza      *
      *              *-------------------------------------------------*
           move      w-wrt-sdb-rss-nns    to   w-cge-gep-emi-nns      .
           perform   cge-gep-emi-000      thru cge-gep-emi-999        .
      *              *-------------------------------------------------*
      *              * Determinazione importo e natura della scadenza  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo operazione  *
      *                  *---------------------------------------------*
           if        w-tes-tip-ope        =    0301 or
                     w-tes-tip-ope        =    0302 or
                     w-tes-tip-ope        =    0303 or
                     w-tes-tip-ope        =    0304
                     go to wrt-sdb-rss-010
           else if   w-tes-tip-ope        =    0301 or
                     w-tes-tip-ope        =    0302 or
                     w-tes-tip-ope        =    0303 or
                     w-tes-tip-ope        =    0304
                     go to wrt-sdb-rss-010
           else if   w-tes-tip-ope        =    0350
                     go to wrt-sdb-rss-020.
       wrt-sdb-rss-010.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : Riscossione o Pagamento   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Importo scadenza                        *
      *                      *-----------------------------------------*
           subtract  w-rig-imp-ris (1)    from w-rig-imp-sdb (1)
                                        giving w-wrt-sdb-rss-ims      .
      *                      *-----------------------------------------*
      *                      * Natura della scadenza : se importo po-  *
      *                      * sitivo, stessa natura della scadenza    *
      *                      * precedente, altrimenti natura contraria *
      *                      *-----------------------------------------*
           if        w-wrt-sdb-rss-ims    >    zero
                     move  "="            to   w-wrt-sdb-rss-nts
           else      move  "#"            to   w-wrt-sdb-rss-nts      .
           go to     wrt-sdb-rss-040.
       wrt-sdb-rss-020.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : Compensazione             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Importo scadenza                        *
      *                      *-----------------------------------------*
           move      w-rig-imp-ris (1)    to   w-wrt-sdb-rss-ims      .
      *                      *-----------------------------------------*
      *                      * Natura della scadenza : la stessa della *
      *                      * scadenza precedente                     *
      *                      *-----------------------------------------*
           move      "="                  to   w-wrt-sdb-rss-nts      .
           go to     wrt-sdb-rss-040.
       wrt-sdb-rss-040.
      *              *-------------------------------------------------*
      *              * Scrittura record [sdb]                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [sdb]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Composizione record [sdb]                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Informazioni generali                   *
      *                      *-----------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rf-sdb-ide-dat         .
           move      s-ute                to   rf-sdb-ide-ute         .
           move      s-fas                to   rf-sdb-ide-fas         .
      *                      *-----------------------------------------*
      *                      * Data registrazione                      *
      *                      *-----------------------------------------*
           move      w-tes-dat-reg        to   rf-sdb-dtr-emi         .
      *                      *-----------------------------------------*
      *                      * Data registrazione contabilita'         *
      *                      *-----------------------------------------*
           move      l-cge-300-dat-reg    to   rf-sdb-drc-emi         .
      *                      *-----------------------------------------*
      *                      * Numero protocollo contabilita'          *
      *                      *-----------------------------------------*
           move      l-cge-300-num-prt    to   rf-sdb-npc-emi         .
      *                      *-----------------------------------------*
      *                      * Numero protocollo fattura cliente       *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sdb-prt-fcl         .
      *                      *-----------------------------------------*
      *                      * Numero scadenza di origine              *
      *                      *-----------------------------------------*
           move      w-rig-num-sdb (1)    to   rf-sdb-nsc-org         .
      *                      *-----------------------------------------*
      *                      * Codice agente                           *
      *                      *-----------------------------------------*
           move      w-rig-cod-age (1)    to   rf-sdb-cod-age         .
      *                      *-----------------------------------------*
      *                      * Numero scadenza                         *
      *                      *-----------------------------------------*
           move      w-wrt-sdb-rss-nns    to   rf-sdb-num-sdb         .
      *                      *-----------------------------------------*
      *                      * Tipo scadenza                           *
      *                      *                                         *
      *                      * Se stessa natura della scadenza di ori- *
      *                      * gine :                                  *
      *                      * - se scadenza di origine insoluta : Ri- *
      *                      *   messa Diretta                         *
      *                      * - altrimenti : stesso tipo scadenza di  *
      *                      *   quello della scadenza di origine      *
      *                      * Se natura diversa, cioe' Anticipo : Ri- *
      *                      * messa Diretta                           *
      *                      *-----------------------------------------*
           if        w-wrt-sdb-rss-nts    =    "="
                     if    w-rig-dtr-isp (1)
                                          =    zero
                           move  w-rig-tip-sdb (1)
                                          to   rf-sdb-tip-sdb
                     else  move  01       to   rf-sdb-tip-sdb
           else      move  01             to   rf-sdb-tip-sdb         .
      *                      *-----------------------------------------*
      *                      * Si/No dilazione concordata              *
      *                      *-----------------------------------------*
           move      "N"                  to   rf-sdb-snx-dlc         .
      *                      *-----------------------------------------*
      *                      * Si/No contrassegno                      *
      *                      *-----------------------------------------*
           move      "N"                  to   rf-sdb-snx-cts         .
      *                      *-----------------------------------------*
      *                      * Tipo acquisizione scadenza              *
      *                      *-----------------------------------------*
           move      01                   to   rf-sdb-tac-sdb         .
      *                      *-----------------------------------------*
      *                      * Tipo valuta per la scadenza             *
      *                      *-----------------------------------------*
           move      w-rig-tvl-sdb (1)    to   rf-sdb-tvl-sdb         .
      *                      *-----------------------------------------*
      *                      * Data scadenza                           *
      *                      *-----------------------------------------*
           if        w-wrt-sdb-rss-nts    =    "="
                     move  w-rig-dts-sdb (1)
                                          to   rf-sdb-dts-sdb
           else      move  zero           to   rf-sdb-dts-sdb         .
      *                      *-----------------------------------------*
      *                      * Tipo debitore                           *
      *                      *-----------------------------------------*
           move      w-tes-tip-dbt (1)    to   rf-sdb-tip-dbt         .
      *                      *-----------------------------------------*
      *                      * Codice debitore                         *
      *                      *-----------------------------------------*
           move      w-tes-cod-dbt (1)    to   rf-sdb-cod-dbt         .
      *                      *-----------------------------------------*
      *                      * Dipendenza debitore                     *
      *                      *-----------------------------------------*
           move      w-rig-dpz-dbt (1)    to   rf-sdb-dpz-dbt         .
      *                      *-----------------------------------------*
      *                      * Inoltro scadenza al debitore            *
      *                      *-----------------------------------------*
           move      w-rig-inl-sdb (1)    to   rf-sdb-inl-sdb         .
      *                      *-----------------------------------------*
      *                      * Sigla valuta                            *
      *                      *-----------------------------------------*
           move      w-tes-sgl-vlt (1)    to   rf-sdb-sgl-vlt         .
      *                      *-----------------------------------------*
      *                      * Decimali valuta                         *
      *                      *-----------------------------------------*
           move      w-tes-dec-vlt (1)    to   rf-sdb-dec-vlt         .
      *                      *-----------------------------------------*
      *                      * Tipo di cambio                          *
      *                      *-----------------------------------------*
           move      w-tes-tdc-vlt (1)    to   rf-sdb-tdc-vlt         .
      *                      *-----------------------------------------*
      *                      * Coefficiente di cambio                  *
      *                      *-----------------------------------------*
           move      w-tes-cdc-rsd (1)    to   rf-sdb-cdc-sdb         .
      *                      *-----------------------------------------*
      *                      * Importo scadenza in valuta              *
      *                      *-----------------------------------------*
           if        w-tes-sgl-vlt (1)    not  = c-sgl
                     move  w-wrt-sdb-rss-ims
                                          to   rf-sdb-iiv-sdb
           else      move  zero           to   rf-sdb-iiv-sdb         .
      *                      *-----------------------------------------*
      *                      * Importo scadenza                        *
      *                      *                                         *
      *                      * N.B.: da rivedere una volta che verran- *
      *                      *       no gestite anche le scadenze in   *
      *                      *       valuta                            *
      *                      *-----------------------------------------*
           if        w-tes-sgl-vlt (1)    =    c-sgl
                     move  w-wrt-sdb-rss-ims
                                          to   rf-sdb-imp-sdb
           else      move  zero           to   rf-sdb-imp-sdb         .
      *                      *-----------------------------------------*
      *                      * Data documento di riferimento           *
      *                      *-----------------------------------------*
           if        w-wrt-sdb-rss-nts    =    "="
                     move  w-rig-dat-ddr (1)
                                          to   rf-sdb-dat-ddr
           else      if    w-tes-ddo-rsd (1)
                                          not  = zero
                           move   w-tes-ddo-rsd (1)
                                          to   rf-sdb-dat-ddr
                     else  move   w-tes-dat-reg
                                          to   rf-sdb-dat-ddr         .
      *                      *-----------------------------------------*
      *                      * Numero documento di riferimento         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Editing numero riscossione          *
      *                          *-------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      w-tes-num-rsd        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Determinazione                      *
      *                          *-------------------------------------*
           if        w-wrt-sdb-rss-nts    =    "="
                     move  w-rig-num-ddr (1)
                                          to   rf-sdb-num-ddr
           else      if    w-tes-ddo-rsd (1)
                                          not  = zero
                           move   w-tes-ndo-rsd (1)
                                          to   rf-sdb-num-ddr
                     else  move   v-edt   to   rf-sdb-num-ddr         .
      *                      *-----------------------------------------*
      *                      * Tipo documento di riferimento           *
      *                      *-----------------------------------------*
           if        w-wrt-sdb-rss-nts    =    "="
                     move  w-rig-tip-ddr (1)
                                          to   rf-sdb-tip-ddr
           else      move  21             to   rf-sdb-tip-ddr         .
      *                      *-----------------------------------------*
      *                      * Importo documento di riferimento        *
      *                      *-----------------------------------------*
           if        w-wrt-sdb-rss-nts    =    "="
                     move  w-rig-imp-ddr (1)
                                          to   rf-sdb-imp-ddr
           else      move  w-tes-imp-rsd (1)
                                          to   rf-sdb-imp-ddr
                     multiply -1          by   rf-sdb-imp-ddr         .
      *                      *-----------------------------------------*
      *                      * Numero rata documento di riferimento    *
      *                      *-----------------------------------------*
           if        w-wrt-sdb-rss-nts    =    "="
                     move  w-rig-nra-ddr (1)
                                          to   rf-sdb-nra-ddr
           else      move  zero           to   rf-sdb-nra-ddr         .
      *                      *-----------------------------------------*
      *                      * Codice ABI per l'appoggio in presenta-  *
      *                      * zione                                   *
      *                      *-----------------------------------------*
           if        w-wrt-sdb-rss-nts    =    "=" and
                     rf-sdb-tip-sdb       not  = 01
                     move  w-rig-abi-app (1)
                                          to   rf-sdb-abi-app
           else      move  zero           to   rf-sdb-abi-app         .
      *                      *-----------------------------------------*
      *                      * Codice CAB per l'appoggio in presenta-  *
      *                      * zione                                   *
      *                      *-----------------------------------------*
           if        w-wrt-sdb-rss-nts    =    "=" and
                     rf-sdb-tip-sdb       not  = 01
                     move  w-rig-cab-app (1)
                                          to   rf-sdb-cab-app
           else      move  zero           to   rf-sdb-cab-app         .
      *                      *-----------------------------------------*
      *                      * Codice conto corrente per l'appoggio in *
      *                      * presentazione                           *
      *                      *-----------------------------------------*
           if        w-wrt-sdb-rss-nts    =    "=" and
                     rf-sdb-tip-sdb       not  = 01
                     move  w-rig-ccc-app (1)
                                          to   rf-sdb-ccc-app
           else      move  spaces         to   rf-sdb-ccc-app         .
      *                      *-----------------------------------------*
      *                      * Codice nostra banca o c/c postale       *
      *                      *-----------------------------------------*
           if        w-wrt-sdb-rss-nts    =    "=" and
                     rf-sdb-tip-sdb       not  = 01
                     move  w-rig-cod-cbp (1)
                                          to   rf-sdb-cod-cbp
           else      move  zero           to   rf-sdb-cod-cbp         .
      *                      *-----------------------------------------*
      *                      * Ultimo livello di sollecito cui e' sta- *
      *                      * ta sottoposta la scadenza               *
      *                      *-----------------------------------------*
           if        w-wrt-sdb-rss-nts    =    "="
                     move  w-rig-liv-slc (1)
                                          to   rf-sdb-liv-slc         .
      *                      *-----------------------------------------*
      *                      * Data sollecito 1                        *
      *                      *-----------------------------------------*
           if        w-wrt-sdb-rss-nts    =    "="
                     move  w-rig-dso-l01 (1)
                                          to   rf-sdb-dso-l01         .
      *                      *-----------------------------------------*
      *                      * Data sollecito 2                        *
      *                      *-----------------------------------------*
           if        w-wrt-sdb-rss-nts    =    "="
                     move  w-rig-dso-l02 (1)
                                          to   rf-sdb-dso-l02         .
      *                      *-----------------------------------------*
      *                      * Data sollecito 2                        *
      *                      *-----------------------------------------*
           if        w-wrt-sdb-rss-nts    =    "="
                     move  w-rig-dso-l03 (1)
                                          to   rf-sdb-dso-l03         .
      *                      *-----------------------------------------*
      *                      * Determinazione data chiusura scadenza   *
      *                      *-----------------------------------------*
           perform   det-dat-chs-000      thru det-dat-chs-999        .
      *                  *---------------------------------------------*
      *                  * Scrittura record [sdb]                      *
      *                  *---------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
       wrt-sdb-rss-999.
           exit.

      *    *===========================================================*
      *    * Test Si/No aggiornamenti contabili da gestione portafo-   *
      *    * glio per i movimenti di emissione                         *
      *    *-----------------------------------------------------------*
       cge-gep-emi-snx-000.
      *              *-------------------------------------------------*
      *              * Se le personalizzazioni indicano che in ogni    *
      *              * caso gli aggiornamenti contabili non devono     *
      *              * essere eseguiti : uscita con 'N'                *
      *              *-------------------------------------------------*
           if        w-prs-gep-snx-cge    =    "N"
                     move  "N"            to   w-cge-gep-emi-snx
                     go to cge-gep-emi-snx-999.
      *              *-------------------------------------------------*
      *              * Determinazione indice su tabella tipi operazio- *
      *              * ne, relativo al tipo operazione di emissione    *
      *              * corrispondente al tipo di scadenza in esame     *
      *              *-------------------------------------------------*
           if        w-cge-gep-emi-tns    =    01
                     move  0101           to   w-cge-gep-emi-wop
           else if   w-cge-gep-emi-tns    =    02
                     move  0102           to   w-cge-gep-emi-wop
           else if   w-cge-gep-emi-tns    =    03
                     move  0103           to   w-cge-gep-emi-wop
           else if   w-cge-gep-emi-tns    =    04
                     move  0104           to   w-cge-gep-emi-wop
           else if   w-cge-gep-emi-tns    =    05
                     move  0105           to   w-cge-gep-emi-wop
           else if   w-cge-gep-emi-tns    =    06
                     move  0106           to   w-cge-gep-emi-wop
           else if   w-cge-gep-emi-tns    =    07
                     move  0107           to   w-cge-gep-emi-wop
           else if   w-cge-gep-emi-tns    =    08
                     move  0108           to   w-cge-gep-emi-wop
           else if   w-cge-gep-emi-tns    =    09
                     move  0109           to   w-cge-gep-emi-wop
           else if   w-cge-gep-emi-tns    =    10
                     move  0110           to   w-cge-gep-emi-wop
           else if   w-cge-gep-emi-tns    =    11
                     move  0111           to   w-cge-gep-emi-wop
           else      move  zero           to   w-cge-gep-emi-wop      .
      *              *-------------------------------------------------*
      *              * Se non determinabile gli aggiornamenti contabi- *
      *              * li non devono essere eseguiti : uscita con 'N'  *
      *              *-------------------------------------------------*
           if        w-cge-gep-emi-wop    =    zero
                     move  "N"            to   w-cge-gep-emi-snx
                     go to cge-gep-emi-snx-999.
      *              *-------------------------------------------------*
      *              * Ricerca del tipo operazione cosi' determinato   *
      *              * in tabella tipi operazione. Se non si trova     *
      *              * l'elemento gli aggiornamenti contabili non de-  *
      *              * vono essere eseguiti : uscita con 'N'           *
      *              *-------------------------------------------------*
           move      zero                 to   w-cge-gep-emi-wix      .
       cge-gep-emi-snx-100.
           add       1                    to   w-cge-gep-emi-wix      .
           if        w-cge-gep-emi-wix    >    w-top-ele-num
                     move  "N"            to   w-cge-gep-emi-snx
                     go to cge-gep-emi-snx-999.
           if        w-top-cod-top
                    (w-cge-gep-emi-wix)   =    w-cge-gep-emi-wop
                     go to cge-gep-emi-snx-200
           else      go to cge-gep-emi-snx-100.
       cge-gep-emi-snx-200.
      *              *-------------------------------------------------*
      *              * Se il codice causale contabile per il tipo ope- *
      *              * razione di emissione e' a zero : uscita con 'N' *
      *              *-------------------------------------------------*
           if        w-top-cau-cge
                    (w-cge-gep-emi-wix)   =    zero
                     move  "N"            to   w-cge-gep-emi-snx
                     go to cge-gep-emi-snx-999.
      *              *-------------------------------------------------*
      *              * Se il codice sottoconto contabile per il tipo   *
      *              * operazione di emissione e' a zero : uscita con  *
      *              * 'N'                                             *
      *              *-------------------------------------------------*
           if        w-top-stc-cge
                    (w-cge-gep-emi-wix)   =    zero
                     move  "N"            to   w-cge-gep-emi-snx
                     go to cge-gep-emi-snx-999.
      *              *-------------------------------------------------*
      *              * Altrimenti : uscita con 'S'                     *
      *              *-------------------------------------------------*
           move      "S"                  to   w-cge-gep-emi-snx      .
       cge-gep-emi-snx-999.
           exit.

      *    *===========================================================*
      *    * Aggiornamenti contabili generati dalla gestione  portafo- *
      *    * glio a fronte del movimento di emissione scadenza         *
      *    *                                                           *
      *    * Nota : Vedere i commenti per il modulo 'pgep3000' per le  *
      *    *        generalita' sugli aggiornamenti contabili riguar-  *
      *    *        danti la gestione portafoglio.                     *
      *    *-----------------------------------------------------------*
       cge-gep-emi-000.
      *              *-------------------------------------------------*
      *              * Test se aggiornamento da eseguire               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo operazione  *
      *                  *---------------------------------------------*
           if        w-tes-tip-ope        =    0301 or
                     w-tes-tip-ope        =    0302 or
                     w-tes-tip-ope        =    0303 or
                     w-tes-tip-ope        =    0304
                     go to cge-gep-emi-010
           else if   w-tes-tip-ope        =    0321 or
                     w-tes-tip-ope        =    0322 or
                     w-tes-tip-ope        =    0323 or
                     w-tes-tip-ope        =    0324
                     go to cge-gep-emi-010
           else if   w-tes-tip-ope        =    0350
                     go to cge-gep-emi-020.
       cge-gep-emi-010.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : Riscossione o Pagamento   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se Anticipo : no aggiornamento          *
      *                      *-----------------------------------------*
           if        w-rig-imp-sdb (1)    >    zero and
                     w-rig-imp-ris (1)    >    w-rig-imp-sdb (1)
                     go to cge-gep-emi-100
           else if   w-rig-imp-sdb (1)    <    zero and
                     w-rig-imp-ris (1)    <    w-rig-imp-sdb (1)
                     go to cge-gep-emi-100.
           go to     cge-gep-emi-030.
       cge-gep-emi-020.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : Compensazione             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Nessun test                             *
      *                      *-----------------------------------------*
           go to     cge-gep-emi-030.
       cge-gep-emi-030.
      *                  *---------------------------------------------*
      *                  * Preparazione tipo scadenza da emettere      *
      *                  *---------------------------------------------*
           if        w-rig-dtr-isp (1)    not  = zero
                     move  01             to   w-cge-gep-emi-tns
           else      move  w-rig-tip-sdb (1)
                                          to   w-cge-gep-emi-tns      .
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           perform   cge-gep-emi-snx-000  thru cge-gep-emi-snx-999    .
      *              *-------------------------------------------------*
      *              * Se Si' : ad aggiornamenti                       *
      *              *-------------------------------------------------*
           if        w-cge-gep-emi-snx    =    "S"
                     go to cge-gep-emi-200.
       cge-gep-emi-100.
      *              *-------------------------------------------------*
      *              * Se No                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Data registrazione movimento contabile : a  *
      *                  * zero                                        *
      *                  *---------------------------------------------*
           move      zero                 to   l-cge-300-dat-reg      .
      *                  *---------------------------------------------*
      *                  * Numero protocollo movimento contabile : a   *
      *                  * zero                                        *
      *                  *---------------------------------------------*
           move      zero                 to   l-cge-300-num-prt      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     cge-gep-emi-999.
       cge-gep-emi-200.
      *              *-------------------------------------------------*
      *              * Determinazione importo scadenza                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo operazione  *
      *                  *---------------------------------------------*
           if        w-tes-tip-ope        =    0301 or
                     w-tes-tip-ope        =    0302 or
                     w-tes-tip-ope        =    0303 or
                     w-tes-tip-ope        =    0304
                     go to cge-gep-emi-210
           else if   w-tes-tip-ope        =    0321 or
                     w-tes-tip-ope        =    0322 or
                     w-tes-tip-ope        =    0323 or
                     w-tes-tip-ope        =    0324
                     go to cge-gep-emi-210
           else if   w-tes-tip-ope        =    0350
                     go to cge-gep-emi-220.
       cge-gep-emi-210.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : Riscossione o Pagamento   *
      *                  *---------------------------------------------*
           subtract  w-rig-imp-ris (1)    from w-rig-imp-sdb (1)
                                        giving w-cge-gep-emi-ims      .
           go to     cge-gep-emi-230.
       cge-gep-emi-220.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : Compensazione             *
      *                  *---------------------------------------------*
           move      w-rig-imp-ris (1)    to   w-cge-gep-emi-ims      .
           go to     cge-gep-emi-230.
       cge-gep-emi-230.
      *              *-------------------------------------------------*
      *              * Esecuzione aggiornamento contabile : viene ese- *
      *              * guita una registrazione con il seguente forma-  *
      *              * to :                                            *
      *              *                                                 *
      *              * - Dare  : Sottoconto contabile                  *
      *              * - Avere : Cliente                               *
      *              *                                                 *
      *              *-------------------------------------------------*
       cge-gep-emi-300.
      *                  *---------------------------------------------*
      *                  * Normalizzazione work-area testata e prima   *
      *                  * riga movimento per aggiornamenti contabili  *
      *                  *---------------------------------------------*
           move      "NO"                 to   l-cge-300-tip-ope      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                  *---------------------------------------------*
      *                  * Preparazione link-area per testata e prima  *
      *                  * riga movimento                              *
      *                  *                                             *
      *                  * Nota : i seguenti campi non vengono prepa-  *
      *                  *        rati in quanto gia' normalizzati :   *
      *                  *                                             *
      *                  *        - Numero protocollo                  *
      *                  *        - Descrizione per codice causale     *
      *                  *        - Codice numerazione                 *
      *                  *        - Numero protocollo Iva              *
      *                  *        - Commento in riga                   *
      *                  *        - Castelletto Iva                    *
      *                  *        - Totale documento Iva               *
      *                  *                                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo operazione                         *
      *                      *-----------------------------------------*
           move      "WR"                 to   l-cge-300-tip-ope      .
      *                      *-----------------------------------------*
      *                      * Data di registrazione                   *
      *                      *-----------------------------------------*
           move      w-tes-dat-reg        to   l-cge-300-dat-reg      .
      *                      *-----------------------------------------*
      *                      * Codice causale contabile                *
      *                      *-----------------------------------------*
           move      w-top-cau-cge
                    (w-cge-gep-emi-wix)   to   l-cge-300-cod-cau      .
      *                      *-----------------------------------------*
      *                      * Descrizione causale                     *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-des-cau      .
      *                      *-----------------------------------------*
      *                      * Si/No data scadenza                     *
      *                      *-----------------------------------------*
           move      "S"                  to   l-cge-300-snx-dts      .
      *                      *-----------------------------------------*
      *                      * Data scadenza                           *
      *                      *-----------------------------------------*
           move      w-rig-dts-sdb (1)    to   l-cge-300-dat-sca      .
      *                      *-----------------------------------------*
      *                      * Data documento                          *
      *                      *-----------------------------------------*
           move      w-tes-dat-reg        to   l-cge-300-dat-doc      .
      *                      *-----------------------------------------*
      *                      * Numero documento                        *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      w-cge-gep-emi-nns    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   l-cge-300-num-doc      .
      *                      *-----------------------------------------*
      *                      * Codice sottoconto                       *
      *                      *-----------------------------------------*
           move      w-top-stc-cge
                    (w-cge-gep-emi-wix)   to   l-cge-300-cod-pdc      .
      *                      *-----------------------------------------*
      *                      * Tipo archivio                           *
      *                      *-----------------------------------------*
           move      "G"                  to   l-cge-300-tip-arc      .
      *                      *-----------------------------------------*
      *                      * Codice archivio                         *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-cod-arc      .
      *                      *-----------------------------------------*
      *                      * Data riferimento                        *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-dat-rif      .
      *                      *-----------------------------------------*
      *                      * Numero riferimento                      *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-num-rif      .
      *                      *-----------------------------------------*
      *                      * Dare/Avere                              *
      *                      *-----------------------------------------*
           move      "D"                  to   l-cge-300-dar-ave      .
      *                      *-----------------------------------------*
      *                      * Importo movimento                       *
      *                      *-----------------------------------------*
           move      w-cge-gep-emi-ims    to   l-cge-300-imp-mov      .
      *                      *-----------------------------------------*
      *                      * Eventuale aggiustamento di Dare/Avere e *
      *                      * importo in caso di importo negativo     *
      *                      *-----------------------------------------*
           if        l-cge-300-imp-mov    <    zero
                     move  "A"            to   l-cge-300-dar-ave
                     multiply -1          by   l-cge-300-imp-mov      .
      *                      *-----------------------------------------*
      *                      * Dati non gestiti                        *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-flg-rfp      .
           move      spaces               to   l-cge-300-sgl-num      .
           move      zero                 to   l-cge-300-dat-acq      .
      *                  *---------------------------------------------*
      *                  * Richiamo sottoprogramma per aggiornamenti   *
      *                  * contabili                                   *
      *                  *---------------------------------------------*
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
       cge-gep-emi-400.
      *                  *---------------------------------------------*
      *                  * Normalizzazione work-area riga movimento    *
      *                  * per aggiornamenti contabili                 *
      *                  *---------------------------------------------*
           move      "N+"                 to   l-cge-300-tip-ope      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                  *---------------------------------------------*
      *                  * Preparazione link-area per seconda riga     *
      *                  * movimento                                   *
      *                  *                                             *
      *                  * Nota : i seguenti campi non vengono prepa-  *
      *                  *        rati in quanto gia' normalizzati :   *
      *                  *                                             *
      *                  *        - Commento in riga                   *
      *                  *                                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo operazione                         *
      *                      *-----------------------------------------*
           move      "W+"                 to   l-cge-300-tip-ope      .
      *                      *-----------------------------------------*
      *                      * Codice sottoconto                       *
      *                      *-----------------------------------------*
           move      w-tes-cod-dbt-cge (1)
                                          to   l-cge-300-cod-pdc      .
      *                      *-----------------------------------------*
      *                      * Tipo archivio                           *
      *                      *-----------------------------------------*
           if        w-tes-tip-dbt (1)    =    01
                     move  "C"            to   l-cge-300-tip-arc
           else      move  "C"            to   l-cge-300-tip-arc      .
      *                      *-----------------------------------------*
      *                      * Codice archivio                         *
      *                      *-----------------------------------------*
           move      w-tes-cod-dbt (1)    to   l-cge-300-cod-arc      .
      *                      *-----------------------------------------*
      *                      * Data riferimento                        *
      *                      *-----------------------------------------*
           move      w-rig-dat-ddr (1)    to   l-cge-300-dat-rif      .
      *                      *-----------------------------------------*
      *                      * Numero riferimento                      *
      *                      *-----------------------------------------*
           move      w-rig-num-ddr (1)    to   l-cge-300-num-rif      .
      *                      *-----------------------------------------*
      *                      * Dare/Avere                              *
      *                      *-----------------------------------------*
           move      "A"                  to   l-cge-300-dar-ave      .
      *                      *-----------------------------------------*
      *                      * Importo movimento                       *
      *                      *-----------------------------------------*
           move      w-cge-gep-emi-ims    to   l-cge-300-imp-mov      .
      *                      *-----------------------------------------*
      *                      * Eventuale aggiustamento di Dare/Avere e *
      *                      * importo in caso di importo negativo     *
      *                      *-----------------------------------------*
           if        l-cge-300-imp-mov    <    zero
                     move  "D"            to   l-cge-300-dar-ave
                     multiply -1          by   l-cge-300-imp-mov      .
      *                      *-----------------------------------------*
      *                      * Dati non gestiti                        *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-flg-rfp      .
           move      spaces               to   l-cge-300-sgl-num      .
           move      zero                 to   l-cge-300-dat-acq      .
      *                  *---------------------------------------------*
      *                  * Richiamo sottoprogramma per aggiornamenti   *
      *                  * contabili                                   *
      *                  *---------------------------------------------*
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
       cge-gep-emi-999.
           exit.

      *    *===========================================================*
      *    * Routine di attribuzione numero riscossione                *
      *    *-----------------------------------------------------------*
       att-num-rsd-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumrsd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-rsd             .
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [numrsd]                                  *
      *              *-------------------------------------------------*
           move      w-num-rsd-scl-ann    to   rn-num-rsd-scl-ann     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [numrsd]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumrsd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-rsd             .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-num-rsd-400.
       att-num-rsd-200.
      *              *-------------------------------------------------*
      *              * Se record non esistente                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Scrittura record normalizzato               *
      *                  *---------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumrsd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-rsd             .
      *                  *---------------------------------------------*
      *                  * Unlock record                               *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumrsd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-rsd             .
      *                  *---------------------------------------------*
      *                  * Ripetizione dell'intera operazione          *
      *                  *---------------------------------------------*
           go to     att-num-rsd-000.
       att-num-rsd-400.
      *              *-------------------------------------------------*
      *              * Se record esistente                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore pre-incremento           *
      *                  *---------------------------------------------*
           move      rn-num-rsd-num-rsd   to   w-num-rsd-num-rsd      .
           move      w-num-rsd-r01-num    to   w-num-rsd-val-pre      .
      *                  *---------------------------------------------*
      *                  * Preparazione valore post-incremento         *
      *                  *---------------------------------------------*
           move      w-num-rsd-val-pre    to   w-num-rsd-val-pos      .
           add       1                    to   w-num-rsd-val-pos      .
           if        w-num-rsd-val-pos    =    zero
