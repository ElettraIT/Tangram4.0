                     go to car-buf-sdb-out-310
           else if   w-tes-tip-ope        =    0303
                     go to car-buf-sdb-out-320
           else if   w-tes-tip-ope        =    0304
                     go to car-buf-sdb-out-330
           else if   w-tes-tip-ope        =    0321 or
                     w-tes-tip-ope        =    0322 or
                     w-tes-tip-ope        =    0323 or
                     w-tes-tip-ope        =    0324
                     go to car-buf-sdb-out-340
           else if   w-tes-tip-ope        =    0350
                     go to car-buf-sdb-out-350
           else      go to car-buf-sdb-out-999.
       car-buf-sdb-out-310.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : 0301 o 0302               *
      *                  *---------------------------------------------*
           if        srt-tip-sdb          =    01
                     go to car-buf-sdb-out-380
           else      go to car-buf-sdb-out-400.
       car-buf-sdb-out-320.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : 0303                      *
      *                  *---------------------------------------------*
           if        srt-tip-sdb          =    07
                     go to car-buf-sdb-out-380
           else      go to car-buf-sdb-out-400.
       car-buf-sdb-out-330.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : 0304                      *
      *                  *---------------------------------------------*
           if        srt-tip-sdb          =    08
                     go to car-buf-sdb-out-380
           else      go to car-buf-sdb-out-400.
       car-buf-sdb-out-340.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : 0321 o 0322 o 0323 o 0324 *
      *                  *---------------------------------------------*
           if        srt-tip-ddr          =    11 or
                     srt-tip-ddr          =    21
                     go to car-buf-sdb-out-380
           else      go to car-buf-sdb-out-400.
       car-buf-sdb-out-350.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : 0350                      *
      *                  *---------------------------------------------*
           go to     car-buf-sdb-out-380.
       car-buf-sdb-out-380.
      *                  *---------------------------------------------*
      *                  * Aggiornamento elemento della tabella con    *
      *                  * indice 01                                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione mese e anno della data   *
      *                      * scadenza                                *
      *                      *-----------------------------------------*
           move      srt-dts-eff          to   s-dat                  .
           move      s-saa                to   w-car-buf-sdb-wsa      .
           move      s-mes                to   w-car-buf-sdb-wms      .
      *                      *-----------------------------------------*
      *                      * Ciclo per sette mesi                    *
      *                      *-----------------------------------------*
           move      zero                 to   w-car-buf-sdb-ctr      .
       car-buf-sdb-out-385.
           add       1                    to   w-car-buf-sdb-ctr      .
      *                          *-------------------------------------*
      *                          * Se data scadenza superiore a tutti  *
      *                          * i mesi in tabella, aggiornamento    *
      *                          * dell'ultimo elemento                *
      *                          *-------------------------------------*
           if        w-car-buf-sdb-ctr    >    7
                     move  7              to   w-car-buf-sdb-ctr
                     go to car-buf-sdb-out-390.
      *                          *-------------------------------------*
      *                          * Se data scadenza superiore al mese  *
      *                          * in considerazione : riciclo         *
      *                          *-------------------------------------*
           if        w-car-buf-sdb-wam    >    w-tes-sel-tpm-sam
                                              (1,
                                               w-car-buf-sdb-ctr)
                     go to car-buf-sdb-out-385.
       car-buf-sdb-out-390.
      *                      *-----------------------------------------*
