      *              * Esecuzione visualizzazione prima linea          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      01                   to   v-pos                  .
           move      w-lin-imm-dsp-lin (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Se una sola linea : uscita                      *
      *              *-------------------------------------------------*
           if        w-lin-num-lin-prc    =    1
                     go to vis-lin-cor-999.
      *              *-------------------------------------------------*
      *              * Esecuzione visualizzazione altre linee          *
      *              *-------------------------------------------------*
           move      1                    to   w-cnt-wrk-ctr-003      .
       vis-lin-cor-925.
           add       1                    to   w-cnt-wrk-ctr-003      .
           if        w-cnt-wrk-ctr-003    >    w-lin-num-lin-prc
                     go to vis-lin-cor-999.
           add       1                    to   w-cnt-wrk-ctr-002      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      01                   to   v-pos                  .
           move      w-lin-imm-dsp-lin
                    (w-cnt-wrk-ctr-003)   to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     vis-lin-cor-925.
       vis-lin-cor-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts area linee di corpo               *
      *    *-----------------------------------------------------------*
       pmt-cor-reg-000.
      *              *-------------------------------------------------*
      *              * Erase linee impegnate sia dall'area per la fin- *
      *              * catura che dall'area delle righe effettive      *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      21                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cor-reg-100.
      *              *-------------------------------------------------*
      *              * Fincatura                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo operazione  *
      *                  *---------------------------------------------*
           if        w-tes-tip-ope        =    0301 or
                     w-tes-tip-ope        =    0302 or
                     w-tes-tip-ope        =    0303 or
                     w-tes-tip-ope        =    0304
                     go to pmt-cor-reg-110
           else if   w-tes-tip-ope        =    0321 or
                     w-tes-tip-ope        =    0322 or
                     w-tes-tip-ope        =    0323 or
                     w-tes-tip-ope        =    0324
                     go to pmt-cor-reg-120
           else if   w-tes-tip-ope        =    0350
                     go to pmt-cor-reg-130.
       pmt-cor-reg-110.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : Riscossione               *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "N.R.|Tipo|  Riferimenti Cliente  |Scadenza|Importo
      -              " Scadenza|Importo Riscosso|C/S"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           go to     pmt-cor-reg-200.
       pmt-cor-reg-120.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : Pagamento                 *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "N.R.|Tipo|  Riferimenti Cliente  |Scadenza|Importo
      -              " Scadenza| Importo Pagato |C/S"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           go to     pmt-cor-reg-200.
       pmt-cor-reg-130.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : Compensazione             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "N.R.|Tipo|  Riferimenti Cliente  |Scadenza|Importo
      -              " Scadenza| Nuovo Importo  |   "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           go to     pmt-cor-reg-200.
       pmt-cor-reg-200.
      *              *-------------------------------------------------*
      *              * Sottolineatura fincatura                        *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "----|----|-----------------------|--------|-------
      -              "---------|----------------|---"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Sottolineatura per i totali                     *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "---------|-----------------------|--------|-------
      -              "---------|----------------|---"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cor-reg-500.
      *              *-------------------------------------------------*
      *              * Literal per i totali                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo operazione  *
      *                  *---------------------------------------------*
           if        w-tes-tip-ope        =    0301 or
                     w-tes-tip-ope        =    0302 or
                     w-tes-tip-ope        =    0303 or
                     w-tes-tip-ope        =    0304
                     go to pmt-cor-reg-510
           else if   w-tes-tip-ope        =    0321 or
                     w-tes-tip-ope        =    0322 or
                     w-tes-tip-ope        =    0323 or
                     w-tes-tip-ope        =    0324
                     go to pmt-cor-reg-510
           else if   w-tes-tip-ope        =    0350
                     go to pmt-cor-reg-520.
       pmt-cor-reg-510.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : Riscossione o Pagamento   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione dell'importo ri- *
      *                      * scosso                                  *
      *                      *-----------------------------------------*
           if        w-tes-imp-rsd (1)    =    zero
                     go to pmt-cor-reg-512
           else      go to pmt-cor-reg-514.
       pmt-cor-reg-512.
      *                      *-----------------------------------------*
      *                      * Importo riscosso : zero                 *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "         |                       |        |       
      -              " Totale: |                |   "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           go to     pmt-cor-reg-600.
       pmt-cor-reg-514.
      *                      *-----------------------------------------*
      *                      * Importo riscosso : diverso da zero      *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Residuo: |                       |        |       
      -              " Totale: |                |   "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           go to     pmt-cor-reg-600.
       pmt-cor-reg-520.
      *                  *---------------------------------------------*
      *                  * Tipo operazione : Compensazione             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Massimo: |                       |        |       
      -              "Abbuono: |                |   "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           go to     pmt-cor-reg-600.
       pmt-cor-reg-600.
      *              *-------------------------------------------------*
      *              * Visualizzazione totali                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Totale scadenze selezionate                 *
      *                  *---------------------------------------------*
           perform   vis-tot-scs-000      thru vis-tot-scs-999        .
      *                  *---------------------------------------------*
      *                  * Residuo da assegnare                        *
      *                  *---------------------------------------------*
           perform   vis-tot-rda-000      thru vis-tot-rda-999        .
       pmt-cor-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione riga corpo di accettazione in w-rig       *
      *    *-----------------------------------------------------------*
       vis-rig-cor-000.
      *              *-------------------------------------------------*
      *              * Se riga di tipo New : nessuna visualizzazione   *
      *              *-------------------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to vis-rig-cor-999.
       vis-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riga corpo di accettazione    *
      *    *-----------------------------------------------------------*
       pmt-rig-cor-000.
       pmt-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Accettazione del primo campo riga corpo espansa : Importo *
      *    * riscosso                                                  *
      *    *-----------------------------------------------------------*
       acc-imp-ris-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to acc-imp-ris-999.
      *                  *---------------------------------------------*
      *                  * Determinazione numero linea assoluta a vi-  *
      *                  * deo                                         *
      *                  *---------------------------------------------*
           move      w-cnt-cor-nrg-dac    to   w-cnt-wrk-ctr-001      .
           subtract  1                    from w-cnt-wrk-ctr-001      .
           divide    w-lin-num-lin-vis    into w-cnt-wrk-ctr-001
                                        giving w-cnt-wrk-ctr-003
                                     remainder w-cnt-wrk-ctr-002      .
           multiply  w-lin-num-lin-prc    by   w-cnt-wrk-ctr-002      .
           add       w-lin-pri-lin-vid    to   w-cnt-wrk-ctr-002      .
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-imp-ris (1)    to   w-sav-imp-ris          .
       acc-imp-ris-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino valore precedente                *
      *                  *---------------------------------------------*
           move      w-sav-imp-ris        to   w-rig-imp-ris (1)      .
      *                  *---------------------------------------------*
      *                  * Note operative                              *
      *                  *---------------------------------------------*
           move      "NT"                 to   v-ope                  .
           if        w-tes-tip-ope        not  = 0350
                     move  "[F1] per modificare se importo in Conto o a 
      -                    "Saldo                               "
                                          to   v-nt1
                     move  spaces         to   v-nt2
           else      move  "Tasto Selezione per contrassegnare le scaden
      -                    "ze da compensare                    "
                                          to   v-nt1
                     move  "[F2] per selezionare la scadenza che accorpa
      -                    " le altre                           "
                                          to   v-nt2                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Parametri generici                          *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vlt (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      61                   to   v-pos                  .
           if        w-tes-tip-ope        =    0350
                     move  "G"            to   v-edm
           else      move  "GB"           to   v-edm                  .
      *                  *---------------------------------------------*
      *                  * Tasti funzione                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Up   : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "UP  "               to   v-pfk (01)             .
      *                      *-----------------------------------------*
      *                      * Down : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "DOWN"         to   v-pfk (02)             .
      *                      *-----------------------------------------*
      *                      * Insr : sempre ammesso, a meno che non   *
      *                      *        si sia in un record New oppure   *
      *                      *        manchi spazio per l'inserimento  *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces and
                     w-cat-rig-ins        =    spaces
                     move  "INSR"         to   v-pfk (04)             .
      *                      *-----------------------------------------*
      *                      * Do   : sempre ammesso, purche' sia con- *
      *                      *        cesso dallo status delle impo-   *
      *                      *        stazioni; eventualmente disat-   *
      *                      *        tivato dal richiamo della sub-   *
      *                      *        routine di accettazione          *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
      *                      *-----------------------------------------*
      *                      * Remv : sempre ammesso, a meno che non   *
      *                      *        ci sia una sola riga             *
      *                      *-----------------------------------------*
           if        w-cat-rig-max        >    1
                     move  "REMV"         to   v-pfk (06)             .
      *                      *-----------------------------------------*
      *                      * Prsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "PRSC"               to   v-pfk (07)             .
      *                      *-----------------------------------------*
      *                      * Nxsc : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "NXSC"         to   v-pfk (08)             .
      *                      *-----------------------------------------*
      *                      * Back : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sulla prima riga     *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    not  = 1
                     move  "BACK"         to   v-pfk (09)             .
      *                      *-----------------------------------------*
      *                      * Tab  : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'ultima riga e   *
      *                      *        che questa sia in Append         *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces or
                     w-cat-rig-lst        =    spaces
                     move  "TAB "         to   v-pfk (10)             .
      *                      *-----------------------------------------*
      *                      * Slct : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "SLCT"               to   v-pfk (11)             .
      *                      *-----------------------------------------*
      *                      * Expd : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "EXPD"               to   v-pfk (12)             .
      *                      *-----------------------------------------*
      *                      * Pf1  : sempre ammesso, a meno che non   *
      *                      *        sia un'operazione di Compensa-   *
      *                      *        zione                            *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        not  = 0350
                     move  "[1] "         to   v-pfk (14)             .
      *                      *-----------------------------------------*
      *                      * Pf2  : ammesso solo in un'operazione di *
      *                      *        Compensazione                    *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        =    0350
                     move  "[2] "         to   v-pfk (15)             .
      *                      *-----------------------------------------*
      *                      * Valore di accettazione                  *
      *                      *-----------------------------------------*
           move      w-rig-imp-ris (1)    to   v-num                  .
       acc-imp-ris-200.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine di accettazione     *
      *                      *-----------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-imp-ris-220.
      *              *-------------------------------------------------*
      *              * Cancellazione eventuali note operative          *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Se Return o Pf1                                 *
      *              *-------------------------------------------------*
           if        v-key                =    spaces or
                     v-key                =    "[1] "
                     go to acc-imp-ris-400.
       acc-imp-ris-250.
      *              *-------------------------------------------------*
      *              * Se Slct                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "SLCT"
                     go to acc-imp-ris-300
           else      go to acc-imp-ris-350.
       acc-imp-ris-300.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda che sia stato variato  *
      *                  * il campo di impostazione                    *
      *                  *---------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-imp-ris-310
           else      go to acc-imp-ris-320.
       acc-imp-ris-310.
      *                  *---------------------------------------------*
      *                  * Se e' stato variato il campo di impostazio- *
      *                  * ne : trattamento tasto SLCT per posiziona-  *
      *                  * mento su riga                               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Conversione numero riga impostato in    *
      *                      * formato numerico                        *
      *                      *-----------------------------------------*
           move      v-num                to   w-cnt-slc-rap-num      .
      *                      *-----------------------------------------*
      *                      * Se numero riga impostato minore di 1 o  *
      *                      * maggiore del massimo : reimpostazione   *
      *                      *-----------------------------------------*
           if        w-cnt-slc-rap-num    =    zero       or
                     w-cnt-slc-rap-num    >    w-cat-rig-max
                     go to acc-imp-ris-100.
      *                      *-----------------------------------------*
      *                      * Se numero riga impostato pari a numero  *
      *                      * riga attuale : reimpostazione           *
      *                      *-----------------------------------------*
           if        w-cnt-slc-rap-num    =    w-cnt-cor-nrg-dac
                     go to acc-imp-ris-100.
      *                      *-----------------------------------------*
      *                      * Preparazione parametri e uscita         *
      *                      *-----------------------------------------*
           move      w-cnt-slc-rap-num    to   w-cnt-slc-num-rig      .
           move      "."                  to   w-cnt-tus-acc-rig      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione importo riscosso        *
      *                      *-----------------------------------------*
           perform   vis-imp-ris-000      thru vis-imp-ris-999        .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     acc-imp-ris-999.
       acc-imp-ris-320.
      *                  *---------------------------------------------*
      *                  * Se non e' stato variato il campo di impo-   *
      *                  * stazione : trattamento tasto SLCT per in-   *
      *                  * versione del campo                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo opera-  *
      *                      * zione                                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        =    0301 or
                     w-tes-tip-ope        =    0302 or
                     w-tes-tip-ope        =    0303 or
                     w-tes-tip-ope        =    0304
                     go to acc-imp-ris-330
           else if   w-tes-tip-ope        =    0321 or
                     w-tes-tip-ope        =    0322 or
                     w-tes-tip-ope        =    0323 or
                     w-tes-tip-ope        =    0324
                     go to acc-imp-ris-330
           else if   w-tes-tip-ope        =    0350
                     go to acc-imp-ris-340.
       acc-imp-ris-330.
      *                      *-----------------------------------------*
      *                      * Tipo operazione : Riscossione o Paga-   *
      *                      * mento                                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se importo riscosso gia' esistente  *
      *                          *-------------------------------------*
           if        w-rig-imp-ris (1)    =    zero
                     go to acc-imp-ris-335.
      *                              *---------------------------------*
      *                              * Normalizzazione importo riscos- *
      *                              * so                              *
      *                              *---------------------------------*
           move      zero                 to   w-rig-imp-ris (1)      .
      *                              *---------------------------------*
      *                              * Normalizzazione segnale di Ac-  *
      *                              * conto/Saldo                     *
      *                              *---------------------------------*
           move      zero                 to   w-rig-aos-ris (1)      .
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     acc-imp-ris-338.
       acc-imp-ris-335.
      *                          *-------------------------------------*
      *                          * Se importo riscosso non esistente   *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Importo riscosso pari all'im-   *
      *                              * porto scadenza                  *
      *                              *---------------------------------*
           move      w-rig-imp-sdb (1)    to   w-rig-imp-ris (1)      .
      *                              *---------------------------------*
      *                              * Segnale di Acconto/Saldo : A    *
      *                              * saldo                           *
      *                              *---------------------------------*
           move      01                   to   w-rig-aos-ris (1)      .
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     acc-imp-ris-338.
       acc-imp-ris-338.
      *                          *-------------------------------------*
      *                          * Visualizzazione importo riscosso    *
      *                          *-------------------------------------*
           perform   vis-imp-ris-000      thru vis-imp-ris-999        .
      *                          *-------------------------------------*
      *                          * Visualizzazione segnale di Acconto/ *
      *                          * Saldo                               *
      *                          *-------------------------------------*
           perform   vis-aos-ris-000      thru vis-aos-ris-999        .
      *                          *-------------------------------------*
      *                          * Uscita come per Return              *
      *                          *-------------------------------------*
           move      spaces               to   w-cnt-tus-acc-rig      .
           go to     acc-imp-ris-999.
       acc-imp-ris-340.
      *                      *-----------------------------------------*
      *                      * Tipo operazione : Compensazione         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se importo riscosso a zero : reim-  *
      *                          * postazione                          *
      *                          *-------------------------------------*
           if        w-rig-imp-ris (1)    =    zero
                     go to acc-imp-ris-100.
      *                          *-------------------------------------*
      *                          * Se scadenza gia' selezionata        *
      *                          *-------------------------------------*
           if        w-rig-flg-scs (1)    =    spaces
                     go to acc-imp-ris-345.
      *                              *---------------------------------*
      *                              * Normalizzazione flag di scaden- *
      *                              * za selezionata                  *
      *                              *---------------------------------*
           move      spaces               to   w-rig-flg-scs (1)      .
           move      spaces               to   w-rig-flg-svs (1)      .
      *                              *---------------------------------*
      *                              * Controaggiornamento numero sca- *
      *                              * denze selezionate positivo o    *
      *                              * negativo                        *
      *                              *---------------------------------*
           if        w-rig-imp-ris (1)    >    zero
                     subtract 1           from w-tes-num-ssp (1)
           else      subtract 1           from w-tes-num-ssn (1)      .
      *                              *---------------------------------*
      *                              * Controaggiornamento importo     *
      *                              * scadenze selezionate positivo o *
      *                              * negativo                        *
      *                              *---------------------------------*
           if        w-rig-imp-ris (1)    >    zero
                     subtract w-rig-imp-ris (1)
                                          from w-tes-imp-ssp (1)
           else      add      w-rig-imp-ris (1)
                                          to   w-tes-imp-ssn (1)      .
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     acc-imp-ris-348.
       acc-imp-ris-345.
      *                          *-------------------------------------*
      *                          * Se scadenza non selezionata         *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Attivazione flag di scadenza    *
      *                              * selezionata                     *
      *                              *---------------------------------*
           move      "#"                  to   w-rig-flg-scs (1)      .
           move      "X"                  to   w-rig-flg-svs (1)      .
      *                              *---------------------------------*
      *                              * Aggiornamento numero scadenze   *
      *                              * selezionate positivo o negativo *
      *                              *---------------------------------*
           if        w-rig-imp-ris (1)    >    zero
                     add      1           to   w-tes-num-ssp (1)
           else      add      1           to   w-tes-num-ssn (1)      .
      *                              *---------------------------------*
      *                              * Aggiornamento importo scadenze  *
      *                              * selezionate positivo o negativo *
      *                              *---------------------------------*
           if        w-rig-imp-ris (1)    >    zero
                     add      w-rig-imp-ris (1)
                                          to   w-tes-imp-ssp (1)
           else      subtract w-rig-imp-ris (1)
                                          from w-tes-imp-ssn (1)      .
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     acc-imp-ris-348.
       acc-imp-ris-348.
      *                          *-------------------------------------*
      *                          * Visualizzazione segnale di scadenza *
      *                          * selezionata                         *
      *                          *-------------------------------------*
           perform   vis-flg-scs-000      thru vis-flg-scs-999        .
      *                          *-------------------------------------*
      *                          * Uscita come per Return              *
      *                          *-------------------------------------*
           move      spaces               to   w-cnt-tus-acc-rig      .
           go to     acc-imp-ris-999.
       acc-imp-ris-350.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-imp-ris-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-rig
                     go to acc-imp-ris-999.
      *              *-------------------------------------------------*
      *              * Se premuto un altro tasto funzione non deve es- *
      *              * sere avvenuta variazione del campo d'impostaz.  *
      *              *-------------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-imp-ris-100.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     move  "U"            to   w-cnt-tus-acc-rig
                     go to acc-imp-ris-999.
      *              *-------------------------------------------------*
      *              * Se Down                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DOWN"
                     move  "D"            to   w-cnt-tus-acc-rig
                     go to acc-imp-ris-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-imp-ris-999
                     else    go to acc-imp-ris-100.
      *              *-------------------------------------------------*
      *              * Se Insr                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "INSR"
                     move  "I"            to   w-cnt-tus-acc-rig
                     go to acc-imp-ris-999.
      *              *-------------------------------------------------*
      *              * Se Expd                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "EXPD"
                     go to acc-imp-ris-360.
      *                  *---------------------------------------------*
      *                  * Espansione su scadenze debitori             *
      *                  *---------------------------------------------*
           move      "N"                  to   w-esp-arc-sdb-sns      .
           move      w-rig-num-sdb (1)    to   w-esp-arc-sdb-num      .
           perform   esp-arc-sdb-000      thru esp-arc-sdb-999        .
      *                  *---------------------------------------------*
      *                  * Reimpostazione                              *
      *                  *---------------------------------------------*
           go to     acc-imp-ris-100.
       acc-imp-ris-360.
      *              *-------------------------------------------------*
      *              * Se Pf2                                          *
      *              *-------------------------------------------------*
           if        v-key                not  = "[2] "
                     go to acc-imp-ris-380.
      *                  *---------------------------------------------*
      *                  * Richiamo routine di compensazione semi-au-  *
      *                  * tomatica scadenze selezionate               *
      *                  *---------------------------------------------*
           perform   cmp-sem-scs-000      thru cmp-sem-scs-999        .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        w-cmp-sem-scs-flg    =    spaces
                     go to acc-imp-ris-362
           else      go to acc-imp-ris-364.
       acc-imp-ris-362.
      *                  *---------------------------------------------*
      *                  * Se esito operazione : Positivo              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Numero pagina attualmente visualizzato  *
      *                      * a zero                                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-cnt-cor-nrp-vis      .
      *                      *-----------------------------------------*
      *                      * Attivazione flag di non-incremento nu-  *
      *                      * mero riga da accettare                  *
      *                      *-----------------------------------------*
           move      "#"                  to   w-acc-cor-reg-fni      .
      *                      *-----------------------------------------*
      *                      * Simulazione uscita come per Down        *
      *                      *-----------------------------------------*
           move      "D"                  to   w-cnt-tus-acc-rig      .
           go to     acc-imp-ris-999.
       acc-imp-ris-364.
      *                  *---------------------------------------------*
      *                  * Se esito operazione : Negativo              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-imp-ris-100.
       acc-imp-ris-380.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-imp-ris-999.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "TAB "
                     move  "T"            to   w-cnt-tus-acc-rig
                     go to acc-imp-ris-999.
      *              *-------------------------------------------------*
      *              * Se Back                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "BACK"
                     move  "B"            to   w-cnt-tus-acc-rig
                     go to acc-imp-ris-999.
      *              *-------------------------------------------------*
      *              * Se Nxsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     move  "N"            to   w-cnt-tus-acc-rig
                     go to acc-imp-ris-999.
      *              *-------------------------------------------------*
      *              * Se Prsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "PRSC"
                     move  "P"            to   w-cnt-tus-acc-rig
                     go to acc-imp-ris-999.
       acc-imp-ris-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore in campo di destinazione             *
      *                  *---------------------------------------------*
           move      v-num                to   w-rig-imp-ris (1)      .
      *                  *---------------------------------------------*
      *                  * Se valore impostato a zero                  *
      *                  *---------------------------------------------*
           if        w-rig-imp-ris (1)    not  = zero
                     go to acc-imp-ris-450.
      *                      *-----------------------------------------*
      *                      * Trattamento segnale di Acconto/Saldo    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da trattare                 *
      *                          *-------------------------------------*
           if        w-tes-tip-ope        =    0350
                     go to acc-imp-ris-450.
      *                          *-------------------------------------*
      *                          * Normalizzazione                     *
      *                          *-------------------------------------*
           move      zero                 to   w-rig-aos-ris (1)      .
      *                          *-------------------------------------*
      *                          * Visualizzazione                     *
      *                          *-------------------------------------*
           perform   vis-aos-ris-000      thru vis-aos-ris-999        .
           go to     acc-imp-ris-600.
       acc-imp-ris-450.
      *                  *---------------------------------------------*
      *                  * Controllo di congruenza segno dell'importo  *
      *                  * scadenza con quello dell'importo riscosso   *
      *                  *---------------------------------------------*
           if        w-rig-imp-ris (1)    =    zero
                     go to acc-imp-ris-470.
           if        w-rig-imp-sdb (1)    <    zero
                     if    w-rig-imp-ris (1)
                                          <    zero
                           go to acc-imp-ris-470
                     else  go to acc-imp-ris-100
           else      if    w-rig-imp-ris (1)
                                          >    zero
                           go to acc-imp-ris-470
                     else  go to acc-imp-ris-100.
       acc-imp-ris-470.
      *                  *---------------------------------------------*
      *                  * Se Pf1                                      *
      *                  *---------------------------------------------*
           if        v-key                not = "[1] "
                     go to acc-imp-ris-500.
      *                      *-----------------------------------------*
      *                      * Se valore impostato a zero : reimposta- *
      *                      * zione                                   *
      *                      *-----------------------------------------*
           if        w-rig-imp-ris (1)    =    zero
                     go to acc-imp-ris-100.
      *                      *-----------------------------------------*
      *                      * Se valore impostato pari a importo sca- *
      *                      * denza : reimpostazione                  *
      *                      *-----------------------------------------*
           if        w-rig-imp-ris (1)    =    w-rig-imp-sdb (1)
                     go to acc-imp-ris-100.
      *                      *-----------------------------------------*
      *                      * Inversione del flag Acconto/Saldo       *
      *                      *-----------------------------------------*
           if        w-rig-aos-ris (1)    =    zero or
                     w-rig-aos-ris (1)    =    02
                     move  01             to   w-rig-aos-ris (1)
           else      move  02             to   w-rig-aos-ris (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione segnale di Acconto/Sal- *
      *                      * do                                      *
      *                      *-----------------------------------------*
           perform   vis-aos-ris-000      thru vis-aos-ris-999        .
           go to     acc-imp-ris-600.
       acc-imp-ris-500.
      *                  *---------------------------------------------*
      *                  * Trattamento segnale di Acconto/Saldo        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da trattare                     *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        =    0350
                     go to acc-imp-ris-600.
           if        w-rig-imp-ris (1)    =    w-sav-imp-ris
                     go to acc-imp-ris-600.
      *                      *-----------------------------------------*
      *                      * Trattamento                             *
      *                      *-----------------------------------------*
           if        w-rig-imp-ris (1)    =    w-rig-imp-sdb (1)
                     move  01             to   w-rig-aos-ris (1)
           else      move  02             to   w-rig-aos-ris (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione segnale di Acconto/Sal- *
      *                      * do                                      *
      *                      *-----------------------------------------*
           perform   vis-aos-ris-000      thru vis-aos-ris-999        .
           go to     acc-imp-ris-600.
       acc-imp-ris-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-imp-ris-800.
       acc-imp-ris-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Importo riscosso                  *
      *    *-----------------------------------------------------------*
       vis-imp-ris-000.
      *              *-------------------------------------------------*
      *              * Determinazione numero linea assoluta a video    *
      *              *-------------------------------------------------*
           move      w-cnt-cor-nrg-dac    to   w-cnt-wrk-ctr-001      .
           subtract  1                    from w-cnt-wrk-ctr-001      .
           divide    w-lin-num-lin-vis    into w-cnt-wrk-ctr-001
                                        giving w-cnt-wrk-ctr-003
                                     remainder w-cnt-wrk-ctr-002      .
           multiply  w-lin-num-lin-prc    by   w-cnt-wrk-ctr-002      .
           add       w-lin-pri-lin-vid    to   w-cnt-wrk-ctr-002      .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vlt (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      61                   to   v-pos                  .
           if        w-tes-tip-ope        =    0350
                     move  "G"            to   v-edm
           else      move  "GB"           to   v-edm                  .
           move      w-rig-imp-ris (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-imp-ris-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Segnale di Acconto/Saldo          *
      *    *-----------------------------------------------------------*
       vis-aos-ris-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        =    0350
                     go to vis-aos-ris-999.
      *              *-------------------------------------------------*
      *              * Determinazione numero linea assoluta a video    *
      *              *-------------------------------------------------*
           move      w-cnt-cor-nrg-dac    to   w-cnt-wrk-ctr-001      .
           subtract  1                    from w-cnt-wrk-ctr-001      .
           divide    w-lin-num-lin-vis    into w-cnt-wrk-ctr-001
                                        giving w-cnt-wrk-ctr-003
                                     remainder w-cnt-wrk-ctr-002      .
           multiply  w-lin-num-lin-prc    by   w-cnt-wrk-ctr-002      .
           add       w-lin-pri-lin-vid    to   w-cnt-wrk-ctr-002      .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      79                   to   v-pos                  .
           if        w-rig-aos-ris (1)    =    01
                     move  "S"            to   v-alf
           else if   w-rig-aos-ris (1)    =    02
                     move  "C"            to   v-alf
           else      move  spaces         to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-aos-ris-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Segnale di scadenza selezionata   *
      *    *-----------------------------------------------------------*
       vis-flg-scs-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        not  = 0350
                     go to vis-flg-scs-999.
      *              *-------------------------------------------------*
      *              * Determinazione numero linea assoluta a video    *
      *              *-------------------------------------------------*
           move      w-cnt-cor-nrg-dac    to   w-cnt-wrk-ctr-001      .
           subtract  1                    from w-cnt-wrk-ctr-001      .
           divide    w-lin-num-lin-vis    into w-cnt-wrk-ctr-001
                                        giving w-cnt-wrk-ctr-003
                                     remainder w-cnt-wrk-ctr-002      .
           multiply  w-lin-num-lin-prc    by   w-cnt-wrk-ctr-002      .
           add       w-lin-pri-lin-vid    to   w-cnt-wrk-ctr-002      .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      79                   to   v-pos                  .
           move      w-rig-flg-svs (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-flg-scs-999.
           exit.

      *    *===========================================================*
      *    * Routine di compensazione semi-automatica scadenze sele-   *
      *    * zionate                                                   *
      *    *-----------------------------------------------------------*
       cmp-sem-scs-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cmp-sem-scs-flg      .
      *              *-------------------------------------------------*
      *              * Test se operazione effettuabile                 *
      *              *-------------------------------------------------*
           if        w-tes-num-ssp (1)    not  = zero or
                     w-tes-num-ssn (1)    not  = zero
                     go to cmp-sem-scs-020.
      *                  *---------------------------------------------*
      *                  * Messaggio                                   *
      *                  *---------------------------------------------*
           move      "Non ci sono scadenze selezionate !                
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Uscita con errore                           *
      *                  *---------------------------------------------*
           go to     cmp-sem-scs-900.
       cmp-sem-scs-020.
      *              *-------------------------------------------------*
      *              * Test se sono state selezionate almeno due sca-  *
      *              * denze                                           *
      *              *-------------------------------------------------*
           add       w-tes-num-ssp (1)
                     w-tes-num-ssn (1)  giving w-cmp-sem-scs-wns      .
           if        w-cmp-sem-scs-wns    not  < 2
                     go to cmp-sem-scs-050.
      *                  *---------------------------------------------*
      *                  * Messaggio                                   *
      *                  *---------------------------------------------*
           move      "Devono essere selezionate almeno due scadenze !   
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Uscita con errore                           *
      *                  *---------------------------------------------*
           go to     cmp-sem-scs-900.
       cmp-sem-scs-050.
      *              *-------------------------------------------------*
      *              * Test se importo totale scadenze selezionate non *
      *              * supera il massimo richiesto                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su importo massimo                     *
      *                  *---------------------------------------------*
           if        w-tes-imp-rsd (1)    =    zero
                     go to cmp-sem-scs-100.
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           add       w-tes-imp-ssp (1)
                     w-tes-imp-ssn (1)  giving w-cmp-sem-scs-psp      .
           if        w-tes-imp-rsd (1)    >    w-cmp-sem-scs-psp
                     go to cmp-sem-scs-100.
      *                  *---------------------------------------------*
      *                  * Messaggio                                   *
      *                  *---------------------------------------------*
           move      "Superato l'importo massimo per la nuova scadena ! 
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Uscita con errore                           *
      *                  *---------------------------------------------*
           go to     cmp-sem-scs-900.
       cmp-sem-scs-100.
      *              *-------------------------------------------------*
      *              * Compensazione di scadenze negative su positive  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se possibile                           *
      *                  *---------------------------------------------*
           if        w-tes-num-ssn (1)    =    zero or
                     w-tes-num-ssp (1)    =    zero
                     go to cmp-sem-scs-500.
      *                  *---------------------------------------------*
      *                  * Test su importi da compensare               *
      *                  *---------------------------------------------*
           if        w-tes-imp-ssn (1)    not  > w-tes-imp-ssp (1)
                     go to cmp-sem-scs-110.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "La somma delle scadenze negative selezionate super
      -              "a quello delle "    to   w-err-box-err-msg      .
           move      "scadenze positive, pertanto l'operazione non e' es
      -              "eguibile !     "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                      *-----------------------------------------*
      *                      * Uscita con errore                       *
      *                      *-----------------------------------------*
           go to     cmp-sem-scs-900.
       cmp-sem-scs-110.
      *                  *---------------------------------------------*
      *                  * Salvataggio area w-rig                      *
      *                  *---------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *                  *---------------------------------------------*
      *                  * Salvataggio area catena                     *
      *                  *---------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *                  *---------------------------------------------*
      *                  * Normalizzazione numero scadenze positive    *
      *                  * incontrate                                  *
      *                  *---------------------------------------------*
           move      zero                 to   w-cmp-sem-scs-nsp      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione progressivo abbattimento    *
      *                  * scadenze positive incontrate                *
      *                  *---------------------------------------------*
           move      zero                 to   w-cmp-sem-scs-psp      .
      *                  *---------------------------------------------*
      *                  * Start su catena per primo movimento         *
      *                  *---------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       cmp-sem-scs-120.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale catena                  *
      *                  *---------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to cmp-sem-scs-300.
      *                  *---------------------------------------------*
      *                  * Movimento da buffer catena a w-rig          *
      *                  *---------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *                  *---------------------------------------------*
      *                  * Selezioni sul record                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su numero scadenza                 *
      *                      *-----------------------------------------*
           if        w-rig-num-sdb (1)    =    zero
                     go to cmp-sem-scs-120.
      *                      *-----------------------------------------*
      *                      * Test se scadenza selezionata            *
      *                      *-----------------------------------------*
           if        w-rig-flg-scs (1)    =    spaces
                     go to cmp-sem-scs-120.
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda che l'importo ris- *
      *                      * cosso sia positivo o negativo           *
      *                      *-----------------------------------------*
           if        w-rig-imp-ris (1)    <    zero
                     go to cmp-sem-scs-140
           else      go to cmp-sem-scs-160.
       cmp-sem-scs-140.
      *                      *-----------------------------------------*
      *                      * Importo scadenza : Negativo             *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Importo riscosso : Zero             *
      *                          *-------------------------------------*
           move      zero                 to   w-rig-imp-ris (1)      .
      *                          *-------------------------------------*
      *                          * Ad aggiornamento record catena      *
      *                          *-------------------------------------*
           go to     cmp-sem-scs-200.
       cmp-sem-scs-160.
      *                      *-----------------------------------------*
      *                      * Importo scadenza : Positivo             *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Incremento numero scadenze positive *
      *                          * incontrate                          *
      *                          *-------------------------------------*
           add       1                    to   w-cmp-sem-scs-nsp      .
      *                          *-------------------------------------*
      *                          * Deviazione a seconda che sia o no   *
      *                          * l'ultima scadenza positiva          *
      *                          *-------------------------------------*
           if        w-cmp-sem-scs-nsp    =    w-tes-num-ssp (1)
                     go to cmp-sem-scs-170
           else      go to cmp-sem-scs-180.
       cmp-sem-scs-170.
      *                          *-------------------------------------*
      *                          * Se ultima scadenza positiva         *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Determinazione quota di abbat-  *
      *                              * timento residua                 *
      *                              *---------------------------------*
           subtract  w-cmp-sem-scs-psp    from w-tes-imp-ssn (1)
                                        giving w-cmp-sem-scs-s18      .
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     cmp-sem-scs-190.
       cmp-sem-scs-180.
      *                          *-------------------------------------*
      *                          * Se non ultima scadenza positiva     *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Determinazione quota di abbat-  *
      *                              * timento dell'importo nuova sca- *
      *                              * denza                           *
      *                              *---------------------------------*
           multiply  w-rig-imp-ris (1)    by   w-tes-imp-ssn (1)
                                        giving w-cmp-sem-scs-s18      .
           divide    w-tes-imp-ssp (1)    into w-cmp-sem-scs-s18
                                               rounded                .
      *                              *---------------------------------*
      *                              * Aggiornamento progressivo ab-   *
      *                              * battimento scadenze positive    *
      *                              * incontrate                      *
      *                              *---------------------------------*
           add       w-cmp-sem-scs-s18    to   w-cmp-sem-scs-psp      .
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     cmp-sem-scs-190.
       cmp-sem-scs-190.
      *                          *-------------------------------------*
      *                          * Aggiornamento importo riscosso con  *
      *                          * quota di abbattimento               *
      *                          *-------------------------------------*
           subtract  w-cmp-sem-scs-s18    from w-rig-imp-ris (1)      .
      *                          *-------------------------------------*
      *                          * Ad aggiornamento record catena      *
      *                          *-------------------------------------*
           go to     cmp-sem-scs-200.
       cmp-sem-scs-200.
      *                      *-----------------------------------------*
      *                      * Normalizzazione segnale di scadenza se- *
      *                      * lezionata                               *
      *                      *-----------------------------------------*
           move      spaces               to   w-rig-flg-scs (1)      .
           move      spaces               to   w-rig-flg-svs (1)      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento record in catena          *
      *                      *-----------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-cur        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                      *-----------------------------------------*
      *                      * Riciclo su lettura catena               *
      *                      *-----------------------------------------*
           go to     cmp-sem-scs-120.
       cmp-sem-scs-300.
      *                  *---------------------------------------------*
      *                  * A uscita con successo                       *
      *                  *---------------------------------------------*
           go to     cmp-sem-scs-700.
       cmp-sem-scs-500.
      *              *-------------------------------------------------*
      *              * Compensazione per scadenze dello stesso segno   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione segno scadenze selezionate   *
      *                  *---------------------------------------------*
           if        w-tes-num-ssp (1)    not  = zero and
                     w-tes-imp-ssp (1)    not  = zero
                     move  "+"            to   w-cmp-sem-scs-sss
                     go to cmp-sem-scs-505
           else if   w-tes-num-ssn (1)    not  = zero and
                     w-tes-imp-ssn (1)    not  = zero
                     move  "-"            to   w-cmp-sem-scs-sss
                     go to cmp-sem-scs-505.
      *                  *---------------------------------------------*
      *                  * Se non determinabile                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "Errore nella selezione scadenze !                 
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Uscita con errore                       *
      *                      *-----------------------------------------*
           go to     cmp-sem-scs-900.
       cmp-sem-scs-505.
      *                  *---------------------------------------------*
      *                  * Test se operazione richiesta da una scaden- *
      *                  * za selezionata                              *
      *                  *---------------------------------------------*
           if        w-rig-flg-scs (1)    not  = spaces
                     go to cmp-sem-scs-510.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "L'operazione e' eseguibile solo da una delle scade
      -              "nze selezionate"    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Uscita con errore                       *
      *                      *-----------------------------------------*
           go to     cmp-sem-scs-900.
       cmp-sem-scs-510.
      *                  *---------------------------------------------*
      *                  * Salvataggio numero scadenza                 *
      *                  *---------------------------------------------*
           move      w-rig-num-sdb (1)    to   w-sav-num-sdb          .
      *                  *---------------------------------------------*
      *                  * Salvataggio area w-rig                      *
      *                  *---------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *                  *---------------------------------------------*
      *                  * Salvataggio area catena                     *
      *                  *---------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *                  *---------------------------------------------*
      *                  * Start su catena per primo movimento         *
      *                  *---------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       cmp-sem-scs-520.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale catena                  *
      *                  *---------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to cmp-sem-scs-700.
      *                  *---------------------------------------------*
      *                  * Movimento da buffer catena a w-rig          *
      *                  *---------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *                  *---------------------------------------------*
      *                  * Selezioni sul record                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su numero scadenza                 *
      *                      *-----------------------------------------*
           if        w-rig-num-sdb (1)    =    zero
                     go to cmp-sem-scs-520.
      *                      *-----------------------------------------*
      *                      * Test se scadenza selezionata            *
      *                      *-----------------------------------------*
           if        w-rig-flg-scs (1)    =    spaces
                     go to cmp-sem-scs-520.
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda che la scadenza    *
      *                      * letta sia pari a quella salvata o no    *
      *                      *-----------------------------------------*
           if        w-rig-num-sdb (1)    =    w-sav-num-sdb
                     go to cmp-sem-scs-540
           else      go to cmp-sem-scs-560.
       cmp-sem-scs-540.
      *                      *-----------------------------------------*
      *                      * Se scadenza letta pari a quella salvata *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Aggiornamento importo riscosso per  *
      *                          * il totale scadenze selezionate      *
      *                          *-------------------------------------*
           if        w-cmp-sem-scs-sss    =    "+"
                     move  w-tes-imp-ssp (1)
                                          to   w-rig-imp-ris (1)
           else      move  w-tes-imp-ssn (1)
                                          to   w-rig-imp-ris (1)
                     multiply -1          by   w-rig-imp-ris (1)      .
      *                          *-------------------------------------*
      *                          * Segnale visualizzato                *
      *                          *-------------------------------------*
           move      "+"                  to   w-rig-flg-svs (1)      .
      *                          *-------------------------------------*
      *                          * Ad aggiornamento record catena      *
      *                          *-------------------------------------*
           go to     cmp-sem-scs-600.
       cmp-sem-scs-560.
      *                      *-----------------------------------------*
      *                      * Se scadenza letta diversa da quella     *
      *                      * salvata                                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Importo riscosso : Zero             *
      *                          *-------------------------------------*
           move      zero                 to   w-rig-imp-ris (1)      .
      *                          *-------------------------------------*
      *                          * Segnale visualizzato                *
      *                          *-------------------------------------*
           move      "-"                  to   w-rig-flg-svs (1)      .
      *                          *-------------------------------------*
      *                          * Ad aggiornamento record catena      *
      *                          *-------------------------------------*
           go to     cmp-sem-scs-600.
       cmp-sem-scs-600.
      *                      *-----------------------------------------*
      *                      * Normalizzazione segnale di scadenza se- *
      *                      * lezionata                               *
      *                      *-----------------------------------------*
           move      spaces               to   w-rig-flg-scs (1)      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento record in catena          *
      *                      *-----------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-cur        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                      *-----------------------------------------*
      *                      * Riciclo su lettura catena               *
      *                      *-----------------------------------------*
           go to     cmp-sem-scs-520.
       cmp-sem-scs-700.
      *                  *---------------------------------------------*
      *                  * Ripristino area catena                      *
      *                  *---------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
      *                  *---------------------------------------------*
      *                  * Ripristino area w-rig                       *
      *                  *---------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *                  *---------------------------------------------*
      *                  * Normalizzazione valori testata di appoggio  *
      *                  * per operazione di compensazione semi-auto-  *
      *                  * matica                                      *
      *                  *---------------------------------------------*
           move      zero                 to   w-tes-num-ssp (1)      .
           move      zero                 to   w-tes-imp-ssp (1)      .
           move      zero                 to   w-tes-num-ssn (1)      .
           move      zero                 to   w-tes-imp-ssn (1)      .
      *                  *---------------------------------------------*
      *                  * Uscita con successo                         *
      *                  *---------------------------------------------*
           go to     cmp-sem-scs-999.
       cmp-sem-scs-900.
      *                  *---------------------------------------------*
      *                  * Uscita senza successo                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di uscita ad errore                *
      *                      *-----------------------------------------*
           move      "#"                  to   w-cmp-sem-scs-flg      .
       cmp-sem-scs-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Numero scadenza debitore             *
      *    *-----------------------------------------------------------*
       acc-num-sdb-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to acc-num-sdb-999.
      *                  *---------------------------------------------*
      *                  * Preparazione box di accettazione            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Salvataggio immagine video              *
      *                      *-----------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Video in Off                            *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Box                                     *
      *                      *-----------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      12                   to   v-lin                  .
           move      14                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      67                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Titolo del box                          *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      31                   to   v-pos                  .
           move      "INSERIMENTO SCADENZA"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Prompt per numero scadenza              *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      30                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      16                   to   v-pos                  .
           move      "Numero scadenza da includere :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Video in On                             *
      *                      *-----------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-num-sdb-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      16                   to   v-lin                  .
           move      47                   to   v-pos                  .
           move      "FIND"               to   v-pfk (03)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "EXPD"               to   v-pfk (12)             .
           move      zero                 to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-num-sdb-900.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-num-sdb-900.
       acc-num-sdb-200.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-num-sdb-250.
      *                  *---------------------------------------------*
      *                  * Find su scadenze debitori                   *
      *                  *---------------------------------------------*
           perform   fnd-sdb-iir-000      thru fnd-sdb-iir-999        .
      *                  *---------------------------------------------*
      *                  * Se selezione non effettuata : a reimposta-  *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           if        w-fnd-sdb-iir-sel    not  = spaces
                     go to acc-num-sdb-100.
      *                  *---------------------------------------------*
      *                  * Numero scadenza selezionata in campo di de- *
      *                  * stinazione                                  *
      *                  *---------------------------------------------*
           move      w-fnd-sdb-iir-num    to   w-rig-num-sdb (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione numero scadenza selezionata *
      *                  *---------------------------------------------*
           perform   vis-num-sdb-000      thru vis-num-sdb-999        .
      *                  *---------------------------------------------*
      *                  * Normalizzazione function-key di impostazio- *
      *                  * ne                                          *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Continuazione post-impostazione             *
      *                  *---------------------------------------------*
           go to     acc-num-sdb-400.
       acc-num-sdb-250.
      *              *-------------------------------------------------*
      *              * Se Expd                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "EXPD"
                     go to acc-num-sdb-300.
      *                  *---------------------------------------------*
      *                  * Espansione su scadenze debitori             *
      *                  *---------------------------------------------*
           if        w-rig-num-sdb (1)    =    zero
                     move  "S"            to   w-esp-arc-sdb-sns
           else      move  "N"            to   w-esp-arc-sdb-sns      .
           move      v-num                to   w-esp-arc-sdb-num      .
           perform   esp-arc-sdb-000      thru esp-arc-sdb-999        .
      *                  *---------------------------------------------*
      *                  * Se selezione non effettuata : a reimposta-  *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           if        w-esp-arc-sdb-sel    not  = spaces
                     go to acc-num-sdb-100.
      *                  *---------------------------------------------*
      *                  * Ripresa numero scadenza selezionata         *
      *                  *---------------------------------------------*
           move      w-esp-arc-sdb-num    to   w-rig-num-sdb (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione numero scadenza selezionata *
      *                  *---------------------------------------------*
           perform   vis-num-sdb-000      thru vis-num-sdb-999        .
      *                  *---------------------------------------------*
      *                  * Normalizzazione function-key di impostazio- *
      *                  * ne                                          *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Continuazione post-impostazione             *
      *                  *---------------------------------------------*
           go to     acc-num-sdb-400.
       acc-num-sdb-300.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-num-sdb (1)      .
       acc-num-sdb-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura scadenza in archivio [sdb]          *
      *                  *---------------------------------------------*
           move      w-rig-num-sdb (1)    to   w-let-arc-sdb-num      .
           perform   let-arc-sdb-000      thru let-arc-sdb-999        .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        w-let-arc-sdb-flg    =    spaces
                     go to acc-num-sdb-420.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Numero scadenza non esistente in archivio scadenze
      -              " !             "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-num-sdb-100.
       acc-num-sdb-420.
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso                   *
      *                  *---------------------------------------------*
           if        w-rig-num-sdb (1)    =    zero
                     go to acc-num-sdb-100.
      *                  *---------------------------------------------*
      *                  * Selezioni bloccanti su record [sdb]         *
      *                  *---------------------------------------------*
           perform   sel-sdb-blo-000      thru sel-sdb-blo-999        .
           if        w-sel-sdb-blo-flg    =    zero
                     go to acc-num-sdb-440.
      *                      *-----------------------------------------*
      *                      * Box di errore per selezioni bloccanti   *
      *                      *-----------------------------------------*
           perform   acc-num-sdb-bsb-000  thru acc-num-sdb-bsb-999    .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-num-sdb-100.
       acc-num-sdb-440.
      *                  *---------------------------------------------*
      *                  * Selezioni non bloccanti su record [sdb]     *
      *                  *---------------------------------------------*
           perform   sel-sdb-nbl-000      thru sel-sdb-nbl-999        .
           if        w-sel-sdb-nbl-flg    =    zero
                     go to acc-num-sdb-460.
      *                      *-----------------------------------------*
      *                      * Box di errore per selezioni non bloc-   *
      *                      * canti                                   *
      *                      *-----------------------------------------*
           perform   acc-num-sdb-bsn-000  thru acc-num-sdb-bsn-999    .
       acc-num-sdb-460.
      *                  *---------------------------------------------*
      *                  * Composizione riga della catena              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Data registrazione contabilita' per     *
      *                      * l'emissione                             *
      *                      *-----------------------------------------*
           move      rf-sdb-drc-emi       to   w-rig-drc-emi (1)      .
      *                      *-----------------------------------------*
      *                      * Numero protocollo contabilita' per l'e- *
      *                      * missione                                *
      *                      *-----------------------------------------*
           move      rf-sdb-npc-emi       to   w-rig-npc-emi (1)      .
      *                      *-----------------------------------------*
      *                      * Numero protocollo fattura cliente       *
      *                      *-----------------------------------------*
           move      rf-sdb-prt-fcl       to   w-rig-prt-fcl (1)      .
      *                      *-----------------------------------------*
      *                      * Codice agente                           *
      *                      *-----------------------------------------*
           move      rf-sdb-cod-age       to   w-rig-cod-age (1)      .
      *                      *-----------------------------------------*
      *                      * Tipo scadenza debitore                  *
      *                      *-----------------------------------------*
           move      rf-sdb-tip-sdb       to   w-rig-tip-sdb (1)      .
      *                      *-----------------------------------------*
      *                      * Si/No dilazione concordata              *
      *                      *-----------------------------------------*
           move      rf-sdb-snx-dlc       to   w-rig-snx-dlc (1)      .
      *                      *-----------------------------------------*
      *                      * Si/No contrassegno                      *
      *                      *-----------------------------------------*
           move      rf-sdb-snx-cts       to   w-rig-snx-cts (1)      .
      *                      *-----------------------------------------*
      *                      * Si/No scadenza ritornata insoluta       *
      *                      *-----------------------------------------*
           if        rf-sdb-dtr-isp       =    zero
                     move  "N"            to   w-rig-snx-ins (1)
           else      move  "S"            to   w-rig-snx-ins (1)      .
      *                      *-----------------------------------------*
      *                      * Tipo acquisizione scadenza debitore     *
      *                      *-----------------------------------------*
           move      rf-sdb-tac-sdb       to   w-rig-tac-sdb (1)      .
      *                      *-----------------------------------------*
      *                      * Tipo valuta scadenza debitore           *
      *                      *-----------------------------------------*
           move      rf-sdb-tvl-sdb       to   w-rig-tvl-sdb (1)      .
      *                      *-----------------------------------------*
      *                      * Data scadenza                           *
      *                      *-----------------------------------------*
           move      rf-sdb-dts-sdb       to   w-rig-dts-sdb (1)      .
      *                      *-----------------------------------------*
      *                      * Codice dipendenza del debitore          *
      *                      *-----------------------------------------*
           move      rf-sdb-dpz-dbt       to   w-rig-dpz-dbt (1)      .
      *                      *-----------------------------------------*
      *                      * Inoltro scadenza al debitore            *
      *                      *-----------------------------------------*
           move      rf-sdb-inl-sdb       to   w-rig-inl-sdb (1)      .
      *                      *-----------------------------------------*
      *                      * Importo scadenza                        *
      *                      *-----------------------------------------*
           move      rf-sdb-imp-sdb       to   w-rig-imp-sdb (1)      .
      *                      *-----------------------------------------*
      *                      * Data documento di riferimento           *
      *                      *-----------------------------------------*
           move      rf-sdb-dat-ddr       to   w-rig-dat-ddr (1)      .
      *                      *-----------------------------------------*
      *                      * Numero documento di riferimento         *
      *                      *-----------------------------------------*
           move      rf-sdb-num-ddr       to   w-rig-num-ddr (1)      .
      *                      *-----------------------------------------*
      *                      * Tipo documento di riferimento           *
      *                      *-----------------------------------------*
           move      rf-sdb-tip-ddr       to   w-rig-tip-ddr (1)      .
      *                      *-----------------------------------------*
      *                      * Importo documento di riferimento        *
      *                      *-----------------------------------------*
           move      rf-sdb-imp-ddr       to   w-rig-imp-ddr (1)      .
      *                      *-----------------------------------------*
      *                      * Numero rata documento di riferimento    *
      *                      *-----------------------------------------*
