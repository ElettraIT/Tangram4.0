           move      "GK"                 to   f-ope                  .
           move      "NUMSDB    "         to   f-key                  .
           move      w-bsd-num-sdb
                    (w-pos-cnf-mod-ctr)   to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                      *-----------------------------------------*
      *                      * Se record non esistente : riciclo       *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to pos-cnf-mod-520.
      *                      *-----------------------------------------*
      *                      * Controlli su scadenza, che non abbia    *
      *                      * nel frattempo avuto modifiche sullo     *
      *                      * status, ricontrollando che lo status    *
      *                      * non indichi movimenti successivi a      *
      *                      * quello di emissione                     *
      *                      *-----------------------------------------*
           perform   det-sts-sdb-000      thru det-sts-sdb-999        .
           if       (w-det-sts-sdb-sts    =    "A"    ) and
                    (w-det-sts-sdb-suo    =    "EMI" or
                     w-det-sts-sdb-suo    =    "ISP"  )
                     go to pos-cnf-mod-540.
      *                      *-----------------------------------------*
      *                      * Se controllo non superato               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Unlock [sdb]                        *
      *                          *-------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                          *-------------------------------------*
