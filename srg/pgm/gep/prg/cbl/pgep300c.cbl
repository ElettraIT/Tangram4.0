      *                  * generale che era stato a suo tempo genera-  *
      *                  * to a fronte del movimento di riscossione    *
      *                  *---------------------------------------------*
           move      "DE"                 to   l-cge-300-tip-ope      .
           move      w-tes-drc-rsd (2)    to   l-cge-300-dat-reg      .
           move      w-tes-npc-rsd (2)    to   l-cge-300-num-prt      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                  *---------------------------------------------*
      *                  * Aggiornamenti contabili generati dalla ge-  *
      *                  * stione portafoglio a fronte del movimento   *
      *                  * di riscossione                              *
      *                  *---------------------------------------------*
           perform   cge-gep-ris-000      thru cge-gep-ris-999        .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione data e protocollo contabi-  *
      *                  * lita'                                       *
      *                  *---------------------------------------------*
           move      l-cge-300-dat-reg    to   w-tes-drc-rsd (1)      .
           move      l-cge-300-num-prt    to   w-tes-npc-rsd (1)      .
       pos-cnf-mod-150.
      *              *-------------------------------------------------*
      *              * Testata riscossione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Composizione record [rsd]                   *
      *                  *---------------------------------------------*
           perform   cmp-rec-rsd-000      thru cmp-rec-rsd-999        .
      *                  *---------------------------------------------*
      *                  * Forced put record [rsd]                     *
      *                  *---------------------------------------------*
           move      "FP"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofrsd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-rsd                 .
       pos-cnf-mod-400.
      *              *-------------------------------------------------*
      *              * Righe riscossione                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da effettuare                       *
      *                  *---------------------------------------------*
           if       (w-tes-tip-ope        =    0301 or
                     w-tes-tip-ope        =    0302 or
                     w-tes-tip-ope        =    0303 or
                     w-tes-tip-ope        =    0304  ) and
                    (w-tes-tip-rsd (1)    not  = 01  )
                     go to pos-cnf-mod-700.
      *                  *---------------------------------------------*
      *                  * Normalizzazione di tutte le righe attuali   *
      *                  * relative alla riscossione.                  *
      *                  * Viene utilizzato il buffer w-bsd per memo-  *
      *                  * rizzare i numeri delle nuove scadenze ge-   *
      *                  * nerate a fronte della riscossione           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione numero elementi nel     *
      *                      * buffer                                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-bsd-num-ele          .
      *                      *-----------------------------------------*
      *                      * Start su file [sdb]                     *
      *                      *-----------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "RISSDB    "         to   f-key                  .
           move      w-tes-num-rsd        to   rf-sdb-num-ris         .
           move      zero                 to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                          *-------------------------------------*
      *                          * Test su esito operazione            *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to pos-cnf-mod-500.
       pos-cnf-mod-420.
      *                      *-----------------------------------------*
      *                      * Ottenimento sequenziale record [sdb]    *
      *                      *-----------------------------------------*
           move      "GN"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                          *-------------------------------------*
      *                          * Test se 'At end'                    *
