      *                      *-----------------------------------------*
           move      "Non e' stata selezionata nessuna scadenza per l'op
      -              "erazione !     "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-400.
      *              *-------------------------------------------------*
      *              * Controllo su : Importo scadenze selezionate     *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        =    0350
                     go to cnt-tdo-nok-420.
           if       (w-tes-tip-ope        =    0301 or
                     w-tes-tip-ope        =    0302 or
                     w-tes-tip-ope        =    0303 or
                     w-tes-tip-ope        =    0304  ) and
                    (w-tes-tip-rsd (1)    not  = 01  )
                     go to cnt-tdo-nok-420.
           if        w-tes-tot-scs (1)    >    zero
                     go to cnt-tdo-nok-420.
           move      "Importo scadenze selezionate non positivo !       
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-420.
      *              *-------------------------------------------------*
      *              * Test di congruenza tra importo dichiarato in    *
      *              * testata e importo scadenze selezionate          *
      *              *-------------------------------------------------*
           if        w-tes-tip-ope        =    0350
                     go to cnt-tdo-nok-440.
           if       (w-tes-tip-ope        =    0301 or
                     w-tes-tip-ope        =    0302 or
                     w-tes-tip-ope        =    0303 or
                     w-tes-tip-ope        =    0304  ) and
                    (w-tes-tip-rsd (1)    not  = 01  )
                     go to cnt-tdo-nok-440.
           if        w-tes-imp-rsd (1)    =    zero
                     go to cnt-tdo-nok-440.
           if        w-tes-imp-rsd (1)    =    w-tes-tot-scs (1)
                     go to cnt-tdo-nok-440.
      *                  *---------------------------------------------*
      *                  * Messaggio con conferma                      *
      *                  *---------------------------------------------*
           if        w-tes-tip-ope        =    0301 or
                     w-tes-tip-ope        =    0302 or
                     w-tes-tip-ope        =    0303 or
                     w-tes-tip-ope        =    0304
                     go to cnt-tdo-nok-422
           else if   w-tes-tip-ope        =    0321 or
                     w-tes-tip-ope        =    0322 or
                     w-tes-tip-ope        =    0323 or
                     w-tes-tip-ope        =    0324
                     go to cnt-tdo-nok-424.
       cnt-tdo-nok-422.
           move      "Il totale delle scadenze selezionate non corrispon
      -              "de all'importo "    to   w-cnt-tdo-nok-msg      .
           move      "riscosso dichiarato.                              
      -              "               "    to   w-cnt-tdo-nok-m02      .
           perform   cnt-tdo-nok-mci-000  thru cnt-tdo-nok-mci-999    .
           go to     cnt-tdo-nok-426.
       cnt-tdo-nok-424.
           move      "Il totale delle scadenze selezionate non corrispon
      -              "de all'importo "    to   w-cnt-tdo-nok-msg      .
           move      "pagamento dichiarato.                             
      -              "               "    to   w-cnt-tdo-nok-m02      .
           perform   cnt-tdo-nok-mci-000  thru cnt-tdo-nok-mci-999    .
           go to     cnt-tdo-nok-426.
       cnt-tdo-nok-426.
      *                  *---------------------------------------------*
      *                  * Se risposta negativa : a errore             *
      *                  *---------------------------------------------*
           if        w-cnt-tdo-nok-mrs    =    "N"
                     go to cnt-tdo-nok-950.
       cnt-tdo-nok-440.
      *              *-------------------------------------------------*
