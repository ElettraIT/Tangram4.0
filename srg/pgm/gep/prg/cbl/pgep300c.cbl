           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      srt-num-sdb          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      spaces               to   w-err-box-err-msg      .
           string    "Attenzione : Scadenza nr. "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " non esistente in archivio!"
                                delimited by   size
