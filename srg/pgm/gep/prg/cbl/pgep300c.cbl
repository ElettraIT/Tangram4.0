      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                      *-----------------------------------------*
      *                      * Riciclo su ottenimento sequenziale re-  *
      *                      * cord [sdb]                              *
      *                      *-----------------------------------------*
           go to     pos-cnf-mod-420.
       pos-cnf-mod-480.
      *                      *-----------------------------------------*
      *                      * Unlock finale di [sdb]                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
       pos-cnf-mod-500.
