           if        rf-sdb-nns-ris       not  = zero
                     add   1              to   w-bsd-num-ele
                     move  rf-sdb-nns-ris to   w-bsd-num-sdb
                                              (w-bsd-num-ele)         .
      *                      *-----------------------------------------*
