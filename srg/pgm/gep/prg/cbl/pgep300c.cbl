       acc-cod-cli-442.
      *                      *-----------------------------------------*
      *                      * Normalizzazione e visualizzazione di-   *
      *                      * pendenza del cliente                    *
      *                      *-----------------------------------------*
           if        w-tes-dpz-dbt (1)    =    spaces and
                     w-tes-dpz-dbt-rag (1)
                                          =    spaces and
                     w-tes-dpz-dbt-via (1)
                                          =    spaces and
                     w-tes-dpz-dbt-loc (1)
                                          =    spaces
                     go to acc-cod-cli-444.
           move      spaces               to   w-tes-dpz-dbt (1)      .
           move      spaces               to   w-tes-dpz-dbt-rag (1)  .
           move      spaces               to   w-tes-dpz-dbt-via (1)  .
