           move      v-num                to   rr-tip-ord             .
       acc-tip-ord-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        rr-tip-ord           =    zero
                     go to acc-tip-ord-100.
       acc-tip-ord-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        rr-tip-ord           =    w-sav-tip-ord
                     go to acc-tip-ord-800.
      *                  *---------------------------------------------*
      *                  * Se tipo selezione : Per Agente/Cliente      *
      *                  *---------------------------------------------*
           if        rr-tip-ord           =    02
                     go to acc-tip-ord-700.
      *                      *-----------------------------------------*
      *                      * Trattamento cliente                     *
      *                      *-----------------------------------------*
           perform   pmt-cod-cli-000      thru pmt-cod-cli-999        .
           move      zero                 to   rr-cod-cli             .
           move      spaces               to   rr-cod-cli-rag         .
           move      spaces               to   rr-cod-cli-via         .
           move      spaces               to   rr-cod-cli-loc         .
           perform   vis-cod-cli-000      thru vis-cod-cli-999        .
           perform   vis-cod-cli-rag-000  thru vis-cod-cli-rag-999    .
           perform   vis-cod-cli-via-000  thru vis-cod-cli-via-999    .
           perform   vis-cod-cli-loc-000  thru vis-cod-cli-loc-999    .
      *                      *-----------------------------------------*
      *                      * Trattamento dipendenza cliente          *
      *                      *-----------------------------------------*
           perform   pmt-dpz-cli-000      thru pmt-dpz-cli-999        .
           move      spaces               to   rr-dpz-cli             .
           move      spaces               to   rr-dpz-cli-rag         .
           move      spaces               to   rr-dpz-cli-via         .
           move      spaces               to   rr-dpz-cli-loc         .
           perform   vis-dpz-cli-000      thru vis-dpz-cli-999        .
           perform   vis-dpz-cli-rag-000  thru vis-dpz-cli-rag-999    .
           perform   vis-dpz-cli-via-000  thru vis-dpz-cli-via-999    .
           perform   vis-dpz-cli-loc-000  thru vis-dpz-cli-loc-999    .
      *                      *-----------------------------------------*
      *                      * Trattamento agente                      *
      *                      *-----------------------------------------*
           perform   pmt-cod-age-000      thru pmt-cod-age-999        .
           perform   pmt-ord-age-000      thru pmt-ord-age-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-tip-ord-800.
       acc-tip-ord-700.
      *                  *---------------------------------------------*
      *                  * Se tipo selezione : Per Cliente             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Trattamento agente                      *
      *                      *-----------------------------------------*
           perform   pmt-cod-age-000      thru pmt-cod-age-999        .
           move      zero                 to   rr-cod-age             .
           move      spaces               to   rr-cod-age-nom         .
           perform   vis-cod-age-000      thru vis-cod-age-999        .
           perform   vis-cod-age-nom-000  thru vis-cod-age-nom-999    .
      *                      *-----------------------------------------*
      *                      * Trattamento ordinamento agente          *
      *                      *-----------------------------------------*
           perform   pmt-ord-age-000      thru pmt-ord-age-999        .
           move      zero                 to   rr-ord-age             .
           perform   vis-ord-age-000      thru vis-ord-age-999        .
      *                      *-----------------------------------------*
      *                      * Trattamento cliente                     *
      *                      *-----------------------------------------*
           perform   pmt-cod-cli-000      thru pmt-cod-cli-999        .
      *                      *-----------------------------------------*
      *                      * Trattamento dipendenza cliente          *
      *                      *-----------------------------------------*
           perform   pmt-dpz-cli-000      thru pmt-dpz-cli-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-tip-ord-800.
       acc-tip-ord-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-tip-ord-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-tip-ord-100.
       acc-tip-ord-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice agente                        *
      *    *-----------------------------------------------------------*
       acc-cod-age-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        rr-tip-ord           not  = 01
                     go to acc-cod-age-999.
       acc-cod-age-100.
