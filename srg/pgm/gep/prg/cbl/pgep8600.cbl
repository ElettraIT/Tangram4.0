           move      spaces               to   w-let-arc-dcc-loc      .
           move      zero                 to   w-let-arc-dcc-abi      .
           move      zero                 to   w-let-arc-dcc-cab      .
           move      zero                 to   w-let-arc-dcc-age      .
       let-arc-dcc-999.
           exit.

