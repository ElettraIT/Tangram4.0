      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura anagrafica commerciale del      *
      *                      * cliente principale                      *
      *                      *-----------------------------------------*
           if        w-ipc-dlp-stp-dpz    =    spaces
                     move  "C"            to   w-let-arc-dcc-tle
           else      move  "D"            to   w-let-arc-dcc-tle      .
           move      w-ipc-dlp-stp-cli    to   w-let-arc-dcc-cod      .
           move      w-ipc-dlp-stp-dpz    to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
           move      w-let-arc-dcc-age    to   rr-cod-age             .
      *                  *---------------------------------------------*
      *                  * Codice cliente                              *
      *                  *---------------------------------------------*
           move      w-ipc-dlp-stp-cli    to   rr-cod-cli             .
      *                  *---------------------------------------------*
      *                  * Codice dipendenza del cliente               *
      *                  *---------------------------------------------*
           move      w-ipc-dlp-stp-dpz    to   rr-dpz-cli             .
      *                  *---------------------------------------------*
      *                  * Tipo intestazione azienda                   *
