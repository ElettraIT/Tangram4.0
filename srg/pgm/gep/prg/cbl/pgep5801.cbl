           else if   w-tot-scd-dat
                    (w-stp-ods-wrk-ctr)   >    w-stp-dat-inp-fm3
                     add  w-tot-scd-imp
                         (w-stp-ods-wrk-ctr)
                                          to   w-stp-ods-cum-ms4
                                              (w-stp-ods-wrk-ele)
           else if   w-tot-scd-dat
                    (w-stp-ods-wrk-ctr)   >    w-stp-dat-inp-fm2
                     add  w-tot-scd-imp
                         (w-stp-ods-wrk-ctr)
                                          to   w-stp-ods-cum-ms3
                                              (w-stp-ods-wrk-ele)
           else if   w-tot-scd-dat
                    (w-stp-ods-wrk-ctr)   >    w-stp-dat-inp-fm1
                     add  w-tot-scd-imp
                         (w-stp-ods-wrk-ctr)
                                          to   w-stp-ods-cum-ms2
                                              (w-stp-ods-wrk-ele)
           else if   w-tot-scd-dat
                    (w-stp-ods-wrk-ctr)   >    w-stp-dat-inp-fmr
                     add  w-tot-scd-imp
                         (w-stp-ods-wrk-ctr)
                                          to   w-stp-ods-cum-ms1
                                              (w-stp-ods-wrk-ele)
           else if   w-tot-scd-dat
                    (w-stp-ods-wrk-ctr)   >    w-stp-dat-inp-fmp
                     add  w-tot-scd-imp
                         (w-stp-ods-wrk-ctr)
                                          to   w-stp-ods-cum-mic
                                              (w-stp-ods-wrk-ele)
           else      add  w-tot-scd-imp
                         (w-stp-ods-wrk-ctr)
                                          to   w-stp-ods-cum-pre
                                              (w-stp-ods-wrk-ele)     .
           go to     prn-liv-det-ods-620.
       prn-liv-det-ods-800.
      *              *-------------------------------------------------*
      *              * Cumulo totali generali                          *
      *              *-------------------------------------------------*
           add       w-stp-ods-cum-pre
                    (w-stp-ods-wrk-ele)   to   w-stp-tot-tot-pre (2)  .
           add       w-stp-ods-cum-mic
                    (w-stp-ods-wrk-ele)   to   w-stp-tot-tot-mic (2)  .
           add       w-stp-ods-cum-ms1
                    (w-stp-ods-wrk-ele)   to   w-stp-tot-tot-ms1 (2)  .
           add       w-stp-ods-cum-ms2
                    (w-stp-ods-wrk-ele)   to   w-stp-tot-tot-ms2 (2)  .
           add       w-stp-ods-cum-ms3
                    (w-stp-ods-wrk-ele)   to   w-stp-tot-tot-ms3 (2)  .
           add       w-stp-ods-cum-ms4
                    (w-stp-ods-wrk-ele)   to   w-stp-tot-tot-ms4 (2)  .
           add       w-stp-ods-cum-ms5
                    (w-stp-ods-wrk-ele)   to   w-stp-tot-tot-ms5 (2)  .
           add       w-stp-ods-cum-ms6
                    (w-stp-ods-wrk-ele)   to   w-stp-tot-tot-ms6 (2)  .
           add       w-stp-ods-cum-mso
                    (w-stp-ods-wrk-ele)   to   w-stp-tot-tot-mso (2)  .
      *              *-------------------------------------------------*
      *              * Cumulo totali cliente                           *
      *              *-------------------------------------------------*
           add       w-stp-ods-cum-pre
                    (w-stp-ods-wrk-ele)   to   w-stp-lvc-tot-pre      .
           add       w-stp-ods-cum-mic
                    (w-stp-ods-wrk-ele)   to   w-stp-lvc-tot-mic      .
           add       w-stp-ods-cum-ms1
                    (w-stp-ods-wrk-ele)   to   w-stp-lvc-tot-ms1      .
           add       w-stp-ods-cum-ms2
                    (w-stp-ods-wrk-ele)   to   w-stp-lvc-tot-ms2      .
           add       w-stp-ods-cum-ms3
                    (w-stp-ods-wrk-ele)   to   w-stp-lvc-tot-ms3      .
           add       w-stp-ods-cum-ms4
                    (w-stp-ods-wrk-ele)   to   w-stp-lvc-tot-ms4      .
           add       w-stp-ods-cum-ms5
                    (w-stp-ods-wrk-ele)   to   w-stp-lvc-tot-ms5      .
           add       w-stp-ods-cum-ms6
                    (w-stp-ods-wrk-ele)   to   w-stp-lvc-tot-ms6      .
           add       w-stp-ods-cum-mso
                    (w-stp-ods-wrk-ele)   to   w-stp-lvc-tot-mso      .
      *              *-------------------------------------------------*
      *              * Cumulo subtotali cliente                        *
      *              *-------------------------------------------------*
           add       w-stp-ods-cum-pre
                    (w-stp-ods-wrk-ele)   to   w-stp-lvc-sbt-pre (2)  .
           add       w-stp-ods-cum-mic
                    (w-stp-ods-wrk-ele)   to   w-stp-lvc-sbt-mic (2)  .
           add       w-stp-ods-cum-ms1
                    (w-stp-ods-wrk-ele)   to   w-stp-lvc-sbt-ms1 (2)  .
           add       w-stp-ods-cum-ms2
                    (w-stp-ods-wrk-ele)   to   w-stp-lvc-sbt-ms2 (2)  .
           add       w-stp-ods-cum-ms3
                    (w-stp-ods-wrk-ele)   to   w-stp-lvc-sbt-ms3 (2)  .
           add       w-stp-ods-cum-ms4
                    (w-stp-ods-wrk-ele)   to   w-stp-lvc-sbt-ms4 (2)  .
           add       w-stp-ods-cum-ms5
                    (w-stp-ods-wrk-ele)   to   w-stp-lvc-sbt-ms5 (2)  .
           add       w-stp-ods-cum-ms6
                    (w-stp-ods-wrk-ele)   to   w-stp-lvc-sbt-ms6 (2)  .
           add       w-stp-ods-cum-mso
                    (w-stp-ods-wrk-ele)   to   w-stp-lvc-sbt-mso (2)  .
      *              *-------------------------------------------------*
      *              * Riciclo a testata ordine successiva             *
      *              *-------------------------------------------------*
           go to     prn-liv-det-ods-200.
       prn-liv-det-ods-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     prn-liv-det-ods-999.
       prn-liv-det-ods-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Livello di dettaglio               *
      *    *                                                           *
      *    * Ciclo di preparazione castelletto bolle da fatturare      *
      *    *-----------------------------------------------------------*
       prn-liv-det-bol-000.
      *              *-------------------------------------------------*
      *              * Test preliminari                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da fare                             *
      *                  *---------------------------------------------*
           if        rr-vde-stp-bol       =    spaces
                     go to prn-liv-det-bol-900.
       prn-liv-det-bol-010.
      *              *-------------------------------------------------*
      *              * Start per codice                                *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "CODDPZ    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      zero                 to   rf-ada-cod-dpz         .
           move      "pgm/azi/fls/ioc/obj/iofada"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ada                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to prn-liv-det-bol-900.
       prn-liv-det-bol-020.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale archivio [ada]              *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/azi/fls/ioc/obj/iofada"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ada                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to prn-liv-det-bol-900.
       prn-liv-det-bol-100.
      *              *-------------------------------------------------*
      *              * Start su file [bit]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DPZARCDAT "         to   f-key                  .
           move      rf-ada-cod-dpz       to   rf-bit-cod-dpz         .
           move      "C"                  to   rf-bit-tip-arc         .
           move      srt-cod-cli          to   rf-bit-cod-arc         .
           move      zero                 to   rf-bit-dat-doc         .
           move      zero                 to   rf-bit-num-doc         .
           move      zero                 to   rf-bit-num-prt         .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to prn-liv-det-bol-020.
       prn-liv-det-bol-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [bit]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to prn-liv-det-bol-020.
       prn-liv-det-bol-300.
      *              *-------------------------------------------------*
      *              * Test max                                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice dipendenza                   *
      *                  *---------------------------------------------*
           if        rf-bit-cod-dpz       not  = rf-ada-cod-dpz
                     go to prn-liv-det-bol-020.
      *                  *---------------------------------------------*
      *                  * Test su tipo archivio                       *
      *                  *---------------------------------------------*
           if        rf-bit-tip-arc       not  = "C"
                     go to prn-liv-det-bol-020.
      *                  *---------------------------------------------*
      *                  * Test su codice cliente                      *
      *                  *---------------------------------------------*
           if        rf-bit-cod-arc       not  = srt-cod-cli
                     go to prn-liv-det-bol-020.
      *                  *---------------------------------------------*
      *                  * Test su data documento                      *
      *                  *---------------------------------------------*
           if        rf-bit-dat-doc       >    w-stp-dat-inp-rif
                     go to prn-liv-det-bol-020.
       prn-liv-det-bol-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su flag di movimento che interessa la  *
      *                  * fatturazion                                 *
      *                  *---------------------------------------------*
           if        rf-bit-int-ftr       not  = 02
                     go to prn-liv-det-bol-200.
           if        rf-bit-tmo-ftr       =    spaces
                     go to prn-liv-det-bol-200.
      *                  *---------------------------------------------*
      *                  * Determinazione status della bolla           *
      *                  *---------------------------------------------*
           perform   det-sts-bol-000      thru det-sts-bol-999        .
      *                  *---------------------------------------------*
      *                  * Test su status della bolla                  *
      *                  *---------------------------------------------*
           if        w-det-sts-bol-flg    not  = spaces
                     go to prn-liv-det-bol-200.
       prn-liv-det-bol-500.
      *              *-------------------------------------------------*
      *              * Incremento numero elementi in tabella bolle da  *
      *              * fatturare                                       *
      *              *-------------------------------------------------*
           add       1                    to   w-stp-bol-wrk-ele      .
           if        w-stp-bol-wrk-ele    >    w-stp-bol-wrk-max
                     go to prn-liv-det-bol-900.
      *              *-------------------------------------------------*
      *              * Normalizzazione tabella elementi                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Estremi bolla                               *
      *                  *---------------------------------------------*
           move      rf-bit-cod-tmb       to   w-stp-bol-tip-doc
                                              (w-stp-bol-wrk-ele)     .
           move      rf-bit-num-doc       to   w-stp-bol-num-doc
                                              (w-stp-bol-wrk-ele)     .
           move      rf-bit-dat-doc       to   w-stp-bol-dat-doc
                                              (w-stp-bol-wrk-ele)     .
      *                  *---------------------------------------------*
      *                  * Valori per cumulo                           *
      *                  *---------------------------------------------*
           move      zero                 to   w-stp-bol-cum-pre
                                              (w-stp-bol-wrk-ele)     .
           move      zero                 to   w-stp-bol-cum-mic
                                              (w-stp-bol-wrk-ele)     .
           move      zero                 to   w-stp-bol-cum-ms1
                                              (w-stp-bol-wrk-ele)     .
           move      zero                 to   w-stp-bol-cum-ms2
                                              (w-stp-bol-wrk-ele)     .
           move      zero                 to   w-stp-bol-cum-ms3
                                              (w-stp-bol-wrk-ele)     .
           move      zero                 to   w-stp-bol-cum-ms4
                                              (w-stp-bol-wrk-ele)     .
           move      zero                 to   w-stp-bol-cum-ms5
                                              (w-stp-bol-wrk-ele)     .
           move      zero                 to   w-stp-bol-cum-ms6
                                              (w-stp-bol-wrk-ele)     .
           move      zero                 to   w-stp-bol-cum-mso
                                              (w-stp-bol-wrk-ele)     .
      *              *-------------------------------------------------*
      *              * Inizializzazione area totali bolla              *
      *              *-------------------------------------------------*
           perform   ini-tot-bol-000      thru ini-tot-bol-999        .
      *              *-------------------------------------------------*
      *              * Determinazione totali dalle righe               *
      *              *-------------------------------------------------*
           perform   det-tri-bol-000      thru det-tri-bol-999        .
      *              *-------------------------------------------------*
      *              * Determinazione totali bolla                     *
      *              *-------------------------------------------------*
           perform   det-tot-bol-000      thru det-tot-bol-999        .
       prn-liv-det-bol-600.
      *              *-------------------------------------------------*
      *              * Sventagliamento delle scadenze nei mesi di      *
      *              * competenza                                      *
      *              *-------------------------------------------------*
           move      zero                 to   w-stp-bol-wrk-ctr      .
       prn-liv-det-bol-620.
           add       1                    to   w-stp-bol-wrk-ctr      .
      *                  *---------------------------------------------*
      *                  * Test preliminari                            *
      *                  *---------------------------------------------*
           if        w-tot-scd-imp
                    (w-stp-bol-wrk-ctr)   =    zero
                     go to prn-liv-det-bol-800.
           if        w-stp-bol-wrk-ctr    >    96
                     go to prn-liv-det-bol-800.
      *                  *---------------------------------------------*
      *                  * Eventuale inversione del segno              *
      *                  *---------------------------------------------*
           if        w-det-sts-bol-idt    =    "N"
                     multiply -1          by   w-tot-scd-imp
                                              (w-stp-bol-wrk-ctr)     .
      *                  *---------------------------------------------*
      *                  * Confronto fra date                          *
      *                  *---------------------------------------------*
           if        w-tot-scd-dat
                    (w-stp-bol-wrk-ctr)   >    w-stp-dat-inp-fm6
                     add  w-tot-scd-imp
                         (w-stp-bol-wrk-ctr)
                                          to   w-stp-bol-cum-mso
                                              (w-stp-bol-wrk-ele)
           else if   w-tot-scd-dat
                    (w-stp-bol-wrk-ctr)   >    w-stp-dat-inp-fm5
                     add  w-tot-scd-imp
                         (w-stp-bol-wrk-ctr)
                                          to   w-stp-bol-cum-ms6
                                              (w-stp-bol-wrk-ele)
           else if   w-tot-scd-dat
                    (w-stp-bol-wrk-ctr)   >    w-stp-dat-inp-fm4
                     add  w-tot-scd-imp
                         (w-stp-bol-wrk-ctr)
                                          to   w-stp-bol-cum-ms5
                                              (w-stp-bol-wrk-ele)
           else if   w-tot-scd-dat
                    (w-stp-bol-wrk-ctr)   >    w-stp-dat-inp-fm3
                     add  w-tot-scd-imp
                         (w-stp-bol-wrk-ctr)
                                          to   w-stp-bol-cum-ms4
                                              (w-stp-bol-wrk-ele)
           else if   w-tot-scd-dat
                    (w-stp-bol-wrk-ctr)   >    w-stp-dat-inp-fm2
                     add  w-tot-scd-imp
                         (w-stp-bol-wrk-ctr)
                                          to   w-stp-bol-cum-ms3
                                              (w-stp-bol-wrk-ele)
           else if   w-tot-scd-dat
                    (w-stp-bol-wrk-ctr)   >    w-stp-dat-inp-fm1
                     add  w-tot-scd-imp
                         (w-stp-bol-wrk-ctr)
                                          to   w-stp-bol-cum-ms2
                                              (w-stp-bol-wrk-ele)
           else if   w-tot-scd-dat
                    (w-stp-bol-wrk-ctr)   >    w-stp-dat-inp-fmr
                     add  w-tot-scd-imp
                         (w-stp-bol-wrk-ctr)
                                          to   w-stp-bol-cum-ms1
                                              (w-stp-bol-wrk-ele)
           else if   w-tot-scd-dat
                    (w-stp-bol-wrk-ctr)   >    w-stp-dat-inp-fmp
                     add  w-tot-scd-imp
                         (w-stp-bol-wrk-ctr)
                                          to   w-stp-bol-cum-mic
                                              (w-stp-bol-wrk-ele)
           else      add  w-tot-scd-imp
                         (w-stp-bol-wrk-ctr)
                                          to   w-stp-bol-cum-pre
                                              (w-stp-bol-wrk-ele)     .
           go to     prn-liv-det-bol-620.
       prn-liv-det-bol-800.
      *              *-------------------------------------------------*
      *              * Cumulo totali generali                          *
      *              *-------------------------------------------------*
           add       w-stp-bol-cum-pre
                    (w-stp-bol-wrk-ele)   to   w-stp-tot-tot-pre (3)  .
           add       w-stp-bol-cum-mic
                    (w-stp-bol-wrk-ele)   to   w-stp-tot-tot-mic (3)  .
           add       w-stp-bol-cum-ms1
                    (w-stp-bol-wrk-ele)   to   w-stp-tot-tot-ms1 (3)  .
           add       w-stp-bol-cum-ms2
                    (w-stp-bol-wrk-ele)   to   w-stp-tot-tot-ms2 (3)  .
           add       w-stp-bol-cum-ms3
                    (w-stp-bol-wrk-ele)   to   w-stp-tot-tot-ms3 (3)  .
           add       w-stp-bol-cum-ms4
                    (w-stp-bol-wrk-ele)   to   w-stp-tot-tot-ms4 (3)  .
           add       w-stp-bol-cum-ms5
                    (w-stp-bol-wrk-ele)   to   w-stp-tot-tot-ms5 (3)  .
           add       w-stp-bol-cum-ms6
                    (w-stp-bol-wrk-ele)   to   w-stp-tot-tot-ms6 (3)  .
           add       w-stp-bol-cum-mso
                    (w-stp-bol-wrk-ele)   to   w-stp-tot-tot-mso (3)  .
      *              *-------------------------------------------------*
      *              * Cumulo totali cliente                           *
      *              *-------------------------------------------------*
           add       w-stp-bol-cum-pre
                    (w-stp-bol-wrk-ele)   to   w-stp-lvc-tot-pre      .
           add       w-stp-bol-cum-mic
                    (w-stp-bol-wrk-ele)   to   w-stp-lvc-tot-mic      .
           add       w-stp-bol-cum-ms1
                    (w-stp-bol-wrk-ele)   to   w-stp-lvc-tot-ms1      .
           add       w-stp-bol-cum-ms2
                    (w-stp-bol-wrk-ele)   to   w-stp-lvc-tot-ms2      .
           add       w-stp-bol-cum-ms3
                    (w-stp-bol-wrk-ele)   to   w-stp-lvc-tot-ms3      .
           add       w-stp-bol-cum-ms4
                    (w-stp-bol-wrk-ele)   to   w-stp-lvc-tot-ms4      .
           add       w-stp-bol-cum-ms5
                    (w-stp-bol-wrk-ele)   to   w-stp-lvc-tot-ms5      .
           add       w-stp-bol-cum-ms6
                    (w-stp-bol-wrk-ele)   to   w-stp-lvc-tot-ms6      .
           add       w-stp-bol-cum-mso
                    (w-stp-bol-wrk-ele)   to   w-stp-lvc-tot-mso      .
      *              *-------------------------------------------------*
      *              * Cumulo subtotali cliente                        *
      *              *-------------------------------------------------*
           add       w-stp-bol-cum-pre
                    (w-stp-bol-wrk-ele)   to   w-stp-lvc-sbt-pre (3)  .
           add       w-stp-bol-cum-mic
                    (w-stp-bol-wrk-ele)   to   w-stp-lvc-sbt-mic (3)  .
           add       w-stp-bol-cum-ms1
                    (w-stp-bol-wrk-ele)   to   w-stp-lvc-sbt-ms1 (3)  .
           add       w-stp-bol-cum-ms2
                    (w-stp-bol-wrk-ele)   to   w-stp-lvc-sbt-ms2 (3)  .
           add       w-stp-bol-cum-ms3
                    (w-stp-bol-wrk-ele)   to   w-stp-lvc-sbt-ms3 (3)  .
           add       w-stp-bol-cum-ms4
                    (w-stp-bol-wrk-ele)   to   w-stp-lvc-sbt-ms4 (3)  .
           add       w-stp-bol-cum-ms5
                    (w-stp-bol-wrk-ele)   to   w-stp-lvc-sbt-ms5 (3)  .
           add       w-stp-bol-cum-ms6
                    (w-stp-bol-wrk-ele)   to   w-stp-lvc-sbt-ms6 (3)  .
           add       w-stp-bol-cum-mso
                    (w-stp-bol-wrk-ele)   to   w-stp-lvc-sbt-mso (3)  .
      *              *-------------------------------------------------*
      *              * Riciclo a testata ordine successiva             *
      *              *-------------------------------------------------*
           go to     prn-liv-det-bol-200.
       prn-liv-det-bol-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     prn-liv-det-bol-999.
       prn-liv-det-bol-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Livello di dettaglio               *
      *    *                                                           *
      *    * Ciclo di preparazione castelletto scadenze in portafolgio *
      *    *-----------------------------------------------------------*
       prn-liv-det-gep-000.
      *              *-------------------------------------------------*
      *              * Test preliminari                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da fare                             *
      *                  *---------------------------------------------*
           if        rr-vde-stp-gep       =    spaces
                     go to prn-liv-det-gep-900.
       prn-liv-det-gep-100.
      *              *-------------------------------------------------*
      *              * Start su file [sdb]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
