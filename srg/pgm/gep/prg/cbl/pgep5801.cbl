      *              *-------------------------------------------------*
           if        rr-tip-ord           =    "C"
                     go to stp-srt-inp-100
           else if   rr-tip-ord           =    "R"
                     go to stp-srt-inp-120
           else      go to stp-srt-inp-100.
       stp-srt-inp-100.
