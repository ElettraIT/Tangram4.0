      *                  * Start per codice                            *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CODCLI    "         to   f-key                  .
           move      rr-cod-min           to   rf-cli-cod-cli         .
           move      "pgm/cge/fls/ioc/obj/iofcli"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cli                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata                             *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * Se Ok                                       *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-120.
      *              *-------------------------------------------------*
      *              * Se ordinamento per ragione sociale              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start per ragione sociale in uppercase      *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "RAGKEY    "         to   f-key                  .
           move      rr-rag-min           to   rf-cli-rag-key         .
           move      zero                 to   rf-cli-cod-cli         .
           move      "pgm/cge/fls/ioc/obj/iofcli"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cli                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata                             *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * Se Ok                                       *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-200.
