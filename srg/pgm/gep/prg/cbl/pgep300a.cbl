      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-abi-app-025.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-tip-sdb (1)    not  = 02 and
                     w-tes-tip-sdb (1)    not  = 03 and
                     w-tes-tip-sdb (1)    not  = 04 and
                     w-tes-tip-sdb (1)    not  = 05 and
                     w-tes-tip-sdb (1)    not  = 06 and
                     w-tes-tip-sdb (1)    not  = 09 and
                     w-tes-tip-sdb (1)    not  = 10 and
                     w-tes-tip-sdb (1)    not  = 11
                     go to acc-abi-app-999.
       acc-abi-app-050.
      *                  *---------------------------------------------*
      *                  * Preparazione eventuale del default          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore attuale diverso da zero : no  *
      *                      * preparazione default                    *
      *                      *-----------------------------------------*
           if        w-tes-abi-app (1)    not  = zero
                     go to acc-abi-app-070.
      *                      *-----------------------------------------*
      *                      * Se non si e' in Inserimento : no prepa- *
      *                      * razione default                         *
      *                      *-----------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-abi-app-070.
      *                      *-----------------------------------------*
      *                      * Se preparazione default gia' eseguita : *
      *                      * no preparazione default                 *
      *                      *-----------------------------------------*
           if        w-fpd-acc-abi-app    not  = spaces
                     go to acc-abi-app-070.
      *                      *-----------------------------------------*
      *                      * Se il tipo debitore non indica che si   *
      *                      * tratta di un cliente : no preparazione  *
      *                      * default                                 *
      *                      *-----------------------------------------*
           if        w-tes-tip-dbt (1)    not  = 01
                     go to acc-abi-app-070.
      *                      *-----------------------------------------*
      *                      * Lettura archivio [dcc] relativa al cli- *
      *                      * ente o alla sua dipendenza              *
      *                      *-----------------------------------------*
           if        w-tes-dpz-dbt (1)    =    spaces
                     move  "C"            to   w-let-arc-dcc-tle
           else      move  "D"            to   w-let-arc-dcc-tle      .
           move      w-tes-cod-dbt (1)    to   w-let-arc-dcc-cod      .
           move      w-tes-dpz-dbt (1)    to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                      *-----------------------------------------*
      *                      * Se record non esistente : no prepara-   *
      *                      * zione default                           *
      *                      *-----------------------------------------*
           if        w-let-arc-dcc-flg    not  = spaces
                     go to acc-abi-app-070.
      *                      *-----------------------------------------*
      *                      * Se codice banca d'appoggio per la pre-  *
      *                      * sentazione associata ai dati commercia- *
      *                      * li del cliente a zero : no preparazione *
      *                      * default                                 *
      *                      *-----------------------------------------*
           if        w-let-arc-dcc-abi    =    zero
                     go to acc-abi-app-070.
       acc-abi-app-055.
      *                      *-----------------------------------------*
      *                      * Preparazione default per codice ABI per *
      *                      * la banca di appoggio                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Lettura archivio [axi]              *
      *                          *-------------------------------------*
           move      w-let-arc-dcc-abi    to   w-let-arc-axi-cod      .
           perform   let-arc-axi-000      thru let-arc-axi-999        .
      *                          *-------------------------------------*
      *                          * Se record non esistente : no prepa- *
      *                          * razione default                     *
      *                          *-------------------------------------*
           if        w-let-arc-axi-flg    not  = spaces
                     go to acc-abi-app-070.
      *                          *-------------------------------------*
      *                          * Preparazione default codice ABI     *
      *                          *-------------------------------------*
           move      w-let-arc-dcc-abi    to   w-tes-abi-app (1)      .
      *                          *-------------------------------------*
      *                          * Memorizzazione denominazione        *
      *                          *-------------------------------------*
           move      w-let-arc-axi-den    to   w-tes-abi-app-den (1)  .
      *                          *-------------------------------------*
      *                          * Visualizzazione codice ABI          *
      *                          *-------------------------------------*
           perform   vis-abi-app-000      thru vis-abi-app-999        .
      *                          *-------------------------------------*
      *                          * Visualizzazione denominazione       *
      *                          *-------------------------------------*
           perform   vis-abi-app-den-000  thru vis-abi-app-den-999    .
       acc-abi-app-060.
      *                      *-----------------------------------------*
      *                      * Preparazione default per codice CAB per *
      *                      * la banca di appoggio                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se codice sportello banca d'appog-  *
      *                          * gio per la presentazione associato  *
      *                          * ai dati commerciali del cliente a   *
      *                          * zero : no preparazione default per  *
      *                          * il codice CAB                       *
      *                          *-------------------------------------*
           if        w-let-arc-dcc-cab    =    zero
                     go to acc-abi-app-070.
      *                          *-------------------------------------*
      *                          * Lettura archivio [axs]              *
      *                          *-------------------------------------*
           move      w-let-arc-dcc-abi    to   w-let-arc-axs-abi      .
           move      w-let-arc-dcc-cab    to   w-let-arc-axs-cab      .
           perform   let-arc-axs-000      thru let-arc-axs-999        .
      *                          *-------------------------------------*
      *                          * Se record non esistente : no prepa- *
      *                          * razione default per il codice CAB   *
      *                          *-------------------------------------*
           if        w-let-arc-axs-flg    not  = spaces
                     go to acc-abi-app-070.
      *                          *-------------------------------------*
      *                          * Preparazione default codice CAB     *
      *                          *-------------------------------------*
           move      w-let-arc-dcc-cab    to   w-tes-cab-app (1)      .
      *                          *-------------------------------------*
      *                          * Memorizzazione denominazione        *
      *                          *-------------------------------------*
           move      w-let-arc-axs-den    to   w-tes-cab-app-den (1)  .
      *                          *-------------------------------------*
      *                          * Visualizzazione codice CAB          *
      *                          *-------------------------------------*
           perform   vis-cab-app-000      thru vis-cab-app-999        .
      *                          *-------------------------------------*
      *                          * Visualizzazione denominazione       *
      *                          *-------------------------------------*
           perform   vis-cab-app-den-000  thru vis-cab-app-den-999    .
       acc-abi-app-065.
      *                      *-----------------------------------------*
      *                      * Preparazione default C/C di appoggio    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se non si tratta di un R.I.D. : no  *
      *                          * preparazione                        *
      *                          *-------------------------------------*
           if        w-tes-tip-sdb (1)    not  = 06
                     go to acc-abi-app-070.
      *                          *-------------------------------------*
      *                          * Preparazione default C/C di appog-  *
      *                          * gio                                 *
      *                          *-------------------------------------*
           move      w-let-arc-dcc-ccc    to   w-tes-ccc-app (1)      .
      *                          *-------------------------------------*
      *                          * Visualizzazione C/C di appoggio     *
      *                          *-------------------------------------*
           perform   vis-ccc-app-000      thru vis-ccc-app-999        .
       acc-abi-app-070.
      *                      *-----------------------------------------*
      *                      * Segnale di preparazione default gia'    *
      *                      * eseguita                                *
      *                      *-----------------------------------------*
           move      "#"                  to   w-fpd-acc-abi-app      .
       acc-abi-app-075.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-abi-app (1)    to   w-sav-abi-app          .
       acc-abi-app-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-abi-ope      .
           move      w-tes-abi-app (1)    to   w-cod-mne-abi-cod      .
           move      13                   to   w-cod-mne-abi-lin      .
           move      30                   to   w-cod-mne-abi-pos      .
           move      13                   to   w-cod-mne-abi-dln      .
           move      41                   to   w-cod-mne-abi-dps      .
           move      "9B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   cod-mne-abi-cll-000  thru cod-mne-abi-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-abi-foi-000  thru cod-mne-abi-foi-999    .
       acc-abi-app-110.
           perform   cod-mne-abi-cll-000  thru cod-mne-abi-cll-999    .
           if        w-cod-mne-abi-ope    =    "F+"
                     go to acc-abi-app-115.
           if        w-cod-mne-abi-ope    =    "AC"
                     go to acc-abi-app-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-abi-app-115.
           perform   cod-mne-abi-foi-000  thru cod-mne-abi-foi-999    .
           go to     acc-abi-app-110.
       acc-abi-app-120.
           move      w-cod-mne-abi-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit, ma in forzatura di riemissione         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"   and
                     w-key-frz-ens        not  = spaces
                     go to acc-abi-app-100.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-abi-app-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-abi-app-999.
       acc-abi-app-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-abi-app (1)      .
       acc-abi-app-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-abi-app-410.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [axi]                      *
      *                  *---------------------------------------------*
           move      w-tes-abi-app (1)    to   w-let-arc-axi-cod      .
           perform   let-arc-axi-000      thru let-arc-axi-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione denominazione                *
      *                  *---------------------------------------------*
           move      w-let-arc-axi-den    to   w-tes-abi-app-den (1)  .
       acc-abi-app-420.
      *                  *---------------------------------------------*
      *                  * Visualizzazione denominazione               *
      *                  *---------------------------------------------*
           perform   vis-abi-app-den-000  thru vis-abi-app-den-999    .
       acc-abi-app-430.
      *                  *---------------------------------------------*
      *                  * Se record non esistente : reimpostazione    *
      *                  *---------------------------------------------*
           if        w-let-arc-axi-flg    =    spaces
                     go to acc-abi-app-440.
       acc-abi-app-432.
      *                      *-----------------------------------------*
      *                      * Normalizzazione e visualizzazione co-   *
      *                      * dice CAB                                *
      *                      *-----------------------------------------*
           if        w-tes-abi-app (1)    =    zero
                     go to acc-abi-app-434.
           move      zero                 to   w-tes-cab-app (1)      .
           move      spaces               to   w-tes-cab-app-den (1)  .
           perform   vis-cab-app-000      thru vis-cab-app-999        .
           perform   vis-cab-app-den-000  thru vis-cab-app-den-999    .
       acc-abi-app-434.
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-abi-app-100.
       acc-abi-app-440.
      *                  *---------------------------------------------*
      *                  * Se codice a zero : reimpostazione, a meno   *
      *                  * che non si sia in Up, o che il tipo scaden- *
      *                  * za non indichi un Paghero' Cambiario        *
      *                  *---------------------------------------------*
           if        w-tes-abi-app (1)    not  = zero
                     go to acc-abi-app-600.
           if        w-tes-tip-sdb (1)    =    11
                     go to acc-abi-app-600.
           if        v-key                =    "UP  "
                     go to acc-abi-app-600
           else      go to acc-abi-app-100.
       acc-abi-app-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale pari al valore precedente *
      *                  * : nessuna dipendenza                        *
      *                  *---------------------------------------------*
           if        w-tes-abi-app (1)    =    w-sav-abi-app
                     go to acc-abi-app-800.
       acc-abi-app-650.
      *                  *---------------------------------------------*
      *                  * Normalizzazione e visualizzazione codice    *
      *                  * CAB                                         *
      *                  *---------------------------------------------*
           if        w-tes-cab-app (1)    =    zero
                     go to acc-abi-app-675.
           move      zero                 to   w-tes-cab-app (1)      .
           move      spaces               to   w-tes-cab-app-den (1)  .
           perform   vis-cab-app-000      thru vis-cab-app-999        .
           perform   vis-cab-app-den-000  thru vis-cab-app-den-999    .
       acc-abi-app-675.
           go to     acc-abi-app-800.
       acc-abi-app-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-abi-app-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-abi-app-100.
       acc-abi-app-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice ABI per l'appoggio in pre- *
      *    *                         sentazione                        *
      *    *-----------------------------------------------------------*
       vis-abi-app-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo scadenza        *
      *              *-------------------------------------------------*
           if        w-tes-tip-sdb (1)    =    02 or
                     w-tes-tip-sdb (1)    =    03 or
                     w-tes-tip-sdb (1)    =    04 or
                     w-tes-tip-sdb (1)    =    05 or
                     w-tes-tip-sdb (1)    =    06 or
                     w-tes-tip-sdb (1)    =    09 or
                     w-tes-tip-sdb (1)    =    10 or
                     w-tes-tip-sdb (1)    =    11
                     go to vis-abi-app-100
           else      go to vis-abi-app-900.
       vis-abi-app-100.
      *              *-------------------------------------------------*
      *              * Se tipo scadenza : 02..06 o 09..11              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9B"                 to   v-edm                  .
           move      13                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-abi-app (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     vis-abi-app-999.
       vis-abi-app-900.
      *              *-------------------------------------------------*
      *              * In tutti gli altri casi                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     vis-abi-app-999.
       vis-abi-app-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice ABI per l'appoggio in presen- *
      *    *                      tazione, denominazione               *
      *    *-----------------------------------------------------------*
       vis-abi-app-den-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo scadenza        *
      *              *-------------------------------------------------*
           if        w-tes-tip-sdb (1)    =    02 or
                     w-tes-tip-sdb (1)    =    03 or
                     w-tes-tip-sdb (1)    =    04 or
                     w-tes-tip-sdb (1)    =    05 or
                     w-tes-tip-sdb (1)    =    06 or
                     w-tes-tip-sdb (1)    =    09 or
                     w-tes-tip-sdb (1)    =    10 or
                     w-tes-tip-sdb (1)    =    11
                     go to vis-abi-app-den-100
           else      go to vis-abi-app-den-900.
       vis-abi-app-den-100.
      *              *-------------------------------------------------*
      *              * Se tipo scadenza : 02..06 o 09..11              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-abi-app-den (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     vis-abi-app-den-999.
       vis-abi-app-den-900.
      *              *-------------------------------------------------*
      *              * In tutti gli altri casi                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     vis-abi-app-den-999.
       vis-abi-app-den-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice CAB per l'appoggio in presen- *
      *    *                      tazione                              *
      *    *-----------------------------------------------------------*
       acc-cab-app-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-cab-app-025.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-tip-sdb (1)    not  = 02 and
                     w-tes-tip-sdb (1)    not  = 03 and
                     w-tes-tip-sdb (1)    not  = 04 and
                     w-tes-tip-sdb (1)    not  = 05 and
                     w-tes-tip-sdb (1)    not  = 06 and
                     w-tes-tip-sdb (1)    not  = 09 and
                     w-tes-tip-sdb (1)    not  = 10 and
                     w-tes-tip-sdb (1)    not  = 11
                     go to acc-cab-app-999.
           if        w-tes-abi-app (1)    =    zero
                     go to acc-cab-app-999.
       acc-cab-app-050.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cab-app (1)    to   w-sav-cab-app          .
       acc-cab-app-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-cab-ope      .
           move      w-tes-abi-app (1)    to   w-cod-mne-cab-abi      .
           move      w-tes-cab-app (1)    to   w-cod-mne-cab-cab      .
           move      14                   to   w-cod-mne-cab-lin      .
           move      30                   to   w-cod-mne-cab-pos      .
           move      14                   to   w-cod-mne-cab-dln      .
           move      41                   to   w-cod-mne-cab-dps      .
           move      "9B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   cod-mne-cab-cll-000  thru cod-mne-cab-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-cab-foi-000  thru cod-mne-cab-foi-999    .
       acc-cab-app-110.
           perform   cod-mne-cab-cll-000  thru cod-mne-cab-cll-999    .
           if        w-cod-mne-cab-ope    =    "F+"
                     go to acc-cab-app-115.
           if        w-cod-mne-cab-ope    =    "AC"
                     go to acc-cab-app-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cab-app-115.
           perform   cod-mne-cab-foi-000  thru cod-mne-cab-foi-999    .
           go to     acc-cab-app-110.
       acc-cab-app-120.
           move      w-cod-mne-cab-cab    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit, ma in forzatura di riemissione         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"   and
                     w-key-frz-ens        not  = spaces
                     go to acc-cab-app-100.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cab-app-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cab-app-999.
       acc-cab-app-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cab-app (1)      .
       acc-cab-app-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-cab-app-410.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [axs]                      *
      *                  *---------------------------------------------*
           move      w-tes-abi-app (1)    to   w-let-arc-axs-abi      .
           move      w-tes-cab-app (1)    to   w-let-arc-axs-cab      .
           perform   let-arc-axs-000      thru let-arc-axs-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione denominazione                *
      *                  *---------------------------------------------*
           move      w-let-arc-axs-den    to   w-tes-cab-app-den (1)  .
       acc-cab-app-420.
      *                  *---------------------------------------------*
      *                  * Visualizzazione denominazione               *
      *                  *---------------------------------------------*
           perform   vis-cab-app-den-000  thru vis-cab-app-den-999    .
       acc-cab-app-430.
      *                  *---------------------------------------------*
      *                  * Se record non esistente : a reimpostazione  *
      *                  *---------------------------------------------*
           if        w-let-arc-axs-flg    not  = spaces
                     go to acc-cab-app-100.
       acc-cab-app-450.
      *                  *---------------------------------------------*
      *                  * Se codice a zero : reimpostazione, a meno   *
      *                  * che non si sia in Up                        *
      *                  *---------------------------------------------*
           if        w-tes-cab-app (1)    not  = zero
                     go to acc-cab-app-600.
           if        v-key                =    "UP  "
                     go to acc-cab-app-600
           else      go to acc-cab-app-100.
       acc-cab-app-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cab-app-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cab-app-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cab-app-100.
       acc-cab-app-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice CAB per l'appoggio in pre- *
      *    *                         sentazione                        *
      *    *-----------------------------------------------------------*
       vis-cab-app-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo scadenza        *
      *              *-------------------------------------------------*
           if        w-tes-tip-sdb (1)    =    02 or
                     w-tes-tip-sdb (1)    =    03 or
