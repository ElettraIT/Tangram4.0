                     move  "#"            to   w-cnt-rou-let-reg
                     go to rou-let-reg-999
           else      move  "V"            to   w-cnt-mfu-tip-fun      .
       rou-let-reg-825.
      *                          *-------------------------------------*
      *                          * Su tipo documento di riferimento,   *
      *                          * che non corrisponda ad una antici-  *
      *                          * po, che essendo generato unicamente *
      *                          * da una operazione di riscossione,   *
      *                          * deve essere trattato in sola visua- *
      *                          * lizzazione                          *
      *                          *-------------------------------------*
           if        w-tes-tip-ddr (1)    not  = 21
                     go to rou-let-reg-900.
           if        w-cnt-mfu-tip-fun    =    "V"
                     go to rou-let-reg-900.
           move      "Attenzione : La scadenza, che rappresenta un antic
      -              "ipo, puo'      "    to   w-err-box-err-msg      .
           move      "             essere modificata solamente tramite u
      -              "na riscossione!"    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           move      "V"                  to   w-cnt-mfu-tip-fun      .
       rou-let-reg-900.
