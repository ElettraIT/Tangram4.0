           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      13                   to   v-lin                  .
           move      74                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-msg-err-999.
           exit.

      *    *===========================================================*
      *    * Box per messaggio di errore esteso, su due righe          *
      *    *-----------------------------------------------------------*
       box-msg-e02-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      11                   to   v-lin                  .
           move      04                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      77                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Messaggio nel box                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Linea 01                                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-msg    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Linea 02                                    *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-err-box-err-m02    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Parentesi quadre di delimitazione               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      13                   to   v-lin                  .
           move      74                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-msg-e02-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazione tasto Do campi chiave           *
      *    *-----------------------------------------------------------*
       cnt-tdo-key-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-key-flg      .
       cnt-tdo-key-999.
           exit.
           
      *    *===========================================================*
      *    * Controllo se chiave vuota                                 *
      *    *-----------------------------------------------------------*
       cnt-key-vuo-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-key-vuo-flg      .
       cnt-key-vuo-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazione tasto Do campi non chiave       *
      *    *-----------------------------------------------------------*
       cnt-tdo-nok-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-nok-flg      .
       cnt-tdo-nok-025.
      *              *-------------------------------------------------*
      *              * Controllo su : Codice del debitore              *
      *              *-------------------------------------------------*
           if        w-tes-cod-dbt (1)    not  = zero
                     go to cnt-tdo-nok-050.
           move      "Manca il codice del cliente debitore              
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-050.
      *              *-------------------------------------------------*
      *              * Controllo su : Codice dipendenza del debitore   *
      *              *-------------------------------------------------*
       cnt-tdo-nok-075.
      *              *-------------------------------------------------*
      *              * Controllo su : Codice nostro conto bancario per *
      *              *                pagamento tramite bonifico, o    *
      *              *                nostro conto corrente postale    *
      *              *                per pagamento tramite c/c posta- *
      *              *                le                               *
      *              *-------------------------------------------------*
       cnt-tdo-nok-100.
      *              *-------------------------------------------------*
      *              * Controllo su : Codice ABI per l'appoggio in     *
      *              *                presentazione                    *
      *              *-------------------------------------------------*
           if        w-tes-tip-sdb (1)    not  = 02 and
                     w-tes-tip-sdb (1)    not  = 03 and
                     w-tes-tip-sdb (1)    not  = 04 and
                     w-tes-tip-sdb (1)    not  = 05 and
                     w-tes-tip-sdb (1)    not  = 06 and
                     w-tes-tip-sdb (1)    not  = 09 and
                     w-tes-tip-sdb (1)    not  = 10 and
                     w-tes-tip-sdb (1)    not  = 11
                     go to cnt-tdo-nok-125.
           if        w-tes-abi-app (1)    not  = zero
                     go to cnt-tdo-nok-125.
           if        w-tes-tip-sdb (1)    =    11
                     go to cnt-tdo-nok-125.
           move      "Manca la banca per la presentazione               
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-125.
      *              *-------------------------------------------------*
      *              * Controllo su : Codice CAB per l'appoggio in     *
      *              *                presentazione                    *
      *              *-------------------------------------------------*
           if        w-tes-tip-sdb (1)    not  = 02 and
                     w-tes-tip-sdb (1)    not  = 03 and
                     w-tes-tip-sdb (1)    not  = 04 and
                     w-tes-tip-sdb (1)    not  = 05 and
                     w-tes-tip-sdb (1)    not  = 06 and
                     w-tes-tip-sdb (1)    not  = 09 and
                     w-tes-tip-sdb (1)    not  = 10 and
                     w-tes-tip-sdb (1)    not  = 11
                     go to cnt-tdo-nok-150.
           if        w-tes-cab-app (1)    not  = zero
                     go to cnt-tdo-nok-150.
           if        w-tes-tip-sdb (1)    =    11   and
                     w-tes-abi-app (1)    =    zero
                     go to cnt-tdo-nok-150.
           move      "Manca lo sportello della banca per la presentazion
      -              "e              "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-150.
      *              *-------------------------------------------------*
      *              * Controllo su : Codice c/c per l'appoggio in     *
      *              *                presentazione                    *
      *              *-------------------------------------------------*
           if        w-tes-tip-sdb (1)    not  = 06
                     go to cnt-tdo-nok-175.
           if        w-tes-ccc-app (1)    not  = spaces
                     go to cnt-tdo-nok-175.
           move      "Manca il c/c per la presentazione                 
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-175.
      *              *-------------------------------------------------*
      *              * Controllo su : Inoltro scadenza al debitore     *
      *              *-------------------------------------------------*
           if        w-tes-tac-sdb (1)    =    02
                     go to cnt-tdo-nok-200.
           if        w-tes-inl-sdb (1)    not  = zero
                     go to cnt-tdo-nok-177.
           move      "Manca il tipo di inoltro scadenza                 
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-177.
           if        w-tes-inl-sdb (1)    not  = 03
                     go to cnt-tdo-nok-200.
           if        w-tes-dpz-dbt (1)    not  = spaces
                     go to cnt-tdo-nok-200.
           move      "Tipo di inoltro scadenza errato                   
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-200.
      *              *-------------------------------------------------*
      *              * Controllo su : Data di scadenza                 *
      *              *-------------------------------------------------*
       cnt-tdo-nok-201.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del valore della data  *
      *                  * scadenza                                    *
      *                  *---------------------------------------------*
           if        w-tes-dts-sdb (1)    not  = zero
                     go to cnt-tdo-nok-210.
       cnt-tdo-nok-205.
      *                  *---------------------------------------------*
      *                  * Se data scadenza a zero                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se il tipo scadenza ammette la data di  *
      *                      * scadenza a vista il controllo e' supe-  *
      *                      * rato                                    *
      *                      *-----------------------------------------*
           if        w-tes-tip-sdb (1)    =    01 or
                     w-tes-tip-sdb (1)    =    07 or
                     w-tes-tip-sdb (1)    =    08 or
                     w-tes-tip-sdb (1)    =    09 or
                     w-tes-tip-sdb (1)    =    10 or
                     w-tes-tip-sdb (1)    =    11
                     go to cnt-tdo-nok-225.
      *                      *-----------------------------------------*
      *                      * Altrimenti errore                       *
      *                      *-----------------------------------------*
           move      "Manca la data di scadenza                         
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-210.
      *                  *---------------------------------------------*
      *                  * Se data scadenza non a zero                 *
      *                  *---------------------------------------------*
       cnt-tdo-nok-211.
      *                      *-----------------------------------------*
      *                      * Se si e' in modifica e la data scadenza *
      *                      * e' inalterata rispetto al valore prece- *
      *                      * dente : nessun controllo                *
      *                      *-----------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "M"           and
                     w-tes-dts-sdb (1)    =    w-tes-dts-sdb (2)
                     go to cnt-tdo-nok-225.
       cnt-tdo-nok-212.
      *                      *-----------------------------------------*
      *                      * Preparazione di un indice per il tipo   *
      *                      * di scadenza, ad uso locale              *
      *                      *-----------------------------------------*
           move      w-tes-tip-sdb (1)    to   w-inx-ctr-inx-001      .
      *                      *-----------------------------------------*
      *                      * Se l'indice per il tipo scadenza non e' *
      *                      * ammissibile : nessun controllo          *
      *                      *-----------------------------------------*
           if        w-inx-ctr-inx-001    <    01 or
                     w-inx-ctr-inx-001    >    11
                     go to cnt-tdo-nok-225.
       cnt-tdo-nok-215.
      *                      *-----------------------------------------*
      *                      * Controllo rispetto alla data di regi-   *
      *                      * strazione                               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se per questo tipo di scadenza non  *
      *                          * deve essere eseguito il controllo   *
      *                          * rispetto alla data di registrazio-  *
      *                          * ne : si continua con il controllo   *
      *                          * sulla data documento                *
      *                          *-------------------------------------*
           if        w-prs-dsi-dat-reg
                    (w-inx-ctr-inx-001)   =    "S"
                     go to cnt-tdo-nok-220.
      *                          *-------------------------------------*
      *                          * Se la data scadenza non e' inferio- *
      *                          * re alla data di registrazione : si  *
      *                          * continua con il controllo sulla da- *
      *                          * ta documento                        *
      *                          *-------------------------------------*
           if        w-tes-dts-sdb (1)    not  < w-tes-dat-reg
                     go to cnt-tdo-nok-220.
      *                          *-------------------------------------*
      *                          * Se si e' in fase di riemissione a   *
      *                          * fronte, e la nuova scadenza ha le   *
      *                          * stesse caratteristiche, si accetta  *
      *                          * anche la data scadenza inferiore se *
      *                          * pari alla precedente                *
      *                          *-------------------------------------*
           if        w-key-flg-ens        not  = spaces      and
                     w-saf-num-sdb        not  = zero        and
                     w-tes-tip-sdb (1)    =    w-saf-tip-sdb and
                     w-tes-dts-sdb (1)    =    w-saf-dts-sdb
                     go to cnt-tdo-nok-220.
      *                          *-------------------------------------*
      *                          * Altrimenti si emette un messaggio   *
      *                          * di errore                           *
      *                          *-------------------------------------*
           move      "Attenzione : Data scadenza inferiore alla data di 
      -              "registrazione! "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                          *-------------------------------------*
      *                          * Se si doveva dare solo una segnala- *
      *                          * zione, si continua, ma omettendo    *
      *                          * il controllo rispetto alla data do- *
      *                          * cumento. Se invece il test era di   *
      *                          * tipo bloccante si esce per errore   *
      *                          *-------------------------------------*
           if        w-prs-dsi-dat-reg
                    (w-inx-ctr-inx-001)   =    "T"
                     go to cnt-tdo-nok-225
           else      go to cnt-tdo-nok-950.
       cnt-tdo-nok-220.
      *                      *-----------------------------------------*
      *                      * Controllo rispetto alla data del docu-  *
      *                      * mento                                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se per questo tipo di scadenza non  *
      *                          * deve essere eseguito il controllo   *
      *                          * rispetto alla data del documento :  *
      *                          * controllo superato                  *
      *                          *-------------------------------------*
           if        w-prs-dsi-dat-doc
                    (w-inx-ctr-inx-001)   =    "S"
                     go to cnt-tdo-nok-225.
      *                          *-------------------------------------*
      *                          * Se la data del documento e' a zero  *
      *                          * : nessun controllo                  *
      *                          *-------------------------------------*
           if        w-tes-dat-ddr (1)    =    zero
                     go to cnt-tdo-nok-225.
      *                          *-------------------------------------*
      *                          * Se la data scadenza non e' inferio- *
      *                          * re alla data di registrazione : il  *
      *                          * controllo e' superato               *
      *                          *-------------------------------------*
           if        w-tes-dts-sdb (1)    not  < w-tes-dat-ddr (1)
                     go to cnt-tdo-nok-225.
      *                          *-------------------------------------*
      *                          * Se si e' in fase di riemissione a   *
      *                          * fronte, e la nuova scadenza ha le   *
      *                          * stesse caratteristiche, si accetta  *
      *                          * anche la data scadenza inferiore se *
      *                          * pari alla precedente                *
      *                          *-------------------------------------*
           if        w-key-flg-ens        not  = spaces      and
                     w-saf-num-sdb        not  = zero        and
                     w-tes-tip-sdb (1)    =    w-saf-tip-sdb and
                     w-tes-dts-sdb (1)    =    w-saf-dts-sdb
                     go to cnt-tdo-nok-225.
      *                          *-------------------------------------*
      *                          * Altrimenti si emette un messaggio   *
      *                          * di errore                           *
      *                          *-------------------------------------*
           move      "Attenzione : Data scadenza inferiore alla data del
      -              " documento!    "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                          *-------------------------------------*
      *                          * Se si doveva dare solo una segnala- *
      *                          * zione, si continua. Se invece il    *
      *                          * test era di tipo bloccante si esce  *
      *                          * esce per errore                     *
      *                          *-------------------------------------*
           if        w-prs-dsi-dat-doc
                    (w-inx-ctr-inx-001)   =    "T"
                     go to cnt-tdo-nok-225
           else      go to cnt-tdo-nok-950.
       cnt-tdo-nok-225.
      *                      *-----------------------------------------*
      *                      * Se valore modificato e il tipo di sca-  *
      *                      * denza prevede l'aggiornamento contabile *
      *                      * si segnala che l'aggiornamento della    *
      *                      * descrizione causale contabile non e'    *
      *                      * automatico                              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se in modifica                 *
      *                          *-------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "M"
                     go to cnt-tdo-nok-230.
      *                          *-------------------------------------*
      *                          * Test se data scadenza variata       *
      *                          *-------------------------------------*
           if        w-tes-dts-sdb (1)    =    w-tes-dts-sdb (2)
                     go to cnt-tdo-nok-230.
      *                          *-------------------------------------*
      *                          * Se il tipo scadenza ammette la      *
      *                          * registrazione contabile             *
      *                          *-------------------------------------*
           if        w-tes-tip-sdb (1)    =    01 or
                     w-tes-tip-sdb (1)    =    07 or
                     w-tes-tip-sdb (1)    =    08
                     go to cnt-tdo-nok-230.
      *                          *-------------------------------------*
      *                          * Se le personalizzazioni indicano    *
      *                          * che in ogni caso gli aggiornamenti  *
      *                          * contabili non devono essere esegui- *
      *                          * ti : oltre                          *
      *                          *-------------------------------------*
           if        w-prs-gep-snx-cge    =    "N"
                     go to cnt-tdo-nok-230.
      *                          *-------------------------------------*
      *                          * Se il codice causale contabile per  *
      *                          * il tipo operazione di emissione e'  *
      *                          * a zero : oltre                      *
      *                          *-------------------------------------*
           if        w-top-cau-cge
                    (w-top-ele-inx)       =    zero
                     go to cnt-tdo-nok-230.
      *                          *-------------------------------------*
      *                          * Altrimenti si emette un messaggio   *
      *                          * di avviso                           *
      *                          *-------------------------------------*
           move      "Attenzione : la modifica alla data scadenza non vi
      -              "ene riportata  "    to   w-err-box-err-msg      .
           move      "             automaticamente nella relativa reg. c
      -              "ontabile       "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       cnt-tdo-nok-230.
      *              *-------------------------------------------------*
      *              * Controllo su : Importo scadenza                 *
      *              *-------------------------------------------------*
           if        w-tes-imp-sdb (1)    not  = zero
                     go to cnt-tdo-nok-250.
           move      "Manca l'importo della scadenza                    
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-250.
      *              *-------------------------------------------------*
      *              * Controllo su : Data documento di riferimento    *
      *              *-------------------------------------------------*
       cnt-tdo-nok-275.
      *              *-------------------------------------------------*
      *              * Controllo su : Numero documento di riferimento  *
      *              *-------------------------------------------------*
       cnt-tdo-nok-300.
      *              *-------------------------------------------------*
      *              * Controllo su : Tipo documento di riferimento    *
      *              *-------------------------------------------------*
       cnt-tdo-nok-325.
      *              *-------------------------------------------------*
      *              * Controllo su : Importo documento di riferimento *
      *              *-------------------------------------------------*
       cnt-tdo-nok-350.
      *              *-------------------------------------------------*
      *              * Controllo su : Nr.rata documento di riferimento *
      *              *-------------------------------------------------*
       cnt-tdo-nok-360.
      *              *-------------------------------------------------*
      *              * Controllo su : Protocollo fattura cliente       *
      *              *-------------------------------------------------*
       cnt-tdo-nok-370.
      *              *-------------------------------------------------*
      *              * Controllo su : Numero scadenza di origine       *
      *              *-------------------------------------------------*
       cnt-tdo-nok-380.
      *              *-------------------------------------------------*
      *              * Controllo su : Codice agente                    *
      *              *-------------------------------------------------*
       cnt-tdo-nok-400.
      *              *-------------------------------------------------*
      *              * Controllo su : Obbligato principale, ragione    *
      *              *                sociale                          *
      *              *-------------------------------------------------*
           if        w-tes-tac-sdb (1)    not  = 02
                     go to cnt-tdo-nok-425.
           if        w-tes-obp-rag-obp (1)
                                          not  = spaces
                     go to cnt-tdo-nok-425.
           move      "Manca la ragione sociale dell'obbligato principale
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-425.
      *              *-------------------------------------------------*
      *              * Controllo su : Obbligato principale, indirizzo  *
      *              *-------------------------------------------------*
           if        w-tes-tac-sdb (1)    not  = 02
                     go to cnt-tdo-nok-450.
           if        w-tes-obp-via-obp (1)
                                          not  = spaces
                     go to cnt-tdo-nok-450.
           move      "Manca l'indirizzo dell'obbligato principale       
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-450.
      *              *-------------------------------------------------*
      *              * Controllo su : Obbligato principale, c.a.p. e   *
      *              * citta'                                          *
      *              *-------------------------------------------------*
           if        w-tes-tac-sdb (1)    not  = 02
                     go to cnt-tdo-nok-500.
           if        w-tes-obp-loc-obp (1)
                                          not  = spaces
                     go to cnt-tdo-nok-500.
           move      "Mancano il c.a.p. e la citta' dell'obbligato princ
      -              "ipale          "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-500.
      *              *-------------------------------------------------*
      *              * Fine controlli, normalizzazioni                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione Si/No dilazione concordata  *
      *                  *---------------------------------------------*
           if        w-tes-snx-dlc (1)    not  = "S"
                     move  "N"            to   w-tes-snx-dlc (1)      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione Si/No contrassegno          *
      *                  *---------------------------------------------*
           if        w-tes-snx-cts (1)    not  = "S"
                     move  "N"            to   w-tes-snx-cts (1)      .
      *              *-------------------------------------------------*
      *              * Fine normalizzazioni, uscita                    *
      *              *-------------------------------------------------*
           go to     cnt-tdo-nok-999.
       cnt-tdo-nok-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore                              *
      *              *-------------------------------------------------*
