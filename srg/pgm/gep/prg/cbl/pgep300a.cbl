      *              *-------------------------------------------------*
           move      v-num                to   w-tes-num-sca          .
       acc-num-sca-250.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-num-sca-300.
      *                  *---------------------------------------------*
      *                  * Find su scadenze debitori                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Si/No ammissibilita' tasto Slct         *
      *                      *-----------------------------------------*
           move      "S"                  to   w-fnd-arc-sdb-sns      .
      *                      *-----------------------------------------*
      *                      * Codice cliente                          *
      *                      *-----------------------------------------*
           move      zero                 to   w-fnd-arc-sdb-cli      .
      *                      *-----------------------------------------*
      *                      * Dipendenza cliente                      *
      *                      *-----------------------------------------*
           move      spaces               to   w-fnd-arc-sdb-dpz      .
      *                      *-----------------------------------------*
      *                      * Tipo scadenza e tipo acquisizione       *
      *                      *-----------------------------------------*
           if        w-tes-tip-ope        =    0101
                     move  01             to   w-fnd-arc-sdb-tip
                     move  zero           to   w-fnd-arc-sdb-tac
           else if   w-tes-tip-ope        =    0102
                     move  02             to   w-fnd-arc-sdb-tip
                     move  zero           to   w-fnd-arc-sdb-tac
           else if   w-tes-tip-ope        =    0103
                     move  03             to   w-fnd-arc-sdb-tip
                     move  zero           to   w-fnd-arc-sdb-tac
           else if   w-tes-tip-ope        =    0104
                     move  04             to   w-fnd-arc-sdb-tip
                     move  zero           to   w-fnd-arc-sdb-tac
           else if   w-tes-tip-ope        =    0105
                     move  05             to   w-fnd-arc-sdb-tip
                     move  zero           to   w-fnd-arc-sdb-tac
           else if   w-tes-tip-ope        =    0106
                     move  06             to   w-fnd-arc-sdb-tip
                     move  zero           to   w-fnd-arc-sdb-tac
           else if   w-tes-tip-ope        =    0107
                     move  07             to   w-fnd-arc-sdb-tip
                     move  zero           to   w-fnd-arc-sdb-tac
           else if   w-tes-tip-ope        =    0108
                     move  08             to   w-fnd-arc-sdb-tip
                     move  zero           to   w-fnd-arc-sdb-tac
           else if   w-tes-tip-ope        =    0109
                     move  09             to   w-fnd-arc-sdb-tip
                     move  zero           to   w-fnd-arc-sdb-tac
           else if   w-tes-tip-ope        =    0110
                     move  10             to   w-fnd-arc-sdb-tip
                     move  zero           to   w-fnd-arc-sdb-tac
           else if   w-tes-tip-ope        =    0111
                     move  11             to   w-fnd-arc-sdb-tip
                     move  01             to   w-fnd-arc-sdb-tac
           else if   w-tes-tip-ope        =    0161
                     move  11             to   w-fnd-arc-sdb-tip
                     move  02             to   w-fnd-arc-sdb-tac
           else      move  zero           to   w-fnd-arc-sdb-tip
                     move  zero           to   w-fnd-arc-sdb-tac      .
      *                      *-----------------------------------------*
      *                      * Status scadenze : Solo quelle emesse    *
      *                      *-----------------------------------------*
           move      03                   to   w-fnd-arc-sdb-sts      .
      *                      *-----------------------------------------*
      *                      * Richiamo routine                        *
      *                      *-----------------------------------------*
           perform   fnd-arc-sdb-000      thru fnd-arc-sdb-999        .
      *                  *---------------------------------------------*
      *                  * Se selezione non effettuata : a reimposta-  *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           if        w-fnd-arc-sdb-sel    not  = spaces
                     go to acc-num-sca-100.
      *                  *---------------------------------------------*
      *                  * Ripresa numero scadenza selezionata         *
      *                  *---------------------------------------------*
           move      w-fnd-arc-sdb-num    to   w-tes-num-sca          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione numero scadenza selezionata *
      *                  *---------------------------------------------*
           perform   vis-num-sca-000      thru vis-num-sca-999        .
      *                  *---------------------------------------------*
      *                  * Forzatura simulata del tasto Do             *
      *                  *---------------------------------------------*
           move      "DO  "               to   v-key                  .
           go to     acc-num-sca-400.
       acc-num-sca-300.
      *              *-------------------------------------------------*
      *              * Se Expd                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "EXPD"
                     go to acc-num-sca-400.
      *                  *---------------------------------------------*
      *                  * Espansione su scadenze debitori             *
      *                  *---------------------------------------------*
           move      "S"                  to   w-esp-arc-sdb-sns      .
           move      w-tes-num-sca        to   w-esp-arc-sdb-num      .
           perform   esp-arc-sdb-000      thru esp-arc-sdb-999        .
      *                  *---------------------------------------------*
      *                  * Se selezione non effettuata : a reimposta-  *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           if        w-esp-arc-sdb-sel    not  = spaces
                     go to acc-num-sca-100.
      *                  *---------------------------------------------*
      *                  * Ripresa numero scadenza selezionata         *
      *                  *---------------------------------------------*
           move      w-esp-arc-sdb-num    to   w-tes-num-sca          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione numero scadenza selezionata *
      *                  *---------------------------------------------*
           perform   vis-num-sca-000      thru vis-num-sca-999        .
      *                  *---------------------------------------------*
      *                  * Forzatura simulata del tasto Do             *
      *                  *---------------------------------------------*
           move      "DO  "               to   v-key                  .
           go to     acc-num-sca-400.
       acc-num-sca-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-num-sca-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del tasto funzione u-  *
      *                  * tilizzato                                   *
      *                  *---------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-num-sca-650
           else      go to acc-num-sca-700.
       acc-num-sca-650.
      *                  *---------------------------------------------*
      *                  * Se terminazione con tasto Up                *
      *                  *---------------------------------------------*
       acc-num-sca-655.
      *                      *-----------------------------------------*
      *                      * Normalizzazione e visualizzazione nume- *
      *                      * ro scadenza                             *
      *                      *-----------------------------------------*
           if        w-tes-num-sca        =    zero
                     go to acc-num-sca-660.
           move      zero                 to   w-tes-num-sca          .
           perform   vis-num-sca-000      thru vis-num-sca-999        .
       acc-num-sca-660.
      *                      *-----------------------------------------*
      *                      * Forzatura del tasto Exit                *
      *                      *-----------------------------------------*
           move      "EXIT"               to   v-key                  .
      *                      *-----------------------------------------*
      *                      * Forzatura del tipo uscita per Up        *
      *                      *-----------------------------------------*
           move      "U"                  to   w-cnt-tus-acc-key      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     acc-num-sca-999.
       acc-num-sca-700.
      *                  *---------------------------------------------*
      *                  * In tutti gli altri casi                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     acc-num-sca-800.
       acc-num-sca-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-num-sca-999.
           perform   cnt-key-vuo-000      thru cnt-key-vuo-999        .
           if        w-cnt-key-vuo-flg    not  = spaces
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-num-sca-999.
           perform   cnt-tdo-key-000      thru cnt-tdo-key-999        .
           if        w-cnt-tdo-key-flg    not  = spaces
                     go to acc-num-sca-100
           else      move  "S"            to   w-cnt-tus-acc-key
                     go to acc-num-sca-999.
       acc-num-sca-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Numero scadenza                   *
      *    *-----------------------------------------------------------*
       vis-num-sca-000.
      *              *-------------------------------------------------*
      *              * Numero scadenza vero e proprio                  *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      06                   to   v-lin                  .
           move      22                   to   v-pos                  .
           move      w-tes-num-sca        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-num-sca-100.
      *              *-------------------------------------------------*
      *              * Dicitura di riemissione, se necessario          *
      *              *-------------------------------------------------*
       vis-num-sca-125.
      *                  *---------------------------------------------*
      *                  * Se non in fase di emissione nuova scadenza  *
      *                  * a fronte dell'operazione appena completata: *
      *                  * nessuna visualizzazione                     *
      *                  *---------------------------------------------*
           if        w-key-flg-ens        =    spaces
                     go to vis-num-sca-900.
       vis-num-sca-150.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del tipo operazione    *
      *                  * appena completata                           *
      *                  *---------------------------------------------*
           if        w-key-tvo-ens        =    0200
                     go to vis-num-sca-200
           else if   w-key-tvo-ens        =    0600
                     go to vis-num-sca-300
           else if   w-key-tvo-ens        =    0620
                     go to vis-num-sca-350
           else      go to vis-num-sca-900.
       vis-num-sca-200.
      *                  *---------------------------------------------*
      *                  * Se : Storno                                 *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      38                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      43                   to   v-pos                  .
           move      "          * A fronte storno scadenza *"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     vis-num-sca-900.
       vis-num-sca-300.
      *                  *---------------------------------------------*
      *                  * Se : Insoluto                               *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      38                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      43                   to   v-pos                  .
           move      "                 * A fronte insoluto *"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     vis-num-sca-900.
       vis-num-sca-350.
      *                  *---------------------------------------------*
      *                  * Se : Richiamo di scadenza presentata        *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      38                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      43                   to   v-pos                  .
           move      "        * A fronte richiamo da banca *"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     vis-num-sca-900.
       vis-num-sca-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     vis-num-sca-999.
       vis-num-sca-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campi non chiave della registrazione         *
      *    *-----------------------------------------------------------*
       acc-nok-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-nok      .
      *              *-------------------------------------------------*
      *              * Visualizzazione tipo funzionamento              *
      *              *-------------------------------------------------*
           perform   vis-tip-fun-000      thru vis-tip-fun-999        .
      *              *-------------------------------------------------*
      *              * Assestamento status di impostazione se in modi- *
      *              * fica o visualizzazione, per testata             *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "M" or
                     w-cnt-mfu-tip-fun    =    "V"
                     move  "#"            to   w-cnt-sts-imp-tes
                     move  all "#"        to   w-cnt-sts-imp-pte
                     move  all "#"        to   w-cnt-sts-ing-pte      .
       acc-nok-reg-200.
      *              *-------------------------------------------------*
      *              * Trattamento testata                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione del numero di pagine che     *
      *                  * compongono la testata                       *
      *                  *---------------------------------------------*
           perform   dmp-tes-reg-000      thru dmp-tes-reg-999        .
      *                  *---------------------------------------------*
      *                  * Video in 'OFF'                              *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Prompts per campi chiave                    *
      *                  *---------------------------------------------*
           if        w-cnt-sts-pmt-key    =    spaces
                     perform pmt-key-reg-000
                                          thru pmt-key-reg-999
                     move    "#"          to   w-cnt-sts-pmt-key      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione dati campi chiave           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-vis-key    =    spaces
                     perform vis-key-reg-000
                                          thru vis-key-reg-999
                     move    "#"          to   w-cnt-sts-vis-key      .
      *                  *---------------------------------------------*
      *                  * Prompts per pagina di testata               *
      *                  *---------------------------------------------*
           if        w-cnt-sts-pmt-ptx
                    (w-cnt-sts-imp-npt)   =    spaces
                     perform pmt-tes-reg-000
                                          thru pmt-tes-reg-999
                     move    "#"          to   w-cnt-sts-pmt-ptx
                                              (w-cnt-sts-imp-npt)     .
      *                  *---------------------------------------------*
      *                  * Visualizzazione dati pagina testata         *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "M"      or
                     w-cnt-mfu-tip-fun    =    "V"      or
                     w-cnt-sts-imp-ptx
                    (w-cnt-sts-imp-npt)   not  = spaces or
                     w-cnt-sts-ing-ptx
                    (w-cnt-sts-imp-npt)   not  = spaces
                     if    w-cnt-sts-vis-ptx
                          (w-cnt-sts-imp-npt)
                                          =    spaces
                           perform vis-tes-reg-000
                                          thru vis-tes-reg-999
                           move    "#"    to   w-cnt-sts-vis-ptx
                                              (w-cnt-sts-imp-npt)     .
      *                  *---------------------------------------------*
      *                  * Flag di ingresso in pagina di testata       *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-sts-ing-ptx
                                              (w-cnt-sts-imp-npt)     .
      *                  *---------------------------------------------*
      *                  * Video in 'ON'                               *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Accettazione dati testata                   *
      *                  *---------------------------------------------*
           perform   acc-tes-reg-000      thru acc-tes-reg-999        .
      *                  *---------------------------------------------*
      *                  * Se tipo uscita definitivo                   *
      *                  *---------------------------------------------*
           if        w-cnt-tus-acc-tes    =    "S" or
                     w-cnt-tus-acc-tes    =    "X" or
                     w-cnt-tus-acc-tes    =    "E"
                     move  w-cnt-tus-acc-tes
                                          to   w-cnt-tus-acc-nok
                     go to acc-nok-reg-999.
      *                  *---------------------------------------------*
      *                  * Se spostamento di pagina                    *
      *                  *---------------------------------------------*
           if        w-cnt-tus-acc-tes    =    "-"
                     go to acc-nok-reg-300
           else      go to acc-nok-reg-400.
       acc-nok-reg-300.
      *                      *-----------------------------------------*
      *                      * Se spostamento a pagina precedente      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se la pagina attuale e' 1 si ignora *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-npt    not  > 1
                     go to acc-nok-reg-200.
      *                          *-------------------------------------*
      *                          * Status di visualizzazione prompts e *
      *                          * dati della chiave a : no            *
      *                          *-------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-key      .
           move      spaces               to   w-cnt-sts-vis-key      .
      *                          *-------------------------------------*
      *                          * Status di visualizzazione prompts e *
      *                          * dati della pagina attuale a : no    *
      *                          *-------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-ptx
                                              (w-cnt-sts-imp-npt)     .
           move      spaces               to   w-cnt-sts-vis-ptx
                                              (w-cnt-sts-imp-npt)     .
       acc-nok-reg-325.
      *                          *-------------------------------------*
      *                          * Decremento numero pagina attuale    *
      *                          *-------------------------------------*
           subtract  1                    from w-cnt-sts-imp-npt      .
      *                          *-------------------------------------*
      *                          * Test se pagina da trattare          *
      *                          *-------------------------------------*
           perform   snp-tes-reg-000      thru snp-tes-reg-999        .
      *                          *-------------------------------------*
      *                          * Se no : decremento ulteriore        *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-snp    not  = spaces and
                     w-cnt-sts-imp-npt    >    1
                     go to acc-nok-reg-325.
      *                          *-------------------------------------*
      *                          * Riciclo ad impostazione testata     *
      *                          *-------------------------------------*
           go to     acc-nok-reg-200.
       acc-nok-reg-400.
      *                      *-----------------------------------------*
      *                      * Se spostamento a pagina successiva      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Salvataggio numero pagina attuale   *
      *                          *-------------------------------------*
           move      w-cnt-sts-imp-npt    to   w-cnt-sts-imp-svp      .
       acc-nok-reg-425.
      *                          *-------------------------------------*
      *                          * Status di impostazione dati della   *
      *                          * della pagina attuale a : si'        *
      *                          *-------------------------------------*
           move      "#"                  to   w-cnt-sts-imp-ptx
                                              (w-cnt-sts-imp-npt)     .
      *                          *-------------------------------------*
      *                          * Se la pagina attuale e' la massima  *
      *                          * si pone lo status di impostazione   *
      *                          * dati generale testata a si'         *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-npt    not  < w-cnt-sts-imp-mpt
                     move  "#"            to   w-cnt-sts-imp-tes      .
      *                          *-------------------------------------*
      *                          * Se la pagina attuale e' la massima  *
      *                          * si va' a conferma impostazioni      *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-npt    not  < w-cnt-sts-imp-mpt
                     move  w-cnt-sts-imp-svp
                                          to   w-cnt-sts-imp-npt
                     go to acc-nok-reg-800.
      *                          *-------------------------------------*
      *                          * Incremento numero pagina attuale    *
      *                          *-------------------------------------*
           add       1                    to   w-cnt-sts-imp-npt      .
      *                          *-------------------------------------*
      *                          * Test se pagina da trattare          *
      *                          *-------------------------------------*
           perform   snp-tes-reg-000      thru snp-tes-reg-999        .
      *                          *-------------------------------------*
      *                          * Se no : a re-incremento             *
      *                          *-------------------------------------*
           if        w-cnt-sts-imp-snp    not  = spaces
                     go to acc-nok-reg-425.
      *                          *-------------------------------------*
      *                          * Status di visualizzazione prompts e *
      *                          * dati della chiave a : no            *
      *                          *-------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-key      .
           move      spaces               to   w-cnt-sts-vis-key      .
      *                          *-------------------------------------*
      *                          * Status di visualizzazione prompts e *
      *                          * dati della pagina impostata a : no  *
      *                          *-------------------------------------*
           move      spaces               to   w-cnt-sts-pmt-ptx
                                              (w-cnt-sts-imp-svp)     .
           move      spaces               to   w-cnt-sts-vis-ptx
                                              (w-cnt-sts-imp-svp)     .
      *                          *-------------------------------------*
      *                          * Riciclo ad impostazione testata     *
      *                          *-------------------------------------*
           go to     acc-nok-reg-200.
       acc-nok-reg-800.
      *              *-------------------------------------------------*
      *              * Conferma impostazioni                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Cancellazione eventuali note operative      *
      *                  *---------------------------------------------*
           move      "NT"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-nok-reg-810.
      *                  *---------------------------------------------*
      *                  * Test se sola visualizzazione                *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "V"
                     go to acc-nok-reg-820
           else      go to acc-nok-reg-830.
       acc-nok-reg-820.
      *                      *-----------------------------------------*
      *                      * Accettazione se sola visualizzazione    *
      *                      *-----------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      "#VIS"               to   v-not                  .
           move      spaces               to   v-alf                  .
           move      "E"                  to   v-msk                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           if        v-key                not  = spaces
                     go to acc-nok-reg-840.
           if        v-alf                =    "E"
                     move  "EXIT"         to   v-key                  .
           go to     acc-nok-reg-840.
       acc-nok-reg-830.
      *                      *-----------------------------------------*
      *                      * Accettazione se inserimento o modifica  *
      *                      *-----------------------------------------*
       acc-nok-reg-831.
      *                          *-------------------------------------*
      *                          * Deviazione a seconda se in forzatu- *
      *                          * ra di riemissione oppure no         *
      *                          *-------------------------------------*
           if        w-key-frz-ens        not  = spaces
                     go to acc-nok-reg-833.
       acc-nok-reg-832.
      *                          *-------------------------------------*
      *                          * Se in emissione normale             *
      *                          *-------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      "#SAV"               to   v-not                  .
           move      spaces               to   v-alf                  .
           move      "SNE"                to   v-msk                  .
           move      "DO  "               to   v-pfk (05)             .
           move      "UP  "               to   v-pfk (01)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     acc-nok-reg-834.
       acc-nok-reg-833.
      *                          *-------------------------------------*
      *                          * Se in emissione per forzatura di    *
      *                          * riemissione                         *
      *                          *-------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      "Conferma impostazioni (S/N) ?"
                                          to   v-not                  .
           move      spaces               to   v-alf                  .
           move      "SN"                 to   v-msk                  .
           move      "DO  "               to   v-pfk (05)             .
           move      "UP  "               to   v-pfk (01)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     acc-nok-reg-834.
       acc-nok-reg-834.
      *                          *-------------------------------------*
      *                          * Continuazione comune                *
      *                          * riemissione                         *
      *                          *-------------------------------------*
           if        v-key                not  = spaces
                     go to acc-nok-reg-840.
           if        v-alf                =    "S"
                     move   "DO  "        to   v-key
           else if   v-alf                =    "E"
                     move   "EXIT"        to   v-key
           else if   v-alf                =    "N"
                     move   "UP  "        to   v-key                  .
       acc-nok-reg-840.
      *                  *---------------------------------------------*
      *                  * Test su risposta dell'utente                *
      *                  *---------------------------------------------*
           if        v-key                =    "DO  "
                     go to acc-nok-reg-850
           else if   v-key                =    "EXIT"
                     go to acc-nok-reg-860
           else if   v-key                =    "UP  "
                     go to acc-nok-reg-870
           else      go to acc-nok-reg-810.
       acc-nok-reg-850.
      *                  *---------------------------------------------*
      *                  * Se Do                                       *
      *                  *---------------------------------------------*
           perform   cnt-tdo-nok-000      thru cnt-tdo-nok-999        .
           if        w-cnt-tdo-nok-flg    =    spaces
                     move  "S"            to   w-cnt-tus-acc-nok
                     go to acc-nok-reg-999
           else      move  spaces         to   w-cnt-tdo-nok-flg
                     go to acc-nok-reg-800.
       acc-nok-reg-860.
      *                  *---------------------------------------------*
      *                  * Se Exit                                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Subroutine di controllo per Exit        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se Exit non attivato : come 'Up'    *
      *                          *-------------------------------------*
           perform   exe-acc-cmp-exi-000  thru exe-acc-cmp-exi-999    .
           if        w-cnt-acc-flg-exi    not  = spaces
                     go to acc-nok-reg-870.
      *                          *-------------------------------------*
      *                          * Se Exit attivato                    *
      *                          *-------------------------------------*
           move      "E"                  to   w-cnt-tus-acc-nok      .
           go to     acc-nok-reg-999.
       acc-nok-reg-870.
