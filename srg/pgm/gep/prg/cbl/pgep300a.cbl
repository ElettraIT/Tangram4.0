      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-vet-999.
       let-arc-vet-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-vet-flg      .
           move      all   "."            to   w-let-arc-vet-rag      .
           go to     let-arc-vet-600.
       let-arc-vet-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-vet-rag      .
       let-arc-vet-600.
           move      spaces               to   w-let-arc-vet-via      .
           move      spaces               to   w-let-arc-vet-loc      .
       let-arc-vet-999.
           exit.

      *    *===========================================================*
      *    * Determinazione status scadenza                            *
      *    *-----------------------------------------------------------*
       det-dat-chs-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione data scadenza chiusa a : Aper- *
      *              * ta                                              *
      *              *-------------------------------------------------*
           move      9999999              to   rf-sdb-dat-chs         .
       det-dat-chs-020.
      *              *-------------------------------------------------*
      *              * Controllo su : Insoluto                         *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-isp       =    zero
                     go to det-dat-chs-040.
      *                  *---------------------------------------------*
      *                  * Se la scadenza e' stata riscossa : oltre    *
      *                  *---------------------------------------------*
           if        rf-sdb-num-ris       not  = zero
                     go to det-dat-chs-040.
      *                  *---------------------------------------------*
      *                  * Se a fronte dell'insoluto non e' stata e-   *
      *                  * messa una nuova scadenza, essa e' da inten- *
      *                  * dersi ancora aperta                         *
      *                  *---------------------------------------------*
           if        rf-sdb-ens-isp       =    02   and
                     rf-sdb-nns-isp       =    zero
                     go to det-dat-chs-999.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-isp       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-040.
      *              *-------------------------------------------------*
      *              * Controllo su : Presunto buon esito              *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-pbe       =     zero
                     go to det-dat-chs-060.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-pbe       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-060.
      *              *-------------------------------------------------*
      *              * Controllo su : Presunto buon esito              *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-nbe       =     zero
                     go to det-dat-chs-080.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-nbe       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-080.
      *              *-------------------------------------------------*
      *              * Controllo su : Accredito scadenza al dopo in-   *
      *              *                casso                            *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-acs       =     zero
                     go to det-dat-chs-100.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-acs       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-100.
      *              *-------------------------------------------------*
      *              * Controllo su : Richiamo della scadenza presen-  *
      *              *                tata                             *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-rsp       =     zero
                     go to det-dat-chs-120.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-rsp       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-120.
      *              *-------------------------------------------------*
      *              * Controllo su : Inclusione in distinta           *
      *              *-------------------------------------------------*
           if        rf-sdb-num-ddp       =     zero
                     go to det-dat-chs-140.
      *                  *---------------------------------------------*
      *                  * Nessuna azione                              *
      *                  *---------------------------------------------*
           go to     det-dat-chs-140.
       det-dat-chs-140.
      *              *-------------------------------------------------*
      *              * Controllo su : Riscossione                      *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-ris       =     zero
                     go to det-dat-chs-160.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-ris       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-160.
      *              *-------------------------------------------------*
      *              * Controllo su : Storno                           *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-sto       =     zero
                     go to det-dat-chs-180.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-sto       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-180.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-999.
           exit.

      *    *===========================================================*
      *    * Routine di attribuzione numero scadenza debitori          *
      *    *-----------------------------------------------------------*
       att-num-sca-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-sdb             .
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [numsdb]                                  *
      *              *-------------------------------------------------*
           move      w-num-sca-scl-ann    to   rn-num-sdb-scl-ann     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [numsdb]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-sdb             .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-num-sca-400.
       att-num-sca-200.
      *              *-------------------------------------------------*
      *              * Se record non esistente                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Scrittura record normalizzato               *
      *                  *---------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-sdb             .
      *                  *---------------------------------------------*
      *                  * Unlock record                               *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-sdb             .
      *                  *---------------------------------------------*
      *                  * Ripetizione dell'intera operazione          *
      *                  *---------------------------------------------*
           go to     att-num-sca-000.
       att-num-sca-400.
      *              *-------------------------------------------------*
      *              * Se record esistente                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore pre-incremento           *
      *                  *---------------------------------------------*
           move      rn-num-sdb-num-sdb   to   w-num-sca-num-sca      .
           move      w-num-sca-r01-num    to   w-num-sca-val-pre      .
      *                  *---------------------------------------------*
      *                  * Preparazione valore post-incremento         *
      *                  *---------------------------------------------*
           move      w-num-sca-val-pre    to   w-num-sca-val-pos      .
           add       1                    to   w-num-sca-val-pos      .
           if        w-num-sca-val-pos    =    zero
                     move  1              to   w-num-sca-val-pos      .
      *                  *---------------------------------------------*
      *                  * Preparazione numero scadenza completo       *
      *                  *---------------------------------------------*
           move      w-num-sca-scl-ann    to   w-num-sca-r01-saa      .
           move      w-num-sca-val-pos    to   w-num-sca-r01-num      .
      *                  *---------------------------------------------*
      *                  * Aggiornamento numero scadenza               *
      *                  *---------------------------------------------*
           move      w-num-sca-num-sca    to   rn-num-sdb-num-sdb     .
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-sdb             .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'esito dell'opera- *
      *                  * zione di update                             *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-num-sca-600.
       att-num-sca-500.
      *                  *---------------------------------------------*
      *                  * Se errore in operazione di update           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-sdb             .
      *                      *-----------------------------------------*
      *                      * Ripetizione dell'intera operazione      *
      *                      *-----------------------------------------*
           go to     att-num-sca-000.
       att-num-sca-600.
      *                  *---------------------------------------------*
      *                  * Se nessun errore in operazione di update    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-sdb             .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     att-num-sca-999.
       att-num-sca-999.
           exit.

      *    *===========================================================*
      *    * Routine di ripristino numero scadenza debitori            *
      *    *-----------------------------------------------------------*
       rip-num-sca-000.
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [numsdb]                                  *
      *              *-------------------------------------------------*
           move      w-num-sca-scl-ann    to   rn-num-sdb-scl-ann     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [numsdb]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-sdb             .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to rip-num-sca-400.
       rip-num-sca-200.
      *              *-------------------------------------------------*
      *              * Se record non esistente                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Unlock record                               *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-sdb             .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     rip-num-sca-999.
       rip-num-sca-400.
      *              *-------------------------------------------------*
      *              * Se record esistente                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Confronto tra il numero scadenza attuale    *
      *                  * contenuto nel record numerazioni ed il va-  *
      *                  * lore post-incremento, e deviazione in fun-  *
      *                  * zione dell'esito del test                   *
      *                  *---------------------------------------------*
           move      rn-num-sdb-num-sdb   to   w-num-sca-num-sca      .
           if        w-num-sca-r01-num    =    w-num-sca-val-pos
                     go to rip-num-sca-600.
       rip-num-sca-500.
      *                  *---------------------------------------------*
      *                  * Se numero scadenza attuale contenuto nel    *
      *                  * record numerazioni diverso dal valore post- *
      *                  * incremento                                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-sdb             .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rip-num-sca-999.
       rip-num-sca-600.
      *                  *---------------------------------------------*
      *                  * Se numero scadenza attuale contenuto nel    *
      *                  * record numerazioni uguale al valore post-   *
      *                  * incremento                                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controaggiornamento del valore attuale  *
      *                      * contenuto nel record numerazioni, ri-   *
      *                      * portandolo al valore pre-incremento     *
      *                      *-----------------------------------------*
           move      w-num-sca-val-pre    to   w-num-sca-r01-num      .
           if        w-num-sca-val-pre    =    zero
                     move  zero           to   w-num-sca-num-sca      .
           move      w-num-sca-num-sca    to   rn-num-sdb-num-sdb     .
      *                      *-----------------------------------------*
      *                      * Update record numerazioni               *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-sdb             .
      *                      *-----------------------------------------*
      *                      * Unlock record numerazioni               *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-sdb             .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rip-num-sca-999.
       rip-num-sca-999.
           exit.

