      *              *-------------------------------------------------*
           if        w-top-cau-cge
                    (w-top-ele-inx)       =    zero
                     move  "N"            to   w-cge-gep-emi-snx
                     go to cge-gep-emi-snx-999.
      *              *-------------------------------------------------*
      *              * Se il codice sottoconto contabile per il tipo   *
      *              * operazione di emissione e' a zero : uscita con  *
      *              * 'N'                                             *
      *              *-------------------------------------------------*
           if        w-top-stc-cge
                    (w-top-ele-inx)       =    zero
                     move  "N"            to   w-cge-gep-emi-snx
                     go to cge-gep-emi-snx-999.
      *              *-------------------------------------------------*
      *              * Se flag di registrazione contabile modificabile *
      *              * a 'No', si esce con 'N'                         *
      *              *-------------------------------------------------*
           if        w-tes-flg-rcm        not  = spaces
                     move  "N"            to   w-cge-gep-emi-snx
                     go to cge-gep-emi-snx-999.
