           move      w-let-arc-cli-rag    to   w-tes-cod-dbt-rag (1)  .
           move      w-let-arc-cli-via    to   w-tes-cod-dbt-via (1)  .
           move      w-let-arc-cli-loc    to   w-tes-cod-dbt-loc (1)  .
           move      w-let-arc-cli-cge    to   w-tes-cod-dbt-cge (1)  .
