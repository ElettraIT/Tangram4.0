      *    *===========================================================*
      *    * Accettazione campo : Codice nostro conto bancario per pa- *
      *    *                      gamento tramite bonifico, o nostro   *
      *    *                      conto corrente postale per pagamento *
      *    *                      tramite c/c postale                  *
      *    *-----------------------------------------------------------*
       acc-cod-cbp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione tipo record per casse, ban-  *
      *                  * che, c/c postali                            *
      *                  *---------------------------------------------*
           if        w-tes-tip-sdb (1)    =    07
                     move  02             to   w-sav-tip-cbp
           else if   w-tes-tip-sdb (1)    =    08
                     move  03             to   w-sav-tip-cbp
           else      move  zero           to   w-sav-tip-cbp          .
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-sav-tip-cbp        not  = 02 and
                     w-sav-tip-cbp        not  = 03
                     go to acc-cod-cbp-999.
       acc-cod-cbp-050.
      *                  *---------------------------------------------*
      *                  * Preparazione eventuale del default          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore attuale diverso da spaces :   *
      *                      * no preparazione default                 *
      *                      *-----------------------------------------*
           if        w-tes-cod-cbp (1)    not  = spaces
                     go to acc-cod-cbp-070.
      *                      *-----------------------------------------*
      *                      * Se non si e' in Inserimento : no prepa- *
      *                      * razione default                         *
      *                      *-----------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-cod-cbp-070.
      *                      *-----------------------------------------*
      *                      * Se preparazione default gia' eseguita : *
      *                      * no preparazione default                 *
      *                      *-----------------------------------------*
           if        w-fpd-acc-cod-cbp    not  = spaces
                     go to acc-cod-cbp-070.
      *                      *-----------------------------------------*
      *                      * Se il tipo debitore non indica che si   *
      *                      * tratta di un cliente : no preparazione  *
      *                      * default                                 *
      *                      *-----------------------------------------*
           if        w-tes-tip-dbt (1)    not  = 01
                     go to acc-cod-cbp-070.
      *                      *-----------------------------------------*
      *                      * Lettura archivio [dcc] relativa al cli- *
      *                      * ente principale                         *
      *                      *-----------------------------------------*
           move      "C"                  to   w-let-arc-dcc-tle      .
           move      w-tes-cod-dbt (1)    to   w-let-arc-dcc-cod      .
           move      spaces               to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                      *-----------------------------------------*
      *                      * Se record non esistente : no prepara-   *
      *                      * zione default                           *
      *                      *-----------------------------------------*
           if        w-let-arc-dcc-flg    not  = spaces
                     go to acc-cod-cbp-070.
      *                      *-----------------------------------------*
      *                      * Preparazione default per codice nostra  *
      *                      * banca o codice ns c/c postale           *
      *                      *-----------------------------------------*
           if        w-sav-tip-cbp        =    02
                     move  w-let-arc-dcc-ban
                                          to   w-tes-cod-cbp (1)
           else      move  w-let-arc-dcc-ccp
                                          to   w-tes-cod-cbp (1)      .
      *                      *-----------------------------------------*
      *                      * Se codice di default a spaces : no pre- *
      *                      * parazione default                       *
      *                      * default                                 *
      *                      *-----------------------------------------*
           if        w-tes-cod-cbp (1)    =    zero
                     go to acc-cod-cbp-070.
      *                      *-----------------------------------------*
      *                      * Lettura record nostra banca o nostro    *
      *                      * c/c postale                             *
      *                      *-----------------------------------------*
           move      w-sav-tip-cbp        to   w-let-arc-cbp-tip      .
           move      w-tes-cod-cbp (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
      *                      *-----------------------------------------*
      *                      * Se record non esistente : normalizza-   *
      *                      * zione codice e no preparazione default  *
      *                      *-----------------------------------------*
           if        w-let-arc-cbp-flg    not  = spaces
                     move  spaces         to   w-tes-cod-cbp (1)
                     go to acc-cod-cbp-070.
      *                          *-------------------------------------*
      *                          * Memorizzazione descrizione          *
      *                          *-------------------------------------*
           move      w-let-arc-cbp-des    to   w-tes-cod-cbp-des (1)  .
      *                          *-------------------------------------*
      *                          * Visualizzazione codice              *
      *                          *-------------------------------------*
           perform   vis-cod-cbp-000      thru vis-cod-cbp-999        .
      *                          *-------------------------------------*
      *                          * Visualizzazione descrizione         *
      *                          *-------------------------------------*
           perform   vis-cod-cbp-des-000  thru vis-cod-cbp-des-999    .
       acc-cod-cbp-070.
      *                  *---------------------------------------------*
      *                  * Ad accettazione                             *
      *                  *---------------------------------------------*
           go to     acc-cod-cbp-100.
       acc-cod-cbp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-des-cbp-ope      .
           move      w-sav-tip-cbp        to   w-cod-des-cbp-tip      .
           move      w-tes-cod-cbp (1)    to   w-cod-des-cbp-cod      .
           move      13                   to   w-cod-des-cbp-lin      .
           move      30                   to   w-cod-des-cbp-pos      .
           move      13                   to   w-cod-des-cbp-dln      .
           move      41                   to   w-cod-des-cbp-dps      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   cod-des-cbp-cll-000  thru cod-des-cbp-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-des-cbp-foi-000  thru cod-des-cbp-foi-999    .
       acc-cod-cbp-110.
           perform   cod-des-cbp-cll-000  thru cod-des-cbp-cll-999    .
           if        w-cod-des-cbp-ope    =    "F+"
                     go to acc-cod-cbp-115.
           if        w-cod-des-cbp-ope    =    "AC"
                     go to acc-cod-cbp-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-cbp-115.
           perform   cod-des-cbp-foi-000  thru cod-des-cbp-foi-999    .
           go to     acc-cod-cbp-110.
       acc-cod-cbp-120.
           move      w-cod-des-cbp-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit, ma in forzatura di riemissione         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"   and
                     w-key-frz-ens        not  = spaces
                     go to acc-cod-cbp-100.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cbp-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cbp-999.
       acc-cod-cbp-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-cod-cbp (1)      .
       acc-cod-cbp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-cod-cbp-410.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [cbp]                      *
      *                  *---------------------------------------------*
           move      w-sav-tip-cbp        to   w-let-arc-cbp-tip      .
           move      w-tes-cod-cbp (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-cbp-des    to   w-tes-cod-cbp-des (1)  .
       acc-cod-cbp-420.
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-cod-cbp-des-000  thru vis-cod-cbp-des-999    .
       acc-cod-cbp-430.
      *                  *---------------------------------------------*
      *                  * Se record non esistente : reimpostazione    *
      *                  * ne                                          *
      *                  *---------------------------------------------*
           if        w-let-arc-cbp-flg    not  = spaces
                     go to acc-cod-cbp-100.
       acc-cod-cbp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-cbp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-cbp-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-cbp-100.
       acc-cod-cbp-999.
           exit.

