      *                  * Nota : i seguenti campi non vengono prepa-  *
      *                  *        rati in quanto gia' normalizzati :   *
      *                  *                                             *
      *                  *        - Commento in riga                   *
      *                  *                                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo operazione                         *
      *                      *-----------------------------------------*
           move      "W+"                 to   l-cge-300-tip-ope      .
      *                      *-----------------------------------------*
      *                      * Codice sottoconto                       *
      *                      *-----------------------------------------*
           move      w-tes-cod-dbt-cge (1)
                                          to   l-cge-300-cod-pdc      .
      *                      *-----------------------------------------*
      *                      * Tipo archivio                           *
      *                      *-----------------------------------------*
           if        w-tes-tip-dbt (1)    =    01
                     move  "C"            to   l-cge-300-tip-arc
           else      move  "C"            to   l-cge-300-tip-arc      .
      *                      *-----------------------------------------*
      *                      * Codice archivio                         *
      *                      *-----------------------------------------*
           move      w-tes-cod-dbt (1)    to   l-cge-300-cod-arc      .
      *                      *-----------------------------------------*
      *                      * Data riferimento                        *
      *                      *-----------------------------------------*
           move      w-tes-dat-ddr (1)    to   l-cge-300-dat-rif      .
      *                      *-----------------------------------------*
      *                      * Numero riferimento                      *
      *                      *-----------------------------------------*
           move      w-tes-num-ddr (1)    to   l-cge-300-num-rif      .
      *                      *-----------------------------------------*
      *                      * Dare/Avere                              *
      *                      *-----------------------------------------*
           move      "A"                  to   l-cge-300-dar-ave      .
      *                      *-----------------------------------------*
      *                      * Importo movimento                       *
      *                      *-----------------------------------------*
           move      w-tes-imp-sdb (1)    to   l-cge-300-imp-mov      .
      *                      *-----------------------------------------*
      *                      * Flag di regime fiscale particolare      *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-flg-rfp      .
      *                      *-----------------------------------------*
      *                      * Sigla numerazione                       *
      *                      *-----------------------------------------*
           move      spaces               to   l-cge-300-sgl-num      .
      *                      *-----------------------------------------*
      *                      * Data acquisizione                       *
