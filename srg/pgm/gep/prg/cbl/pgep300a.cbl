      *                      *-----------------------------------------*
           if        w-tes-dpz-dbt (1)    =    spaces and
                     w-tes-dpz-dbt-rag (1)
                                          =    spaces and
                     w-tes-dpz-dbt-via (1)
                                          =    spaces and
