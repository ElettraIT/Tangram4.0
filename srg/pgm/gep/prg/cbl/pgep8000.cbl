      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-snx-alv-999.
       acc-snx-alv-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    01
                     move  "S"            to   rr-snx-alv
           else if   v-num                =    02
                     move  "N"            to   rr-snx-alv
           else      move  spaces         to   rr-snx-alv             .
       acc-snx-alv-400.
