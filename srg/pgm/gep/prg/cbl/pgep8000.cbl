           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Test se esecuzione batch                        *
      *              *-------------------------------------------------*
           if        rr-snx-btc           not  = "S"
                     go to stp-srt-inp-010.
      *              *-------------------------------------------------*
      *              * Forzature                                       *
      *              *-------------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rr-dat-rif             .
           move      02                   to   rr-tip-sel             .
           move      "N"                  to   rr-snx-alv             .
           move      zero                 to   rr-cod-age             .
           move      spaces               to   rr-cod-age-nom         .
           move      zero                 to   rr-cod-cli             .
           move      spaces               to   rr-cod-cli-rag         .
           move      spaces               to   rr-cod-cli-via         .
           move      spaces               to   rr-cod-cli-loc         .
           move      spaces               to   rr-dpz-cli             .
           move      spaces               to   rr-dpz-cli-rag         .
           move      spaces               to   rr-dpz-cli-via         .
           move      spaces               to   rr-dpz-cli-loc         .
           move      zero                 to   rr-snx-deb             .
           move      zero                 to   rr-dts-min             .
           move      zero                 to   rr-dts-max             .
           move      01                   to   rr-esc-csi             .
           move      zero                 to   rr-dri-min             .
           move      zero                 to   rr-dri-max             .
       stp-srt-inp-010.
      *              *-------------------------------------------------*
      *              * Inizializzazione contatore elementi nel buffer  *
      *              * clienti da stampare                             *
      *              *-------------------------------------------------*
           move      zero                 to   w-bcs-num-ele          .
      *              *-------------------------------------------------*
      *              * Start su file [sdb]                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo selezione   *
      *                  *---------------------------------------------*
           if        rr-tip-sel           =    01
                     go to stp-srt-inp-020
           else if   rr-tip-sel           =    02
                     go to stp-srt-inp-040.
       stp-srt-inp-020.
      *                  *---------------------------------------------*
      *                  * Tipo selezione : Per Agente/Cliente         *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "GT"                 to   f-cfr                  .
           move      "DATCHS    "         to   f-key                  .
           move      rr-dat-rif           to   rf-sdb-dat-chs         .
           move      zero                 to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
           go to     stp-srt-inp-080.
       stp-srt-inp-040.
      *                  *---------------------------------------------*
      *                  * Tipo selezione : Per Cliente                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda che sia stato ri-  *
      *                      * chiesto un cliente o tutti              *
      *                      *-----------------------------------------*
           if        rr-cod-cli           not  = zero
                     go to stp-srt-inp-042
           else      go to stp-srt-inp-044.
       stp-srt-inp-042.
      *                      *-----------------------------------------*
      *                      * Se richiesto un solo cliente            *
      *                      *-----------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DBTDTS    "         to   f-key                  .
           move      01                   to   rf-sdb-tip-dbt         .
           move      rr-cod-cli           to   rf-sdb-cod-dbt         .
           move      zero                 to   rf-sdb-dts-sdb         .
           move      zero                 to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
           go to     stp-srt-inp-080.
       stp-srt-inp-044.
      *                      *-----------------------------------------*
      *                      * Se richiesto per tutti i clienti        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Stessa Start che per agente         *
      *                          *-------------------------------------*
           go to     stp-srt-inp-020.
       stp-srt-inp-080.
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-800.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [sdb]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo selezione   *
      *                  *---------------------------------------------*
           if        rr-tip-sel           =    01
                     go to stp-srt-inp-120
           else if   rr-tip-sel           =    02
                     go to stp-srt-inp-140.
       stp-srt-inp-120.
      *                  *---------------------------------------------*
      *                  * Tipo selezione : Per Agente/Cliente         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Nessun test                             *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-140.
      *                  *---------------------------------------------*
      *                  * Tipo selezione : Per Cliente                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda che sia stato ri-  *
      *                      * chiesto un cliente o tutti              *
      *                      *-----------------------------------------*
           if        rr-cod-cli           not  = zero
                     go to stp-srt-inp-142
           else      go to stp-srt-inp-144.
       stp-srt-inp-142.
      *                      *-----------------------------------------*
      *                      * Se richiesto un solo cliente            *
      *                      *-----------------------------------------*
           if        rf-sdb-tip-dbt       not  = 01 or
                     rf-sdb-cod-dbt       not  = rr-cod-cli
                     go to stp-srt-inp-800.
       stp-srt-inp-144.
      *                      *-----------------------------------------*
      *                      * Se richiesto per tutti i clienti        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Nessun test                         *
      *                          *-------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Selezioni sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dcc]                      *
      *                  *---------------------------------------------*
           if        rf-sdb-dpz-dbt       =    spaces
                     move  "C"            to   w-let-arc-dcc-tle
           else      move  "D"            to   w-let-arc-dcc-tle      .
           move      rf-sdb-cod-dbt       to   w-let-arc-dcc-cod      .
           move      rf-sdb-dpz-dbt       to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo selezione   *
      *                  *---------------------------------------------*
           if        rr-tip-sel           =    01
                     go to stp-srt-inp-220
           else if   rr-tip-sel           =    02
                     go to stp-srt-inp-240.
       stp-srt-inp-220.
      *                  *---------------------------------------------*
      *                  * Tipo selezione : Per Agente/Cliente         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da effettuare                   *
      *                      *-----------------------------------------*
           if        rr-cod-age           =    zero
                     go to stp-srt-inp-300.
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-let-arc-dcc-age    not  = rr-cod-age
                     go to stp-srt-inp-100.
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-300.
       stp-srt-inp-240.
      *                  *---------------------------------------------*
      *                  * Tipo selezione : Per Cliente                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da effettuare                   *
      *                      *-----------------------------------------*
           if        rr-cod-cli           =    zero
                     go to stp-srt-inp-300.
      *                      *-----------------------------------------*
      *                      * Test su codice cliente                  *
      *                      *-----------------------------------------*
           if        rf-sdb-cod-dbt       not  = rr-cod-cli
                     go to stp-srt-inp-100.
      *                      *-----------------------------------------*
      *                      * Test su dipendenza del cliente          *
      *                      *-----------------------------------------*
           if        rr-dpz-cli           =    "*   "
                     go to stp-srt-inp-300.
           if        rf-sdb-dpz-dbt       not  = rr-dpz-cli
                     go to stp-srt-inp-100.
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-300.
       stp-srt-inp-300.
      *                  *---------------------------------------------*
      *                  * Selezioni su anagrafica controllo crediti   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura record [ccc]                    *
      *                      *-----------------------------------------*
           move      rf-sdb-cod-dbt       to   w-let-arc-ccc-cod      .
           perform   let-arc-ccc-000      thru let-arc-ccc-999        .
      *                      *-----------------------------------------*
      *                      * Test se cliente con sollecito           *
      *                      *-----------------------------------------*
           if        w-let-arc-ccc-ems    =    99
                     go to stp-srt-inp-100.
       stp-srt-inp-350.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [age]                      *
      *                  *---------------------------------------------*
           move      w-let-arc-dcc-age    to   w-let-arc-age-cod      .
           perform   let-arc-age-000      thru let-arc-age-999        .
      *                  *---------------------------------------------*
      *                  * Selezioni su record [sdb]                   *
      *                  *---------------------------------------------*
           perform   sel-rec-sdb-000      thru sel-rec-sdb-999        .
           if        w-sel-rec-sdb-flg    not  = spaces
                     go to stp-srt-inp-100.
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Aggiornamento buffer clienti da stampare        *
      *              *-------------------------------------------------*
           perform   stp-srt-inp-bcs-000  thru stp-srt-inp-bcs-999    .
       stp-srt-inp-500.
      *              *-------------------------------------------------*
      *              * Composizione record di sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Chiave nr. 1                                *
      *                  *---------------------------------------------*
           move      rf-sdb-cod-dbt       to   srt-cod-cli            .
           move      rf-sdb-inl-sdb       to   srt-inl-sdb            .
           if        rf-sdb-inl-sdb       =    03
                     move  rf-sdb-dpz-dbt to   srt-dpc-key
           else      move  spaces         to   srt-dpc-key            .
      *                  *---------------------------------------------*
      *                  * Chiave nr. 2                                *
      *                  *---------------------------------------------*
           move      w-let-arc-dcc-age    to   srt-cod-age            .
           move      rf-sdb-dat-ddr       to   srt-dat-ddr            .
           move      rf-sdb-num-ddr       to   srt-num-ddr            .
           move      rf-sdb-tip-ddr       to   srt-tip-ddr            .
           move      rf-sdb-dts-sdb       to   srt-dts-sdb            .
      *                  *---------------------------------------------*
      *                  * Dati                                        *
      *                  *---------------------------------------------*
           move      rf-sdb-dpz-dbt       to   srt-dpz-cli            .
           move      w-let-arc-ccc-ems    to   srt-emi-slc            .
           move      w-let-arc-ccc-tts    to   srt-tdt-slc            .
           move      w-let-arc-ccc-ts1    to   srt-tso-l01            .
           move      w-let-arc-ccc-ts2    to   srt-tso-l02            .
           move      w-let-arc-ccc-ts3    to   srt-tso-l03            .
           move      rf-sdb-num-sdb       to   srt-num-sdb            .
           move      rf-sdb-liv-slc       to   srt-liv-slc            .
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-600.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale record [sdb]     *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-100.
       stp-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Eventuale ciclo di scansione su saldo cliente   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        rr-snx-deb           not  = 02
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * Scansione saldi cliente                     *
      *                  *---------------------------------------------*
           perform   stp-srt-inp-css-000  thru stp-srt-inp-css-999    .
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Trattamento buffer clienti da stampare                    *
      *    *-----------------------------------------------------------*
       stp-srt-inp-bcs-000.
      *              *-------------------------------------------------*
      *              * Test su data scadenza min e max                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Comodo per selezione                        *
      *                  *---------------------------------------------*
           move      rf-sdb-dts-sdb       to   w-sel-rec-dts-sdb      .
      *                  *---------------------------------------------*
      *                  * Eventuali scadenze a vista                  *
      *                  *---------------------------------------------*
           if        rf-sdb-dts-sdb       =    zero
                     move  rf-sdb-dat-ddr to   w-sel-rec-dts-sdb      .
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        rr-dts-min           not  = zero and
                     w-sel-rec-dts-sdb    not  = zero and
                     w-sel-rec-dts-sdb    <    rr-dts-min
                     go to stp-srt-inp-bcs-900.
           if        rr-dts-max           not  = zero and
                     w-sel-rec-dts-sdb    not  = zero and
                     w-sel-rec-dts-sdb    >    rr-dts-max
                     go to stp-srt-inp-bcs-900.
       stp-srt-inp-bcs-100.
      *              *-------------------------------------------------*
      *              * Test su registrazione insoluto min e max        *
      *              *-------------------------------------------------*
           if        rf-sdb-tip-sdb       =    01 or
                     rf-sdb-tip-sdb       =    07 or
                     rf-sdb-tip-sdb       =    08
                     go to stp-srt-inp-bcs-200.
           if        rr-dri-min           not  = zero and
                     w-det-srd-sdb-dro    not  = zero and
                     w-det-srd-sdb-dro    <    rr-dri-min
                     go to stp-srt-inp-bcs-900.
           if        rr-dri-max           not  = zero and
                     w-det-srd-sdb-dro    not  = zero and
                     w-det-srd-sdb-dro    >    rr-dri-max
                     go to stp-srt-inp-bcs-900.
       stp-srt-inp-bcs-200.
      *              *-------------------------------------------------*
      *              * Test su segnale di esclusione                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se nessuna esclusione scadenze              *
      *                  *---------------------------------------------*
           if        rr-esc-csi           =    01
                     go to stp-srt-inp-bcs-600.
      *                  *---------------------------------------------*
      *                  * Se esclusione clienti con solo insoluti     *
      *                  *---------------------------------------------*
           if        rr-esc-csi           not  = 02
                     go to stp-srt-inp-bcs-300.
           if        w-det-srd-sdb-suo    =    "ISP"
                     go to stp-srt-inp-bcs-900
           else      go to stp-srt-inp-bcs-600.
       stp-srt-inp-bcs-300.
      *                  *---------------------------------------------*
      *                  * Se solo clienti con insoluti                *
      *                  *---------------------------------------------*
           if        w-det-srd-sdb-suo    =    "ISP"
                     go to stp-srt-inp-bcs-600
           else      go to stp-srt-inp-bcs-900.
       stp-srt-inp-bcs-600.
      *              *-------------------------------------------------*
      *              * Aggiornamento file di appoggio                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura file di appoggio [kk0]              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Composizione chiave                     *
      *                      *-----------------------------------------*
           move      rf-sdb-cod-dbt       to   kk0-cod-cli            .
           move      rf-sdb-dpz-dbt       to   kk0-dpz-cli            .
      *                      *-----------------------------------------*
      *                      * Lettura                                 *
      *                      *-----------------------------------------*
           read      kk0    key is  kk0-key
                            invalid key
                            go to stp-srt-inp-bcs-800.
       stp-srt-inp-bcs-700.
      *                  *---------------------------------------------*
      *                  * Se record trovato                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-bcs-900.
       stp-srt-inp-bcs-800.
      *                  *---------------------------------------------*
      *                  * Se record non trovato                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Preparazione record [kk0]               *
      *                      *-----------------------------------------*
           move      rf-sdb-cod-dbt       to   kk0-cod-cli            .
           move      rf-sdb-dpz-dbt       to   kk0-dpz-cli            .
           move      spaces               to   kk0-flg-stp            .
      *                      *-----------------------------------------*
      *                      * Scrittura file [kk0]                    *
      *                      *-----------------------------------------*
           write     kk0-rec                                          .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-bcs-900.
       stp-srt-inp-bcs-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-bcs-999.
       stp-srt-inp-bcs-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Ciclo di scansione saldi cliente                          *
      *    *-----------------------------------------------------------*
       stp-srt-inp-css-000.
      *              *-------------------------------------------------*
      *              * Start su file [kk0]                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Composizione chiave                         *
      *                  *---------------------------------------------*
           move      zero                 to   kk0-cod-cli            .
           move      spaces               to   kk0-dpz-cli            .
      *                  *---------------------------------------------*
      *                  * Operazione di Start                         *
      *                  *---------------------------------------------*
           start     kk0    key not less
                            kk0-key
                            invalid key
                            go to stp-srt-inp-css-900.
       stp-srt-inp-css-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file di appoggio [kk0]      *
      *              *-------------------------------------------------*
           read      kk0    next
                            with no lock
                            at end
                            go to stp-srt-inp-css-900.
       stp-srt-inp-css-300.
      *              *-------------------------------------------------*
      *              * Test-max su record [kk0]                        *
      *              *-------------------------------------------------*
       stp-srt-inp-css-400.
      *              *-------------------------------------------------*
      *              * Selezione su record [kk0]                       *
      *              *-------------------------------------------------*
       stp-srt-inp-css-500.
      *              *-------------------------------------------------*
      *              * Determinazione saldo cliente                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           move      kk0-cod-cli          to   w-det-sdo-gep-cli      .
           move      kk0-dpz-cli          to   w-det-sdo-gep-dpz      .
           perform   det-sdo-gep-000      thru det-sdo-gep-999        .
      *                  *---------------------------------------------*
      *                  * Test su saldo determinato                   *
      *                  *---------------------------------------------*
           if        w-det-sdo-gep-sdo    >    zero
                     go to stp-srt-inp-css-800.
      *                  *---------------------------------------------*
      *                  * Aggiornamento flag di stampa                *
      *                  *---------------------------------------------*
           move      "#"                  to   kk0-flg-stp            .
      *                  *---------------------------------------------*
      *                  * Scrittura dati aggiornati                   *
      *                  *---------------------------------------------*
           rewrite   kk0-rec                                          .
       stp-srt-inp-css-800.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-css-200.
       stp-srt-inp-css-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-css-999.
       stp-srt-inp-css-999.
           exit.

      *    *===========================================================*
      *    * Selezioni su record [sdb]                                 *
      *    *-----------------------------------------------------------*
       sel-rec-sdb-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-sel-rec-sdb-flg      .
      *              *-------------------------------------------------*
      *              * Se dilazione concordata: selezione non superata *
      *              *-------------------------------------------------*
           if        rf-sdb-tip-sdb       =    01 and
                     rf-sdb-snx-dlc       =    "S"
                     go to sel-rec-sdb-900.
       sel-rec-sdb-010.
      *              *-------------------------------------------------*
      *              * Eventuale selezione su date scadenza            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Comodo per selezione                        *
      *                  *---------------------------------------------*
           move      rf-sdb-dts-sdb       to   w-sel-rec-dts-sdb      .
      *                  *---------------------------------------------*
      *                  * Eventuali scadenze a vista                  *
      *                  *---------------------------------------------*
           if        rf-sdb-dts-sdb       =    zero
                     move  rf-sdb-dat-ddr to   w-sel-rec-dts-sdb      .
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        rr-dts-min           not  = zero and
                     w-sel-rec-dts-sdb    not  = zero and
                     w-sel-rec-dts-sdb    <    rr-dts-min
                     go to sel-rec-sdb-900.
           if        rr-dts-max           not  = zero and
                     w-sel-rec-dts-sdb    not  = zero and
                     w-sel-rec-dts-sdb    >    rr-dts-max
                     go to sel-rec-sdb-900.
       sel-rec-sdb-020.
      *              *-------------------------------------------------*
      *              * Determinazione status scadenza                  *
      *              *-------------------------------------------------*
           move      rr-dat-rif           to   w-det-srd-sdb-drd      .
           perform   det-srd-sdb-000      thru det-srd-sdb-999        .
      *              *-------------------------------------------------*
      *              * Test se scadenza ancora aperta                  *
      *              *-------------------------------------------------*
           if        w-det-srd-sdb-sts    not  = "A"
                     go to sel-rec-sdb-900.
       sel-rec-sdb-030.
       sel-rec-sdb-080.
      *              *-------------------------------------------------*
      *              * Test se sigla ultima operazione eseguita e' a   *
      *              * spazi                                           *
      *              *-------------------------------------------------*
           if        w-det-srd-sdb-suo    =    spaces
                     go to sel-rec-sdb-900.
       sel-rec-sdb-100.
      *              *-------------------------------------------------*
      *              * Test su ultima operazione effettuata sulla sca- *
      *              * denza                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo scadenza    *
      *                  *---------------------------------------------*
           go to     sel-rec-sdb-101
                     sel-rec-sdb-102
                     sel-rec-sdb-103
                     sel-rec-sdb-104
                     sel-rec-sdb-105
                     sel-rec-sdb-106
                     sel-rec-sdb-107
                     sel-rec-sdb-108
                     sel-rec-sdb-109
                     sel-rec-sdb-110
                     sel-rec-sdb-111
                     depending            on rf-sdb-tip-sdb           .
           go to     sel-rec-sdb-900.
       sel-rec-sdb-101.
      *                  *---------------------------------------------*
      *                  * Tipo scadenza : Rimessa diretta             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deve essere solo emessa                 *
      *                      *-----------------------------------------*
           if        w-det-srd-sdb-suo    not  = "EMI"
                     go to sel-rec-sdb-900.
           go to     sel-rec-sdb-200.
       sel-rec-sdb-102.
      *                  *---------------------------------------------*
      *                  * Tipo scadenza : Incasso elettronico         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Puo' essere solo insoluto               *
      *                      *-----------------------------------------*
           if        w-det-srd-sdb-suo    not  = "ISP"
                     go to sel-rec-sdb-900.
           go to     sel-rec-sdb-200.
       sel-rec-sdb-103.
      *                  *---------------------------------------------*
      *                  * Tipo scadenza : Ri.Ba.                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Puo' essere solo insoluto               *
      *                      *-----------------------------------------*
           if        w-det-srd-sdb-suo    not  = "ISP"
                     go to sel-rec-sdb-900.
           go to     sel-rec-sdb-200.
       sel-rec-sdb-104.
      *                  *---------------------------------------------*
      *                  * Tipo scadenza : C.d.O.                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Puo' essere solo insoluto               *
      *                      *-----------------------------------------*
           if        w-det-srd-sdb-suo    not  = "ISP"
                     go to sel-rec-sdb-900.
           go to     sel-rec-sdb-200.
       sel-rec-sdb-105.
      *                  *---------------------------------------------*
      *                  * Tipo scadenza : M.Av.                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Puo' essere solo insoluto               *
      *                      *-----------------------------------------*
           if        w-det-srd-sdb-suo    not  = "ISP"
                     go to sel-rec-sdb-900.
           go to     sel-rec-sdb-200.
       sel-rec-sdb-106.
      *                  *---------------------------------------------*
      *                  * Tipo scadenza : R.I.D.                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Puo' essere solo insoluto               *
      *                      *-----------------------------------------*
           if        w-det-srd-sdb-suo    not  = "ISP"
                     go to sel-rec-sdb-900.
           go to     sel-rec-sdb-200.
       sel-rec-sdb-107.
      *                  *---------------------------------------------*
      *                  * Tipo scadenza : Bonifico bancario           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deve essere solo emessa                 *
      *                      *-----------------------------------------*
           if        w-det-srd-sdb-suo    not  = "EMI"
                     go to sel-rec-sdb-900.
           go to     sel-rec-sdb-200.
       sel-rec-sdb-108.
      *                  *---------------------------------------------*
      *                  * Tipo scadenza : C/C postale                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deve essere solo emessa                 *
      *                      *-----------------------------------------*
           if        w-det-srd-sdb-suo    not  = "EMI"
                     go to sel-rec-sdb-900.
           go to     sel-rec-sdb-200.
       sel-rec-sdb-109.
      *                  *---------------------------------------------*
      *                  * Tipo scadenza : Ricevuta bancaria           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Puo' essere solo insoluto               *
      *                      *-----------------------------------------*
           if        w-det-srd-sdb-suo    not  = "ISP"
                     go to sel-rec-sdb-900.
           go to     sel-rec-sdb-200.
       sel-rec-sdb-110.
      *                  *---------------------------------------------*
      *                  * Tipo scadenza : Tratta                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Puo' essere solo insoluto               *
      *                      *-----------------------------------------*
           if        w-det-srd-sdb-suo    not  = "ISP"
                     go to sel-rec-sdb-900.
           go to     sel-rec-sdb-200.
       sel-rec-sdb-111.
      *                  *---------------------------------------------*
      *                  * Tipo scadenza : Paghero' cambiario          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Puo' essere solo insoluto               *
      *                      *-----------------------------------------*
           if        w-det-srd-sdb-suo    not  = "ISP"
                     go to sel-rec-sdb-900.
           go to     sel-rec-sdb-200.
       sel-rec-sdb-200.
      *              *-------------------------------------------------*
      *              * Se scadenza insoluta : a selezione superata     *
      *              *-------------------------------------------------*
           if        w-det-srd-sdb-suo    =    "ISP"
                     go to sel-rec-sdb-800.
      *              *-------------------------------------------------*
      *              * Determinazione numero giorni di ritardo ammessi *
      *              *-------------------------------------------------*
           if        rf-sdb-tip-sdb       =    01
                     move  w-prs-ngg-scd-rim
                                          to   w-sel-rec-sdb-ngr
           else if   rf-sdb-tip-sdb       =    07
                     move  w-prs-ngg-scd-bon
                                          to   w-sel-rec-sdb-ngr
           else if   rf-sdb-tip-sdb       =    08
                     move  w-prs-ngg-scd-ccp
                                          to   w-sel-rec-sdb-ngr      .
      *              *-------------------------------------------------*
      *              * Se numero giorni di ritardo ammessi pari a 99,  *
      *              * selezione non superata                          *
      *              *-------------------------------------------------*
           if        w-sel-rec-sdb-ngr    =    99
                     go to sel-rec-sdb-900.
      *              *-------------------------------------------------*
      *              * Determinazione data scadenza comprensiva del    *
      *              * numero giorni di ritardo ammessi                *
      *              *-------------------------------------------------*
           if        rf-sdb-dts-sdb       =    zero
                     move  rf-sdb-dtr-emi to   w-det-dat-mng-dti
           else      move  rf-sdb-dts-sdb to   w-det-dat-mng-dti      .
           move      w-sel-rec-sdb-ngr    to   w-det-dat-mng-ngi      .
           perform   det-dat-mng-000      thru det-dat-mng-999        .
      *              *-------------------------------------------------*
      *              * Se la data cosi' determinata non e' inferiore   *
      *              * alla data di riferimento : selezione non supe-  *
      *              * rata                                            *
      *              *-------------------------------------------------*
           if        w-det-dat-mng-dto    not  < rr-dat-rif
                     go to sel-rec-sdb-900.
       sel-rec-sdb-800.
      *              *-------------------------------------------------*
      *              * Uscita per selezione superata                   *
      *              *-------------------------------------------------*
           go to     sel-rec-sdb-999.
       sel-rec-sdb-900.
      *              *-------------------------------------------------*
      *              * Uscita per selezione non superata               *
      *              *-------------------------------------------------*
           move      "#"                  to   w-sel-rec-sdb-flg      .
       sel-rec-sdb-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Start iniziale                     *
      *    *-----------------------------------------------------------*
       prn-str-ini-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
      *              *-------------------------------------------------*
      *              * Normalizzazioni                                 *
      *              *-------------------------------------------------*
           move      zero                 to   w-prn-rot-cli          .
           move      zero                 to   w-prn-num-cli          .
           move      zero                 to   w-prn-tot-slc          .
       prn-str-ini-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Messaggio per nessuna registraz.   *
      *    *-----------------------------------------------------------*
       prn-nes-ela-000.
           move      "WR"                 to   m-ope                  .
           move      "Nessun sollecito da trattare entro i limiti assegn
      -              "ati!"
                                          to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       prn-nes-ela-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Lettura sequenziale                *
      *    *-----------------------------------------------------------*
       prn-let-seq-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale archivio sortato [srt]      *
      *              *-------------------------------------------------*
           return    srt    at end
                            move  "#"     to   w-cnt-prn-flg-sub
                            go to prn-let-seq-999.
       prn-let-seq-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Test se superamento limiti massimi *
      *    *-----------------------------------------------------------*
       prn-tst-max-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
       prn-tst-max-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Selezione su record letto          *
      *    *-----------------------------------------------------------*
       prn-sel-rec-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
       prn-sel-rec-100.
      *              *-------------------------------------------------*
      *              * Test se cliente da stampare                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se rottura cliente                          *
      *                  *---------------------------------------------*
           if        srt-cod-cli          =    w-prn-rot-cli
                     go to prn-sel-rec-200.
      *                      *-----------------------------------------*
      *                      * Aggiornamento area rottura cliente      *
      *                      *-----------------------------------------*
           move      srt-cod-cli          to   w-prn-rot-cli          .
      *                      *-----------------------------------------*
      *                      * Chiave [kk0]                           *
      *                      *-----------------------------------------*
           move      srt-cod-cli          to   kk0-cod-cli            .
           move      srt-dpz-cli          to   kk0-dpz-cli            .
      *                      *-----------------------------------------*
      *                      * Lettura [kk0]                           *
      *                      *-----------------------------------------*
           read      kk0    key is  kk0-key
                            invalid key
                            go to prn-sel-rec-140.
       prn-sel-rec-120.
      *                  *---------------------------------------------*
      *                  * Se record trovato                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test del flag di cliente da stampare    *
      *                      * contenuto nel record [kk0]              *
      *                      *                                         *
      *                      * Se il flag e' non spaces, ci si compor- *
      *                      * ta come per cliente da non stampare     *
      *                      *-----------------------------------------*
           if        kk0-flg-stp          =    "#"
                     go to prn-sel-rec-140.
      *                      *-----------------------------------------*
      *                      * Set del flag di cliente da stampare     *
      *                      *-----------------------------------------*
           move      "#"                  to   w-prn-flg-cds          .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     prn-sel-rec-200.
       prn-sel-rec-140.
      *                  *---------------------------------------------*
      *                  * Se record non trovato                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione flag di cliente da      *
      *                      * stampare                                *
      *                      *-----------------------------------------*
           move      spaces               to   w-prn-flg-cds          .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     prn-sel-rec-200.
       prn-sel-rec-200.
      *                  *---------------------------------------------*
      *                  * Se non rottura cliente                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su flag di cliente da stampare     *
      *                      *-----------------------------------------*
           if        w-prn-flg-cds        =    spaces
                     move  "#"            to   w-cnt-prn-flg-sub      .
       prn-sel-rec-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Composizione area per rotture      *
      *    *-----------------------------------------------------------*
       prn-cmp-rot-000.
           move      srt-cod-cli          to   w-rot-l02-cod-cli      .
           move      srt-inl-sdb          to   w-rot-l01-inl-sdb      .
           move      srt-dpc-key          to   w-rot-l01-dpc-key      .
       prn-cmp-rot-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Esecuzione per inizio ciclo        *
      *    *-----------------------------------------------------------*
       prn-ini-cic-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
       prn-ini-cic-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Esecuzione per fine ciclo          *
      *    *-----------------------------------------------------------*
       prn-fin-cic-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
      *              *-------------------------------------------------*
      *              * Aggiornamento numerazione [lotslc]              *
      *              *-------------------------------------------------*
           perform   agg-lot-slc-000      thru agg-lot-slc-999        .
      *              *-------------------------------------------------*
      *              * Editing contatore clienti                       *
      *              *-------------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-prn-num-cli        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Messaggio di fine esecuzione                    *
      *              *-------------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      spaces               to   m-msg                  .
           string    "Selezionati "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " clienti"
                                delimited by   size
                                          into m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
           move      m-msg                to   w-prn-msg-bt1          .
      *              *-------------------------------------------------*
      *              * Editing totale solleciti                        *
      *              *-------------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-prn-tot-slc        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Messaggio di fine esecuzione                    *
      *              *-------------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      spaces               to   m-msg                  .
           string    "per "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " solleciti"
                                delimited by   size
                                          into m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
           move      m-msg                to   w-prn-msg-bt2          .
       prn-fin-cic-300.
      *              *-------------------------------------------------*
      *              * Eventuali forzature per batch                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su flag                                *
      *                  *---------------------------------------------*
           if        rr-snx-btc           not  = "S"
                     go to prn-fin-cic-999.
      *                  *---------------------------------------------*
      *                  * Messaggi di fine esecuzione                 *
      *                  *---------------------------------------------*
           display   w-prn-msg-bt1                                    .
           display   w-prn-msg-bt2                                    .
       prn-fin-cic-999.
           exit.

      *    *===========================================================*
      *    * Routine di aggiornamento numerazione [lotslc]             *
      *    *-----------------------------------------------------------*
       agg-lot-slc-000.
      *              *-------------------------------------------------*
      *              * Ottenimento record [lotslc]                     *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/inlotslc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-lot-slc             .
