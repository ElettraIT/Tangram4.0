      *              *-------------------------------------------------*
           move      w-det-str-lod-dat    to   w-det-str-lod-wdt      .
      *              *-------------------------------------------------*
      *              * Preparazione giorno                             *
      *              *-------------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      02                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      w-det-str-lod-wgg    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-det-str-lod-wge      .
      *              *-------------------------------------------------*
      *              * Preparazione anno                               *
      *              *-------------------------------------------------*
           move      w-det-str-lod-wsa    to   w-det-str-lod-wae      .
           add       1900                 to   w-det-str-lod-wae      .
      *              *-------------------------------------------------*
      *              * Determinazione localita'                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione valore                      *
      *                  *---------------------------------------------*
           move      spaces               to   w-det-str-lod-wlo
      *                  *---------------------------------------------*
      *                  * Test se contenuta in referenza              *
      *                  *---------------------------------------------*
           if        w-ref-den-loc        not  = spaces
                     move  w-ref-den-loc  to   w-det-str-lod-wlo
                     go to det-str-lod-100.
      *                  *---------------------------------------------*
      *                  * Scomposizione localita' da [ada]            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione [ada]                   *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/azi/fls/ioc/obj/iofada"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ada                 .
      *                      *-----------------------------------------*
      *                      * Lettura [ada] dati anagrafici Sede      *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODDPZ    "         to   f-key                  .
           move      zero                 to   rf-ada-cod-dpz         .
           move      "pgm/azi/fls/ioc/obj/iofada"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ada                 .
      *                      *-----------------------------------------*
      *                      * Richiamo routine di scomposizione       *
      *                      *-----------------------------------------*
           move      rf-ada-loc-azi       to   w-scm-loc-ccp-loc      .
           perform   scm-loc-ccp-000      thru scm-loc-ccp-999        .
           move      w-scm-loc-ccp-cit    to   w-det-str-lod-wlo      .
       det-str-lod-100.
      *              *-------------------------------------------------*
      *              * Preparazione stringa                            *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-str-lod-str      .
           move      1                    to   w-det-str-lod-pnt      .
      *                  *---------------------------------------------*
      *                  * Localita'                                   *
      *                  *---------------------------------------------*
           string    w-det-str-lod-wlo
                                delimited by   size
                                          into w-det-str-lod-str
                                  with pointer w-det-str-lod-pnt      .
      *                  *---------------------------------------------*
      *                  * Concatenamento ','                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione ultimo non-blank         *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-str-lod-pnt      .
           inspect   w-det-str-lod-str
                                      tallying w-det-str-lod-pnt
                                          for  trailing spaces        .
           subtract  60                   from w-det-str-lod-pnt      .
           add       1                    to   w-det-str-lod-pnt      .
      *                      *-----------------------------------------*
      *                      * Se localita' a spazi : oltre            *
      *                      *-----------------------------------------*
           if        w-det-str-lod-str    =    spaces
                     go to det-str-lod-120.
      *                      *-----------------------------------------*
      *                      * String                                  *
      *                      *-----------------------------------------*
           string    ", "
                                delimited by   size
                                          into w-det-str-lod-str
                                  with pointer w-det-str-lod-pnt      .
       det-str-lod-120.
      *                  *---------------------------------------------*
      *                  * Giorno                                      *
      *                  *---------------------------------------------*
           string    w-det-str-lod-wge
                                delimited by   spaces
                                          into w-det-str-lod-str
                                  with pointer w-det-str-lod-pnt      .
      *                  *---------------------------------------------*
      *                  * Literal del mese, da segreteria             *
      *                  *---------------------------------------------*
           move      "LM"                 to   s-ope                  .
           move      "E"                  to   s-tip                  .
           move      w-det-str-lod-wmm    to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Mese                                        *
      *                  *---------------------------------------------*
           string    " "
                                delimited by   size
                     s-alf      delimited by   spaces
                                          into w-det-str-lod-str
                                  with pointer w-det-str-lod-pnt      .
      *                  *---------------------------------------------*
      *                  * Anno                                        *
      *                  *---------------------------------------------*
           string    " "
                                delimited by   size
                     w-det-str-lod-wae
                                delimited by   spaces
                                          into w-det-str-lod-str
                                  with pointer w-det-str-lod-pnt      .
       det-str-lod-999.
           exit.

