           move      1                    to   w-stp-rie-slc-nrn      .
      *                      *-----------------------------------------*
      *                      * Riga per importi scaduti                *
      *                      *-----------------------------------------*
           add       1                    to   w-stp-rie-slc-nrn      .
      *                      *-----------------------------------------*
      *                      * Riga per interessi                      *
      *                      *-----------------------------------------*
           if        w-slc-tot-int        not  = zero
                     add   1              to   w-stp-rie-slc-nrn      .
      *                      *-----------------------------------------*
      *                      * Riga per spese                          *
      *                      *-----------------------------------------*
           if        w-slc-tot-spe        not  = zero
                     add   1              to   w-stp-rie-slc-nrn      .
      *                      *-----------------------------------------*
      *                      * Riga per iva su spese                   *
      *                      *-----------------------------------------*
           if       (w-slc-tot-spe        not  = zero  ) and
                    (w-slc-civ-ads        >    00000 and
                     w-slc-civ-ads        <    00100   )
                     add   1              to   w-stp-rie-slc-nrn      .
      *                      *-----------------------------------------*
      *                      * Due righe per totale                    *
      *                      *-----------------------------------------*
           add       2                    to   w-stp-rie-slc-nrn      .
      *                  *---------------------------------------------*
      *                  * Test se righe residue sufficienti           *
      *                  *---------------------------------------------*
