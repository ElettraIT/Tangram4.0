      *    *===========================================================*
      *    * Routine per calcoli ed operazioni su date                 *
      *    *-----------------------------------------------------------*
       clc-ope-dat-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
           move      zero                 to   w-clc-dat-nrg          .
           move      w-clc-dat-min        to   w-clc-dat-ng0          .
      *              *-------------------------------------------------*
      *              * Test preliminari                                *
      *              *-------------------------------------------------*
           if        w-clc-dat-max        not  > w-clc-dat-min
                     go to clc-ope-dat-999.
       clc-ope-dat-100.
      *              *-------------------------------------------------*
      *              * Ciclo                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Incremento                                  *
      *                  *---------------------------------------------*
           add       1                    to   w-clc-dat-nrg          .
           move      w-clc-dat-ng0        to   w-det-dat-nrg-dtb      .
           move      1                    to   w-det-dat-nrg-ngi      .
           perform   det-dat-nrg-000      thru det-dat-nrg-999        .
           move      w-det-dat-nrg-dti    to   w-clc-dat-ng0          .
           if        w-clc-dat-ng0        =    w-clc-dat-max
                     go to clc-ope-dat-999.
           go to     clc-ope-dat-100.
       clc-ope-dat-999.
           exit.

