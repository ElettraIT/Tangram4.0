      *    *===========================================================*
      *    * Routine di calcolo importo interessi                      *
      *    *-----------------------------------------------------------*
       cal-imp-int-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore in output                *
      *              *-------------------------------------------------*
           move      zero                 to   w-cal-imp-int-imi      .
      *              *-------------------------------------------------*
      *              * Controllo ammissibilita' valori in input        *
      *              *-------------------------------------------------*
           if        w-cal-imp-int-tdi    =    zero or
                     w-cal-imp-int-imm    =    zero or
                     w-cal-imp-int-nrg    =    zero
                     go to cal-imp-int-999.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo applicazione    *
      *              * interessi personalizzata                        *
      *              *-------------------------------------------------*
           if        w-cal-imp-int-tap    =    01
                     go to cal-imp-int-100
           else      go to cal-imp-int-999.
       cal-imp-int-100.
      *              *-------------------------------------------------*
      *              * Tipo applicazione interessi : Standard          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Calcolo                                     *
      *                  *---------------------------------------------*
           divide    100                  into w-cal-imp-int-tdi
                                        giving w-cal-imp-int-w01      .
           multiply  w-cal-imp-int-imm    by   w-cal-imp-int-w01      .
           divide    365                  into w-cal-imp-int-w01
                                               rounded                .
           multiply  w-cal-imp-int-nrg    by   w-cal-imp-int-w01
                                        giving w-cal-imp-int-imi      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     cal-imp-int-999.
       cal-imp-int-999.
           exit.

      *    *===========================================================*
      *    * Scomposizione di una localita' in Cap, Citta', Provincia  *
      *    *-----------------------------------------------------------*
       scm-loc-ccp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valori in output                *
      *              *-------------------------------------------------*
           move      zero                 to   w-scm-loc-ccp-cap      .
           move      spaces               to   w-scm-loc-ccp-cit      .
           move      spaces               to   w-scm-loc-ccp-prv      .
      *              *-------------------------------------------------*
      *              * Se valore in input a spaces : uscita            *
      *              *-------------------------------------------------*
           if        w-scm-loc-ccp-loc    =    spaces
                     go to scm-loc-ccp-999.
      *              *-------------------------------------------------*
      *              * Valore in input in work di comodo               *
      *              *-------------------------------------------------*
           move      w-scm-loc-ccp-loc    to   w-scm-loc-ccp-wlc      .
       scm-loc-ccp-100.
      *              *-------------------------------------------------*
      *              * Identificazione Cap                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se Cap corretto                        *
      *                  *---------------------------------------------*
           if        w-scm-loc-ccp-w15    not  numeric  or
                     w-scm-loc-ccp-w66    not  = spaces
                     go to scm-loc-ccp-120
           else      go to scm-loc-ccp-140.
       scm-loc-ccp-120.
      *                  *---------------------------------------------*
      *                  * Se Cap non corretto                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     scm-loc-ccp-200.
       scm-loc-ccp-140.
      *                  *---------------------------------------------*
      *                  * Se Cap corretto                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione Cap                     *
      *                      *-----------------------------------------*
           move      w-scm-loc-ccp-w15    to   w-scm-loc-ccp-cap      .
      *                      *-----------------------------------------*
      *                      * Preparazione nuova work di lavoro       *
      *                      *-----------------------------------------*
           move      w-scm-loc-ccp-loc
                    (7 : 34)              to   w-scm-loc-ccp-wlc      .
           go to     scm-loc-ccp-200.
       scm-loc-ccp-200.
      *              *-------------------------------------------------*
      *              * Identificazione Provincia                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-scm-loc-ccp-c01      .
           inspect   w-scm-loc-ccp-wlc
                                      tallying w-scm-loc-ccp-c01
                                  for trailing spaces                 .
           move      40                   to   w-scm-loc-ccp-c02      .
           subtract  w-scm-loc-ccp-c01    from w-scm-loc-ccp-c02      .
      *                  *---------------------------------------------*
      *                  * Se provincia non identificabile : oltre     *
      *                  *---------------------------------------------*
           if        w-scm-loc-ccp-c02    <    4
                     go to scm-loc-ccp-300.
           subtract  2                    from w-scm-loc-ccp-c02      .
           if        w-scm-loc-ccp-wlc
                    (w-scm-loc-ccp-c02 : 1)
                                          not  = spaces
                     go to scm-loc-ccp-300.
           add       1                    to   w-scm-loc-ccp-c02      .
           if        w-scm-loc-ccp-wlc
                    (w-scm-loc-ccp-c02 : 1)
                                          =    spaces
                     go to scm-loc-ccp-300.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione Provincia                   *
      *                  *---------------------------------------------*
           move      w-scm-loc-ccp-wlc
                    (w-scm-loc-ccp-c02 : 2)
                                          to   w-scm-loc-ccp-prv      .
      *                  *---------------------------------------------*
      *                  * Eliminazione Provincia                      *
      *                  *---------------------------------------------*
           move      spaces               to   w-scm-loc-ccp-wlc
                                              (w-scm-loc-ccp-c02 : 2) .
       scm-loc-ccp-300.
      *              *-------------------------------------------------*
      *              * Identificazione Citta'                          *
      *              *-------------------------------------------------*
           move      w-scm-loc-ccp-wlc    to   w-scm-loc-ccp-cit      .
       scm-loc-ccp-999.
           exit.

