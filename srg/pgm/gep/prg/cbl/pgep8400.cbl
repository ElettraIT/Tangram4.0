      *    *===========================================================*
      *    * Accettazione campo testata : Livello di sollecito         *
      *    *-----------------------------------------------------------*
       acc-liv-slc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-ems-aac (1)    not  = 99
                     go to acc-liv-slc-050.
           move      zero                 to   w-tes-liv-slc (1)      .
           perform   vis-liv-slc-000      thru vis-liv-slc-999        .
           go to     acc-liv-slc-400.
       acc-liv-slc-050.
      *                  *---------------------------------------------*
      *                  * Note operative a piede video                *
      *                  *---------------------------------------------*
           move      "NT"                 to   v-ope                  .
           move      "Nota: Porre il livello a zero se si intende esclud
      -              "ere completamente la stampa   "
                                          to   v-nt1                  .
           move      "      del sollecito per il cliente.               
      -              "                              "
                                          to   v-nt2                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-liv-slc-075.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-liv-slc (1)    to   w-sav-liv-slc          .
       acc-liv-slc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      14                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "9"                  to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      w-tes-liv-slc (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Cancellazione note operative a piede video      *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           move      spaces               to   v-nt1                  .
           move      spaces               to   v-nt2                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-liv-slc-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-liv-slc-999.
       acc-liv-slc-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-liv-slc (1)      .
       acc-liv-slc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su valore massimo personalizzato       *
      *                  *---------------------------------------------*
           if        w-tes-liv-slc (1)    >    w-prs-max-liv
                     go to acc-liv-slc-100.
      *                  *---------------------------------------------*
      *                  * Test su valore massimo per il cliente       *
      *                  *---------------------------------------------*
           if        w-tes-ems-aac (1)    =    zero
                     go to acc-liv-slc-600.
           if        w-tes-liv-slc (1)    not  > w-tes-ems-aac (1)
                     go to acc-liv-slc-600.
           move      "Livello di sollecito non accettabile per il client
      -              "e !            "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-liv-slc-100.
       acc-liv-slc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-liv-slc (1)    =    w-sav-liv-slc
                     go to acc-liv-slc-800.
      *                  *---------------------------------------------*
      *                  * Trattamento codice sollecito                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se livello a zero : normalizzazione co- *
      *                      * dice sollecito                          *
      *                      *-----------------------------------------*
           if        w-tes-liv-slc (1)    =    zero
                     move  zero           to   w-tes-cod-tso (1)
                     go to acc-liv-slc-700.
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo testo   *
      *                      * associato al cliente                    *
      *                      *-----------------------------------------*
           if        w-tes-tts-aac (1)    =    zero
                     go to acc-liv-slc-610
           else if   w-tes-tts-aac (1)    =    01
                     go to acc-liv-slc-620
           else if   w-tes-tts-aac (1)    =    02
                     go to acc-liv-slc-630
           else if   w-tes-tts-aac (1)    =    03
                     go to acc-liv-slc-640
           else if   w-tes-tts-aac (1)    =    99
                     go to acc-liv-slc-650.
       acc-liv-slc-610.
      *                      *-----------------------------------------*
      *                      * Tipo di testo : Standard                *
      *                      *-----------------------------------------*
           if        w-tes-liv-slc (1)    =    01
                     move  w-ref-tso-std-l01
                                          to   w-tes-cod-tso (1)
           else if   w-tes-liv-slc (1)    =    02
                     move  w-ref-tso-std-l02
                                          to   w-tes-cod-tso (1)
           else if   w-tes-liv-slc (1)    =    03
                     move  w-ref-tso-std-l03
                                          to   w-tes-cod-tso (1)      .
           go to     acc-liv-slc-700.
       acc-liv-slc-620.
      *                      *-----------------------------------------*
      *                      * Tipo di testo : Sempre testo di livello *
      *                      * 1                                       *
      *                      *-----------------------------------------*
           move      w-ref-tso-std-l01    to   w-tes-cod-tso (1)      .
           go to     acc-liv-slc-700.
       acc-liv-slc-630.
      *                      *-----------------------------------------*
      *                      * Tipo di testo : Sempre testo di livello *
      *                      * 2                                       *
      *                      *-----------------------------------------*
           move      w-ref-tso-std-l02    to   w-tes-cod-tso (1)      .
           go to     acc-liv-slc-700.
       acc-liv-slc-640.
      *                      *-----------------------------------------*
      *                      * Tipo di testo : Sempre testo di livello *
      *                      * 3                                       *
      *                      *-----------------------------------------*
           move      w-ref-tso-std-l03    to   w-tes-cod-tso (1)      .
           go to     acc-liv-slc-700.
       acc-liv-slc-650.
      *                      *-----------------------------------------*
      *                      * Tipo di testo : Personalizzato          *
      *                      *-----------------------------------------*
           if        w-tes-liv-slc (1)    =    01
                     move  w-tes-ts1-aac (1)
                                          to   w-tes-cod-tso (1)
           else if   w-tes-liv-slc (1)    =    02
                     move  w-tes-ts2-aac (1)
                                          to   w-tes-cod-tso (1)
           else if   w-tes-liv-slc (1)    =    03
                     move  w-tes-ts3-aac (1)
                                          to   w-tes-cod-tso (1)      .
           go to     acc-liv-slc-700.
       acc-liv-slc-700.
      *                      *-----------------------------------------*
      *                      * Lettura record [zso]                    *
      *                      *-----------------------------------------*
           move      w-tes-cod-tso (1)    to   w-let-arc-zso-cod      .
           perform   let-arc-zso-000      thru let-arc-zso-999        .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione             *
      *                      *-----------------------------------------*
           move      w-let-arc-zso-des    to   w-tes-cod-tso-des (1)  .
      *                      *-----------------------------------------*
      *                      * Visualizzazione codice e descrizione    *
      *                      *-----------------------------------------*
           perform   vis-cod-tso-000      thru vis-cod-tso-999        .
           perform   vis-cod-tso-des-000  thru vis-cod-tso-des-999    .
       acc-liv-slc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-liv-slc-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-liv-slc-100.
       acc-liv-slc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Livello di sollecito      *
      *    *-----------------------------------------------------------*
       vis-liv-slc-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      14                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "9"                  to   v-edm                  .
           move      w-tes-liv-slc (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-liv-slc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice tipo sollecito                *
      *    *-----------------------------------------------------------*
       acc-cod-tso-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-liv-slc (1)    =    zero
                     go to acc-cod-tso-999.
           if        w-tes-ems-aac (1)    =    99
                     go to acc-cod-tso-999.
       acc-cod-tso-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zso-ope      .
           move      w-tes-cod-tso (1)    to   w-cod-mne-zso-cod      .
           move      18                   to   w-cod-mne-zso-lin      .
           move      30                   to   w-cod-mne-zso-pos      .
           move      18                   to   w-cod-mne-zso-dln      .
           move      41                   to   w-cod-mne-zso-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   cod-mne-zso-cll-000  thru cod-mne-zso-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zso-foi-000  thru cod-mne-zso-foi-999    .
       acc-cod-tso-110.
           perform   cod-mne-zso-cll-000  thru cod-mne-zso-cll-999    .
           if        w-cod-mne-zso-ope    =    "F+"
                     go to acc-cod-tso-115.
           if        w-cod-mne-zso-ope    =    "AC"
                     go to acc-cod-tso-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-tso-115.
           perform   cod-mne-zso-foi-000  thru cod-mne-zso-foi-999    .
           go to     acc-cod-tso-110.
       acc-cod-tso-120.
           move      w-cod-mne-zso-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-tso-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-tso-999.
       acc-cod-tso-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-tso (1)      .
       acc-cod-tso-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella [zso]                       *
      *                  *---------------------------------------------*
           move      w-tes-cod-tso (1)    to   w-let-arc-zso-cod      .
           perform   let-arc-zso-000      thru let-arc-zso-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-zso-des    to   w-tes-cod-tso-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-cod-tso-des-000  thru vis-cod-tso-des-999    .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-zso-flg    not  = spaces
                     go to acc-cod-tso-100.
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-tes-cod-tso (1)    not  = zero
                     go to acc-cod-tso-600.
           if        v-key                =    "UP  "
                     go to acc-cod-tso-600
           else      go to acc-cod-tso-100.
       acc-cod-tso-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-tso-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-tso-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-tso-100.
       acc-cod-tso-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice tipo sollecito             *
      *    *-----------------------------------------------------------*
       vis-cod-tso-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      18                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-tso (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-tso-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice tipo sollecito, descrizio- *
      *    *                         ne                                *
      *    *-----------------------------------------------------------*
       vis-cod-tso-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-tso-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-tso-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione corpo a partire dalla riga con numero d'or-  *
      *    * dine : w-cnt-cor-nrg-dac                                  *
      *    *-----------------------------------------------------------*
       acc-cor-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione tipo uscita da corpo            *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-cor      .
      *              *-------------------------------------------------*
      *              * Confronto tra numero d'ordine riga da accettare *
      *              * e numero d'ordine dell'ultima riga              *
      *              *-------------------------------------------------*
           if        w-cnt-cor-nrg-dac    not  > w-cat-rig-max
                     go to acc-cor-reg-025.
      *              *-------------------------------------------------*
      *              * Se oltre numero riga massimo si esce con status *
      *              * di uscita "+"                                   *
      *              *-------------------------------------------------*
           move      "+"                  to   w-cnt-tus-acc-cor      .
           go to     acc-cor-reg-990.
       acc-cor-reg-025.
      *              *-------------------------------------------------*
      *              * Video in 'OFF'                                  *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Prompts per corpo                               *
      *              *-------------------------------------------------*
           if        w-cnt-sts-pmt-cor    =    spaces
                     perform pmt-cor-reg-000
                                          thru pmt-cor-reg-999
                     move    "#"          to   w-cnt-sts-pmt-cor      .
      *              *-------------------------------------------------*
      *              * Visualizzazione dati corpo                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione nr pagina da visualizzare    *
      *                  *---------------------------------------------*
           move      w-cnt-cor-nrg-dac    to   w-cnt-cor-nrp-dav      .
           add       w-lin-num-lin-vis    to   w-cnt-cor-nrp-dav      .
           subtract  1                    from w-cnt-cor-nrp-dav      .
           divide    w-lin-num-lin-vis    into w-cnt-cor-nrp-dav      .
      *                  *---------------------------------------------*
      *                  * Se non e' visualizzata nessuna pagina corpo *
      *                  * o una pagina corpo diversa da quella da vi- *
      *                  * sualizzare si procede alla visualizzazione  *
      *                  *---------------------------------------------*
           if        w-cnt-sts-vis-cor    =    spaces           or
                     w-cnt-cor-nrp-vis    not  = w-cnt-cor-nrp-dav
                     perform vis-cor-reg-000
                                          thru vis-cor-reg-999
                     move    "#"          to   w-cnt-sts-vis-cor
                     move    w-cnt-cor-nrp-dav
                                          to   w-cnt-cor-nrp-vis      .
      *              *-------------------------------------------------*
      *              * Lettura riga da catena                          *
      *              *-------------------------------------------------*
           move      "RD"                 to   w-cat-rig-ope          .
           move      w-cnt-cor-nrg-dac    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se riga nuova si normalizza il corpo            *
      *              *-------------------------------------------------*
