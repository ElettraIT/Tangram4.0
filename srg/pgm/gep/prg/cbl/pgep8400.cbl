           move      w-tes-cod-cli        to   rf-scr-cod-cli         .
           move      w-tes-num-slc        to   rf-scr-num-slc         .
           move      w-scr-mov-fil-prg    to   rf-scr-num-prg         .
           move      srt-num-sdb          to   rf-scr-num-sdb         .
           move      srt-sel-sdb          to   rf-scr-sel-sdb         .
