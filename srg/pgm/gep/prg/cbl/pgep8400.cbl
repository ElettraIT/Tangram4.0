           perform   fnd-sdb-iis-000      thru fnd-sdb-iis-999        .
      *                  *---------------------------------------------*
      *                  * Se selezione non effettuata : a reimposta-  *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           if        w-fnd-sdb-iis-sel    not  = spaces
                     go to acc-num-sdb-100.
      *                  *---------------------------------------------*
      *                  * Numero scadenza selezionata in campo di de- *
      *                  * stinazione                                  *
      *                  *---------------------------------------------*
           move      w-fnd-sdb-iis-num    to   w-rig-num-sdb (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione numero scadenza selezionata *
      *                  *---------------------------------------------*
           perform   vis-num-sdb-000      thru vis-num-sdb-999        .
      *                  *---------------------------------------------*
      *                  * Normalizzazione function-key di impostazio- *
      *                  * ne                                          *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Continuazione post-impostazione             *
      *                  *---------------------------------------------*
           go to     acc-num-sdb-400.
       acc-num-sdb-250.
      *              *-------------------------------------------------*
      *              * Se Expd                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "EXPD"
                     go to acc-num-sdb-300.
      *                  *---------------------------------------------*
      *                  * Espansione su scadenze debitori             *
      *                  *---------------------------------------------*
           if        w-rig-num-sdb (1)    =    zero
                     move  "S"            to   w-esp-arc-sdb-sns
           else      move  "N"            to   w-esp-arc-sdb-sns      .
           move      v-num                to   w-esp-arc-sdb-num      .
           perform   esp-arc-sdb-000      thru esp-arc-sdb-999        .
      *                  *---------------------------------------------*
      *                  * Se selezione non effettuata : a reimposta-  *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           if        w-esp-arc-sdb-sel    not  = spaces
                     go to acc-num-sdb-100.
      *                  *---------------------------------------------*
      *                  * Ripresa numero scadenza selezionata         *
      *                  *---------------------------------------------*
           move      w-esp-arc-sdb-num    to   w-rig-num-sdb (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione numero scadenza selezionata *
      *                  *---------------------------------------------*
           perform   vis-num-sdb-000      thru vis-num-sdb-999        .
      *                  *---------------------------------------------*
      *                  * Normalizzazione function-key di impostazio- *
      *                  * ne                                          *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Continuazione post-impostazione             *
      *                  *---------------------------------------------*
           go to     acc-num-sdb-400.
       acc-num-sdb-300.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-num-sdb (1)      .
       acc-num-sdb-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura scadenza in archivio [sdb]          *
      *                  *---------------------------------------------*
           move      w-rig-num-sdb (1)    to   w-let-arc-sdb-num      .
           perform   let-arc-sdb-000      thru let-arc-sdb-999        .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        w-let-arc-sdb-flg    =    spaces
                     go to acc-num-sdb-420.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Numero scadenza non esistente in archivio scadenze
      -              " !             "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-num-sdb-100.
       acc-num-sdb-420.
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso                   *
      *                  *---------------------------------------------*
           if        w-rig-num-sdb (1)    =    zero
                     go to acc-num-sdb-100.
      *                  *---------------------------------------------*
      *                  * Selezioni bloccanti su record [sdb]         *
      *                  *---------------------------------------------*
           perform   sel-sdb-blo-000      thru sel-sdb-blo-999        .
           if        w-sel-sdb-blo-flg    =    zero
                     go to acc-num-sdb-440.
      *                      *-----------------------------------------*
      *                      * Box di errore per selezioni bloccanti   *
      *                      *-----------------------------------------*
           perform   acc-num-sdb-bsb-000  thru acc-num-sdb-bsb-999    .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-num-sdb-100.
       acc-num-sdb-440.
      *                  *---------------------------------------------*
      *                  * Composizione riga della catena              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo scadenza debitore                  *
      *                      *-----------------------------------------*
           move      rf-sdb-tip-sdb       to   w-rig-tip-sdb (1)      .
      *                      *-----------------------------------------*
      *                      * Tipo documento di riferimento           *
      *                      *-----------------------------------------*
           move      rf-sdb-tip-ddr       to   w-rig-tip-ddr (1)      .
      *                      *-----------------------------------------*
      *                      * Numero documento di riferimento         *
      *                      *-----------------------------------------*
           move      rf-sdb-num-ddr       to   w-rig-num-ddr (1)      .
      *                      *-----------------------------------------*
      *                      * Data documento di riferimento           *
      *                      *-----------------------------------------*
           move      rf-sdb-dat-ddr       to   w-rig-dat-ddr (1)      .
      *                      *-----------------------------------------*
      *                      * Data scadenza                           *
      *                      *-----------------------------------------*
           move      rf-sdb-dts-sdb       to   w-rig-dts-sdb (1)      .
      *                      *-----------------------------------------*
      *                      * Importo scadenza                        *
      *                      *-----------------------------------------*
           move      rf-sdb-imp-sdb       to   w-rig-imp-sdb (1)      .
      *                      *-----------------------------------------*
      *                      * Selezione scadenza                      *
      *                      *-----------------------------------------*
           move      01                   to   w-rig-sel-sdb (1)      .
      *                      *-----------------------------------------*
      *                      * Data sollecito 1                        *
      *                      *-----------------------------------------*
           move      rf-sdb-dso-l01       to   w-rig-dso-l01 (1)      .
      *                      *-----------------------------------------*
      *                      * Data sollecito 2                        *
      *                      *-----------------------------------------*
           move      rf-sdb-dso-l02       to   w-rig-dso-l02 (1)      .
      *                      *-----------------------------------------*
      *                      * Data sollecito 3                        *
      *                      *-----------------------------------------*
           move      rf-sdb-dso-l03       to   w-rig-dso-l03 (1)      .
       acc-num-sdb-500.
      *                  *---------------------------------------------*
      *                  * Controllo che la scadenza non faccia gia'   *
      *                  * parte dell'operazione in corso              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Salvataggio numero scadenza             *
      *                      *-----------------------------------------*
           move      w-rig-num-sdb (1)    to   w-sav-num-sdb          .
      *                      *-----------------------------------------*
      *                      * Salvataggio area w-rig                  *
      *                      *-----------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *                      *-----------------------------------------*
      *                      * Salvataggio area catena                 *
      *                      *-----------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *                      *-----------------------------------------*
      *                      * Start su catena per primo movimento     *
      *                      *-----------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       acc-num-sdb-520.
      *                      *-----------------------------------------*
      *                      * Lettura sequenziale catena              *
      *                      *-----------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                      *-----------------------------------------*
      *                      * Se fine catena                          *
      *                      *-----------------------------------------*
           if        w-cat-rig-exs        =    spaces
                     go to acc-num-sdb-560.
      *                          *-------------------------------------*
      *                          * Ripristino area catena              *
      *                          *-------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
      *                          *-------------------------------------*
      *                          * Ripristino area w-rig               *
      *                          *-------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *                          *-------------------------------------*
      *                          * A fine controlli                    *
      *                          *-------------------------------------*
           go to     acc-num-sdb-600.
       acc-num-sdb-560.
      *                      *-----------------------------------------*
      *                      * Se non fine catena                      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Movimento da buffer catena a w-rig  *
      *                          *-------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *                          *-------------------------------------*
      *                          * Se numero scadenza a zero si ignora *
      *                          * il record e si passa a leggere il   *
      *                          * successivo                          *
      *                          *-------------------------------------*
           if        w-rig-num-sdb (1)    =    zero
                     go to acc-num-sdb-520.
      *                          *-------------------------------------*
      *                          * Se numero scadenza diverso da quel- *
      *                          * lo in esame si ignora il record e   *
      *                          * si passa a leggere il successivo    *
      *                          *-------------------------------------*
           if        w-rig-num-sdb (1)    not  = w-sav-num-sdb
                     go to acc-num-sdb-520.
      *                          *-------------------------------------*
      *                          * Altrimenti : errore                 *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Ripristino area catena          *
      *                              *---------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
      *                              *---------------------------------*
      *                              * Ripristino area w-rig           *
      *                              *---------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *                              *---------------------------------*
      *                              * Emissione messaggio di errore   *
      *                              *---------------------------------*
           move      "Scadenza gia' presente nel sollecito in corso di t
      -              "rattamento     "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                              *---------------------------------*
      *                              * A reimpostazione                *
      *                              *---------------------------------*
           go to     acc-num-sdb-100.
       acc-num-sdb-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Attivazione flag di non-incremento numero   *
      *                  * riga da accettare                           *
      *                  *---------------------------------------------*
           move      "#"                  to   w-acc-cor-reg-fni      .
       acc-num-sdb-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
       acc-num-sdb-900.
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-num-sdb-999.
           exit.

      *    *===========================================================*
      *    * Selezioni bloccanti su record [sdb]                       *
      *    *                                                           *
      *    * Input  :                                                  *
      *    *                                                           *
      *    *  - Area w-tes e record [sdb] da esaminare                 *
      *    *                                                           *
      *    * Output :                                                  *
      *    *                                                           *
      *    *  - w-sel-sdb-blo-flg : Flag fondamentale di uscita        *
      *    *    - 00 : Selezione superata                              *
      *    *    - nn : Selezione non superata, con causa codice nn     *
      *    *           - 10 : Tipo e codice cliente diverso da quello  *
      *    *                  in corso di trattamento                  *
      *    *           - 11 : Inoltro scadenza non compatibile         *
      *    *           - 12 : Codice dipendenza del cliente non compa- *
      *    *                  tibile                                   *
      *    *           - 13 : Tipo scadenza non riconosciuto           *
      *    *           - 14 : Tipo valuta della scadenza non ammissi-  *
      *    *                  bile per la registrazione in corso       *
      *    *           - 15 : Status scadenza indicante scadenza non   *
      *    *                  sollecitabile                            *
      *    *           - 16 : Segno scadenza errato                    *
      *    *           - 17 : La scadenza e' bloccata                  *
      *    *           - 18 : La scadenza e' in fase di pulizia        *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       sel-sdb-blo-000.
      *              *-------------------------------------------------*
      *              * Selezione su tipo e codice cliente              *
      *              *-------------------------------------------------*
           if        rf-sdb-tip-dbt       =    01 and
                     rf-sdb-cod-dbt       =    w-tes-cod-cli
                     go to sel-sdb-blo-100.
           move      10                   to   w-sel-sdb-blo-flg      .
           move      "Codice cliente diverso da quello in corso di tratt
      -              "amento         "    to   w-sel-sdb-blo-err      .
           go to     sel-sdb-blo-999.
       sel-sdb-blo-100.
      *              *-------------------------------------------------*
      *              * Selezione su inoltro scadenza                   *
      *              *-------------------------------------------------*
           if        rf-sdb-inl-sdb       =    w-tes-inl-slc (1)
                     go to sel-sdb-blo-200.
           move      11                   to   w-sel-sdb-blo-flg      .
           move      "Inoltro scadenza non compatibile con l'inoltro sol
      -              "lecito         "    to   w-sel-sdb-blo-err      .
           go to     sel-sdb-blo-999.
       sel-sdb-blo-200.
      *              *-------------------------------------------------*
      *              * Selezione su dipendenza cliente                 *
      *              *-------------------------------------------------*
           if        w-tes-inl-slc (1)    not  = 03
                     go to sel-sdb-blo-300.
           if        rf-sdb-dpz-dbt       =    w-tes-dpc-key (1)
                     go to sel-sdb-blo-300.
           move      12                   to   w-sel-sdb-blo-flg      .
           move      "Codice dipendenza del cliente incompatibile       
      -              "               "    to   w-sel-sdb-blo-err      .
           go to     sel-sdb-blo-999.
       sel-sdb-blo-300.
      *              *-------------------------------------------------*
      *              * Selezione su tipo scadenza, che sia riconosciu- *
      *              * to                                              *
      *              *-------------------------------------------------*
           if        rf-sdb-tip-sdb       =    01 or
                     rf-sdb-tip-sdb       =    02 or
                     rf-sdb-tip-sdb       =    03 or
                     rf-sdb-tip-sdb       =    04 or
                     rf-sdb-tip-sdb       =    05 or
                     rf-sdb-tip-sdb       =    06 or
                     rf-sdb-tip-sdb       =    07 or
                     rf-sdb-tip-sdb       =    08 or
                     rf-sdb-tip-sdb       =    09 or
                     rf-sdb-tip-sdb       =    10 or
                     rf-sdb-tip-sdb       =    11
                     go to sel-sdb-blo-400.
           move      13                   to   w-sel-sdb-blo-flg      .
           move      "Tipo scadenza non riconosciuto                    
      -              "               "    to   w-sel-sdb-blo-err      .
           go to     sel-sdb-blo-999.
       sel-sdb-blo-400.
      *              *-------------------------------------------------*
      *              * Selezione su tipo valuta, che sia compatibile   *
      *              *-------------------------------------------------*
           if        rf-sdb-tvl-sdb       =    01
                     go to sel-sdb-blo-500.
           move      14                   to   w-sel-sdb-blo-flg      .
           move      "Tipo valuta per la scadenza incompatibile         
      -              "               "    to   w-sel-sdb-blo-err      .
           go to     sel-sdb-blo-999.
       sel-sdb-blo-500.
      *              *-------------------------------------------------*
      *              * Selezione su status della scadenza              *
      *              *-------------------------------------------------*
           move      w-num-dat-rif        to   w-det-srd-sdb-drd      .
           perform   det-srd-sdb-000      thru det-srd-sdb-999        .
           if        w-det-srd-sdb-sts    =    "A"
                     go to sel-sdb-blo-600.
           move      15                   to   w-sel-sdb-blo-flg      .
           move      "Scadenza non sottoponibile a sollecito            
      -              "               "    to   w-sel-sdb-blo-err      .
           go to     sel-sdb-blo-999.
       sel-sdb-blo-600.
      *              *-------------------------------------------------*
      *              * Selezione sul segno dell'importo scadenza       *
      *              *-------------------------------------------------*
           if        rf-sdb-tip-ddr       =    11 or
                     rf-sdb-tip-ddr       =    21
                     if    rf-sdb-imp-sdb <    zero
                           go to sel-sdb-blo-700
                     else  go to sel-sdb-blo-620
           else      if    rf-sdb-imp-sdb >    zero
                           go to sel-sdb-blo-700
                     else  go to sel-sdb-blo-620.
       sel-sdb-blo-620.
           move      16                   to   w-sel-sdb-blo-flg      .
           move      "Segno dell'importo scadenza errato                
      -              "               "    to   w-sel-sdb-blo-err      .
           go to     sel-sdb-blo-999.
       sel-sdb-blo-700.
      *              *-------------------------------------------------*
      *              * Selezione su flag bloccanti                     *
      *              *-------------------------------------------------*
           if        rf-sdb-flg-blo       =    spaces
                     go to sel-sdb-blo-800.
           move      17                   to   w-sel-sdb-blo-flg      .
           move      "La scadenza e' stata sottoposta ad elaborazioni   
      -              "               "    to   w-sel-sdb-blo-err      .
           go to     sel-sdb-blo-999.
       sel-sdb-blo-800.
      *              *-------------------------------------------------*
      *              * Selezione su flag di pulizia                    *
      *              *-------------------------------------------------*
           if        rf-sdb-flg-pul       =    spaces
                     go to sel-sdb-blo-900.
           move      18                   to   w-sel-sdb-blo-flg      .
           move      "La scadenza e' in corso di eliminazione           
      -              "               "    to   w-sel-sdb-blo-err      .
           go to     sel-sdb-blo-999.
       sel-sdb-blo-900.
      *              *-------------------------------------------------*
      *              * Selezione superata                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-sel-sdb-blo-flg      .
           move      spaces               to   w-sel-sdb-blo-err      .
       sel-sdb-blo-999.
           exit.

      *    *===========================================================*
      *    * Box per messaggio su selezioni record [sdb] bloccanti     *
      *    *-----------------------------------------------------------*
       acc-num-sdb-bsb-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      10                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      19                   to   v-lto                  .
           move      80                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Premessa fissa                                  *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      76                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      03                   to   v-pos                  .
           move      "                             A T T E N Z I O N E  
      -              "                          "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      76                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      03                   to   v-pos                  .
           move      "La scadenza selezionata non puo' essere inclusa ne
      -              "l sollecito in corso      "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Motivazione                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Prompt                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      03                   to   v-pos                  .
           move      "Motivo  : "         to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Valore                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      13                   to   v-pos                  .
           move      w-sel-sdb-blo-err    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Parentesi quadre di delimitazione               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      76                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      18                   to   v-lin                  .
           move      77                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-num-sdb-bsb-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Numero scadenza debitore          *
      *    *-----------------------------------------------------------*
       vis-num-sdb-000.
           move      "DS"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      16                   to   v-lin                  .
           move      47                   to   v-pos                  .
           move      w-rig-num-sdb (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-num-sdb-999.
           exit.

      *    *===========================================================*
      *    * Box per messaggio di errore                               *
      *    *-----------------------------------------------------------*
       box-msg-err-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      12                   to   v-lin                  .
           move      04                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      77                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
