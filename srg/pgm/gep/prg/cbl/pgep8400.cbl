           move      "V"                  to   v-tip                  .
           if        w-rig-imp-sdb (1)    >    999999999 or
                     w-rig-imp-sdb (1)    <   -999999999
                     move  11             to   v-car
                     move  spaces         to   v-edm
           else      move  09             to   v-car
                     move  "G"            to   v-edm                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      w-rig-imp-sdb (1)    to   v-num                  .
