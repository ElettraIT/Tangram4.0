      *                      *-----------------------------------------*
           add       1                    to   w-fnd-sdb-iis-i02      .
      *                      *-----------------------------------------*
      *                      * Memorizzo numero scadenza               *
      *                      *-----------------------------------------*
           move      w-rig-num-sdb (1)    to   w-fnd-sdb-iis-wrn
                                              (w-fnd-sdb-iis-i02)     .
      *                      *-----------------------------------------*
      *                      * Se non e' l'ultimo elemento si ricicla  *
      *                      * a leggere la riga successiva della ca-  *
      *                      * tena                                    *
      *                      *-----------------------------------------*
           if        w-fnd-sdb-iis-i02    <    7
                     go to fnd-sdb-iis-350.
      *                      *-----------------------------------------*
      *                      * Incremento indice per gruppo di 7 sca-  *
      *                      * denze                                   *
      *                      *-----------------------------------------*
           add       1                    to   w-fnd-sdb-iis-i01      .
      *                      *-----------------------------------------*
      *                      * Scrittura variabile di i.p.c. per il    *
      *                      * gruppo di 7 scadenze                    *
      *                      *-----------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "nsd-eds"            to   w-fnd-sdb-iis-wn0      .
           move      w-fnd-sdb-iis-i01    to   w-fnd-sdb-iis-wn9      .
           move      w-fnd-sdb-iis-wnv    to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      80                   to   s-car                  .
           move      w-fnd-sdb-iis-wrl    to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Inizializzazione indice 1..7 per gruppo *
      *                      * di numeri scadenza                      *
      *                      *-----------------------------------------*
           move      zero                 to   w-fnd-sdb-iis-i02      .
      *                      *-----------------------------------------*
      *                      * Riciclo su riga successiva dalla catena *
      *                      *-----------------------------------------*
           go to     fnd-sdb-iis-350.
       fnd-sdb-iis-355.
      *                      *-----------------------------------------*
      *                      * Se l' indice 1..7 per gruppo di numeri  *
      *                      * scadenza e' a zero : no scrittura del   *
      *                      * record finale in sospeso                *
      *                      *-----------------------------------------*
           if        w-fnd-sdb-iis-i02    =    zero
                     go to fnd-sdb-iis-360.
      *                      *-----------------------------------------*
      *                      * Incremento indice per gruppo di 7 sca-  *
      *                      * denze                                   *
      *                      *-----------------------------------------*
           add       1                    to   w-fnd-sdb-iis-i01      .
      *                      *-----------------------------------------*
      *                      * Scrittura variabile di i.p.c. per il    *
      *                      * gruppo di 7 scadenze                    *
      *                      *-----------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "nsd-eds"            to   w-fnd-sdb-iis-wn0      .
           move      w-fnd-sdb-iis-i01    to   w-fnd-sdb-iis-wn9      .
           move      w-fnd-sdb-iis-wnv    to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      80                   to   s-car                  .
           move      w-fnd-sdb-iis-wrl    to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       fnd-sdb-iis-360.
      *                      *-----------------------------------------*
      *                      * Ripristino area catena                  *
      *                      *-----------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
      *                      *-----------------------------------------*
      *                      * Ripristino area w-rig                   *
      *                      *-----------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
       fnd-sdb-iis-400.
      *              *-------------------------------------------------*
      *              * Richiamo del programma di interrogazione        *
      *              *-------------------------------------------------*
           move      "pgm/gep/prg/obj/pgep3010"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
       fnd-sdb-iis-450.
      *              *-------------------------------------------------*
      *              * Cancellazione del programma di interrogazione   *
      *              *-------------------------------------------------*
           cancel    s-pat                                            .
       fnd-sdb-iis-500.
      *              *-------------------------------------------------*
      *              * Determinazione selezione avvenuta               *
      *              *-------------------------------------------------*
       fnd-sdb-iis-505.
      *                  *---------------------------------------------*
      *                  * Lettura variabile di i.p.c. 'num-sdb' dal   *
      *                  * livello successivo per numero scadenza se-  *
      *                  * lezionato                                   *
      *                  *---------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "num-sdb"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'esito della let-  *
      *                  * tura                                        *
      *                  *---------------------------------------------*
           if        s-ves                =    spaces
                     go to fnd-sdb-iis-510
           else      go to fnd-sdb-iis-515.
       fnd-sdb-iis-510.
      *                  *---------------------------------------------*
      *                  * Se variabile esistente                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di selezione avvenuta              *
      *                      *-----------------------------------------*
           move      spaces               to   w-fnd-sdb-iis-sel      .
      *                      *-----------------------------------------*
      *                      * Numero scadenza selezionata             *
      *                      *-----------------------------------------*
           move      s-num                to   w-fnd-sdb-iis-num      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     fnd-sdb-iis-999.
       fnd-sdb-iis-515.
      *                  *---------------------------------------------*
      *                  * Se variabile non esistente                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     fnd-sdb-iis-999.
       fnd-sdb-iis-999.
           exit.

