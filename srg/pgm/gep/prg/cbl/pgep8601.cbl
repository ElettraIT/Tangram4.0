      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-120.
      *              *-------------------------------------------------*
      *              * Test max                                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se programma chiamato                  *
      *                  *---------------------------------------------*
           if        rr-num-slc           =    zero
                     go to stp-srt-inp-130.
      *                  *---------------------------------------------*
      *                  * Test su codice cliente                      *
      *                  *---------------------------------------------*
           if        rf-sct-cod-cli       not  = rr-cod-cli
                     go to stp-srt-inp-999.
      *                  *---------------------------------------------*
      *                  * Test su numero sollecito                    *
      *                  *---------------------------------------------*
           if        rf-sct-num-slc       not  = rr-num-slc
                     go to stp-srt-inp-999.
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-180.
       stp-srt-inp-130.
      *              *-------------------------------------------------*
      *              * Selezione sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo ordinamento *
      *                  *---------------------------------------------*
           if        rr-tip-ord           =    01
                     go to stp-srt-inp-140
           else if   rr-tip-ord           =    02
                     go to stp-srt-inp-160.
       stp-srt-inp-140.
      *                  *---------------------------------------------*
      *                  * Tipo ordinamento : Per Agente/Cliente       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se codice agente a zero : riciclo       *
      *                      *-----------------------------------------*
           if        rf-sct-cod-age       =    zero
                     go to stp-srt-inp-100.
      *                      *-----------------------------------------*
      *                      * Test su codice agente                   *
      *                      *-----------------------------------------*
           if        rr-cod-age           =    zero
                     go to stp-srt-inp-142.
           if        rf-sct-cod-age       not  = rr-cod-age
                     go to stp-srt-inp-100.
       stp-srt-inp-142.
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-180.
       stp-srt-inp-160.
      *                  *---------------------------------------------*
      *                  * Tipo ordinamento : Per Cliente              *
      *                  *---------------------------------------------*
           if        rr-cod-cli           =    zero
                     go to stp-srt-inp-162.
      *                      *-----------------------------------------*
      *                      * Test su codice cliente                  *
      *                      *-----------------------------------------*
           if        rf-sct-cod-cli       not  = rr-cod-cli
                     go to stp-srt-inp-100.
      *                      *-----------------------------------------*
      *                      * Test su codice dipendenza cliente       *
      *                      *-----------------------------------------*
           if        rr-dpz-cli           =    "*   "
                     go to stp-srt-inp-162.
           if        rf-sct-dpz-cli       not  = rr-dpz-cli
                     go to stp-srt-inp-100.
       stp-srt-inp-162.
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-180.
       stp-srt-inp-180.
      *                  *---------------------------------------------*
      *                  * Test se sollecito da inviare                *
      *                  *---------------------------------------------*
           if        rf-sct-liv-slc       =    zero
                     go to stp-srt-inp-100.
       stp-srt-inp-190.
      *                  *---------------------------------------------*
      *                  * Test su numero sollecito da inviare         *
      *                  *---------------------------------------------*
           if        rr-num-slc           =    zero
                     go to stp-srt-inp-200.
           if        rf-sct-num-slc       not  = rr-num-slc
                     go to stp-srt-inp-100.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Lettura archivio [age]                          *
      *              *-------------------------------------------------*
           move      rf-sct-cod-age       to   w-let-arc-age-cod      .
           perform   let-arc-age-000      thru let-arc-age-999        .
       stp-srt-inp-220.
      *              *-------------------------------------------------*
      *              * Determinazione indirizzo di inoltro sollecito   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo inoltro     *
      *                  *---------------------------------------------*
           if        rf-sct-inl-slc       =   01
                     go to stp-srt-inp-221
           else if   rf-sct-inl-slc       =   02
                     go to stp-srt-inp-222
           else if   rf-sct-inl-slc       =   03
                     go to stp-srt-inp-223.
       stp-srt-inp-221.
      *                  *---------------------------------------------*
      *                  * Inoltro sollecito : alla sede               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura record [dcc] principale         *
      *                      *-----------------------------------------*
           move      rf-sct-cod-cli       to   w-let-arc-dcc-cli      .
           move      spaces               to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
           move      w-let-arc-dcc-rsu    to   w-stp-srt-inp-rsu      .
           move      w-let-arc-dcc-rs1    to   w-stp-srt-inp-rs1      .
           move      w-let-arc-dcc-rs2    to   w-stp-srt-inp-rs2      .
           move      w-let-arc-dcc-via    to   w-stp-srt-inp-via      .
           move      w-let-arc-dcc-loc    to   w-stp-srt-inp-loc      .
           go to     stp-srt-inp-300.
       stp-srt-inp-222.
      *                  *---------------------------------------------*
      *                  * Inoltro sollecito : alla sede legale        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura record [cli]                    *
      *                      *-----------------------------------------*
           move      rf-sct-cod-cli       to   w-let-arc-cli-cod      .
           perform   let-arc-cli-000      thru let-arc-cli-999        .
           move      w-let-arc-cli-rsu    to   w-stp-srt-inp-rsu      .
           move      w-let-arc-cli-rag    to   w-stp-srt-inp-rs1      .
           move      spaces               to   w-stp-srt-inp-rs2      .
           move      w-let-arc-cli-via    to   w-stp-srt-inp-via      .
           move      w-let-arc-cli-loc    to   w-stp-srt-inp-loc      .
           go to     stp-srt-inp-300.
       stp-srt-inp-223.
      *                  *---------------------------------------------*
      *                  * Inoltro sollecito : alla dipendenza         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura record [dcc] della dipendenza   *
      *                      *-----------------------------------------*
           move      rf-sct-cod-cli       to   w-let-arc-dcc-cli      .
           move      rf-sct-dpz-cli       to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
           move      w-let-arc-dcc-rsu    to   w-stp-srt-inp-rsu      .
           move      w-let-arc-dcc-rs1    to   w-stp-srt-inp-rs1      .
           move      w-let-arc-dcc-rs2    to   w-stp-srt-inp-rs2      .
           move      w-let-arc-dcc-via    to   w-stp-srt-inp-via      .
           move      w-let-arc-dcc-loc    to   w-stp-srt-inp-loc      .
           go to     stp-srt-inp-300.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Composizione record di sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Chiave del sort                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Dati agente                             *
      *                      *-----------------------------------------*
           if        rr-tip-ord           not  = 01
                     move  spaces         to   srt-kdo-age
                     move  zero           to   srt-cod-age
                     go to stp-srt-inp-310.
           if        rr-ord-age           =    01
                     move  w-let-arc-age-nmu
                                          to   srt-kdo-age
           else if   rr-ord-age           =    02
                     move  spaces         to   srt-kdo-age
           else if   rr-ord-age           =    03
                     move  w-let-arc-age-mne
                                          to   srt-kdo-age            .
           move      w-let-arc-age-cod    to   srt-cod-age            .
       stp-srt-inp-310.
      *                      *-----------------------------------------*
      *                      * Dati cliente                            *
      *                      *-----------------------------------------*
           move      w-stp-srt-inp-rsu    to   srt-rsc-key            .
           move      rf-sct-cod-cli       to   srt-cod-cli            .
           move      rf-sct-inl-slc       to   srt-inl-slc            .
           move      rf-sct-dpc-key       to   srt-dpc-key            .
      *                  *---------------------------------------------*
      *                  * Dati del sort                               *
      *                  *---------------------------------------------*
           move      rf-sct-num-slc       to   srt-num-slc            .
           move      rf-sct-dpz-cli       to   srt-dpz-cli            .
           move      w-stp-srt-inp-rs1    to   srt-inl-rs1            .
           move      w-stp-srt-inp-rs2    to   srt-inl-rs2            .
           move      w-stp-srt-inp-via    to   srt-inl-via            .
           move      w-stp-srt-inp-loc    to   srt-inl-loc            .
           move      w-let-arc-age-nom    to   srt-nom-age            .
           move      rf-sct-liv-slc       to   srt-liv-slc            .
           move      rf-sct-cod-tso       to   srt-cod-tso            .
           move      spaces               to   srt-flg-sdp            .
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale record [sct]     *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-100.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Subroutine di preparazione per stampa sollecito di prova  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-ssp-000.
      *              *-------------------------------------------------*
      *              * Composizione record di sort fittizio            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Chiave del sort                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Dati agente                             *
      *                      *-----------------------------------------*
           move      spaces               to   srt-cod-age            .
           move      zero                 to   srt-cod-age            .
      *                      *-----------------------------------------*
      *                      * Dati cliente                            *
      *                      *-----------------------------------------*
           move      "RAGIONE SOCIALE CLIENTE DI PROVA SOLLEC."
                                          to   srt-rsc-key            .
           move      zero                 to   srt-cod-cli            .
           move      zero                 to   srt-inl-slc            .
           move      spaces               to   srt-dpc-key            .
      *                  *---------------------------------------------*
      *                  * Dati del sort                               *
      *                  *---------------------------------------------*
           move      zero                 to   srt-num-slc            .
           move      spaces               to   srt-dpz-cli            .
           move      "Ragione sociale Cliente di prova sollec."
                                          to   srt-inl-rs1            .
           move      "(Su due righe)                          "
                                          to   srt-inl-rs2            .
           move      "Indirizzo del Cliente di prova          "
                                          to   srt-inl-via            .
           move      "Localita' del Cliente di prova          "
                                          to   srt-inl-loc            .
           move      spaces               to   srt-nom-age            .
           move      zero                 to   srt-liv-slc            .
           move      rr-cod-age           to   srt-cod-tso            .
           move      "#"                  to   srt-flg-sdp            .
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-ssp-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Start iniziale                     *
      *    *-----------------------------------------------------------*
       prn-str-ini-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di primo passaggio         *
      *              *-------------------------------------------------*
           move      spaces               to   w-prn-flg-uno          .
       prn-str-ini-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Messaggio per nessuna registraz.   *
      *    *-----------------------------------------------------------*
       prn-nes-ela-000.
           move      "WR"                 to   m-ope                  .
           move      "Nessun sollecito da stampare entro i limiti assegn
      -              "ati !"
                                          to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       prn-nes-ela-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Lettura sequenziale                *
      *    *-----------------------------------------------------------*
       prn-let-seq-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
      *              *-------------------------------------------------*
      *              * Test su flag di primo passaggio                 *
      *              *-------------------------------------------------*
           if        w-prn-flg-uno        =    spaces
                     move  "#"            to   w-prn-flg-uno
                     go to prn-let-seq-200
           else      go to prn-let-seq-400.
       prn-let-seq-200.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale archivio sortato [srt]      *
      *              *-------------------------------------------------*
           return    srt    at end
                            move  "#"     to   w-cnt-prn-flg-sub
                            go to prn-let-seq-999.
      *              *-------------------------------------------------*
      *              * Lettura record [zso]                            *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODTSO    "         to   f-key                  .
           move      srt-cod-tso          to   rf-zso-cod-tso         .
           move      "pgm/gep/fls/ioc/obj/iofzso"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zso                 .
      *              *-------------------------------------------------*
      *              * Test su esito operazione                        *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to prn-let-seq-200.
       prn-let-seq-300.
      *              *-------------------------------------------------*
      *              * Test se stampa di prova                         *
      *              *-------------------------------------------------*
           if        srt-flg-sdp          =    spaces
                     go to prn-let-seq-350.
      *              *-------------------------------------------------*
      *              * Precablaggio di un record [sdb] per la stampa   *
      *              * di prova                                        *
      *              *-------------------------------------------------*
           perform   stp-let-seq-ssp-000  thru stp-let-seq-ssp-999    .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     prn-let-seq-999.
       prn-let-seq-350.
      *              *-------------------------------------------------*
      *              * Start su file [scr]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CLINMS    "         to   f-key                  .
           move      srt-cod-cli          to   rf-scr-cod-cli         .
           move      srt-num-slc          to   rf-scr-num-slc         .
           move      zero                 to   rf-scr-num-prg         .
           move      "pgm/gep/fls/ioc/obj/iofscr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-scr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to prn-let-seq-200.
       prn-let-seq-400.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [scr]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofscr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-scr                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to prn-let-seq-200.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-scr-cod-cli       not  = srt-cod-cli or
                     rf-scr-num-slc       not  = srt-num-slc
                     go to prn-let-seq-200.
      *              *-------------------------------------------------*
      *              * Selezione sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se scadenza selezionata                *
      *                  *---------------------------------------------*
           if        rf-scr-sel-sdb       not  = 01
                     go to prn-let-seq-400.
      *              *-------------------------------------------------*
      *              * Lettura record [sdb]                            *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMSDB    "         to   f-key                  .
           move      rf-scr-num-sdb       to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to prn-let-seq-400.
       prn-let-seq-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Lettura sequenziale                *
      *    *                                                           *
      *    * Subroutine di preparazione per stampa sollecito di prova  *
      *    *-----------------------------------------------------------*
       stp-let-seq-ssp-000.
      *              *-------------------------------------------------*
      *              * Data di stampa                                  *
      *              *-------------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rr-dat-stp             .
      *              *-------------------------------------------------*
      *              * Normalizzazione record [sdb]                    *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *              *-------------------------------------------------*
      *              * Composizione record [sdb] fittizio              *
      *              *-------------------------------------------------*
           move      01                   to   rf-sdb-tip-ddr         .
           move      9999999              to   rf-sdb-dat-ddr         .
           move      "99999XXXXX"         to   rf-sdb-num-ddr         .
           move      9999999              to   rf-sdb-imp-sdb         .
           move      9999999              to   rf-sdb-imp-ddr         .
           move      02                   to   rf-sdb-tip-sdb         .
           move      01                   to   rf-sdb-nra-ddr         .
           move      rr-dat-stp           to   rf-sdb-dts-sdb         .
           move      rr-dat-stp           to   w-det-dat-nrg-dtb      .
           move      60                   to   w-det-dat-nrg-ngi      .
           perform   det-dat-nrg-000      thru det-dat-nrg-999        .
           move      w-det-dat-nrg-dti    to   w-num-dat-rif          .
       stp-let-seq-ssp-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Test se superamento limiti massimi *
      *    *-----------------------------------------------------------*
       prn-tst-max-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
        prn-tst-max-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Selezione su record letto          *
      *    *-----------------------------------------------------------*
       prn-sel-rec-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
       prn-sel-rec-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Composizione area per rotture      *
      *    *-----------------------------------------------------------*
       prn-cmp-rot-000.
           move      srt-cod-cli          to   w-rot-l02-cod-cli      .
           move      srt-inl-slc          to   w-rot-l02-inl-slc      .
           move      srt-dpc-key          to   w-rot-l02-dpc-key      .
           move      rf-sdb-tip-ddr       to   w-rot-l01-tip-ddr      .
           move      rf-sdb-dat-ddr       to   w-rot-l01-dat-ddr      .
           move      rf-sdb-num-ddr       to   w-rot-l01-num-ddr      .
       prn-cmp-rot-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Esecuzione per inizio ciclo        *
      *    *-----------------------------------------------------------*
       prn-ini-cic-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
      *              *-------------------------------------------------*
      *              * Determinazione stringa per localita' e data     *
      *              *-------------------------------------------------*
           move      rr-dat-stp           to   w-det-str-lod-dat      .
           perform   det-str-lod-000      thru det-str-lod-999        .
           move      w-det-str-lod-str    to   w-prn-str-lod          .
      *              *-------------------------------------------------*
      *              * Preparazione eventuale intestazione azienda     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se necessario                          *
      *                  *---------------------------------------------*
           if        rr-tip-iaz           not  = 02
                     go to prn-ini-cic-999.
      *                  *---------------------------------------------*
      *                  * Normalizzazione [ada]                       *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/azi/fls/ioc/obj/iofada"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ada                 .
      *                  *---------------------------------------------*
      *                  * Lettura [ada] dati anagrafici Sede          *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODDPZ    "         to   f-key                  .
           move      zero                 to   rf-ada-cod-dpz         .
           move      "pgm/azi/fls/ioc/obj/iofada"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ada                 .
      *                  *---------------------------------------------*
      *                  * Determinazione nome azienda                 *
      *                  *---------------------------------------------*
           move      "IA"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione                             *
      *                  *---------------------------------------------*
           move      s-asx                to   w-stp-tes-slc-i01      .
           move      rf-ada-via-azi       to   w-stp-tes-slc-i02      .
           move      rf-ada-loc-azi       to   w-stp-tes-slc-i03      .
       prn-ini-cic-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Esecuzione per fine ciclo          *
