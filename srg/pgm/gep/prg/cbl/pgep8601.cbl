      *    *===========================================================*
      *    * Determinazione stringa localita' con data                 *
      *    *-----------------------------------------------------------*
       det-str-lod-000.
      *              *-------------------------------------------------*
      *              * Data in work ridefinito                         *
      *              *-------------------------------------------------*
           move      w-det-str-lod-dat    to   w-det-str-lod-wdt      .
      *              *-------------------------------------------------*
      *              * Preparazione giorno                             *
      *              *-------------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      02                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      w-det-str-lod-wgg    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-det-str-lod-wge      .
      *              *-------------------------------------------------*
      *              * Preparazione anno                               *
      *              *-------------------------------------------------*
           move      w-det-str-lod-wsa    to   w-det-str-lod-wae      .
           add       1900                 to   w-det-str-lod-wae      .
      *              *-------------------------------------------------*
      *              * Determinazione localita'                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione valore                      *
      *                  *---------------------------------------------*
           move      spaces               to   w-det-str-lod-wlo
      *                  *---------------------------------------------*
      *                  * Test se contenuta in referenza              *
      *                  *---------------------------------------------*
           if        w-ref-den-loc        not  = spaces
                     move  w-ref-den-loc  to   w-det-str-lod-wlo
                     go to det-str-lod-100.
      *                  *---------------------------------------------*
      *                  * Scomposizione localita' da [ada]            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione [ada]                   *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/azi/fls/ioc/obj/iofada"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ada                 .
      *                      *-----------------------------------------*
      *                      * Lettura [ada] dati anagrafici Sede      *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODDPZ    "         to   f-key                  .
           move      zero                 to   rf-ada-cod-dpz         .
           move      "pgm/azi/fls/ioc/obj/iofada"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ada                 .
      *                      *-----------------------------------------*
      *                      * Richiamo routine di scomposizione       *
      *                      *-----------------------------------------*
           move      rf-ada-loc-azi       to   w-scm-loc-ccp-loc      .
           perform   scm-loc-ccp-000      thru scm-loc-ccp-999        .
           move      w-scm-loc-ccp-cit    to   w-det-str-lod-wlo      .
       det-str-lod-100.
      *              *-------------------------------------------------*
      *              * Preparazione stringa                            *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-str-lod-str      .
           move      1                    to   w-det-str-lod-pnt      .
      *                  *---------------------------------------------*
      *                  * Localita'                                   *
      *                  *---------------------------------------------*
           string    w-det-str-lod-wlo
                                delimited by   size
                                          into w-det-str-lod-str
                                  with pointer w-det-str-lod-pnt      .
      *                  *---------------------------------------------*
      *                  * Concatenamento ','                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione ultimo non-blank         *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-str-lod-pnt      .
           inspect   w-det-str-lod-str
                                      tallying w-det-str-lod-pnt
                                          for  trailing spaces        .
           subtract  60                   from w-det-str-lod-pnt      .
           add       1                    to   w-det-str-lod-pnt      .
      *                      *-----------------------------------------*
      *                      * Se localita' a spazi : oltre            *
      *                      *-----------------------------------------*
           if        w-det-str-lod-str    =    spaces
                     go to det-str-lod-120.
      *                      *-----------------------------------------*
      *                      * String                                  *
      *                      *-----------------------------------------*
           string    ", "
                                delimited by   size
                                          into w-det-str-lod-str
                                  with pointer w-det-str-lod-pnt      .
       det-str-lod-120.
      *                  *---------------------------------------------*
      *                  * Giorno                                      *
      *                  *---------------------------------------------*
           string    w-det-str-lod-wge
                                delimited by   spaces
                                          into w-det-str-lod-str
                                  with pointer w-det-str-lod-pnt      .
      *                  *---------------------------------------------*
      *                  * Literal del mese, da segreteria             *
      *                  *---------------------------------------------*
           move      "LM"                 to   s-ope                  .
           move      "E"                  to   s-tip                  .
           move      w-det-str-lod-wmm    to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Mese                                        *
      *                  *---------------------------------------------*
           string    " "
                                delimited by   size
                     s-alf      delimited by   spaces
                                          into w-det-str-lod-str
                                  with pointer w-det-str-lod-pnt      .
      *                  *---------------------------------------------*
      *                  * Anno                                        *
      *                  *---------------------------------------------*
           string    " "
                                delimited by   size
                     w-det-str-lod-wae
                                delimited by   spaces
                                          into w-det-str-lod-str
                                  with pointer w-det-str-lod-pnt      .
       det-str-lod-999.
           exit.

      *    *===========================================================*
      *    * Determinazione imposta iva                                *
      *    *-----------------------------------------------------------*
       det-imp-iva-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore in output                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-imp-iva-imp      .
      *              *-------------------------------------------------*
      *              * Esecuzione calcolo                              *
      *              *-------------------------------------------------*
           move      w-det-imp-iva-ibl    to   d-imp-iva-ibl-iva      .
           move      w-det-imp-iva-cod    to   d-imp-iva-cod-iva      .
      *              *-------------------------------------------------*
      *              * Determinazione                                  *
      *              *-------------------------------------------------*
           move      "DI"                 to   d-imp-iva-tip-ope      .
           perform   det-imp-iva-cll-000  thru det-imp-iva-cll-999    .
      *              *-------------------------------------------------*
      *              * Esito determinazione                            *
      *              *-------------------------------------------------*
           add       d-imp-iva-ims-iva    to   w-det-imp-iva-imp      .
       det-imp-iva-999.
           exit.

      *    *===========================================================*
      *    * Routine di calcolo importo interessi                      *
      *    *-----------------------------------------------------------*
       cal-imp-int-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore in output                *
      *              *-------------------------------------------------*
           move      zero                 to   w-cal-imp-int-imi      .
      *              *-------------------------------------------------*
      *              * Controllo ammissibilita' valori in input        *
      *              *-------------------------------------------------*
           if        w-cal-imp-int-tdi    =    zero or
                     w-cal-imp-int-imm    =    zero or
                     w-cal-imp-int-nrg    =    zero
                     go to cal-imp-int-999.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo applicazione    *
      *              * interessi personalizzata                        *
      *              *-------------------------------------------------*
           if        w-cal-imp-int-tap    =    01
                     go to cal-imp-int-100
           else      go to cal-imp-int-999.
       cal-imp-int-100.
      *              *-------------------------------------------------*
      *              * Tipo applicazione interessi : Standard          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Calcolo                                     *
      *                  *---------------------------------------------*
           divide    100                  into w-cal-imp-int-tdi
                                        giving w-cal-imp-int-w01      .
           multiply  w-cal-imp-int-imm    by   w-cal-imp-int-w01      .
           divide    365                  into w-cal-imp-int-w01
                                               rounded                .
           multiply  w-cal-imp-int-nrg    by   w-cal-imp-int-w01
                                        giving w-cal-imp-int-imi      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     cal-imp-int-999.
       cal-imp-int-999.
           exit.

      *    *===========================================================*
      *    * Scomposizione di una localita' in Cap, Citta', Provincia  *
      *    *-----------------------------------------------------------*
       scm-loc-ccp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valori in output                *
      *              *-------------------------------------------------*
           move      zero                 to   w-scm-loc-ccp-cap      .
           move      spaces               to   w-scm-loc-ccp-cit      .
           move      spaces               to   w-scm-loc-ccp-prv      .
      *              *-------------------------------------------------*
      *              * Se valore in input a spaces : uscita            *
      *              *-------------------------------------------------*
           if        w-scm-loc-ccp-loc    =    spaces
                     go to scm-loc-ccp-999.
      *              *-------------------------------------------------*
      *              * Valore in input in work di comodo               *
      *              *-------------------------------------------------*
           move      w-scm-loc-ccp-loc    to   w-scm-loc-ccp-wlc      .
       scm-loc-ccp-100.
      *              *-------------------------------------------------*
      *              * Identificazione Cap                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se Cap corretto                        *
      *                  *---------------------------------------------*
           if        w-scm-loc-ccp-w15    not  numeric  or
                     w-scm-loc-ccp-w66    not  = spaces
                     go to scm-loc-ccp-120
           else      go to scm-loc-ccp-140.
       scm-loc-ccp-120.
      *                  *---------------------------------------------*
      *                  * Se Cap non corretto                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     scm-loc-ccp-200.
       scm-loc-ccp-140.
      *                  *---------------------------------------------*
      *                  * Se Cap corretto                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione Cap                     *
      *                      *-----------------------------------------*
           move      w-scm-loc-ccp-w15    to   w-scm-loc-ccp-cap      .
      *                      *-----------------------------------------*
      *                      * Preparazione nuova work di lavoro       *
      *                      *-----------------------------------------*
           move      w-scm-loc-ccp-loc
                    (7 : 34)              to   w-scm-loc-ccp-wlc      .
           go to     scm-loc-ccp-200.
       scm-loc-ccp-200.
      *              *-------------------------------------------------*
      *              * Identificazione Provincia                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-scm-loc-ccp-c01      .
           inspect   w-scm-loc-ccp-wlc
                                      tallying w-scm-loc-ccp-c01
                                  for trailing spaces                 .
           move      40                   to   w-scm-loc-ccp-c02      .
           subtract  w-scm-loc-ccp-c01    from w-scm-loc-ccp-c02      .
      *                  *---------------------------------------------*
      *                  * Se provincia non identificabile : oltre     *
      *                  *---------------------------------------------*
           if        w-scm-loc-ccp-c02    <    4
                     go to scm-loc-ccp-300.
           subtract  2                    from w-scm-loc-ccp-c02      .
           if        w-scm-loc-ccp-wlc
                    (w-scm-loc-ccp-c02 : 1)
                                          not  = spaces
                     go to scm-loc-ccp-300.
           add       1                    to   w-scm-loc-ccp-c02      .
           if        w-scm-loc-ccp-wlc
                    (w-scm-loc-ccp-c02 : 1)
                                          =    spaces
                     go to scm-loc-ccp-300.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione Provincia                   *
      *                  *---------------------------------------------*
           move      w-scm-loc-ccp-wlc
                    (w-scm-loc-ccp-c02 : 2)
                                          to   w-scm-loc-ccp-prv      .
      *                  *---------------------------------------------*
      *                  * Eliminazione Provincia                      *
      *                  *---------------------------------------------*
           move      spaces               to   w-scm-loc-ccp-wlc
                                              (w-scm-loc-ccp-c02 : 2) .
       scm-loc-ccp-300.
      *              *-------------------------------------------------*
      *              * Identificazione Citta'                          *
      *              *-------------------------------------------------*
           move      w-scm-loc-ccp-wlc    to   w-scm-loc-ccp-cit      .
       scm-loc-ccp-999.
           exit.

      *    *===========================================================*
      *    * Routine per calcoli ed operazioni su date                 *
      *    *-----------------------------------------------------------*
       clc-ope-dat-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
           move      zero                 to   w-clc-dat-nrg          .
           move      w-clc-dat-min        to   w-clc-dat-ng0          .
      *              *-------------------------------------------------*
      *              * Test preliminari                                *
      *              *-------------------------------------------------*
           if        w-clc-dat-max        not  > w-clc-dat-min
                     go to clc-ope-dat-999.
       clc-ope-dat-100.
      *              *-------------------------------------------------*
      *              * Ciclo                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Incremento                                  *
      *                  *---------------------------------------------*
           add       1                    to   w-clc-dat-nrg          .
           move      w-clc-dat-ng0        to   w-det-dat-nrg-dtb      .
           move      1                    to   w-det-dat-nrg-ngi      .
           perform   det-dat-nrg-000      thru det-dat-nrg-999        .
           move      w-det-dat-nrg-dti    to   w-clc-dat-ng0          .
           if        w-clc-dat-ng0        =    w-clc-dat-max
                     go to clc-ope-dat-999.
           go to     clc-ope-dat-100.
       clc-ope-dat-999.
           exit.

