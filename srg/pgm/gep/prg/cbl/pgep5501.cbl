      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Editing anno                    *
      *                              *---------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      04                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      w-tot-pmc-saa
                    (w-stp-tot-cir-c01)   to   p-num                  .
           add       1900                 to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                              *---------------------------------*
      *                              * String                          *
      *                              *---------------------------------*
           string    " "        delimited by   size
                     p-edt      delimited by   spaces
                                          into w-stp-tot-cir-x14
                                  with pointer w-stp-tot-cir-pnt      .
       stp-tot-cir-340.
      *                      *-----------------------------------------*
      *                      * Stampa                                  *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      14                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           multiply  w-stp-tot-cir-c01    by   14
                                        giving p-pos                  .
           add       w-stp-tot-cir-c01    to   p-pos                  .
           subtract  1                    from p-pos                  .
           subtract  w-stp-tot-cir-pnt    from 14
                                        giving w-stp-tot-cir-inx      .
           divide    2                    into w-stp-tot-cir-inx      .
           add       w-stp-tot-cir-inx    to   p-pos                  .
           add       1                    to   p-pos                  .
           move      w-stp-tot-cir-x14    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Riciclo                                 *
      *                      *-----------------------------------------*
           go to     stp-tot-cir-320.
       stp-tot-cir-360.
      *              *-------------------------------------------------*
      *              * Sottolineatura fincatura                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Per tipo scadenza                           *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      11                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      "-----------"        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione mesi bufferizzati in ta- *
      *                  * bella totali                                *
      *                  *---------------------------------------------*
           move      zero                 to   w-stp-tot-cir-c01      .
       stp-tot-cir-380.
           add       1                    to   w-stp-tot-cir-c01      .
           if        w-stp-tot-cir-c01    >    w-tot-pmc-inx
                     go to stp-tot-cir-400.
      *                      *-----------------------------------------*
      *                      * Stampa                                  *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      14                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           multiply  w-stp-tot-cir-c01    by   14
                                        giving p-pos                  .
           add       w-stp-tot-cir-c01    to   p-pos                  .
           subtract  1                    from p-pos                  .
           move      all "-"              to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Riciclo                                 *
      *                      *-----------------------------------------*
           go to     stp-tot-cir-380.
       stp-tot-cir-400.
      *              *-------------------------------------------------*
      *              * Ciclo per ciascun tipo scadenza                 *
      *              *-------------------------------------------------*
           move      zero                 to   w-stp-tot-cir-c01      .
       stp-tot-cir-420.
           add       1                    to   w-stp-tot-cir-c01      .
           if        w-stp-tot-cir-c01    >    12
                     go to stp-tot-cir-500.
      *                  *---------------------------------------------*
      *                  * Test se tipo scadenza da stampare           *
      *                  *---------------------------------------------*
           move      zero                 to   w-stp-tot-cir-c02      .
       stp-tot-cir-422.
           add       1                    to   w-stp-tot-cir-c02      .
           if        w-stp-tot-cir-c02    >    w-tot-pmc-inx
                     go to stp-tot-cir-420.
           if        w-tot-pmc-imp
                    (w-stp-tot-cir-c02
                     w-stp-tot-cir-c01)   not  = zero
                     go to stp-tot-cir-430.
           go to     stp-tot-cir-422.
       stp-tot-cir-430.
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Ciclo per ciascun mese                      *
      *                  *---------------------------------------------*
           move      zero                 to   w-stp-tot-cir-c02      .
       stp-tot-cir-440.
           add       1                    to   w-stp-tot-cir-c02      .
           if        w-stp-tot-cir-c02    >    w-tot-pmc-inx
                     go to stp-tot-cir-460.
      *                  *---------------------------------------------*
