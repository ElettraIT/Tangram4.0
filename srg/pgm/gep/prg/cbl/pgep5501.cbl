      *                      *-----------------------------------------*
      *                      * Stampa                                  *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      14                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           multiply  w-stp-tot-cir-c01    by   14
                                        giving p-pos                  .
           add       w-stp-tot-cir-c01    to   p-pos                  .
           subtract  1                    from p-pos                  .
           move      all "-"              to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Riciclo                                 *
      *                      *-----------------------------------------*
           go to     stp-tot-cir-520.
       stp-tot-cir-600.
      *              *-------------------------------------------------*
      *              * Totali finali                                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Literal                                     *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      11                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      "Totale"             to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Ciclo per ciascun mese                      *
      *                  *---------------------------------------------*
           move      zero                 to   w-stp-tot-cir-c02      .
       stp-tot-cir-620.
           add       1                    to   w-stp-tot-cir-c02      .
           if        w-stp-tot-cir-c02    >    8
                     go to stp-tot-cir-640.
      *                  *---------------------------------------------*
      *                  * Totale per tipo scadenza nel mese           *
      *                  *---------------------------------------------*
           move      w-tot-pmc-tme
                    (w-stp-tot-cir-c02)   to   w-stp-imp-vlb-val      .
      *
           multiply  w-stp-tot-cir-c02    by   2
                                        giving w-stp-imp-vlb-pos      .
