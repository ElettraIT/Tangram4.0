      *                  *---------------------------------------------*
           move      rr-dat-bcm           to   w-det-srd-sdb-drd      .
           perform   det-srd-sdb-000      thru det-srd-sdb-999        .
      *                  *---------------------------------------------*
      *                  * Test se scadenza ancora aperta              *
      *                  *---------------------------------------------*
           if        w-det-srd-sdb-sts    not  = "A"
                     go to stp-srt-inp-120.
      *                  *---------------------------------------------*
      *                  * Test su tipo scadenza                       *
      *                  *---------------------------------------------*
           if        rf-sdb-tip-sdb       not  = 01 and
                     rf-sdb-tip-sdb       not  = 07 and
                     rf-sdb-tip-sdb       not  = 08
                     go to stp-srt-inp-350.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione della selezione su   *
      *                  * status scadenze                             *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-301
                     stp-srt-inp-302
                     stp-srt-inp-303
                     depending            on   rr-sts-scd             .
       stp-srt-inp-301.
      *                  *---------------------------------------------*
      *                  * Scadenze sia a scadere che scadute          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Nessuna selezione                       *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-400.
       stp-srt-inp-302.
      *                  *---------------------------------------------*
      *                  * Solo quelle a scadere                       *
      *                  *---------------------------------------------*
           if        rf-sdb-dts-sdb       not  >  rr-dat-bcm
                     go to stp-srt-inp-120.
           go to     stp-srt-inp-400.
       stp-srt-inp-303.
      *                  *---------------------------------------------*
      *                  * Solo quelle scadute                         *
      *                  *---------------------------------------------*
           if        rf-sdb-dts-sdb       >    rr-dat-bcm
                     go to stp-srt-inp-120.
           go to     stp-srt-inp-400.
       stp-srt-inp-350.
      *              *-------------------------------------------------*
      *              * Selezione su status effetti                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione della selezione su   *
      *                  * status effetti                              *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-351
                     stp-srt-inp-352
                     stp-srt-inp-353
                     stp-srt-inp-354
                     depending            on   rr-sts-eff             .
       stp-srt-inp-351.
      *                  *---------------------------------------------*
      *                  * Tutti gli effetti                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Nessuna selezione                       *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-400.
       stp-srt-inp-352.
      *                  *---------------------------------------------*
