      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      04                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           if        w-stp-tot-cir-c01    =    01
                     move  "RD  "         to   p-alf
           else if   w-stp-tot-cir-c01    =    02
                     move  "DC  "         to   p-alf
           else if   w-stp-tot-cir-c01    =    03
                     move  "IE  "         to   p-alf
           else if   w-stp-tot-cir-c01    =    04
                     move  "RIBA"         to   p-alf
           else if   w-stp-tot-cir-c01    =    05
                     move  "CDO "         to   p-alf
           else if   w-stp-tot-cir-c01    =    06
                     move  "MAV "         to   p-alf
           else if   w-stp-tot-cir-c01    =    07
                     move  "RID "         to   p-alf
           else if   w-stp-tot-cir-c01    =    08
                     move  "BB  "         to   p-alf
           else if   w-stp-tot-cir-c01    =    09
                     move  "CCP "         to   p-alf
           else if   w-stp-tot-cir-c01    =    10
                     move  "RB  "         to   p-alf
           else if   w-stp-tot-cir-c01    =    11
                     move  "TR  "         to   p-alf
           else if   w-stp-tot-cir-c01    =    12
                     move  "PC  "         to   p-alf
           else      move  spaces         to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Totale per tipo scadenza nel mese           *
      *                  *---------------------------------------------*
           move      w-tot-pmc-imp
                    (w-stp-tot-cir-c02
                     w-stp-tot-cir-c01)   to   w-stp-imp-vlb-val      .
      *
           multiply  w-stp-tot-cir-c02    by   2
                                        giving w-stp-imp-vlb-pos      .
           subtract  2                    from w-stp-imp-vlb-pos      .
           multiply  w-stp-tot-cir-c02    by   13
                                        giving w-stp-tot-cir-inx      .
           add       w-stp-tot-cir-inx    to   w-stp-imp-vlb-pos      .
      *
           perform   stp-imp-vlb-000      thru stp-imp-vlb-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     stp-tot-cir-440.
       stp-tot-cir-460.
