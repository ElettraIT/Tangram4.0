      *              *-------------------------------------------------*
           if        srt-tip-sdb          =    01 and
                     srt-snx-dlc          =    "N"
                     move  01             to   w-agg-tot-rie-its
           else if   srt-tip-sdb          =    01 and
                     srt-snx-dlc          =    "S"
                     move  02             to   w-agg-tot-rie-its
           else if   srt-tip-sdb          =    02
                     move  03             to   w-agg-tot-rie-its
           else if   srt-tip-sdb          =    03
                     move  04             to   w-agg-tot-rie-its
           else if   srt-tip-sdb          =    04
                     move  05             to   w-agg-tot-rie-its
           else if   srt-tip-sdb          =    05
                     move  06             to   w-agg-tot-rie-its
           else if   srt-tip-sdb          =    06
                     move  07             to   w-agg-tot-rie-its
           else if   srt-tip-sdb          =    07
                     move  08             to   w-agg-tot-rie-its
           else if   srt-tip-sdb          =    08
                     move  09             to   w-agg-tot-rie-its
           else if   srt-tip-sdb          =    09
