           move      "Attenzione : La data di registrazione, che rappres
      -              "enta la data   "    to   w-err-box-err-msg      .
           move      "             di stampa, non puo' essere inferiore 
      -              "alla data di   "    to   w-err-box-err-m02      .
           move      "             composizione della distinta. - Stampa
      -              "non ammessa.   "    to   w-err-box-err-m03      .
           perform   box-msg-e03-000      thru box-msg-e03-999        .
           move      "V"                  to   w-cnt-mfu-tip-fun      .
       rou-let-reg-250.
      *                      *-----------------------------------------*
      *                      * Se la distinta ha il flag di sottoponi- *
      *                      * bilita' a pulizia in On si pone la sola *
      *                      * Visualizzazione, dopo aver emesso un    *
      *                      * messaggio di errore                     *
      *                      *                                         *
      *                      * N.B. : Il tipo funzionamento in questo  *
      *                      *        programma e' puramente conven-   *
      *                      *        zionale.                         *
      *                      *-----------------------------------------*
           if        w-tes-flg-pul (1)    =    spaces
                     go to rou-let-reg-275.
           if        w-cnt-mfu-tip-fun    =    "V"
                     go to rou-let-reg-275.
           move      "Attenzione : La distinta e' in corso di eliminazio
      -              "ne.            "    to   w-err-box-err-msg      .
           move      "             Pertanto la stampa effetti non e' amm
      -              "essa.          "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           move      "V"                  to   w-cnt-mfu-tip-fun      .
       rou-let-reg-275.
      *                      *-----------------------------------------*
      *                      * Se la distinta non e' ancora stata pre- *
      *                      * sentata si pone la sola Visualizzazio-  *
      *                      * ne, dopo aver emesso un messaggio di    *
      *                      * errore                                  *
      *                      *                                         *
      *                      * N.B. : Il tipo funzionamento in questo  *
      *                      *        programma e' puramente conven-   *
      *                      *        zionale.                         *
      *                      *-----------------------------------------*
           if        w-tes-dtr-pre (1)    not  = zero
                     go to rou-let-reg-300.
           if        w-cnt-mfu-tip-fun    =    "V"
                     go to rou-let-reg-300.
           move      "Attenzione : La distinta non e' ancora stata prese
      -              "ntata.         "    to   w-err-box-err-msg      .
           move      "             Pertanto la stampa effetti non e' amm
      -              "essa.          "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
           move      "V"                  to   w-cnt-mfu-tip-fun      .
       rou-let-reg-300.
      *                      *-----------------------------------------*
      *                      * A caricamento righe                     *
      *                      *-----------------------------------------*
           go to     rou-let-reg-700.
       rou-let-reg-700.
      *                      *-----------------------------------------*
      *                      * Caricamento righe, con ordinamento per  *
      *                      * data di scadenza, e con calcolo del to- *
      *                      * tale importo scadenze caricate          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Messaggio di caricamento in esecu-  *
      *                          * zione                               *
      *                          *-------------------------------------*
           move      "               Caricamento distinta in esecuzione 
      -              "               "    to   w-err-box-err-msg      .
           perform   msg-cnt-box-000      thru msg-cnt-box-999        .
      *                          *-------------------------------------*
      *                          * Sort                                *
      *                          *-------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   srt-inp-prc-000
                                          thru srt-inp-prc-999
                     output procedure     is   srt-out-prc-000
                                          thru srt-out-prc-999        .
      *                          *-------------------------------------*
      *                          * Messaggio di fine caricamento       *
      *                          * zione                               *
      *                          *-------------------------------------*
           move      spaces               to   w-err-box-err-msg      .
           perform   msg-cnt-box-000      thru msg-cnt-box-999        .
       rou-let-reg-725.
      *                      *-----------------------------------------*
      *                      * Assestamenti post-caricamento righe di- *
      *                      * stinta                                  *
      *                      *-----------------------------------------*
       rou-let-reg-730.
      *                          *-------------------------------------*
      *                          * Controllo che l'importo effettivo   *
      *                          * della distinta sia pari alla som-   *
      *                          * matoria delle righe caricate        *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se si' : continuazione          *
      *                              *---------------------------------*
           if        w-srt-sdb-out-igc    =    w-tes-imp-ddp (1)
                     go to rou-let-reg-735.
      *                              *---------------------------------*
      *                              * Se no                           *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Se si e' gia' in sola Vi-   *
      *                                  * sualizzazione : nessun mes- *
      *                                  * saggio                      *
      *                                  *-----------------------------*
           if        w-cnt-mfu-tip-fun    =    "V"
                     go to rou-let-reg-735.
      *                                  *-----------------------------*
      *                                  * Emissione messaggio di er-  *
      *                                  * rore                        *
      *                                  *-----------------------------*
           move      "Attenzione : L'importo totale della distinta risul
      -              "ta diverso da  "    to   w-err-box-err-msg      .
           move      "             quello determinato nella composizione
      -              " distinta !    "    to   w-err-box-err-m02      .
           move      "             Pertanto la stampa effetti non e' amm
      -              "essa.          "    to   w-err-box-err-m03      .
           perform   box-msg-e03-000      thru box-msg-e03-999        .
      *                                  *-----------------------------*
      *                                  * Sola visualizzazione        *
      *                                  *                             *
      *                                  * N.B. : Il tipo funzionamen- *
      *                                  *        to in questo pro-    *
      *                                  *        gramma e' puramente  *
      *                                  *        convenzionale        *
      *                                  *-----------------------------*
           move      "V"                  to   w-cnt-mfu-tip-fun      .
       rou-let-reg-735.
      *                          *-------------------------------------*
      *                          * Controllo che la distinta comprenda *
      *                          * almeno una ricevuta bancaria o una  *
      *                          * tratta                              *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se si' : continuazione          *
      *                              *---------------------------------*
           if        w-srt-sdb-out-nrb    >    zero or
                     w-srt-sdb-out-ntr    >    zero
                     go to rou-let-reg-740.
      *                              *---------------------------------*
      *                              * Se no                           *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Se si e' gia' in sola Vi-   *
      *                                  * sualizzazione : nessun mes- *
      *                                  * saggio                      *
      *                                  *-----------------------------*
           if        w-cnt-mfu-tip-fun    =    "V"
                     go to rou-let-reg-740.
      *                                  *-----------------------------*
      *                                  * Emissione messaggio di er-  *
      *                                  * rore                        *
      *                                  *-----------------------------*
           move      "Attenzione : La distinta non comprende nemmeno una
      -              " scadenza di   "    to   w-err-box-err-msg      .
           move      "             tipo Ricevuta Bancaria o Tratta !    
      -              "               "    to   w-err-box-err-m02      .
           move      "             Pertanto la stampa effetti non e' amm
      -              "essa.          "    to   w-err-box-err-m03      .
           perform   box-msg-e03-000      thru box-msg-e03-999        .
      *                                  *-----------------------------*
      *                                  * Sola visualizzazione        *
      *                                  *                             *
      *                                  * N.B. : Il tipo funzionamen- *
      *                                  *        to in questo pro-    *
      *                                  *        gramma e' puramente  *
      *                                  *        convenzionale        *
      *                                  *-----------------------------*
           move      "V"                  to   w-cnt-mfu-tip-fun      .
       rou-let-reg-740.
      *                          *-------------------------------------*
      *                          * Importo effettivo della distinta,   *
      *                          * da sommatoria righe caricate        *
      *                          *-------------------------------------*
           move      w-srt-sdb-out-igc    to   w-tes-imp-ddp (1)      .
      *                          *-------------------------------------*
      *                          * Numero ricevute bancarie incluse    *
      *                          * nella distinta                      *
      *                          *-------------------------------------*
           move      w-srt-sdb-out-nrb    to   w-tes-sce-nrb (1)      .
      *                          *-------------------------------------*
      *                          * Numero tratte incluse nella distin- *
      *                          * ta                                  *
      *                          *-------------------------------------*
           move      w-srt-sdb-out-ntr    to   w-tes-sce-ntr (1)      .
      *                          *-------------------------------------*
      *                          * Numero effetti appartenenti alla    *
      *                          * distinta, che sono gia' stati stam- *
      *                          * pati                                *
      *                          *-------------------------------------*
           move      w-srt-sdb-out-ngs    to   w-tes-sce-ngs (1)      .
       rou-let-reg-800.
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rou-let-reg-999.
       rou-let-reg-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort scadenze della distinta per :    *
      *    *                                                           *
      *    * -  Data di scadenza                                       *
      *    * -  Ragione sociale del debitore                           *
      *    * -  Tipo debitore                                          *
      *    * -  Codice debitore                                        *
      *    * -  Numero scadenza                                        *
      *    *-----------------------------------------------------------*
       srt-inp-prc-000.
      *              *-------------------------------------------------*
      *              * Start su scadenze appartenenti alla distinta di *
      *              * presentazione                                   *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "DDPNRS    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      w-tes-num-dis        to   rf-sdb-num-ddp         .
           move      zero                 to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *              *-------------------------------------------------*
      *              * Se start errata : fine input procedure          *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  srt-inp-prc-999.
       srt-inp-prc-200.
      *              *-------------------------------------------------*
      *              * Next su scadenze appartenenti alla distinta di  *
      *              * presentazione                                   *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *              *-------------------------------------------------*
      *              * Se at end : fine input procedure                *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  srt-inp-prc-999.
       srt-inp-prc-300.
      *              *-------------------------------------------------*
      *              * Test max su su scadenze appartenenti alla di-   *
      *              * stinta di presentazione, se non superato : fi-  *
      *              * ne input procedure                              *
      *              *-------------------------------------------------*
           if        rf-sdb-num-ddp       not  = w-tes-num-dis
                     go to  srt-inp-prc-999.
       srt-inp-prc-400.
      *              *-------------------------------------------------*
      *              * Composizione sort-record                        *
      *              *-------------------------------------------------*
       srt-inp-prc-410.
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
       srt-inp-prc-420.
      *                  *---------------------------------------------*
      *                  * Data di scadenza                            *
      *                  *---------------------------------------------*
           move      rf-sdb-dts-sdb       to   srt-dts-sdb            .
       srt-inp-prc-430.
      *                  *---------------------------------------------*
      *                  * Ragione sociale del debitore                *
      *                  *---------------------------------------------*
           move      rf-sdb-tip-dbt       to   w-let-arc-dbt-tip      .
           move      rf-sdb-cod-dbt       to   w-let-arc-dbt-cod      .
           perform   let-arc-dbt-000      thru let-arc-dbt-999        .
           move      w-let-arc-dbt-rag    to   srt-rag-soc            .
       srt-inp-prc-440.
      *                  *---------------------------------------------*
      *                  * Tipo debitore                               *
      *                  *---------------------------------------------*
           move      rf-sdb-tip-dbt       to   srt-tip-dbt            .
       srt-inp-prc-450.
      *                  *---------------------------------------------*
      *                  * Codice debitore                             *
      *                  *---------------------------------------------*
           move      rf-sdb-cod-dbt       to   srt-cod-dbt            .
       srt-inp-prc-460.
      *                  *---------------------------------------------*
      *                  * Numero scadenza                             *
      *                  *---------------------------------------------*
           move      rf-sdb-num-sdb       to   srt-num-sdb            .
       srt-inp-prc-470.
      *                  *---------------------------------------------*
      *                  * Importo scadenza                            *
      *                  *---------------------------------------------*
           move      rf-sdb-imp-sdb       to   srt-imp-sdb            .
       srt-inp-prc-480.
      *                  *---------------------------------------------*
      *                  * Tipo scadenza                               *
      *                  *---------------------------------------------*
           move      rf-sdb-tip-sdb       to   srt-tip-sdb            .
       srt-inp-prc-490.
      *                  *---------------------------------------------*
      *                  * Tipo acquisizione scadenza                  *
      *                  *---------------------------------------------*
           move      rf-sdb-tac-sdb       to   srt-tac-sdb            .
       srt-inp-prc-500.
      *                  *---------------------------------------------*
      *                  * Codice dipendenza del debitore              *
      *                  *---------------------------------------------*
           move      rf-sdb-dpz-dbt       to   srt-dpz-dbt            .
       srt-inp-prc-510.
      *                  *---------------------------------------------*
      *                  * Inoltro scadenza al debitore                *
      *                  *---------------------------------------------*
           move      rf-sdb-inl-sdb       to   srt-inl-sdb            .
       srt-inp-prc-520.
      *                  *---------------------------------------------*
      *                  * Codice ABI per l'appoggio                   *
      *                  *---------------------------------------------*
           move      rf-sdb-abi-app       to   srt-abi-app            .
       srt-inp-prc-530.
      *                  *---------------------------------------------*
      *                  * Codice CAB per l'appoggio                   *
      *                  *---------------------------------------------*
           move      rf-sdb-cab-app       to   srt-cab-app            .
       srt-inp-prc-540.
      *                  *---------------------------------------------*
      *                  * Codice C/C per l'appoggio                   *
      *                  *---------------------------------------------*
           move      rf-sdb-ccc-app       to   srt-ccc-app            .
       srt-inp-prc-550.
      *                  *---------------------------------------------*
      *                  * Data documento di riferimento               *
      *                  *---------------------------------------------*
           move      rf-sdb-dat-ddr       to   srt-dat-ddr            .
       srt-inp-prc-560.
      *                  *---------------------------------------------*
      *                  * Numero documento di riferimento             *
      *                  *---------------------------------------------*
           move      rf-sdb-num-ddr       to   srt-num-ddr            .
       srt-inp-prc-570.
      *                  *---------------------------------------------*
      *                  * Tipo documento di riferimento               *
      *                  *---------------------------------------------*
           move      rf-sdb-tip-ddr       to   srt-tip-ddr            .
       srt-inp-prc-580.
      *                  *---------------------------------------------*
      *                  * Importo documento di riferimento            *
      *                  *---------------------------------------------*
           move      rf-sdb-imp-ddr       to   srt-imp-ddr            .
       srt-inp-prc-590.
      *                  *---------------------------------------------*
      *                  * Numero rata documento di riferimento        *
      *                  *---------------------------------------------*
           move      rf-sdb-nra-ddr       to   srt-nra-ddr            .
       srt-inp-prc-600.
      *                  *---------------------------------------------*
      *                  * Tipo avviso ottenuto                        *
      *                  *---------------------------------------------*
           move      rf-sdb-tav-ott       to   srt-tav-ott            .
       srt-inp-prc-610.
      *                  *---------------------------------------------*
      *                  * Status della scadenza                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se richiamata                           *
      *                      *-----------------------------------------*
           if        rf-sdb-dtr-rsp       not  = zero
                     move  01             to   srt-sts-sca
                     go to srt-inp-prc-620.
      *                      *-----------------------------------------*
      *                      * Se accreditata, se al dopo incasso      *
      *                      *-----------------------------------------*
           if        rf-sdb-dtr-acs       not  = zero
                     move  02             to   srt-sts-sca
                     go to srt-inp-prc-620.
      *                      *-----------------------------------------*
      *                      * Se con notizia di buon esito            *
      *                      *-----------------------------------------*
           if        rf-sdb-dtr-nbe       not  = zero
                     move  03             to   srt-sts-sca
                     go to srt-inp-prc-620.
      *                      *-----------------------------------------*
      *                      * Se con presunto buon esito              *
      *                      *-----------------------------------------*
           if        rf-sdb-dtr-pbe       not  = zero
                     move  04             to   srt-sts-sca
                     go to srt-inp-prc-620.
      *                      *-----------------------------------------*
      *                      * Se insoluta                             *
      *                      *-----------------------------------------*
           if        rf-sdb-dtr-isp       not  = zero
                     move  05             to   srt-sts-sca
                     go to srt-inp-prc-620.
      *                      *-----------------------------------------*
      *                      * Se con flags di elaborazione bloccanti  *
      *                      *-----------------------------------------*
           if        rf-sdb-flg-blo       not  = spaces
                     move  06             to   srt-sts-sca
                     go to srt-inp-prc-620.
      *                      *-----------------------------------------*
      *                      * Se con flags di sottoponibilita' a pu-  *
      *                      * lizia                                   *
      *                      *-----------------------------------------*
           if        rf-sdb-flg-pul       not  = spaces
                     move  07             to   srt-sts-sca
                     go to srt-inp-prc-620.
      *                      *-----------------------------------------*
      *                      * Altrimenti : normale                    *
      *                      *-----------------------------------------*
           move      zero                 to   srt-sts-sca            .
       srt-inp-prc-620.
      *                  *---------------------------------------------*
      *                  * Data registrazione movimento di richiamo    *
      *                  * scadenza presentata                         *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-rsp       to   srt-dtr-rsp            .
       srt-inp-prc-630.
      *                  *---------------------------------------------*
      *                  * Data registrazione movimento di accredito   *
      *                  * scadenza presentata al dopo incasso         *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-acs       to   srt-dtr-acs            .
       srt-inp-prc-640.
      *                  *---------------------------------------------*
      *                  * Data registrazione movimento di notizia di  *
      *                  * buon esito su scadenza presentata           *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-nbe       to   srt-dtr-nbe            .
       srt-inp-prc-650.
      *                  *---------------------------------------------*
      *                  * Data registrazione movimento di presunto    *
      *                  * buon esito su scadenza presentata           *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-pbe       to   srt-dtr-pbe            .
       srt-inp-prc-660.
      *                  *---------------------------------------------*
      *                  * Data registrazione movimento di insoluto su *
      *                  * scadenza presentata                         *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-isp       to   srt-dtr-isp            .
       srt-inp-prc-665.
      *                  *---------------------------------------------*
      *                  * Flag/contatore di stampa effetto eseguita   *
      *                  * scadenza presentata                         *
      *                  *---------------------------------------------*
           move      rf-sdb-flc-stp       to   srt-flc-stp            .
       srt-inp-prc-670.
      *                  *---------------------------------------------*
      *                  * Flags di elaborazione, sia bloccanti che    *
      *                  * non bloccanti                               *
      *                  *---------------------------------------------*
           move      rf-sdb-flg-ela       to   srt-flg-ela            .
       srt-inp-prc-680.
      *                  *---------------------------------------------*
      *                  * Flag di sottoponibilita' a pulizia          *
      *                  *---------------------------------------------*
           move      rf-sdb-flg-pul       to   srt-flg-pul            .
       srt-inp-prc-700.
      *                  *---------------------------------------------*
      *                  * Fine composizione                           *
      *                  *---------------------------------------------*
           go to     srt-inp-prc-800.
       srt-inp-prc-800.
      *              *-------------------------------------------------*
      *              * Rilascio record al sort                         *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       srt-inp-prc-900.
      *              *-------------------------------------------------*
      *              * Riciclo a  Next su scadenze appartenenti alla   *
      *              * distinta                                        *
      *              *-------------------------------------------------*
           go to     srt-inp-prc-200.
       srt-inp-prc-999.
           exit.

      *    *===========================================================*
      *    * Output procedure per sort scadenze della distinta per :   *
      *    *                                                           *
      *    * -  Data di scadenza                                       *
      *    * -  Ragione sociale del debitore                           *
      *    * -  Tipo debitore                                          *
      *    * -  Codice debitore                                        *
      *    * -  Numero scadenza                                        *
      *    *-----------------------------------------------------------*
       srt-out-prc-000.
      *              *-------------------------------------------------*
      *              * Preparazioni iniziali                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione importo globale caricato    *
      *                  *---------------------------------------------*
           move      zero                 to   w-srt-sdb-out-igc      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione numero ricevute bancarie    *
      *                  * incluse nella distinta                      *
      *                  *---------------------------------------------*
           move      zero                 to   w-srt-sdb-out-nrb      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione numero tratte incluse nella *
      *                  * distinta                                    *
      *                  *---------------------------------------------*
           move      zero                 to   w-srt-sdb-out-ntr      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione numero effetti appartenenti *
      *                  * alla distinta che sono gia' stati stampati  *
      *                  *---------------------------------------------*
           move      zero                 to   w-srt-sdb-out-ngs      .
       srt-out-prc-200.
      *              *-------------------------------------------------*
      *              * Reperimento record dal sort, se fine lettura :  *
      *              * a fine output procedure                         *
      *              *-------------------------------------------------*
           return    srt    at end
                            go to srt-out-prc-999.
       srt-out-prc-500.
      *              *-------------------------------------------------*
      *              * Aggiornamento importo globale caricato          *
      *              *-------------------------------------------------*
           add       srt-imp-sdb          to   w-srt-sdb-out-igc      .
      *              *-------------------------------------------------*
      *              * Aggiornamento numero ricevute bancarie incluse  *
      *              * nella distinta                                  *
      *              *-------------------------------------------------*
           if        srt-tip-sdb          =    09
                     add   1              to   w-srt-sdb-out-nrb      .
      *              *-------------------------------------------------*
      *              * Aggiornamento numero trette incluse nella di-   *
      *              * stinta                                          *
      *              *-------------------------------------------------*
           if        srt-tip-sdb          =    10
                     add   1              to   w-srt-sdb-out-ntr      .
      *              *-------------------------------------------------*
      *              * Aggiornamento numero effetti appartenenti alla  *
      *              * distinta e che sono gia' stati stampati         *
      *              *-------------------------------------------------*
           if        srt-tip-sdb          =    09 or
                     srt-tip-sdb          =    10
                     if      srt-flc-stp  >    zero
                             add   1      to   w-srt-sdb-out-ngs      .
      *              *-------------------------------------------------*
      *              * Put su catena movimenti [rig]                   *
      *              *-------------------------------------------------*
           perform   srt-put-wri-000      thru srt-put-wri-999        .
       srt-out-prc-600.
      *                  *---------------------------------------------*
      *                  * Tests vari su scadenza caricata             *
      *                  *---------------------------------------------*
       srt-out-prc-625.
      *                          *-------------------------------------*
      *                          * Su flags di sottoponibilita' a pu-  *
      *                          * lizia                               *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se flag di sottoponibilita' a   *
      *                              * pulizia a spaces : il controllo *
      *                              * e' superato                     *
      *                              *---------------------------------*
           if        srt-flg-pul          =    spaces
                     go to srt-out-prc-700.
      *                              *---------------------------------*
      *                              * Altrimenti                      *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Se si e' gia in sola Visua- *
      *                                  * lizzazione : continuazione  *
      *                                  *-----------------------------*
           if        w-cnt-mfu-tip-fun    =    "V"
                     go to srt-out-prc-700.
      *                                  *-----------------------------*
      *                                  * Messaggio di errore         *
      *                                  *-----------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      srt-num-sdb          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      spaces               to   w-err-box-err-msg      .
           string    "Attenzione : Anomalia relativa alla scadenza nr. "
                                delimited by   size
                     v-edt      delimited by   spaces
                     "!"        delimited by   size
                                          into w-err-box-err-msg      .
           move      "             La scadenza e' in corso di eliminazio
      -              "ne.            "    to   w-err-box-err-m02      .
           move      "             Pertanto la stampa effetti non e' amm
      -              "essa.          "    to   w-err-box-err-m03      .
           perform   box-msg-e03-000      thru box-msg-e03-999        .
      *                                  *-----------------------------*
      *                                  * Sola visualizzazione        *
      *                                  *                             *
      *                                  * N.B. : Il tipo funzionamen- *
      *                                  *        to in questo pro-    *
      *                                  *        gramma e' puramente  *
      *                                  *        convenzionale        *
      *                                  *-----------------------------*
           move      "V"                  to   w-cnt-mfu-tip-fun      .
       srt-out-prc-700.
      *                      *-----------------------------------------*
      *                      * Fine controlli relativi ai movimenti su *
      *                      * scadenza che possono essere eseguiti    *
      *                      * solamente post-composizione-distinta    *
      *                      *-----------------------------------------*
           go to     srt-out-prc-800.
       srt-out-prc-800.
      *              *-------------------------------------------------*
      *              * Riciclo a reperimento record dal sort           *
      *              *-------------------------------------------------*
           go to     srt-out-prc-200.
       srt-out-prc-999.
           exit.

      *    *===========================================================*
      *    * Procedure per memorizzazione scadenza in catena w-rig per *
      *    * sort scadenze della distinta per :                        *
      *    *                                                           *
      *    * -  Data di scadenza                                       *
      *    * -  Ragione sociale del debitore                           *
      *    * -  Tipo debitore                                          *
      *    * -  Codice debitore                                        *
      *    * -  Numero scadenza                                        *
      *    *-----------------------------------------------------------*
       srt-put-wri-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione dati non chiave riga corpo      *
      *              *-------------------------------------------------*
           perform   nor-nok-rig-000      thru nor-nok-rig-999        .
      *              *-------------------------------------------------*
      *              * Preparazione area w-rig, indice 1, da scadenza  *
      *              * letta in area sort [srt], ad esclusione del     *
      *              * numero progressivo                              *
      *              *-------------------------------------------------*
           perform   pre-wri-sdb-000      thru pre-wri-sdb-999        .
      *              *-------------------------------------------------*
      *              * Append di un record vuoto a fine catena         *
      *              *-------------------------------------------------*
           move      "AP"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Aggiornamento del numero progressivo            *
      *              *-------------------------------------------------*
           perform   prg-rig-cor-000      thru prg-rig-cor-999        .
      *              *-------------------------------------------------*
      *              * Duplicazione dati attuali su dati precedenti    *
      *              *-------------------------------------------------*
           move      w-rig-val-aep (1)    to   w-rig-val-aep (2)      .
      *              *-------------------------------------------------*
      *              * Update del record vuoto di fine catena          *
      *              *-------------------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-max        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       srt-put-wri-999.
           exit.

      *    *===========================================================*
