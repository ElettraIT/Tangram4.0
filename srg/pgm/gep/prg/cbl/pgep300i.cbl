      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-sce-tse-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-sce-tse-lun    to   v-car                  .
           move      w-exp-sce-tse-num    to   v-ldt                  .
           move      "MST#"               to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      w-exp-sce-tse-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      11                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-sce-tse (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-sce-tse-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-sce-tse-999.
       acc-sce-tse-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-sce-tse (1)      .
       acc-sce-tse-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-sce-tse-425.
      *                  *---------------------------------------------*
      *                  * Test che il valore non sia a zero, a meno   *
      *                  * che non si sia in Up                        *
      *                  *---------------------------------------------*
           if        w-tes-sce-tse (1)    not  = zero
                     go to acc-sce-tse-600.
           if        v-key                =    "UP  "
                     go to acc-sce-tse-600
           else      go to acc-sce-tse-100.
       acc-sce-tse-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-sce-tse-625.
      *                  *---------------------------------------------*
      *                  * Se tipo selezione effetti da stampare manu- *
      *                  * ale : si normalizza e si visualizza la      *
      *                  * scelta di stampa per le ricevute bancarie   *
      *                  *---------------------------------------------*
           if        w-tes-sce-tse (1)    not  = 02
                     go to acc-sce-tse-650.
           if        w-tes-sce-srb (1)    =    spaces
                     go to acc-sce-tse-650.
           move      spaces               to   w-tes-sce-srb (1)      .
           perform   vis-sce-srb-000      thru vis-sce-srb-999        .
       acc-sce-tse-650.
      *                  *---------------------------------------------*
      *                  * Se tipo selezione effetti da stampare manu- *
      *                  * ale : si normalizza e si visualizza la      *
      *                  * scelta di stampa per le tratte              *
      *                  *---------------------------------------------*
           if        w-tes-sce-tse (1)    not  = 02
                     go to acc-sce-tse-675.
           if        w-tes-sce-str (1)    =    spaces
                     go to acc-sce-tse-675.
           move      spaces               to   w-tes-sce-str (1)      .
           perform   vis-sce-str-000      thru vis-sce-str-999        .
       acc-sce-tse-675.
      *                  *---------------------------------------------*
      *                  * Fine dipendenze dall'impostazione           *
      *                  *---------------------------------------------*
           go to     acc-sce-tse-800.
       acc-sce-tse-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-sce-tse-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-sce-tse-100.
       acc-sce-tse-999.
           exit.

