      *    *===========================================================*
      *    * Routine post-conferma di inserimento                      *
      *    *-----------------------------------------------------------*
       pos-cnf-ins-000.
      *              *-------------------------------------------------*
      *              * Lettura record [ddp], senza lock                *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMDDP    "         to   f-key                  .
           move      w-tes-num-ddp (1)    to   rf-ddp-num-ddp         .
           move      "pgm/gep/fls/ioc/obj/iofddp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddp                 .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to pos-cnf-ins-200.
       pos-cnf-ins-100.
      *              *-------------------------------------------------*
      *              * Se record [ddp] non esistente                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   e01-cnf-ins-000      thru e01-cnf-ins-999        .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     pos-cnf-ins-999.
       pos-cnf-ins-200.
      *              *-------------------------------------------------*
      *              * Se record [ddp] esistente                       *
      *              *-------------------------------------------------*
       pos-cnf-ins-250.
      *                  *---------------------------------------------*
      *                  * Controllo che la distinta di presentazione  *
      *                  * non sia nel frattempo stata variata         *
      *                  *---------------------------------------------*
           if        rf-ddp-dtr-com       not  = w-tes-dtr-com (1) or
                     rf-ddp-dtr-pre       not  = w-tes-dtr-pre (1) or
                     rf-ddp-drc-pre       not  = w-tes-drc-pre (1) or
                     rf-ddp-npc-pre       not  = w-tes-npc-pre (1) or
                     rf-ddp-cod-cbp       not  = w-tes-cod-cbp (1) or
                     rf-ddp-snx-stp       not  = w-tes-snx-stp (1) or
                     rf-ddp-flc-stp       not  = w-tes-flc-stp (1) or
                     rf-ddp-snx-ads       not  = w-tes-snx-ads (1) or
                     rf-ddp-flc-ads       not  = w-tes-flc-ads (1) or
                     rf-ddp-tip-ias       not  = w-tes-tip-ias (1) or
                     rf-ddp-flc-ias       not  = w-tes-flc-ias (1) or
                     rf-ddp-dtr-act       not  = w-tes-dtr-act (1) or
                     rf-ddp-drc-act       not  = w-tes-drc-act (1) or
                     rf-ddp-npc-act       not  = w-tes-npc-act (1) or
                     rf-ddp-dtr-acd       not  = w-tes-dtr-acd (1) or
                     rf-ddp-drc-acd       not  = w-tes-drc-acd (1) or
                     rf-ddp-npc-acd       not  = w-tes-npc-acd (1) or
                     rf-ddp-flg-ela       not  = w-tes-flg-ela (1) or
                     rf-ddp-flg-pul       not  = w-tes-flg-pul (1)
                     go to pos-cnf-ins-275.
           go to     pos-cnf-ins-600.
       pos-cnf-ins-275.
      *                  *---------------------------------------------*
      *                  * Se la distinta di presentazione e' stata    *
      *                  * nel frattempo variata                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Emissione messaggio di errore           *
      *                      *-----------------------------------------*
           perform   e11-cnf-ins-000      thru e11-cnf-ins-999        .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     pos-cnf-ins-999.
       pos-cnf-ins-600.
      *                  *---------------------------------------------*
      *                  * Esecuzione della stampa effettiva degli ef- *
      *                  * fetti a fronte distinta, in foreground      *
      *                  *---------------------------------------------*
           perform   stp-frg-inc-000      thru stp-frg-inc-999        .
       pos-cnf-ins-999.
           exit.

      *    *===========================================================*
      *    * Messaggio di errore di tipo 01 su conferma impostazioni   *
      *    * per inserimento                                           *
      *    *                                                           *
      *    * Distinta di presentazione non piu' esistente              *
      *    *-----------------------------------------------------------*
       e01-cnf-ins-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      07                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      80                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Literal per 'Attenzione'                        *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      03                   to   v-pos                  .
           move      "Attenzione :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Contenuto per il literal di 'Attenzione'        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione numero distinta editato        *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      w-tes-num-ddp (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione contenuto literal di 'At-   *
      *                  * tenzione'                                   *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      63                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      16                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           string    "Non esiste piu' la distinta numero "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " !"       delimited by   size
                                          into v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Literal per 'Messaggio'                         *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      03                   to   v-pos                  .
           move      "Messaggio  :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Contenuto per il literal di 'Messaggio'         *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      63                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      16                   to   v-pos                  .
           move      "La stampa degli effetti non puo' pertanto essere e
      -              "seguita.     "      to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Literal per 'Presa visione'                     *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      38                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      "Premere un tasto per presa visione [ ]"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      16                   to   v-lin                  .
           move      77                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       e01-cnf-ins-999.
           exit.

      *    *===========================================================*
      *    * Messaggio di errore di tipo 02 su conferma impostazioni   *
      *    * per inserimento                                           *
      *    *                                                           *
      *    * Distinta di presentazione variata nel frattempo           *
      *    *-----------------------------------------------------------*
       e11-cnf-ins-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      07                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      80                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Literal per 'Attenzione'                        *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      03                   to   v-pos                  .
           move      "Attenzione :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Contenuto per il literal di 'Attenzione'        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione numero distinta editato        *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      "<"                  to   v-edm                  .
           move      w-tes-num-ddp (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione contenuto literal di 'At-   *
      *                  * tenzione'                                   *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      63                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      16                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           string    "La distinta numero "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " e' nel frattempo stata variata !"
                                delimited by   size
                                          into v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Literal per 'Messaggio'                         *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      03                   to   v-pos                  .
           move      "Messaggio  :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Contenuto per il literal di 'Messaggio'         *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      63                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      16                   to   v-pos                  .
           move      "La stampa degli effetti non puo' pertanto essere e
      -              "seguita.     "      to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Literal per 'Presa visione'                     *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      38                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      "Premere un tasto per presa visione [ ]"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
