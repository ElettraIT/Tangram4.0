      *                  *---------------------------------------------*
           move      srt-num-sdb          to   w-rig-num-sdb (1)      .
      *                  *---------------------------------------------*
      *                  * Tipo scadenza                               *
      *                  *---------------------------------------------*
           move      srt-tip-sdb          to   w-rig-tip-sdb (1)      .
      *                  *---------------------------------------------*
      *                  * Tipo acquisizione scadenza                  *
      *                  *---------------------------------------------*
           move      srt-tac-sdb          to   w-rig-tac-sdb (1)      .
      *                  *---------------------------------------------*
      *                  * Data scadenza                               *
      *                  *---------------------------------------------*
           move      srt-dts-sdb          to   w-rig-dts-sdb (1)      .
      *                  *---------------------------------------------*
      *                  * Tipo debitore                               *
      *                  *---------------------------------------------*
           move      srt-tip-dbt          to   w-rig-tip-dbt (1)      .
      *                  *---------------------------------------------*
      *                  * Codice debitore                             *
      *                  *---------------------------------------------*
           move      srt-cod-dbt          to   w-rig-cod-dbt (1)      .
      *                  *---------------------------------------------*
      *                  * Codice dipendenza del debitore              *
      *                  *---------------------------------------------*
           move      srt-dpz-dbt          to   w-rig-dpz-dbt (1)      .
      *                  *---------------------------------------------*
      *                  * Inoltro scadenza al debitore                *
      *                  *---------------------------------------------*
           move      srt-inl-sdb          to   w-rig-inl-sdb (1)      .
      *                  *---------------------------------------------*
      *                  * Importo scadenza                            *
      *                  *---------------------------------------------*
           move      srt-imp-sdb          to   w-rig-imp-sdb (1)      .
      *                  *---------------------------------------------*
      *                  * Codice ABI per l'appoggio                   *
      *                  *---------------------------------------------*
           move      srt-abi-app          to   w-rig-abi-app (1)      .
      *                  *---------------------------------------------*
      *                  * Codice CAB per l'appoggio                   *
      *                  *---------------------------------------------*
           move      srt-cab-app          to   w-rig-cab-app (1)      .
      *                  *---------------------------------------------*
      *                  * Codice C/C per l'appoggio                   *
      *                  *---------------------------------------------*
           move      srt-ccc-app          to   w-rig-ccc-app (1)      .
      *                  *---------------------------------------------*
      *                  * Data documento di riferimento               *
      *                  *---------------------------------------------*
           move      srt-dat-ddr          to   w-rig-dat-ddr (1)      .
      *                  *---------------------------------------------*
      *                  * Numero documento di riferimento             *
      *                  *---------------------------------------------*
           move      srt-num-ddr          to   w-rig-num-ddr (1)      .
      *                  *---------------------------------------------*
      *                  * Tipo documento di riferimento               *
      *                  *---------------------------------------------*
           move      srt-tip-ddr          to   w-rig-tip-ddr (1)      .
      *                  *---------------------------------------------*
      *                  * Importo documento di riferimento            *
      *                  *---------------------------------------------*
           move      srt-imp-ddr          to   w-rig-imp-ddr (1)      .
      *                  *---------------------------------------------*
      *                  * Numero rata documento di riferimento        *
      *                  *---------------------------------------------*
           move      srt-nra-ddr          to   w-rig-nra-ddr (1)      .
      *                  *---------------------------------------------*
      *                  * Tipo avviso ottenuto                        *
      *                  *---------------------------------------------*
           move      srt-tav-ott          to   w-rig-tav-ott (1)      .
      *                  *---------------------------------------------*
      *                  * Flag contatore di stampa effetto eseguita   *
      *                  *---------------------------------------------*
           move      srt-flc-stp          to   w-rig-flc-stp (1)      .
      *                  *---------------------------------------------*
      *                  * Status scadenza                             *
      *                  *---------------------------------------------*
           move      srt-sts-sca          to   w-rig-sts-sca (1)      .
       pre-wri-sdb-500.
      *              *-------------------------------------------------*
      *              * Valori ottenuti indirettamente                  *
      *              *-------------------------------------------------*
       pre-wri-sdb-525.
      *                  *---------------------------------------------*
      *                  * Codice debitore, ragione sociale            *
      *                  *                  indirizzo                  *
      *                  *                  localita'                  *
      *                  *---------------------------------------------*
           move      w-rig-tip-dbt (1)    to   w-let-arc-dbt-tip      .
           move      w-rig-cod-dbt (1)    to   w-let-arc-dbt-cod      .
           perform   let-arc-dbt-000      thru let-arc-dbt-999        .
           move      w-let-arc-dbt-rag    to   w-rig-cod-dbt-rag (1)  .
           move      w-let-arc-dbt-via    to   w-rig-cod-dbt-via (1)  .
           move      w-let-arc-dbt-loc    to   w-rig-cod-dbt-loc (1)  .
       pre-wri-sdb-550.
      *                  *---------------------------------------------*
      *                  * Codice dipendenza del debitore, ragione so- *
      *                  * ciale, indirizzo, localita'                 *
      *                  *---------------------------------------------*
           move      w-rig-tip-dbt (1)    to   w-let-dpz-dbt-tip      .
           move      w-rig-cod-dbt (1)    to   w-let-dpz-dbt-cod      .
           move      w-rig-dpz-dbt (1)    to   w-let-dpz-dbt-dpz      .
           perform   let-dpz-dbt-000      thru let-dpz-dbt-999        .
           move      w-let-dpz-dbt-rag    to   w-rig-dpz-dbt-rag (1)  .
           move      w-let-dpz-dbt-via    to   w-rig-dpz-dbt-via (1)  .
           move      w-let-dpz-dbt-loc    to   w-rig-dpz-dbt-loc (1)  .
       pre-wri-sdb-999.
           exit.

