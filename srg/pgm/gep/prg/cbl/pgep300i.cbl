      *                  * anagrafica cliente contabile                *
      *                  *---------------------------------------------*
           if        w-rig-cod-dbt (1)    =    zero
                     go to det-gdd-inl-400.
      *                  *---------------------------------------------*
      *                  * Lettura da anagrafica cliente commerciale   *
      *                  * per la sede                                 *
      *                  *---------------------------------------------*
           move      "C"                  to   w-let-arc-dcc-tle      .
           move      w-rig-cod-dbt (1)    to   w-let-arc-dcc-cod      .
           move      spaces               to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                  *---------------------------------------------*
      *                  * Se record non trovato : a lettura da ana-   *
      *                  * grafica cliente contabile                   *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-flg    not  = spaces
                     go to det-gdd-inl-400.
      *                  *---------------------------------------------*
      *                  * Se record trovato                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Spostamento dati                        *
      *                      *-----------------------------------------*
           move      w-let-arc-dcc-rag    to   w-sta-eff-deb-rag      .
           move      w-let-arc-dcc-via    to   w-sta-eff-deb-via      .
           move      w-let-arc-dcc-loc    to   w-sta-eff-deb-loc      .
      *                      *-----------------------------------------*
      *                      * A uscita                                *
      *                      *-----------------------------------------*
           go to     det-gdd-inl-900.
       det-gdd-inl-400.
      *              *-------------------------------------------------*
      *              * Se inoltro alla sede legale                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura da anagrafica cliente contabile     *
      *                  *---------------------------------------------*
           move      w-rig-tip-dbt (1)    to   w-let-arc-dbt-tip      .
           move      w-rig-cod-dbt (1)    to   w-let-arc-dbt-cod      .
           perform   let-arc-dbt-000      thru let-arc-dbt-999        .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda se record trovato op-  *
      *                  * pure no                                     *
      *                  *---------------------------------------------*
           if        w-let-arc-dbt-flg    =    spaces
                     go to det-gdd-inl-420
           else      go to det-gdd-inl-440.
       det-gdd-inl-420.
      *                  *---------------------------------------------*
      *                  * Se record trovato                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Spostamento dati                        *
      *                      *-----------------------------------------*
           move      w-let-arc-dbt-rag    to   w-sta-eff-deb-rag      .
           move      w-let-arc-dbt-via    to   w-sta-eff-deb-via      .
           move      w-let-arc-dbt-loc    to   w-sta-eff-deb-loc      .
      *                      *-----------------------------------------*
      *                      * A uscita                                *
      *                      *-----------------------------------------*
           go to     det-gdd-inl-900.
       det-gdd-inl-440.
      *                  *---------------------------------------------*
      *                  * Se record non trovato                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Riempimento con puntini                 *
      *                      *-----------------------------------------*
           move      all   "."            to   w-sta-eff-deb-rag      .
           move      all   "."            to   w-sta-eff-deb-via      .
           move      all   "."            to   w-sta-eff-deb-loc      .
      *                      *-----------------------------------------*
      *                      * A uscita                                *
      *                      *-----------------------------------------*
           go to     det-gdd-inl-900.
       det-gdd-inl-600.
      *              *-------------------------------------------------*
      *              * Se inoltro alla dipendenza                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se il tipo debitore indica che non si trat- *
      *                  * ta di un cliente : a lettura da anagrafica  *
      *                  * cliente contabile                           *
      *                  *---------------------------------------------*
           if        w-rig-tip-dbt (1)    >    01
                     go to det-gdd-inl-400.
      *                  *---------------------------------------------*
      *                  * Se codice debitore a zero : a lettura da    *
      *                  * anagrafica cliente commerciale              *
      *                  *---------------------------------------------*
           if        w-rig-cod-dbt (1)    =    zero
                     go to det-gdd-inl-200.
      *                  *---------------------------------------------*
      *                  * Se codice dipendenza a spaces : a lettura   *
      *                  * anagrafica cliente commerciale              *
      *                  *---------------------------------------------*
           if        w-rig-dpz-dbt (1)    =    spaces
                     go to det-gdd-inl-200.
      *                  *---------------------------------------------*
      *                  * Lettura da anagrafica cliente commerciale   *
      *                  * per la dipendenza                           *
      *                  *---------------------------------------------*
           move      "D"                  to   w-let-arc-dcc-tle      .
           move      w-rig-cod-dbt (1)    to   w-let-arc-dcc-cod      .
           move      w-rig-dpz-dbt (1)    to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                  *---------------------------------------------*
      *                  * Se record non trovato : a lettura da ana-   *
      *                  * grafica cliente commerciale                 *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-flg    not  = spaces
                     go to det-gdd-inl-200.
      *                  *---------------------------------------------*
      *                  * Se record trovato                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Spostamento dati                        *
      *                      *-----------------------------------------*
           move      w-let-arc-dcc-rag    to   w-sta-eff-deb-rag      .
           move      w-let-arc-dcc-via    to   w-sta-eff-deb-via      .
           move      w-let-arc-dcc-loc    to   w-sta-eff-deb-loc      .
      *                      *-----------------------------------------*
      *                      * A uscita                                *
      *                      *-----------------------------------------*
           go to     det-gdd-inl-900.
       det-gdd-inl-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-gdd-inl-999.
       det-gdd-inl-999.
           exit.

      *    *===========================================================*
      *    * Aggiornamento flag/contatore di stampa su effetto sele-   *
      *    * zionato                                                   *
      *    *-----------------------------------------------------------*
       agg-eff-sel-000.
      *              *-------------------------------------------------*
      *              * Lettura record [sdb] con lock                   *
      *              *-------------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMSDB    "         to   f-key                  .
           move      w-rig-num-sdb (1)    to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito della lettura   *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to agg-eff-sel-200.
       agg-eff-sel-100.
      *              *-------------------------------------------------*
      *              * Se record [sdb] non esistente                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita senza alcun aggiornamento            *
      *                  *---------------------------------------------*
           go to     agg-eff-sel-999.
       agg-eff-sel-200.
      *              *-------------------------------------------------*
      *              * Se record [sdb] esistente                       *
      *              *-------------------------------------------------*
       agg-eff-sel-220.
      *                  *---------------------------------------------*
      *                  * Flag/contatore di stampa su carta eseguita  *
      *                  * per la scadenza                             *
      *                  *---------------------------------------------*
           if        rf-sdb-flc-stp       <    99
                     add    1             to   rf-sdb-flc-stp         .
      *                  *---------------------------------------------*
      *                  * Aggiornamento data chiusura scadenza        *
      *                  *---------------------------------------------*
           perform   det-dat-chs-000      thru det-dat-chs-999        .
       agg-eff-sel-240.
      *                  *---------------------------------------------*
      *                  * Update record [sdb]                         *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
       agg-eff-sel-260.
      *                  *---------------------------------------------*
      *                  * Unlock record [sdb]                         *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
       agg-eff-sel-280.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     agg-eff-sel-999.
       agg-eff-sel-999.
           exit.

      *    *===========================================================*
      *    * Lettura personalizzazioni portafoglio S.I.A.              *
      *    *-----------------------------------------------------------*
       prs-gep-sia-000.
      *              *-------------------------------------------------*
      *              * Lettura record personalizzazioni                *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODGEP    "         to   f-key                  .
           move      10                   to   rf-gep-tip-gep         .
           move      "SIA       "         to   rf-gep-cod-gep         .
           move      "pgm/gep/fls/ioc/obj/iofgep"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gep                 .
      *              *-------------------------------------------------*
      *              * Deviazione secondo l'esito della lettura        *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to prs-gep-sia-200
           else      go to prs-gep-sia-400.
       prs-gep-sia-200.
      *              *-------------------------------------------------*
      *              * Se record personalizzazioni esistente           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Dati record in area per ridefinizione delle *
      *                  * personalizzazioni portafoglio S.I.A.        *
      *                  *---------------------------------------------*
           move      rf-gep-dat-rec       to   w-prs-sia-dat-rec      .
      *                  *---------------------------------------------*
      *                  * Eventuali normalizzazioni                   *
      *                  *---------------------------------------------*
           if        w-prs-sia-cda-sia    not  numeric
                     move  zero           to   w-prs-sia-cda-sia      .
           if        w-prs-sia-num-aut    not  numeric
                     move  zero           to   w-prs-sia-num-aut      .
           if        w-prs-sia-dat-aut    not  numeric
                     move  zero           to   w-prs-sia-dat-aut      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     prs-gep-sia-999.
       prs-gep-sia-400.
      *              *-------------------------------------------------*
      *              * Se record personalizzazioni non esistente       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione area per ridefinizione del- *
      *                  * le personalizzazioni portafoglio S.I.A.     *
      *                  *---------------------------------------------*
           move      spaces               to   w-prs-sia-daz-001      .
           move      spaces               to   w-prs-sia-daz-002      .
           move      spaces               to   w-prs-sia-daz-003      .
           move      spaces               to   w-prs-sia-daz-004      .
           move      spaces               to   w-prs-sia-fir-emi      .
           move      zero                 to   w-prs-sia-cda-sia      .
           move      spaces               to   w-prs-sia-cor-ndg      .
           move      spaces               to   w-prs-sia-pvc-aut      .
           move      zero                 to   w-prs-sia-num-aut      .
           move      zero                 to   w-prs-sia-dat-aut      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     prs-gep-sia-999.
       prs-gep-sia-999.
           exit.

      *    *===========================================================*
      *    * Caricamento iniziale tabella per calcolo spese bollo su   *
      *    * effetti                                                   *
      *    *-----------------------------------------------------------*
       spe-bol-loa-000.
      *              *-------------------------------------------------*
      *              * Open file [zsb]                                 *
      *              *-------------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofzsb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zsb                 .
       spe-bol-loa-100.
      *              *-------------------------------------------------*
      *              * Caricamento tabella                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizializzazione indice per tabella spese   *
      *                  * bollo per tipo scadenza                     *
      *                  *---------------------------------------------*
           move      zero                 to   w-spe-bol-inx-pag      .
       spe-bol-loa-200.
      *                  *---------------------------------------------*
      *                  * Incremento indice per tabella spese bollo   *
      *                  * per tipo scadenza                           *
      *                  *---------------------------------------------*
           add       1                    to   w-spe-bol-inx-pag      .
      *                  *---------------------------------------------*
      *                  * Se oltre il valore massimo : fine carica-   *
      *                  * mento                                       *
      *                  *---------------------------------------------*
           if        w-spe-bol-inx-pag    >    3
                     go to spe-bol-loa-900.
       spe-bol-loa-300.
      *                  *---------------------------------------------*
      *                  * Lettura tabella spese bollo relativa al ti- *
      *                  * po di pagamento corrispondente all'indice   *
      *                  * su tabella                                  *
      *                  *                                             *
      *                  * Indice 01 : Tipo pagamento 09 : Ric. Banc.  *
      *                  * Indice 02 : Tipo pagamento 10 : Tratte      *
      *                  * Indice 03 : Tipo pagamento 11 : Paghero'    *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "TIPPAG    "         to   f-key                  .
           if        w-spe-bol-inx-pag    =    01
                     move  09             to   rf-zsb-tip-pag
           else if   w-spe-bol-inx-pag    =    02
                     move  10             to   rf-zsb-tip-pag
           else if   w-spe-bol-inx-pag    =    03
                     move  11             to   rf-zsb-tip-pag
           else      move  zero           to   rf-zsb-tip-pag         .
           move      "pgm/gep/fls/ioc/obj/iofzsb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zsb                 .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'esito della let-  *
      *                  * tura                                        *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to spe-bol-loa-500.
       spe-bol-loa-400.
      *                  *---------------------------------------------*
      *                  * Se record non esistente                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione record tabella          *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofzsb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zsb                 .
      *                      *-----------------------------------------*
      *                      * Segnale di elemento non esistente       *
      *                      *-----------------------------------------*
           move      "N"                  to   w-spe-bol-snx-ele
                                              (w-spe-bol-inx-pag)     .
      *                      *-----------------------------------------*
      *                      * A bufferizzazione elemento              *
      *                      *-----------------------------------------*
           go to     spe-bol-loa-600.
       spe-bol-loa-500.
      *                  *---------------------------------------------*
      *                  * Se record esistente                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Segnale di elemento esistente           *
      *                      *-----------------------------------------*
           move      "S"                  to   w-spe-bol-snx-ele
                                              (w-spe-bol-inx-pag)     .
      *                      *-----------------------------------------*
      *                      * A bufferizzazione elemento              *
      *                      *-----------------------------------------*
           go to     spe-bol-loa-600.
       spe-bol-loa-600.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione elemento                    *
      *                  *---------------------------------------------*
       spe-bol-loa-620.
      *                      *-----------------------------------------*
      *                      * Tipo di automatismo per calcolo spesa   *
      *                      *-----------------------------------------*
           move      rf-zsb-tau-spb       to   w-spe-bol-tau-spb
                                              (w-spe-bol-inx-pag)     .
       spe-bol-loa-640.
      *                      *-----------------------------------------*
      *                      * Percentuale per la determinazione delle *
      *                      * spese bollo                             *
      *                      *-----------------------------------------*
           move      rf-zsb-per-spb       to   w-spe-bol-per-spb
                                              (w-spe-bol-inx-pag)     .
       spe-bol-loa-660.
      *                      *-----------------------------------------*
      *                      * Tabella scaglioni                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Inizializzazione indice 1..10       *
      *                          *-------------------------------------*
           move      zero                 to   w-spe-bol-inx-scg      .
       spe-bol-loa-665.
      *                          *-------------------------------------*
      *                          * Incremento indice 1..10             *
      *                          *-------------------------------------*
           add       1                    to   w-spe-bol-inx-scg      .
      *                          *-------------------------------------*
      *                          * Se oltre il massimo : fine scaglio- *
      *                          * ni                                  *
      *                          *-------------------------------------*
           if        w-spe-bol-inx-scg    >    10
                     go to spe-bol-loa-700.
       spe-bol-loa-670.
      *                          *-------------------------------------*
      *                          * Elemento dello scaglione            *
      *                          *-------------------------------------*
       spe-bol-loa-672.
      *                              *---------------------------------*
      *                              * Scaglione                       *
      *                              *---------------------------------*
           move      rf-zsb-tbe-scg
                    (w-spe-bol-inx-scg)   to   w-spe-bol-tbe-scg
                                              (w-spe-bol-inx-pag,
                                               w-spe-bol-inx-scg)     .
       spe-bol-loa-674.
      *                              *---------------------------------*
      *                              * Ammontare sullo scaglione       *
      *                              *---------------------------------*
           move      rf-zsb-tbe-asc
                    (w-spe-bol-inx-scg)   to   w-spe-bol-tbe-asc
                                              (w-spe-bol-inx-pag,
                                               w-spe-bol-inx-scg)     .
       spe-bol-loa-676.
      *                              *---------------------------------*
      *                              * Percentuale sullo scaglione     *
      *                              *---------------------------------*
           move      rf-zsb-tbe-psc
                    (w-spe-bol-inx-scg)   to   w-spe-bol-tbe-psc
                                              (w-spe-bol-inx-pag,
                                               w-spe-bol-inx-scg)     .
       spe-bol-loa-680.
      *                          *-------------------------------------*
      *                          * Ad elemento successivo per lo sca-  *
      *                          * glione                              *
      *                          *-------------------------------------*
           go to     spe-bol-loa-665.
       spe-bol-loa-700.
      *                      *-----------------------------------------*
      *                      * Tetto di esenzione per la spesa         *
      *                      *-----------------------------------------*
           move      rf-zsb-tet-spb       to   w-spe-bol-tet-spb
                                              (w-spe-bol-inx-pag)     .
       spe-bol-loa-720.
      *                      *-----------------------------------------*
      *                      * Valore minimo per la spesa              *
      *                      *-----------------------------------------*
           move      rf-zsb-min-spb       to   w-spe-bol-min-spb
                                              (w-spe-bol-inx-pag)     .
       spe-bol-loa-740.
      *                      *-----------------------------------------*
      *                      * Valore massimo per la spesa             *
      *                      *-----------------------------------------*
           move      rf-zsb-max-spb       to   w-spe-bol-max-spb
                                              (w-spe-bol-inx-pag)     .
       spe-bol-loa-760.
      *                      *-----------------------------------------*
      *                      * Tipo di arrotondamento                  *
      *                      *-----------------------------------------*
           move      rf-zsb-tar-spb       to   w-spe-bol-tar-spb
                                              (w-spe-bol-inx-pag)     .
       spe-bol-loa-780.
      *                      *-----------------------------------------*
      *                      * Valore di arrotondamento                *
      *                      *-----------------------------------------*
           move      rf-zsb-var-spb       to   w-spe-bol-var-spb
                                              (w-spe-bol-inx-pag)     .
       spe-bol-loa-800.
      *                  *---------------------------------------------*
      *                  * Riciclo su elemento di tabella successivo   *
      *                  *---------------------------------------------*
           go to     spe-bol-loa-200.
       spe-bol-loa-900.
      *              *-------------------------------------------------*
      *              * Close file [zsb]                                *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofzsb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zsb                 .
       spe-bol-loa-999.
           exit.

      *    *===========================================================*
      *    * Calcolo totale spese bollo su effetti                     *
      *    *                                                           *
      *    * Input  : w-spe-bol-tip-sdb = tipo scadenza                *
      *    *                              - 01 Ricevuta bancaria       *
      *    *                              - 02 Tratta                  *
      *    *                              - 03 Paghero'                *
      *    *           w-spe-bol-imp-sdb = importo scadenza            *
      *    *                                                           *
      *    * Output : w-spe-bol-spe-bol = importo spese bolle          *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       spe-bol-sdb-000.
      *              *-------------------------------------------------*
      *              * Azzeramento importo spese bollo calcolate       *
      *              *-------------------------------------------------*
           move      zero                 to   w-spe-bol-spe-bol      .
      *              *-------------------------------------------------*
      *              * Se importo scadenza non superiore a zero : u-   *
      *              * scita con importo spese bollo calcolate a zero  *
      *              *-------------------------------------------------*
           if        w-spe-bol-imp-sdb    not  > zero
                     go to spe-bol-sdb-999.
      *              *-------------------------------------------------*
      *              * Determinazione indice per il tipo pagamento su  *
      *              * tabella spese bollo per tipo scadenza           *
      *              *-------------------------------------------------*
           if        w-spe-bol-tip-sdb    =    09
                     move  01             to   w-spe-bol-inx-pag
           else if   w-spe-bol-tip-sdb    =    10
                     move  02             to   w-spe-bol-inx-pag
           else if   w-spe-bol-tip-sdb    =    11
                     move  03             to   w-spe-bol-inx-pag
           else      move  zero           to   w-spe-bol-inx-pag      .
      *              *-------------------------------------------------*
      *              * Se indice non determinabile : uscita con impor- *
      *              * to spese bollo calcolate a zero                 *
      *              *-------------------------------------------------*
           if        w-spe-bol-inx-pag    =    zero
                     go to spe-bol-sdb-999.
      *              *-------------------------------------------------*
      *              * Se elemento non esistente in tabella : uscita   *
      *              * con importo spese bollo calcolate a zero        *
      *              *-------------------------------------------------*
           if        w-spe-bol-snx-ele
                    (w-spe-bol-inx-pag)   not  = "S"
                     go to spe-bol-sdb-999.
      *              *-------------------------------------------------*
      *              * Se l'importo scadenza non e' maggiore del tetto *
      *              * di esenzione : uscita con importo spese bollo   *
      *              * calcolate a zero                                *
      *              *-------------------------------------------------*
           if        w-spe-bol-imp-sdb    not  > w-spe-bol-tet-spb
                                                (w-spe-bol-inx-pag)
                     go to spe-bol-sdb-999.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo di automatismo, *
      *              * e se tipo di automatismo non riconosciuto : u-  *
      *              * scita con importo spese bollo calcolate a zero  *
      *              *-------------------------------------------------*
           if        w-spe-bol-tau-spb
                    (w-spe-bol-inx-pag)   =    01
                     go to spe-bol-sdb-100
           else if   w-spe-bol-tau-spb
                    (w-spe-bol-inx-pag)   =    02
                     go to spe-bol-sdb-200
           else if   w-spe-bol-tau-spb
                    (w-spe-bol-inx-pag)   =    03
                     go to spe-bol-sdb-300
           else      go to spe-bol-sdb-999.
       spe-bol-sdb-100.
      *              *-------------------------------------------------*
      *              * Se tipo di automatismo 01 : in percentuale sul  *
      *              * totale scadenza                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione importo spese bollo          *
      *                  *---------------------------------------------*
           multiply  w-spe-bol-per-spb
                    (w-spe-bol-inx-pag)   by   w-spe-bol-imp-sdb
                                        giving w-spe-bol-wrk-s01      .
           divide    100                  into w-spe-bol-wrk-s01
                                        giving w-spe-bol-spe-bol
                                                         rounded      .
      *                  *---------------------------------------------*
      *                  * Ad arrotondamenti                           *
      *                  *---------------------------------------------*
           go to     spe-bol-sdb-500.
       spe-bol-sdb-200.
      *              *-------------------------------------------------*
      *              * Se tipo di automatismo 02 : a scaglioni         *
      *              *-------------------------------------------------*
       spe-bol-sdb-220.
      *                  *---------------------------------------------*
      *                  * Ricerca importo scadenza tra gli scaglioni, *
      *                  * se non trovato : uscita con importo spese   *
      *                  * bollo calcolate a zero                      *
      *                  *---------------------------------------------*
           move      zero                 to   w-spe-bol-inx-scg      .
       spe-bol-sdb-225.
           add       1                    to   w-spe-bol-inx-scg      .
           if        w-spe-bol-inx-scg    >    10
                     go to spe-bol-sdb-999.
           if        w-spe-bol-tbe-scg
                    (w-spe-bol-inx-pag,
                     w-spe-bol-inx-scg)   =    zero
                     go to spe-bol-sdb-225.
           if        w-spe-bol-imp-sdb    >    w-spe-bol-tbe-scg
                                              (w-spe-bol-inx-pag,
                                               w-spe-bol-inx-scg)
                     go to spe-bol-sdb-225.
       spe-bol-sdb-240.
      *                  *---------------------------------------------*
      *                  * Se scaglione trovato si pone l'ammontare    *
      *                  * per lo scaglione come importo spese cal-    *
      *                  * colate                                      *
      *                  *---------------------------------------------*
           move      w-spe-bol-tbe-asc
                    (w-spe-bol-inx-pag,
                     w-spe-bol-inx-scg)   to   w-spe-bol-spe-bol      .
      *                  *---------------------------------------------*
      *                  * E poi ad arrotondamenti                     *
      *                  *---------------------------------------------*
           go to     spe-bol-sdb-500.
       spe-bol-sdb-300.
      *              *-------------------------------------------------*
      *              * Se tipo di automatismo 03 : a scaglioni con     *
      *              *                             percentuale sul-    *
      *              *                             l'eccedenza         *
      *              *-------------------------------------------------*
       spe-bol-sdb-310.
      *                  *---------------------------------------------*
      *                  * Inizializzazione comodo per imponibile spe- *
      *                  * sa decrescente                              *
      *                  *---------------------------------------------*
           move      w-spe-bol-imp-sdb    to   w-spe-bol-ibl-t03      .
      *                  *---------------------------------------------*
      *                  * Inizializzazione indice per scansione della *
      *                  * tabella degli scaglioni                     *
      *                  *---------------------------------------------*
           move      zero                 to   w-spe-bol-inx-scg      .
       spe-bol-sdb-320.
      *                  *---------------------------------------------*
      *                  * Incremento indice per scansione della ta-   *
      *                  * bella degli scaglioni                       *
      *                  *---------------------------------------------*
           add       1                    to   w-spe-bol-inx-scg      .
      *                  *---------------------------------------------*
      *                  * Se fine tabella : ad arrotondamenti         *
      *                  *---------------------------------------------*
           if        w-spe-bol-inx-scg    >    10
                     go to spe-bol-sdb-500.
      *                  *---------------------------------------------*
      *                  * Se scaglione a zero : lo si ignora          *
      *                  *---------------------------------------------*
           if        w-spe-bol-tbe-scg
                    (w-spe-bol-inx-pag,
                     w-spe-bol-inx-scg)   =    zero
                     go to spe-bol-sdb-320.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del confronto tra l'-  *
      *                  * importo scaglione e l'importo del residuo   *
      *                  * decrescente                                 *
      *                  *---------------------------------------------*
           if        w-spe-bol-tbe-scg
                    (w-spe-bol-inx-pag,
                     w-spe-bol-inx-scg)   <    w-spe-bol-ibl-t03
                     go to spe-bol-sdb-330
           else if   w-spe-bol-tbe-scg
                    (w-spe-bol-inx-pag,
                     w-spe-bol-inx-scg)   =    w-spe-bol-ibl-t03
                     go to spe-bol-sdb-340
           else      go to spe-bol-sdb-350.
       spe-bol-sdb-330.
      *                  *---------------------------------------------*
      *                  * Se l'importo scaglione e' minore del resi-  *
      *                  * duo imponibile decrescente                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Calcolo quota spesa bollo relativa allo *
      *                      * scaglione                               *
      *                      *-----------------------------------------*
           multiply  w-spe-bol-tbe-psc
                    (w-spe-bol-inx-pag,
                     w-spe-bol-inx-scg)   by   w-spe-bol-tbe-scg
                                              (w-spe-bol-inx-pag,
                                               w-spe-bol-inx-scg)
                                        giving w-spe-bol-wrk-s01
                                                         rounded      .
           divide    100                  into w-spe-bol-wrk-s01
                                        giving w-spe-bol-wrk-s02
                                                         rounded      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento importo spese bollo cal-  *
      *                      * colate                                  *
      *                      *-----------------------------------------*
           add       w-spe-bol-wrk-s02    to   w-spe-bol-spe-bol      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento importo residuo decre-    *
      *                      * scente                                  *
      *                      *-----------------------------------------*
           subtract  w-spe-bol-tbe-scg
                    (w-spe-bol-inx-pag,
                     w-spe-bol-inx-scg)   from w-spe-bol-ibl-t03      .
      *                      *-----------------------------------------*
      *                      * Riciclo a scaglione successivo          *
      *                      *-----------------------------------------*
           go to     spe-bol-sdb-320.
       spe-bol-sdb-340.
      *                  *---------------------------------------------*
      *                  * Se l'importo scaglione e' uguale al resi-   *
      *                  * duo imponibile decrescente                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Calcolo quota spesa bollo relativa allo *
      *                      * scaglione                               *
      *                      *-----------------------------------------*
           multiply  w-spe-bol-tbe-psc
                    (w-spe-bol-inx-pag,
                     w-spe-bol-inx-scg)   by   w-spe-bol-tbe-scg
                                              (w-spe-bol-inx-pag,
                                               w-spe-bol-inx-scg)
                                        giving w-spe-bol-wrk-s01
                                                         rounded      .
           divide    100                  into w-spe-bol-wrk-s01
                                        giving w-spe-bol-wrk-s02
                                                         rounded      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento importo spese bollo cal-  *
      *                      * colate                                  *
      *                      *-----------------------------------------*
           add       w-spe-bol-wrk-s02    to   w-spe-bol-spe-bol      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento importo residuo decre-    *
      *                      * scente                                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-spe-bol-ibl-t03      .
      *                      *-----------------------------------------*
      *                      * Ad arrotondamenti                       *
      *                      *-----------------------------------------*
           go to     spe-bol-sdb-500.
       spe-bol-sdb-350.
      *                  *---------------------------------------------*
      *                  * Se l'importo scaglione e' maggiore del re-  *
      *                  * siduo imponibile decrescente                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Calcolo quota spesa bollo relativa al   *
      *                      * residuo decrescente                     *
      *                      *-----------------------------------------*
           multiply  w-spe-bol-tbe-psc
                    (w-spe-bol-inx-pag,
                     w-spe-bol-inx-scg)   by   w-spe-bol-ibl-t03
                                        giving w-spe-bol-wrk-s01
                                                         rounded      .
           divide    100                  into w-spe-bol-wrk-s01
                                        giving w-spe-bol-wrk-s02
                                                         rounded      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento importo spese bollo cal-  *
      *                      * colate                                  *
      *                      *-----------------------------------------*
           add       w-spe-bol-wrk-s02    to   w-spe-bol-spe-bol      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento importo residuo decre-    *
      *                      * scente                                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-spe-bol-ibl-t03      .
      *                      *-----------------------------------------*
      *                      * Ad arrotondamenti                       *
      *                      *-----------------------------------------*
           go to     spe-bol-sdb-500.
       spe-bol-sdb-500.
      *              *-------------------------------------------------*
      *              * Arrotondamenti finali                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se importo spesa a zero : nessun arrotonda- *
      *                  * mento                                       *
      *                  *---------------------------------------------*
           if        w-spe-bol-spe-bol    =    zero
                     go to spe-bol-sdb-900.
       spe-bol-sdb-550.
      *                  *---------------------------------------------*
      *                  * Su valore minimo per l'importo spesa        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore minimo per l'importo spesa a  *
      *                      * zero : nessuna azione                   *
      *                      *-----------------------------------------*
           if        w-spe-bol-min-spb
                    (w-spe-bol-inx-pag)   =    zero
                     go to spe-bol-sdb-600.
      *                      *-----------------------------------------*
      *                      * Se l'importo spesa bollo sin qui calco- *
      *                      * lato e' inferiore all'importo minimo :  *
      *                      * si forza il valore minimo               *
      *                      *-----------------------------------------*
           if        w-spe-bol-spe-bol    <    w-spe-bol-min-spb
                                              (w-spe-bol-inx-pag)
                     move  w-spe-bol-min-spb
                          (w-spe-bol-inx-pag)
                                          to   w-spe-bol-spe-bol      .
       spe-bol-sdb-600.
      *                  *---------------------------------------------*
      *                  * Su valore massimo per l'importo spesa       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore massimo per l'importo spesa a *
      *                      * zero : nessuna azione                   *
      *                      *-----------------------------------------*
           if        w-spe-bol-max-spb
                    (w-spe-bol-inx-pag)   =    zero
                     go to spe-bol-sdb-650.
      *                      *-----------------------------------------*
      *                      * Se l'importo spesa bollo sin qui calco- *
      *                      * lato e' superiore all'importo massimo : *
      *                      * si forza il valore massimo              *
      *                      *-----------------------------------------*
           if        w-spe-bol-spe-bol    >    w-spe-bol-max-spb
                                              (w-spe-bol-inx-pag)
                     move  w-spe-bol-max-spb
                          (w-spe-bol-inx-pag)
                                          to   w-spe-bol-spe-bol      .
       spe-bol-sdb-650.
      *                  *---------------------------------------------*
      *                  * Arrotondamento vero e proprio               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore di arrotondamento a zero : no *
      *                      * arrotondamento                          *
      *                      *-----------------------------------------*
           if        w-spe-bol-var-spb
                    (w-spe-bol-inx-pag)   =    zero
                     go to spe-bol-sdb-900.
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo arro-   *
      *                      * tondamento                              *
      *                      *-----------------------------------------*
           go to     spe-bol-sdb-700
                     spe-bol-sdb-750
                     spe-bol-sdb-800
                     spe-bol-sdb-850
                                depending on   w-spe-bol-tar-spb
                                              (w-spe-bol-inx-pag)     .
      *                      *-----------------------------------------*
      *                      * Se tipo arrotondamento zero, o non ri-  *
      *                      * conosciuto : nessuna azione             *
      *                      *-----------------------------------------*
           go to     spe-bol-sdb-900.
       spe-bol-sdb-700.
      *                      *-----------------------------------------*
      *                      * Se tipo arrotondamento 01 : Al valore   *
      *                      * superiore                               *
      *                      *-----------------------------------------*
           add       w-spe-bol-var-spb
                    (w-spe-bol-inx-pag)   to   w-spe-bol-spe-bol      .
           subtract  1                    from w-spe-bol-spe-bol      .
           divide    w-spe-bol-var-spb
                    (w-spe-bol-inx-pag)   into w-spe-bol-spe-bol      .
           multiply  w-spe-bol-var-spb
                    (w-spe-bol-inx-pag)   by   w-spe-bol-spe-bol      .
           go to     spe-bol-sdb-900.
       spe-bol-sdb-750.
      *                      *-----------------------------------------*
      *                      * Se tipo arrotondamento 01 : Al valore   *
      *                      * inferiore                               *
      *                      *-----------------------------------------*
           divide    w-spe-bol-var-spb
                    (w-spe-bol-inx-pag)   into w-spe-bol-spe-bol      .
           multiply  w-spe-bol-var-spb
                    (w-spe-bol-inx-pag)   by   w-spe-bol-spe-bol      .
           go to     spe-bol-sdb-900.
       spe-bol-sdb-800.
      *                      *-----------------------------------------*
      *                      * Se tipo arrotondamento 01 : Di tipo     *
      *                      * commerciale                             *
      *                      *-----------------------------------------*
           divide    w-spe-bol-var-spb
                    (w-spe-bol-inx-pag)   into w-spe-bol-spe-bol
                                                         rounded      .
           multiply  w-spe-bol-var-spb
                    (w-spe-bol-inx-pag)   by   w-spe-bol-spe-bol      .
           go to     spe-bol-sdb-900.
       spe-bol-sdb-850.
      *                      *-----------------------------------------*
      *                      * Se tipo arrotondamento 01 : Di tipo     *
      *                      * statale                                 *
      *                      *-----------------------------------------*
           divide    2                    into w-spe-bol-var-spb
                                              (w-spe-bol-inx-pag)
                                        giving w-spe-bol-wrk-s01      .
           add       w-spe-bol-wrk-s01    to   w-spe-bol-var-spb
                                              (w-spe-bol-inx-pag)     .
           subtract  1                    from w-spe-bol-var-spb
                                              (w-spe-bol-inx-pag)     .
           divide    w-spe-bol-var-spb
                    (w-spe-bol-inx-pag)   into w-spe-bol-spe-bol      .
           multiply  w-spe-bol-var-spb
                    (w-spe-bol-inx-pag)   by   w-spe-bol-spe-bol      .
           go to     spe-bol-sdb-900.
       spe-bol-sdb-900.
      *                  *---------------------------------------------*
      *                  * Fine arrotondamenti : uscita                *
      *                  *---------------------------------------------*
           go to     spe-bol-sdb-999.
       spe-bol-sdb-999.
           exit.

      *    *===========================================================*
      *    * Routine di decodifica da cifre a lettere                  *
      *    *                                                           *
      *    * Input  : Si entra con il campo 'w-cif-let-imp' contenente *
      *    *          il numero da decodificare; questo deve essere al *
      *    *          massimo di 9 cifre senza segno;                  *
      *    *                                                           *
      *    * Output : Si esce con il campo 'w-cif-let-let' contenente  *
      *    *          la decodifica eseguita; questo campo consta al   *
      *    *          massimo di 'w-cif-let-tmx' caratteri; nel caso   *
      *    *          che non fossero sufficienti il campo lettere     *
      *    *          contiene il numero editato (allineato a sinistra)*
      *    *          con la maschera : "*ZZZ.ZZZ.ZZZ*"; nel caso che  *
      *    *          entro 'w-cif-let-tmx' caratteri non sia possibile*
      *    *          sviluppare la decodifica completa le ultime tre  *
      *    *          cifre vengono riportate numericamente, altrimenti*
      *    *          anch'esse vengono decodificate.                  *
      *    *          Se il numero viene editato con la maschera di cui*
      *    *          sopra il flag 'w-cif-let-flg' viene posto = a"#" *
      *    *                                                           *
      *    *-----------------------------------------------------------*
           copy      "swd/std/prg/cpy/wciflet0.cps"                   .
      *    *===========================================================*
      *    * Determinazione status scadenza                            *
      *    *-----------------------------------------------------------*
       det-dat-chs-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione data scadenza chiusa a : Aper- *
      *              * ta                                              *
      *              *-------------------------------------------------*
           move      9999999              to   rf-sdb-dat-chs         .
       det-dat-chs-020.
      *              *-------------------------------------------------*
      *              * Controllo su : Insoluto                         *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-isp       =    zero
                     go to det-dat-chs-040.
      *                  *---------------------------------------------*
      *                  * Se la scadenza e' stata riscossa : oltre    *
      *                  *---------------------------------------------*
           if        rf-sdb-num-ris       not  = zero
                     go to det-dat-chs-040.
      *                  *---------------------------------------------*
      *                  * Se a fronte dell'insoluto non e' stata e-   *
      *                  * messa una nuova scadenza, essa e' da inten- *
      *                  * dersi ancora aperta                         *
      *                  *---------------------------------------------*
           if        rf-sdb-ens-isp       =    02   and
                     rf-sdb-nns-isp       =    zero
                     go to det-dat-chs-999.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-isp       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-040.
      *              *-------------------------------------------------*
      *              * Controllo su : Presunto buon esito              *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-pbe       =     zero
                     go to det-dat-chs-060.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-pbe       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-060.
      *              *-------------------------------------------------*
      *              * Controllo su : Presunto buon esito              *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-nbe       =     zero
                     go to det-dat-chs-080.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-nbe       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-080.
      *              *-------------------------------------------------*
      *              * Controllo su : Accredito scadenza al dopo in-   *
      *              *                casso                            *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-acs       =     zero
                     go to det-dat-chs-100.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-acs       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-100.
      *              *-------------------------------------------------*
      *              * Controllo su : Richiamo della scadenza presen-  *
      *              *                tata                             *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-rsp       =     zero
                     go to det-dat-chs-120.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-rsp       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-120.
      *              *-------------------------------------------------*
      *              * Controllo su : Inclusione in distinta           *
      *              *-------------------------------------------------*
           if        rf-sdb-num-ddp       =     zero
                     go to det-dat-chs-140.
      *                  *---------------------------------------------*
      *                  * Nessuna azione                              *
      *                  *---------------------------------------------*
           go to     det-dat-chs-140.
       det-dat-chs-140.
      *              *-------------------------------------------------*
      *              * Controllo su : Riscossione                      *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-ris       =     zero
                     go to det-dat-chs-160.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-ris       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-160.
      *              *-------------------------------------------------*
      *              * Controllo su : Storno                           *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-sto       =     zero
                     go to det-dat-chs-180.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-sto       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-180.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-999.
           exit.

