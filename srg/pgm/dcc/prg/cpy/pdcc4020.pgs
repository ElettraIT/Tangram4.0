       stp-srt-inp-sel-b06.
      *                      *-----------------------------------------*
      *                      * Preparazione chiavi per il sort         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Chiave numerica                     *
      *                          *-------------------------------------*
           move      rf-zcs-cod-csc       to   w-srt-key-num          .
      *                          *-------------------------------------*
      *                          * Chiave alfanumerica                 *
      *                          *-------------------------------------*
           if        rr-ord-ana-scr       =    01
                     move  spaces         to   w-srt-key-alf
           else if   rr-ord-ana-scr       =    02
                     move  rf-zcs-des-csc to   w-srt-key-alf
           else if   rr-ord-ana-scr       =    03
                     move  rf-zcs-mne-csc to   w-srt-key-alf          .
      *                          *-------------------------------------*
      *                          * Chiave alfanumerica 2               *
      *                          *-------------------------------------*
           move      spaces               to   w-srt-key-al2          .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-sel-800.
       stp-srt-inp-sel-c00.
      *                  *---------------------------------------------*
      *                  * Se ordinamento per categoria sc. chiusura   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se categoria sconto a zero : uscita     *
      *                      * per elemento non selezionato            *
      *                      *-----------------------------------------*
           if        rf-dcc-cat-scc       =    zero
                     go to stp-srt-inp-sel-900.
      *                      *-----------------------------------------*
      *                      * Lettura preliminare anagrafica catego-  *
      *                      * ria sconto in chiusura                  *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCSC    "         to   f-key                  .
           move      01                   to   rf-zcs-tip-csc         .
           move      rf-dcc-cat-scc       to   rf-zcs-cod-csc         .
           move      "pgm/dcc/fls/ioc/obj/iofzcs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zcs                 .
      *                          *-------------------------------------*
      *                          * Se record trovato : a selezioni     *
      *                          *-------------------------------------*
           if        f-sts                =    e-not-err
                     go to stp-srt-inp-sel-c02.
      *                          *-------------------------------------*
      *                          * Se record non trovato               *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Normalizzazione record          *
      *                              *---------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofzcs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zcs                 .
      *                              *---------------------------------*
      *                              * Normalizzazione descrizione     *
      *                              *---------------------------------*
           move      all "."              to   rf-zcs-des-csc         .
      *                              *---------------------------------*
      *                              * Se ordinamento per codice : a   *
      *                              * selezione su solo codice        *
      *                              *---------------------------------*
           if        rr-ord-ana-scc       =    01
                     go to stp-srt-inp-sel-c04.
      *                              *---------------------------------*
      *                              * Altrimenti                      *
      *                              *  - Se selezione totale : Ok     *
      *                              *  - In caso contrario   : Ko     *
      *                              *---------------------------------*
           if        rr-ord-ana-scc       =    02
                     if    rr-sel-scc-dei =    all " " and
                           rr-sel-scc-def =    all "z"
                           go to stp-srt-inp-sel-c06
                     else  go to stp-srt-inp-sel-900
           else if   rr-ord-ana-scc       =    03
                     if    rr-sel-scc-mni =    all " " and
                           rr-sel-scc-mnf =    all "z"
                           go to stp-srt-inp-sel-c06
                     else  go to stp-srt-inp-sel-900.
       stp-srt-inp-sel-c02.
      *                      *-----------------------------------------*
      *                      * Selezioni su anagrafica categorie sc.   *
      *                      *-----------------------------------------*
           if        rf-zcs-des-key       >    rr-sel-scc-def or
                     rf-zcs-des-key       <    rr-sel-scc-dei
                     go to stp-srt-inp-sel-900.
           if        rf-zcs-mne-csc       >    rr-sel-scc-mnf or
                     rf-zcs-mne-csc       <    rr-sel-scc-mni
                     go to stp-srt-inp-sel-900.
       stp-srt-inp-sel-c04.
           if        rf-zcs-cod-csc       >    rr-sel-scc-cof or
                     rf-zcs-cod-csc       <    rr-sel-scc-coi
                     go to stp-srt-inp-sel-900.
       stp-srt-inp-sel-c06.
      *                      *-----------------------------------------*
      *                      * Preparazione chiavi per il sort         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Chiave numerica                     *
      *                          *-------------------------------------*
           move      rf-zcs-cod-csc       to   w-srt-key-num          .
      *                          *-------------------------------------*
      *                          * Chiave alfanumerica                 *
      *                          *-------------------------------------*
           if        rr-ord-ana-scc       =    01
                     move  spaces         to   w-srt-key-alf
           else if   rr-ord-ana-scc       =    02
                     move  rf-zcs-des-csc to   w-srt-key-alf
           else if   rr-ord-ana-scc       =    03
                     move  rf-zcs-mne-csc to   w-srt-key-alf          .
      *                          *-------------------------------------*
      *                          * Chiave alfanumerica 2               *
      *                          *-------------------------------------*
           move      spaces               to   w-srt-key-al2          .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-sel-800.
       stp-srt-inp-sel-800.
      *              *-------------------------------------------------*
      *              * Uscita per selezioni superate                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-sel-999.
       stp-srt-inp-sel-900.
      *              *-------------------------------------------------*
      *              * Uscita per selezioni non superate               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita                              *
      *                  *---------------------------------------------*
           move      "#"                  to   w-srt-sel-rec          .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-sel-999.
       stp-srt-inp-sel-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Selezioni su anagrafica clienti in funzione dei selet-    *
      *    * tori                                                      *
      *    *-----------------------------------------------------------*
       stp-srt-inp-svd-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-srt-sel-rec          .
       stp-srt-inp-svd-100.
      *              *-------------------------------------------------*
      *              * Test su codice Agente                           *
      *              *-------------------------------------------------*
           if        rr-vag-dst-age       not  = "X"
                     go to stp-srt-inp-svd-125.
           if        rf-dcc-cod-age       =    zero   and
                     rr-snx-cse           =    02
                     go to stp-srt-inp-svd-900.
           if        rf-dcc-cod-age       not  = zero and
                     rr-snx-cse           =    03
                     go to stp-srt-inp-svd-900.
       stp-srt-inp-svd-125.
      *              *-------------------------------------------------*
      *              * Test su codice Zona                             *
      *              *-------------------------------------------------*
           if        rr-vag-dst-zon       not  = "X"
                     go to stp-srt-inp-svd-150.
           if        rf-dcc-cod-zon       =    zero   and
                     rr-snx-cse           =    02
                     go to stp-srt-inp-svd-900.
           if        rf-dcc-cod-zon       not  = zero and
                     rr-snx-cse           =    03
                     go to stp-srt-inp-svd-900.
       stp-srt-inp-svd-150.
      *              *-------------------------------------------------*
      *              * Test su codice Categoria                        *
      *              *-------------------------------------------------*
           if        rr-vag-dst-cat       not  = "X"
                     go to stp-srt-inp-svd-175.
           if        rf-dcc-cod-cat       =    zero   and
                     rr-snx-cse           =    02
                     go to stp-srt-inp-svd-900.
           if        rf-dcc-cod-cat       not  = zero and
                     rr-snx-cse           =    03
                     go to stp-srt-inp-svd-900.
       stp-srt-inp-svd-175.
      *              *-------------------------------------------------*
      *              * Test su codice Classificatore statistico        *
      *              *-------------------------------------------------*
           if        rr-vag-dst-stt       not  = "X"
                     go to stp-srt-inp-svd-200.
           if        rf-dcc-cod-stt       =    zero   and
                     rr-snx-cse           =    02
                     go to stp-srt-inp-svd-900.
           if        rf-dcc-cod-stt       not  = zero and
                     rr-snx-cse           =    03
                     go to stp-srt-inp-svd-900.
       stp-srt-inp-svd-200.
      *              *-------------------------------------------------*
      *              * Test su codice Codice listino                   *
      *              *-------------------------------------------------*
           if        rr-vag-dst-lst       not  = "X"
                     go to stp-srt-inp-svd-215.
           if        rf-dcc-cod-lst       =    spaces   and
                     rr-snx-cse           =    02
                     go to stp-srt-inp-svd-900.
           if        rf-dcc-cod-stt       not  = spaces and
                     rr-snx-cse           =    03
                     go to stp-srt-inp-svd-900.
       stp-srt-inp-svd-215.
      *              *-------------------------------------------------*
      *              * Test su codice Codice marketing                 *
      *              *-------------------------------------------------*
       stp-srt-inp-svd-225.
      *              *-------------------------------------------------*
      *              * Test su codice Condizioni di pagamento          *
      *              *-------------------------------------------------*
           if        rr-vag-dst-pag       not  = "X"
                     go to stp-srt-inp-svd-300.
           if        rf-dcc-cod-fop       =    zero   and
                     rf-dcc-dpz-cli       =    spaces and
                     rr-snx-cse           =    02
                     go to stp-srt-inp-svd-900.
           if        rf-dcc-cod-fop       not  = zero and
                     rr-snx-cse           =    03
                     go to stp-srt-inp-svd-900.
       stp-srt-inp-svd-300.
      *              *-------------------------------------------------*
      *              * Test su Banca d'appoggio                        *
      *              *-------------------------------------------------*
           if        rr-vag-dst-ban       not  = "X"
                     go to stp-srt-inp-svd-350.
           if        rf-dcc-cod-abi       =    zero   and
                     rf-dcc-cod-cab       =    zero   and
                     rr-snx-cse           =    02
                     go to stp-srt-inp-svd-900.
           if        rf-dcc-cod-abi       not  = zero and
                     rf-dcc-cod-cab       not  = zero and
                     rr-snx-cse           =    03
                     go to stp-srt-inp-svd-900.
       stp-srt-inp-svd-350.
      *              *-------------------------------------------------*
      *              * Test su Telefono                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se selezione da eseguire               *
      *                  *---------------------------------------------*
           if        rr-vag-dst-tel       not  = "X"
                     go to stp-srt-inp-svd-375.
      *                  *---------------------------------------------*
      *                  * Determinazione contatti - telefono          *
      *                  *---------------------------------------------*
           move      "DT"                 to   d-con-arc-tip-ope      .
           move      02                   to   d-con-arc-tip-arc      .
           move      rf-dcc-cod-cli       to   d-con-arc-cod-arc      .
           move      rf-dcc-dpz-cli       to   d-con-arc-dpz-arc      .
           move      "TEL"                to   d-con-arc-tip-sel      .
           move      01                   to   d-con-arc-num-edr      .
           perform   con-arc-tip-cll-000  thru con-arc-tip-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test su esito determinazione                *
      *                  *---------------------------------------------*
           if        d-con-arc-num-con (1)
                                          =    spaces   and
                     rr-snx-cse           =    02
                     go to stp-srt-inp-svd-900.
           if        d-con-arc-num-con (1)
                                          not  = spaces and
                     rr-snx-cse           =    03
                     go to stp-srt-inp-svd-900.
       stp-srt-inp-svd-375.
      *              *-------------------------------------------------*
      *              * Test su Fax                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se selezione da eseguire               *
      *                  *---------------------------------------------*
           if        rr-vag-dst-fax       not  = "X"
                     go to stp-srt-inp-svd-380.
      *                  *---------------------------------------------*
      *                  * Determinazione contatti - fax               *
      *                  *---------------------------------------------*
           move      "DT"                 to   d-con-arc-tip-ope      .
           move      02                   to   d-con-arc-tip-arc      .
           move      rf-dcc-cod-cli       to   d-con-arc-cod-arc      .
           move      rf-dcc-dpz-cli       to   d-con-arc-dpz-arc      .
           move      "FAX"                to   d-con-arc-tip-sel      .
           move      01                   to   d-con-arc-num-edr      .
           perform   con-arc-tip-cll-000  thru con-arc-tip-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test su esito determinazione                *
      *                  *---------------------------------------------*
           if        d-con-arc-num-con (1)
                                          =    spaces   and
                     rr-snx-cse           =    02
                     go to stp-srt-inp-svd-900.
           if        d-con-arc-num-con (1)
                                          not  = spaces and
                     rr-snx-cse           =    03
                     go to stp-srt-inp-svd-900.
       stp-srt-inp-svd-380.
      *              *-------------------------------------------------*
      *              * Test su Cellulare                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se selezione da eseguire               *
      *                  *---------------------------------------------*
           if        rr-vag-dst-cel       not  = "X"
                     go to stp-srt-inp-svd-400.
      *                  *---------------------------------------------*
      *                  * Determinazione contatti - cellulare         *
      *                  *---------------------------------------------*
           move      "DT"                 to   d-con-arc-tip-ope      .
           move      02                   to   d-con-arc-tip-arc      .
           move      rf-dcc-cod-cli       to   d-con-arc-cod-arc      .
           move      rf-dcc-dpz-cli       to   d-con-arc-dpz-arc      .
           move      "CEL"                to   d-con-arc-tip-sel      .
           move      01                   to   d-con-arc-num-edr      .
           perform   con-arc-tip-cll-000  thru con-arc-tip-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test su esito determinazione                *
      *                  *---------------------------------------------*
           if        d-con-arc-num-con (1)
                                          =    spaces   and
                     rr-snx-cse           =    02
                     go to stp-srt-inp-svd-900.
           if        d-con-arc-num-con (1)
                                          not  = spaces and
                     rr-snx-cse           =    03
                     go to stp-srt-inp-svd-900.
       stp-srt-inp-svd-400.
      *              *-------------------------------------------------*
      *              * Test su E-mail                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se selezione da eseguire               *
      *                  *---------------------------------------------*
           if        rr-vag-dst-eml       not  = "X"
                     go to stp-srt-inp-svd-410.
      *                  *---------------------------------------------*
      *                  * Determinazione contatti - email             *
      *                  *---------------------------------------------*
           move      "DT"                 to   d-con-arc-tip-ope      .
           move      02                   to   d-con-arc-tip-arc      .
           move      rf-dcc-cod-cli       to   d-con-arc-cod-arc      .
           move      rf-dcc-dpz-cli       to   d-con-arc-dpz-arc      .
           move      "EML"                to   d-con-arc-tip-sel      .
           move      01                   to   d-con-arc-num-edr      .
           perform   con-arc-tip-cll-000  thru con-arc-tip-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test su esito determinazione                *
      *                  *---------------------------------------------*
           if        d-con-arc-num-con (1)
                                          =    spaces   and
                     rr-snx-cse           =    02
                     go to stp-srt-inp-svd-900.
           if        d-con-arc-num-con (1)
                                          not  = spaces and
                     rr-snx-cse           =    03
                     go to stp-srt-inp-svd-900.
       stp-srt-inp-svd-410.
      *              *-------------------------------------------------*
      *              * Test su E-mail PEC                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se selezione da eseguire               *
      *                  *---------------------------------------------*
           if        rr-vag-dst-pec       not  = "X"
                     go to stp-srt-inp-svd-420.
      *                  *---------------------------------------------*
      *                  * Determinazione contatti - email             *
      *                  *---------------------------------------------*
           move      "DT"                 to   d-con-arc-tip-ope      .
           move      02                   to   d-con-arc-tip-arc      .
           move      rf-dcc-cod-cli       to   d-con-arc-cod-arc      .
           move      rf-dcc-dpz-cli       to   d-con-arc-dpz-arc      .
           move      "PEC"                to   d-con-arc-tip-sel      .
           move      01                   to   d-con-arc-num-edr      .
           perform   con-arc-tip-cll-000  thru con-arc-tip-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test su esito determinazione                *
      *                  *---------------------------------------------*
           if        d-con-arc-num-con (1)
                                          =    spaces   and
                     rr-snx-cse           =    02
                     go to stp-srt-inp-svd-900.
           if        d-con-arc-num-con (1)
                                          not  = spaces and
                     rr-snx-cse           =    03
                     go to stp-srt-inp-svd-900.
       stp-srt-inp-svd-420.
      *              *-------------------------------------------------*
      *              * Test su codice SDI                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se selezione da eseguire               *
      *                  *---------------------------------------------*
           if        rr-vag-dst-sdi       not  = "X"
                     go to stp-srt-inp-svd-425.
           if        rf-dcc-idn-em2       =    spaces   and
                     rr-snx-cse           =    02
                     go to stp-srt-inp-svd-900.
           if        rf-dcc-idn-em2       not  = spaces and
                     rr-snx-cse           =    03
                     go to stp-srt-inp-svd-900.
       stp-srt-inp-svd-425.
      *              *-------------------------------------------------*
      *              * Test su Interlocutore                           *
      *              *-------------------------------------------------*
       stp-srt-inp-svd-450.
      *              *-------------------------------------------------*
      *              * Test su Partita I.v.a.                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su selettore                           *
      *                  *---------------------------------------------*
           if        rr-vag-dst-piv       not  = "X"
                     go to stp-srt-inp-svd-480.
      *                  *---------------------------------------------*
      *                  * Test sul tipo ordinamento                   *
      *                  *---------------------------------------------*
           if        w-srt-ord-cli        =    03
                     go to stp-srt-inp-svd-470.
       stp-srt-inp-svd-460.
      *                  *---------------------------------------------*
      *                  * Se ordinamento per codice o ragione sociale *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione record [cli]            *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofcli"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cli                 .
      *                      *-----------------------------------------*
      *                      * Lettura record [cli]                    *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLI"             to   f-key                  .
           move      rf-dcc-cod-cli       to   rf-cli-cod-cli         .
           move      "pgm/cge/fls/ioc/obj/iofcli"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cli                 .
       stp-srt-inp-svd-470.
      *                  *---------------------------------------------*
      *                  * Se ordinamento per mnemonico                *
      *                  *---------------------------------------------*
           if        rf-cli-prt-iva       =    zero   and
                     rr-snx-cse           =    02
                     go to stp-srt-inp-svd-900.
           if        rf-cli-prt-iva       not  = zero and
                     rr-snx-cse           =    03
                     go to stp-srt-inp-svd-900.
       stp-srt-inp-svd-480.
      *              *-------------------------------------------------*
      *              * Test su Codice Fiscale                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su selettore                           *
      *                  *---------------------------------------------*
           if        rr-vag-dst-cfi       not  = "X"
                     go to stp-srt-inp-svd-500.
      *                  *---------------------------------------------*
      *                  * Test sul tipo ordinamento                   *
      *                  *---------------------------------------------*
           if        w-srt-ord-cli        =    03
                     go to stp-srt-inp-svd-490.
       stp-srt-inp-svd-485.
      *                  *---------------------------------------------*
      *                  * Se ordinamento per codice o ragione sociale *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione record [cli]            *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofcli"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cli                 .
      *                      *-----------------------------------------*
      *                      * Lettura record [cli]                    *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLI"             to   f-key                  .
           move      rf-dcc-cod-cli       to   rf-cli-cod-cli         .
           move      "pgm/cge/fls/ioc/obj/iofcli"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cli                 .
       stp-srt-inp-svd-490.
      *                  *---------------------------------------------*
      *                  * Se ordinamento per mnemonico                *
      *                  *---------------------------------------------*
           if        rf-cli-cod-fis       =    spaces   and
                     rr-snx-cse           =    02
                     go to stp-srt-inp-svd-900.
           if        rf-cli-cod-fis       not  = spaces and
                     rr-snx-cse           =    03
                     go to stp-srt-inp-svd-900.
       stp-srt-inp-svd-500.
      *              *-------------------------------------------------*
      *              * Test su Giorni di chiusura                      *
      *              *-------------------------------------------------*
           if        rr-vag-dst-gch       not  = "X"
                     go to stp-srt-inp-svd-600.
           if        rf-dcc-gdl-nls       =    spaces   and
                     rr-snx-cse           =    02
                     go to stp-srt-inp-svd-900.
           if        rf-dcc-gdl-nls       not  = spaces and
                     rr-snx-cse           =    03
                     go to stp-srt-inp-svd-900.
       stp-srt-inp-svd-600.
      *              *-------------------------------------------------*
      *              * Test su Annotazioni                             *
      *              *-------------------------------------------------*
           if        rr-vag-dst-ann       not  = "X"
                     go to stp-srt-inp-svd-650.
           if        rf-dcc-not-g01       =    spaces and
                     rf-dcc-not-g02       =    spaces and
                     rf-dcc-not-g03       =    spaces
                     go to stp-srt-inp-svd-900.
       stp-srt-inp-svd-650.
      *              *-------------------------------------------------*
      *              * Test su Status                                  *
      *              *-------------------------------------------------*
           if        rr-vag-dst-sts       not  = "X"
                     go to stp-srt-inp-svd-800.
           if        rf-dcc-sta-tus       =    zero   and
                     rr-snx-cse           =    02
                     go to stp-srt-inp-svd-900.
           if        rf-dcc-sta-tus       not  = zero and
                     rr-snx-cse           =    03
                     go to stp-srt-inp-svd-900.
       stp-srt-inp-svd-800.
      *              *-------------------------------------------------*
      *              * Uscita per selezioni superate                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-svd-999.
       stp-srt-inp-svd-900.
      *              *-------------------------------------------------*
      *              * Uscita per selezioni non superate               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita                              *
      *                  *---------------------------------------------*
           move      "#"                  to   w-srt-sel-rec          .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-svd-999.
       stp-srt-inp-svd-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Selezioni supplementari su anagrafica clienti             *
      *    *-----------------------------------------------------------*
       stp-srt-inp-ssu-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-srt-sel-rec          .
       stp-srt-inp-ssu-050.
      *              *-------------------------------------------------*
      *              * Se si tratta di una dipendenza e la selezione   *
      *              * implica clienti con status diverso da normale : *
      *              * selezione non superata, a meno che non sia una  *
      *              * richiesta di stampa di singola scheda           *
      *              *-------------------------------------------------*
           if        rr-sel-cli-dpz       not  = spaces
                     go to stp-srt-inp-ssu-800.
           if        rf-dcc-dpz-cli       not  = spaces      and
                     rr-ssu-sta-tus       not  = "X         "
                     go to stp-srt-inp-ssu-900.
      *              *-------------------------------------------------*
      *              * Se si tratta di una dipendenza e la selezione   *
      *              * implica solo  clienti con status pari a normale *
      *              * : non si seleziona sullo status commerciale     *
      *              * ___ SISTEMARE !!! ___                           *
      *              *-------------------------------------------------*
           if        rf-dcc-dpz-cli       not  = spaces
                     go to stp-srt-inp-ssu-100.
      *              *-------------------------------------------------*
      *              * Selezione su status commerciale del cliente     *
      *              *-------------------------------------------------*
           if        rf-dcc-sta-tus       =    01 and
                     rr-ssu-sta-tus (01 : 01)
                                          =    spaces
                     go to stp-srt-inp-ssu-900.
           if        rf-dcc-sta-tus       =    09 and
                     rr-ssu-sta-tus (02 : 01)
                                          =    spaces
                     go to stp-srt-inp-ssu-900.
           if        rf-dcc-sta-tus       =    11 and
                     rr-ssu-sta-tus (03 : 01)
                                          =    spaces
                     go to stp-srt-inp-ssu-900.
           if        rf-dcc-sta-tus       =    21 and
                     rr-ssu-sta-tus (04 : 01)
                                          =    spaces
                     go to stp-srt-inp-ssu-900.
           if        rf-dcc-sta-tus       =    51 and
                     rr-ssu-sta-tus (05 : 01)
                                          =    spaces
                     go to stp-srt-inp-ssu-900.
           if        rf-dcc-sta-tus       =    52 and
                     rr-ssu-sta-tus (06 : 01)
                                          =    spaces
                     go to stp-srt-inp-ssu-900.
           if        rf-dcc-sta-tus       =    61 and
                     rr-ssu-sta-tus (07 : 01)
                                          =    spaces
                     go to stp-srt-inp-ssu-900.
           if        rf-dcc-sta-tus       =    62 and
                     rr-ssu-sta-tus (08 : 01)
                                          =    spaces
                     go to stp-srt-inp-ssu-900.
           if        rf-dcc-sta-tus       =    71 and
                     rr-ssu-sta-tus (09 : 01)
                                          =    spaces
                     go to stp-srt-inp-ssu-900.
           if        rf-dcc-sta-tus       =    72 and
                     rr-ssu-sta-tus (10 : 01)
                                          =    spaces
                     go to stp-srt-inp-ssu-900.
       stp-srt-inp-ssu-100.
      *              *-------------------------------------------------*
      *              * Codice agente                                   *
      *              *-------------------------------------------------*
           if        rr-ssu-cod-age       =    zero
                     go to stp-srt-inp-ssu-200.
           if        rf-dcc-cod-age       not  = rr-ssu-cod-age
                     go to stp-srt-inp-ssu-900.
       stp-srt-inp-ssu-200.
      *              *-------------------------------------------------*
      *              * Codice zona                                     *
      *              *-------------------------------------------------*
           if        rr-ssu-cod-zon       =    zero
                     go to stp-srt-inp-ssu-300.
           if        rf-dcc-cod-zon       not  = rr-ssu-cod-zon
                     go to stp-srt-inp-ssu-900.
       stp-srt-inp-ssu-300.
      *              *-------------------------------------------------*
      *              * Codice categoria                                *
      *              *-------------------------------------------------*
           if        rr-ssu-cod-cat       =    zero
                     go to stp-srt-inp-ssu-400.
           if        rf-dcc-cod-cat       not  = rr-ssu-cod-cat
                     go to stp-srt-inp-ssu-900.
       stp-srt-inp-ssu-400.
      *              *-------------------------------------------------*
      *              * Codice statistico                               *
      *              *-------------------------------------------------*
           if        rr-ssu-cod-stt       =    zero
                     go to stp-srt-inp-ssu-410.
           if        rf-dcc-cod-stt       not  = rr-ssu-cod-stt
                     go to stp-srt-inp-ssu-900.
       stp-srt-inp-ssu-410.
      *              *-------------------------------------------------*
      *              * Codice nostra banca                             *
      *              *-------------------------------------------------*
           if        rr-ssu-cod-cbp       =    spaces
                     go to stp-srt-inp-ssu-425.
           if        rf-dcc-nos-ban       not  = rr-ssu-cod-cbp
                     go to stp-srt-inp-ssu-900.
       stp-srt-inp-ssu-425.
      *              *-------------------------------------------------*
      *              * Codice regione                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se codice a spazi : oltre                   *
      *                  *---------------------------------------------*
           if        rr-ssu-cod-rgn       =    spaces
                     go to stp-srt-inp-ssu-450.
      *                  *---------------------------------------------*
      *                  * Se codice nazione non e' 'IT' : uscita per  *
      *                  * elemento non selezionato                    *
      *                  *---------------------------------------------*
           if        rf-dcc-cod-naz       not  = "IT "
                     go to stp-srt-inp-ssu-900.
      *                  *---------------------------------------------*
      *                  * Determinazione codice regione               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se codice comune a zero : uscita per    *
      *                      * elemento non selezionato                *
      *                      *-----------------------------------------*
           if        rf-dcc-cod-cmn       =    zero
                     go to stp-srt-inp-ssu-900.
      *                      *-----------------------------------------*
      *                      * Lettura preliminare del codice comune   *
      *                      * per rilevamento del codice provincia    *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCFL    "         to   f-key                  .
           move      rf-dcc-cod-cmn       to   rf-gxc-cod-cmn         .
           move      zero                 to   rf-gxc-cod-fzn         .
           move      zero                 to   rf-gxc-cod-lct         .
           move      "pgm/geo/fls/ioc/obj/iofgxc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gxc                 .
      *                          *-------------------------------------*
      *                          * Se record non trovato : uscita per  *
      *                          * elemento non selezionato            *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-ssu-900.
      *                      *-----------------------------------------*
      *                      * Se codice provincia a spaces : uscita   *
      *                      * per elemento non selezionato            *
      *                      *-----------------------------------------*
           if        rf-gxc-cod-prv       =    spaces
                     go to stp-srt-inp-ssu-900.
      *                      *-----------------------------------------*
      *                      * Lettura preliminare del codice provin-  *
      *                      * cia per rilevamento del codice regione  *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODPRV    "         to   f-key                  .
           move      rf-gxc-cod-prv       to   rf-gxp-cod-prv         .
           move      "pgm/geo/fls/ioc/obj/iofgxp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gxp                 .
      *                          *-------------------------------------*
      *                          * Se record non trovato : uscita per  *
      *                          * elemento non selezionato            *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-ssu-900.
      *                      *-----------------------------------------*
      *                      * Se codice regione a spaces : uscita per *
      *                      * elemento non selezionato                *
      *                      *-----------------------------------------*
           if        rf-gxp-cod-rgn       =    spaces
                     go to stp-srt-inp-ssu-900.
      *                  *---------------------------------------------*
      *                  * Test di selezione                           *
      *                  *---------------------------------------------*
           if        rf-gxp-cod-rgn       not  = rr-ssu-cod-rgn
                     go to stp-srt-inp-ssu-900.
       stp-srt-inp-ssu-450.
      *              *-------------------------------------------------*
      *              * Codice provincia                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se codice a spazi : oltre                   *
      *                  *---------------------------------------------*
           if        rr-ssu-cod-prv       =    spaces
                     go to stp-srt-inp-ssu-500.
      *                  *---------------------------------------------*
      *                  * Se codice nazione non e' 'IT' : uscita per  *
      *                  * elemento non selezionato                    *
      *                  *---------------------------------------------*
           if        rf-dcc-cod-naz       not  = "IT "
                     go to stp-srt-inp-ssu-900.
      *                  *---------------------------------------------*
      *                  * Determinazione codice provincia             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se codice comune a zero : uscita per    *
      *                      * elemento non selezionato                *
      *                      *-----------------------------------------*
           if        rf-dcc-cod-cmn       =    zero
                     go to stp-srt-inp-ssu-900.
      *                      *-----------------------------------------*
      *                      * Lettura preliminare del codice comune   *
      *                      * per rilevamento del codice provincia    *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCFL    "         to   f-key                  .
           move      rf-dcc-cod-cmn       to   rf-gxc-cod-cmn         .
           move      zero                 to   rf-gxc-cod-fzn         .
           move      zero                 to   rf-gxc-cod-lct         .
           move      "pgm/geo/fls/ioc/obj/iofgxc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gxc                 .
      *                          *-------------------------------------*
      *                          * Se record non trovato : uscita per  *
      *                          * elemento non selezionato            *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-ssu-900.
      *                      *-----------------------------------------*
      *                      * Se codice provincia a spaces : uscita   *
      *                      * per elemento non selezionato            *
      *                      *-----------------------------------------*
           if        rf-gxc-cod-prv       =    spaces
                     go to stp-srt-inp-ssu-900.
      *                  *---------------------------------------------*
      *                  * Test di selezione                           *
      *                  *---------------------------------------------*
           if        rf-gxc-cod-prv       not  = rr-ssu-cod-prv
                     go to stp-srt-inp-ssu-900.
       stp-srt-inp-ssu-500.
      *              *-------------------------------------------------*
      *              * Codici di avviamento postale                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se tutti i CAP a spaces : a selezione  *
      *                  * superata                                    *
      *                  *---------------------------------------------*
           if        rr-ssu-cod-cap (1)   =    spaces and
                     rr-ssu-cod-cap (2)   =    spaces
                     go to stp-srt-inp-ssu-600.
      *                  *---------------------------------------------*
      *                  * Se codice nazione non e' 'IT' : uscita per  *
      *                  * elemento non selezionato                    *
      *                  *---------------------------------------------*
           if        rf-dcc-cod-naz       not  = "IT "
                     go to stp-srt-inp-ssu-900.
      *                  *---------------------------------------------*
      *                  * Se il tipo ordinamento stampa e' per comune *
      *                  * si utilizza il CAP gia' rilevato dal comune *
      *                  * stesso                                      *
      *                  *---------------------------------------------*
           if        rr-tip-ors           =    14
                     go to stp-srt-inp-ssu-540.
       stp-srt-inp-ssu-520.
      *                  *---------------------------------------------*
      *                  * Rilevamento del codice avviamento postale   *
      *                  * dal campo localita'                         *
      *                  *---------------------------------------------*
           move      rf-dcc-loc-dcc       to   w-srt-cap-avp          .
      *                  *---------------------------------------------*
      *                  * Se il CAP non e' un valore numerico : usci- *
      *                  * ta per elemento non selezionato             *
      *                  *---------------------------------------------*
           if        w-srt-cap-avp-num    not  numeric
                     go to stp-srt-inp-ssu-900.
       stp-srt-inp-ssu-540.
      *                  *---------------------------------------------*
      *                  * Regolarizzazione dei CAP richiesti          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * CAP richiesto '1'                       *
      *                      *-----------------------------------------*
           move      rr-ssu-cod-cap (1)   to   w-srt-cap-in1          .
           inspect   w-srt-cap-in1   replacing all " "
                                          by       "0"                .
           move      rr-ssu-cod-cap (1)   to   w-srt-cap-fi1          .
           inspect   w-srt-cap-fi1   replacing all " "
                                          by       "9"                .
      *                      *-----------------------------------------*
      *                      * CAP richiesto '2'                       *
      *                      *-----------------------------------------*
           move      rr-ssu-cod-cap (2)   to   w-srt-cap-in2          .
           inspect   w-srt-cap-in2   replacing all " "
                                          by       "0"                .
           move      rr-ssu-cod-cap (2)   to   w-srt-cap-fi2          .
           inspect   w-srt-cap-fi2   replacing all " "
                                          by       "9"                .
      *                  *---------------------------------------------*
      *                  * Test per la selezione                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se selezione superata              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test su CAP 1 : sempre eseguito     *
      *                          *-------------------------------------*
           if        w-srt-cap-avp        not  < w-srt-cap-in1  and
                     w-srt-cap-avp        not  > w-srt-cap-fi1
                     go to stp-srt-inp-ssu-600.
      *                          *-------------------------------------*
      *                          * Test su CAP 2 : solo se CAP diverso *
      *                          * da spaces, altrimenti test non su-  *
      *                          * perato                              *
      *                          *-------------------------------------*
           if        rr-ssu-cod-cap (2)   =    spaces
                     go to stp-srt-inp-ssu-900.
           if        w-srt-cap-avp        not  < w-srt-cap-in2  and
                     w-srt-cap-avp        not  > w-srt-cap-fi2
                     go to stp-srt-inp-ssu-600.
      *                          *-------------------------------------*
      *                          * Selezione non superata comunque     *
      *                          *-------------------------------------*
           go to     stp-srt-inp-ssu-900.
       stp-srt-inp-ssu-600.
      *              *-------------------------------------------------*
      *              * Data acquisizione minima                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da eseguire                         *
      *                  *---------------------------------------------*
           if        rr-ssu-aqz-min       =    zero
                     go to stp-srt-inp-ssu-650.
           if        rf-dcc-dat-aqz       <    rr-ssu-aqz-min
                     go to stp-srt-inp-ssu-900.
       stp-srt-inp-ssu-650.
      *              *-------------------------------------------------*
      *              * Data acquisizione massima                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da eseguire                         *
      *                  *---------------------------------------------*
           if        rr-ssu-aqz-max       =    zero
                     go to stp-srt-inp-ssu-700.
           if        rf-dcc-dat-aqz       >    rr-ssu-aqz-max
                     go to stp-srt-inp-ssu-900.
       stp-srt-inp-ssu-700.
      *              *-------------------------------------------------*
      *              * Set di 'svf'                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da eseguire                         *
      *                  *---------------------------------------------*
           if        rr-ssu-set-svf       =    spaces
                     go to stp-srt-inp-ssu-800.
      *                  *---------------------------------------------*
      *                  * Data, utente, fase, di ultimo inserimento o *
      *                  * modifica                                    *
      *                  *---------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Lettura set                                 *
      *                  *---------------------------------------------*
           move      "RD"                 to   w-mod-set-tip-ope      .
           move      s-ute                to   w-mod-set-ide-ute      .
           move      rr-ssu-set-svf       to   w-mod-set-ide-fas      .
           move      01                   to   w-mod-set-tip-arc      .
           move      rf-dcc-cod-cli       to   w-mod-set-cod-arc      .
           move      rf-dcc-dpz-cli       to   w-mod-set-alf-arc      .
           perform   mdl-gen-set-cll-000  thru mdl-gen-set-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        w-mod-set-exi-sts    not  = spaces
                     go to stp-srt-inp-ssu-900.
      *                  *---------------------------------------------*
      *                  * Ad uscita per selezione superata            *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-ssu-800.
       stp-srt-inp-ssu-800.
      *              *-------------------------------------------------*
      *              * Uscita per selezioni supplementari superate     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-ssu-999.
       stp-srt-inp-ssu-900.
      *              *-------------------------------------------------*
      *              * Uscita per selezioni non superate               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita                              *
      *                  *---------------------------------------------*
           move      "#"                  to   w-srt-sel-rec          .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-ssu-999.
       stp-srt-inp-ssu-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Composizione area di sort                                 *
      *    *-----------------------------------------------------------*
       stp-srt-inp-cms-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione preliminare                     *
      *              *-------------------------------------------------*
           move      spaces               to   srt-rec                .
       stp-srt-inp-cms-100.
      *              *-------------------------------------------------*
      *              * Composizione chiave di sort per i clienti       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo ordinamento *
      *                  * per cliente                                 *
      *                  *---------------------------------------------*
           if        w-srt-ord-cli        =    01
                     go to stp-srt-inp-cms-110
           else if   w-srt-ord-cli        =    02
                     go to stp-srt-inp-cms-120
           else if   w-srt-ord-cli        =    03
                     go to stp-srt-inp-cms-130.
       stp-srt-inp-cms-110.
      *                      *-----------------------------------------*
      *                      * Se ordinamento per ragione sociale      *
      *                      *-----------------------------------------*
           move      zero                 to   srt-key-num            .
           move      spaces               to   srt-key-alf            .
           move      spaces               to   srt-key-al2            .
           move      zero                 to   srt-key-ncl            .
           move      rf-dcc-rag-key       to   srt-key-acl            .
           move      spaces               to   srt-key-adp            .
      *                          *-------------------------------------*
      *                          * A composizione chiave di sort       *
      *                          *-------------------------------------*
           go to     stp-srt-inp-cms-200.
       stp-srt-inp-cms-120.
      *                      *-----------------------------------------*
      *                      * Se ordinamento per codice               *
      *                      *-----------------------------------------*
           move      zero                 to   srt-key-num            .
           move      spaces               to   srt-key-alf            .
           move      spaces               to   srt-key-al2            .
           move      rf-dcc-cod-cli       to   srt-key-ncl            .
           move      spaces               to   srt-key-acl            .
           move      rf-dcc-dpz-cli       to   srt-key-adp            .
      *                          *-------------------------------------*
      *                          * A composizione chiave di sort       *
      *                          *-------------------------------------*
           go to     stp-srt-inp-cms-200.
       stp-srt-inp-cms-130.
      *                      *-----------------------------------------*
      *                      * Se ordinamento per mnemonico            *
      *                      *-----------------------------------------*
           move      zero                 to   srt-key-num            .
           move      spaces               to   srt-key-alf            .
           move      spaces               to   srt-key-al2            .
           move      zero                 to   srt-key-ncl            .
           move      rf-cli-cod-mne       to   srt-key-acl            .
           move      rf-dcc-dpz-cli       to   srt-key-adp            .
      *                          *-------------------------------------*
      *                          * A composizione chiave di sort       *
      *                          *-------------------------------------*
           go to     stp-srt-inp-cms-200.
       stp-srt-inp-cms-200.
      *              *-------------------------------------------------*
      *              * Composizione chiave di sort generica            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Chiave di ordinamento numerica generica     *
      *                  *---------------------------------------------*
           move      w-srt-key-num        to   srt-key-num            .
      *                  *---------------------------------------------*
      *                  * Chiave di ordinamento alfanumerica generica *
      *                  *---------------------------------------------*
           move      w-srt-key-alf        to   srt-key-alf            .
      *                  *---------------------------------------------*
      *                  * Chiave di ordinamento alfanumerica generica *
      *                  * numero 2                                    *
      *                  *---------------------------------------------*
           move      w-srt-key-al2        to   srt-key-al2            .
       stp-srt-inp-cms-600.
      *              *-------------------------------------------------*
      *              * Composizione dati di sort                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Per ospitare un intero 'rf-dcc'             *
      *                  *---------------------------------------------*
           move      rf-dcc               to   srt-dat-rec-dcc        .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-cms-900.
       stp-srt-inp-cms-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-cms-999.
       stp-srt-inp-cms-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Composizione area di sort supplementare in caso di ordi-  *
      *    * namento clienti per mnemonico                             *
      *    *-----------------------------------------------------------*
       stp-srt-inp-csu-000.
      *              *-------------------------------------------------*
      *              * Test preliminare                                *
      *              *-------------------------------------------------*
           if        w-srt-ord-cli        not  = 03
                     go to stp-srt-inp-csu-900.
      *              *-------------------------------------------------*
      *              * Preparazione preliminare del codice cliente per *
      *              * la scansione                                    *
      *              *-------------------------------------------------*
           move      rf-dcc-cod-cli       to   w-srt-cod-cli          .
      *              *-------------------------------------------------*
      *              * Preparazione preliminare delle chiavi di sort   *
      *              *-------------------------------------------------*
           move      srt-key-ncl          to   w-srt-key-ncl          .
           move      srt-key-acl          to   w-srt-key-acl          .
       stp-srt-inp-csu-100.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione eventuali dipendenze per il  *
      *              * cliente in corso di trattamento                 *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CODCLI    "         to   f-key                  .
           move      w-srt-cod-cli        to   rf-dcc-cod-cli         .
           move      spaces               to   rf-dcc-dpz-cli         .
           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : ad uscita                 *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-csu-900.
       stp-srt-inp-csu-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale archivio [dcc]              *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
      *                  *---------------------------------------------*
      *                  * Se lettura errata : ad uscita               *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-csu-900.
       stp-srt-inp-csu-300.
      *              *-------------------------------------------------*
      *              * Test max                                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice                              *
      *                  *---------------------------------------------*
           if        rf-dcc-cod-cli       >    w-srt-cod-cli
                     go to stp-srt-inp-csu-900.
       stp-srt-inp-csu-400.
      *              *-------------------------------------------------*
      *              * Selezioni per le dipendenze                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se codice dipendenza a spaces : riciclo     *
      *                  *---------------------------------------------*
           if        rf-dcc-dpz-cli       =    spaces
                     go to stp-srt-inp-csu-200.
      *                  *---------------------------------------------*
      *                  * Selettori supplementari                     *
      *                  *---------------------------------------------*
       stp-srt-inp-csu-410.
      *                      *-----------------------------------------*
      *                      * Codice agente                           *
      *                      *-----------------------------------------*
           if        rr-ssu-cod-age       =    zero
                     go to stp-srt-inp-csu-420.
           if        rf-dcc-cod-age       not  = rr-ssu-cod-age
                     go to stp-srt-inp-csu-200.
       stp-srt-inp-csu-420.
      *                      *-----------------------------------------*
      *                      * Codice zona                             *
      *                      *-----------------------------------------*
           if        rr-ssu-cod-zon       =    zero
                     go to stp-srt-inp-csu-600.
           if        rf-dcc-cod-zon       not  = rr-ssu-cod-zon
                     go to stp-srt-inp-csu-200.
       stp-srt-inp-csu-430.
      *                      *-----------------------------------------*
      *                      * Codici di avviamento postale            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Rilevamento del codice avviamento   *
      *                          * postale dal campo localita'         *
      *                          *-------------------------------------*
           move      rf-dcc-loc-dcc       to   w-srt-cap-avp          .
      *                          *-------------------------------------*
      *                          * Test sui CAP                        *
      *                          *-------------------------------------*
           if        w-srt-cap-avp        >    w-srt-cap-fi1  or
                     w-srt-cap-avp        <    w-srt-cap-in1
                     go to stp-srt-inp-csu-200.
           if        w-srt-cap-avp        >    w-srt-cap-fi2  or
                     w-srt-cap-avp        <    w-srt-cap-in2
                     go to stp-srt-inp-csu-200.
           if        w-srt-cap-avp        >    w-srt-cap-fi3  or
                     w-srt-cap-avp        <    w-srt-cap-in3
                     go to stp-srt-inp-csu-200.
           if        w-srt-cap-avp        >    w-srt-cap-fi4  or
                     w-srt-cap-avp        <    w-srt-cap-in4
                     go to stp-srt-inp-csu-200.
           if        w-srt-cap-avp        >    w-srt-cap-fi5  or
                     w-srt-cap-avp        <    w-srt-cap-in5
                     go to stp-srt-inp-csu-200.
           if        w-srt-cap-avp        >    w-srt-cap-fi6  or
                     w-srt-cap-avp        <    w-srt-cap-in6
                     go to stp-srt-inp-csu-200.
       stp-srt-inp-csu-600.
      *              *-------------------------------------------------*
      *              * Composizione area di sort                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Composizione chiavi di sort                 *
      *                  *---------------------------------------------*
           move      w-srt-key-num        to   srt-key-num            .
           move      w-srt-key-alf        to   srt-key-alf            .
           move      w-srt-key-al2        to   srt-key-al2            .
           move      w-srt-key-ncl        to   srt-key-ncl            .
           move      w-srt-key-acl        to   srt-key-acl            .
           move      rf-dcc-dpz-cli       to   srt-key-adp            .
      *                  *---------------------------------------------*
      *                  * Composizione dati di sort                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Per ospitare un intero 'rf-dcc'         *
      *                      *-----------------------------------------*
           move      rf-dcc               to   srt-dat-rec-dcc        .
       stp-srt-inp-csu-800.
      *              *-------------------------------------------------*
      *              * Rilascio del record al sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-csu-850.
      *              *-------------------------------------------------*
      *              * Riciclo a record successivo                     *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-csu-200.
       stp-srt-inp-csu-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-csu-999.
       stp-srt-inp-csu-999.
           exit.

