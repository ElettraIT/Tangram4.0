                                         using s                      .
           call      s-pat               using f
                                               rf-zfp                 .
      *                              *---------------------------------*
      *                              * Normalizzazione descrizione     *
      *                              *---------------------------------*
           move      all "."              to   rf-zfp-des-fop         .
