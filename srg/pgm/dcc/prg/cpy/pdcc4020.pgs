      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * N.B. : Questa parte del programma e' perfettamente uguale *
      *    *        per tutte le overlay 'dcc402'                      *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Preparazione del tipo ordinamento anagrafica    *
      *              * clienti e dei selettori per la scansione del-   *
      *              * anagrafica clienti                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-srt-ord-cli          .
           move      zero                 to   w-srt-coc-min          .
           move      zero                 to   w-srt-coc-max          .
           move      spaces               to   w-srt-rsc-min          .
           move      spaces               to   w-srt-rsc-max          .
           move      spaces               to   w-srt-mnc-min          .
           move      spaces               to   w-srt-mnc-max          .
      *              *-------------------------------------------------*
      *              * Test sul tipo ordinamento stampa                *
      *              *-------------------------------------------------*
           if        rr-tip-ors           =    01
                     go to stp-srt-inp-020.
       stp-srt-inp-010.
      *              *-------------------------------------------------*
      *              * Se ordinamento stampa per altra anagrafica      *
      *              *-------------------------------------------------*
           move      rr-tip-ocp           to   w-srt-ord-cli          .
           move      zero                 to   w-srt-coc-min          .
           move      9999999              to   w-srt-coc-max          .
           move      spaces               to   w-srt-rsc-min          .
           move      all "z"              to   w-srt-rsc-max          .
           move      spaces               to   w-srt-mnc-min          .
           move      all "z"              to   w-srt-mnc-max          .
      *                  *---------------------------------------------*
      *                  * A inizio ciclo di scansione                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-100.
       stp-srt-inp-020.
      *              *-------------------------------------------------*
      *              * Se ordinamento stampa per cliente               *
      *              *-------------------------------------------------*
           move      rr-ord-ana-cli       to   w-srt-ord-cli          .
           move      rr-sel-cli-coi       to   w-srt-coc-min          .
           move      rr-sel-cli-cof       to   w-srt-coc-max          .
           move      rr-sel-cli-rsi       to   w-srt-rsc-min          .
           move      rr-sel-cli-rsf       to   w-srt-rsc-max          .
           move      rr-sel-cli-mni       to   w-srt-mnc-min          .
           move      rr-sel-cli-mnf       to   w-srt-mnc-max          .
      *                  *---------------------------------------------*
      *                  * A inizio ciclo di scansione                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-100.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Inizio ciclo di scansione archivio clienti      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo ordinamento *
      *                  * clienti                                     *
      *                  *---------------------------------------------*
           if        w-srt-ord-cli        =    01
                     go to stp-srt-inp-110
           else if   w-srt-ord-cli        =    02
                     go to stp-srt-inp-120
           else if   w-srt-ord-cli        =    03
                     go to stp-srt-inp-130.
       stp-srt-inp-110.
      *              *-------------------------------------------------*
      *              * Se ordinamento clienti per ragione sociale      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start per ragione sociale in uppercase      *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "RAGKEY    "         to   f-key                  .
           move      w-srt-rsc-min        to   rf-dcc-rag-key         .
           move      zero                 to   rf-dcc-cod-cli         .
           move      spaces               to   rf-dcc-dpz-cli         .
           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
      *                      *-----------------------------------------*
      *                      * Se Start errata : ad uscita             *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A read-next                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-120.
      *              *-------------------------------------------------*
      *              * Se ordinamento clienti per codice               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start per codice                            *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CODCLI    "         to   f-key                  .
           move      w-srt-coc-min        to   rf-dcc-cod-cli         .
           move      spaces               to   rf-dcc-dpz-cli         .
           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
      *                      *-----------------------------------------*
      *                      * Se Start errata : ad uscita             *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A read-next                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-130.
      *              *-------------------------------------------------*
      *              * Se ordinamento clienti per mnemonico            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start per mnemonico su archivio [cli]       *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CODMNE    "         to   f-key                  .
           move      w-srt-mnc-min        to   rf-cli-cod-mne         .
           move      zero                 to   rf-cli-cod-cli         .
           move      "pgm/cge/fls/ioc/obj/iofcli"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cli                 .
      *                      *-----------------------------------------*
      *                      * Se Start errata : ad uscita             *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A read-next                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Read-next su anagrafica clienti                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Indicatore di programma in esecuzione       *
      *                  *---------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo ordinamento *
      *                  * clienti                                     *
      *                  *---------------------------------------------*
           if        w-srt-ord-cli        =    01
                     go to stp-srt-inp-210
           else if   w-srt-ord-cli        =    02
                     go to stp-srt-inp-210
           else if   w-srt-ord-cli        =    03
                     go to stp-srt-inp-230.
       stp-srt-inp-210.
      *              *-------------------------------------------------*
      *              * Se ordinamento clienti per ragione sociale o    *
      *              * codice                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale archivio [dcc]          *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
      *                      *-----------------------------------------*
      *                      * Se lettura errata : ad uscita           *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A test-max                                  *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-300.
       stp-srt-inp-230.
      *              *-------------------------------------------------*
      *              * Se ordinamento clienti per mnemonico            *
      *              * codice                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale archivio [cli]          *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofcli"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cli                 .
      *                      *-----------------------------------------*
      *                      * Se lettura errata : ad uscita           *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A test-max                                  *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-300.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Test-max su anagrafica clienti                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo ordinamento *
      *                  * clienti                                     *
      *                  *---------------------------------------------*
           if        w-srt-ord-cli        =    01
                     go to stp-srt-inp-310
           else if   w-srt-ord-cli        =    02
                     go to stp-srt-inp-320
           else if   w-srt-ord-cli        =    03
                     go to stp-srt-inp-330.
       stp-srt-inp-310.
      *              *-------------------------------------------------*
      *              * Se ordinamento clienti per ragione sociale      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su ragione sociale in chiave           *
      *                  *---------------------------------------------*
           if        rf-dcc-rag-key       >    w-srt-rsc-max
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A selezioni                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-400.
       stp-srt-inp-320.
      *              *-------------------------------------------------*
      *              * Se ordinamento clienti per codice               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice                              *
      *                  *---------------------------------------------*
           if        rf-dcc-cod-cli       >    w-srt-coc-max
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A selezioni                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-400.
       stp-srt-inp-330.
      *              *-------------------------------------------------*
      *              * Se ordinamento clienti per mnemonico            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su mnemonico                           *
      *                  *---------------------------------------------*
           if        rf-cli-cod-mne       >    w-srt-mnc-max
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A selezioni                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-400.
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni su anagrafica clienti                 *
      *              *-------------------------------------------------*
           perform   stp-srt-inp-sel-000  thru stp-srt-inp-sel-999    .
      *                  *---------------------------------------------*
      *                  * Test sul flag di uscita dalla routine di    *
      *                  * selezione                                   *
      *                  *---------------------------------------------*
           if        w-srt-sel-rec        not  = spaces
                     go to stp-srt-inp-200.
       stp-srt-inp-450.
      *              *-------------------------------------------------*
      *              * Selezioni su anagrafica clienti in relazione    *
      *              * alle voci aggiuntive usate come selettori       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test sul tipo stampa                        *
      *                  *---------------------------------------------*
           if        rr-tip-stp           not  = 11 and
                     rr-tip-stp           not  = 51
                     go to stp-srt-inp-500.
      *                  *---------------------------------------------*
      *                  * Test su si/no campi selettori               *
      *                  *---------------------------------------------*
           if        rr-snx-cse           not  = 02 and
                     rr-snx-cse           not  = 03
                     go to stp-srt-inp-500.
      *                  *---------------------------------------------*
      *                  * Selezioni vere e proprie                    *
      *                  *---------------------------------------------*
           perform   stp-srt-inp-svd-000  thru stp-srt-inp-svd-999    .
      *                  *---------------------------------------------*
      *                  * Test sul flag di uscita dalla routine di    *
      *                  * selezione                                   *
      *                  *---------------------------------------------*
           if        w-srt-sel-rec        not  = spaces
                     go to stp-srt-inp-200.
       stp-srt-inp-500.
      *              *-------------------------------------------------*
      *              * Selezioni supplementari su anagrafica clienti   *
      *              *-------------------------------------------------*
           perform   stp-srt-inp-ssu-000  thru stp-srt-inp-ssu-999    .
      *                  *---------------------------------------------*
      *                  * Test sul flag di uscita dalla routine di    *
      *                  * selezione                                   *
      *                  *---------------------------------------------*
           if        w-srt-sel-rec        not  = spaces
                     go to stp-srt-inp-200.
       stp-srt-inp-600.
      *              *-------------------------------------------------*
      *              * Composizione area di sort                       *
      *              *-------------------------------------------------*
           perform   stp-srt-inp-cms-000  thru stp-srt-inp-cms-999    .
       stp-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Rilascio del record al sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-820.
      *              *-------------------------------------------------*
      *              * Composizione area di sort supplementare per le  *
      *              * dipendenze, solo in caso di ordinamento per co- *
      *              * dice mnemonico clienti                          *
      *              *-------------------------------------------------*
           perform   stp-srt-inp-csu-000  thru stp-srt-inp-csu-999    .
       stp-srt-inp-880.
      *              *-------------------------------------------------*
      *              * Riciclo ad anagrafica cliente successiva        *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Selezioni su anagrafica clienti                           *
      *    *-----------------------------------------------------------*
       stp-srt-inp-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-srt-sel-rec          .
      *              *-------------------------------------------------*
      *              * Normalizzazione chiavi di sort per anagrafiche  *
      *              * generiche                                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-srt-key-num          .
           move      spaces               to   w-srt-key-alf          .
           move      spaces               to   w-srt-key-al2          .
       stp-srt-inp-sel-010.
      *              *-------------------------------------------------*
      *              * In caso di ordinamento clienti per mnemonico si *
      *              * legge la relativa anagrafica [dcc]              *
      *              *-------------------------------------------------*
           if        w-srt-ord-cli        not  = 03
                     go to stp-srt-inp-sel-050.
      *                  *---------------------------------------------*
      *                  * Lettura per codice record [dcc]             *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLI"             to   f-key                  .
           move      rf-cli-cod-cli       to   rf-dcc-cod-cli         .
           move      spaces               to   rf-dcc-dpz-cli         .
           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
      *                      *-----------------------------------------*
      *                      * Se record [dcc] non trovato : uscita    *
      *                      * per selezione non superata              *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-sel-900.
       stp-srt-inp-sel-050.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del Tipo ordinamento     *
      *              * stampa                                          *
      *              *-------------------------------------------------*
           if        rr-tip-ors           =    01
                     go to stp-srt-inp-sel-100
           else if   rr-tip-ors           =    02
                     go to stp-srt-inp-sel-200
           else if   rr-tip-ors           =    03
                     go to stp-srt-inp-sel-300
           else if   rr-tip-ors           =    04
                     go to stp-srt-inp-sel-400
           else if   rr-tip-ors           =    05
                     go to stp-srt-inp-sel-500
           else if   rr-tip-ors           =    06
                     go to stp-srt-inp-sel-600
           else if   rr-tip-ors           =    07
                     go to stp-srt-inp-sel-a00
           else if   rr-tip-ors           =    08
                     go to stp-srt-inp-sel-b00
           else if   rr-tip-ors           =    09
                     go to stp-srt-inp-sel-c00
           else if   rr-tip-ors           =    11
                     go to stp-srt-inp-sel-610
           else if   rr-tip-ors           =    12
                     go to stp-srt-inp-sel-620
           else if   rr-tip-ors           =    13
                     go to stp-srt-inp-sel-630
           else if   rr-tip-ors           =    14
                     go to stp-srt-inp-sel-640
           else if   rr-tip-ors           =    21   or
                     rr-tip-ors           =    22
                     go to stp-srt-inp-sel-710
           else      go to stp-srt-inp-sel-800.
       stp-srt-inp-sel-100.
      *                  *---------------------------------------------*
      *                  * Se ordinamento per cliente                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Selezione su codice dipendenza          *
      *                      *                                         *
      *                      * N.B.: Questa selezione si opera solo    *
      *                      *       nel caso che sia stata richiesta  *
      *                      *       la stampa di una singola scheda   *
      *                      *       dal programma di gestione         *
      *                      *-----------------------------------------*
           if        rr-sel-cli-dpz       =    spaces
                     go to stp-srt-inp-sel-180.
           if        rf-dcc-dpz-cli       not  = rr-sel-cli-dpz
                     go to stp-srt-inp-sel-900.
       stp-srt-inp-sel-180.
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-sel-800.
       stp-srt-inp-sel-200.
      *                  *---------------------------------------------*
      *                  * Se ordinamento per agente                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se codice agente a zero : uscita per    *
      *                      * elemento non selezionato                *
      *                      *-----------------------------------------*
           if        rf-dcc-cod-age       =    zero
                     go to stp-srt-inp-sel-900.
      *                      *-----------------------------------------*
      *                      * Lettura preliminare anagrafica agente   *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODAGE    "         to   f-key                  .
           move      rf-dcc-cod-age       to   rf-age-cod-age         .
           move      "pgm/age/fls/ioc/obj/iofage"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-age                 .
      *                          *-------------------------------------*
      *                          * Se record trovato : a selezioni     *
      *                          *-------------------------------------*
           if        f-sts                =    e-not-err
                     go to stp-srt-inp-sel-210.
      *                          *-------------------------------------*
      *                          * Se record non trovato               *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Normalizzazione record          *
      *                              *---------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/age/fls/ioc/obj/iofage"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-age                 .
      *                              *---------------------------------*
      *                              * Normalizzazione nominativo      *
      *                              *---------------------------------*
           move      all "."              to   rf-age-nom-age         .
      *                              *---------------------------------*
      *                              * Normalizzazione ragione sociale *
      *                              *---------------------------------*
           move      all "."              to   rf-age-rag-soc         .
      *                              *---------------------------------*
      *                              * Se ordinamento per codice : a   *
      *                              * selezione su solo codice        *
      *                              *---------------------------------*
           if        rr-ord-ana-age       =    03
                     go to stp-srt-inp-sel-212.
      *                              *---------------------------------*
      *                              * Altrimenti                      *
      *                              *  - Se selezione totale : Ok     *
      *                              *  - In caso contrario   : Ko     *
      *                              *---------------------------------*
           if        rr-ord-ana-age       =    01
                     if    rr-sel-age-noi =    all " " and
                           rr-sel-age-nof =    all "z"
                           go to stp-srt-inp-sel-214
                     else  go to stp-srt-inp-sel-900
           else if   rr-ord-ana-age       =    02
                     if    rr-sel-age-rsi =    all " " and
                           rr-sel-age-rsf =    all "z"
                           go to stp-srt-inp-sel-214
                     else  go to stp-srt-inp-sel-900
           else if   rr-ord-ana-age       =    04
                     if    rr-sel-age-mni =    all " " and
                           rr-sel-age-mnf =    all "z"
                           go to stp-srt-inp-sel-214
                     else  go to stp-srt-inp-sel-900.
       stp-srt-inp-sel-210.
      *                      *-----------------------------------------*
      *                      * Selezioni su anagrafica agente          *
      *                      *-----------------------------------------*
           if        rf-age-nom-age       >    rr-sel-age-nof or
                     rf-age-nom-age       <    rr-sel-age-noi
                     go to stp-srt-inp-sel-900.
           if        rf-age-rag-soc       >    rr-sel-age-rsf or
                     rf-age-rag-soc       <    rr-sel-age-rsi
                     go to stp-srt-inp-sel-900.
           if        rf-age-cod-mne       >    rr-sel-age-mnf or
                     rf-age-cod-mne       <    rr-sel-age-mni
                     go to stp-srt-inp-sel-900.
       stp-srt-inp-sel-212.
           if        rf-age-cod-age       >    rr-sel-age-cof or
                     rf-age-cod-age       <    rr-sel-age-coi
                     go to stp-srt-inp-sel-900.
       stp-srt-inp-sel-214.
      *                      *-----------------------------------------*
      *                      * Preparazione chiavi per il sort         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Chiave numerica                     *
      *                          *-------------------------------------*
           move      rf-age-cod-age       to   w-srt-key-num          .
      *                          *-------------------------------------*
      *                          * Chiave alfanumerica                 *
      *                          *-------------------------------------*
           if        rr-ord-ana-age       =    01
                     move  rf-age-nom-age to   w-srt-key-alf
           else if   rr-ord-ana-age       =    02
                     move  rf-age-rag-soc to   w-srt-key-alf
           else if   rr-ord-ana-age       =    03
                     move  spaces         to   w-srt-key-alf
           else if   rr-ord-ana-age       =    04
                     move  rf-age-cod-mne to   w-srt-key-alf          .
      *                          *-------------------------------------*
      *                          * Chiave alfanumerica 2               *
      *                          *-------------------------------------*
           move      spaces               to   w-srt-key-al2          .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-sel-800.
