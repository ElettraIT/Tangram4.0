      *    *===========================================================*
      *    * Subroutines per l'accettazione del codice lingua          *
      *    *-----------------------------------------------------------*
       cod-cod-zln-opn-000.
           move      "pgm/dcc/prg/obj/acodzln0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           move      s-pat                to   w-cod-cod-zln-pth      .
           move      "OP"                 to   w-cod-cod-zln-ope      .
           perform   cod-cod-zln-cll-000  thru cod-cod-zln-cll-999    .
       cod-cod-zln-opn-999.
           exit.
       cod-cod-zln-cls-000.
           move      "CL"                 to   w-cod-cod-zln-ope      .
           perform   cod-cod-zln-cll-000  thru cod-cod-zln-cll-999    .
           move      "C?"                 to   w-cod-cod-zln-ope      .
           perform   cod-cod-zln-cll-000  thru cod-cod-zln-cll-999    .
           if        w-cod-cod-zln-ope    not  = spaces
                     go to cod-cod-zln-cls-999.
           cancel    w-cod-cod-zln-pth                                .
       cod-cod-zln-cls-999.
           exit.
       cod-cod-zln-foi-000.
           if        v-key                not  = "INSR"
                     go to cod-cod-zln-foi-500.
           move      "P?"                 to   s-ope                  .
           move      "pdcc0100"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to cod-cod-zln-foi-999.
           move      "pgm/dcc/prg/obj/pdcc0100"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
           move      "I+"                 to   w-cod-cod-zln-ope      .
           go to     cod-cod-zln-foi-999.
       cod-cod-zln-foi-500.
           if        v-key                not  = "FIND"
                     go to cod-cod-zln-foi-999.
           move      "P?"                 to   s-ope                  .
           move      "pdcc0110"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to cod-cod-zln-foi-999.
           move      "PV"                 to   s-ope                  .
           move      "fkselect"           to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      04                   to   s-car                  .
           move      "SLCT"               to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      "pgm/dcc/prg/obj/pdcc0110"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
           move      "F+"                 to   w-cod-cod-zln-ope      .
           go to     cod-cod-zln-foi-999.
       cod-cod-zln-foi-999.
           exit.
       cod-cod-zln-cll-000.
           call      w-cod-cod-zln-pth   using w-cod-cod-zln
                                               v
                                               s                      .
       cod-cod-zln-cll-999.
           exit.

