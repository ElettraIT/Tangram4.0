      *    *===========================================================*
      *    * Subroutines per l'accettazione del codice marketing cli-  *
      *    * enti                                                      *
      *    *-----------------------------------------------------------*
       cmn-zkc-001-opn-000.
           move      "pgm/dcc/prg/obj/acmnzkc1"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           move      s-pat                to   w-cmn-zkc-001-pth      .
           move      "OP"                 to   w-cmn-zkc-001-ope      .
           perform   cmn-zkc-001-cll-000  thru cmn-zkc-001-cll-999    .
       cmn-zkc-001-opn-999.
           exit.
       cmn-zkc-001-cls-000.
           move      "CL"                 to   w-cmn-zkc-001-ope      .
           perform   cmn-zkc-001-cll-000  thru cmn-zkc-001-cll-999    .
           move      "C?"                 to   w-cmn-zkc-001-ope      .
           perform   cmn-zkc-001-cll-000  thru cmn-zkc-001-cll-999    .
           if        w-cmn-zkc-001-ope    not  = spaces
                     go to cmn-zkc-001-cls-999.
           cancel    w-cmn-zkc-001-pth                                .
       cmn-zkc-001-cls-999.
           exit.
       cmn-zkc-001-foi-000.
           if        v-key                not  = "INSR"
                     go to cmn-zkc-001-foi-500.
           move      "P?"                 to   s-ope                  .
           move      "pdcc1450"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to cmn-zkc-001-foi-999.
           move      "pgm/dcc/prg/obj/pdcc1450"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
           move      "I+"                 to   w-cmn-zkc-001-ope      .
           go to     cmn-zkc-001-foi-999.
       cmn-zkc-001-foi-500.
           if        v-key                not  = "FIND"
                     go to cmn-zkc-001-foi-999.
           move      "P?"                 to   s-ope                  .
           move      "pdcc1460"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to cmn-zkc-001-foi-999.
           move      "PV"                 to   s-ope                  .
           move      "fkselect"           to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      04                   to   s-car                  .
           move      "SLCT"               to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      "pgm/dcc/prg/obj/pdcc1460"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
           move      "F+"                 to   w-cmn-zkc-001-ope      .
           go to     cmn-zkc-001-foi-999.
       cmn-zkc-001-foi-999.
           exit.
       cmn-zkc-001-cll-000.
           call      w-cmn-zkc-001-pth   using w-cmn-zkc-001
                                               v
                                               s                      .
       cmn-zkc-001-cll-999.
           exit.

