           if        rr-snx-pze           =    01
                     go to prn-sel-rec-500.
           if        w-det-prz-lst-pr1    =    w-det-prz-lst-pr2
                     go to prn-sel-rec-900.
       prn-sel-rec-500.
      *              *-------------------------------------------------*
      *              * Selezione su validita'                          *
      *              *-------------------------------------------------*
           if        rr-sel-vld           =    01
                     go to prn-sel-rec-800.
      *              *-------------------------------------------------*
      *              * Test se presenti date di validita'              *
      *              *-------------------------------------------------*
           if        w-let-arc-lst-ini    =    zero and
                     w-let-arc-lst-fin    =    zero
                     go to prn-sel-rec-800.
      *              *-------------------------------------------------*
      *              * Data di sistema                                 *
      *              *-------------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       prn-sel-rec-520.
      *              *-------------------------------------------------*
      *              * Se solo prezzi in vigore                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        rr-sel-vld           =    03
                     go to prn-sel-rec-540.
      *                  *---------------------------------------------*
      *                  * Confronto data iniziale                     *
      *                  *---------------------------------------------*
           if        w-let-arc-lst-ini    =    zero
                     go to prn-sel-rec-522.
           if        w-let-arc-lst-ini    not  < s-dat
                     go to prn-sel-rec-900.
       prn-sel-rec-522.
      *                  *---------------------------------------------*
      *                  * Confronto data finale                       *
      *                  *---------------------------------------------*
           if        w-let-arc-lst-fin    =    zero
                     go to prn-sel-rec-800.
           if        w-let-arc-lst-fin    <    s-dat
                     go to prn-sel-rec-900.
      *
           go to     prn-sel-rec-800.
       prn-sel-rec-540.
      *              *-------------------------------------------------*
      *              * Se solo prezzi scaduti                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Confronto data iniziale                     *
      *                  *---------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Confronto data finale                       *
      *                  *---------------------------------------------*
           if        w-let-arc-lst-fin    =    zero
                     go to prn-sel-rec-800.
           if        w-let-arc-lst-fin    >    s-dat
                     go to prn-sel-rec-900.
