           move      "PV"                 to   d-prz-ven-tip-ope      .
           move      zero                 to   d-prz-ven-cod-cli      .
           move      c-sgl                to   d-prz-ven-sgl-vpp      .
           move      c-dec                to   d-prz-ven-dec-vpp      .
           move      rf-dcp-num-pro       to   d-prz-ven-num-pro      .
           move      rr-cod-lst           to   d-prz-ven-cod-lst      .
           move      rf-dcp-prz-lst       to   d-prz-ven-prz-lsb      .
           move      c-sgl                to   d-prz-ven-sgl-vlb      .
           move      c-dec                to   d-prz-ven-dec-vlb      .
