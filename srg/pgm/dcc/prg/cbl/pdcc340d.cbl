           move      zero                 to   w-let-arc-zp2-sqz      .
       let-arc-zp2-999.
           exit.

      *    *===========================================================*
      *    * Routine lettura tabella [zp3]                             *
      *    *-----------------------------------------------------------*
       let-arc-zp3-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-zp3-flg      .
      *              *-------------------------------------------------*
      *              * Test se codice sottogruppo a zero               *
      *              *-------------------------------------------------*
           if        w-let-arc-zp3-sgr    =    zero
                     go to let-arc-zp3-500.
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODSGR    "         to   f-key                  .
           move      w-let-arc-zp3-cla    to   rf-zp3-cod-cla         .
           move      w-let-arc-zp3-gru    to   rf-zp3-cod-gru         .
           move      w-let-arc-zp3-sgr    to   rf-zp3-cod-sgr         .
           move      "pgm/dcp/fls/ioc/obj/iofzp3"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zp3                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-zp3-400.
       let-arc-zp3-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-zp3-des-sgr       to   w-let-arc-zp3-des      .
           move      rf-zp3-mne-sgr       to   w-let-arc-zp3-mne      .
           move      rf-zp3-ult-sud       to   w-let-arc-zp3-sud      .
           move      rf-zp3-sqz-num       to   w-let-arc-zp3-sqz      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-zp3-999.
       let-arc-zp3-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-zp3-flg      .
           move      all   "."            to   w-let-arc-zp3-des      .
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      05                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      w-let-arc-zp3-sgr    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edm                to   w-let-arc-zp3-mne      .
           go to     let-arc-zp3-600.
       let-arc-zp3-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-zp3-des      .
           move      spaces               to   w-let-arc-zp3-mne      .
       let-arc-zp3-600.
           move      zero                 to   w-let-arc-zp3-sud      .
           move      zero                 to   w-let-arc-zp3-sqz      .
       let-arc-zp3-999.
           exit.

      *    *===========================================================*
      *    * Routine lettura tabella [lst]                             *
      *    *-----------------------------------------------------------*
       let-arc-lst-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-lst-flg      .
      *              *-------------------------------------------------*
      *              * Test se codice a spazi                          *
      *              *-------------------------------------------------*
           if        w-let-arc-lst-tip    =    01     and
                     w-let-arc-lst-cod    =    spaces
                     go to let-arc-lst-500.
           if        w-let-arc-lst-tip    =    02     and
                     w-let-arc-lst-cli    =    zero
                     go to let-arc-lst-500.
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "LSTPRO    "         to   f-key                  .
           move      w-let-arc-lst-tip    to   rf-lst-tip-rec         .
           move      w-let-arc-lst-cod    to   rf-lst-cod-lst         .
           move      w-let-arc-lst-cli    to   rf-lst-cod-cli         .
           move      w-let-arc-lst-vlt    to   rf-lst-sgl-vlt         .
           move      w-let-arc-lst-pro    to   rf-lst-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-lst-400.
       let-arc-lst-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-lst-prz-lst       to   w-let-arc-lst-prz      .
           move      rf-lst-per-sco (1)   to   w-let-arc-lst-sco (1)  .
           move      rf-lst-per-sco (2)   to   w-let-arc-lst-sco (2)  .
           move      rf-lst-per-sco (3)   to   w-let-arc-lst-sco (3)  .
           move      rf-lst-per-sco (4)   to   w-let-arc-lst-sco (4)  .
           move      rf-lst-per-sco (5)   to   w-let-arc-lst-sco (5)  .
           move      rf-lst-per-pvg (1)   to   w-let-arc-lst-pvg (1)  .
           move      rf-lst-per-pvg (2)   to   w-let-arc-lst-pvg (2)  .
           move      rf-lst-per-pvg (3)   to   w-let-arc-lst-pvg (3)  .
           move      rf-lst-dva-ini       to   w-let-arc-lst-ini      .
           move      rf-lst-dva-fin       to   w-let-arc-lst-fin      .
      *                  *---------------------------------------------*
      *                  * Preparazione tipo funzionamento             *
      *                  *---------------------------------------------*
           if        rf-lst-snx-prz       =    "S"  and
                     rf-lst-snx-sco       =    "S"  and
                     rf-lst-snx-pvg       =    "S"
                     move  01             to   w-let-arc-lst-tfu
           else if   rf-lst-snx-prz       =    "S"  and
                     rf-lst-snx-sco       =    "N"  and
                     rf-lst-snx-pvg       =    "N"
                     move  02             to   w-let-arc-lst-tfu
           else if   rf-lst-snx-prz       =    "N"  and
                     rf-lst-snx-sco       =    "S"  and
                     rf-lst-snx-pvg       =    "N"
                     move  03             to   w-let-arc-lst-tfu
           else if   rf-lst-snx-prz       =    "N"  and
                     rf-lst-snx-sco       =    "N"  and
                     rf-lst-snx-pvg       =    "S"
                     move  04             to   w-let-arc-lst-tfu
           else if   rf-lst-snx-prz       =    "S"  and
                     rf-lst-snx-sco       =    "S"  and
                     rf-lst-snx-pvg       =    "N"
                     move  05             to   w-let-arc-lst-tfu
           else if   rf-lst-snx-prz       =    "S"  and
                     rf-lst-snx-sco       =    "N"  and
                     rf-lst-snx-pvg       =    "S"
                     move  06             to   w-let-arc-lst-tfu
           else if   rf-lst-snx-prz       =    "N"  and
                     rf-lst-snx-sco       =    "S"  and
                     rf-lst-snx-pvg       =    "S"
                     move  07             to   w-let-arc-lst-tfu
           else      move  zero           to   w-let-arc-lst-tfu      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-lst-999.
       let-arc-lst-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-lst-flg      .
           move      zero                 to   w-let-arc-lst-prz      .
           go to     let-arc-lst-600.
       let-arc-lst-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-let-arc-lst-prz      .
       let-arc-lst-600.
           move      zero                 to   w-let-arc-lst-sco (1)  .
           move      zero                 to   w-let-arc-lst-sco (2)  .
           move      zero                 to   w-let-arc-lst-sco (3)  .
           move      zero                 to   w-let-arc-lst-sco (4)  .
           move      zero                 to   w-let-arc-lst-sco (5)  .
           move      zero                 to   w-let-arc-lst-pvg (1)  .
           move      zero                 to   w-let-arc-lst-pvg (2)  .
           move      zero                 to   w-let-arc-lst-pvg (3)  .
           move      zero                 to   w-let-arc-lst-ini      .
           move      zero                 to   w-let-arc-lst-fin      .
           move      zero                 to   w-let-arc-lst-tfu      .
       let-arc-lst-999.
           exit.

