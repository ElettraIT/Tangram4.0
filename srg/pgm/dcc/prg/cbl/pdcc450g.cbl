           move      16                   to   w-cmn-zst-002-lin      .
           move      30                   to   w-cmn-zst-002-pos      .
           move      16                   to   w-cmn-zst-002-dln      .
           move      41                   to   w-cmn-zst-002-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "[1] "               to   v-pfk (14)             .
