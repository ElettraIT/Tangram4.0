           move      "AC"                 to   w-cmn-zst-001-ope      .
           move      w-tes-cod-zon        to   w-cmn-zst-001-cod      .
           move      w-lpt-cod-zon-lin    to   w-cmn-zst-001-lin      .
           move      w-lpt-cod-zon-pos    to   w-cmn-zst-001-pos      .
           add       16                   to   w-cmn-zst-001-pos      .
           move      zero                 to   w-cmn-zst-001-dln      .
           move      zero                 to   w-cmn-zst-001-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   cmn-zst-001-cll-000  thru cmn-zst-001-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cmn-zst-001-foi-000  thru cmn-zst-001-foi-999    .
       acc-cod-zon-so1-110.
           perform   cmn-zst-001-cll-000  thru cmn-zst-001-cll-999    .
           if        w-cmn-zst-001-ope    =    "F+"
                     go to acc-cod-zon-so1-115.
           if        w-cmn-zst-001-ope    =    "AC"
                     go to acc-cod-zon-so1-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-zon-so1-115.
           perform   cmn-zst-001-foi-000  thru cmn-zst-001-foi-999    .
           go to     acc-cod-zon-so1-110.
