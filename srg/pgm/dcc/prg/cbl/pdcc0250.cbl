      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cdc-vlt-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cdc-vlt-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-cdc-vlt (1)      .
       acc-cdc-vlt-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-cdc-vlt-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione % di scostamento             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se coefficiente di cambio a zero : no   *
      *                      * determinazione                          *
      *                      *-----------------------------------------*
           if        w-rig-cdc-vlt (1)    =    zero
                     move  zero           to   w-rig-per-scs (1)
                     move  spaces         to   w-rig-sgn-scs (1)
                     go to acc-cdc-vlt-800.
      *                      *-----------------------------------------*
      *                      * Se ultimo cambio rilevato a zero : no   *
      *                      * determinazione                          *
      *                      *-----------------------------------------*
           if        w-rig-cdc-urc (1)    =    zero
                     move  zero           to   w-rig-per-scs (1)
                     move  spaces         to   w-rig-sgn-scs (1)
                     go to acc-cdc-vlt-800.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           subtract  w-rig-cdc-urc (1)    from w-rig-cdc-vlt (1)
                                        giving w-rig-per-scs (1)      .
           multiply  100                  by   w-rig-per-scs (1)      .
           divide    w-rig-cdc-urc (1)    into w-rig-per-scs (1)
                                               rounded                .
      *                  *---------------------------------------------*
      *                  * Segnale di scostamento                      *
      *                  *---------------------------------------------*
           if        w-rig-per-scs (1)    >    10 or
                     w-rig-per-scs (1)    <   -10
                     move  "**"           to   w-rig-sgn-scs (1)
           else      move  spaces         to   w-rig-sgn-scs (1)      .
      *                  *---------------------------------------------*
      *                  * Se scostamento oltre il 10 % : box di av-   *
      *                  * vertimento                                  *
      *                  *---------------------------------------------*
           if        w-rig-sgn-scs (1)    =    spaces
                     go to acc-cdc-vlt-800.
           move      "Lo scostamento dal cambio base e' oltre il 10 % ! 
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
       acc-cdc-vlt-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
