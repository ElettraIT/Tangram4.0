      *    *===========================================================*
      *    * Composizione record righe [vlt]                           *
      *    *-----------------------------------------------------------*
       cmp-rec-vlt-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofvlt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vlt                 .
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           move      w-tes-dat-vlt        to   rf-vlt-dat-vlt         .
           move      99999999             to   rf-vlt-dat-rev         .
           if        rf-vlt-dat-vlt       not  = zero
                     subtract 19000000    from rf-vlt-dat-rev
                     subtract rf-vlt-dat-vlt
                                          from rf-vlt-dat-rev         .
           move      w-rig-sgl-vlt (1)    to   rf-vlt-sgl-vlt         .
           move      w-rig-tdc-vlt (1)    to   rf-vlt-tdc-vlt         .
           move      w-rig-cdc-vlt (1)    to   rf-vlt-cdc-vlt         .
           move      w-rig-cdc-add (1, 01)
                                          to   rf-vlt-cdc-add  (1)    .
           move      w-rig-cdc-add (1, 02)
                                          to   rf-vlt-cdc-add  (2)    .
           move      w-rig-cdc-add (1, 03)
                                          to   rf-vlt-cdc-add  (3)    .
           move      w-rig-cdc-add (1, 04)
                                          to   rf-vlt-cdc-add  (4)    .
           move      w-rig-cdc-add (1, 05)
                                          to   rf-vlt-cdc-add  (5)    .
           move      w-rig-cdc-add (1, 06)
                                          to   rf-vlt-cdc-add  (6)    .
           move      w-rig-cdc-add (1, 07)
                                          to   rf-vlt-cdc-add  (7)    .
           move      w-rig-cdc-add (1, 08)
                                          to   rf-vlt-cdc-add  (8)    .
           move      w-rig-cdc-add (1, 09)
                                          to   rf-vlt-cdc-add  (9)    .
           move      w-rig-alx-exp (1)    to   rf-vlt-alx-exp         .
       cmp-rec-vlt-999.
           exit.

      *    *===========================================================*
      *    * Scrittura record righe [vlt]                              *
      *    *-----------------------------------------------------------*
       wrt-rec-vlt-000.
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           perform   cmp-rec-vlt-000      thru cmp-rec-vlt-999        .
      *              *-------------------------------------------------*
      *              * Put record                                      *
      *              *-------------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofvlt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vlt                 .
       wrt-rec-vlt-999.
           exit.

      *    *===========================================================*
      *    * Riscrittura record righe [vlt]                            *
      *    *-----------------------------------------------------------*
       rew-rec-vlt-000.
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           perform   cmp-rec-vlt-000      thru cmp-rec-vlt-999        .
      *              *-------------------------------------------------*
      *              * Force Put record                                *
      *              *-------------------------------------------------*
           move      "FP"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofvlt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vlt                 .
       rew-rec-vlt-999.
           exit.

      *    *===========================================================*
      *    * Cancellazione record righe [vlt]                          *
      *    *-----------------------------------------------------------*
       del-rec-vlt-000.
      *              *-------------------------------------------------*
      *              * Composizione chiave primaria                    *
      *              *-------------------------------------------------*
           move      w-tes-dat-vlt        to   rf-vlt-dat-vlt         .
           move      w-rig-sgl-vlt (2)    to   rf-vlt-sgl-vlt         .
      *              *-------------------------------------------------*
      *              * Delete record                                   *
      *              *-------------------------------------------------*
           move      "DE"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofvlt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vlt                 .
       del-rec-vlt-999.
           exit.

      *    *===========================================================*
      *    * Precaricamento tabella valute                             *
      *    *-----------------------------------------------------------*
       pre-tbl-vlt-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-vlt-tbl-flg          .
      *              *-------------------------------------------------*
      *              * Normalizzazione contatore sigle valuta          *
      *              *-------------------------------------------------*
           move      zero                 to   w-vlt-ctr-rig          .
       pre-tbl-vlt-100.
      *              *-------------------------------------------------*
      *              * Open file [zvl]                                 *
      *              *-------------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofzvl"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zvl                 .
      *              *-------------------------------------------------*
      *              * Inizio ciclo di caricamento                     *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "CODVLT    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      spaces               to   rf-zvl-sgl-vlt         .
           move      "pgm/dcc/fls/ioc/obj/iofzvl"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zvl                 .
      *                  *---------------------------------------------*
      *                  * Se errore di start : uscita con flag di er- *
      *                  * rore                                        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     move  "#"            to   w-vlt-tbl-flg
                     go to  pre-tbl-vlt-900.
       pre-tbl-vlt-200.
      *              *-------------------------------------------------*
      *              * Read-next su file [zvl]                         *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofzvl"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zvl                 .
      *                  *---------------------------------------------*
      *                  * Se errore di start : a test sul contatore   *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to pre-tbl-vlt-500.
      *              *-------------------------------------------------*
      *              * Test se valuta di base                          *
      *              *-------------------------------------------------*
           if        rf-zvl-sgl-vlt       =    c-sgl
                     go to pre-tbl-vlt-200.
      *              *-------------------------------------------------*
      *              * Test su status valuta                           *
      *              *-------------------------------------------------*
           if        rf-zvl-sta-tus       not  = spaces
                     go to pre-tbl-vlt-200.
      *              *-------------------------------------------------*
      *              * Incremento contatore                            *
      *              *-------------------------------------------------*
           add       1                    to   w-vlt-ctr-rig          .
           if        w-vlt-ctr-rig        >    w-vlt-ctr-max
                     go to pre-tbl-vlt-500.
      *              *-------------------------------------------------*
      *              * Bufferizzazioni                                 *
      *              *-------------------------------------------------*
           move      rf-zvl-sgl-vlt       to   w-vlt-sgl-vlt
                                              (w-vlt-ctr-rig)         .
           move      rf-zvl-des-ita       to   w-vlt-des-vlt
                                              (w-vlt-ctr-rig)         .
           move      rf-zvl-def-tdc       to   w-vlt-tdc-vlt
                                              (w-vlt-ctr-rig)         .
      *              *-------------------------------------------------*
      *              * Riciclo a riga successiva                       *
      *              *-------------------------------------------------*
           go to     pre-tbl-vlt-200.
       pre-tbl-vlt-500.
      *              *-------------------------------------------------*
      *              * Test sul contatore                              *
      *              *-------------------------------------------------*
           if        w-vlt-ctr-rig        =    zero
                     move  "#"            to   w-vlt-tbl-flg          .
       pre-tbl-vlt-900.
      *              *-------------------------------------------------*
      *              * Close file [zvl]                                *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofzvl"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zvl                 .
       pre-tbl-vlt-999.
           exit.

