      *                  *---------------------------------------------*
      *                  * Bufferizzazione valori contenuti in tabella *
      *                  * valute                                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Numero riga                             *
      *                      *-----------------------------------------*
           move      w-cix-ctr-rig        to   w-rig-num-prg (1)      .
      *                      *-----------------------------------------*
      *                      * Sigla valuta                            *
      *                      *-----------------------------------------*
           move      w-vlt-sgl-vlt
                    (w-cix-ctr-rig)       to   w-rig-sgl-vlt (1)      .
      *                      *-----------------------------------------*
      *                      * Descrizione valuta                      *
      *                      *-----------------------------------------*
           move      w-vlt-des-vlt
                    (w-cix-ctr-rig)       to   w-rig-sgl-vlt-des (1)  .
      *                      *-----------------------------------------*
      *                      * Tipo di coefficiente                    *
      *                      *-----------------------------------------*
           move      w-vlt-tdc-vlt
                    (w-cix-ctr-rig)       to   w-rig-tdc-vlt (1)      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valori contenuti diretta-   *
      *                  * mente in record [vlt]                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione record [vlt]            *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofvlt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vlt                 .
      *                      *-----------------------------------------*
      *                      * Lettura record [vlt]                    *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "DATSGL    "         to   f-key                  .
           move      w-tes-dat-vlt        to   rf-vlt-dat-vlt         .
           move      w-rig-sgl-vlt (1)    to   rf-vlt-sgl-vlt         .
           move      "pgm/dcc/fls/ioc/obj/iofvlt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vlt                 .
      *                      *-----------------------------------------*
      *                      * Coefficiente di cambio ufficiale        *
      *                      *-----------------------------------------*
           move      rf-vlt-cdc-vlt       to   w-rig-cdc-vlt (1)      .
      *                      *-----------------------------------------*
      *                      * Coefficienti di cambio addizionali      *
      *                      *-----------------------------------------*
           move      rf-vlt-cdc-add (01)  to   w-rig-cdc-add (1, 01)  .
           move      rf-vlt-cdc-add (02)  to   w-rig-cdc-add (1, 02)  .
           move      rf-vlt-cdc-add (03)  to   w-rig-cdc-add (1, 03)  .
           move      rf-vlt-cdc-add (04)  to   w-rig-cdc-add (1, 04)  .
           move      rf-vlt-cdc-add (05)  to   w-rig-cdc-add (1, 05)  .
           move      rf-vlt-cdc-add (06)  to   w-rig-cdc-add (1, 06)  .
           move      rf-vlt-cdc-add (07)  to   w-rig-cdc-add (1, 07)  .
           move      rf-vlt-cdc-add (08)  to   w-rig-cdc-add (1, 08)  .
           move      rf-vlt-cdc-add (09)  to   w-rig-cdc-add (1, 09)  .
      *                      *-----------------------------------------*
      *                      * Area libera per espansioni future       *
      *                      *-----------------------------------------*
           move      rf-vlt-alx-exp       to   w-rig-alx-exp (1)      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valori contenuti indiretta- *
      *                  * mente in record [vlt]                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione valori ultimo rilevamen- *
      *                      * to                                      *
      *                      *-----------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      w-rig-sgl-vlt (1)    to   w-coe-cmb-vlt-sdv      .
           move      w-rig-tdc-vlt (1)    to   w-coe-cmb-vlt-tdc      .
           move      w-tes-dat-vlt        to   s-dat                  .
       rou-let-reg-610.
           subtract  1                    from s-gio                  .
           if        s-gio                =    zero
                     move  31             to   s-gio
                     subtract 1           from s-mes                  .
           if        s-mes                =    zero
                     move  12             to   s-mes
                     subtract 1           from s-saa                  .
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                not  = spaces
                     go to rou-let-reg-610.
           move      s-dat                to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                      *-----------------------------------------*
      *                      * Coefficiente di cambio ultimo rileva-   *
      *                      * mento cambio                            *
      *                      *-----------------------------------------*
           move      w-coe-cmb-vlt-cdc    to   w-rig-cdc-urc (1)      .
      *                      *-----------------------------------------*
      *                      * Data ultimo rilevamento cambio          *
      *                      *-----------------------------------------*
           move      w-coe-cmb-vlt-drc    to   w-rig-dat-urc (1)      .
      *                      *-----------------------------------------*
      *                      * Determinazione % di scostamento         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se coefficiente di cambio a zero :  *
      *                          * no determinazione                   *
      *                          *-------------------------------------*
           if        w-rig-cdc-vlt (1)    =    zero
                     move  zero           to   w-rig-per-scs (1)
                     move  spaces         to   w-rig-sgn-scs (1)
                     go to rou-let-reg-800.
      *                          *-------------------------------------*
      *                          * Se ultimo cambio rilevato a zero :  *
      *                          * no determinazione                   *
      *                          *-------------------------------------*
           if        w-rig-cdc-urc (1)    =    zero
                     move  zero           to   w-rig-per-scs (1)
                     move  spaces         to   w-rig-sgn-scs (1)
                     go to rou-let-reg-800.
      *                          *-------------------------------------*
      *                          * Determinazione                      *
      *                          *-------------------------------------*
           subtract  w-rig-cdc-urc (1)    from w-rig-cdc-vlt (1)
                                        giving w-rig-per-scs (1)      .
           multiply  100                  by   w-rig-per-scs (1)      .
           divide    w-rig-cdc-urc (1)    into w-rig-per-scs (1)      .
      *                      *-----------------------------------------*
      *                      * Segnale di scostamento                  *
      *                      *-----------------------------------------*
           if        w-rig-per-scs (1)    >    50 or
                     w-rig-per-scs (1)    <   -50
                     move  "**"           to   w-rig-sgn-scs (1)
           else      move  spaces         to   w-rig-sgn-scs (1)      .
       rou-let-reg-800.
      *                  *---------------------------------------------*
      *                  * Valori precedenti                           *
      *                  *---------------------------------------------*
           move      w-rig-val-aep (1)    to   w-rig-val-aep (2)      .
       rou-let-reg-850.
      *                  *---------------------------------------------*
      *                  * Put su catena movimenti [rig]               *
      *                  *---------------------------------------------*
           move      "PT"                 to   w-cat-rig-ope          .
           move      w-cix-ctr-rig        to   w-cat-rig-prg          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo a successivo                        *
      *                  *---------------------------------------------*
           go to     rou-let-reg-600.
       rou-let-reg-900.
      *              *-------------------------------------------------*
      *              * Test per visualizzazione                        *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-vis-sgr    =    "V"
                     move  "V"            to   w-cnt-mfu-tip-fun      .
       rou-let-reg-920.
      *              *-------------------------------------------------*
      *              * Se il programma e' stato richiamato si pone in  *
      *              * visualizzazione                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su variabile di i.p.c.                 *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    not  = "VI"
                     go to rou-let-reg-999.
      *                  *---------------------------------------------*
      *                  * Tipo funzionamento : Visualizzazione        *
      *                  *---------------------------------------------*
           move      "V"                  to   w-cnt-mfu-tip-fun      .
       rou-let-reg-999.
           exit.

