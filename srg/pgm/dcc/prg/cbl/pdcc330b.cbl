      *                  * Deviazione secondo l'esito della lettura    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to let-arc-zvl-750.
       let-arc-zvl-700.
      *                  *---------------------------------------------*
      *                  * Se record esistente                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Descrizione valuta in lingua italiana   *
      *                      *-----------------------------------------*
           move      rf-zvl-des-ita       to   w-let-arc-zvl-des      .
      *                      *-----------------------------------------*
      *                      * Descrizione valuta internazionale       *
      *                      *-----------------------------------------*
           move      rf-zvl-des-int       to   w-let-arc-zvl-din      .
      *                      *-----------------------------------------*
      *                      * Numero decimali valuta                  *
      *                      *-----------------------------------------*
           move      rf-zvl-num-dec       to   w-let-arc-zvl-dec      .
      *                      *-----------------------------------------*
      *                      * Tipo di coefficiente per cambio valuta  *
      *                      *-----------------------------------------*
           move      rf-zvl-def-tdc       to   w-let-arc-zvl-tdc      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     let-arc-zvl-999.
       let-arc-zvl-750.
      *                  *---------------------------------------------*
      *                  * Se record non esistente                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di uscita ad errore                *
      *                      *-----------------------------------------*
           move      "#"                  to   w-let-arc-zvl-flg      .
      *                      *-----------------------------------------*
      *                      * Descrizione valuta in lingua italiana   *
      *                      *-----------------------------------------*
           move      all   "."            to   w-let-arc-zvl-des      .
      *                      *-----------------------------------------*
      *                      * Descrizione valuta internazionale       *
      *                      *-----------------------------------------*
           move      all   "."            to   w-let-arc-zvl-din      .
      *                      *-----------------------------------------*
      *                      * Numero decimali valuta                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-let-arc-zvl-dec      .
      *                      *-----------------------------------------*
      *                      * Tipo di coefficiente per cambio valuta  *
      *                      *-----------------------------------------*
           move      spaces               to   w-let-arc-zvl-tdc      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     let-arc-zvl-999.
       let-arc-zvl-999.
           exit.

      *    *===========================================================*
      *    * Routine lettura archivio [zos] per [dcp]                  *
      *    *-----------------------------------------------------------*
           copy      "pgm/dcp/prg/cpy/lzosdcp0.lts"                   .
          
      *    *===========================================================*
      *    * Controllo su tasto Do in parametri di selezione           *
      *    *-----------------------------------------------------------*
       tdo-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Test su codice listino di origine               *
      *              *-------------------------------------------------*
           if        rr-lor-cod-lst       not  = spaces
                     go to tdo-ric-sel-150.
           if        rr-lor-des-lst       not  = spaces
                     go to tdo-ric-sel-150.
           move      "Manca il codice listino di origine !         "
                                          to   w-box-msg-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-150.
      *              *-------------------------------------------------*
      *              * Test su sigla valuta di origine                 *
      *              *-------------------------------------------------*
           if        rr-lor-cod-vlt       not  = spaces
                     go to tdo-ric-sel-155.
           move      "Manca la valuta del listino !                "
                                          to   w-box-msg-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-155.
           move      rr-lor-cod-vlt       to   w-let-arc-zvl-cod      .
           perform   let-arc-zvl-000      thru let-arc-zvl-999        .
           if        w-let-arc-zvl-flg    =    spaces
                     go to tdo-ric-sel-200.
           move      "Valuta per il listino non esistente !        "
                                          to   w-box-msg-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Test su coefficiente di cambio di origine       *
      *              *-------------------------------------------------*
           if        rr-lor-cod-vlt       =    c-sgl
                     go to tdo-ric-sel-300.
           if        rr-lor-cdc-vlt       not  = zero
                     go to tdo-ric-sel-300.
           move      "Manca il cambio per la valuta del listino !  "
                                          to   w-box-msg-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-300.
      *              *-------------------------------------------------*
      *              * Test su codice cliente di destinazione          *
      *              *-------------------------------------------------*
           if        rr-cde-cod-cli       not  = zero
                     go to tdo-ric-sel-350.
           move      "Manca il codice cliente di destinazione !    "
                                          to   w-box-msg-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-350.
      *              *-------------------------------------------------*
      *              * Test su sigla valuta di destinazione            *
      *              *-------------------------------------------------*
           if        rr-cde-cod-vlt       not  = spaces
                     go to tdo-ric-sel-355.
           move      "Manca la valuta per il cliente !             "
                                          to   w-box-msg-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-355.
           move      rr-cde-cod-vlt       to   w-let-arc-zvl-cod      .
           perform   let-arc-zvl-000      thru let-arc-zvl-999        .
           if        w-let-arc-zvl-flg    =    spaces
                     go to tdo-ric-sel-400.
           move      "Valuta per il cliente non esistente !        "
                                          to   w-box-msg-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-400.
      *              *-------------------------------------------------*
      *              * Test su coefficiente di cambio di destinazione  *
      *              *-------------------------------------------------*
           if        rr-cde-cod-vlt       =    c-sgl
                     go to tdo-ric-sel-500.
           if        rr-cde-cdc-vlt       not  = zero
                     go to tdo-ric-sel-500.
           move      "Manca il cambio per la valuta del cliente !  "
                                          to   w-box-msg-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-500.
      *              *-------------------------------------------------*
      *              * Test su tipo di aggiornamento                   *
      *              *-------------------------------------------------*
           if        rr-opz-tip-agg       not  = zero
                     go to tdo-ric-sel-505.
           move      "Manca il tipo di aggiornamento !             "
                                          to   w-box-msg-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-505.
           if        rr-opz-tip-agg       =    01 or
                     rr-opz-tip-agg       =    02 or
                     rr-opz-tip-agg       =    03
                     go to tdo-ric-sel-550.
           move      "Tipo di aggiornamento errato !               "
                                          to   w-box-msg-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-550.
      *              *-------------------------------------------------*
      *              * Test su % di aggiornamento                      *
      *              *-------------------------------------------------*
           if        rr-opz-tip-agg       =    01
                     go to tdo-ric-sel-600.
           if        rr-opz-per-ag1       not  = zero or
                     rr-opz-per-ag2       not  = zero or
                     rr-opz-per-ag3       not  = zero
                     go to tdo-ric-sel-600.
           move      "Mancano le percentuali di aggiornamento !    "
                                          to   w-box-msg-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-600.
      *              *-------------------------------------------------*
      *              * Test su tipo arrotondamento                     *
      *              *-------------------------------------------------*
           if        rr-opz-tip-agg       =    01
                     go to tdo-ric-sel-650.
           if        rr-opz-tip-arr       not  = zero
                     go to tdo-ric-sel-605.
           move      "Manca il tipo di arrotondamento !            "
                                          to   w-box-msg-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-605.
           if        rr-opz-tip-arr       =    01 or
                     rr-opz-tip-arr       =    02 or
                     rr-opz-tip-arr       =    03 or
                     rr-opz-tip-arr       =    04
                     go to tdo-ric-sel-650.
           move      "Tipo di arrotondamento errato !              "
                                          to   w-box-msg-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-650.
      *              *-------------------------------------------------*
      *              * Test su valore di arrotondamento                *
      *              *-------------------------------------------------*
           if        rr-opz-tip-agg       =    01
                     go to tdo-ric-sel-700.
           if        rr-opz-tip-arr       =    01
                     go to tdo-ric-sel-700.
           if        rr-opz-val-arr       not  = zero
                     go to tdo-ric-sel-700.
           move      "Manca il valore di arrotondamento !          "
                                          to   w-box-msg-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-700.
      *              *-------------------------------------------------*
      *              * Normalizzazioni se controlli superati           *
      *              *-------------------------------------------------*
       tdo-ric-sel-705.
      *                  *---------------------------------------------*
      *                  * Coefficiente di cambio di origine           *
      *                  *---------------------------------------------*
           if        rr-lor-cod-vlt       =    c-sgl
                     move  1              to   rr-lor-cdc-vlt         .
       tdo-ric-sel-710.
      *                  *---------------------------------------------*
      *                  * Coefficiente di cambio di destinazione      *
      *                  *---------------------------------------------*
           if        rr-cde-cod-vlt       =    c-sgl
                     move  1              to   rr-cde-cdc-vlt         .
       tdo-ric-sel-715.
      *                  *---------------------------------------------*
      *                  * Tipo di aggiornamento                       *
      *                  *---------------------------------------------*
           if        rr-opz-tip-agg       not  = 02 and
                     rr-opz-tip-agg       not  = 03
                     move  01             to   rr-opz-tip-agg         .
       tdo-ric-sel-720.
      *                  *---------------------------------------------*
      *                  * % di aggiornamento                          *
      *                  *---------------------------------------------*
           if        rr-opz-tip-agg       =    01
                     move  zero           to   rr-opz-per-ag1
                     move  zero           to   rr-opz-per-ag2
                     move  zero           to   rr-opz-per-ag3         .
       tdo-ric-sel-725.
      *                  *---------------------------------------------*
      *                  * Tipo di arrotondamento                      *
      *                  *---------------------------------------------*
           if        rr-opz-tip-agg       =    01
                     move  01             to   rr-opz-tip-arr
                     go to tdo-ric-sel-730.
           if        rr-opz-tip-arr       not  = 02 and
                     rr-opz-tip-arr       not  = 03 and
                     rr-opz-tip-arr       not  = 04
                     move  01             to   rr-opz-tip-arr
                     go to tdo-ric-sel-730.
       tdo-ric-sel-730.
      *                  *---------------------------------------------*
      *                  * Valore di arrotondamento                    *
      *                  *---------------------------------------------*
           if        rr-opz-tip-arr       =    01
                     move  zero           to   rr-opz-val-arr         .
       tdo-ric-sel-800.
      *              *-------------------------------------------------*
      *              * Uscita per controlli superati                   *
      *              *-------------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-900.
      *              *-------------------------------------------------*
      *              * Emissione messaggio di errore e set del flag di *
      *              * uscita ad errore                                *
      *              *-------------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di errore in uscita                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-ric-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Regolarizzazione dei parametri di selezione               *
      *    *-----------------------------------------------------------*
       reg-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione eventuale di si/no duplicazione *
      *              * dei prezzi a zero                               *
      *              *-------------------------------------------------*
           if        rr-snd-paz           =    zero
                     move  1              to   rr-snd-paz             .
       reg-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione richieste di selezione                    *
      *    *-----------------------------------------------------------*
       nor-ric-sel-000.
           move      spaces               to   rr-lor-cod-lst         .
           move      spaces               to   rr-lor-des-lst         .
           move      spaces               to   rr-lor-cod-vlt         .
           move      spaces               to   rr-lor-des-vlt         .
           move      zero                 to   rr-lor-dec-vlt         .
           move      spaces               to   rr-lor-tdc-vlt         .
           move      zero                 to   rr-lor-cdc-vlt         .
           move      zero                 to   rr-cde-cod-cli         .
           move      spaces               to   rr-cde-rag-cli         .
           move      spaces               to   rr-cde-cod-vlt         .
           move      spaces               to   rr-cde-des-vlt         .
           move      zero                 to   rr-cde-dec-vlt         .
           move      spaces               to   rr-cde-tdc-vlt         .
           move      zero                 to   rr-cde-cdc-vlt         .
           move      zero                 to   rr-opz-fso-dcp         .
           move      spaces               to   rr-opz-fso-des         .
           move      zero                 to   rr-opz-tip-agg         .
           move      zero                 to   rr-opz-per-ag1         .
           move      zero                 to   rr-opz-per-ag2         .
           move      zero                 to   rr-opz-per-ag3         .
           move      zero                 to   rr-opz-tip-arr         .
           move      zero                 to   rr-opz-val-arr         .
           move      zero                 to   rr-snd-paz             .
       nor-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Box per messaggio di errore                               *
      *    *-----------------------------------------------------------*
       box-msg-err-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      12                   to   v-lin                  .
           move      07                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      74                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Messaggio nel box                               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      w-box-msg-err-msg    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Parentesi quadre di delimitazione               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      70                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      13                   to   v-lin                  .
           move      71                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-msg-err-999.
           exit.

      *    *===========================================================*
      *    * Esecuzione sub-program : Duplicazione prezzi da listino   *
      *    *                          a cliente                        *
      *    *-----------------------------------------------------------*
       exe-sub-pgm-000.
      *              *-------------------------------------------------*
      *              * Messaggio di programma in esecuzione            *
      *              *-------------------------------------------------*
           move      "PE"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Esecuzione duplicazione da un listino base o    *
      *              * alternativo ad un listino per un cliente        *
      *              *-------------------------------------------------*
           perform   dup-boa-cli-000      thru dup-boa-cli-999        .
      *              *-------------------------------------------------*
      *              * Messaggio di fine esecuzione                    *
      *              *-------------------------------------------------*
           move      "FE"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-sub-pgm-999.
           exit.

      *    *===========================================================*
      *    * Duplicazione da Listino Base o Alternativo a Listino per  *
      *    * un Cliente                                                *
      *    *-----------------------------------------------------------*
       dup-boa-cli-000.
      *              *-------------------------------------------------*
      *              * Start filtro di ordinamento e selezione per il  *
      *              * file [dcp]                                      *
      *              *-------------------------------------------------*
           move      "ST"                 to   f-ope                  .
           move      rr-opz-fso-dcp       to   f-key                  .
           move      "pgm/dcp/prg/obj/bzosdcp0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *              *-------------------------------------------------*
      *              * Se errore su Start : uscita                     *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to dup-boa-cli-999.
       dup-boa-cli-100.
      *              *-------------------------------------------------*
      *              * Read Next filtro di ordinamento e selezione per *
      *              * file [dcp]                                      *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcp/prg/obj/bzosdcp0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *              *-------------------------------------------------*
      *              * Se At End : uscita                              *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to dup-boa-cli-999.
       dup-boa-cli-200.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del listino di origine     *
      *              *-------------------------------------------------*
           if        rr-lor-cod-lst       =    spaces
                     go to dup-boa-cli-225
           else      go to dup-boa-cli-250.
       dup-boa-cli-225.
      *              *-------------------------------------------------*
      *              * Se listino di origine : listino base            *
      *              *-------------------------------------------------*
       dup-boa-cli-230.
      *                  *---------------------------------------------*
      *                  * Preparazione valori da [dcp]                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Prezzo                                  *
      *                      *-----------------------------------------*
           move      rf-dcp-prz-lst       to   w-lst-boa-prz          .
      *                      *-----------------------------------------*
      *                      * Sigla valuta                            *
      *                      *-----------------------------------------*
           move      rf-dcp-sgl-vlt       to   w-lst-boa-vlt          .
      *                      *-----------------------------------------*
      *                      * Numero decimali valuta                  *
      *                      *-----------------------------------------*
           move      rf-dcp-dec-vlt       to   w-lst-boa-dcv          .
       dup-boa-cli-235.
      *                  *---------------------------------------------*
      *                  * Continuazione                               *
      *                  *---------------------------------------------*
           go to     dup-boa-cli-300.
       dup-boa-cli-250.
      *              *-------------------------------------------------*
      *              * Se listino di origine : listino alternativo     *
      *              *-------------------------------------------------*
       dup-boa-cli-255.
      *                  *---------------------------------------------*
      *                  * Lettura [lst], con eventuali normalizzazio- *
      *                  * ni in caso di record non esistente          *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "LSTPRO    "         to   f-key                  .
           move      01                   to   rf-lst-tip-rec         .
           move      rr-lor-cod-lst       to   rf-lst-cod-lst         .
           move      zero                 to   rf-lst-cod-cli         .
           move      rr-lor-cod-vlt       to   rf-lst-sgl-vlt         .
           move      rf-dcp-num-pro       to   rf-lst-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
      *              *-------------------------------------------------*
      *              * Se record non trovato : normalizzazioni         *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     move  zero           to   rf-lst-prz-lst
                     move  spaces         to   rf-lst-sgl-vlt
                     move  zero           to   rf-lst-dec-vlt         .
       dup-boa-cli-260.
      *                  *---------------------------------------------*
      *                  * Preparazione valori da [lst]                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Prezzo                                  *
      *                      *-----------------------------------------*
           move      rf-lst-prz-lst       to   w-lst-boa-prz          .
      *                      *-----------------------------------------*
      *                      * Sigla valuta                            *
      *                      *-----------------------------------------*
           move      rf-lst-sgl-vlt       to   w-lst-boa-vlt          .
      *                      *-----------------------------------------*
      *                      * Numero decimali valuta                  *
      *                      *-----------------------------------------*
           move      rf-lst-dec-vlt       to   w-lst-boa-dcv          .
       dup-boa-cli-265.
      *                  *---------------------------------------------*
      *                  * Continuazione                               *
      *                  *---------------------------------------------*
           go to     dup-boa-cli-300.
       dup-boa-cli-300.
      *              *-------------------------------------------------*
      *              * Selezioni sul record letto                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se prezzo pari a zero : test su richieste   *
      *                  *---------------------------------------------*
           if        w-lst-boa-prz        not  = zero
                     go to dup-boa-cli-320.
           if        rr-snd-paz           =    1
                     go to dup-boa-cli-100
           else      go to dup-boa-cli-400.
       dup-boa-cli-320.
      *                  *---------------------------------------------*
      *                  * Se sigla valuta diversa da quanto ci si a-  *
      *                  * spetta : no selezione                       *
      *                  *---------------------------------------------*
           if        w-lst-boa-vlt        not  = rr-lor-cod-vlt
                     go to dup-boa-cli-100.
      *                  *---------------------------------------------*
      *                  * Se numero decimali valuta diversi da quanto *
      *                  * ci si aspetta : no selezione                *
      *                  *---------------------------------------------*
           if        w-lst-boa-dcv        not  = rr-lor-dec-vlt
                     go to dup-boa-cli-100.
      *                  *---------------------------------------------*
      *                  * Determinazione prezzo di listino nel campo  *
      *                  * di comodo 'w-det-new-prz-new', mediante     *
      *                  * sottoposizione al cambio e sottoposizione   *
      *                  * ad aggiornamento ed arrotondamento          *
      *                  *---------------------------------------------*
           move      w-lst-boa-prz        to   w-det-new-prz-old      .
           perform   det-new-prz-000      thru det-new-prz-999        .
      *                  *---------------------------------------------*
      *                  * Se nuovo prezzo di listino determinato me-  *
      *                  * diante sottoposizione al cambio pari a ze-  *
      *                  * ro : no selezione                           *
      *                  *---------------------------------------------*
           if        w-det-new-prz-new    =    zero
                     go to dup-boa-cli-100.
       dup-boa-cli-400.
      *              *-------------------------------------------------*
      *              * Aggiornamento listino cliente di destinazione   *
      *              *-------------------------------------------------*
       dup-boa-cli-450.
      *                  *---------------------------------------------*
      *                  * Lettura record da listino di destinazione,  *
      *                  * con lock                                    *
      *                  *---------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "LSTPRO    "         to   f-key                  .
           move      02                   to   rf-lst-tip-rec         .
           move      spaces               to   rf-lst-cod-lst         .
           move      rr-cde-cod-cli       to   rf-lst-cod-cli         .
           move      rr-cde-cod-vlt       to   rf-lst-sgl-vlt         .
           move      rf-dcp-num-pro       to   rf-lst-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'esito della let-  *
      *                  * tura                                        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to dup-boa-cli-600.
       dup-boa-cli-500.
      *                  *---------------------------------------------*
      *                  * Se record [lst] di destinazione esistente   *
      *                  *---------------------------------------------*
       dup-boa-cli-510.
      *                      *-----------------------------------------*
      *                      * Aggiornamento numero decimali valuta    *
      *                      *-----------------------------------------*
           move      rr-cde-dec-vlt       to   rf-lst-dec-vlt         .
      *                      *-----------------------------------------*
      *                      * Aggiornamento nuovo prezzo              *
      *                      *-----------------------------------------*
           move      w-det-new-prz-new    to   rf-lst-prz-lst         .
      *                      *-----------------------------------------*
      *                      * Aggiornamento altri valori              *
      *                      *-----------------------------------------*
           move      zero                 to   rf-lst-per-sco (1)     .
           move      zero                 to   rf-lst-per-sco (2)     .
           move      zero                 to   rf-lst-per-sco (3)     .
           move      zero                 to   rf-lst-per-sco (4)     .
           move      zero                 to   rf-lst-per-sco (5)     .
           move      "S"                  to   rf-lst-snx-prz         .
           move      "S"                  to   rf-lst-snx-pvg         .
           move      "S"                  to   rf-lst-snx-sco         .
           move      zero                 to   rf-lst-dva-ini         .
           move      zero                 to   rf-lst-dva-fin         .
       dup-boa-cli-520.
      *                      *-----------------------------------------*
      *                      * Update del record                       *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
       dup-boa-cli-530.
      *                      *-----------------------------------------*
      *                      * Unlock del record                       *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
       dup-boa-cli-540.
      *                      *-----------------------------------------*
      *                      * Riciclo alla lettura sequenzialme       *
      *                      *-----------------------------------------*
           go to     dup-boa-cli-100.
       dup-boa-cli-600.
      *                  *---------------------------------------------*
      *                  * Se record [lst] di destinazione non esi-    *
      *                  * stente                                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione record [lst] di desti-  *
      *                      * nazione                                 *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
      *                      *-----------------------------------------*
      *                      * Composizione record [lst] di destina-   *
      *                      * zione                                   *
      *                      *-----------------------------------------*
           move      02                   to   rf-lst-tip-rec         .
           move      spaces               to   rf-lst-cod-lst         .
           move      rr-cde-cod-cli       to   rf-lst-cod-cli         .
           move      rr-cde-cod-vlt       to   rf-lst-sgl-vlt         .
           move      rr-cde-dec-vlt       to   rf-lst-dec-vlt         .
           move      rf-dcp-num-pro       to   rf-lst-num-pro         .
           move      w-det-new-prz-new    to   rf-lst-prz-lst         .
           move      zero                 to   rf-lst-per-pvg (1)     .
           move      zero                 to   rf-lst-per-pvg (2)     .
           move      zero                 to   rf-lst-per-pvg (3)     .
           move      zero                 to   rf-lst-per-sco (1)     .
           move      zero                 to   rf-lst-per-sco (2)     .
           move      zero                 to   rf-lst-per-sco (3)     .
           move      zero                 to   rf-lst-per-sco (4)     .
           move      zero                 to   rf-lst-per-sco (5)     .
           move      "S"                  to   rf-lst-snx-prz         .
           move      "S"                  to   rf-lst-snx-pvg         .
           move      "S"                  to   rf-lst-snx-sco         .
           move      zero                 to   rf-lst-dva-ini         .
           move      zero                 to   rf-lst-dva-fin         .
           move      spaces               to   rf-lst-alx-exp         .
      *                      *-----------------------------------------*
      *                      * Force Put su [lst] di destinazione      *
      *                      *-----------------------------------------*
           move      "FP"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
      *                      *-----------------------------------------*
      *                      * Riciclo alla lettura sequenzialme       *
      *                      *-----------------------------------------*
           go to     dup-boa-cli-100.
       dup-boa-cli-999.
           exit.

      *    *===========================================================*
      *    * Determinazione nuovo prezzo di listino, per sottoposizio- *
      *    * ne al cambio, all'aggiornamento, e all'arrotondamento     *
      *    *-----------------------------------------------------------*
       det-new-prz-000.
      *              *-------------------------------------------------*
      *              * Sottoposizione al cambio                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Cambio dalla valuta di origine alla valuta  *
      *                  * base                                        *
      *                  *---------------------------------------------*
           move      rr-lor-cod-vlt       to   w-cvs-vlt-sgl          .
           move      rr-lor-dec-vlt       to   w-cvs-vlt-dec          .
           move      rr-lor-tdc-vlt       to   w-cvs-vlt-tdc          .
           move      rr-lor-cdc-vlt       to   w-cvs-vlt-cdc          .
           move      w-det-new-prz-old    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
      *                  *---------------------------------------------*
      *                  * Cambio dalla valuta base alla valuta di de- *
      *                  * stinazione                                  *
      *                  *---------------------------------------------*
           move      rr-cde-cod-vlt       to   w-cvs-vlt-sgl          .
           move      rr-cde-dec-vlt       to   w-cvs-vlt-dec          .
           move      rr-cde-tdc-vlt       to   w-cvs-vlt-tdc          .
           move      rr-cde-cdc-vlt       to   w-cvs-vlt-cdc          .
           perform   cvs-vlb-alt-000      thru cvs-vlb-alt-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione del risultato                *
      *                  *---------------------------------------------*
           move      w-cvs-vlt-aav        to   w-det-new-prz-new      .
       det-new-prz-100.
      *              *-------------------------------------------------*
      *              * Aggiornamento                                   *
      *              *-------------------------------------------------*
       det-new-prz-150.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo di aggior-  *
      *                  * namento                                     *
      *                  *---------------------------------------------*
           if        rr-opz-tip-agg       =    02
                     go to det-new-prz-200
           else if   rr-opz-tip-agg       =    03
                     go to det-new-prz-250
           else      go to det-new-prz-300.
       det-new-prz-200.
      *                  *---------------------------------------------*
      *                  * Se tipo di aggiornamento : Aumento          *
      *                  *---------------------------------------------*
       det-new-prz-210.
      *                      *-----------------------------------------*
      *                      * Calcolo aggiornamento % nr. 1           *
      *                      *-----------------------------------------*
           if        rr-opz-per-ag1       =    zero
                     go to det-new-prz-220.
           move      100,0                to   w-det-new-prz-coe      .
           add       rr-opz-per-ag1       to   w-det-new-prz-coe      .
           multiply  w-det-new-prz-coe    by   w-det-new-prz-new      .
           divide    100                  into w-det-new-prz-new      .
       det-new-prz-220.
      *                      *-----------------------------------------*
      *                      * Calcolo aggiornamento % nr. 2           *
      *                      *-----------------------------------------*
           if        rr-opz-per-ag2       =    zero
                     go to det-new-prz-230.
           move      100,0                to   w-det-new-prz-coe      .
           add       rr-opz-per-ag2       to   w-det-new-prz-coe      .
           multiply  w-det-new-prz-coe    by   w-det-new-prz-new      .
           divide    100                  into w-det-new-prz-new      .
       det-new-prz-230.
      *                      *-----------------------------------------*
      *                      * Calcolo aggiornamento % nr. 3           *
      *                      *-----------------------------------------*
           if        rr-opz-per-ag3       =    zero
                     go to det-new-prz-240.
           move      100,0                to   w-det-new-prz-coe      .
           add       rr-opz-per-ag3       to   w-det-new-prz-coe      .
           multiply  w-det-new-prz-coe    by   w-det-new-prz-new      .
           divide    100                  into w-det-new-prz-new      .
       det-new-prz-240.
      *                      *-----------------------------------------*
      *                      * Ad arrotondamento                       *
      *                      *-----------------------------------------*
           go to     det-new-prz-400.
       det-new-prz-250.
      *                  *---------------------------------------------*
      *                  * Se tipo di aggiornamento : Diminuzione      *
      *                  *---------------------------------------------*
       det-new-prz-260.
      *                      *-----------------------------------------*
      *                      * Calcolo aggiornamento % nr. 1           *
      *                      *-----------------------------------------*
           if        rr-opz-per-ag1       =    zero
                     go to det-new-prz-270.
           move      100,0                to   w-det-new-prz-coe      .
           subtract  rr-opz-per-ag1       from w-det-new-prz-coe      .
           multiply  w-det-new-prz-coe    by   w-det-new-prz-new      .
           divide    100                  into w-det-new-prz-new      .
       det-new-prz-270.
      *                      *-----------------------------------------*
      *                      * Calcolo aggiornamento % nr. 2           *
      *                      *-----------------------------------------*
           if        rr-opz-per-ag2       =    zero
                     go to det-new-prz-280.
           move      100,0                to   w-det-new-prz-coe      .
           subtract  rr-opz-per-ag2       from w-det-new-prz-coe      .
           multiply  w-det-new-prz-coe    by   w-det-new-prz-new      .
           divide    100                  into w-det-new-prz-new      .
       det-new-prz-280.
      *                      *-----------------------------------------*
      *                      * Calcolo aggiornamento % nr. 3           *
      *                      *-----------------------------------------*
           if        rr-opz-per-ag3       =    zero
                     go to det-new-prz-290.
           move      100,0                to   w-det-new-prz-coe      .
           subtract  rr-opz-per-ag2       from w-det-new-prz-coe      .
           multiply  w-det-new-prz-coe    by   w-det-new-prz-new      .
           divide    100                  into w-det-new-prz-new      .
       det-new-prz-290.
      *                      *-----------------------------------------*
      *                      * Ad arrotondamento                       *
      *                      *-----------------------------------------*
           go to     det-new-prz-400.
       det-new-prz-300.
      *                  *---------------------------------------------*
      *                  * Se tipo di aggiornamento : Nessuno          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ad arrotondamento                       *
      *                      *-----------------------------------------*
           go to     det-new-prz-400.
       det-new-prz-400.
      *              *-------------------------------------------------*
      *              * Arrotondamento                                  *
      *              *-------------------------------------------------*
       det-new-prz-450.
      *                  *---------------------------------------------*
      *                  * Se il tipo di aggiornamento non e' signifi- *
      *                  * cativo : uscita                             *
      *                  *---------------------------------------------*
           if        rr-opz-tip-agg       not  = 02 and
                     rr-opz-tip-agg       not  = 03
                     go to det-new-prz-999.
      *                  *---------------------------------------------*
      *                  * Se il tipo di arrotondamento non e' signi-  *
      *                  * ficativo : uscita                           *
      *                  *---------------------------------------------*
           if        rr-opz-tip-arr       not  = 02 and
                     rr-opz-tip-arr       not  = 03 and
                     rr-opz-tip-arr       not  = 04
                     go to det-new-prz-999.
      *                  *---------------------------------------------*
      *                  * Se il valore di arrotondamento non e' si-   *
      *                  * gnificativo : uscita                        *
      *                  *---------------------------------------------*
           if        rr-opz-val-arr       =    zero or
                     rr-opz-val-arr       =    1
                     go to det-new-prz-999.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo di arroton- *
      *                  * damento                                     *
      *                  *---------------------------------------------*
           if        rr-opz-tip-arr       =    01
                     go to det-new-prz-500
           else if   rr-opz-tip-arr       =    02
                     go to det-new-prz-550
           else if   rr-opz-tip-arr       =    03
                     go to det-new-prz-600
           else if   rr-opz-tip-arr       =    04
                     go to det-new-prz-650.
       det-new-prz-500.
      *                  *---------------------------------------------*
      *                  * Se tipo di arrotondamento : Nessuno         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     det-new-prz-999.
       det-new-prz-550.
      *                  *---------------------------------------------*
      *                  * Se tipo di arrotondamento : Commerciale     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Calcolo arrotondamento                  *
      *                      *-----------------------------------------*
           divide    rr-opz-val-arr       into w-det-new-prz-new
                                                         rounded      .
           multiply  rr-opz-val-arr       by   w-det-new-prz-new      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     det-new-prz-999.
       det-new-prz-600.
      *                  *---------------------------------------------*
      *                  * Se tipo di arrotondamento : Al valore supe- *
      *                  * riore                                       *
      *                  *---------------------------------------------*
           add       rr-opz-val-arr       to   w-det-new-prz-new      .
           subtract  1                    from w-det-new-prz-new      .
           divide    rr-opz-val-arr       into w-det-new-prz-new      .
           multiply  rr-opz-val-arr       by   w-det-new-prz-new      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     det-new-prz-999.
       det-new-prz-650.
      *                  *---------------------------------------------*
      *                  * Se tipo di arrotondamento : Al valore infe- *
      *                  * riore                                       *
      *                  *---------------------------------------------*
           divide    rr-opz-val-arr       into w-det-new-prz-new      .
           multiply  rr-opz-val-arr       by   w-det-new-prz-new      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     det-new-prz-999.
       det-new-prz-999.
           exit.

      *    *===========================================================*
      *    * Routine di conversione da altra valuta a valuta base      *
      *    *                                                           *
      *    * Input  : w-cvs-vlt-sgl = Sigla dell'altra valuta          *
      *    *                                                           *
      *    *          w-cvs-vlt-dec = Numero decimali dell'altra valu- *
      *    *                          ta                               *
      *    *                                                           *
      *    *          w-cvs-vlt-tdc = Tipo di coefficiente dell'altra  *
      *    *                          valuta                           *
      *    *                                                           *
      *    *          w-cvs-vlt-cdc = Coefficiente di cambio dell'al-  *
      *    *                          tra valuta                       *
      *    *                                                           *
      *    *          w-cvs-vlt-aav = Ammontare da convertire, espres- *
      *    *                          so nell'altra valuta             *
      *    *                                                           *
      *    * Output : w-cvs-vlt-avb = Ammontare convertito, espresso   *
      *    *                          nella valuta base                *
      *    *                                                           *
      *    *-----------------------------------------------------------*
      *    * Routine di conversione da valuta base ad altra valuta     *
      *    *                                                           *
      *    * Input  : w-cvs-vlt-sgl = Sigla dell'altra valuta          *
      *    *                                                           *
      *    *          w-cvs-vlt-dec = Numero decimali dell'altra valu- *
      *    *                          ta                               *
      *    *                                                           *
      *    *          w-cvs-vlt-tdc = Tipo di coefficiente dell'altra  *
      *    *                          valuta                           *
      *    *                                                           *
      *    *          w-cvs-vlt-cdc = Coefficiente di cambio dell'al-  *
      *    *                          tra valuta                       *
      *    *                                                           *
      *    *          w-cvs-vlt-avb = Ammontare da convertire, espres- *
      *    *                          so nella valuta base             *
      *    *                                                           *
      *    * Output : w-cvs-vlt-aav = Ammontare convertito, espresso   *
      *    *                          nell'altra valuta                *
      *    *                                                           *
      *    *-----------------------------------------------------------*
      *    * Routine di conversione da valuta a valuta                 *
      *    *                                                           *
      *    * Input  : Valuta da trasformare                            *
      *    *                                                           *
      *    *            - w-cvs-vdt-sgl = Sigla valuta                 *
      *    *                                                           *
      *    *            - w-cvs-vdt-dec = Numero decimali              *
      *    *                                                           *
      *    *            - w-cvs-vdt-tdc = Tipo di coefficiente         *
      *    *                                                           *
      *    *            - w-cvs-vdt-cdc = Coefficiente di cambio ri-   *
      *    *                              spetto alla valuta base      *
      *    *                                                           *
      *    *            - w-cvs-vdt-amm = Ammontare da convertire,     *
      *    *                              espresso nella valuta da     *
      *    *                              trasformare                  *
      *    *                                                           *
      *    *          Valuta in cui trasformare                        *
      *    *                                                           *
      *    *            - w-cvs-vnu-sgl = Sigla valuta                 *
      *    *                                                           *
      *    *            - w-cvs-vnu-dec = Numero decimali              *
      *    *                                                           *
      *    *            - w-cvs-vnu-tdc = Tipo di coefficiente         *
      *    *                                                           *
      *    *            - w-cvs-vnu-cdc = Coefficiente di cambio ri-   *
      *    *                              spetto alla valuta base      *
      *    *                                                           *
      *    * Output : Valuta in cui trasformare                        *
      *    *                                                           *
      *    *            - w-cvs-vnu-amm = Ammontare convertito,        *
      *    *                              espresso nella valuta        *
      *    *                              in cui trasformare           *
      *    *                                                           *
      *    *-----------------------------------------------------------*
           copy      "swd/std/prg/cpy/wcvsvlt0.cps"                   .

