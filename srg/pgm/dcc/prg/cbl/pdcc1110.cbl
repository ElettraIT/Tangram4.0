      *                  * Numero voce                                 *
      *                  *---------------------------------------------*
           perform   acc-num-def-000      thru acc-num-def-999        .
           if        w-cnt-acc-ric-sel    not  = spaces
                     go to acc-ric-sel-999.
       acc-ric-sel-200.
      *                  *---------------------------------------------*
      *                  * Codice lingua                               *
      *                  *---------------------------------------------*
           perform   acc-cod-lng-000      thru acc-cod-lng-999        .
           if        w-cnt-acc-ric-sel    not  = spaces
                     go to acc-ric-sel-999.
           if        v-key                =    "UP  "
                     go to acc-ric-sel-100.
       acc-ric-sel-900.
      *              *-------------------------------------------------*
      *              * Flag di controllo status impostazioni           *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-sts-imp-ric      .
      *              *-------------------------------------------------*
      *              * Flag di controllo status visualizzazione        *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-sts-vis-ric      .
      *              *-------------------------------------------------*
      *              * Conferma impostazioni                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Cancellazione eventuali note operative      *
      *                  *---------------------------------------------*
           move      "NT"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-ric-sel-910.
      *                  *---------------------------------------------*
      *                  * Accettazione conferma                       *
      *                  *---------------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      "#CNF"               to   v-not                  .
           move      "S"                  to   v-alf                  .
           move      "SNE"                to   v-msk                  .
           move      "DO  "               to   v-pfk (05)             .
           move      "UP  "               to   v-pfk (01)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           if        v-key                not  = spaces
                     go to acc-ric-sel-920.
           if        v-alf                =    "S"
                     move   "DO  "        to   v-key
           else if   v-alf                =    "E"
                     move   "EXIT"        to   v-key
           else if   v-alf                =    "N"
                     move   "UP  "        to   v-key                  .
       acc-ric-sel-920.
      *                  *---------------------------------------------*
      *                  * Test su risposta dell'utente                *
      *                  *---------------------------------------------*
           if        v-key                =    "DO  "
                     go to acc-ric-sel-930
           else if   v-key                =    "EXIT"
                     go to acc-ric-sel-940
           else if   v-key                =    "UP  "
                     go to acc-ric-sel-950
           else      go to acc-ric-sel-910.
       acc-ric-sel-930.
      *                  *---------------------------------------------*
      *                  * Se Do                                       *
      *                  *---------------------------------------------*
           perform   tdo-ric-sel-000      thru tdo-ric-sel-999        .
           if        w-cnt-tdo-ric-flg    =    spaces
                     move  "S"            to   w-cnt-acc-ric-sel
                     go to acc-ric-sel-999
           else      move  spaces         to   w-cnt-tdo-ric-flg
                     go to acc-ric-sel-900.
       acc-ric-sel-940.
      *                  *---------------------------------------------*
      *                  * Se Exit                                     *
      *                  *---------------------------------------------*
           move      "E"                  to   w-cnt-acc-ric-sel      .
           go to     acc-ric-sel-999.
       acc-ric-sel-950.
      *                  *---------------------------------------------*
      *                  * Se Up                                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ad accettazioni                         *
      *                      *-----------------------------------------*
           go to     acc-ric-sel-100.
       acc-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per richieste di selezione        *
      *    *-----------------------------------------------------------*
       pmt-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Numero voce                                     *
      *              *-------------------------------------------------*
           perform   pmt-num-def-000      thru pmt-num-def-999        .
      *              *-------------------------------------------------*
      *              * Codice lingua                                   *
      *              *-------------------------------------------------*
           perform   pmt-cod-lng-000      thru pmt-cod-lng-999        .
       pmt-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per Codice tipo voce descrittiva  *
      *    *-----------------------------------------------------------*
       pmt-num-def-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      32                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Tipo voce descrittiva          :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-num-def-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per Codice lingua                 *
      *    *-----------------------------------------------------------*
       pmt-cod-lng-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      32                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Codice lingua                  :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cod-lng-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo chiave : Numero tipo voce descrittiva  *
      *    *-----------------------------------------------------------*
       acc-num-def-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-num-def-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "B"                  to   v-edm                  .
           move      05                   to   v-lin                  .
           move      34                   to   v-pos                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           if        w-cnt-sts-imp-ric    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      rr-num-def           to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-num-def-999.
       acc-num-def-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   rr-num-def             .
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-num-def-400.
      *                  *---------------------------------------------*
      *                  * Find su tabella [zdf]                       *
      *                  *---------------------------------------------*
           perform   fnd-arc-zdf-000      thru fnd-arc-zdf-999        .
           if        w-fnd-arc-zdf-sel    not  = spaces
                     go to acc-num-def-100.
           move      w-fnd-arc-zdf-def    to   rr-num-def             .
           move      w-fnd-arc-zdf-lng    to   rr-cod-lng             .
      *                  *---------------------------------------------*
      *                  * Visualizzazioni                             *
      *                  *---------------------------------------------*
           perform   vis-num-def-000      thru vis-num-def-999        .
           perform   vis-cod-lng-000      thru vis-cod-lng-999        .
       acc-num-def-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se zero : forzatura Exit                    *
      *                  *---------------------------------------------*
           if        rr-num-def           not  = zero
                     go to acc-num-def-450.
           move      "E"                  to   w-cnt-acc-ric-sel
           go to     acc-num-def-999.
       acc-num-def-450.
      *                  *---------------------------------------------*
      *                  * Se valore maggiore di 6 : messaggio di er-  *
      *                  * rore e reimpostazione                       *
      *                  *---------------------------------------------*
           if        rr-num-def           not  > 6
                     go to acc-num-def-500.
           move      "Il codice non puo' essere maggiore di 6 !"
                                          to   w-err-tdo-nok-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-num-def-100.
       acc-num-def-500.
      *                  *---------------------------------------------*
      *                  * Lettura tabella [zdf] se codice lingua gia' *
      *                  * impostato o selezionato da Find             *
      *                  *---------------------------------------------*
           if        rr-cod-lng           =    spaces
                     go to acc-num-def-600.
      *                  *---------------------------------------------*
      *                  * Lettura tabella [zln]                       *
      *                  *---------------------------------------------*
           move      rr-cod-lng           to   w-let-arc-zln-cod      .
           perform   let-arc-zln-000      thru let-arc-zln-999        .
           move      w-let-arc-zln-des    to   rr-cod-lng-des         .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione lingua          *
      *                  *---------------------------------------------*
           perform   vis-des-lng-000      thru vis-des-lng-999        .
      *                  *---------------------------------------------*
      *                  * Lettura tabella [zdf]                       *
      *                  *---------------------------------------------*
           move      rr-num-def           to   w-let-arc-zdf-def      .
           move      rr-cod-lng           to   w-let-arc-zdf-lng      .
           perform   let-arc-zdf-000      thru let-arc-zdf-999        .
           move      w-let-arc-zdf-des    to   rr-num-def-des         .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione tipo di voce    *
      *                  *---------------------------------------------*
           perform   vis-des-def-000      thru vis-des-def-999        .
      *                  *---------------------------------------------*
      *                  * Test sul flag                               *
      *                  *---------------------------------------------*
           if        w-let-arc-zdf-flg    not  = spaces
                     go to acc-num-def-100.
       acc-num-def-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-num-def-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-num-def-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-num-def-100.
       acc-num-def-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo chiave : Codice tipo voce descrit.  *
      *    *-----------------------------------------------------------*
       vis-num-def-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "B"                  to   v-edm                  .
           move      05                   to   v-lin                  .
           move      34                   to   v-pos                  .
           move      rr-num-def           to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-num-def-999.
           exit.

