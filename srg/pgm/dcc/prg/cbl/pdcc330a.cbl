      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLI"             to   f-key                  .
           move      w-let-arc-dcc-cli    to   rf-dcc-cod-cli         .
           move      w-let-arc-dcc-dpz    to   rf-dcc-dpz-cli         .
           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-dcc-400.
       let-arc-dcc-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-dcc-rag-soc       to   w-let-arc-dcc-rag      .
           move      rf-dcc-cod-vlt       to   w-let-arc-dcc-vlt      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-dcc-999.
       let-arc-dcc-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-dcc-flg      .
           move      all"."               to   w-let-arc-dcc-rag      .
           move      spaces               to   w-let-arc-dcc-vlt      .
           go to     let-arc-dcc-999.
       let-arc-dcc-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-dcc-rag      .
           move      spaces               to   w-let-arc-dcc-vlt      .
       let-arc-dcc-999.
           exit.

      *    *===========================================================*
      *    * Routine lettura tabella [zvl]                             *
      *    *-----------------------------------------------------------*
       let-arc-zvl-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-zvl-flg      .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del valore della sigla va- *
      *              * luta                                            *
      *              *-------------------------------------------------*
           if        w-let-arc-zvl-cod    =    c-sgl
                     go to let-arc-zvl-200
           else if   w-let-arc-zvl-cod    =    spaces
                     go to let-arc-zvl-400
           else      go to let-arc-zvl-600.
       let-arc-zvl-200.
      *              *-------------------------------------------------*
      *              * Se sigla valuta pari alla valuta base           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Descrizione valuta in lingua italiana       *
      *                  *---------------------------------------------*
           move      c-des                to   w-let-arc-zvl-des      .
      *                  *---------------------------------------------*
      *                  * Descrizione valuta internazionale           *
      *                  *---------------------------------------------*
           move      c-din                to   w-let-arc-zvl-din      .
      *                  *---------------------------------------------*
      *                  * Numero decimali valuta                      *
      *                  *---------------------------------------------*
           move      c-dec                to   w-let-arc-zvl-dec      .
      *                  *---------------------------------------------*
      *                  * Tipo di coefficiente per cambio valuta      *
      *                  *---------------------------------------------*
           move      c-tdc                to   w-let-arc-zvl-tdc      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     let-arc-zvl-999.
       let-arc-zvl-400.
      *              *-------------------------------------------------*
      *              * Se sigla valuta a Spaces                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Descrizione valuta in lingua italiana       *
      *                  *---------------------------------------------*
           move      spaces               to   w-let-arc-zvl-des      .
      *                  *---------------------------------------------*
      *                  * Descrizione valuta internazionale           *
      *                  *---------------------------------------------*
           move      spaces               to   w-let-arc-zvl-din      .
      *                  *---------------------------------------------*
      *                  * Numero decimali valuta                      *
      *                  *---------------------------------------------*
           move      zero                 to   w-let-arc-zvl-dec      .
      *                  *---------------------------------------------*
      *                  * Tipo di coefficiente per cambio valuta      *
      *                  *---------------------------------------------*
           move      spaces               to   w-let-arc-zvl-tdc      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     let-arc-zvl-999.
       let-arc-zvl-600.
      *              *-------------------------------------------------*
      *              * Se sigla valuta diversa dalla valuta base ed    *
      *              * anche diversa da Spaces                         *
      *              *-------------------------------------------------*
       let-arc-zvl-650.
      *                  *---------------------------------------------*
      *                  * Lettura per sigla valuta                    *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODVLT    "         to   f-key                  .
           move      w-let-arc-zvl-cod    to   rf-zvl-sgl-vlt         .
           move      "pgm/dcc/fls/ioc/obj/iofzvl"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zvl                 .
      *                  *---------------------------------------------*
      *                  * Deviazione secondo l'esito della lettura    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to let-arc-zvl-750.
       let-arc-zvl-700.
      *                  *---------------------------------------------*
      *                  * Se record esistente                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Descrizione valuta in lingua italiana   *
      *                      *-----------------------------------------*
           move      rf-zvl-des-ita       to   w-let-arc-zvl-des      .
      *                      *-----------------------------------------*
      *                      * Descrizione valuta internazionale       *
      *                      *-----------------------------------------*
           move      rf-zvl-des-int       to   w-let-arc-zvl-din      .
      *                      *-----------------------------------------*
      *                      * Numero decimali valuta                  *
      *                      *-----------------------------------------*
           move      rf-zvl-num-dec       to   w-let-arc-zvl-dec      .
      *                      *-----------------------------------------*
      *                      * Tipo di coefficiente per cambio valuta  *
      *                      *-----------------------------------------*
           move      rf-zvl-def-tdc       to   w-let-arc-zvl-tdc      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     let-arc-zvl-999.
       let-arc-zvl-750.
      *                  *---------------------------------------------*
      *                  * Se record non esistente                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di uscita ad errore                *
      *                      *-----------------------------------------*
           move      "#"                  to   w-let-arc-zvl-flg      .
      *                      *-----------------------------------------*
      *                      * Descrizione valuta in lingua italiana   *
      *                      *-----------------------------------------*
           move      all   "."            to   w-let-arc-zvl-des      .
      *                      *-----------------------------------------*
      *                      * Descrizione valuta internazionale       *
      *                      *-----------------------------------------*
           move      all   "."            to   w-let-arc-zvl-din      .
      *                      *-----------------------------------------*
      *                      * Numero decimali valuta                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-let-arc-zvl-dec      .
      *                      *-----------------------------------------*
      *                      * Tipo di coefficiente per cambio valuta  *
      *                      *-----------------------------------------*
           move      spaces               to   w-let-arc-zvl-tdc      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     let-arc-zvl-999.
       let-arc-zvl-999.
           exit.

      *    *===========================================================*
      *    * Controllo su tasto Do in parametri di selezione           *
      *    *-----------------------------------------------------------*
       tdo-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Test su codice cliente di origine               *
      *              *-------------------------------------------------*
           if        rr-cor-cod-cli       not  = zero
                     go to tdo-ric-sel-150.
           move      "Manca il codice cliente di origine !         "
                                          to   w-box-msg-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-150.
      *              *-------------------------------------------------*
      *              * Test su sigla valuta di origine                 *
      *              *-------------------------------------------------*
           if        rr-cor-sgl-vlt       not  = spaces
                     go to tdo-ric-sel-155.
           move      "Manca la valuta di origine !                 "
                                          to   w-box-msg-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-155.
           move      rr-cor-sgl-vlt       to   w-let-arc-zvl-cod      .
           perform   let-arc-zvl-000      thru let-arc-zvl-999        .
           if        w-let-arc-zvl-flg    =    spaces
                     go to tdo-ric-sel-160.
           move      "Valuta di origine non esistente !            "
                                          to   w-box-msg-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-160.
           move      w-let-arc-zvl-des    to   rr-cor-sgl-vlt-des     .
           move      w-let-arc-zvl-din    to   rr-cor-sgl-vlt-din     .
           move      w-let-arc-zvl-dec    to   rr-cor-sgl-vlt-dec     .
           move      w-let-arc-zvl-tdc    to   rr-cor-sgl-vlt-tdc     .
       tdo-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Test su coefficiente di cambio di origine       *
      *              *-------------------------------------------------*
           if        rr-cor-sgl-vlt       =    c-sgl
                     go to tdo-ric-sel-300.
           if        rr-cor-coe-cmb       not  = zero
                     go to tdo-ric-sel-300.
           move      "Manca il cambio di origine !                 "
                                          to   w-box-msg-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-300.
      *              *-------------------------------------------------*
      *              * Test su codice cliente di destinazione          *
      *              *-------------------------------------------------*
           if        rr-cde-cod-cli       not  = zero
                     go to tdo-ric-sel-350.
           move      "Manca il codice cliente di destinazione !    "
                                          to   w-box-msg-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-350.
      *              *-------------------------------------------------*
      *              * Test su sigla valuta di destinazione            *
      *              *-------------------------------------------------*
           if        rr-cde-sgl-vlt       not  = spaces
                     go to tdo-ric-sel-355.
           move      "Manca la valuta di destinazione !            "
                                          to   w-box-msg-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-355.
           move      rr-cde-sgl-vlt       to   w-let-arc-zvl-cod      .
           perform   let-arc-zvl-000      thru let-arc-zvl-999        .
           if        w-let-arc-zvl-flg    =    spaces
                     go to tdo-ric-sel-360.
           move      "Valuta di destinazione non esistente !       "
                                          to   w-box-msg-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-360.
           move      w-let-arc-zvl-des    to   rr-cde-sgl-vlt-des     .
           move      w-let-arc-zvl-din    to   rr-cde-sgl-vlt-din     .
           move      w-let-arc-zvl-dec    to   rr-cde-sgl-vlt-dec     .
           move      w-let-arc-zvl-tdc    to   rr-cde-sgl-vlt-tdc     .
       tdo-ric-sel-400.
      *              *-------------------------------------------------*
      *              * Test su coefficiente di cambio di destinazione  *
      *              *-------------------------------------------------*
           if        rr-cde-sgl-vlt       =    c-sgl
                     go to tdo-ric-sel-500.
           if        rr-cde-coe-cmb       not  = zero
                     go to tdo-ric-sel-500.
           move      "Manca il cambio di destinazione !            "
                                          to   w-box-msg-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-500.
      *              *-------------------------------------------------*
      *              * Normalizzazioni se controlli superati           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Coefficiente di cambio di origine           *
      *                  *---------------------------------------------*
           if        rr-cor-sgl-vlt       =    c-sgl
                     move  1              to   rr-cor-coe-cmb         .
      *                  *---------------------------------------------*
      *                  * Coefficiente di cambio di destinazione      *
      *                  *---------------------------------------------*
           if        rr-cde-sgl-vlt       =    c-sgl
                     move  1              to   rr-cde-coe-cmb         .
       tdo-ric-sel-600.
      *              *-------------------------------------------------*
      *              * Uscita per controlli superati                   *
      *              *-------------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-900.
      *              *-------------------------------------------------*
      *              * Emissione messaggio di errore e set del flag di *
      *              * uscita ad errore                                *
      *              *-------------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di errore in uscita                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-ric-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Regolarizzazione dei parametri di selezione               *
      *    *-----------------------------------------------------------*
       reg-ric-sel-000.
       reg-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione richieste di selezione                    *
      *    *-----------------------------------------------------------*
       nor-ric-sel-000.
           move      zero                 to   rr-tip-rec             .
           move      spaces               to   rr-cod-lst             .
           move      zero                 to   rr-cor-cod-cli         .
           move      spaces               to   rr-cor-cod-cli-rag     .
           move      spaces               to   rr-cor-cod-cli-vlt     .
           move      spaces               to   rr-cor-sgl-vlt         .
           move      spaces               to   rr-cor-sgl-vlt-des     .
           move      spaces               to   rr-cor-sgl-vlt-din     .
           move      zero                 to   rr-cor-sgl-vlt-dec     .
           move      spaces               to   rr-cor-sgl-vlt-tdc     .
           move      zero                 to   rr-cor-coe-cmb         .
           move      zero                 to   rr-cde-cod-cli         .
           move      spaces               to   rr-cde-cod-cli-rag     .
           move      spaces               to   rr-cde-cod-cli-vlt     .
           move      spaces               to   rr-cde-sgl-vlt         .
           move      spaces               to   rr-cde-sgl-vlt-des     .
           move      spaces               to   rr-cde-sgl-vlt-din     .
           move      zero                 to   rr-cde-sgl-vlt-dec     .
           move      spaces               to   rr-cde-sgl-vlt-tdc     .
           move      zero                 to   rr-cde-coe-cmb         .
       nor-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Box per messaggio di errore                               *
      *    *-----------------------------------------------------------*
       box-msg-err-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      12                   to   v-lin                  .
           move      07                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      74                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Messaggio nel box                               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      w-box-msg-err-msg    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Parentesi quadre di delimitazione               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      70                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      13                   to   v-lin                  .
           move      71                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-msg-err-999.
           exit.

      *    *===========================================================*
      *    * Esecuzione sub-program : Cancellazione prezzi cliente     *
      *    *-----------------------------------------------------------*
       exe-sub-pgm-000.
      *              *-------------------------------------------------*
      *              * Messaggio di programma in esecuzione            *
      *              *-------------------------------------------------*
           move      "PE"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Esecuzione operazione                           *
      *              *-------------------------------------------------*
           perform   dup-cli-cli-000      thru dup-cli-cli-999        .
      *              *-------------------------------------------------*
      *              * Messaggio di fine esecuzione                    *
      *              *-------------------------------------------------*
           move      "FE"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-sub-pgm-999.
           exit.

      *    *===========================================================*
      *    * Duplicazione di : Listino cliente --> Listino cliente     *
      *    *-----------------------------------------------------------*
       dup-cli-cli-000.
      *              *-------------------------------------------------*
      *              * Azzeramento preliminare del listino cliente di  *
      *              * destinazione                                    *
      *              *-------------------------------------------------*
       dup-cli-cli-010.
      *                  *---------------------------------------------*
      *                  * Start su file [lst]                         *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "LSTPRO    "         to   f-key                  .
           move      rr-tip-rec           to   rf-lst-tip-rec         .
           move      rr-cod-lst           to   rf-lst-cod-lst         .
           move      rr-cde-cod-cli       to   rf-lst-cod-cli         .
           move      rr-cde-sgl-vlt       to   rf-lst-sgl-vlt         .
           move      zero                 to   rf-lst-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : a duplicazione            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to dup-cli-cli-050.
       dup-cli-cli-020.
      *                  *---------------------------------------------*
      *                  * Get Next su file [lst]                      *
      *                  *---------------------------------------------*
           move      "GN"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
      *                  *---------------------------------------------*
      *                  * Se At End : a duplicazione                  *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to dup-cli-cli-050.
       dup-cli-cli-030.
      *                  *---------------------------------------------*
      *                  * Test Max su [lst] ; se fine : ad unlock e a *
      *                  * duplicazione                                *
      *                  *---------------------------------------------*
           if        rf-lst-tip-rec       not  = rr-tip-rec     or
                     rf-lst-cod-lst       not  = rr-cod-lst     or
                     rf-lst-cod-cli       not  = rr-cde-cod-cli or
                     rf-lst-sgl-vlt       not  = rr-cde-sgl-vlt
                     go to dup-cli-cli-040.
      *                  *---------------------------------------------*
      *                  * Azzeramento prezzo di listino               *
      *                  *---------------------------------------------*
           move      zero                 to   rf-lst-prz-lst         .
      *                  *---------------------------------------------*
      *                  * Azzeramento provvigioni associate           *
      *                  *---------------------------------------------*
           move      zero                 to   rf-lst-per-pvg (1)     .
           move      zero                 to   rf-lst-per-pvg (2)     .
           move      zero                 to   rf-lst-per-pvg (3)     .
      *                  *---------------------------------------------*
      *                  * Azzeramento sconti associati                *
      *                  *---------------------------------------------*
           move      zero                 to   rf-lst-per-sco (1)     .
           move      zero                 to   rf-lst-per-sco (2)     .
           move      zero                 to   rf-lst-per-sco (3)     .
           move      zero                 to   rf-lst-per-sco (4)     .
           move      zero                 to   rf-lst-per-sco (5)     .
      *                  *---------------------------------------------*
      *                  * Normalizzazione flags                       *
      *                  *---------------------------------------------*
           move      spaces               to   rf-lst-snx-prz         .
           move      spaces               to   rf-lst-snx-pvg         .
           move      spaces               to   rf-lst-snx-sco         .
      *                  *---------------------------------------------*
      *                  * Normalizzazione date                        *
      *                  *---------------------------------------------*
           move      zero                 to   rf-lst-dva-ini         .
           move      zero                 to   rf-lst-dva-fin         .
      *                  *---------------------------------------------*
      *                  * Normalizzazione area libera per espansioni  *
      *                  *---------------------------------------------*
           move      spaces               to   rf-lst-alx-exp         .
      *                  *---------------------------------------------*
      *                  * Update record [lst]                         *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
      *                  *---------------------------------------------*
      *                  * Release record [lst]                        *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
      *                  *---------------------------------------------*
      *                  * Riciclo su Get Next su file [lst]           *
      *                  *---------------------------------------------*
           go to     dup-cli-cli-020.
       dup-cli-cli-040.
      *                  *---------------------------------------------*
      *                  * Release record [lst]                        *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
       dup-cli-cli-050.
      *                  *---------------------------------------------*
      *                  * A duplicazione                              *
      *                  *---------------------------------------------*
           go to     dup-cli-cli-100.
       dup-cli-cli-100.
      *              *-------------------------------------------------*
      *              * Duplicazione vera e propria                     *
      *              *-------------------------------------------------*
       dup-cli-cli-200.
      *                  *---------------------------------------------*
      *                  * Start su file [lst] di origine              *
      *                  *---------------------------------------------*
