           move      09                   to   w-all-str-num          .
           move      "/"                  to   w-all-str-cat (2)      .
           move      "_"                  to   w-all-str-cat (4)      .
           move      "_"                  to   w-all-str-cat (6)      .
           move      "_"                  to   w-all-str-cat (8)      .
           move      w-rig-cod-cli-mne    to   w-all-str-cat (9)      .
