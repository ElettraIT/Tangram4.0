      *    *===========================================================*
      *    * Accettazione : Si/no invio                                *
      *    *-----------------------------------------------------------*
       acc-snx-inv-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-snx-inv-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-flg-itm-lun    to   v-car                  .
           move      w-exp-flg-itm-num    to   v-ldt                  .
           move      "SN#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      w-exp-flg-itm-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      20                   to   v-lin                  .
           move      22                   to   v-pos                  .
      *
           if        w-rig-snx-inv        =    spaces
                     move  01             to   v-num
           else if   w-rig-snx-inv        =    "S"
                     move  01             to   v-num
           else if   w-rig-snx-inv        =    "N"
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
      *
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-snx-inv-999.
       acc-snx-inv-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    01
                     move  "S"            to   w-rig-snx-inv
           else if   v-num                =    02
                     move  "N"            to   w-rig-snx-inv
           else      move  spaces         to   w-rig-snx-inv          .
       acc-snx-inv-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-snx-inv-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-snx-inv-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-snx-inv-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-snx-inv-100.
       acc-snx-inv-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione : Si/no invio                             *
      *    *-----------------------------------------------------------*
       vis-snx-inv-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-flg-itm-lun    to   v-car                  .
           move      w-exp-flg-itm-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-flg-itm-tbl    to   v-txt                  .
           move      20                   to   v-lin                  .
           move      22                   to   v-pos                  .
      *
           if        w-rig-snx-inv        =    spaces
                     move  01             to   v-num
           else if   w-rig-snx-inv        =    "S"
                     move  01             to   v-num
           else if   w-rig-snx-inv        =    "N"
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       vis-snx-inv-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Indirizzo mail                       *
      *    *-----------------------------------------------------------*
       acc-ind-eml-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-snx-inv        =    "N"
                     go to acc-ind-eml-999.
       acc-ind-eml-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "L"                  to   v-tip                  .
           move      55                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      22                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      w-rig-ind-eml        to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-ind-eml-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-ind-eml          .
       acc-ind-eml-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se a spazi, oltre                           *
      *                  *---------------------------------------------*
           if        w-rig-ind-eml        =    spaces
                     go to acc-ind-eml-600.
      *                  *---------------------------------------------*
      *                  * Che contenga solo 1 '@'                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           move      zero                 to   w-all-str-inx          .
           inspect   w-rig-ind-eml  tallying   w-all-str-inx
                                          for  all "@"                .
           if        w-all-str-inx        =    1
                     go to acc-ind-eml-460
           else if   w-all-str-inx        =    0
                     go to acc-ind-eml-420
           else      go to acc-ind-eml-440.
       acc-ind-eml-420.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Indirizzo e-mail formalmente non corretto (senza @
      -              ") !       "         to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-ind-eml-100.
       acc-ind-eml-440.
      *                      *-----------------------------------------*
      *                      * Verifica se doppio                      *
      *                      *-----------------------------------------*
           move      zero                 to   w-all-str-inx          .
           inspect   w-rig-ind-eml  tallying   w-all-str-inx
                                          for  all "#"                .
           if        w-all-str-inx        =    1
                     go to acc-ind-eml-460.
      *
           move      "Indirizzo e-mail formalmente non corretto (troppi 
      -              "@) !      "         to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-ind-eml-100.
       acc-ind-eml-460.
      *                  *---------------------------------------------*
      *                  * Che contenga almeno 1 '.'                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           move      zero                 to   w-all-str-inx          .
           inspect   w-rig-ind-eml  tallying   w-all-str-inx
                                          for  all "."                .
           if        w-all-str-inx        >    zero
                     go to acc-ind-eml-490.
       acc-ind-eml-480.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Indirizzo e-mail formalmente non corretto (senza p
      -              "unti) !   "         to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-ind-eml-100.
       acc-ind-eml-490.
      *                  *---------------------------------------------*
      *                  * Che non contenga spazi                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           move      w-rig-ind-eml        to   w-all-str-alf          .
           move      80                   to   w-all-str-lun          .
           perform   all-str-ble-000      thru all-str-ble-999        .
           if        w-all-str-flg        =    spaces
                     go to acc-ind-eml-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Indirizzo e-mail formalmente non corretto (contien
      -              "e spazi)! "         to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-ind-eml-100.
       acc-ind-eml-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ind-eml-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-ind-eml-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-ind-eml-100.
       acc-ind-eml-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Indirizzo mail                    *
      *    *-----------------------------------------------------------*
