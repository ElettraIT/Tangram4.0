      *    *-----------------------------------------------------------*
       opn-mod-stp-000.
      *              *-------------------------------------------------*
      *              * Preparazione variabile "inp-mst"                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   w-inp-mst              .
      *                  *---------------------------------------------*
      *                  * Tipo operazione                             *
      *                  *---------------------------------------------*
           move      "OP"                 to   w-inp-mst-ope          .
      *                  *---------------------------------------------*
      *                  * Preparazione indicatore di ripetizione per  *
      *                  * generazione file, con flag di inizio        *
      *                  *---------------------------------------------*
           if        w-cnt-mst-flg        =    spaces
                     move  "r"            to   w-inp-mst-sel
           else      move  "R"            to   w-inp-mst-sel          .
      *                  *---------------------------------------------*
      *                  * Altri parametri                             *
      *                  *---------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-azi                to   w-inp-mst-azi          .
           move      s-ter                to   w-inp-mst-ter          .
           move      s-ute                to   w-inp-mst-ute          .
           move      i-ide-sap            to   w-inp-mst-sap          .
           move      i-ide-arg            to   w-inp-mst-arg          .
           move      i-ide-set            to   w-inp-mst-set          .
      *                  *---------------------------------------------*
      *                  * Identificatore fase                         *
      *                  *---------------------------------------------*
           move      "lstpdf"             to   w-inp-mst-fas          .
      *                  *---------------------------------------------*
      *                  * Identificatore documento                    *
      *                  *                                             *
      *                  * Formato: 'AAAA/MM_GG_CLIENTE_MNE'           *
      *                  *                                             *
      *                  * AAAA       = Anno per esteso (data valid)   *
      *                  * MM         = Mese            (data valid)   *
      *                  * GG         = Giorno          (data valid)   *
      *                  * CLIENTE    = Codice cliente                 *
      *                  * MNE        = Codice mnemonico cliente       *
      *                  *             (primi 3 caratteri)             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing anno in corso                   *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
      *
           move      w-tes-dat-vld        to   s-dat                  .
           move      s-saa                to   v-num                  .
           add       1900                 to   v-num                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-all-str-cat (1)      .
      *                      *-----------------------------------------*
      *                      * Editing mese data validita'             *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
      *
           move      w-tes-dat-vld        to   s-dat                  .
           move      s-mes                to   v-num                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-all-str-cat (3)      .
      *                      *-----------------------------------------*
      *                      * Editing giorno data validita'           *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
      *
           move      w-tes-dat-vld        to   s-dat                  .
           move      s-gio                to   v-num                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-all-str-cat (5)      .
