           if        f-sts                not  = e-not-err
                     move  all "."        to   rf-zvl-des-ita         .
      *                      *-----------------------------------------*
      *                      * Stampa descrizione valuta               *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      20                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      010                  to   p-pos                  .
           move      rf-zvl-des-ita       to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-pag-sta-200.
      *              *-------------------------------------------------*
      *              * Stampa ragione sociale cliente centrata         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione lunghezza ragione sociale    *
      *                  * cliente                                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Composizione con il prompt              *
      *                      *-----------------------------------------*
           move      spaces               to   w-int-pag-sta-rag      .
           string    "Cliente : "
                                delimited by size
                     w-buf-l04-rag-cli
                                delimited by size
                                          into w-int-pag-sta-rag      .
      *                      *-----------------------------------------*
      *                      * Determinazione lunghezza stringa com-   *
      *                      * posta                                   *
      *                      *-----------------------------------------*
           move      zero                 to   w-int-pag-sta-inx      .
           inspect   w-int-pag-sta-rag
                                      tallying w-int-pag-sta-inx
                                          for  trailing spaces        .
           move      70                   to   w-int-pag-sta-pnt      .
           subtract  w-int-pag-sta-inx    from w-int-pag-sta-pnt      .
      *                      *-----------------------------------------*
      *                      * Determinazione posizione per la stringa *
      *                      *-----------------------------------------*
           subtract  w-int-pag-sta-pnt    from p-sel-als-sel
                                        giving w-int-pag-sta-pos      .
           divide    2                    into w-int-pag-sta-pos      .
           add       1                    to   w-int-pag-sta-pos      .
      *                      *-----------------------------------------*
      *                      * Stampa della stringa                    *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      50                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-int-pag-sta-pos    to   p-pos                  .
           move      w-int-pag-sta-rag    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       int-pag-sta-400.
