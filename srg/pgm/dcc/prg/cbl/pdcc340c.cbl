           perform   cod-zos-dcp-cll-000  thru cod-zos-dcp-cll-999    .
           if        w-cod-zos-dcp-ope    =    "F+"
                     go to acc-fso-dcp-115.
           if        w-cod-zos-dcp-ope    =    "AC"
                     go to acc-fso-dcp-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-fso-dcp-115.
           perform   cod-zos-dcp-foi-000  thru cod-zos-dcp-foi-999    .
           go to     acc-fso-dcp-110.
       acc-fso-dcp-120.
           move      w-cod-zos-dcp-cod    to   v-num                  .
       acc-fso-dcp-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-fso-dcp-999.
       acc-fso-dcp-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   rr-fso-dcp             .
       acc-fso-dcp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura codice filtro selezione e ordina-   *
      *                  * mento per file [dcp]                        *
      *                  *---------------------------------------------*
           move      rr-fso-dcp           to   w-let-fso-dcp-cod      .
           perform   let-fso-dcp-000      thru let-fso-dcp-999        .
           move      w-let-fso-dcp-des    to   rr-fso-dcp-des         .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione filtro          *
      *                  *---------------------------------------------*
           perform   vis-des-fso-000      thru vis-des-fso-999        .
      *                  *---------------------------------------------*
      *                  * Se codice filtro non esistente : a reimpo-  *
      *                  * stazione                                    *
      *                  *---------------------------------------------*
           if        w-let-fso-dcp-flg    not  = spaces
                     go to acc-fso-dcp-100.
       acc-fso-dcp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-fso-dcp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-fso-dcp-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-fso-dcp-100.
       acc-fso-dcp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione : Codice filtro per selezione e ordina-   *
      *    *                   mento per il le [dcp]                   *
      *    *-----------------------------------------------------------*
       vis-fso-dcp-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      18                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      rr-fso-dcp           to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-fso-dcp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione : Codice filtro per selezione e ordina-   *
      *    *                   mento per il le [dcp], descrizione      *
      *    *-----------------------------------------------------------*
       vis-des-fso-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      rr-fso-dcp-des       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-fso-999.
           exit.

      *    *===========================================================*
      *    * Accettazione : Selezione su validita'                     *
      *    *-----------------------------------------------------------*
       acc-sel-vld-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione eventuale default              *
      *                  *---------------------------------------------*
           if        rr-sel-vld           not  = zero
                     go to acc-sel-vld-100.
           move      01                   to   rr-sel-vld             .
       acc-sel-vld-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-sel-vld-lun    to   v-car                  .
           move      w-exp-sel-vld-num    to   v-ldt                  .
           move      "TVS#"               to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      20                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-sel-vld-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-ric    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      rr-sel-vld           to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-sel-vld-999.
       acc-sel-vld-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   rr-sel-vld             .
       acc-sel-vld-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Sa zero : reimpostazione                    *
      *                  *---------------------------------------------*
           if        rr-sel-vld           =    zero
                     go to acc-sel-vld-100.
       acc-sel-vld-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-sel-vld-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-sel-vld-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-sel-vld-100.
       acc-sel-vld-999.
           exit.

      *    *===========================================================*
      *    * Controllo su tasto Do in parametri di selezione           *
      *    *-----------------------------------------------------------*
       tdo-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-800.
      *              *-------------------------------------------------*
      *              * Uscita per controlli tutti superati             *
      *              *-------------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-900.
      *              *-------------------------------------------------*
      *              * Emissione messaggio di errore e set del flag di *
      *              * uscita ad errore                                *
      *              *-------------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di errore in uscita                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-ric-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Regolarizzazione dei parametri di selezione               *
      *    *-----------------------------------------------------------*
       reg-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Tipo record                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Forzatura del valore a 02 = 'Prezzi netti   *
      *                  * concordati clienti'                         *
      *                  *---------------------------------------------*
           move      02                   to   rr-tip-rec             .
       reg-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Normalizzazione tipo ordinamento                *
      *              *-------------------------------------------------*
           if        rr-tip-ord           =    zero
                     move  01             to   rr-tip-ord             .
       reg-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Normalizzazione si/no stampa provvigioni        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Forzatura del valore a 02 = 'No'            *
      *                  *---------------------------------------------*
           move      02                   to   rr-snx-spv             .
       reg-ric-sel-300.
      *              *-------------------------------------------------*
      *              * Normalizzazione si/no stampa sconti             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Forzatura del valore a 01 = 'Si'            *
      *                  *---------------------------------------------*
           move      01                   to   rr-snx-ssc             .
       reg-ric-sel-400.
      *              *-------------------------------------------------*
      *              * Normalizzazione titolo per la stampa            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Forzatura del valore 'LISTINO PREZZI'       *
      *                  *---------------------------------------------*
           move      "LISTINO PREZZI"     to   rr-tit-stp             .
       reg-ric-sel-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione codice filtro di selezione      *
      *              *-------------------------------------------------*
           if        rr-fso-dcp           =    zero
                     move  9999999        to   rr-fso-dcp             .
      *              *-------------------------------------------------*
      *              * Lettura tipo ordinamento dal codice filtro      *
      *              *-------------------------------------------------*
           move      "TO"                 to   f-ope                  .
           move      rr-fso-dcp-alf       to   f-key                  .
           move      "pgm/dcp/prg/obj/bzosdcp0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
           if        f-sts                =    "01"
                     move  01             to   rr-fso-dcp-ord
           else if   f-sts                =    "02"
                     move  02             to   rr-fso-dcp-ord
           else if   f-sts                =    "03"
                     move  03             to   rr-fso-dcp-ord
           else if   f-sts                =    "04"
                     move  04             to   rr-fso-dcp-ord
           else      move  01             to   rr-fso-dcp-ord         .
       reg-ric-sel-600.
      *              *-------------------------------------------------*
      *              * Normalizzazione Selezione su validita'          *
      *              *-------------------------------------------------*
           if        rr-sel-vld           not  = zero
                     go to reg-ric-sel-999.
           move      01                   to   rr-sel-vld             .
       reg-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione richieste di selezione                    *
      *    *-----------------------------------------------------------*
       nor-ric-sel-000.
           move      zero                 to   rr-tip-rec             .
           move      zero                 to   rr-tip-ord             .
           move      zero                 to   rr-cod-age             .
           move      spaces               to   rr-cod-age-nom         .
           move      spaces               to   rr-cod-naz             .
           move      spaces               to   rr-cod-naz-des         .
           move      zero                 to   rr-cod-zon             .
           move      spaces               to   rr-cod-zon-des         .
           move      zero                 to   rr-cod-cat             .
           move      spaces               to   rr-cod-cat-des         .
           move      zero                 to   rr-cod-stt             .
           move      spaces               to   rr-cod-stt-des         .
           move      zero                 to   rr-fso-dcp             .
           move      spaces               to   rr-fso-dcp-des         .
           move      zero                 to   rr-fso-dcp-ord         .
           move      zero                 to   rr-snx-spv             .
           move      zero                 to   rr-snx-ssc             .
           move      spaces               to   rr-tit-stp             .
           move      zero                 to   rr-sel-vld             .
       nor-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Preparazione parametri per selezione stampa               *
      *    *-----------------------------------------------------------*
       pre-prm-stp-000.
      *              *-------------------------------------------------*
      *              * Flags di tipo selezione                         *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-tip-sel      .
      *              *-------------------------------------------------*
      *              * Codice stampante                                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-cod-stp      .
      *              *-------------------------------------------------*
      *              * Tipo di stampa                                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-tip-sta      .
      *              *-------------------------------------------------*
      *              * Codice modulo                                   *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-cod-mod      .
      *              *-------------------------------------------------*
      *              * Tipo modulo                                     *
      *              *   - L : Libero                                  *
      *              *   - T : Tipografico                             *
      *              *-------------------------------------------------*
           move      "L"                  to   w-cnt-stp-tip-mod      .
      *              *-------------------------------------------------*
      *              * Ampiezza linea di stampa in caratteri           *
      *              *-------------------------------------------------*
           move      120                  to   w-cnt-stp-amp-lin      .
      *              *-------------------------------------------------*
      *              * Top margin in linee                             *
      *              *-------------------------------------------------*
           move      1                    to   w-cnt-stp-top-lin      .
      *              *-------------------------------------------------*
      *              * Numero linee di stampa minimo                   *
      *              *-------------------------------------------------*
           move      30                   to   w-cnt-stp-lin-min      .
      *              *-------------------------------------------------*
      *              * Bottom margin in linee                          *
      *              *-------------------------------------------------*
           move      1                    to   w-cnt-stp-bot-lin      .
      *              *-------------------------------------------------*
      *              * Ampiezza caratteri                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-cnt-stp-amp-car      .
      *              *-------------------------------------------------*
      *              * Altezza interlinea                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-cnt-stp-alt-int      .
      *              *-------------------------------------------------*
      *              * Area riservata per espansioni future            *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-esp-fut      .
      *              *-------------------------------------------------*
      *              * Area riservata per espansioni speciali          *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-stp-fnz-spc      .
       pre-prm-stp-999.
           exit.

      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Lettura tipo ordinamento dal codice filtro      *
      *              *-------------------------------------------------*
           move      "TO"                 to   f-ope                  .
           move      rr-fso-dcp-alf       to   f-key                  .
           move      "pgm/dcp/prg/obj/bzosdcp0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Start su archivio [lst]                         *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "LSTPRO    "         to   f-key                  .
           move      rr-tip-rec           to   rf-lst-tip-rec         .
           move      spaces               to   rf-lst-cod-lst         .
           move      zero                 to   rf-lst-cod-cli         .
           move      spaces               to   rf-lst-sgl-vlt         .
           move      zero                 to   rf-lst-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Read-next su archivio [lst]                     *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
      *                  *---------------------------------------------*
      *                  * Se at end : uscita                          *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-220.
      *                  *---------------------------------------------*
      *                  * Test sul massimo                            *
      *                  *---------------------------------------------*
           if        rf-lst-tip-rec       not  = rr-tip-rec     or
                     rf-lst-cod-lst       not  = spaces
                     go to stp-srt-inp-999.
       stp-srt-inp-240.
      *                  *---------------------------------------------*
      *                  * Lettura record [dcp] per ordinamenti        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      rf-lst-num-pro       to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *                      *-----------------------------------------*
      *                      * Se record non trovato : a prodotto suc- *
      *                      * cessivo                                 *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-200.
       stp-srt-inp-250.
      *                  *---------------------------------------------*
      *                  * Selezione su record [dcp] letto mediante    *
      *                  * richiamo del filtro di ordinamento e se-    *
      *                  * lezione                                     *
      *                  *---------------------------------------------*
           move      "SE"                 to   f-ope                  .
           move      "pgm/dcp/prg/obj/bzosdcp0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *                      *-----------------------------------------*
      *                      * Se selezione non superata : a prodotto  *
      *                      * successivo                              *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-200.
       stp-srt-inp-260.
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare numeri di se-   *
      *                  * quenza per classe, gruppo, sottogruppo      *
      *                  *---------------------------------------------*
           move      zero                 to   w-let-arc-zp1-sqz      .
           move      zero                 to   w-let-arc-zp2-sqz      .
           move      zero                 to   w-let-arc-zp3-sqz      .
      *                  *---------------------------------------------*
      *                  * Lettura numeri di sequenza per classe,      *
      *                  * gruppo e sottogruppo solo se richiesto da   *
      *                  * tipo ordinamento il quale va decodificato   *
      *                  * nel modo che segue :                        *
      *                  *                                             *
      *                  * - 01 : Per classe, gruppo e sottogruppo e   *
      *                  *        codice prodotto                      *
      *                  * - 02 : Per classe, gruppo e sottogruppo e   *
      *                  *        descrizione prodotto                 *
      *                  * - 03 : Per codice prodotto                  *
      *                  * - 04 : Per descrizione prodotto             *
      *                  *---------------------------------------------*
           if        rr-fso-dcp-ord       >    2
                     go to stp-srt-inp-300.
      *                      *-----------------------------------------*
      *                      * Lettura classe di appartenenza          *
      *                      *-----------------------------------------*
           move      rf-dcp-cla-pro       to   w-let-arc-zp1-cla      .
           perform   let-arc-zp1-000      thru let-arc-zp1-999        .
      *                          *-------------------------------------*
      *                          * Se classe non trovata : a selezioni *
      *                          * su cliente                          *
      *                          *-------------------------------------*
           if        w-let-arc-zp1-flg    not  = spaces
                     go to stp-srt-inp-400.
      *                          *-------------------------------------*
      *                          * Se la classe non ulteriormente sud- *
      *                          * divisa : a selezioni su cliente     *
      *                          *-------------------------------------*
           if        w-let-arc-zp1-sud    =    01
                     go to stp-srt-inp-400.
      *                      *-----------------------------------------*
      *                      * Lettura gruppo di appartenenza          *
      *                      *-----------------------------------------*
           move      rf-dcp-cla-pro       to   w-let-arc-zp2-cla      .
           move      rf-dcp-gru-pro       to   w-let-arc-zp2-gru      .
           perform   let-arc-zp2-000      thru let-arc-zp2-999        .
      *                          *-------------------------------------*
      *                          * Se gruppo non trovato : a selezioni *
      *                          * su cliente                          *
      *                          *-------------------------------------*
           if        w-let-arc-zp2-flg    not  = spaces
                     go to stp-srt-inp-400.
      *                          *-------------------------------------*
      *                          * Se il gruppo non ulteriormente sud- *
      *                          * diviso : a selezioni su cliente     *
      *                          *-------------------------------------*
           if        w-let-arc-zp2-sud    =    01
                     go to stp-srt-inp-400.
      *                      *-----------------------------------------*
      *                      * Lettura sottogruppo di appartenenza     *
      *                      *-----------------------------------------*
           move      rf-dcp-cla-pro       to   w-let-arc-zp3-cla      .
           move      rf-dcp-gru-pro       to   w-let-arc-zp3-gru      .
           move      rf-dcp-sgr-pro       to   w-let-arc-zp3-sgr      .
           perform   let-arc-zp3-000      thru let-arc-zp3-999        .
      *                          *-------------------------------------*
      *                          * Se sottogruppo non trovato : a se-  *
      *                          * lezioni su cliente                  *
      *                          *-------------------------------------*
           if        w-let-arc-zp3-flg    not  = spaces
                     go to stp-srt-inp-400.
      *                          *-------------------------------------*
      *                          * Se il sottogruppo non ulteriormente *
      *                          * suddiviso : a selezioni su cliente  *
      *                          *-------------------------------------*
           if        w-let-arc-zp3-sud    =    01
                     go to stp-srt-inp-400.
       stp-srt-inp-300.
      *                  *---------------------------------------------*
      *                  * Se ordinamento per codice o descrizione :   *
      *                  * nessuna azione                              *
      *                  *---------------------------------------------*
      *                          *-------------------------------------*
      *                          * A selezioni su cliente              *
      *                          *-------------------------------------*
           go to     stp-srt-inp-400.
       stp-srt-inp-400.
      *                  *---------------------------------------------*
      *                  * Selezioni su anagrafica [dcc] relativa al   *
      *                  * cliente in corso di trattamento             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura record [dcc]                    *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLI"             to   f-key                  .
