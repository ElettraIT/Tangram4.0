                     go to cnt-tdo-ric-300.
           if        rr-cod-max           not  < rr-cod-min
                     go to cnt-tdo-ric-300.
           move      "ME"                 to   v-ope                  .
           move      "Il codice massimo non puo' essere inferiore al cod
      -              "ice minimo !"       to   v-not                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "#"                  to   w-cnt-tdo-ric-flg      .
           go to     cnt-tdo-ric-999.
       cnt-tdo-ric-300.
