      *                      * Se record non trovato : a cliente suc-  *
      *                      * cessivo                                 *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-200.
       stp-srt-inp-500.
      *                  *---------------------------------------------*
      *                  * Preparazione record di sort                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Pulizia preliminare                     *
      *                      *-----------------------------------------*
           move      spaces               to   srt-rec                .
      *                      *-----------------------------------------*
      *                      * Campi chiave                            *
      *                      *-----------------------------------------*
           move      rf-dcc-rag-soc       to   srt-rag-cli            .
      *                      *-----------------------------------------*
      *                      * Preparazione dati                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Codice cliente                      *
      *                          *-------------------------------------*
           move      rf-lst-cod-cli       to   srt-cod-cli            .
      *                          *-------------------------------------*
      *                          * Sigla valuta                        *
      *                          *-------------------------------------*
           move      rf-lst-sgl-vlt       to   srt-sgl-vlt            .
      *                          *-------------------------------------*
      *                          * Decimali valuta                     *
      *                          *-------------------------------------*
           move      rf-lst-dec-vlt       to   srt-dec-vlt            .
      *                          *-------------------------------------*
      *                          * Decimali prezzo                     *
      *                          *-------------------------------------*
           move      rf-lst-num-pro       to   w-let-arc-dcp-cod      .
           perform   let-arc-dcp-000      thru let-arc-dcp-999        .
           move      w-let-arc-dcp-dec    to   srt-dec-prz            .
      *                          *-------------------------------------*
      *                          * Prezzo di listino precedente        *
      *                          *-------------------------------------*
           move      rf-lst-prz-lst       to   srt-pre-lst            .
      *                          *-------------------------------------*
      *                          * Prezzo di listino attuale           *
      *                          *-------------------------------------*
           move      rf-lst-prz-lst       to   srt-prz-lst            .
      *                          *-------------------------------------*
      *                          * % di provvigioni                    *
      *                          *-------------------------------------*
           move      rf-lst-per-pvg (1)   to   srt-per-pvg (1)        .
           move      rf-lst-per-pvg (2)   to   srt-per-pvg (2)        .
           move      rf-lst-per-pvg (3)   to   srt-per-pvg (3)        .
      *                          *-------------------------------------*
      *                          * % sconto                            *
      *                          *-------------------------------------*
           move      rf-lst-per-sco (1)   to   srt-per-sco (1)        .
           move      rf-lst-per-sco (2)   to   srt-per-sco (2)        .
           move      rf-lst-per-sco (3)   to   srt-per-sco (3)        .
           move      rf-lst-per-sco (4)   to   srt-per-sco (4)        .
           move      rf-lst-per-sco (5)   to   srt-per-sco (5)        .
      *                          *-------------------------------------*
      *                          * Flags di si/no utilizzo             *
      *                          *-------------------------------------*
           move      rf-lst-snx-prz       to   srt-snx-prz            .
           move      rf-lst-snx-pvg       to   srt-snx-pvg            .
           move      rf-lst-snx-sco       to   srt-snx-sco            .
      *                          *-------------------------------------*
      *                          * Data validita' iniziale             *
      *                          *-------------------------------------*
           move      rf-lst-dva-ini       to   srt-dva-ini            .
      *                          *-------------------------------------*
      *                          * Data validita' finale               *
      *                          *-------------------------------------*
           move      rf-lst-dva-fin       to   srt-dva-fin            .
      *                      *-----------------------------------------*
      *                      * Tipo funzionamento                      *
      *                      *-----------------------------------------*
           if        srt-snx-prz          =    "S"  and
                     srt-snx-sco          =    "S"  and
                     srt-snx-pvg          =    "S"
                     move  01             to   srt-tip-fnz
           else if   srt-snx-prz          =    "S"  and
                     srt-snx-sco          =    "N"  and
                     srt-snx-pvg          =    "N"
                     move  02             to   srt-tip-fnz
           else if   srt-snx-prz          =    "N"  and
                     srt-snx-sco          =    "S"  and
                     srt-snx-pvg          =    "N"
                     move  03             to   srt-tip-fnz
           else if   srt-snx-prz          =    "N"  and
                     srt-snx-sco          =    "N"  and
                     srt-snx-pvg          =    "S"
                     move  04             to   srt-tip-fnz
           else if   srt-snx-prz          =    "S"  and
                     srt-snx-sco          =    "S"  and
                     srt-snx-pvg          =    "N"
                     move  05             to   srt-tip-fnz
           else if   srt-snx-prz          =    "S"  and
                     srt-snx-sco          =    "N"  and
                     srt-snx-pvg          =    "S"
                     move  06             to   srt-tip-fnz
           else if   srt-snx-prz          =    "N"  and
                     srt-snx-sco          =    "S"  and
                     srt-snx-pvg          =    "S"
                     move  07             to   srt-tip-fnz
           else      move  zero           to   srt-tip-fnz          .
      *                  *---------------------------------------------*
      *                  * Rilascio record al sort                     *
      *                  *---------------------------------------------*
           release   srt-rec                                          .
      *                  *---------------------------------------------*
      *                  * A riciclo su record [lst]                   *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-999.
           exit.

