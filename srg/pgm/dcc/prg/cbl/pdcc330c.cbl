                     go to det-pbs-lst-600.
           if        w-det-pbs-bas-vlt    =    spaces
                     go to det-pbs-lst-600.
           if        w-det-pbs-bas-vlt    not  = rf-lsd-sgl-vlt
                     go to det-pbs-lst-600.
           if        w-det-pbs-bas-dcv    not  = rf-lsd-dec-vlt
                     go to det-pbs-lst-600.
           if        w-det-pbs-bas-prz    not  = rf-lsd-prz-lst
                     go to det-pbs-lst-600.
           if        w-det-pbs-dat-sys    <    rf-lsd-dva-fin
                     go to det-pbs-lst-600.
           go to     det-pbs-lst-450.
       det-pbs-lst-600.
      *                  *---------------------------------------------*
      *                  * Incremento numero prezzi storici trovati    *
      *                  *---------------------------------------------*
           add       1                    to   w-det-pbs-sto-num      .
       det-pbs-lst-650.
      *                  *---------------------------------------------*
      *                  * Memorizzazione prezzo storico trovato       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Sigla valuta                            *
      *                      *-----------------------------------------*
           move      rf-lsd-sgl-vlt       to   w-det-pbs-sto-vlt
                                              (w-det-pbs-sto-num)     .
      *                      *-----------------------------------------*
      *                      * Decimali valuta                         *
      *                      *-----------------------------------------*
           move      rf-lsd-dec-vlt       to   w-det-pbs-sto-dcv
                                              (w-det-pbs-sto-num)     .
      *                      *-----------------------------------------*
      *                      * Prezzo                                  *
      *                      *-----------------------------------------*
           move      rf-lsd-prz-lst       to   w-det-pbs-sto-prz
                                              (w-det-pbs-sto-num)     .
      *                      *-----------------------------------------*
      *                      * Data di validita' finale                *
      *                      *-----------------------------------------*
           move      rf-lsd-dva-fin       to   w-det-pbs-sto-dvf
                                              (w-det-pbs-sto-num)     .
       det-pbs-lst-700.
      *                  *---------------------------------------------*
      *                  * Se raggiunto il max numero di prezzi stori- *
      *                  * ci da ricercare si esce, altrimenti si ri-  *
      *                  * cerca il prezzo storico successivo          *
      *                  *---------------------------------------------*
           if        w-det-pbs-sto-num    =    w-det-pbs-max-sto
                     go to det-pbs-lst-900
           else      go to det-pbs-lst-450.
       det-pbs-lst-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-pbs-lst-999.
       det-pbs-lst-999.
           exit.

      *    *===========================================================*
      *    * Determinazione nuovo prezzo di listino, per sottoposizio- *
      *    * ne all'aggiornamento                                      *
      *    *-----------------------------------------------------------*
       det-new-prz-000.
      *              *-------------------------------------------------*
      *              * Preliminari                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Vecchio prezzo su nuovo prezzo              *
      *                  *---------------------------------------------*
           move      w-det-new-prz-old    to   w-det-new-prz-new      .
      *                  *---------------------------------------------*
      *                  * Se prezzo a zero : uscita                   *
      *                  *---------------------------------------------*
           if        w-det-new-prz-new    =    zero
                     go to det-new-prz-999.
       det-new-prz-100.
      *              *-------------------------------------------------*
      *              * Aggiornamento                                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale aggiustamento per decimali prezzo *
      *                  *---------------------------------------------*
           if        w-det-new-prz-dec    =    1
                     divide    10         into w-det-new-prz-new
           else if   w-det-new-prz-dec    =    2
                     divide    100        into w-det-new-prz-new      .
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo di aggior-  *
      *                  * namento                                     *
      *                  *---------------------------------------------*
           if        w-tes-tip-agg        =    01
                     go to det-new-prz-200
           else if   w-tes-tip-agg        =    02
                     go to det-new-prz-250
           else      go to det-new-prz-300.
       det-new-prz-200.
      *                  *---------------------------------------------*
      *                  * Se tipo di aggiornamento : Aumento          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Calcolo aggiornamento                   *
      *                      *-----------------------------------------*
           move      100,0                to   w-det-new-prz-coe      .
           add       w-tes-per-aod        to   w-det-new-prz-coe      .
           multiply  w-det-new-prz-coe    by   w-det-new-prz-new      .
           divide    100                  into w-det-new-prz-new      .
      *                      *-----------------------------------------*
      *                      * Ad arrotondamento                       *
      *                      *-----------------------------------------*
           go to     det-new-prz-400.
       det-new-prz-250.
      *                  *---------------------------------------------*
      *                  * Se tipo di aggiornamento : Diminuzione      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Calcolo aggiornamento                   *
      *                      *-----------------------------------------*
           move      100,0                to   w-det-new-prz-coe      .
           subtract  w-tes-per-aod        from w-det-new-prz-coe      .
           multiply  w-det-new-prz-coe    by   w-det-new-prz-new      .
           divide    100                  into w-det-new-prz-new      .
      *                      *-----------------------------------------*
      *                      * Ad arrotondamento                       *
      *                      *-----------------------------------------*
           go to     det-new-prz-400.
       det-new-prz-300.
      *                  *---------------------------------------------*
      *                  * Se tipo di aggiornamento : Solo arrotonda-  *
      *                  *                            mento            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ad arrotondamento                       *
      *                      *-----------------------------------------*
           go to     det-new-prz-400.
       det-new-prz-400.
      *              *-------------------------------------------------*
      *              * Arrotondamento                                  *
      *              *-------------------------------------------------*
       det-new-prz-450.
      *                  *---------------------------------------------*
      *                  * Se il valore di arrotondamento non e' si-   *
      *                  * gnificativo : ad eventuali aggiustamenti    *
      *                  *---------------------------------------------*
           if        w-tes-val-arr        =    zero or
                     w-tes-val-arr        =    1
                     go to det-new-prz-800.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo di arroton- *
      *                  * damento                                     *
      *                  *---------------------------------------------*
           if        w-tes-tip-arr        =    01
                     go to det-new-prz-500
           else if   w-tes-tip-arr        =    02
                     go to det-new-prz-550
           else if   w-tes-tip-arr        =    03
                     go to det-new-prz-600
           else if   w-tes-tip-arr        =    04
                     go to det-new-prz-650.
       det-new-prz-500.
      *                  *---------------------------------------------*
      *                  * Se tipo di arrotondamento : Nessuno         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ad eventuali aggiustamenti              *
      *                      *-----------------------------------------*
           go to     det-new-prz-800.
       det-new-prz-550.
      *                  *---------------------------------------------*
      *                  * Se tipo di arrotondamento : Commerciale     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Calcolo arrotondamento                  *
      *                      *-----------------------------------------*
           divide    w-tes-val-arr        into w-det-new-prz-new
                                                         rounded      .
           multiply  w-tes-val-arr        by   w-det-new-prz-new      .
      *                      *-----------------------------------------*
      *                      * Ad eventuali aggiustamenti              *
      *                      *-----------------------------------------*
           go to     det-new-prz-800.
       det-new-prz-600.
      *                  *---------------------------------------------*
      *                  * Se tipo di arrotondamento : Al valore supe- *
      *                  * riore                                       *
      *                  *---------------------------------------------*
           add       w-tes-val-arr        to   w-det-new-prz-new      .
           subtract  1                    from w-det-new-prz-new      .
           divide    w-tes-val-arr        into w-det-new-prz-new      .
           multiply  w-tes-val-arr        by   w-det-new-prz-new      .
      *                      *-----------------------------------------*
      *                      * Ad eventuali aggiustamenti              *
      *                      *-----------------------------------------*
           go to     det-new-prz-800.
       det-new-prz-650.
      *                  *---------------------------------------------*
      *                  * Se tipo di arrotondamento : Al valore infe- *
      *                  * riore                                       *
      *                  *---------------------------------------------*
           divide    w-tes-val-arr        into w-det-new-prz-new      .
           multiply  w-tes-val-arr        by   w-det-new-prz-new      .
      *                      *-----------------------------------------*
      *                      * Ad eventuali aggiustamenti              *
      *                      *-----------------------------------------*
           go to     det-new-prz-800.
       det-new-prz-800.
      *              *-------------------------------------------------*
      *              * Eventuali aggiustamenti                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale aggiustamento per decimali prezzo *
      *                  *---------------------------------------------*
           if        w-det-new-prz-dec    =    1
                     multiply  10         by   w-det-new-prz-new
           else if   w-det-new-prz-dec    =    2
                     multiply  100        by   w-det-new-prz-new      .
       det-new-prz-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-new-prz-999.
       det-new-prz-999.
           exit.

      *    *===========================================================*
      *    * Routine lettura tabella [zvl]                             *
      *    *-----------------------------------------------------------*
       let-arc-zvl-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-zvl-flg      .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del valore della sigla va- *
      *              * luta                                            *
      *              *-------------------------------------------------*
           if        w-let-arc-zvl-cod    =    c-sgl
                     go to let-arc-zvl-200
           else if   w-let-arc-zvl-cod    =    spaces
                     go to let-arc-zvl-400
           else      go to let-arc-zvl-600.
       let-arc-zvl-200.
      *              *-------------------------------------------------*
      *              * Se sigla valuta pari alla valuta base           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Descrizione valuta in lingua italiana       *
      *                  *---------------------------------------------*
           move      c-des                to   w-let-arc-zvl-des      .
      *                  *---------------------------------------------*
      *                  * Descrizione valuta internazionale           *
      *                  *---------------------------------------------*
           move      c-din                to   w-let-arc-zvl-din      .
      *                  *---------------------------------------------*
      *                  * Numero decimali valuta                      *
      *                  *---------------------------------------------*
           move      c-dec                to   w-let-arc-zvl-dec      .
      *                  *---------------------------------------------*
      *                  * Tipo di coefficiente per cambio valuta      *
      *                  *---------------------------------------------*
           move      c-tdc                to   w-let-arc-zvl-tdc      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     let-arc-zvl-999.
       let-arc-zvl-400.
      *              *-------------------------------------------------*
      *              * Se sigla valuta a Spaces                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Descrizione valuta in lingua italiana       *
      *                  *---------------------------------------------*
           move      spaces               to   w-let-arc-zvl-des      .
      *                  *---------------------------------------------*
      *                  * Descrizione valuta internazionale           *
      *                  *---------------------------------------------*
           move      spaces               to   w-let-arc-zvl-din      .
      *                  *---------------------------------------------*
      *                  * Numero decimali valuta                      *
      *                  *---------------------------------------------*
           move      zero                 to   w-let-arc-zvl-dec      .
      *                  *---------------------------------------------*
      *                  * Tipo di coefficiente per cambio valuta      *
      *                  *---------------------------------------------*
           move      spaces               to   w-let-arc-zvl-tdc      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     let-arc-zvl-999.
       let-arc-zvl-600.
      *              *-------------------------------------------------*
      *              * Se sigla valuta diversa dalla valuta base ed    *
      *              * anche diversa da Spaces                         *
      *              *-------------------------------------------------*
       let-arc-zvl-650.
      *                  *---------------------------------------------*
      *                  * Lettura per sigla valuta                    *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODVLT    "         to   f-key                  .
           move      w-let-arc-zvl-cod    to   rf-zvl-sgl-vlt         .
           move      "pgm/dcc/fls/ioc/obj/iofzvl"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zvl                 .
      *                  *---------------------------------------------*
      *                  * Deviazione secondo l'esito della lettura    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to let-arc-zvl-750.
       let-arc-zvl-700.
      *                  *---------------------------------------------*
      *                  * Se record esistente                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Descrizione valuta in lingua italiana   *
      *                      *-----------------------------------------*
           move      rf-zvl-des-ita       to   w-let-arc-zvl-des      .
      *                      *-----------------------------------------*
      *                      * Descrizione valuta internazionale       *
      *                      *-----------------------------------------*
           move      rf-zvl-des-int       to   w-let-arc-zvl-din      .
      *                      *-----------------------------------------*
      *                      * Numero decimali valuta                  *
      *                      *-----------------------------------------*
           move      rf-zvl-num-dec       to   w-let-arc-zvl-dec      .
      *                      *-----------------------------------------*
      *                      * Tipo di coefficiente per cambio valuta  *
      *                      *-----------------------------------------*
           move      rf-zvl-def-tdc       to   w-let-arc-zvl-tdc      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     let-arc-zvl-999.
       let-arc-zvl-750.
      *                  *---------------------------------------------*
      *                  * Se record non esistente                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di uscita ad errore                *
      *                      *-----------------------------------------*
           move      "#"                  to   w-let-arc-zvl-flg      .
      *                      *-----------------------------------------*
      *                      * Descrizione valuta in lingua italiana   *
      *                      *-----------------------------------------*
           move      all   "."            to   w-let-arc-zvl-des      .
      *                      *-----------------------------------------*
      *                      * Descrizione valuta internazionale       *
      *                      *-----------------------------------------*
           move      all   "."            to   w-let-arc-zvl-din      .
      *                      *-----------------------------------------*
      *                      * Numero decimali valuta                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-let-arc-zvl-dec      .
      *                      *-----------------------------------------*
      *                      * Tipo di coefficiente per cambio valuta  *
      *                      *-----------------------------------------*
           move      spaces               to   w-let-arc-zvl-tdc      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     let-arc-zvl-999.
       let-arc-zvl-999.
           exit.

