           move      "AC"                 to   w-cmn-zcs-003-ope      .
           move      rr-cod-due           to   w-cmn-zcs-003-cod      .
           move      09                   to   w-cmn-zcs-003-lin      .
           move      30                   to   w-cmn-zcs-003-pos      .
           move      09                   to   w-cmn-zcs-003-dln      .
           move      41                   to   w-cmn-zcs-003-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   cmn-zcs-003-cll-000  thru cmn-zcs-003-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cmn-zcs-003-foi-000  thru cmn-zcs-003-foi-999    .
       acc-cod-due-110.
           perform   cmn-zcs-003-cll-000  thru cmn-zcs-003-cll-999    .
           if        w-cmn-zcs-003-ope    =    "F+"
                     go to acc-cod-due-115.
           if        w-cmn-zcs-003-ope    =    "AC"
                     go to acc-cod-due-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-due-115.
           perform   cmn-zcs-003-foi-000  thru cmn-zcs-003-foi-999    .
           go to     acc-cod-due-110.
       acc-cod-due-120.
           move      w-cmn-zcs-003-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Visualizzazione note operative                  *
      *              *-------------------------------------------------*
           if        rr-tip-ord           =    "P"
                     go to acc-cod-due-122.
           move      "NT"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-due-122.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-cod-due-999.
       acc-cod-due-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   rr-cod-due             .
       acc-cod-due-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura descrizione                         *
      *                  *---------------------------------------------*
           move      03                   to   w-let-arc-zcs-tip      .
           move      rr-cod-due           to   w-let-arc-zcs-cod      .
           perform   let-arc-zcs-000      thru let-arc-zcs-999        .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione descrizione                 *
      *                  *---------------------------------------------*
           if        rr-cod-due           =    zero
                     move  "Tutte"        to   rr-cod-due-des
           else      move  w-let-arc-zcs-des
                                          to   rr-cod-due-des         .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-due-000      thru vis-des-due-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-zcs-flg    not  = spaces
                     go to acc-cod-due-100.
      *                  *---------------------------------------------*
      *                  * Se tipo ordinamento tabella per cliente :   *
      *                  * campo obbligatorio                          *
      *                  *---------------------------------------------*
           if        rr-tip-ord           not  = "P"
                     go to acc-cod-due-600.
           if        rr-cod-due           not  = zero
                     go to acc-cod-due-600.
           if        v-key                =    "UP  "
                     go to acc-cod-due-600
           else      go to acc-cod-due-100.
       acc-cod-due-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-due-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-cod-due-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-cod-due-100.
       acc-cod-due-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo chiave : Codice sconto in riga pr.  *
      *    *-----------------------------------------------------------*
       vis-cod-due-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      09                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<B"                 to   v-edm                  .
           move      rr-cod-due           to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-due-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo chiave : Descrizione sconto in riga *
      *    *                                prodotto                   *
      *    *-----------------------------------------------------------*
       vis-des-due-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      rr-cod-due-des       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-due-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Tipo ordinamento categorie           *
      *    *-----------------------------------------------------------*
       acc-tip-cat-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        rr-cod-due           not  = zero
                     go to acc-tip-cat-999.
       acc-tip-cat-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-cat-lun    to   v-car                  .
           move      w-exp-tip-cat-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      "DC#"                to   v-msk                  .
           move      w-exp-tip-cat-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-ric    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      11                   to   v-lin                  .
           move      30                   to   v-pos                  .
      *
           if        rr-tip-cat           =    "D"
                     move  01             to   v-num
           else if   rr-tip-cat           =    "C"
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
      *
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-tip-cat-999.
       acc-tip-cat-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    01
                     move  "D"            to   rr-tip-cat
           else if   v-num                =    02
                     move  "C"            to   rr-tip-cat
           else      move  spaces         to   rr-tip-cat             .
       acc-tip-cat-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
           if        rr-tip-cat           =    spaces
                     go to acc-tip-cat-100.
       acc-tip-cat-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-tip-cat-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-tip-cat-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-tip-cat-100.
       acc-tip-cat-999.
           exit.

      *    *===========================================================*
      *    * Box per messaggio di errore                               *
      *    *-----------------------------------------------------------*
       box-msg-err-000.
      *              *-------------------------------------------------*
      *              * Salvataggio immagine video                      *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in Off                                    *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Box                                             *
      *              *-------------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      12                   to   v-lin                  .
           move      13                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      68                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Messaggio nel box                               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      48                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      15                   to   v-pos                  .
           move      w-box-msg-err-msg    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Parentesi quadre di delimitazione               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      64                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      13                   to   v-lin                  .
           move      65                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       box-msg-err-999.
           exit.

      *    *===========================================================*
      *    * Controllo su tasto Do in parametri di selezione           *
      *    *-----------------------------------------------------------*
       tdo-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Controllo su tipo ordinamento                   *
      *              *-------------------------------------------------*
           if        rr-tip-ord           =    "C" or
                     rr-tip-ord           =    "P"
                     go to tdo-ric-sel-300.
           move      "Tipo ordinamento tabella errato !"
                                          to   w-box-msg-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           move      "#"                  to   w-cnt-tdo-ric-flg      .
           go to     tdo-ric-sel-999.
       tdo-ric-sel-300.
      *              *-------------------------------------------------*
      *              * Controllo su codice cliente                     *
      *              *-------------------------------------------------*
           if        rr-tip-ord           not  = "C"
                     go to tdo-ric-sel-400.
           if        rr-cod-uno           not  = zero
                     go to tdo-ric-sel-999.
           move      "ME"                 to   v-ope                  .
           move      "Manca il codice cliente !"
                                          to   w-box-msg-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           move      "#"                  to   w-cnt-tdo-ric-flg      .
           go to     tdo-ric-sel-999.
       tdo-ric-sel-400.
      *              *-------------------------------------------------*
      *              * Controllo su codice sconto prodotto             *
      *              *-------------------------------------------------*
           if        rr-cod-due           not  = zero
                     go to tdo-ric-sel-999.
           move      "ME"                 to   v-ope                  .
           move      "Manca il codice sconto prodotto !"
                                          to   w-box-msg-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           move      "#"                  to   w-cnt-tdo-ric-flg      .
           go to     tdo-ric-sel-999.
       tdo-ric-sel-800.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Regolarizzazione dei parametri di selezione               *
      *    *-----------------------------------------------------------*
       reg-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Regolarizzazione tipo ordinamento tabella       *
      *              *-------------------------------------------------*
           if        rr-tip-ord           =    spaces
                     move  "C"            to   rr-tip-ord             .
      *              *-------------------------------------------------*
      *              * Regolarizzazione tipo ordinamento categorie     *
      *              *-------------------------------------------------*
           if        rr-tip-cat           =    spaces
                     move  "D"            to   rr-tip-cat             .
       reg-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione richieste di selezione                    *
      *    *-----------------------------------------------------------*
       nor-ric-sel-000.
           move      spaces               to   rr-tip-ord             .
           move      zero                 to   rr-cod-uno             .
           move      spaces               to   rr-cod-uno-des         .
           move      zero                 to   rr-cod-due             .
           move      spaces               to   rr-cod-due-des         .
           move      spaces               to   rr-tip-cat             .
       nor-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Interrogazione : Open files                               *
      *    *-----------------------------------------------------------*
       qry-opn-fls-000.
      *              *-------------------------------------------------*
      *              * [zcs]                                           *
      *              *-------------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofzcs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zcs                 .
      *              *-------------------------------------------------*
      *              * [zsx]                                           *
      *              *-------------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofzsx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zsx                 .
       qry-opn-fls-999.
           exit.

      *    *===========================================================*
      *    * Interrogazione : Close files                              *
      *    *-----------------------------------------------------------*
       qry-cls-fls-000.
      *              *-------------------------------------------------*
      *              * [zcs]                                           *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofzcs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zcs                 .
      *              *-------------------------------------------------*
      *              * [zsx]                                           *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofzsx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zsx                 .
       qry-cls-fls-999.
           exit.

      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   qry-rou-pri-000
                                          thru qry-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Start su file [zsx]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
      *
           if        rr-tip-ord           =    "C"
                     move  "UNODUE    "   to   f-key
           else      move  "DUEUNO    "   to   f-key                  .
      *
           move      02                   to   rf-zsx-tip-inc         .
           move      rr-cod-uno           to   rf-zsx-cod-uno         .
           move      rr-cod-due           to   rf-zsx-cod-due         .
           move      "pgm/dcc/fls/ioc/obj/iofzsx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zsx                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata                             *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [zsx]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofzsx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zsx                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo incrocio                       *
      *                  *---------------------------------------------*
           if        rf-zsx-tip-inc       not  = 02
                     go to stp-srt-inp-999.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo ordinamento *
      *                  *---------------------------------------------*
           if        rr-tip-ord           =    "C"
                     go to stp-srt-inp-120
           else      go to stp-srt-inp-140.
       stp-srt-inp-120.
      *                  *---------------------------------------------*
      *                  * Tipo ordinamento : per cliente              *
      *                  *---------------------------------------------*
           if        rf-zsx-cod-uno       not  = rr-cod-uno
                     go to stp-srt-inp-999.
           if        rr-cod-due           not  = zero and
                     rf-zsx-cod-due       not  = rr-cod-due
                     go to stp-srt-inp-999.
           go to     stp-srt-inp-200.
       stp-srt-inp-140.
      *                  *---------------------------------------------*
      *                  * Tipo ordinamento : per categoria prodotto   *
      *                  *---------------------------------------------*
           if        rf-zsx-cod-due       not  = rr-cod-due
                     go to stp-srt-inp-999.
           if        rr-cod-uno           not  = zero and
                     rf-zsx-cod-uno       not  = rr-cod-uno
                     go to stp-srt-inp-999.
           go to     stp-srt-inp-200.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Lettura descrizione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo ordinamento *
      *                  *---------------------------------------------*
           if        rr-tip-ord           =    "C"
                     go to stp-srt-inp-220
           else      go to stp-srt-inp-240.
       stp-srt-inp-220.
      *                  *---------------------------------------------*
      *                  * Tipo ordinamento : per cliente              *
      *                  *---------------------------------------------*
           move      03                   to   w-let-arc-zcs-tip      .
           move      rf-zsx-cod-due       to   w-let-arc-zcs-cod      .
           perform   let-arc-zcs-000      thru let-arc-zcs-999        .
           move      w-let-arc-zcs-des    to   w-stp-srt-inp-des      .
           move      rf-zsx-cod-due       to   w-stp-srt-inp-cod      .
           go to     stp-srt-inp-300.
       stp-srt-inp-240.
      *                  *---------------------------------------------*
      *                  * Tipo ordinamento : per categoria prodotto   *
      *                  *---------------------------------------------*
           move      rf-zsx-cod-uno       to   w-let-arc-dcc-cli      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
           move      w-let-arc-dcc-rag    to   w-stp-srt-inp-des      .
           move      rf-zsx-cod-uno       to   w-stp-srt-inp-cod      .
           go to     stp-srt-inp-300.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Composizione record di sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Chiave                                      *
      *                  *---------------------------------------------*
           move      w-stp-srt-inp-cod    to   srt-cod-key            .
           if        rr-tip-cat           =    "D"
                     move  w-stp-srt-inp-des
                                          to   srt-des-key
           else      move  spaces         to   srt-des-key            .
      *                  *---------------------------------------------*
      *                  * Dati                                        *
      *                  *---------------------------------------------*
           move      w-stp-srt-inp-des    to   srt-des-cds            .
           move      w-stp-srt-inp-cod    to   srt-cod-cds            .
           move      rf-zsx-per-sco (1)   to   srt-per-sco (1)        .
           move      rf-zsx-per-sco (2)   to   srt-per-sco (2)        .
           move      rf-zsx-per-sco (3)   to   srt-per-sco (3)        .
           move      rf-zsx-per-sco (4)   to   srt-per-sco (4)        .
           move      rf-zsx-per-sco (5)   to   srt-per-sco (5)        .
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale record [zsx]     *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-100.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Interrogazione : Start iniziale                           *
      *    *-----------------------------------------------------------*
       qry-str-ini-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
