      *    *===========================================================*
      *    * Accettazione campo testata : Spese per fatturazione       *
      *    *-----------------------------------------------------------*
       acc-add-spe-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se nessuna spesa personalizzata : uscita    *
      *                  *---------------------------------------------*
           if        w-prs-spe-fat-nst    =    zero
                     go to acc-add-spe-999.
       acc-add-spe-100.
      *              *-------------------------------------------------*
      *              * Accettazione valori                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore 01..06           *
      *                  *---------------------------------------------*
           move      zero                 to   w-prs-spe-fat-i01      .
       acc-add-spe-150.
      *                  *---------------------------------------------*
      *                  * Incremento contatore 01..06                 *
      *                  *---------------------------------------------*
           add       01                   to   w-prs-spe-fat-i01      .
      *                  *---------------------------------------------*
      *                  * Se maggiore del massimo numero di spese     *
      *                  * personalizzate : uscita con function-key    *
      *                  * di uscita a Spaces                          *
      *                  *---------------------------------------------*
           if        w-prs-spe-fat-i01    >    w-prs-spe-fat-nst
                     move  spaces         to   v-key
                     go to acc-add-spe-999.
       acc-add-spe-200.
      *                  *---------------------------------------------*
      *                  * Preparazione indice reale per la spesa      *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-prs-spe-fat-i01)   to   w-prs-spe-fat-i02      .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del tipo funzionamen-  *
      *                  * to della spesa                              *
      *                  *---------------------------------------------*
           if        w-prs-spe-fat-tfs
                    (w-prs-spe-fat-i01)   =    01 or
                     w-prs-spe-fat-tfs
                    (w-prs-spe-fat-i01)   =    03
                     go to acc-add-spe-250
           else if   w-prs-spe-fat-tfs
                    (w-prs-spe-fat-i01)   =    02
                     go to acc-add-spe-300
           else if   w-prs-spe-fat-tfs
                    (w-prs-spe-fat-i01)   =    04
                     go to acc-add-spe-400
           else if   w-prs-spe-fat-tfs
                    (w-prs-spe-fat-i01)   =    05
                     go to acc-add-spe-500.
       acc-add-spe-250.
      *                  *---------------------------------------------*
      *                  * Se tipo funzionamento : 01, a percentuale   *
      *                  * fissa per tutti i clienti cui viene adde-   *
      *                  * bitata la spesa, oppure                     *
      *                  * Se tipo funzionamento : 03, ad importo fis- *
      *                  * so per tutti i clienti cui viene addebitata *
      *                  * la spesa                                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Accettazione scelta tra :               *
      *                      * - No addebito spesa                     *
      *                      * - Si addebito spesa                     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Salvataggio valore precedente       *
      *                          *-------------------------------------*
           move      w-tes-snm-spe
                    (1, w-prs-spe-fat-i02)
                                          to   w-sav-snm-spe          .
       acc-add-spe-255.
      *                          *-------------------------------------*
      *                          * Accettazione valore                 *
      *                          *-------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-ads-snx-lun    to   v-car                  .
           move      w-exp-ads-snx-num    to   v-ldt                  .
           move      "NS#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      w-prs-spe-fat-i01    to   v-lin                  .
           add       w-prs-spe-fat-lv1    to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-ads-snx-tbl    to   v-txt                  .
           if        w-tes-snm-spe
                    (1, w-prs-spe-fat-i02)
                                          =    01
                     move  01             to   v-num
           else if   w-tes-snm-spe
                    (1, w-prs-spe-fat-i02)
                                          =    02
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "PRSC"               to   v-pfk (07)             .
           move      "NXSC"               to   v-pfk (08)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-add-spe-260.
      *                          *-------------------------------------*
      *                          * Se Exit                             *
      *                          *-------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-add-spe-999.
       acc-add-spe-265.
      *                          *-------------------------------------*
      *                          * Se Delt                             *
      *                          *-------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-add-spe-999.
       acc-add-spe-270.
      *                          *-------------------------------------*
      *                          * Valore impostato in campo di de-    *
      *                          * stinazione                          *
      *                          *-------------------------------------*
           if        v-num                =    01
                     move  01             to   w-tes-snm-spe
                                              (1, w-prs-spe-fat-i02)
           else if   v-num                =    02
                     move  02             to   w-tes-snm-spe
                                              (1, w-prs-spe-fat-i02)
           else      move  zero           to   w-tes-snm-spe
                                              (1, w-prs-spe-fat-i02)  .
       acc-add-spe-280.
      *                          *-------------------------------------*
      *                          * Se valore impostato diverso dal va- *
      *                          * lore salvato si normalizzano i cam- *
      *                          * pi strettamente dipendenti          *
      *                          *-------------------------------------*
           if        w-tes-snm-spe
                    (1, w-prs-spe-fat-i02)
                                          =    w-sav-snm-spe
                     go to acc-add-spe-285.
           if        w-sav-snm-spe        =    zero
                     go to acc-add-spe-285.
           if        w-tes-per-spe
                    (1, w-prs-spe-fat-i02)
                                          =    zero
                     go to acc-add-spe-281.
           move      zero                 to   w-tes-per-spe
                                              (1, w-prs-spe-fat-i02)  .
           perform   vis-per-spe-000      thru vis-per-spe-999        .
       acc-add-spe-281.
           if        w-tes-imp-spe
                    (1, w-prs-spe-fat-i02)
                                          =    zero
                     go to acc-add-spe-285.
           move      zero                 to   w-tes-imp-spe
                                              (1, w-prs-spe-fat-i02)  .
           perform   vis-imp-spe-000      thru vis-imp-spe-999        .
       acc-add-spe-285.
      *                          *-------------------------------------*
