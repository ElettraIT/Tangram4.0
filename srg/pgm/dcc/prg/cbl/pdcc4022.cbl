      *    *===========================================================*
      *    * Routine di stampa addebiti in fattura                     *
      *    *-----------------------------------------------------------*
       stp-add-fat-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione contatore 01..06               *
      *              *-------------------------------------------------*
           move      zero                 to   w-prs-spe-fat-i01      .
       stp-add-fat-150.
      *              *-------------------------------------------------*
      *              * Incremento contatore 01..06                     *
      *              *-------------------------------------------------*
           add       01                   to   w-prs-spe-fat-i01      .
      *              *-------------------------------------------------*
      *              * Se maggiore del massimo numero di spese         *
      *              * personalizzate : uscita                         *
      *              *-------------------------------------------------*
           if        w-prs-spe-fat-i01    >    w-prs-spe-fat-nst
                     go to stp-add-fat-999.
       stp-add-fat-200.
      *              *-------------------------------------------------*
      *              * Preparazione indice reale per la spesa          *
      *              *-------------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-prs-spe-fat-i01)   to   w-prs-spe-fat-i02      .
           if        w-prs-spe-fat-i01    =    01
                     go to stp-add-fat-220.
      *              *-------------------------------------------------*
      *              * Interlinea                                      *
      *              *-------------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-add-fat-220.
      *              *-------------------------------------------------*
      *              * Bordo a sinistra                                *
      *              *-------------------------------------------------*
           move      "S"                  to   w-stp-brd-sod-sgn      .
           perform   stp-brd-sod-000      thru stp-brd-sod-999        .
      *              *-------------------------------------------------*
      *              * Literal per il tipo di addebito                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * '-'                                         *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      01                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      024                  to   p-pos                  .
           move      "-"                  to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Prompt                                      *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      23                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      026                  to   p-pos                  .
           move      w-prs-spe-fat-dve
                    (w-prs-spe-fat-i01)   to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * ':'                                         *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      01                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      050                  to   p-pos                  .
           move      ":"                  to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del tipo funzionamento     *
      *              * della spesa                                     *
      *              *-------------------------------------------------*
           if        w-prs-spe-fat-tfs
                    (w-prs-spe-fat-i01)   =    01 or
                     w-prs-spe-fat-tfs
                    (w-prs-spe-fat-i01)   =    03
                     go to stp-add-fat-250
           else if   w-prs-spe-fat-tfs
                    (w-prs-spe-fat-i01)   =    02
                     go to stp-add-fat-300
           else if   w-prs-spe-fat-tfs
                    (w-prs-spe-fat-i01)   =    04
                     go to stp-add-fat-350
           else if   w-prs-spe-fat-tfs
                    (w-prs-spe-fat-i01)   =    05
                     go to stp-add-fat-400.
       stp-add-fat-250.
      *                  *---------------------------------------------*
      *                  * Se tipo funzionamento : 01, a percentuale   *
      *                  * fissa per tutti i clienti cui viene adde-   *
      *                  * bitata la spesa, oppure                     *
      *                  * Se tipo funzionamento : 03, ad importo fis- *
      *                  * so per tutti i clienti cui viene addebitata *
      *                  * la spesa                                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Stampa tipo di addebito                 *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      20                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      052                  to   p-pos                  .
           if        w-buf-snm-spe
                    (w-prs-spe-fat-i02)   =    01
                     move  "No addebito         "
                                          to   p-alf
           else if   w-buf-snm-spe
                    (w-prs-spe-fat-i02)   =    02
                     move  "Si addebito         "
                                          to   p-alf
           else      move  "?                   "
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Bordo a destra                          *
      *                      *-----------------------------------------*
           move      "D"                  to   w-stp-brd-sod-sgn      .
           perform   stp-brd-sod-000      thru stp-brd-sod-999        .
      *                      *-----------------------------------------*
      *                      * A spesa successiva                      *
      *                      *-----------------------------------------*
           go to     stp-add-fat-150.
       stp-add-fat-300.
      *                  *---------------------------------------------*
      *                  * Se tipo funzionamento : 02, a percentuale   *
      *                  * variabile per ogni cliente cui viene adde-  *
      *                  * bitata la spesa, con la percentuale spesa   *
      *                  * espressa nel record dati commerciali del    *
      *                  * cliente                                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Stampa tipo di addebito                 *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      20                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      052                  to   p-pos                  .
           if        w-buf-snm-spe
                    (w-prs-spe-fat-i02)   =    01
                     move  "No addebito         "
                                          to   p-alf
           else if   w-buf-snm-spe
                    (w-prs-spe-fat-i02)   =    02
                     move  "Si addebito         "
                                          to   p-alf
           else      move  "?                   "
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Stampa percentuale                      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se zero : no visualizzazione        *
      *                          *-------------------------------------*
           if        w-buf-per-spe
                    (w-prs-spe-fat-i02)   =    zero
                     go to stp-add-fat-305.
      *                          *-------------------------------------*
      *                          * Literal per percentuale             *
      *                          *-------------------------------------*
           perform   stp-ltp-spe-000      thru stp-ltp-spe-999        .
      *                          *-------------------------------------*
      *                          * Percentuale                         *
      *                          *-------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      02                   to   p-car                  .
           move      01                   to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<B"                 to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      084                  to   p-pos                  .
           move      w-buf-per-spe
                    (w-prs-spe-fat-i02)   to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-add-fat-305.
      *                      *-----------------------------------------*
      *                      * Bordo a destra                          *
      *                      *-----------------------------------------*
           move      "D"                  to   w-stp-brd-sod-sgn      .
           perform   stp-brd-sod-000      thru stp-brd-sod-999        .
      *                      *-----------------------------------------*
      *                      * A spesa successiva                      *
      *                      *-----------------------------------------*
           go to     stp-add-fat-150.
       stp-add-fat-350.
      *                  *---------------------------------------------*
      *                  * Se tipo funzionamento : 04, ad importo va-  *
      *                  * riabile per ogni cliente cui viene addebi-  *
      *                  * tata la spesa, con l'importo spesa espres-  *
      *                  * so nel record dati commerciali del cliente  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Stampa tipo di addebito                 *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      20                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      052                  to   p-pos                  .
           if        w-buf-snm-spe
                    (w-prs-spe-fat-i02)   =    01
                     move  "No addebito         "
                                          to   p-alf
           else if   w-buf-snm-spe
                    (w-prs-spe-fat-i02)   =    02
