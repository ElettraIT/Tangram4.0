           move      001                  to   p-pos                  .
           move      "|       Codice |                 Ragione sociale  
      -              "              |                               Note
      -              "                               |"
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Finatura 2                                  *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      132                  to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      "| Mnemonico    |              Indirizzo e localita
      -              "'             |                                   
      -              "                               |"
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Sottolineatura                              *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      132                  to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      001                  to   p-pos                  .
           move      "+--------------+----------------------------------
      -              "--------------+-----------------------------------
      -              "-------------------------------+"
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     int-fin-det-900.
       int-fin-det-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     int-fin-det-999.
       int-fin-det-999.
           exit.

      *    *===========================================================*
      *    * Determinazione se CAP stradario                           *
      *    *                                                           *
      *    * N.B.: Se il CAP in corso di trattamento e' relativo a     *
      *    *       una frazione o ad una localita', si ricicla fino    *
      *    *       a che non si trova uno stradario di un comune.      *
      *    *-----------------------------------------------------------*
       det-std-gxs-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di esito                   *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-std-gxs-flg      .
      *              *-------------------------------------------------*
      *              * Normalizzazione codice comune                   *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-std-gxs-cmn      .
      *              *-------------------------------------------------*
      *              * Normalizzazione codice CAP per il comune        *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-std-gxs-ccm      .
       det-std-gxs-100.
      *              *-------------------------------------------------*
      *              * Start su file [gxs]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CAPDES    "         to   f-key                  .
           move      w-det-std-gxs-cap    to   rf-gxs-cap-avp         .
           move      spaces               to   rf-gxs-sgl-std         .
           move      spaces               to   rf-gxs-des-key         .
           move      spaces               to   rf-gxs-spc-key         .
           move      "pgm/geo/fls/ioc/obj/iofgxs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gxs                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : a test di controllo       *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-std-gxs-800.
       det-std-gxs-200.
      *              *-------------------------------------------------*
      *              * Next su [gxs]                                   *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/geo/fls/ioc/obj/iofgxs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gxs                 .
      *                  *---------------------------------------------*
      *                  * Se 'at end' : a test di controllo           *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-std-gxs-800.
       det-std-gxs-300.
      *              *-------------------------------------------------*
      *              * Max su [gxs], se non superato : a test di con-  *
      *              *                                 trollo          *
      *              *-------------------------------------------------*
           if        rf-gxs-cap-avp       not  = w-det-std-gxs-cap
                     go to det-std-gxs-800.
       det-std-gxs-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se elemento 'frazione' : a riciclo          *
      *                  *---------------------------------------------*
           if        rf-gxs-cod-fzn       not  = zero
                     go to det-std-gxs-200.
      *                  *---------------------------------------------*
      *                  * Se elemento 'localita'' : a riciclo         *
      *                  *---------------------------------------------*
           if        rf-gxs-cod-lct       not  = zero
                     go to det-std-gxs-200.
       det-std-gxs-600.
      *              *-------------------------------------------------*
      *              * Bufferizzazione del codice comune rilevato      *
      *              *-------------------------------------------------*
           move      rf-gxs-cod-cmn       to   w-det-std-gxs-cmn      .
      *                  *---------------------------------------------*
      *                  * A test di controllo                         *
      *                  *---------------------------------------------*
           go to     det-std-gxs-800.
       det-std-gxs-500.
      *              *-------------------------------------------------*
      *              * Riciclo a record [gxs] successivo               *
      *              *-------------------------------------------------*
           go to     det-std-gxs-200.
       det-std-gxs-800.
      *              *-------------------------------------------------*
      *              * Test di controllo                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se il codice comune e' a zero : uscita per  *
      *                  * rilevamento non effettuato                  *
      *                  *---------------------------------------------*
           if        w-det-std-gxs-cmn    =    zero
                     go to det-std-gxs-900.
      *                  *---------------------------------------------*
      *                  * Lettura del codice comune rilevato per ot-  *
      *                  * tenere il CAP                               *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCFL    "         to   f-key                  .
           move      w-det-std-gxs-cmn    to   rf-gxc-cod-cmn         .
           move      zero                 to   rf-gxc-cod-fzn         .
           move      zero                 to   rf-gxc-cod-lct         .
           move      "pgm/geo/fls/ioc/obj/iofgxc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gxc                 .
      *                      *-----------------------------------------*
      *                      * Se record non trovato : uscita per ri-  *
      *                      * levamento non effettuato                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-std-gxs-900.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione del CAP ottenuto            *
      *                  *---------------------------------------------*
           move      rf-gxc-cap-avp       to   w-det-std-gxs-ccm      .
      *                  *---------------------------------------------*
      *                  * Ad uscita per rilevamento effettuato        *
      *                  *---------------------------------------------*
           go to     det-std-gxs-890.
       det-std-gxs-890.
      *              *-------------------------------------------------*
      *              * Uscita per rilevamento effettuato               *
      *              *-------------------------------------------------*
           go to     det-std-gxs-999.
       det-std-gxs-900.
      *              *-------------------------------------------------*
      *              * Uscita per rilevamento non effettuato           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di rilevamento non effettuato          *
      *                  *---------------------------------------------*
           move      "#"                  to   w-det-std-gxs-flg      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-std-gxs-999.
       det-std-gxs-999.
           exit.

