      *    *===========================================================*
      *    * Ciclo Report Program : Esecuzione per fine ciclo          *
      *    *                                                           *
      *    * Subroutine per stampa contatore generale elementi         *
      *    *-----------------------------------------------------------*
       prn-fin-cic-stc-000.
      *              *-------------------------------------------------*
      *              * Test se stampa da eseguire                      *
      *              *-------------------------------------------------*
           if        rr-sns-cte           not  = 01
                     go to prn-fin-cic-stc-900.
           if        w-tot-gen-ele        not  > 1
                     go to prn-fin-cic-stc-900.
           if        rr-tip-ors           =    01
                     go to prn-fin-cic-stc-010.
           if        w-tot-gen-lr1        not  > 1
                     go to prn-fin-cic-stc-900.
       prn-fin-cic-stc-010.
      *              *-------------------------------------------------*
      *              * Test su linee residue                           *
      *              *-------------------------------------------------*
           if        p-res                >    03
                     go to prn-fin-cic-stc-100.
       prn-fin-cic-stc-050.
      *              *-------------------------------------------------*
      *              * Intestazione pagina                             *
      *              *-------------------------------------------------*
           perform   int-pag-sta-000      thru int-pag-sta-999        .
      *                  *---------------------------------------------*
      *                  * Test se interruzione forzata                *
      *                  *---------------------------------------------*
           if        w-cnt-prn-flg-int    not  = spaces
                     go to prn-fin-cic-stc-999.
       prn-fin-cic-stc-100.
      *              *-------------------------------------------------*
      *              * Fincatura superiore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * 2 interlinee subordinate                    *
      *                  *---------------------------------------------*
           move      "VS"                 to   p-ope                  .
           add       2
                     p-lnr              giving p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       prn-fin-cic-stc-300.
      *              *-------------------------------------------------*
      *              * Intestazione                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Concatenamento di literal e contatore       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing contatore                       *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      07                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<BG"                to   p-edm                  .
           move      w-tot-gen-ele        to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Concatenamento                          *
      *                      *-----------------------------------------*
           move      132                  to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
           move      "["                  to   w-all-str-cat (1)      .
           move      w-tot-gen-lit        to   w-all-str-cat (2)      .
           move      p-edt                to   w-all-str-cat (3)      .
           move      "]"                  to   w-all-str-cat (4)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                      *-----------------------------------------*
      *                      * Allineamento a destra                   *
      *                      *-----------------------------------------*
           perform   all-str-adx-000      thru all-str-adx-999        .
      *                      *-----------------------------------------*
      *                      * Stampa                                  *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
