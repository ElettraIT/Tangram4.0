      *    *===========================================================*
      *    * Determinazione prezzo su listino base e su storico dei    *
      *    * listini                                                   *
      *    *-----------------------------------------------------------*
       det-pbs-lst-000.
      *              *-------------------------------------------------*
      *              * Determinazione prezzo su listino base           *
      *              *-------------------------------------------------*
       det-pbs-lst-050.
      *                  *---------------------------------------------*
      *                  * Se record gia' in memoria si devia a se-    *
      *                  * conda se esisteva oppure no, controllando   *
      *                  * il codice prodotto alfanumerico             *
      *                  *---------------------------------------------*
           if        w-det-pbs-dcp-mem    not  = "S"
                     go to det-pbs-lst-100
           else if   rf-dcp-alf-pro       =    all "." or
                     rf-dcp-alf-pro       =    spaces
                     go to det-pbs-lst-160
           else      go to det-pbs-lst-200.
       det-pbs-lst-100.
      *                  *---------------------------------------------*
      *                  * Lettura record da [dcp]                     *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      w-det-pbs-num-pro    to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
       det-pbs-lst-150.
      *                  *---------------------------------------------*
      *                  * Se record non esistente                     *
      *                  *---------------------------------------------*
       det-pbs-lst-155.
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        f-sts                =    e-not-err
                     go to det-pbs-lst-200.
       det-pbs-lst-160.
      *                      *-----------------------------------------*
      *                      * Flag di esistenza a No                  *
      *                      *-----------------------------------------*
           move      "N"                  to   w-det-pbs-bas-flg      .
      *                      *-----------------------------------------*
      *                      * Sigla valuta a spaces                   *
      *                      *-----------------------------------------*
           move      spaces               to   w-det-pbs-bas-vlt      .
      *                      *-----------------------------------------*
      *                      * Decimali valuta a zero                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-pbs-bas-dcv      .
      *                      *-----------------------------------------*
      *                      * Prezzo a zero                           *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-pbs-bas-prz      .
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     det-pbs-lst-300.
       det-pbs-lst-200.
      *                  *---------------------------------------------*
      *                  * Se record esistente                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di esistenza a Si                  *
      *                      *-----------------------------------------*
           move      "S"                  to   w-det-pbs-bas-flg      .
      *                      *-----------------------------------------*
      *                      * Sigla valuta                            *
      *                      *-----------------------------------------*
           move      rf-dcp-sgl-vlt       to   w-det-pbs-bas-vlt      .
      *                      *-----------------------------------------*
      *                      * Decimali valuta                         *
      *                      *-----------------------------------------*
           move      rf-dcp-dec-vlt       to   w-det-pbs-bas-dcv      .
      *                      *-----------------------------------------*
      *                      * Prezzo                                  *
      *                      *-----------------------------------------*
           move      rf-dcp-prz-lst       to   w-det-pbs-bas-prz      .
      *                      *-----------------------------------------*
      *                      * Continuazione                           *
      *                      *-----------------------------------------*
           go to     det-pbs-lst-300.
       det-pbs-lst-300.
      *              *-------------------------------------------------*
      *              * Determinazione prezzi su storico listini        *
      *              *-------------------------------------------------*
       det-pbs-lst-350.
      *                  *---------------------------------------------*
      *                  * Numero prezzi storici trovati : zero        *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-pbs-sto-num      .
      *                  *---------------------------------------------*
      *                  * Se max numero di prezzi storici da ricerca- *
      *                  * re a zero : uscita                          *
      *                  *---------------------------------------------*
           if        w-det-pbs-max-sto    =    zero
                     go to det-pbs-lst-900.
       det-pbs-lst-400.
      *                  *---------------------------------------------*
      *                  * Start su storico listini                    *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "LSTPRODFR "         to   f-key                  .
           move      w-det-pbs-tip-rec    to   rf-lsd-tip-rec         .
           move      w-det-pbs-cod-lst    to   rf-lsd-cod-lst         .
           move      w-det-pbs-cod-cli    to   rf-lsd-cod-cli         .
           move      w-det-pbs-sgl-vlt    to   rf-lsd-sgl-vlt         .
           move      w-det-pbs-num-pro    to   rf-lsd-num-pro         .
           move      zero                 to   rf-lsd-dvf-rev         .
           move      "pgm/dcp/fls/ioc/obj/ioflsd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lsd                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-pbs-lst-900.
       det-pbs-lst-450.
      *                  *---------------------------------------------*
      *                  * Read next su storico listini                *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflsd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lsd                 .
      *                  *---------------------------------------------*
      *                  * Se At end : uscita                          *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-pbs-lst-900.
       det-pbs-lst-500.
      *                  *---------------------------------------------*
      *                  * Test max su storico listini                 *
      *                  *---------------------------------------------*
           if        rf-lsd-tip-rec       not  = w-det-pbs-tip-rec or
                     rf-lsd-cod-lst       not  = w-det-pbs-cod-lst or
                     rf-lsd-cod-cli       not  = w-det-pbs-cod-cli or
                     rf-lsd-sgl-vlt       not  = w-det-pbs-sgl-vlt or
                     rf-lsd-num-pro       not  = w-det-pbs-num-pro
                     go to det-pbs-lst-900.
       det-pbs-lst-550.
      *                  *---------------------------------------------*
      *                  * Se sigla valuta a spaces si ignora l'ele-   *
      *                  * mento                                       *
      *                  *---------------------------------------------*
           if        rf-lsd-sgl-vlt       =    spaces
                     go to det-pbs-lst-450.
      *                  *---------------------------------------------*
      *                  * Se si tratta del primo elemento trovato ed  *
      *                  * il prezzo e' pari a quello del listino ba-  *
      *                  * se lo si ignora, a meno che la sua data di  *
      *                  * validita' finale non sia superiore alla da- *
      *                  * ta di sistema attuale                       *
      *                  *---------------------------------------------*
           if        w-det-pbs-sto-num    >    zero
                     go to det-pbs-lst-600.
           if        w-det-pbs-bas-flg    =    "N"
                     go to det-pbs-lst-600.
           if        w-det-pbs-bas-vlt    =    spaces
                     go to det-pbs-lst-600.
           if        w-det-pbs-bas-vlt    not  = rf-lsd-sgl-vlt
                     go to det-pbs-lst-600.
           if        w-det-pbs-bas-dcv    not  = rf-lsd-dec-vlt
                     go to det-pbs-lst-600.
           if        w-det-pbs-bas-prz    not  = rf-lsd-prz-lst
                     go to det-pbs-lst-600.
           if        w-det-pbs-dat-sys    <    rf-lsd-dva-fin
                     go to det-pbs-lst-600.
           go to     det-pbs-lst-450.
       det-pbs-lst-600.
      *                  *---------------------------------------------*
      *                  * Incremento numero prezzi storici trovati    *
      *                  *---------------------------------------------*
           add       1                    to   w-det-pbs-sto-num      .
       det-pbs-lst-650.
      *                  *---------------------------------------------*
      *                  * Memorizzazione prezzo storico trovato       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Sigla valuta                            *
      *                      *-----------------------------------------*
           move      rf-lsd-sgl-vlt       to   w-det-pbs-sto-vlt
                                              (w-det-pbs-sto-num)     .
      *                      *-----------------------------------------*
      *                      * Decimali valuta                         *
      *                      *-----------------------------------------*
           move      rf-lsd-dec-vlt       to   w-det-pbs-sto-dcv
                                              (w-det-pbs-sto-num)     .
      *                      *-----------------------------------------*
      *                      * Prezzo                                  *
      *                      *-----------------------------------------*
           move      rf-lsd-prz-lst       to   w-det-pbs-sto-prz
                                              (w-det-pbs-sto-num)     .
      *                      *-----------------------------------------*
      *                      * Data di validita' finale                *
      *                      *-----------------------------------------*
           move      rf-lsd-dva-fin       to   w-det-pbs-sto-dvf
                                              (w-det-pbs-sto-num)     .
       det-pbs-lst-700.
      *                  *---------------------------------------------*
      *                  * Se raggiunto il max numero di prezzi stori- *
      *                  * ci da ricercare si esce, altrimenti si ri-  *
      *                  * cerca il prezzo storico successivo          *
      *                  *---------------------------------------------*
           if        w-det-pbs-sto-num    =    w-det-pbs-max-sto
                     go to det-pbs-lst-900
           else      go to det-pbs-lst-450.
       det-pbs-lst-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-pbs-lst-999.
       det-pbs-lst-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [cli]                         *
      *    *-----------------------------------------------------------*
       let-arc-cli-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-cli-flg      .
