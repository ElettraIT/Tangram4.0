      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to let-arc-pdx-800.
       let-arc-pdx-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [pdx]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
      *                  *---------------------------------------------*
      *                  * Test se 'at end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to let-arc-pdx-800.
       let-arc-pdx-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-pdx-tip-rec       not  = w-let-arc-pdx-rec or
                     rf-pdx-cod-arc       not  = w-let-arc-pdx-arc or
                     rf-pdx-cod-lng       not  = w-let-arc-pdx-lng or
                     rf-pdx-cod-num       not  = w-let-arc-pdx-pro or
                     rf-pdx-for-mat       not  = w-let-arc-pdx-fmt
                     go to let-arc-pdx-800.
       let-arc-pdx-400.
      *              *-------------------------------------------------*
      *              * Test su contenuto descrizione                   *
      *              *-------------------------------------------------*
           if        rf-pdx-des-pro       =    spaces
                     go to let-arc-pdx-200.
       let-arc-pdx-500.
      *              *-------------------------------------------------*
      *              * Incremento contatore                            *
      *              *-------------------------------------------------*
           add       1                    to   w-let-arc-pdx-ctr      .
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-pdx-des-pro       to   w-let-arc-pdx-rig
                                              (w-let-arc-pdx-ctr)     .
       let-arc-pdx-600.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura                              *
      *              *-------------------------------------------------*
           go to     let-arc-pdx-200.
       let-arc-pdx-800.
      *              *-------------------------------------------------*
      *              * Test su contatore elementi letti                *
      *              *-------------------------------------------------*
           if        w-let-arc-pdx-ctr    =    zero
                     go to let-arc-pdx-820
           else      go to let-arc-pdx-900.
       let-arc-pdx-820.
      *                  *---------------------------------------------*
      *                  * Se nessun elemento rilevato                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di nessun elemento rilevato        *
      *                      *-----------------------------------------*
           move      "#"                  to   w-let-arc-pdx-flg      .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     let-arc-pdx-900.
       let-arc-pdx-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-pdx-999.
       let-arc-pdx-999.
           exit.

      *    *===========================================================*
      *    * Stampa prezzo                                             *
      *    *-----------------------------------------------------------*
       stp-sta-prz-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
           move      spaces               to   w-stp-sta-prz-lit      .
      *              *-------------------------------------------------*
      *              * Test su valore in input                         *
      *              *-------------------------------------------------*
           if        w-stp-sta-prz-prz    =    zero
                     go to  stp-sta-prz-900.
       stp-sta-prz-100.
      *              *-------------------------------------------------*
      *              * Editing                                         *
      *              *-------------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           move      09                   to   p-car                  .
           move      w-stp-sta-prz-dec    to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "BG"                 to   p-edm                  .
           move      w-stp-sta-prz-prz    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-sta-prz-200.
      *              *-------------------------------------------------*
      *              * Allineamento a sinistra valore editato          *
      *              *-------------------------------------------------*
           move      14                   to   w-all-str-lun          .
           move      p-edt                to   w-all-str-alf          .
           perform   all-str-asx-000      thru all-str-asx-999        .
      *              *-------------------------------------------------*
      *              * Scomposizione del valore in interi e decimali   *
      *              *-------------------------------------------------*
           move      w-all-str-alf        to   w-all-str-alf          .
           move      ","                  to   w-all-str-del          .
           perform   all-str-ext-000      thru all-str-ext-999        .
           move      w-all-str-cat (1)    to   w-stp-sta-prz-int      .
           move      w-all-str-cat (2)    to   w-stp-sta-prz-dcm      .
           move      ","                  to   w-stp-sta-prz-vir      .
       stp-sta-prz-300.
      *              *-------------------------------------------------*
      *              * Allineamento a destra interi                    *
      *              *-------------------------------------------------*
           move      08                   to   w-all-str-lun          .
           move      w-stp-sta-prz-int    to   w-all-str-alf          .
           perform   all-str-adx-000      thru all-str-adx-999        .
           move      w-all-str-alf        to   w-stp-sta-prz-int      .
      *              *-------------------------------------------------*
      *              * Allineamento a sinistra decimali                *
      *              *-------------------------------------------------*
           move      05                   to   w-all-str-lun          .
           move      w-stp-sta-prz-dcm    to   w-all-str-alf          .
           perform   all-str-asx-000      thru all-str-asx-999        .
           move      w-all-str-alf        to   w-stp-sta-prz-dcm      .
       stp-sta-prz-500.
      *              *-------------------------------------------------*
      *              * Stampa prezzo                                   *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      14                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-stp-sta-prz-pos    to   p-pos                  .
           move      w-stp-sta-prz-lit    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-sta-prz-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-sta-prz-999.
       stp-sta-prz-999.
           exit.

