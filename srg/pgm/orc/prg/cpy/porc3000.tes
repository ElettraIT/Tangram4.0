      *    *===========================================================*
      *    * Visualizzazione prompt : Codice archivio                  *
      *    *-----------------------------------------------------------*
       pmt-cod-arc-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo archivio        *
      *              *-------------------------------------------------*
           if        w-tes-tip-arc (1)    =    "C"
                     go to pmt-cod-arc-100
           else if   w-tes-tip-arc (1)    =    "D"
                     go to pmt-cod-arc-200
           else      go to pmt-cod-arc-100.
       pmt-cod-arc-100.
      *              *-------------------------------------------------*
      *              * Cliente                                         *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      25                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Cliente commerciale     :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           go to     pmt-cod-arc-999.
       pmt-cod-arc-200.
      *              *-------------------------------------------------*
      *              * Dipendenza                                      *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      25                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Ns. dipendenza          :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           go to     pmt-cod-arc-999.
       pmt-cod-arc-999.
           exit.

