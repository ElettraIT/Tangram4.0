      *    *===========================================================*
      *    * Determinazione numero pagine che compongono la testata    *
      *    *-----------------------------------------------------------*
       dmp-tes-reg-000.
      *              *-------------------------------------------------*
      *              * La testata e' composta di nr. 6 pagine          *
      *              *-------------------------------------------------*
           move      6                    to   w-cnt-sts-imp-mpt      .
       dmp-tes-reg-999.
           exit.

      *    *===========================================================*
      *    * Determinazione si/no pagina w-cnt-sts-imp-npt da trattare *
      *    *-----------------------------------------------------------*
       snp-tes-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-sts-imp-snp      .
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del numero pagina        *
      *              *-------------------------------------------------*
           go to     snp-tes-reg-100
                     snp-tes-reg-200
                     snp-tes-reg-300
                     snp-tes-reg-400
                     snp-tes-reg-500
                     snp-tes-reg-600
                     depending            on   w-cnt-sts-imp-npt      .
           go to     snp-tes-reg-999.
       snp-tes-reg-100.
      *              *-------------------------------------------------*
      *              * Pagina 1 : sempre accettata                     *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-sts-imp-snp      .
           go to     snp-tes-reg-999.
       snp-tes-reg-200.
      *              *-------------------------------------------------*
      *              * Pagina 2                                        *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-sts-imp-snp      .
      *                  *---------------------------------------------*
      *                  * Test su tipo archivio                       *
      *                  *---------------------------------------------*
           if        w-tes-tip-arc (1)    =    "D"
                     move  "#"            to   w-cnt-sts-imp-snp
                     go to snp-tes-reg-999.
      *                  *---------------------------------------------*
      *                  * Test se personalizzazione lo prevede        *
      *                  *---------------------------------------------*
           if        w-prs-ges-apf        not  = 11 and
                     w-prs-ges-apf        not  = 21 and
                     w-prs-ges-apf        not  = 99
                     move  "#"            to   w-cnt-sts-imp-snp
                     go to snp-tes-reg-999.
      *                  *---------------------------------------------*
      *                  * Test su tipo fornitura                      *
      *                  *---------------------------------------------*
           if        w-tes-tip-frn (1)    =    01
                     move  "#"            to   w-cnt-sts-imp-snp
                     go to snp-tes-reg-999.
           go to     snp-tes-reg-999.
       snp-tes-reg-300.
      *              *-------------------------------------------------*
      *              * Pagina 3 : sempre accettata                     *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-sts-imp-snp      .
           go to     snp-tes-reg-999.
       snp-tes-reg-400.
      *              *-------------------------------------------------*
      *              * Pagina 4                                        *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-sts-imp-snp      .
      *                  *---------------------------------------------*
      *                  * Test su tipo archivio                       *
      *                  *---------------------------------------------*
           if        w-tes-tip-arc (1)    =    "D"
                     move  "#"            to   w-cnt-sts-imp-snp
                     go to snp-tes-reg-999.
           go to     snp-tes-reg-999.
       snp-tes-reg-500.
      *              *-------------------------------------------------*
      *              * Pagina 5                                        *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-sts-imp-snp      .
      *                  *---------------------------------------------*
      *                  * Test su tipo archivio                       *
      *                  *---------------------------------------------*
           if        w-tes-tip-arc (1)    =    "D"
                     move  "#"            to   w-cnt-sts-imp-snp
                     go to snp-tes-reg-999.
           go to     snp-tes-reg-999.
       snp-tes-reg-600.
      *              *-------------------------------------------------*
      *              * Pagina 6                                        *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-sts-imp-snp      .
      *                  *---------------------------------------------*
      *                  * Test su tipo archivio                       *
      *                  *---------------------------------------------*
           if        w-tes-tip-arc (1)    =    "D"
                     move  "#"            to   w-cnt-sts-imp-snp
                     go to snp-tes-reg-999.
           go to     snp-tes-reg-999.
       snp-tes-reg-999.
           exit.

      *    *===========================================================*
      *    * Accettazione testata registrazione                        *
      *    *-----------------------------------------------------------*
       acc-tes-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione tipo uscita                     *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-tes      .
      *              *-------------------------------------------------*
      *              * Normalizzazione function-key                    *
      *              *-------------------------------------------------*
           move      spaces               to   v-key                  .
      *              *-------------------------------------------------*
      *              * Tipo impostazione : testata                     *
      *              *-------------------------------------------------*
           move      "T"                  to   w-cnt-mfu-tip-imp      .
      *              *-------------------------------------------------*
      *              * Accettazioni                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del numero pagina    *
      *                  *---------------------------------------------*
           go to     acc-tes-reg-100
                     acc-tes-reg-200
                     acc-tes-reg-300
                     acc-tes-reg-400
                     acc-tes-reg-500
                     acc-tes-reg-600
                     depending            on   w-cnt-sts-imp-npt      .
           go to     acc-tes-reg-999.
       acc-tes-reg-100.
      *                  *---------------------------------------------*
      *                  * Normalizzazione func-key di impostazione    *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Tipo archivio                               *
      *                  *---------------------------------------------*
           perform   acc-tip-arc-000      thru acc-tip-arc-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
       acc-tes-reg-103.
      *                  *---------------------------------------------*
      *                  * Se in modifica, si passa ad accettare il    *
      *                  * codice dipendenza dell'archivio             *
      *                  *---------------------------------------------*
           if        w-tes-fda-pt1 (1)    not  = spaces
                     go to acc-tes-reg-110.
       acc-tes-reg-105.
      *                  *---------------------------------------------*
      *                  * Codice archivio                             *
      *                  *---------------------------------------------*
           perform   acc-cod-arc-000      thru acc-cod-arc-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
       acc-tes-reg-110.
      *                  *---------------------------------------------*
      *                  * Codice dipendenza cliente                   *
      *                  *---------------------------------------------*
           perform   acc-dpz-cli-000      thru acc-dpz-cli-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     move  spaces         to   v-key
                     go to acc-tes-reg-105.
       acc-tes-reg-120.
      *                  *---------------------------------------------*
      *                  * Tipo indirizzo di spedizione                *
      *                  *---------------------------------------------*
           perform   acc-tip-ids-000      thru acc-tip-ids-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-110.
       acc-tes-reg-130.
      *                  *---------------------------------------------*
      *                  * Ragione sociale per spedizione - 1          *
      *                  *---------------------------------------------*
           perform   acc-rag-ids-000      thru acc-rag-ids-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-120.
       acc-tes-reg-135.
      *                  *---------------------------------------------*
      *                  * Ragione sociale per spedizione - 2          *
      *                  *---------------------------------------------*
           perform   acc-rs2-ids-000      thru acc-rs2-ids-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-130.
       acc-tes-reg-140.
      *                  *---------------------------------------------*
      *                  * Indirizzo per spedizione                    *
      *                  *---------------------------------------------*
           perform   acc-via-ids-000      thru acc-via-ids-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-135.
       acc-tes-reg-150.
      *                  *---------------------------------------------*
      *                  * Localita' per spedizione                    *
      *                  *---------------------------------------------*
           perform   acc-loc-ids-000      thru acc-loc-ids-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-140.
       acc-tes-reg-160.
      *                  *---------------------------------------------*
      *                  * Tipo fornitura                              *
      *                  *---------------------------------------------*
           perform   acc-tip-frn-000      thru acc-tip-frn-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-150.
       acc-tes-reg-165.
      *                  *---------------------------------------------*
      *                  * Si/no ordine da verificare                  *
      *                  *---------------------------------------------*
           perform   acc-snx-oav-000      thru acc-snx-oav-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-160.
      *                  *---------------------------------------------*
      *                  * Se Next Screen o Tab in corso               *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-tes-reg-190.
      *                  *---------------------------------------------*
      *                  * Presa visione per pagina 1                  *
      *                  *---------------------------------------------*
           perform   acc-pre-vpg-000      thru acc-pre-vpg-999        .
           if        v-key                =    "NXSC"
                     go to acc-tes-reg-190
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-165.
       acc-tes-reg-190.
      *                  *---------------------------------------------*
      *                  * Flag di accettazione pagina testata 1       *
      *                  *---------------------------------------------*
           move      "#"                  to   w-tes-fda-pt1 (1)      .
      *                  *---------------------------------------------*
      *                  * Trattamento archivio per fatturazione       *
      *                  *---------------------------------------------*
           perform   trt-arc-plf-000      thru trt-arc-plf-999        .
      *                  *---------------------------------------------*
      *                  * Fine Pagina                                 *
      *                  *---------------------------------------------*
           move      "+"                  to   w-cnt-tus-acc-tes      .
           go to     acc-tes-reg-999.
       acc-tes-reg-200.
      *                  *---------------------------------------------*
      *                  * Codice archivio per fatturazione            *
      *                  *---------------------------------------------*
           perform   acc-arc-plf-000      thru acc-arc-plf-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     move  "-"            to   w-cnt-tus-acc-tes
                     go to acc-tes-reg-999.
       acc-tes-reg-210.
      *                  *---------------------------------------------*
      *                  * Dipendenza archivio per fatturazione        *
      *                  *---------------------------------------------*
           perform   acc-dpz-plf-000      thru acc-dpz-plf-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-200.
       acc-tes-reg-220.
      *                  *---------------------------------------------*
      *                  * Tipo fatturazione                           *
      *                  *---------------------------------------------*
           perform   acc-tip-ftz-000      thru acc-tip-ftz-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-210.
      *                  *---------------------------------------------*
      *                  * Se Next Screen o Tab in corso               *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-tes-reg-290.
      *                  *---------------------------------------------*
      *                  * Presa visione per pagina 2                  *
      *                  *---------------------------------------------*
           perform   acc-pre-vpg-000      thru acc-pre-vpg-999        .
           if        v-key                =    "NXSC"
                     go to acc-tes-reg-290
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-210.
       acc-tes-reg-290.
      *                  *---------------------------------------------*
      *                  * Flag di accettazione pagina testata 2       *
      *                  *---------------------------------------------*
           move      "#"                  to   w-tes-fda-pt2 (1)      .
      *                  *---------------------------------------------*
      *                  * Fine Pagina                                 *
      *                  *---------------------------------------------*
           move      "+"                  to   w-cnt-tus-acc-tes      .
           go to     acc-tes-reg-999.
       acc-tes-reg-300.
      *                  *---------------------------------------------*
      *                  * Data ordine cliente                         *
      *                  *---------------------------------------------*
           perform   acc-ocl-dat-000      thru acc-ocl-dat-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     move  "-"            to   w-cnt-tus-acc-tes
                     go to acc-tes-reg-999.
       acc-tes-reg-305.
      *                  *---------------------------------------------*
      *                  * Numero ordine cliente                       *
      *                  *---------------------------------------------*
           perform   acc-ocl-num-000      thru acc-ocl-num-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-300.
       acc-tes-reg-310.
      *                  *---------------------------------------------*
      *                  * Riferimenti ordine cliente                  *
      *                  *---------------------------------------------*
           perform   acc-ocl-rif-000      thru acc-ocl-rif-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-305.
       acc-tes-reg-312.
      *                  *---------------------------------------------*
      *                  * Codice responsabile ordine                  *
      *                  *---------------------------------------------*
           perform   acc-cod-rsp-000      thru acc-cod-rsp-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-310.
       acc-tes-reg-315.
      *                  *---------------------------------------------*
      *                  * Data consegna prevista                      *
      *                  *---------------------------------------------*
           perform   acc-dat-cns-000      thru acc-dat-cns-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-312.
       acc-tes-reg-320.
      *                  *---------------------------------------------*
      *                  * Formato stampa data consegna                *
      *                  *---------------------------------------------*
           perform   acc-fds-dtc-000      thru acc-fds-dtc-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-315.
       acc-tes-reg-321.
      *                  *---------------------------------------------*
      *                  * Si/no stampa prezzi e sconti                *
      *                  *---------------------------------------------*
           perform   acc-snx-sps-000      thru acc-snx-sps-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-320.
       acc-tes-reg-323.
      *                  *---------------------------------------------*
      *                  * Codice primo vettore                        *
      *                  *---------------------------------------------*
           perform   acc-cod-vet-000      thru acc-cod-vet-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-321.
       acc-tes-reg-325.
      *                  *---------------------------------------------*
      *                  * Tipo evasione richiesta                     *
      *                  *---------------------------------------------*
           perform   acc-tip-eva-000      thru acc-tip-eva-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-323.
       acc-tes-reg-330.
      *                  *---------------------------------------------*
      *                  * Priorita' di evasione                       *
      *                  *---------------------------------------------*
           perform   acc-pri-eva-000      thru acc-pri-eva-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-325.
       acc-tes-reg-335.
      *                  *---------------------------------------------*
      *                  * Codice condizioni di vendita                *
      *                  *---------------------------------------------*
           perform   acc-cod-cdv-000      thru acc-cod-cdv-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-330.
       acc-tes-reg-340.
      *                  *---------------------------------------------*
      *                  * Descrizione condizioni di vendita           *
      *                  *---------------------------------------------*
           perform   acc-des-cdv-000      thru acc-des-cdv-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-335.
       acc-tes-reg-345.
      *                  *---------------------------------------------*
      *                  * Commento ad uso interno                     *
      *                  *---------------------------------------------*
           perform   acc-com-int-000      thru acc-com-int-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-340.
      *                  *---------------------------------------------*
      *                  * Se Next Screen o Tab in corso               *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     move  "+"            to   w-cnt-tus-acc-tes
                     go to acc-tes-reg-999.
      *                  *---------------------------------------------*
      *                  * Presa visione per pagina 3                  *
      *                  *---------------------------------------------*
           perform   acc-pre-vpg-000      thru acc-pre-vpg-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-tes      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-345.
      *                  *---------------------------------------------*
      *                  * Fine Pagina                                 *
      *                  *---------------------------------------------*
           move      "+"                  to   w-cnt-tus-acc-tes      .
           go to     acc-tes-reg-999.
       acc-tes-reg-400.
      *                  *---------------------------------------------*
      *                  * Inoltro documenti                           *
      *                  *---------------------------------------------*
           perform   acc-inl-dcm-000      thru acc-inl-dcm-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     move  "-"            to   w-cnt-tus-acc-tes
                     go to acc-tes-reg-999.
       acc-tes-reg-410.
      *                  *---------------------------------------------*
      *                  * Inoltro pagamenti                           *
      *                  *---------------------------------------------*
           perform   acc-inl-pgt-000      thru acc-inl-pgt-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-400.
       acc-tes-reg-415.
      *                  *---------------------------------------------*
      *                  * Sigla valuta per fatturazione               *
      *                  *---------------------------------------------*
           perform   acc-sgl-vpf-000      thru acc-sgl-vpf-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-410.
       acc-tes-reg-420.
      *                  *---------------------------------------------*
      *                  * Assoggettamento iva                         *
      *                  *---------------------------------------------*
           perform   acc-ass-iva-000      thru acc-ass-iva-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-415.
       acc-tes-reg-430.
      *                  *---------------------------------------------*
      *                  * Contropartita vendite                       *
      *                  *---------------------------------------------*
           perform   acc-ctp-ven-000      thru acc-ctp-ven-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-420.
       acc-tes-reg-440.
      *                  *---------------------------------------------*
      *                  * Fatturazione separata per il documento      *
      *                  *---------------------------------------------*
           perform   acc-fat-sep-000      thru acc-fat-sep-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-430.
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore per tabella vo-  *
      *                  * ci descrittive                              *
      *                  *---------------------------------------------*
           move      1                    to   w-acc-voc-des-ctr      .
           move      "D"                  to   w-acc-voc-des-dir      .
       acc-tes-reg-450.
      *                  *---------------------------------------------*
      *                  * Voci descrittive                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Accettazione                            *
      *                      *-----------------------------------------*
           perform   acc-voc-des-000      thru acc-voc-des-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
      *                      *-----------------------------------------*
      *                      * Test se Up                              *
      *                      *-----------------------------------------*
           if        v-key                not  = "UP  "
                     go to acc-tes-reg-454.
       acc-tes-reg-452.
      *                      *-----------------------------------------*
      *                      * Se Up                                   *
      *                      *-----------------------------------------*
           move      "U"                  to   w-acc-voc-des-dir      .
           subtract  1                    from w-acc-voc-des-ctr      .
           if        w-acc-voc-des-ctr    =    zero
                     go to acc-tes-reg-430
           else      go to acc-tes-reg-450.
       acc-tes-reg-454.
      *                      *-----------------------------------------*
      *                      * Se Down o Return                        *
      *                      *-----------------------------------------*
           move      "D"                  to   w-acc-voc-des-dir      .
           add       1                    to   w-acc-voc-des-ctr      .
           if        w-acc-voc-des-ctr    >    w-prs-vde-fat-nvt
                     go to acc-tes-reg-490
           else      go to acc-tes-reg-450.
       acc-tes-reg-490.
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore per tabella vo-  *
      *                  * ci descrittive                              *
      *                  *---------------------------------------------*
           move      w-prs-vde-fat-nvt    to   w-acc-voc-des-ctr      .
           move      "U"                  to   w-acc-voc-des-dir      .
      *                  *---------------------------------------------*
      *                  * Se Next Screen o Tab in corso               *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     move  "+"            to   w-cnt-tus-acc-tes
                     go to acc-tes-reg-999.
      *                  *---------------------------------------------*
      *                  * Presa visione per pagina 4                  *
      *                  *---------------------------------------------*
           perform   acc-pre-vpg-000      thru acc-pre-vpg-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-tes      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-450.
      *                  *---------------------------------------------*
      *                  * Fine Pagina                                 *
      *                  *---------------------------------------------*
           move      "+"                  to   w-cnt-tus-acc-tes      .
           go to     acc-tes-reg-999.
       acc-tes-reg-500.
      *                  *---------------------------------------------*
      *                  * Codice listino                              *
      *                  *---------------------------------------------*
           perform   acc-cod-lst-000      thru acc-cod-lst-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     move  "-"            to   w-cnt-tus-acc-tes
                     go to acc-tes-reg-999.
       acc-tes-reg-505.
      *                  *---------------------------------------------*
      *                  * Codice lingua                               *
      *                  *---------------------------------------------*
           perform   acc-cod-lng-000      thru acc-cod-lng-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-500.
       acc-tes-reg-510.
      *                  *---------------------------------------------*
      *                  * Categoria sconto in riga                    *
      *                  *---------------------------------------------*
           perform   acc-csr-aac-000      thru acc-csr-aac-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-505.
       acc-tes-reg-520.
      *                  *---------------------------------------------*
      *                  * Categoria sconto in chiusura                *
      *                  *---------------------------------------------*
           perform   acc-csc-aac-000      thru acc-csc-aac-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-510.
       acc-tes-reg-530.
      *                  *---------------------------------------------*
      *                  * Codice agente                               *
      *                  *---------------------------------------------*
           perform   acc-cod-age-000      thru acc-cod-age-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-520.
       acc-tes-reg-540.
      *                  *---------------------------------------------*
      *                  * Flag di significativita' provvigioni per il *
      *                  * documento                                   *
      *                  *---------------------------------------------*
           perform   acc-fsp-doc-000      thru acc-fsp-doc-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-530.
       acc-tes-reg-550.
      *                  *---------------------------------------------*
      *                  * Tipo vendita per l'agente                   *
      *                  *---------------------------------------------*
           perform   acc-tip-vpa-000      thru acc-tip-vpa-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-540.
       acc-tes-reg-560.
      *                  *---------------------------------------------*
      *                  * Importo provvigione per l'agente            *
      *                  *---------------------------------------------*
           perform   acc-pvf-age-000      thru acc-pvf-age-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-550.
      *                  *---------------------------------------------*
      *                  * Se Next Screen o Tab in corso               *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     move  "+"            to   w-cnt-tus-acc-tes
                     go to acc-tes-reg-999.
      *                  *---------------------------------------------*
      *                  * Presa visione per pagina 5                  *
      *                  *---------------------------------------------*
           perform   acc-pre-vpg-000      thru acc-pre-vpg-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-tes      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-560.
      *                  *---------------------------------------------*
      *                  * Fine Pagina                                 *
      *                  *---------------------------------------------*
           move      "+"                  to   w-cnt-tus-acc-tes      .
           go to     acc-tes-reg-999.
       acc-tes-reg-600.
