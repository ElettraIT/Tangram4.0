      *              *-------------------------------------------------*
           move      zero                 to   w-pmt-voc-des-ctr      .
       pmt-voc-des-100.
           add       1                    to   w-pmt-voc-des-ctr      .
           if        w-pmt-voc-des-ctr    >    w-prs-vde-fat-nvt
                     go to pmt-voc-des-999.
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      25                   to   v-car                  .
           add       15
                     w-pmt-voc-des-ctr  giving v-lin                  .
           move      01                   to   v-pos                  .
           move      w-prs-vde-fat-dve
                    (w-pmt-voc-des-ctr)   to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           add       15
                     w-pmt-voc-des-ctr  giving v-lin                  .
           move      28                   to   v-pos                  .
           move      ":"                  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     pmt-voc-des-100.
       pmt-voc-des-999.
           exit.

