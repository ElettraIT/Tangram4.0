      *                  *---------------------------------------------*
           perform   acc-pag-dsm-000      thru acc-pag-dsm-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-635.
       acc-tes-reg-645.
      *                  *---------------------------------------------*
      *                  * Ammontare quota a forfait pagamento         *
      *                  *---------------------------------------------*
           perform   acc-pag-qaf-000      thru acc-pag-qaf-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-640.
       acc-tes-reg-650.
      *                  *---------------------------------------------*
      *                  * Ammontare acconto                           *
      *                  *---------------------------------------------*
           perform   acc-pag-act-000      thru acc-pag-act-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-645.
      *                  *---------------------------------------------*
      *                  * Se Next Screen o Tab in corso               *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     move  "+"            to   w-cnt-tus-acc-tes
                     go to acc-tes-reg-999.
      *                  *---------------------------------------------*
      *                  * Presa visione per pagina 6                  *
      *                  *---------------------------------------------*
           perform   acc-pre-vpg-000      thru acc-pre-vpg-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-tes      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-650.
      *                  *---------------------------------------------*
      *                  * Fine Pagina                                 *
      *                  *---------------------------------------------*
           move      "+"                  to   w-cnt-tus-acc-tes      .
           go to     acc-tes-reg-999.
       acc-tes-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione testata registrazione                     *
