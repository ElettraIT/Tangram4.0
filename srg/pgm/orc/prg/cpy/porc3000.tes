      *    * Visualizzazione prompt : Codice dipendenza cliente        *
      *    *-----------------------------------------------------------*
       pmt-dpz-cli-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      25                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Sua dipendenza          :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       pmt-dpz-cli-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompt : Tipo indirizzo di spedizione     *
      *    *-----------------------------------------------------------*
       pmt-tip-ids-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      25                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Indirizzo di spedizione :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       pmt-tip-ids-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompt : Tipo fornitura                   *
      *    *-----------------------------------------------------------*
       pmt-tip-frn-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-tes-tip-arc (1)    =    "D"
                     go to pmt-tip-frn-999.
           if        w-prs-ges-apf        not  = 11 and
                     w-prs-ges-apf        not  = 21 and
                     w-prs-ges-apf        not  = 99
                     go to pmt-tip-frn-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      25                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Tipo fornitura          :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       pmt-tip-frn-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompt : Si/no ordine da verificare       *
      *    *-----------------------------------------------------------*
       pmt-snx-oav-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-prs-snx-oav-snx    =    "N"
                     go to pmt-snx-oav-999.
       pmt-snx-oav-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      25                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Verifica ordine         :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       pmt-snx-oav-999.
           exit.

