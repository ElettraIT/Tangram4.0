      *    *===========================================================*
      *    * Accettazione campo testata : Presa visione per pagina     *
      *    *-----------------------------------------------------------*
       acc-pre-vpg-000.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      spaces               to   v-msk                  .
           move      spaces               to   v-alf                  .
           move      spaces               to   v-not                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vpg-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vpg-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pre-vpg-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pre-vpg-000.
       acc-pre-vpg-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Tipo archivio                *
      *    *-----------------------------------------------------------*
       acc-tip-arc-000.
      *              *-------------------------------------------------*
      *              * Forzatura del default letto dal tipo movimento  *
      *              * ed eventuale normalizzazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Forzatura                                   *
      *                  *---------------------------------------------*
           move      w-tes-tmo-orc-tar    to   w-tes-tip-arc (1)      .
      *                  *---------------------------------------------*
      *                  * Eventuale normalizzazione                   *
      *                  *---------------------------------------------*
           if        w-tes-tip-arc (1)    =    spaces
                     move  "C"            to   w-tes-tip-arc (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione propmt tipo archivio        *
      *                  *---------------------------------------------*
           perform   pmt-cod-arc-000      thru pmt-cod-arc-999        .
       acc-tip-arc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice archivio              *
      *    *-----------------------------------------------------------*
       acc-cod-arc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-cod-arc-100.
      *              *-------------------------------------------------*
      *              * Accettazione                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo archivio    *
      *                  *---------------------------------------------*
           if        w-tes-tip-arc (1)    =    "C"
                     perform acc-cod-cli-000
                                          thru acc-cod-cli-999
           else if   w-tes-tip-arc (1)    =    "D"
                     perform acc-cod-dpz-000
                                          thru acc-cod-dpz-999
           else      perform acc-cod-cli-000
                                          thru acc-cod-cli-999        .
       acc-cod-arc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-arc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice archivio           *
      *    *-----------------------------------------------------------*
       vis-cod-arc-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      08                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      "<B"                 to   v-edm                  .
           move      w-tes-cod-arc (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-arc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione archivio      *
      *    *-----------------------------------------------------------*
       vis-cod-arc-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-arc-rag (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-arc-via (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-arc-loc (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-arc-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice archivio              *
      *    *-----------------------------------------------------------*
       acc-cod-cli-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-sav-cod-cli          .
       acc-cod-cli-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-dcc-ope      .
           move      w-tes-cod-arc (1)    to   w-cod-mne-dcc-cod      .
           move      08                   to   w-cod-mne-dcc-lin      .
           move      27                   to   w-cod-mne-dcc-pos      .
           move      08                   to   w-cod-mne-dcc-rln      .
           move      41                   to   w-cod-mne-dcc-rps      .
           move      09                   to   w-cod-mne-dcc-vln      .
           move      41                   to   w-cod-mne-dcc-vps      .
           move      10                   to   w-cod-mne-dcc-lln      .
           move      41                   to   w-cod-mne-dcc-lps      .
           move      "<B"                 to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "EXPD"               to   v-pfk (13)             .
           move      "[2] "               to   v-pfk (15)             .
           perform   cod-mne-dcc-cll-000  thru cod-mne-dcc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-dcc-foi-000  thru cod-mne-dcc-foi-999    .
       acc-cod-cli-110.
           perform   cod-mne-dcc-cll-000  thru cod-mne-dcc-cll-999    .
           if        w-cod-mne-dcc-ope    =    "F+"
                     go to acc-cod-cli-115.
           if        w-cod-mne-dcc-ope    =    "AC"
                     go to acc-cod-cli-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-cli-115.
           perform   cod-mne-dcc-foi-000  thru cod-mne-dcc-foi-999    .
           go to     acc-cod-cli-110.
       acc-cod-cli-120.
           move      w-cod-mne-dcc-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cli-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cli-999.
       acc-cod-cli-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-arc (1)      .
       acc-cod-cli-300.
      *              *-------------------------------------------------*
      *              * Se Expd                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        v-key                not  = "EXPD"
                     go to acc-cod-cli-400.
           if        w-tes-cod-arc (1)    =    zero
                     go to acc-cod-cli-400.
      *                  *---------------------------------------------*
      *                  * Box di espansione                           *
      *                  *---------------------------------------------*
           perform   rou-exp-cec-000      thru rou-exp-cec-999        .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-cod-cli-100.
       acc-cod-cli-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Subroutine per controlli su cliente         *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-ctl-cod-cli-cod      .
           perform   acc-cod-cli-ctl-000  thru acc-cod-cli-ctl-999    .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione cliente         *
      *                  *---------------------------------------------*
           perform   vis-cod-arc-des-000  thru vis-cod-arc-des-999    .
      *                  *---------------------------------------------*
      *                  * Controllo su flag di 'exit'                 *
      *                  *---------------------------------------------*
           if        w-ctl-cod-cli-ext    not  = spaces
                     go to acc-cod-cli-999.
      *                  *---------------------------------------------*
      *                  * Controllo su flag di errore                 *
      *                  *---------------------------------------------*
           if        w-ctl-cod-cli-flg    not  = spaces
                     go to acc-cod-cli-100.
      *                  *---------------------------------------------*
      *                  * Subroutine per note su cliente              *
      *                  *---------------------------------------------*
           perform   cod-mne-dcc-not-000  thru cod-mne-dcc-not-999    .
       acc-cod-cli-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-tes-cod-arc (1)    =    w-sav-cod-cli
                     go to acc-cod-cli-800.
      *                      *-----------------------------------------*
      *                      * Test se modificabile                    *
      *                      *-----------------------------------------*
           if        w-tes-fda-pt1 (1)    =    spaces
                     go to acc-cod-cli-610.
      *                      *-----------------------------------------*
      *                      * Box di avvertimento                     *
      *                      *-----------------------------------------*
           perform   acc-cod-cli-mod-000  thru acc-cod-cli-mod-999    .
      *                      *-----------------------------------------*
      *                      * Test su scelta                          *
      *                      *-----------------------------------------*
           if        w-exp-arc-mod-sce    =    01
                     go to acc-cod-cli-100.
       acc-cod-cli-610.
      *                      *-----------------------------------------*
      *                      * Normalizzazione e rivisualizzazione di- *
      *                      * pendenza                                *
      *                      *-----------------------------------------*
           move      spaces               to   w-tes-dpz-arc (1)      .
           move      spaces               to   w-tes-dpz-arc-rag (1)  .
           move      spaces               to   w-tes-dpz-arc-via (1)  .
           move      spaces               to   w-tes-dpz-arc-loc (1)  .
           perform   vis-dpz-cli-000      thru vis-dpz-cli-999        .
           perform   vis-dpz-cli-des-000  thru vis-dpz-cli-des-999    .
      *                      *-----------------------------------------*
      *                      * Normalizzazione dati testata associati  *
      *                      * alla dipendenza                         *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-abi-dpz (1)      .
           move      spaces               to   w-tes-abi-dpz-den (1)  .
           move      zero                 to   w-tes-cab-dpz (1)      .
           move      spaces               to   w-tes-cab-dpz-den (1)  .
           move      spaces               to   w-tes-cca-dpz (1)      .
           move      zero                 to   w-tes-age-aad (1)      .
      *                      *-----------------------------------------*
      *                      * Determinazione valori testata indotti   *
      *                      * da record [dcc] principale              *
      *                      *-----------------------------------------*
           move      "C"                  to   w-det-vlt-dcc-tdt      .
           perform   det-vlt-dcc-000      thru det-vlt-dcc-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione funzionamento spese      *
      *                      *-----------------------------------------*
           move      "C"                  to   w-det-fun-spe-tdt      .
           perform   det-fun-spe-000      thru det-fun-spe-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione valori testata dipendenti*
      *                      * dall'inoltro pagamenti                  *
      *                      *-----------------------------------------*
           move      w-tes-dpz-arc (1)    to   w-det-vlt-ipg-dpz      .
           perform   det-vlt-ipg-000      thru det-vlt-ipg-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione valori testata associati *
      *                      * all'agente                              *
      *                      *-----------------------------------------*
           move      w-tes-dpz-arc (1)    to   w-det-vlt-age-dpz      .
           perform   det-vlt-age-000      thru det-vlt-age-999        .
      *                          *-------------------------------------*
      *                          * Flag di significativita' provvigio- *
      *                          * ni                                  *
      *                          *-------------------------------------*
           if        w-tes-fsp-doc (1)    =    02  and
                     w-tes-cod-age (1)    not  =   zero
                     move  01             to   w-tes-fsp-doc (1)      .
      *                      *-----------------------------------------*
      *                      * Trattamento tipo fornitura abituale     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da trattare                 *
      *                          *-------------------------------------*
           if        w-prs-ges-apf        not  = 11 and
                     w-prs-ges-apf        not  = 21 and
                     w-prs-ges-apf        not  = 99
                     go to acc-cod-cli-620.
      *                          *-------------------------------------*
      *                          * Bufferizzazione e visualizzazione   *
      *                          *-------------------------------------*
           move      w-let-arc-dcc-tpf    to   w-tes-tip-frn (1)      .
           perform   vis-tip-frn-000      thru vis-tip-frn-999        .
       acc-cod-cli-620.
      *                      *-----------------------------------------*
      *                      * Determinazione se il cliente ha dipen-  *
      *                      * denze                                   *
      *                      *-----------------------------------------*
           move      w-tes-cod-arc (1)    to   w-det-snd-dcc-cli      .
           perform   det-snd-dcc-000      thru det-snd-dcc-999        .
           move      w-det-snd-dcc-snx    to   w-tes-cod-arc-snd (1)  .
       acc-cod-cli-640.
      *                      *-----------------------------------------*
      *                      * Trattamento indirizzo di spedizione     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Numero elementi nel pop-up di ac-   *
      *                          * cettazione : 3                      *
      *                          *-------------------------------------*
           move      03                   to   w-exp-tip-ids-num      .
      *                          *-------------------------------------*
      *                          * Se il valore e' gia' a :            *
      *                          * - 01 : Sede Legale  oppure          *
      *                          * - 02 : Manuale                      *
      *                          * oltre                               *
      *                          *-------------------------------------*
           if        w-tes-tip-ids (1)    =    01 or
                     w-tes-tip-ids (1)    =    02
                     go to acc-cod-cli-800.
      *                          *-------------------------------------*
      *                          * Tipo indirizzo di spedizione : Sede *
      *                          *-------------------------------------*
           move      03                   to   w-tes-tip-ids (1)      .
           perform   vis-tip-ids-000      thru vis-tip-ids-999        .
      *                          *-------------------------------------*
      *                          * Indirizzo di spedizione : Sede      *
      *                          *-------------------------------------*
           move      w-tes-rag-sed (1)    to   w-tes-rag-ids (1)      .
           move      spaces               to   w-tes-rs2-ids (1)      .
           move      w-tes-via-sed (1)    to   w-tes-via-ids (1)      .
           move      w-tes-loc-sed (1)    to   w-tes-loc-ids (1)      .
           perform   vis-rag-ids-000      thru vis-rag-ids-999        .
           perform   vis-rs2-ids-000      thru vis-rs2-ids-999        .
           perform   vis-via-ids-000      thru vis-via-ids-999        .
           perform   vis-loc-ids-000      thru vis-loc-ids-999        .
      *                          *-------------------------------------*
      *                          * Determinazione esposizione cliente  *
      *                          *-------------------------------------*
           perform   rou-det-cec-000      thru rou-det-cec-999        .
           if        w-det-esp-cli-olf    =    spaces
                     go to acc-cod-cli-800.
           perform   rou-exp-cec-000      thru rou-exp-cec-999        .
       acc-cod-cli-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-cli-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-cli-100.
       acc-cod-cli-999.
           exit.

      *    *===========================================================*
      *    * Determinazione esposizione cliente                        *
      *    *-----------------------------------------------------------*
       rou-det-cec-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-esp-cli-esp      .
           move      zero                 to   w-det-esp-cli-wfd      .
           move      zero                 to   w-det-esp-cli-wac      .
           move      spaces               to   w-det-esp-cli-olf      .
       rou-det-cec-100.
      *              *-------------------------------------------------*
      *              * Preparazione parametri                          *
      *              *-------------------------------------------------*
           move      "EC"                 to   d-esp-cec-tip-ope      .
           move      w-tes-cod-arc (1)    to   d-esp-cec-cod-cli      .
      *              *-------------------------------------------------*
      *              * Modulo di determinazione                        *
      *              *-------------------------------------------------*
           move      "pgm/gep/prg/obj/despcec0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-esp-cec              .
       rou-det-cec-200.
      *              *-------------------------------------------------*
      *              * Determinazione se cliente oltre Fido            *
      *              *-------------------------------------------------*
           add       w-pie-tot-net (1)    to   d-esp-cec-esp-orc      .   
           move      d-esp-cec-esp-orc    to   w-det-esp-cli-esp      .
      *
           add       d-esp-cec-esp-ods    to   w-det-esp-cli-esp      .
           add       d-esp-cec-esp-bol    to   w-det-esp-cli-esp      .
           add       d-esp-cec-esp-gep    to   w-det-esp-cli-esp      .
      *
           move      d-esp-cec-max-fid    to   w-det-esp-cli-wfd      .
           move      d-esp-cec-imp-acr    to   w-det-esp-cli-wac      .
      *
           if        w-det-esp-cli-wfd    =    zero
                     go to rou-det-cec-250.
      *
           if        c-dec                =    2
                     multiply  100        by   w-det-esp-cli-wfd
           else if   c-dec                =    1
                     multiply  10         by   w-det-esp-cli-wfd      .
       rou-det-cec-250.
           if        w-det-esp-cli-wac    =    zero
                     go to rou-det-cec-300.
      *
           if        c-dec                =    2
                     multiply  100        by   w-det-esp-cli-wac
           else if   c-dec                =    1
                     multiply  10         by   w-det-esp-cli-wac      .
       rou-det-cec-300.
      *              *-------------------------------------------------*
      *              * Test su Fido                                    *
      *              *-------------------------------------------------*
           if        w-det-esp-cli-esp    =    zero or
                     w-det-esp-cli-wfd    =    zero
                     go to rou-det-cec-400.
      *
           if        w-det-esp-cli-esp    >    w-det-esp-cli-wfd
                     move  "#"            to   w-det-esp-cli-olf      .
       rou-det-cec-400.
      *              *-------------------------------------------------*
      *              * Test su Assicurazione                           *
      *              *-------------------------------------------------*
           if        d-esp-cec-snx-acr    =    "N" or
                     d-esp-cec-snx-acr    =    spaces
                     go to rou-det-cec-900.
           if        w-det-esp-cli-esp    =    zero or
                     w-det-esp-cli-wac    =    zero
                     go to rou-det-cec-900.
      *
           if        w-det-esp-cli-esp    >    w-det-esp-cli-wac
                     move  "#"            to   w-det-esp-cli-olf      .
       rou-det-cec-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     rou-det-cec-999.
       rou-det-cec-999.
           exit.

      *    *===========================================================*
      *    * Espansione per informazioni su esposizione cliente        *
      *    *-----------------------------------------------------------*
       rou-exp-cec-000.
      *              *-------------------------------------------------*
      *              * Preparazione parametri                          *
      *              *-------------------------------------------------*
           move      "VE"                 to   d-esp-cec-tip-ope      .
           move      w-tes-cod-arc (1)    to   d-esp-cec-cod-cli      .
           move      w-pie-tot-net (1)    to   d-esp-cec-esp-coi      .   
           move      zero                 to   d-esp-cec-esp-csi      .   
           move      zero                 to   d-esp-cec-esp-cbf      .   
           move      zero                 to   d-esp-cec-esp-csp      .   
           move      zero                 to   d-esp-cec-esp-cv1      .   
           move      zero                 to   d-esp-cec-esp-cv2      .   
      *              *-------------------------------------------------*
      *              * Chiamata modulo                                 *
      *              *-------------------------------------------------*
           move      "pgm/gep/prg/obj/despcec0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-esp-cec              .
       rou-exp-cec-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     rou-exp-cec-999.
       rou-exp-cec-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice archivio              *
      *    *                                                           *
      *    * Routine di avviso per cambio codice archivio              *
      *    *-----------------------------------------------------------*
       acc-cod-cli-mod-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
       acc-cod-cli-mod-100.
      *              *-------------------------------------------------*
      *              * Box di avviso con conferma                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      07                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      74                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Messaggi nel box                            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "                       A T T E N Z I O N E        
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "La modifica del codice cliente non comporta alcuna
      -              " variazione   "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "nelle condizioni gia' presenti nell'ordine !      
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "Si desidera :"      to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Preparazione default per risposta           *
      *                  *---------------------------------------------*
           move      spaces               to   v-alf                  .
           move      zero                 to   w-exp-arc-mod-sce      .
       acc-cod-cli-mod-120.
      *                  *---------------------------------------------*
      *                  * Accettazione risposta                       *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-arc-mod-lun    to   v-car                  .
           move      w-exp-arc-mod-num    to   v-ldt                  .
           move      "AP#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      15                   to   v-lin                  .
           move      23                   to   v-pos                  .
           move      w-exp-arc-mod-tbl    to   v-txt                  .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-exp-arc-mod-sce    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Controllo risposta operatore                *
      *                  *---------------------------------------------*
           if        v-key                =    "EXIT"
                     move  01             to   v-num
                     go to acc-cod-cli-mod-800.
           if        v-num                not  = 01 and
                     v-num                not  = 02
                     go to acc-cod-cli-mod-120.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione risposta operatore          *
      *                  *---------------------------------------------*
           move      v-num                to   w-exp-arc-mod-sce      .
       acc-cod-cli-mod-800.
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-cli-mod-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-cod-cli-mod-999.
       acc-cod-cli-mod-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice archivio              *
      *    *                                                           *
      *    * Controlli                                                 *
      *    *-----------------------------------------------------------*
       acc-cod-cli-ctl-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flags di uscita                 *
      *              *-------------------------------------------------*
           move      spaces               to   w-ctl-cod-cli-flg      .
           move      spaces               to   w-ctl-cod-cli-ext      .
       acc-cod-cli-ctl-100.
      *              *-------------------------------------------------*
      *              * Lettura file [cli]                              *
      *              *-------------------------------------------------*
           move      w-ctl-cod-cli-cod    to   w-let-arc-cli-cod      .
           perform   let-arc-cli-000      thru let-arc-cli-999        .
           move      w-let-arc-cli-rag    to   w-tes-cod-arc-rag (1)  .
           move      w-let-arc-cli-via    to   w-tes-cod-arc-via (1)  .
           move      w-let-arc-cli-loc    to   w-tes-cod-arc-loc (1)  .
           move      w-let-arc-cli-piv    to   w-tes-cod-arc-piv (1)  .
           move      w-let-arc-cli-stc    to   w-tes-cod-arc-stc (1)  .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : ad uscita per con-  *
      *                  * trollo non superato senza messaggio di er-  *
      *                  * rore                                        *
      *                  *---------------------------------------------*
           if        w-let-arc-cli-flg    not  = spaces or
                     w-ctl-cod-cli-cod    =    zero
                     go to acc-cod-cli-ctl-930.
      *                  *---------------------------------------------*
      *                  * Test su codice sottoconto associato al      *
      *                  * cliente                                     *
      *                  *---------------------------------------------*
           if        w-tes-cod-arc-stc (1)
                                          not  = zero
                     go to acc-cod-cli-ctl-200.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Manca il sottoconto contabile per il cliente !    
      -              "               "    to   w-err-box-err-msg      .
      *                      *-----------------------------------------*
      *                      * Ad uscita per controllo non superato    *
      *                      * con emissione messaggio di errore       *
      *                      *-----------------------------------------*
           go to     acc-cod-cli-ctl-920.
       acc-cod-cli-ctl-200.
      *                  *---------------------------------------------*
      *                  * Lettura record [dcc] principale             *
      *                  *---------------------------------------------*
           move      w-ctl-cod-cli-cod    to   w-let-arc-dcc-cli      .
           move      spaces               to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                  *---------------------------------------------*
      *                  * Se lettura OK : oltre                       *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-flg    =    spaces
                     go to acc-cod-cli-ctl-300.
      *                      *-----------------------------------------*
      *                      * Altrimenti : messaggio di errore        *
      *                      *-----------------------------------------*
           move      "Manca l'anagrafica commerciale per il cliente     
      -              "               "    to   w-err-box-err-msg      .
      *                      *-----------------------------------------*
      *                      * Ad uscita per controllo non superato    *
      *                      * con emissione messaggio di errore       *
      *                      *-----------------------------------------*
           go to     acc-cod-cli-ctl-920.
       acc-cod-cli-ctl-300.
      *              *-------------------------------------------------*
      *              * Trattamento assoggettamento iva                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo assoggetta- *
      *                  * mento iva del cliente                       *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-tai    =    01
                     go to acc-cod-cli-ctl-320
           else if   w-let-arc-dcc-tai    =    02
                     go to acc-cod-cli-ctl-340
           else if   w-let-arc-dcc-tai    =    03
                     go to acc-cod-cli-ctl-360
           else if   w-let-arc-dcc-tai    =    04
                     go to acc-cod-cli-ctl-380.
       acc-cod-cli-ctl-320.
      *                  *---------------------------------------------*
      *                  * Tipo assoggettamento iva cliente : sempre   *
      *                  * soggetto ad iva                             *
      *                  *---------------------------------------------*
           move      zero                 to   w-tes-ass-iva (1)      .
           move      "Soggetto ad iva"    to   w-tes-ass-iva-des (1)  .
           go to     acc-cod-cli-ctl-400.
       acc-cod-cli-ctl-340.
      *                  *---------------------------------------------*
      *                  * Tipo assoggettamento iva cliente : sempre   *
      *                  * esente da iva                               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controllo che il codice iva in anagra-  *
      *                      * fica cliente sia un titolo di esenzione *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    >    2 and
                     w-edt-iva-cod-003    <    7
                     go to acc-cod-cli-ctl-345.
      *                          *-------------------------------------*
      *                          * Preparazione messaggio di errore    *
      *                          *-------------------------------------*
           move      "Assoggettamento iva errato in anagrafica cliente c
      -              "ontabile       "    to   w-err-box-err-msg      .
      *                          *-------------------------------------*
      *                          * Ad uscita per controllo non supera- *
      *                          * to con emissione messaggio di erro- *
      *                          * re                                  *
      *                          *-------------------------------------*
           go to     acc-cod-cli-ctl-920.
       acc-cod-cli-ctl-345.
      *                      *-----------------------------------------*
      *                      * Lettura tabella [codiva]                *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata                       *
      *                      *-----------------------------------------*
           if        w-let-arc-zci-flg    =    spaces
                     go to acc-cod-cli-ctl-350.
      *                          *-------------------------------------*
      *                          * Preparazione messaggio di errore    *
      *                          *-------------------------------------*
           move      "Assoggettamento iva non esistente in anagrafica cl
      -              "iente contabile"    to   w-err-box-err-msg      .
      *                          *-------------------------------------*
      *                          * Ad uscita per controllo non supera- *
      *                          * to con emissione messaggio di erro- *
      *                          * re                                  *
      *                          *-------------------------------------*
           go to     acc-cod-cli-ctl-920.
       acc-cod-cli-ctl-350.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione assoggettamento iva     *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-tes-ass-iva (1)      .
           move      w-let-arc-zci-des    to   w-tes-ass-iva-des (1)  .
           go to     acc-cod-cli-ctl-400.
       acc-cod-cli-ctl-360.
      *                  *---------------------------------------------*
      *                  * Tipo assoggettamento iva cliente : Cliente  *
      *                  * con plafond                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione relativa alla *
      *                      * gestione lettera d'intenti              *
      *                      *-----------------------------------------*
           if        w-prs-snx-lic        not  = "S"
                     go to acc-cod-cli-ctl-365.
      *                      *-----------------------------------------*
      *                      * Lettura record [lic]                    *
      *                      *-----------------------------------------*
           move      w-ctl-cod-cli-cod    to   w-let-arc-lic-cod      .
           perform   let-arc-lic-000      thru let-arc-lic-999        .
      *                      *-----------------------------------------*
      *                      * Se data documento non compresa tra data *
      *                      * riferimento iniziale e finale : si pro- *
      *                      * cede come per cliente sempre soggetto   *
      *                      *-----------------------------------------*
           if        w-tes-dat-doc        not  < w-let-arc-lic-dri and
                     w-tes-dat-doc        not  > w-let-arc-lic-drf
                     go to acc-cod-cli-ctl-365.
      *                          *-------------------------------------*
      *                          * Messaggio                           *
      *                          *-------------------------------------*
           move      "Il documento non ricade entro gli estremi della le
      -              "ttera d'intenti"    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                          *-------------------------------------*
      *                          * Si procede come per cliente sempre  *
      *                          * soggetto                            *
      *                          *-------------------------------------*
           go to     acc-cod-cli-ctl-320.
       acc-cod-cli-ctl-365.
      *                      *-----------------------------------------*
      *                      * Controllo che il codice iva in anagra-  *
      *                      * fica cliente sia un titolo di esenzione *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    >    2 and
                     w-edt-iva-cod-003    <    7
                     go to acc-cod-cli-ctl-370.
      *                          *-------------------------------------*
      *                          * Preparazione messaggio di errore    *
      *                          *-------------------------------------*
           move      "Assoggettamento iva errato in anagrafica cliente c
      -              "ontabile       "    to   w-err-box-err-msg      .
      *                          *-------------------------------------*
      *                          * Ad uscita per controllo non supera- *
      *                          * to con emissione messaggio di erro- *
      *                          * re                                  *
      *                          *-------------------------------------*
           go to     acc-cod-cli-ctl-920.
       acc-cod-cli-ctl-370.
      *                      *-----------------------------------------*
      *                      * Lettura tabella [codiva]                *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata                       *
      *                      *-----------------------------------------*
           if        w-let-arc-zci-flg    =    spaces
                     go to acc-cod-cli-ctl-375.
      *                          *-------------------------------------*
      *                          * Preparazione messaggio di errore    *
      *                          *-------------------------------------*
           move      "Assoggettamento iva non esistente in anagrafica cl
      -              "iente contabile"    to   w-err-box-err-msg      .
      *                          *-------------------------------------*
      *                          * Ad uscita per controllo non supera- *
      *                          * to con emissione messaggio di erro- *
      *                          * re                                  *
      *                          *-------------------------------------*
           go to     acc-cod-cli-ctl-920.
       acc-cod-cli-ctl-375.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione assoggettamento iva     *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-tes-ass-iva (1)      .
           move      w-let-arc-zci-des    to   w-tes-ass-iva-des (1)  .
           go to     acc-cod-cli-ctl-400.
       acc-cod-cli-ctl-380.
      *                  *---------------------------------------------*
      *                  * Tipo assoggettamento iva cliente : Cliente  *
      *                  * in regime di Scissione Pagamenti            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Assoggettamento Iva                     *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-ass-iva (1)      .
      *                      *-----------------------------------------*
      *                      * Segnale di Scissione Pagamenti          *
      *                      *-----------------------------------------*
           move      "S"                  to   w-tes-ass-iva-spl (1)  .
      *                      *-----------------------------------------*
      *                      * Dicitura per aliquota Iva               *
      *                      *-----------------------------------------*
           move      "Scissione Pagamenti"
                                          to   w-tes-ass-iva-des (1)  .
      *                      *-----------------------------------------*
      *                      * Nessun controllo in questa fase         *
      *                      *-----------------------------------------*
           go to     acc-cod-cli-ctl-400.
       acc-cod-cli-ctl-400.
      *                  *---------------------------------------------*
      *                  * Test su segnale di ordini bloccati          *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-cod-cli-ctl-800.
           if        w-let-arc-dcc-obl    not  = 02
                     go to acc-cod-cli-ctl-500.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "ATTENZIONE : Cliente con ordini bloccati !        
      -              "               "    to   w-err-box-err-msg      .
      *                      *-----------------------------------------*
      *                      * A seconda della personalizzazione rela- *
      *                      * tiva alla modalita' di blocco del cli-  *
      *                      * ente si prosegue, oppure si esce simu-  *
      *                      * lando il tasto Exit                     *
      *                      *-----------------------------------------*
           if        w-prs-blo-cli-t01    =    "B"
                     go to acc-cod-cli-ctl-920
           else      go to acc-cod-cli-ctl-910.
       acc-cod-cli-ctl-500.
      *                  *---------------------------------------------*
      *                  * Test su tipo documento preferenziale        *
      *                  *---------------------------------------------*
       acc-cod-cli-ctl-600.
      *                  *---------------------------------------------*
      *                  * Test su status commerciale del cliente      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se la personalizzazione lo prevede *
      *                      *-----------------------------------------*
           if        w-prs-ttd-sts-dcc    =    "N"
                     go to acc-cod-cli-ctl-800.
      *                      *-----------------------------------------*
      *                      * Se status normale : ad uscita           *
      *                      *-----------------------------------------*
           if        w-let-arc-dcc-tus    =    01 or
                     w-let-arc-dcc-tus    =    09
                     go to acc-cod-cli-ctl-800.
      *                      *-----------------------------------------*
      *                      * Se status non normale : box specifico   *
      *                      * per lo status commerciale               *
      *                      *-----------------------------------------*
           perform   acc-cod-cli-bsc-000  thru acc-cod-cli-bsc-999    .
      *                      *-----------------------------------------*
      *                      * Tipo di uscita a seconda della persona- *
      *                      * lizzazione                              *
      *                      *-----------------------------------------*
           if        w-prs-ttd-sts-dcc    =    "B"
                     go to acc-cod-cli-ctl-930
           else      go to acc-cod-cli-ctl-800.
       acc-cod-cli-ctl-800.
      *              *-------------------------------------------------*
      *              * Uscita per controlli superati                   *
      *              *-------------------------------------------------*
           go to     acc-cod-cli-ctl-999.
       acc-cod-cli-ctl-900.
      *              *-------------------------------------------------*
      *              * Uscita per controlli non superati o per emis-   *
      *              * sione messaggio di errore                       *
      *              *-------------------------------------------------*
       acc-cod-cli-ctl-910.
      *                  *---------------------------------------------*
      *                  * Uscita con solo messaggio di errore         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Box di errore                           *
      *                      *-----------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     acc-cod-cli-ctl-999.
       acc-cod-cli-ctl-920.
      *                  *---------------------------------------------*
      *                  * Uscita con messaggio di errore e flag di    *
      *                  * errore                                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Box di errore                           *
      *                      *-----------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
       acc-cod-cli-ctl-930.
      *                  *---------------------------------------------*
      *                  * Uscita con flag di errore                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di uscita                          *
      *                      *-----------------------------------------*
           move      "#"                  to   w-ctl-cod-cli-flg      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     acc-cod-cli-ctl-999.
       acc-cod-cli-ctl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice archivio              *
      *    *                                                           *
      *    * Box di errore emesso in funzione dello status commerciale *
      *    * del cliente, se diverso da 'normale'                      *
      *    *-----------------------------------------------------------*
       acc-cod-cli-bsc-000.
      *              *-------------------------------------------------*
      *              * Messaggio di errore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio del video attuale               *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      20                   to   v-lto                  .
           move      08                   to   v-pos                  .
           move      73                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-cli-bsc-200.
      *                  *---------------------------------------------*
      *                  * Messaggi entro il box                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Titolo centrale                         *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "                     A T T E N Z I O N E          
      -              "            "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 1                        *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "Per il cliente impostato si rileva la seguente con
      -              "dizione :   "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Preparazione riga messaggio 2           *
      *                      *-----------------------------------------*
           if        w-let-arc-dcc-tus    =    11
                     move  "[Esauriti i rapporti commerciali]           
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    21
                     move  "[Sostituito da ns. nuovo cliente]           
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    51
                     move  "[Cessata attivita']                         
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    52
                     move  "[Cessata attivita', ma sostituito da ns. nuo
      -                    "vo cliente]       "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    61
                     move  "[In contenzioso]                            
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    62
                     move  "[In contenzioso, ma sostituito da ns. nuovo 
      -                    "cliente]          "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    71
                     move  "[Fallito]                                   
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    72
                     move  "[Fallito, ma sostituito da ns. nuovo cliente
      -                    "]                 "
                                          to   v-alf
           else      move  "(status non determinato)                    
      -                    "                  "
                                          to   v-alf                  .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 2                        *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      10                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 3                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da emettere                 *
      *                          *-------------------------------------*
           if        w-let-arc-dcc-tud    =    zero
                     go to acc-cod-cli-bsc-300.
      *                          *-------------------------------------*
      *                          * Emissione                           *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "La determinazione di tale condizione risale al :  
      -              "            "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Data di rilevamento status          *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      15                   to   v-lin                  .
           move      59                   to   v-pos                  .
           move      w-let-arc-dcc-tud    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-cli-bsc-300.
      *                      *-----------------------------------------*
      *                      * Righe messaggio 4 e 5                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da emettere                 *
      *                          *-------------------------------------*
           if        w-let-arc-dcc-tuc    =    zero
                     go to acc-cod-cli-bsc-600.
      *                          *-------------------------------------*
      *                          * Emissione                           *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "Il cliente utilizzabile in alternativa e' il segue
      -              "nte :       "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Codice cliente alternativo          *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      19                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      w-let-arc-dcc-tuc    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Lettura descrizione per il cliente  *
      *                          * alternativo                         *
      *                          *-------------------------------------*
           move      w-let-arc-dcc-tuc    to   w-let-arc-cli-cod      .
           perform   let-arc-cli-000      thru let-arc-cli-999        .
           if        w-let-arc-cli-flg    not  = spaces
                     move  all "."        to   v-alf
           else      move  w-let-arc-cli-rag
                                          to   v-alf                  .
      *                          *-------------------------------------*
      *                          * Emissione                           *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      20                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-cli-bsc-600.
      *                      *-----------------------------------------*
      *                      * Prompt per presa visione                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      69                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-cli-bsc-800.
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      19                   to   v-lin                  .
           move      70                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-cli-bsc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice dipendenza cliente    *
      *    *-----------------------------------------------------------*
       acc-dpz-cli-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo archivio                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    not  = "C"
                     go to acc-dpz-cli-999.
      *                      *-----------------------------------------*
      *                      * Test sul segnale che indica la presen-  *
      *                      * za di dipendenze per il cliente in cor- *
      *                      * so di trattamento.                      *
      *                      * Comunque si va a ritarare il Pop-Up     *
      *                      * relativo all'indirizzo di spedizione    *
      *                      *-----------------------------------------*
           if        w-tes-cod-arc-snd (1)
                                          =    "N"
                     go to acc-dpz-cli-700.
       acc-dpz-cli-030.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-dpz-arc (1)    to   w-sav-dpz-cli          .
       acc-dpz-cli-040.
      *                  *---------------------------------------------*
      *                  * Se la personalizzazione lo prevede si pre-  *
      *                  * para l'unica dipendenza del cliente come    *
      *                  * default di accettazione                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione               *
      *                      *-----------------------------------------*
           if        w-prs-snx-udd-dcc    not  = "S"
                     go to acc-dpz-cli-050.
      *                      *-----------------------------------------*
      *                      * Test se valore gia' impostato           *
      *                      *-----------------------------------------*
           if        w-tes-dpz-arc (1)    not  = spaces
                     go to acc-dpz-cli-050.
      *                      *-----------------------------------------*
      *                      * Test se cliente con piu' di una dipen-  *
      *                      * denza                                   *
      *                      *-----------------------------------------*
           if        w-det-snd-dcc-ctr    >    1
                     go to acc-dpz-cli-050.
      *                      *-----------------------------------------*
      *                      * Test se pagina testata gia' impostata   *
      *                      *-----------------------------------------*
           if        w-tes-fda-pt1 (1)    not  = spaces
                     go to acc-dpz-cli-050.
      *                      *-----------------------------------------*
      *                      * Default                                 *
      *                      *-----------------------------------------*
           move      w-det-snd-dcc-dpz    to   w-tes-dpz-arc (1)      .
       acc-dpz-cli-050.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-dpz-cli-400.
       acc-dpz-cli-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-dcc-ope      .
           move      w-tes-cod-arc (1)    to   w-cod-cod-dcc-cli      .
           move      w-tes-dpz-arc (1)    to   w-cod-cod-dcc-cod      .
           move      12                   to   w-cod-cod-dcc-lin      .
           move      27                   to   w-cod-cod-dcc-pos      .
           move      12                   to   w-cod-cod-dcc-rln      .
           move      41                   to   w-cod-cod-dcc-rps      .
           move      13                   to   w-cod-cod-dcc-vln      .
           move      41                   to   w-cod-cod-dcc-vps      .
           move      14                   to   w-cod-cod-dcc-lln      .
           move      41                   to   w-cod-cod-dcc-lps      .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-dcc-cll-000  thru cod-cod-dcc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-dcc-foi-000  thru cod-cod-dcc-foi-999    .
       acc-dpz-cli-110.
           perform   cod-cod-dcc-cll-000  thru cod-cod-dcc-cll-999    .
           if        w-cod-cod-dcc-ope    =    "F+"
                     go to acc-dpz-cli-115.
           if        w-cod-cod-dcc-ope    =    "AC"
                     go to acc-dpz-cli-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-dpz-cli-115.
           perform   cod-cod-dcc-foi-000  thru cod-cod-dcc-foi-999    .
           go to     acc-dpz-cli-110.
       acc-dpz-cli-120.
           move      w-cod-cod-dcc-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-dpz-cli-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-dpz-cli-999.
       acc-dpz-cli-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-dpz-arc (1)      .
       acc-dpz-cli-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura file [dcc]                          *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-let-arc-dcc-cli      .
           move      w-tes-dpz-arc (1)    to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           move      w-let-arc-dcc-rag    to   w-tes-dpz-arc-rag (1)  .
           move      w-let-arc-dcc-via    to   w-tes-dpz-arc-via (1)  .
           move      w-let-arc-dcc-loc    to   w-tes-dpz-arc-loc (1)  .
           perform   vis-dpz-cli-des-000  thru vis-dpz-cli-des-999    .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-flg    not  = spaces
                     go to acc-dpz-cli-100.
       acc-dpz-cli-500.
      *                  *---------------------------------------------*
      *                  * Test su segnale di ordini bloccati          *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-dpz-cli-580.
           if        w-let-arc-dcc-obl    not  = 02
                     go to acc-dpz-cli-580.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "ATTENZIONE : Dipendenza con ordini bloccati !     
      -              "               "    to   w-err-box-err-msg      .
      *                      *-----------------------------------------*
      *                      * Box di errore                           *
      *                      *-----------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A seconda della personalizzazione rela- *
      *                      * tiva alla modalita' di blocco del cli-  *
      *                      * ente si prosegue, oppure si esce simu-  *
      *                      * lando il tasto Exit                     *
      *                      *-----------------------------------------*
           if        w-prs-blo-cli-t01    =    "B"
                     go to acc-dpz-cli-100
           else      go to acc-dpz-cli-580.
       acc-dpz-cli-580.
      *                  *---------------------------------------------*
      *                  * Subroutine per note su dipendenza cliente   *
      *                  *---------------------------------------------*
           perform   cod-cod-dcc-not-000  thru cod-cod-dcc-not-999    .
       acc-dpz-cli-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-dpz-arc (1)    =    w-sav-dpz-cli
                     go to acc-dpz-cli-700.
      *                      *-----------------------------------------*
      *                      * Eventuale normalizzazione valore per i- *
      *                      * noltro pagamenti                        *
      *                      *-----------------------------------------*
           if        w-tes-dpz-arc (1)    =    spaces and
                     w-tes-inl-pgt (1)    =    03
                     move  02             to   w-tes-inl-pgt (1)      .
      *                      *-----------------------------------------*
      *                      * Valori testata indotti da record [dcc]  *
      *                      * relativo alla dipendenza                *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione                      *
      *                          *-------------------------------------*
           move      "C"                  to   w-det-vlt-dcd-tdt      .
           move      w-tes-dpz-arc (1)    to   w-det-vlt-dcd-dpz      .
           perform   det-vlt-dcd-000      thru det-vlt-dcd-999        .
      *                          *-------------------------------------*
      *                          * Determinazione funzionamento spese  *
      *                          *-------------------------------------*
           move      "C"                  to   w-det-fun-spe-tdt      .
           perform   det-fun-spe-000      thru det-fun-spe-999        .
      *                          *-------------------------------------*
      *                          * Eventuale messaggio                 *
      *                          *-------------------------------------*
           if        w-tes-age-aad (1)    =    w-tes-cod-age (1)
                     go to acc-dpz-cli-620.
      *                          *-------------------------------------*
      *                          * Messaggio                           *
      *                          *-------------------------------------*
           move      "Attenzione: il codice agente per la dipendenza e' 
      -              "diverso        "    to   w-err-box-err-msg      .
           move      "            da quello attualmente impostato per la
      -              " Sede          "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       acc-dpz-cli-620.
      *                      *-----------------------------------------*
      *                      * Determinazione valori testata dipendenti*
      *                      * dall'inoltro pagamenti                  *
      *                      *-----------------------------------------*
           move      w-tes-dpz-arc (1)    to   w-det-vlt-ipg-dpz      .
           perform   det-vlt-ipg-000      thru det-vlt-ipg-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione valori testata associati *
      *                      * all'agente                              *
      *                      *-----------------------------------------*
           move      w-tes-dpz-arc (1)    to   w-det-vlt-age-dpz      .
           perform   det-vlt-age-000      thru det-vlt-age-999        .
       acc-dpz-cli-700.
      *                      *-----------------------------------------*
      *                      * Trattamento indirizzo di spedizione     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se dipendenza esistente             *
      *                          *-------------------------------------*
           if        w-tes-dpz-arc (1)    =    spaces
                     go to acc-dpz-cli-720.
      *                              *---------------------------------*
      *                              * Numero elementi nel pop-up di   *
      *                              * accettazione : 4                *
      *                              *---------------------------------*
           move      04                   to   w-exp-tip-ids-num      .
      *                              *---------------------------------*
      *                              * Se tipo indirizzo di spedizione *
      *                              * 'Sede legale' o 'Manuale': oltre*
      *                              *---------------------------------*
           if        w-tes-tip-ids (1)    =    01 or
                     w-tes-tip-ids (1)    =    02
                     go to acc-dpz-cli-800.
      *                              *---------------------------------*
      *                              * Se il valore precedente non era *
      *                              * a spazi : oltre                 *
      *                              *---------------------------------*
           if        w-sav-dpz-cli        not  = spaces
                     go to acc-dpz-cli-800.
      *                              *---------------------------------*
      *                              * Forzatura dei dati dipendenza   *
      *                              * nell'indirizzo di spedizione    *
      *                              *---------------------------------*
           move      04                   to   w-tes-tip-ids (1)      .
           perform   vis-tip-ids-000      thru vis-tip-ids-999        .
           move      w-tes-dpz-arc-rag (1)
                                          to   w-tes-rag-ids (1)      .
           move      spaces               to   w-tes-rs2-ids (1)      .
           move      w-tes-dpz-arc-via (1)
                                          to   w-tes-via-ids (1)      .
           move      w-tes-dpz-arc-loc (1)
                                          to   w-tes-loc-ids (1)      .
           perform   vis-rag-ids-000      thru vis-rag-ids-999        .
           perform   vis-rs2-ids-000      thru vis-rs2-ids-999        .
           perform   vis-via-ids-000      thru vis-via-ids-999        .
           perform   vis-loc-ids-000      thru vis-loc-ids-999        .
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     acc-dpz-cli-800.
       acc-dpz-cli-720.
      *                          *-------------------------------------*
      *                          * Se dipendenza non esistente         *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Si pone a 3 il numero di elemen-*
      *                              * ti del pop-up di accettazione   *
      *                              * del tipo di spedizione          *
      *                              *---------------------------------*
           move      03                   to   w-exp-tip-ids-num      .
      *                              *---------------------------------*
      *                              * Se il tipo indirizzo di spedi-  *
      *                              * zione attuale vale 04, lo si    *
      *                              * forza a 03 (Sede) e cosi' i va- *
      *                              * lori anagrafici                 *
      *                              *---------------------------------*
           if        w-tes-tip-ids (1)    not  = 04
                     go to acc-dpz-cli-800.
           move      03                   to   w-tes-tip-ids (1)      .
           perform   vis-tip-ids-000      thru vis-tip-ids-999        .
           move      w-tes-rag-sed (1)    to   w-tes-rag-ids (1)      .
           move      spaces               to   w-tes-rs2-ids (1)      .
           move      w-tes-via-sed (1)    to   w-tes-via-ids (1)      .
           move      w-tes-loc-sed (1)    to   w-tes-loc-ids (1)      .
           perform   vis-rag-ids-000      thru vis-rag-ids-999        .
           perform   vis-rs2-ids-000      thru vis-rs2-ids-999        .
           perform   vis-via-ids-000      thru vis-via-ids-999        .
           perform   vis-loc-ids-000      thru vis-loc-ids-999        .
       acc-dpz-cli-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-dpz-cli-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-dpz-cli-100.
       acc-dpz-cli-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Dipendenza del cliente    *
      *    *-----------------------------------------------------------*
       vis-dpz-cli-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      w-tes-dpz-arc (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dpz-cli-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione dipendenza    *
      *    *-----------------------------------------------------------*
       vis-dpz-cli-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-dpz-arc-rag (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-dpz-arc-via (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-dpz-arc-loc (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dpz-cli-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice nostra dipendenza     *
      *    *-----------------------------------------------------------*
       acc-cod-dpz-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-cod-dpz-025.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-sav-cod-dpz          .
       acc-cod-dpz-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-dpz-ope      .
           move      w-tes-cod-arc (1)    to   w-cod-cod-dpz-cod      .
           move      08                   to   w-cod-cod-dpz-lin      .
           move      27                   to   w-cod-cod-dpz-pos      .
           move      08                   to   w-cod-cod-dpz-dln      .
           move      41                   to   w-cod-cod-dpz-dps      .
           move      "<B"                 to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-dpz-cll-000  thru cod-cod-dpz-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-dpz-foi-000  thru cod-cod-dpz-foi-999    .
       acc-cod-dpz-110.
           perform   cod-cod-dpz-cll-000  thru cod-cod-dpz-cll-999    .
           if        w-cod-cod-dpz-ope    =    "F+"
                     go to acc-cod-dpz-115.
           if        w-cod-cod-dpz-ope    =    "AC"
                     go to acc-cod-dpz-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-dpz-115.
           perform   cod-cod-dpz-foi-000  thru cod-cod-dpz-foi-999    .
           go to     acc-cod-dpz-110.
       acc-cod-dpz-120.
           move      w-cod-cod-dpz-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-dpz-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-dpz-999.
       acc-cod-dpz-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-arc (1)      .
       acc-cod-dpz-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-cod-dpz-410.
      *                  *---------------------------------------------*
      *                  * Lettura dipendenza per l'azienda            *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-let-arc-dpz-cod      .
           perform   let-arc-dpz-000      thru let-arc-dpz-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-dpz-des    to   w-tes-cod-arc-rag (1)  .
           move      spaces               to   w-tes-cod-arc-via (1)  .
           move      spaces               to   w-tes-cod-arc-loc (1)  .
       acc-cod-dpz-420.
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-cod-arc-des-000  thru vis-cod-arc-des-999    .
       acc-cod-dpz-430.
      *                  *---------------------------------------------*
      *                  * Se dipendenza non esistente : reimpostazio- *
      *                  * ne                                          *
      *                  *---------------------------------------------*
           if        w-let-arc-dpz-flg    not  = spaces
                     go to acc-cod-dpz-100.
       acc-cod-dpz-440.
      *                  *---------------------------------------------*
      *                  * Se codice a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-tes-cod-arc (1)    =    zero
                     go to acc-cod-dpz-100.
       acc-cod-dpz-450.
      *                  *---------------------------------------------*
      *                  * Controllo che il codice dipendenza non sia  *
      *                  * pari al codice dipendenza in uso            *
      *                  *                                             *
      *                  * Solo avvertimento                           *
      *                  *---------------------------------------------*
           if        w-tes-cod-arc (1)    not  = w-tes-cod-dpz
                     go to acc-cod-dpz-600.
           move      "Attenzione: dipendenza in uso !                   
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
       acc-cod-dpz-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-cod-arc (1)    =    w-sav-cod-dpz
                     go to acc-cod-dpz-800.
      *                      *-----------------------------------------*
      *                      * Trattamento indirizzo di spedizione     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Numero elementi nel pop-up di ac-   *
      *                          * cettazione : 2                      *
      *                          *-------------------------------------*
           move      02                   to   w-exp-tip-ids-num      .
      *                          *-------------------------------------*
      *                          * Se il valore e' gia' a :            *
      *                          * - 01 : Sede Legale    oppure        *
      *                          * - 02 : Manuale                      *
      *                          * oltre                               *
      *                          *-------------------------------------*
           if        w-tes-tip-ids (1)    =    01 or
                     w-tes-tip-ids (1)    =    02
                     go to acc-cod-dpz-620.
      *                          *-------------------------------------*
      *                          * Tipo indirizzo di spedizione        *
      *                          *-------------------------------------*
           move      01                   to   w-tes-tip-ids (1)      .
           perform   vis-tip-ids-000      thru vis-tip-ids-999        .
      *                          *-------------------------------------*
      *                          * Indirizzo di spedizione             *
      *                          *-------------------------------------*
           move      w-let-arc-dpz-rag    to   w-tes-rag-ids (1)      .
           move      spaces               to   w-tes-rs2-ids (1)      .
           move      w-let-arc-dpz-via    to   w-tes-via-ids (1)      .
           move      w-let-arc-dpz-loc    to   w-tes-loc-ids (1)      .
           perform   vis-rag-ids-000      thru vis-rag-ids-999        .
           perform   vis-rs2-ids-000      thru vis-rs2-ids-999        .
           perform   vis-via-ids-000      thru vis-via-ids-999        .
           perform   vis-loc-ids-000      thru vis-loc-ids-999        .
       acc-cod-dpz-620.
       acc-cod-dpz-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-dpz-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-dpz-100.
       acc-cod-dpz-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Tipo indirizzo di spedizione *
      *    *-----------------------------------------------------------*
       acc-tip-ids-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-tip-ids (1)    to   w-sav-tip-ids          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-tip-ids-400.
       acc-tip-ids-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-ids-lun    to   v-car                  .
           move      w-exp-tip-ids-num    to   v-ldt                  .
           move      "LMSD#"              to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      16                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      w-exp-tip-ids-tbl    to   v-txt                  .
           move      w-tes-tip-ids (1)    to   v-num                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-tip-ids-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-tip-ids-999.
       acc-tip-ids-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-tip-ids (1)      .
       acc-tip-ids-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se zero : reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-tes-tip-ids (1)    not  = zero
                     go to acc-tip-ids-600.
           if        v-key                =    "UP  "
                     go to acc-tip-ids-600
           else      go to acc-tip-ids-100.
       acc-tip-ids-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-tip-ids (1)    =    w-sav-tip-ids
                     go to acc-tip-ids-800.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo indirizzo   *
      *                  * di spedizione                               *
      *                  *---------------------------------------------*
           go to     acc-tip-ids-610
                     acc-tip-ids-620
                     acc-tip-ids-630
                     acc-tip-ids-640
                     depending            on   w-tes-tip-ids (1)      .
       acc-tip-ids-610.
      *                  *---------------------------------------------*
      *                  * Tipo indirizzo di spedizione : Sede legale  *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc-rag (1)
                                          to   w-tes-rag-ids (1)      .
           move      spaces               to   w-tes-rs2-ids (1)      .
           move      w-tes-cod-arc-via (1)
                                          to   w-tes-via-ids (1)      .
           move      w-tes-cod-arc-loc (1)
                                          to   w-tes-loc-ids (1)      .
           go to     acc-tip-ids-650.
       acc-tip-ids-620.
      *                  *---------------------------------------------*
      *                  * Tipo indirizzo di spedizione : Manuale      *
      *                  *---------------------------------------------*
           move      spaces               to   w-tes-rag-ids (1)      .
           move      spaces               to   w-tes-rs2-ids (1)      .
           move      spaces               to   w-tes-via-ids (1)      .
           move      spaces               to   w-tes-loc-ids (1)      .
           go to     acc-tip-ids-650.
       acc-tip-ids-630.
      *                  *---------------------------------------------*
      *                  * Tipo indirizzo di spedizione : Sede         *
      *                  *---------------------------------------------*
           move      w-tes-rag-sed (1)    to   w-tes-rag-ids (1)      .
           move      spaces               to   w-tes-rs2-ids (1)      .
           move      w-tes-via-sed (1)    to   w-tes-via-ids (1)      .
           move      w-tes-loc-sed (1)    to   w-tes-loc-ids (1)      .
           go to     acc-tip-ids-650.
       acc-tip-ids-640.
      *                  *---------------------------------------------*
      *                  * Tipo indirizzo di spedizione : Dipendenza   *
      *                  *---------------------------------------------*
           move      w-tes-dpz-arc-rag (1)
                                          to   w-tes-rag-ids (1)      .
           move      spaces               to   w-tes-rs2-ids (1)      .
           move      w-tes-dpz-arc-via (1)
                                          to   w-tes-via-ids (1)      .
           move      w-tes-dpz-arc-loc (1)
                                          to   w-tes-loc-ids (1)      .
           go to     acc-tip-ids-650.
       acc-tip-ids-650.
      *                  *---------------------------------------------*
      *                  * Visualizzazione dati indirizzo di spedizione*
      *                  *---------------------------------------------*
           perform   vis-rag-ids-000      thru vis-rag-ids-999        .
           perform   vis-rs2-ids-000      thru vis-rs2-ids-999        .
           perform   vis-via-ids-000      thru vis-via-ids-999        .
           perform   vis-loc-ids-000      thru vis-loc-ids-999        .
       acc-tip-ids-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-tip-ids-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-tip-ids-100.
       acc-tip-ids-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Tipo indirizzo di spedi-  *
      *    *                                 zione                     *
      *    *-----------------------------------------------------------*
       vis-tip-ids-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-ids-lun    to   v-car                  .
           move      w-exp-tip-ids-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      16                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      w-exp-tip-ids-tbl    to   v-txt                  .
           move      w-tes-tip-ids (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tip-ids-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Ragione sociale indirizzo di *
      *    *                              spedizione - 1               *
      *    *-----------------------------------------------------------*
       acc-rag-ids-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-tip-ids (1)    not  = 02
                     go to acc-rag-ids-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-rag-ids-400.
       acc-rag-ids-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione evidenziatore area di input :   *
      *              * inizio                                          *
      *              *-------------------------------------------------*
           perform   vis-eai-ids-ini-000  thru vis-eai-ids-ini-999    .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-rag-ids (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-rag-ids-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-rag-ids-999.
       acc-rag-ids-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-rag-ids (1)      .
      *              *-------------------------------------------------*
      *              * Visualizzazione evidenziatore area di input :   *
      *              * fine                                            *
      *              *-------------------------------------------------*
           perform   vis-eai-ids-fin-000  thru vis-eai-ids-fin-999    .
       acc-rag-ids-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a spaces : reimpostazione, a meno *
      *                  * che non sia su tasto Up                     *
      *                  *---------------------------------------------*
           if        w-tes-rag-ids (1)    not  = spaces
                     go to acc-rag-ids-450.
           if        v-key                =    "UP  "
                     go to acc-rag-ids-600
           else      go to acc-rag-ids-100.
       acc-rag-ids-450.
       acc-rag-ids-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-rag-ids-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-rag-ids-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-rag-ids-100.
       acc-rag-ids-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Ragione sociale indirizzo *
      *    *                                 di spedizione - 1         *
      *    *-----------------------------------------------------------*
       vis-rag-ids-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-rag-ids (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-rag-ids-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione evidenziatore area di input : inizio      *
      *    *-----------------------------------------------------------*
       vis-eai-ids-ini-000.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      40                   to   v-pos                  .
           move      "|"                  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      40                   to   v-pos                  .
           move      "|"                  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      40                   to   v-pos                  .
           move      "|"                  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      40                   to   v-pos                  .
           move      "|"                  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-eai-ids-ini-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione evidenziatore area di input : fine        *
      *    *-----------------------------------------------------------*
       vis-eai-ids-fin-000.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      40                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      40                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      40                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      40                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-eai-ids-fin-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Ragione sociale indirizzo di *
      *    *                              spedizione - 2               *
      *    *-----------------------------------------------------------*
       acc-rs2-ids-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-tip-ids (1)    not  = 02
                     go to acc-rs2-ids-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-rs2-ids-400.
       acc-rs2-ids-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione evidenziatore area di input :   *
      *              * inizio                                          *
      *              *-------------------------------------------------*
           perform   vis-eai-ids-ini-000  thru vis-eai-ids-ini-999    .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-rs2-ids (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-rs2-ids-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-rs2-ids-999.
       acc-rs2-ids-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-rs2-ids (1)      .
      *              *-------------------------------------------------*
      *              * Visualizzazione evidenziatore area di input :   *
      *              * fine                                            *
      *              *-------------------------------------------------*
           perform   vis-eai-ids-fin-000  thru vis-eai-ids-fin-999    .
       acc-rs2-ids-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-rs2-ids-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-rs2-ids-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-rs2-ids-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-rs2-ids-100.
       acc-rs2-ids-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Ragione sociale indirizzo *
      *    *                                 di spedizione - 2         *
      *    *-----------------------------------------------------------*
       vis-rs2-ids-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-rs2-ids (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-rs2-ids-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Via per indirizzo di spedi-  *
      *    *                              zione                        *
      *    *-----------------------------------------------------------*
       acc-via-ids-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-tip-ids (1)    not  = 02
                     go to acc-via-ids-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-via-ids-400.
       acc-via-ids-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione evidenziatore area di input :   *
      *              * inizio                                          *
      *              *-------------------------------------------------*
           perform   vis-eai-ids-ini-000  thru vis-eai-ids-ini-999    .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-ind-cec-geo-ope      .
           move      "IT "                to   w-ind-cec-geo-naz      .
           move      w-tes-via-ids (1)    to   w-ind-cec-geo-ind      .
           move      18                   to   w-ind-cec-geo-lin      .
           move      41                   to   w-ind-cec-geo-pos      .
           move      w-tes-loc-ids (1)    to   w-ind-cec-geo-cec      .
           move      zero                 to   w-ind-cec-geo-cmn      .
           move      spaces               to   w-ind-cec-geo-dco      .
           move      spaces               to   w-ind-cec-geo-prv      .
           move      zero                 to   w-ind-cec-geo-fzn      .
           move      spaces               to   w-ind-cec-geo-dfr      .
           move      zero                 to   w-ind-cec-geo-lct      .
           move      spaces               to   w-ind-cec-geo-dlo      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   ind-cec-geo-cll-000  thru ind-cec-geo-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   ind-cec-geo-foi-000  thru ind-cec-geo-foi-999    .
       acc-via-ids-110.
           perform   ind-cec-geo-cll-000  thru ind-cec-geo-cll-999    .
           if        w-ind-cec-geo-ope    =    "F+"
                     go to acc-via-ids-115.
           if        w-ind-cec-geo-ope    =    "AC"
                     go to acc-via-ids-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-via-ids-115.
           perform   ind-cec-geo-foi-000  thru ind-cec-geo-foi-999    .
           go to     acc-via-ids-110.
       acc-via-ids-120.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-via-ids-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-via-ids-999.
       acc-via-ids-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      w-ind-cec-geo-ind    to   w-tes-via-ids (1)      .
      *              *-------------------------------------------------*
      *              * Visualizzazione evidenziatore area di input :   *
      *              * fine                                            *
      *              *-------------------------------------------------*
           perform   vis-eai-ids-fin-000  thru vis-eai-ids-fin-999    .
      *              *-------------------------------------------------*
      *              * Altri valori se automatismo eseguito            *
      *              *-------------------------------------------------*
           if        w-ind-cec-geo-aut    =    spaces
                     go to acc-via-ids-400.
      *                  *---------------------------------------------*
      *                  * Localita'                                   *
      *                  *---------------------------------------------*
           move      w-ind-cec-geo-cec    to   w-tes-loc-ids (1)      .
           perform   vis-loc-ids-000      thru vis-loc-ids-999        .
       acc-via-ids-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-via-ids-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-via-ids-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-via-ids-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-via-ids-100.
       acc-via-ids-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Via per indirizzo di spe- *
      *    *                                 dizione                   *
      *    *-----------------------------------------------------------*
       vis-via-ids-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-via-ids (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-via-ids-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Localita' indirizzo di spe-  *
      *    *                              dizione                      *
      *    *-----------------------------------------------------------*
       acc-loc-ids-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-tip-ids (1)    not  = 02
                     go to acc-loc-ids-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-loc-ids-400.
       acc-loc-ids-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione evidenziatore area di input :   *
      *              * inizio                                          *
      *              *-------------------------------------------------*
           perform   vis-eai-ids-ini-000  thru vis-eai-ids-ini-999    .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cap-cit-geo-ope      .
           move      "IT "                to   w-cap-cit-geo-naz      .
           move      w-tes-loc-ids (1)    to   w-cap-cit-geo-cec      .
           move      19                   to   w-cap-cit-geo-lin      .
           move      41                   to   w-cap-cit-geo-pos      .
           move      zero                 to   w-cap-cit-geo-cmn      .
           move      spaces               to   w-cap-cit-geo-dco      .
           move      spaces               to   w-cap-cit-geo-prv      .
           move      zero                 to   w-cap-cit-geo-fzn      .
           move      spaces               to   w-cap-cit-geo-dfr      .
           move      zero                 to   w-cap-cit-geo-lct      .
           move      spaces               to   w-cap-cit-geo-dlo      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cap-cit-geo-cll-000  thru cap-cit-geo-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cap-cit-geo-foi-000  thru cap-cit-geo-foi-999    .
       acc-loc-ids-110.
           perform   cap-cit-geo-cll-000  thru cap-cit-geo-cll-999    .
           if        w-cap-cit-geo-ope    =    "F+"
                     go to acc-loc-ids-115.
           if        w-cap-cit-geo-ope    =    "AC"
                     go to acc-loc-ids-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-loc-ids-115.
           perform   cap-cit-geo-foi-000  thru cap-cit-geo-foi-999    .
           go to     acc-loc-ids-110.
       acc-loc-ids-120.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-loc-ids-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-loc-ids-999.
       acc-loc-ids-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      w-cap-cit-geo-cec    to   w-tes-loc-ids (1)      .
      *              *-------------------------------------------------*
      *              * Visualizzazione evidenziatore area di input :   *
      *              * fine                                            *
      *              *-------------------------------------------------*
           perform   vis-eai-ids-fin-000  thru vis-eai-ids-fin-999    .
      *              *-------------------------------------------------*
      *              * Altri valori se automatismo eseguito            *
      *              *-------------------------------------------------*
           if        w-cap-cit-geo-aut    =    spaces
                     go to acc-loc-ids-400.
       acc-loc-ids-300.
      *                  *---------------------------------------------*
      *                  * Indirizzo, solo se l'elemento selezionato   *
      *                  * e' una localita'                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se non si tratta di una localita' non   *
      *                      * si esegue alcun automatismo sull'indi-  *
      *                      * rizzo                                   *
      *                      *-----------------------------------------*
           if        w-cap-cit-geo-lct    =    zero
                     go to acc-loc-ids-350.
      *                      *-----------------------------------------*
      *                      * Concatenamento della localita' selezio- *
      *                      * nata con l'indirizzo precedente         *
      *                      *-----------------------------------------*
           move      "IL"                 to   w-ind-cec-geo-ope      .
           move      w-tes-via-ids (1)    to   w-ind-cec-geo-ind      .
           move      w-cap-cit-geo-dlo    to   w-ind-cec-geo-dlo      .
           perform   ind-cec-geo-cll-000  thru ind-cec-geo-cll-999    .
           move      w-ind-cec-geo-ind    to   w-tes-via-ids (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione via concatenata         *
      *                      *-----------------------------------------*
           perform   vis-via-ids-000      thru vis-via-ids-999        .
       acc-loc-ids-350.
       acc-loc-ids-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-loc-ids-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-loc-ids-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-loc-ids-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-loc-ids-100.
       acc-loc-ids-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Localita' indirizzo di    *
      *    *                                 spedizione                *
      *    *-----------------------------------------------------------*
       vis-loc-ids-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-loc-ids (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-loc-ids-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Tipo fornitura               *
      *    *-----------------------------------------------------------*
       acc-tip-frn-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da trattare                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo archivio                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    =    "D"
                     go to acc-tip-frn-999.
      *                      *-----------------------------------------*
      *                      * Test se personalizzazione lo prevede    *
      *                      *-----------------------------------------*
           if        w-prs-ges-apf        not  = 11 and
                     w-prs-ges-apf        not  = 21 and
                     w-prs-ges-apf        not  = 99
                     go to acc-tip-frn-999.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se pagina testata gia' impostata   *
      *                      *-----------------------------------------*
           if        w-tes-fda-pt1 (1)    not  = spaces
                     go to acc-tip-frn-999.
      *                  *---------------------------------------------*
      *                  * Preparazione eventuale default              *
      *                  *---------------------------------------------*
           if        w-tes-tip-frn (1)    =    zero
                     move  01             to   w-tes-tip-frn (1)      .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-tip-frn-400.
       acc-tip-frn-050.
      *                  *---------------------------------------------*
      *                  * Preparazione Pop-Up di accettazione in fun- *
      *                  * zione della personalizzazione               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del valore della *
      *                      * personalizzazione                       *
      *                      *-----------------------------------------*
           if        w-prs-ges-apf        =    11
                     go to acc-tip-frn-052
           else if   w-prs-ges-apf        =    21
                     go to acc-tip-frn-054
           else if   w-prs-ges-apf        =    99
                     go to acc-tip-frn-056.
       acc-tip-frn-052.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per : Leasing          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Aggiustamento numero elementi del   *
      *                          * Pop-Up                              *
      *                          *-------------------------------------*
           move      02                   to   w-exp-tip-frn-num      .
      *                          *-------------------------------------*
      *                          * Ad accettazione                     *
      *                          *-------------------------------------*
           go to     acc-tip-frn-100.
       acc-tip-frn-054.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per: Gruppo d'Acquisto *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Aggiustamento numero elementi del   *
      *                          * Pop-Up                              *
      *                          *-------------------------------------*
           move      02                   to   w-exp-tip-frn-num      .
      *                          *-------------------------------------*
      *                          * Shift del terzo elemento sul secon- *
      *                          * do                                  *
      *                          *-------------------------------------*
           move      w-exp-tip-frn-ele (03)
                                          to   w-exp-tip-frn-ele (02) .
      *                          *-------------------------------------*
      *                          * Ad accettazione                     *
      *                          *-------------------------------------*
           go to     acc-tip-frn-100.
       acc-tip-frn-056.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per : Completa         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Ad accettazione                     *
      *                          *-------------------------------------*
           go to     acc-tip-frn-100.
       acc-tip-frn-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Parametri di accettazione                   *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-frn-lun    to   v-car                  .
           move      w-exp-tip-frn-num    to   v-ldt                  .
           move      "DLG#"               to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      20                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      w-exp-tip-frn-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
       acc-tip-frn-150.
      *                  *---------------------------------------------*
      *                  * Valore di accettazione                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del valore della *
      *                      * personalizzazione                       *
      *                      *-----------------------------------------*
           if        w-prs-ges-apf        =    11
                     go to acc-tip-frn-152
           else if   w-prs-ges-apf        =    21
                     go to acc-tip-frn-154
           else if   w-prs-ges-apf        =    99
                     go to acc-tip-frn-156.
       acc-tip-frn-152.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per : Leasing          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Preparazione v-num                  *
      *                          *-------------------------------------*
           if        w-tes-tip-frn (1)    =    01
                     move  01             to   v-num
           else if   w-tes-tip-frn (1)    =    11
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
      *                          *-------------------------------------*
      *                          * A richiamo accettazione             *
      *                          *-------------------------------------*
           go to     acc-tip-frn-160.
       acc-tip-frn-154.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per: Gruppo d'Acquisto *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Preparazione v-num                  *
      *                          *-------------------------------------*
           if        w-tes-tip-frn (1)    =    01
                     move  01             to   v-num
           else if   w-tes-tip-frn (1)    =    21
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
      *                          *-------------------------------------*
      *                          * A richiamo accettazione             *
      *                          *-------------------------------------*
           go to     acc-tip-frn-160.
       acc-tip-frn-156.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per : Completa         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Preparazione v-num                  *
      *                          *-------------------------------------*
           if        w-tes-tip-frn (1)    =    01
                     move  01             to   v-num
           else if   w-tes-tip-frn (1)    =    11
                     move  02             to   v-num
           else if   w-tes-tip-frn (1)    =    21
                     move  03             to   v-num
           else      move  zero           to   v-num                  .
      *                          *-------------------------------------*
      *                          * A richiamo accettazione             *
      *                          *-------------------------------------*
           go to     acc-tip-frn-160.
       acc-tip-frn-160.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-tip-frn-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-tip-frn-999.
       acc-tip-frn-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del valore della     *
      *                  * personalizzazione                           *
      *                  *---------------------------------------------*
           if        w-prs-ges-apf        =    11
                     go to acc-tip-frn-202
           else if   w-prs-ges-apf        =    21
                     go to acc-tip-frn-204
           else if   w-prs-ges-apf        =    99
                     go to acc-tip-frn-206.
       acc-tip-frn-202.
      *                  *---------------------------------------------*
      *                  * Se gestione solo per : Leasing              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Spostamento da v-num                    *
      *                      *-----------------------------------------*
           if        v-num                =    01
                     move  01             to   w-tes-tip-frn (1)
           else if   v-num                =    02
                     move  11             to   w-tes-tip-frn (1)
           else      move  zero           to   w-tes-tip-frn (1)      .
      *                      *-----------------------------------------*
      *                      * A controllo valore impostato            *
      *                      *-----------------------------------------*
           go to     acc-tip-frn-400.
       acc-tip-frn-204.
      *                  *---------------------------------------------*
      *                  * Se gestione solo per : Gruppo d'Acquisto    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Spostamento da v-num                    *
      *                      *-----------------------------------------*
           if        v-num                =    01
                     move  01             to   w-tes-tip-frn (1)
           else if   v-num                =    02
                     move  21             to   w-tes-tip-frn (1)
           else      move  zero           to   w-tes-tip-frn (1)      .
      *                      *-----------------------------------------*
      *                      * A controllo valore impostato            *
      *                      *-----------------------------------------*
           go to     acc-tip-frn-400.
       acc-tip-frn-206.
      *                  *---------------------------------------------*
      *                  * Se gestione solo per : Completa             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Spostamento da v-num                    *
      *                      *-----------------------------------------*
           if        v-num                =    01
                     move  01             to   w-tes-tip-frn (1)
           else if   v-num                =    02
                     move  11             to   w-tes-tip-frn (1)
           else if   v-num                =    03
                     move  21             to   w-tes-tip-frn (1)
           else      move  zero           to   w-tes-tip-frn (1)      .
      *                      *-----------------------------------------*
      *                      * A controllo valore impostato            *
      *                      *-----------------------------------------*
           go to     acc-tip-frn-400.
       acc-tip-frn-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se zero : reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-tes-tip-frn (1)    not  = zero
                     go to acc-tip-frn-600.
           if        v-key                =    "UP  "
                     go to acc-tip-frn-600
           else      go to acc-tip-frn-100.
       acc-tip-frn-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-tip-frn-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-tip-frn-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-tip-frn-100.
       acc-tip-frn-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Tipo fornitura            *
      *    *-----------------------------------------------------------*
       vis-tip-frn-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da trattare                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se personalizzazione lo prevede    *
      *                      *-----------------------------------------*
           if        w-prs-ges-apf        not  = 11 and
                     w-prs-ges-apf        not  = 21 and
                     w-prs-ges-apf        not  = 99
                     go to vis-tip-frn-999.
       vis-tip-frn-050.
      *                  *---------------------------------------------*
      *                  * Preparazione Pop-Up di accettazione in fun- *
      *                  * zione della personalizzazione               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del valore della *
      *                      * personalizzazione                       *
      *                      *-----------------------------------------*
           if        w-prs-ges-apf        =    11
                     go to vis-tip-frn-052
           else if   w-prs-ges-apf        =    21
                     go to vis-tip-frn-054
           else if   w-prs-ges-apf        =    99
                     go to vis-tip-frn-056.
       vis-tip-frn-052.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per : Leasing          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Aggiustamento numero elementi del   *
      *                          * Pop-Up                              *
      *                          *-------------------------------------*
           move      02                   to   w-exp-tip-frn-num      .
      *                          *-------------------------------------*
      *                          * A visualizzazione                   *
      *                          *-------------------------------------*
           go to     vis-tip-frn-100.
       vis-tip-frn-054.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per: Gruppo d'Acquisto *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Aggiustamento numero elementi del   *
      *                          * Pop-Up                              *
      *                          *-------------------------------------*
           move      02                   to   w-exp-tip-frn-num      .
      *                          *-------------------------------------*
      *                          * Shift del terzo elemento sul secon- *
      *                          * do                                  *
      *                          *-------------------------------------*
           move      w-exp-tip-frn-ele (03)
                                          to   w-exp-tip-frn-ele (02) .
      *                          *-------------------------------------*
      *                          * A visualizzazione                   *
      *                          *-------------------------------------*
           go to     vis-tip-frn-100.
       vis-tip-frn-056.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per : Completa         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * A visualizzazione                   *
      *                          *-------------------------------------*
           go to     vis-tip-frn-100.
       vis-tip-frn-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Parametri di visualizzazione                *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-frn-lun    to   v-car                  .
           move      w-exp-tip-frn-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      20                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      w-exp-tip-frn-tbl    to   v-txt                  .
       vis-tip-frn-150.
      *                  *---------------------------------------------*
      *                  * Valore di visualizzazione                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del valore della *
      *                      * personalizzazione                       *
      *                      *-----------------------------------------*
           if        w-prs-ges-apf        =    11
                     go to vis-tip-frn-152
           else if   w-prs-ges-apf        =    21
                     go to vis-tip-frn-154
           else if   w-prs-ges-apf        =    99
                     go to vis-tip-frn-156.
       vis-tip-frn-152.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per : Leasing          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Preparazione v-num                  *
      *                          *-------------------------------------*
           if        w-tes-tip-frn (1)    =    01
                     move  01             to   v-num
           else if   w-tes-tip-frn (1)    =    11
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
      *                          *-------------------------------------*
      *                          * A richiamo visualizzazione          *
      *                          *-------------------------------------*
           go to     vis-tip-frn-160.
       vis-tip-frn-154.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per: Gruppo d'Acquisto *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Preparazione v-num                  *
      *                          *-------------------------------------*
           if        w-tes-tip-frn (1)    =    01
                     move  01             to   v-num
           else if   w-tes-tip-frn (1)    =    21
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
      *                          *-------------------------------------*
      *                          * A richiamo visualizzazione          *
      *                          *-------------------------------------*
           go to     vis-tip-frn-160.
       vis-tip-frn-156.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per : Completa         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Preparazione v-num                  *
      *                          *-------------------------------------*
           if        w-tes-tip-frn (1)    =    01
                     move  01             to   v-num
           else if   w-tes-tip-frn (1)    =    11
                     move  02             to   v-num
           else if   w-tes-tip-frn (1)    =    21
                     move  03             to   v-num
           else      move  zero           to   v-num                  .
      *                          *-------------------------------------*
      *                          * A richiamo visualizzazione          *
      *                          *-------------------------------------*
           go to     vis-tip-frn-160.
       vis-tip-frn-160.
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tip-frn-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Si/no ordine da verificare           *
      *    *-----------------------------------------------------------*
       acc-snx-oav-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se personalizzazione lo prevede    *
      *                      *-----------------------------------------*
           if        w-prs-snx-oav-snx    =    "N"
                     go to acc-snx-oav-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-flg-nbx (1, 1)
                                          to   w-sav-snx-oav          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-snx-oav-400.
       acc-snx-oav-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-snx-oav-lun    to   v-car                  .
           move      w-exp-snx-oav-lun    to   v-car                  .
           move      w-exp-snx-oav-num    to   v-ldt                  .
           move      "DE#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      21                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      w-exp-snx-oav-tbl    to   v-txt                  .
      *
           if        w-tes-flg-nbx (1, 1) =    "#"
                     move  1              to   v-num
           else if   w-tes-flg-nbx (1, 1) =    spaces
                     move  2              to   v-num
           else      move  zero           to   v-num                  .
      *
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-snx-oav-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-snx-oav-999.
       acc-snx-oav-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    1
                     move  "#"            to   w-tes-flg-nbx (1, 1)
           else if   v-num                =    2
                     move  spaces         to   w-tes-flg-nbx (1, 1)
           else      move  spaces         to   w-tes-flg-nbx (1, 1)   .
       acc-snx-oav-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-snx-oav-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-flg-nbx (1, 1) =    w-sav-snx-oav
                     go to acc-snx-oav-800.
      *                  *---------------------------------------------*
      *                  * Ricalcolo indicatore in riga di ordine da   *
      *                  * verificare                                  *
      *                  *---------------------------------------------*
           perform   rcl-oav-rig-000      thru rcl-oav-rig-999        .
       acc-snx-oav-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-snx-oav-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-snx-oav-100.
       acc-snx-oav-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Si/no ordine da verificare        *
      *    *-----------------------------------------------------------*
       vis-snx-oav-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-prs-snx-oav-snx    =    "N"
                     go to vis-snx-oav-999.
       vis-snx-oav-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione valore                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-snx-oav-lun    to   v-car                  .
           move      w-exp-snx-oav-num    to   v-ldt                  .
           move      "DE#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      21                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      w-exp-snx-oav-tbl    to   v-txt                  .
      *
           if        w-tes-flg-nbx (1, 1) =    "#"
                     move  1              to   v-num
           else if   w-tes-flg-nbx (1, 1) =    spaces
                     move  2              to   v-num
           else      move  zero           to   v-num                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-snx-oav-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Indicatore di invio tramite mail  *
      *    *-----------------------------------------------------------*
       vis-inv-eml-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Solo in modifica o visualizzazione          *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "I"
                     go to vis-inv-eml-999.
      *                  *---------------------------------------------*
      *                  * Solo se contatore maggiore di zero          *
      *                  *---------------------------------------------*
           if        w-det-prt-eml-ele    not  > zero
                     go to vis-inv-eml-999.
       vis-inv-eml-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompt                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      71                   to   v-pos                  .
           move      "Mail :"             to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione valore                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      21                   to   v-lin                  .
           move      78                   to   v-pos                  .
           move      "<B"                 to   v-edm                  .
           move      w-det-prt-eml-ele    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-inv-eml-999.
           exit.

      *    *===========================================================*
      *    * Trattamento archivio per fatturazione                     *
      *    *-----------------------------------------------------------*
       trt-arc-plf-000.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del tipo fornitura         *
      *              *-------------------------------------------------*
           if        w-tes-tip-frn (1)    =    01
                     go to trt-arc-plf-200
           else if   w-tes-tip-frn (1)    =    11
                     go to trt-arc-plf-400
           else if   w-tes-tip-frn (1)    =    21
                     go to trt-arc-plf-600
           else      go to trt-arc-plf-999.
       trt-arc-plf-200.
      *              *-------------------------------------------------*
      *              * Tipo fornitura : Diretta                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Forzatura dei valori relativi al cliente    *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-tes-arc-plf (1)      .
           move      w-tes-dpz-arc (1)    to   w-tes-dpz-plf (1)      .
           go to     trt-arc-plf-999.
       trt-arc-plf-400.
      *              *-------------------------------------------------*
      *              * Tipo fornitura : Tramite Leasing                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Nessuna azione                              *
      *                  *---------------------------------------------*
           go to     trt-arc-plf-999.
       trt-arc-plf-600.
      *              *-------------------------------------------------*
      *              * Tipo fornitura : Tramite Gruppo d'Acquisto      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore gia' presente : nessuna azione    *
      *                  *---------------------------------------------*
           if        w-tes-arc-plf (1)    not  = zero
                     go to trt-arc-plf-999.
      *                  *---------------------------------------------*
      *                  * Preparazione default da anagrafica commer-  *
      *                  * ciale                                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura record [dcc] principale del     *
      *                      * cliente commerciale                     *
      *                      *-----------------------------------------*
           move      w-tes-cod-arc (1)    to   w-let-arc-dcc-cli      .
           move      spaces               to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione codice e dipendenza ar- *
      *                      * chivio per fatturazione                 *
      *                      *-----------------------------------------*
           move      w-let-arc-dcc-apf    to   w-tes-arc-plf (1)      .
           move      w-let-arc-dcc-dpf    to   w-tes-dpz-plf (1)      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione tipo fatturazione       *
      *                      *-----------------------------------------*
           move      w-let-arc-dcc-tfz    to   w-tes-tip-ftz (1)      .
       trt-arc-plf-610.
      *                      *-----------------------------------------*
      *                      * Lettura record [cli] del cliente per    *
      *                      * fatturazione associato al cliente com-  *
      *                      * merciale                                *
      *                      *-----------------------------------------*
           move      w-tes-arc-plf (1)    to   w-let-arc-cli-cod      .
           perform   let-arc-cli-000      thru let-arc-cli-999        .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione archivio    *
      *                      * per fatturazione                        *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-rag    to   w-tes-arc-plf-rag (1)  .
           move      w-let-arc-cli-via    to   w-tes-arc-plf-via (1)  .
           move      w-let-arc-cli-loc    to   w-tes-arc-plf-loc (1)  .
      *                      *-----------------------------------------*
      *                      * Lettura record [dcc] relativo alla di-  *
      *                      * pendenza dell'archivio per fatturazione *
      *                      * associato al cliente commerciale        *
      *                      *-----------------------------------------*
           move      w-tes-arc-plf (1)    to   w-let-arc-dcc-cli      .
           move      w-tes-dpz-plf (1)    to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione dipendenza  *
      *                      * dell'archivio per fatturazione associa- *
      *                      * to al cliente commerciale               *
      *                      *-----------------------------------------*
           move      w-let-arc-dcc-rag    to   w-tes-dpz-plf-rag (1)  .
           move      w-let-arc-dcc-via    to   w-tes-dpz-plf-via (1)  .
           move      w-let-arc-dcc-loc    to   w-tes-dpz-plf-loc (1)  .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     trt-arc-plf-999.
       trt-arc-plf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice archivio per fattura- *
      *    * zione                                                     *
      *    *-----------------------------------------------------------*
       acc-arc-plf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-fda-pt2 (1)    not  = spaces
                     go to acc-arc-plf-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-arc-plf (1)    to   w-sav-arc-plf          .
      *                  *---------------------------------------------*
      *                  * Se Tab in corso : a controllo valore impo-  *
      *                  * stato                                       *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-arc-plf-400.
       acc-arc-plf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-dcc-ope      .
           move      w-tes-arc-plf (1)    to   w-cod-mne-dcc-cod      .
           move      05                   to   w-cod-mne-dcc-lin      .
           move      30                   to   w-cod-mne-dcc-pos      .
           move      05                   to   w-cod-mne-dcc-rln      .
           move      41                   to   w-cod-mne-dcc-rps      .
           move      06                   to   w-cod-mne-dcc-vln      .
           move      41                   to   w-cod-mne-dcc-vps      .
           move      07                   to   w-cod-mne-dcc-lln      .
           move      41                   to   w-cod-mne-dcc-lps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-dcc-cll-000  thru cod-mne-dcc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-dcc-foi-000  thru cod-mne-dcc-foi-999    .
       acc-arc-plf-110.
           perform   cod-mne-dcc-cll-000  thru cod-mne-dcc-cll-999    .
           if        w-cod-mne-dcc-ope    =    "F+"
                     go to acc-arc-plf-115.
           if        w-cod-mne-dcc-ope    =    "AC"
                     go to acc-arc-plf-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-arc-plf-115.
           perform   cod-mne-dcc-foi-000  thru cod-mne-dcc-foi-999    .
           go to     acc-arc-plf-110.
       acc-arc-plf-120.
           move      w-cod-mne-dcc-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-arc-plf-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-arc-plf-999.
       acc-arc-plf-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-arc-plf (1)      .
       acc-arc-plf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Subroutine per controlli su cliente per la  *
      *                  * fatturazione                                *
      *                  *---------------------------------------------*
           move      w-tes-arc-plf (1)    to   w-ctl-cod-cli-cod      .
           perform   acc-arc-plf-ctl-000  thru acc-arc-plf-ctl-999    .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione cliente         *
      *                  *---------------------------------------------*
           perform   vis-arc-plf-des-000  thru vis-arc-plf-des-999    .
      *                  *---------------------------------------------*
      *                  * Controllo su flag di 'exit'                 *
      *                  *---------------------------------------------*
           if        w-ctl-cod-cli-ext    not  = spaces
                     go to acc-arc-plf-999.
      *                  *---------------------------------------------*
      *                  * Controllo su flag di errore                 *
      *                  *---------------------------------------------*
           if        w-ctl-cod-cli-flg    not  = spaces
                     go to acc-arc-plf-100.
       acc-arc-plf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazioni anche se valore attuale come *
      *                  * precedente                                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione valori testata indotti   *
      *                      * da record [dcc] principale              *
      *                      *-----------------------------------------*
           move      "F"                  to   w-det-vlt-dcc-tdt      .
           perform   det-vlt-dcc-000      thru det-vlt-dcc-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione funzionamento spese      *
      *                      *-----------------------------------------*
           move      "F"                  to   w-det-fun-spe-tdt      .
           perform   det-fun-spe-000      thru det-fun-spe-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione valori testata dipendenti*
      *                      * dall'inoltro pagamenti                  *
      *                      *-----------------------------------------*
           move      w-tes-dpz-plf (1)    to   w-det-vlt-ipg-dpz      .
           perform   det-vlt-ipg-000      thru det-vlt-ipg-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione valori testata associati *
      *                      * all'agente                              *
      *                      *-----------------------------------------*
           move      w-tes-dpz-plf (1)    to   w-det-vlt-age-dpz      .
           perform   det-vlt-age-000      thru det-vlt-age-999        .
       acc-arc-plf-620.
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-arc-plf (1)    =    w-sav-arc-plf
                     go to acc-arc-plf-800.
      *                      *-----------------------------------------*
      *                      * Trattamento dipendenza                  *
      *                      *-----------------------------------------*
           if        w-tes-dpz-plf (1)    =    spaces
                     go to acc-arc-plf-610.
      *                          *-------------------------------------*
      *                          * Normalizzazione e rivisualizzazione *
      *                          *-------------------------------------*
           move      spaces               to   w-tes-dpz-plf (1)      .
           move      spaces               to   w-tes-dpz-plf-rag (1)  .
           move      spaces               to   w-tes-dpz-plf-via (1)  .
           move      spaces               to   w-tes-dpz-plf-loc (1)  .
           perform   vis-dpz-plf-000      thru vis-dpz-plf-999        .
           perform   vis-dpz-plf-des-000  thru vis-dpz-plf-des-999    .
      *                          *-------------------------------------*
      *                          * Normalizzazione dati testata asso-  *
      *                          * ciati alla dipendenza               *
      *                          *-------------------------------------*
           move      zero                 to   w-tes-abi-dpz (1)      .
           move      spaces               to   w-tes-abi-dpz-den (1)  .
           move      zero                 to   w-tes-cab-dpz (1)      .
           move      spaces               to   w-tes-cab-dpz-den (1)  .
           move      spaces               to   w-tes-cca-dpz (1)      .
           move      zero                 to   w-tes-age-aad (1)      .
       acc-arc-plf-610.
      *                  *---------------------------------------------*
      *                  * Determinazione se presenti dipendenze per   *
      *                  * l'archivio per fatturazione                 *
      *                  *---------------------------------------------*
           move      w-tes-arc-plf (1)    to   w-det-snd-dcc-cli      .
           perform   det-snd-dcc-000      thru det-snd-dcc-999        .
           move      w-det-snd-dcc-snx    to   w-tes-arc-plf-snd (1)  .
       acc-arc-plf-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-arc-plf-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-arc-plf-100.
       acc-arc-plf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice cliente per fattura-  *
      *    * zione                                                     *
      *    *                                                           *
      *    * Controlli                                                 *
      *    *-----------------------------------------------------------*
       acc-arc-plf-ctl-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flags di uscita                 *
      *              *-------------------------------------------------*
           move      spaces               to   w-ctl-cod-cli-flg      .
           move      spaces               to   w-ctl-cod-cli-ext      .
       acc-arc-plf-ctl-100.
      *              *-------------------------------------------------*
      *              * Lettura file [cli]                              *
      *              *-------------------------------------------------*
           move      w-ctl-cod-cli-cod    to   w-let-arc-cli-cod      .
           perform   let-arc-cli-000      thru let-arc-cli-999        .
           move      w-let-arc-cli-rag    to   w-tes-arc-plf-rag (1)  .
           move      w-let-arc-cli-via    to   w-tes-arc-plf-via (1)  .
           move      w-let-arc-cli-loc    to   w-tes-arc-plf-loc (1)  .
           move      w-let-arc-cli-stc    to   w-tes-cod-arc-stc (1)  .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : ad uscita per con-  *
      *                  * trollo non superato senza messaggio di er-  *
      *                  * rore                                        *
      *                  *---------------------------------------------*
           if        w-let-arc-cli-flg    not  = spaces
                     go to acc-arc-plf-ctl-930.
       acc-arc-plf-ctl-120.
      *                  *---------------------------------------------*
      *                  * Controllo che cliente impostato sia diverso *
      *                  * da zero                                     *
      *                  *---------------------------------------------*
           if        w-ctl-cod-cli-cod    not  = zero
                     go to acc-arc-plf-ctl-130.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Cliente per fatturazione a zero non accettabile ! 
      -              "               "    to   w-err-box-err-msg      .
      *                      *-----------------------------------------*
      *                      * Ad uscita per controllo non superato    *
      *                      * con emissione messaggio di errore       *
      *                      *-----------------------------------------*
           go to     acc-arc-plf-ctl-920.
       acc-arc-plf-ctl-130.
      *                  *---------------------------------------------*
      *                  * Controllo che cliente impostato sia diverso *
      *                  * da quello principale                        *
      *                  *---------------------------------------------*
           if        w-ctl-cod-cli-cod    not  = w-tes-cod-arc (1)
                     go to acc-arc-plf-ctl-140.
      *                      *-----------------------------------------*
      *                      * Se fornitura tramite gruppo d'acquisto, *
      *                      * si ammette, solo in modifica, che il    *
      *                      * cliente per fatturazione sia pari a     *
      *                      * quello commerciale                      *
      *                      *-----------------------------------------*
           if        w-tes-tip-frn (1)    =    21  and
                     w-cnt-mfu-tip-fun    =    "M"
                     go to acc-arc-plf-ctl-140.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Cliente per fatturazione uguale a quello principal
      -              "e !            "    to   w-err-box-err-msg      .
      *                      *-----------------------------------------*
      *                      * Ad uscita per controllo non superato    *
      *                      * con emissione messaggio di errore       *
      *                      *-----------------------------------------*
           go to     acc-arc-plf-ctl-920.
       acc-arc-plf-ctl-140.
      *                  *---------------------------------------------*
      *                  * Test su codice sottoconto associato al      *
      *                  * cliente                                     *
      *                  *---------------------------------------------*
           if        w-tes-cod-arc-stc (1)
                                          not  = zero
                     go to acc-arc-plf-ctl-200.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Manca il sottoconto contabile per il cliente !    
      -              "               "    to   w-err-box-err-msg      .
      *                      *-----------------------------------------*
      *                      * Ad uscita per controllo non superato    *
      *                      * con emissione messaggio di errore       *
      *                      *-----------------------------------------*
           go to     acc-arc-plf-ctl-920.
       acc-arc-plf-ctl-200.
      *                  *---------------------------------------------*
      *                  * Lettura record [dcc] principale             *
      *                  *---------------------------------------------*
           move      w-ctl-cod-cli-cod    to   w-let-arc-dcc-cli      .
           move      spaces               to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                  *---------------------------------------------*
      *                  * Se lettura OK : oltre                       *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-flg    =    spaces
                     go to acc-arc-plf-ctl-300.
      *                      *-----------------------------------------*
      *                      * Altrimenti : messaggio di errore        *
      *                      *-----------------------------------------*
           move      "Manca l'anagrafica commerciale per il cliente     
      -              "               "    to   w-err-box-err-msg      .
      *                      *-----------------------------------------*
      *                      * Ad uscita per controllo non superato    *
      *                      * con emissione messaggio di errore       *
      *                      *-----------------------------------------*
           go to     acc-arc-plf-ctl-920.
       acc-arc-plf-ctl-300.
      *              *-------------------------------------------------*
      *              * Trattamento assoggettamento iva                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo assoggetta- *
      *                  * mento iva del cliente                       *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-tai    =    01
                     go to acc-arc-plf-ctl-320
           else if   w-let-arc-dcc-tai    =    02
                     go to acc-arc-plf-ctl-340
           else if   w-let-arc-dcc-tai    =    03
                     go to acc-arc-plf-ctl-360
           else if   w-let-arc-dcc-tai    =    04
                     go to acc-arc-plf-ctl-380.
       acc-arc-plf-ctl-320.
      *                  *---------------------------------------------*
      *                  * Tipo assoggettamento iva cliente : sempre   *
      *                  * soggetto ad iva                             *
      *                  *---------------------------------------------*
           move      zero                 to   w-tes-ass-iva (1)      .
           move      "Soggetto ad iva"    to   w-tes-ass-iva-des (1)  .
           go to     acc-arc-plf-ctl-400.
       acc-arc-plf-ctl-340.
      *                  *---------------------------------------------*
      *                  * Tipo assoggettamento iva cliente : sempre   *
      *                  * esente da iva                               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controllo che il codice iva in anagra-  *
      *                      * fica cliente sia un titolo di esenzione *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    >    2 and
                     w-edt-iva-cod-003    <    7
                     go to acc-arc-plf-ctl-345.
      *                          *-------------------------------------*
      *                          * Preparazione messaggio di errore    *
      *                          *-------------------------------------*
           move      "Assoggettamento iva errato in anagrafica cliente c
      -              "ontabile       "    to   w-err-box-err-msg      .
      *                          *-------------------------------------*
      *                          * Ad uscita per controllo non supera- *
      *                          * to con emissione messaggio di erro- *
      *                          * re                                  *
      *                          *-------------------------------------*
           go to     acc-arc-plf-ctl-920.
       acc-arc-plf-ctl-345.
      *                      *-----------------------------------------*
      *                      * Lettura tabella [codiva]                *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata                       *
      *                      *-----------------------------------------*
           if        w-let-arc-zci-flg    =    spaces
                     go to acc-arc-plf-ctl-350.
      *                          *-------------------------------------*
      *                          * Preparazione messaggio di errore    *
      *                          *-------------------------------------*
           move      "Assoggettamento iva non esistente in anagrafica cl
      -              "iente contabile"    to   w-err-box-err-msg      .
      *                          *-------------------------------------*
      *                          * Ad uscita per controllo non supera- *
      *                          * to con emissione messaggio di erro- *
      *                          * re                                  *
      *                          *-------------------------------------*
           go to     acc-arc-plf-ctl-920.
       acc-arc-plf-ctl-350.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione assoggettamento iva     *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-tes-ass-iva (1)      .
           move      w-let-arc-zci-des    to   w-tes-ass-iva-des (1)  .
           go to     acc-arc-plf-ctl-400.
       acc-arc-plf-ctl-360.
      *                  *---------------------------------------------*
      *                  * Tipo assoggettamento iva cliente : Cliente  *
      *                  * con plafond                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione relativa alla *
      *                      * gestione lettera d'intenti              *
      *                      *-----------------------------------------*
           if        w-prs-snx-lic        not  = "S"
                     go to acc-arc-plf-ctl-365.
      *                      *-----------------------------------------*
      *                      * Lettura record [lic]                    *
      *                      *-----------------------------------------*
           move      w-ctl-cod-cli-cod    to   w-let-arc-lic-cod      .
           perform   let-arc-lic-000      thru let-arc-lic-999        .
      *                      *-----------------------------------------*
      *                      * Se data documento non compresa tra data *
      *                      * riferimento iniziale e finale : si pro- *
      *                      * cede come per cliente sempre soggetto   *
      *                      *-----------------------------------------*
           if        w-tes-dat-doc        not  < w-let-arc-lic-dri and
                     w-tes-dat-doc        not  > w-let-arc-lic-drf
                     go to acc-arc-plf-ctl-365.
      *                          *-------------------------------------*
      *                          * Messaggio                           *
      *                          *-------------------------------------*
           move      "Il documento non ricade entro gli estremi della le
      -              "ttera d'intenti"    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                          *-------------------------------------*
      *                          * Si procede come per cliente sempre  *
      *                          * soggetto                            *
      *                          *-------------------------------------*
           go to     acc-arc-plf-ctl-320.
       acc-arc-plf-ctl-365.
      *                      *-----------------------------------------*
      *                      * Controllo che il codice iva in anagra-  *
      *                      * fica cliente sia un titolo di esenzione *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    >    2 and
                     w-edt-iva-cod-003    <    7
                     go to acc-arc-plf-ctl-370.
      *                          *-------------------------------------*
      *                          * Preparazione messaggio di errore    *
      *                          *-------------------------------------*
           move      "Assoggettamento iva errato in anagrafica cliente c
      -              "ontabile       "    to   w-err-box-err-msg      .
      *                          *-------------------------------------*
      *                          * Ad uscita per controllo non supera- *
      *                          * to con emissione messaggio di erro- *
      *                          * re                                  *
      *                          *-------------------------------------*
           go to     acc-arc-plf-ctl-920.
       acc-arc-plf-ctl-370.
      *                      *-----------------------------------------*
      *                      * Lettura tabella [codiva]                *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata                       *
      *                      *-----------------------------------------*
           if        w-let-arc-zci-flg    =    spaces
                     go to acc-arc-plf-ctl-375.
      *                          *-------------------------------------*
      *                          * Preparazione messaggio di errore    *
      *                          *-------------------------------------*
           move      "Assoggettamento iva non esistente in anagrafica cl
      -              "iente contabile"    to   w-err-box-err-msg      .
      *                          *-------------------------------------*
      *                          * Ad uscita per controllo non supera- *
      *                          * to con emissione messaggio di erro- *
      *                          * re                                  *
      *                          *-------------------------------------*
           go to     acc-arc-plf-ctl-920.
       acc-arc-plf-ctl-375.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione assoggettamento iva     *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-tes-ass-iva (1)      .
           move      w-let-arc-zci-des    to   w-tes-ass-iva-des (1)  .
           go to     acc-arc-plf-ctl-400.
       acc-arc-plf-ctl-380.
      *                  *---------------------------------------------*
      *                  * Tipo assoggettamento iva cliente : Cliente  *
      *                  * in regime di Scissione Pagamenti            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Assoggettamento Iva                     *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-ass-iva (1)      .
      *                      *-----------------------------------------*
      *                      * Segnale di Scissione Pagamenti          *
      *                      *-----------------------------------------*
           move      "S"                  to   w-tes-ass-iva-spl (1)  .
      *                      *-----------------------------------------*
      *                      * Dicitura per aliquota Iva               *
      *                      *-----------------------------------------*
           move      "Scissione Pagamenti"
                                          to   w-tes-ass-iva-des (1)  .
      *                      *-----------------------------------------*
      *                      * Nessun controllo in questa fase         *
      *                      *-----------------------------------------*
           go to     acc-arc-plf-ctl-400.
       acc-arc-plf-ctl-400.
      *                  *---------------------------------------------*
      *                  * Test su segnale di ordini bloccati          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Solo se in inserimento                  *
      *                      *-----------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-arc-plf-ctl-800.
      *                      *-----------------------------------------*
      *                      * Test su flag letto da [dcc]             *
      *                      *-----------------------------------------*
           if        w-let-arc-dcc-obl    not  = 02
                     go to acc-arc-plf-ctl-500.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "ATTENZIONE : Cliente con ordini bloccati !        
      -              "               "    to   w-err-box-err-msg      .
      *                      *-----------------------------------------*
      *                      * A seconda della personalizzazione rela- *
      *                      * tiva alla modalita' di blocco del cli-  *
      *                      * ente si prosegue, oppure si esce simu-  *
      *                      * lando il tasto Exit                     *
      *                      *-----------------------------------------*
           if        w-prs-blo-cli-t01    =    "B"
                     go to acc-arc-plf-ctl-920
           else      go to acc-arc-plf-ctl-910.
       acc-arc-plf-ctl-500.
      *                  *---------------------------------------------*
      *                  * Test su tipo documento preferenziale        *
      *                  *---------------------------------------------*
       acc-arc-plf-ctl-600.
      *                  *---------------------------------------------*
      *                  * Test su status commerciale del cliente      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se status normale : ad uscita           *
      *                      *-----------------------------------------*
           if        w-let-arc-dcc-tus    =    01 or
                     w-let-arc-dcc-tus    =    09
                     go to acc-arc-plf-ctl-800.
      *                      *-----------------------------------------*
      *                      * Se status non normale : box specifico   *
      *                      * per lo status commerciale               *
      *                      *-----------------------------------------*
           perform   acc-arc-plf-bsc-000  thru acc-arc-plf-bsc-999    .
      *                      *-----------------------------------------*
      *                      * Ad uscita per controllo non superato    *
      *                      * ma senza emissione messaggio di errore  *
      *                      *-----------------------------------------*
           go to     acc-arc-plf-ctl-930.
       acc-arc-plf-ctl-800.
      *              *-------------------------------------------------*
      *              * Uscita per controlli superati                   *
      *              *-------------------------------------------------*
           go to     acc-arc-plf-ctl-999.
       acc-arc-plf-ctl-900.
      *              *-------------------------------------------------*
      *              * Uscita per controlli non superati o per emis-   *
      *              * sione messaggio di errore                       *
      *              *-------------------------------------------------*
       acc-arc-plf-ctl-910.
      *                  *---------------------------------------------*
      *                  * Uscita con solo messaggio di errore         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Box di errore                           *
      *                      *-----------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     acc-arc-plf-ctl-999.
       acc-arc-plf-ctl-920.
      *                  *---------------------------------------------*
      *                  * Uscita con messaggio di errore e flag di    *
      *                  * errore                                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Box di errore                           *
      *                      *-----------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
       acc-arc-plf-ctl-930.
      *                  *---------------------------------------------*
      *                  * Uscita con flag di errore                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di uscita                          *
      *                      *-----------------------------------------*
           move      "#"                  to   w-ctl-cod-cli-flg      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     acc-arc-plf-ctl-999.
       acc-arc-plf-ctl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice cliente per fattura-  *
      *    * zione                                                     *
      *    *                                                           *
      *    * Box di errore emesso in funzione dello status commerciale *
      *    * del cliente, se diverso da 'normale'                      *
      *    *-----------------------------------------------------------*
       acc-arc-plf-bsc-000.
      *              *-------------------------------------------------*
      *              * Messaggio di errore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio del video attuale               *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      20                   to   v-lto                  .
           move      08                   to   v-pos                  .
           move      73                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-arc-plf-bsc-200.
      *                  *---------------------------------------------*
      *                  * Messaggi entro il box                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Titolo centrale                         *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "                     A T T E N Z I O N E          
      -              "            "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 1                        *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "Per il cliente impostato si rileva la seguente con
      -              "dizione :   "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Preparazione riga messaggio 2           *
      *                      *-----------------------------------------*
           if        w-let-arc-dcc-tus    =    11
                     move  "[Esauriti i rapporti commerciali]           
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    21
                     move  "[Sostituito da ns. nuovo cliente]           
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    51
                     move  "[Cessata attivita']                         
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    52
                     move  "[Cessata attivita', ma sostituito da ns. nuo
      -                    "vo cliente]       "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    61
                     move  "[In contenzioso]                            
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    62
                     move  "[In contenzioso, ma sostituito da ns. nuovo 
      -                    "cliente]          "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    71
                     move  "[Fallito]                                   
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    72
                     move  "[Fallito, ma sostituito da ns. nuovo cliente
      -                    "]                 "
                                          to   v-alf
           else      move  "(status non determinato)                    
      -                    "                  "
                                          to   v-alf                  .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 2                        *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      10                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 3                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da emettere                 *
      *                          *-------------------------------------*
           if        w-let-arc-dcc-tud    =    zero
                     go to acc-arc-plf-bsc-300.
      *                          *-------------------------------------*
      *                          * Emissione                           *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "La determinazione di tale condizione risale al :  
      -              "            "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Data di rilevamento status          *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      15                   to   v-lin                  .
           move      59                   to   v-pos                  .
           move      w-let-arc-dcc-tud    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-arc-plf-bsc-300.
      *                      *-----------------------------------------*
      *                      * Righe messaggio 4 e 5                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da emettere                 *
      *                          *-------------------------------------*
           if        w-let-arc-dcc-tuc    =    zero
                     go to acc-arc-plf-bsc-600.
      *                          *-------------------------------------*
      *                          * Emissione                           *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "Il cliente utilizzabile in alternativa e' il segue
      -              "nte :       "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Codice cliente alternativo          *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      19                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      w-let-arc-dcc-tuc    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Lettura descrizione per il cliente  *
      *                          * alternativo                         *
      *                          *-------------------------------------*
           move      w-let-arc-dcc-tuc    to   w-let-arc-cli-cod      .
           perform   let-arc-cli-000      thru let-arc-cli-999        .
           if        w-let-arc-cli-flg    not  = spaces
                     move  all "."        to   v-alf
           else      move  w-let-arc-cli-rag
                                          to   v-alf                  .
      *                          *-------------------------------------*
      *                          * Emissione                           *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      20                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-arc-plf-bsc-600.
      *                      *-----------------------------------------*
      *                      * Prompt per presa visione                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      69                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-arc-plf-bsc-800.
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      19                   to   v-lin                  .
           move      70                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-arc-plf-bsc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice archivio per fat-  *
      *    * turazione                                                 *
      *    *-----------------------------------------------------------*
       vis-arc-plf-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<B"                 to   v-edm                  .
           move      w-tes-arc-plf (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-arc-plf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione archivio per  *
      *    * fatturazione                                              *
      *    *-----------------------------------------------------------*
       vis-arc-plf-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-arc-plf-rag (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-arc-plf-via (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-arc-plf-loc (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-arc-plf-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Dipendenza archivio per fat- *
      *    * turazione                                                 *
      *    *-----------------------------------------------------------*
       acc-dpz-plf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test  se campo da accettare                 *
      *                  *---------------------------------------------*
           if        w-tes-arc-plf-snd (1)
                                          =    "N"
                     go to acc-dpz-plf-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-dpz-plf (1)    to   w-sav-dpz-plf          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-dpz-plf-400.
       acc-dpz-plf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-dcc-ope      .
           move      w-tes-arc-plf (1)    to   w-cod-cod-dcc-cli      .
           move      w-tes-dpz-plf (1)    to   w-cod-cod-dcc-cod      .
           move      09                   to   w-cod-cod-dcc-lin      .
           move      30                   to   w-cod-cod-dcc-pos      .
           move      09                   to   w-cod-cod-dcc-rln      .
           move      41                   to   w-cod-cod-dcc-rps      .
           move      10                   to   w-cod-cod-dcc-vln      .
           move      41                   to   w-cod-cod-dcc-vps      .
           move      11                   to   w-cod-cod-dcc-lln      .
           move      41                   to   w-cod-cod-dcc-lps      .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-dcc-cll-000  thru cod-cod-dcc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-dcc-foi-000  thru cod-cod-dcc-foi-999    .
       acc-dpz-plf-110.
           perform   cod-cod-dcc-cll-000  thru cod-cod-dcc-cll-999    .
           if        w-cod-cod-dcc-ope    =    "F+"
                     go to acc-dpz-plf-115.
           if        w-cod-cod-dcc-ope    =    "AC"
                     go to acc-dpz-plf-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-dpz-plf-115.
           perform   cod-cod-dcc-foi-000  thru cod-cod-dcc-foi-999    .
           go to     acc-dpz-plf-110.
       acc-dpz-plf-120.
           move      w-cod-cod-dcc-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-dpz-plf-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-dpz-plf-999.
       acc-dpz-plf-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-dpz-plf (1)      .
       acc-dpz-plf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura file [dcc]                          *
      *                  *---------------------------------------------*
           move      w-tes-arc-plf (1)    to   w-let-arc-dcc-cli      .
           move      w-tes-dpz-plf (1)    to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           move      w-let-arc-dcc-rag    to   w-tes-dpz-plf-rag (1)  .
           move      w-let-arc-dcc-via    to   w-tes-dpz-plf-via (1)  .
           move      w-let-arc-dcc-loc    to   w-tes-dpz-plf-loc (1)  .
           perform   vis-dpz-plf-des-000  thru vis-dpz-plf-des-999    .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-flg    not  = spaces
                     go to acc-dpz-plf-100.
       acc-dpz-plf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-dpz-plf (1)    =    w-sav-dpz-plf
                     go to acc-dpz-plf-800.
      *                      *-----------------------------------------*
      *                      * Eventuale normalizzazione valore per i- *
      *                      * noltro pagamenti                        *
      *                      *-----------------------------------------*
           if        w-tes-dpz-plf (1)    =    spaces and
                     w-tes-inl-pgt (1)    =    03
                     move  02             to   w-tes-inl-pgt (1)      .
      *                      *-----------------------------------------*
      *                      * Determinazione funzionamento spese      *
      *                      *-----------------------------------------*
           move      "F"                  to   w-det-fun-spe-tdt      .
           perform   det-fun-spe-000      thru det-fun-spe-999        .
      *                      *-----------------------------------------*
      *                      * Valori testata indotti da record [dcc]  *
      *                      * relativo alla dipendenza                *
      *                      *-----------------------------------------*
           move      "F"                  to   w-det-vlt-dcd-tdt      .
           move      w-tes-dpz-plf (1)    to   w-det-vlt-dcd-dpz      .
           perform   det-vlt-dcd-000      thru det-vlt-dcd-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione valori testata dipendenti*
      *                      * dall'inoltro pagamenti                  *
      *                      *-----------------------------------------*
           move      w-tes-dpz-plf (1)    to   w-det-vlt-ipg-dpz      .
           perform   det-vlt-ipg-000      thru det-vlt-ipg-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione valori testata associati *
      *                      * all'agente                              *
      *                      *-----------------------------------------*
           move      w-tes-dpz-plf (1)    to   w-det-vlt-age-dpz      .
           perform   det-vlt-age-000      thru det-vlt-age-999        .
       acc-dpz-plf-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-dpz-plf-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-dpz-plf-100.
       acc-dpz-plf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Dipendenza archivio per   *
      *    * fatturazione                                              *
      *    *-----------------------------------------------------------*
       vis-dpz-plf-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-dpz-plf (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dpz-plf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione dipendenza    *
      *    * archivio per la fatturazione                              *
      *    *-----------------------------------------------------------*
       vis-dpz-plf-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-dpz-plf-rag (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-dpz-plf-via (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-dpz-plf-loc (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dpz-plf-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Tipo fatturazione            *
      *    *-----------------------------------------------------------*
       acc-tip-ftz-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da trattare                   *
      *                  *---------------------------------------------*
           if        w-tes-tip-frn (1)    not  = 21
                     go to acc-tip-ftz-999.
      *                  *---------------------------------------------*
      *                  * Preparazione eventuale default              *
      *                  *---------------------------------------------*
           if        w-tes-tip-ftz (1)    not  = zero
                     go to acc-tip-ftz-050.
           move      01                   to   w-tes-tip-ftz (1)      .
           perform   vis-tip-ftz-000      thru vis-tip-ftz-999        .
       acc-tip-ftz-050.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-tip-ftz-400.
       acc-tip-ftz-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-ftz-lun    to   v-car                  .
           move      w-exp-tip-ftz-num    to   v-ldt                  .
           move      "SC#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      13                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-tip-ftz-tbl    to   v-txt                  .
           move      w-tes-tip-ftz (1)    to   v-num                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-tip-ftz-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-tip-ftz-999.
       acc-tip-ftz-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-tip-ftz (1)      .
       acc-tip-ftz-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammeso, a meno che non si *
      *                  * sia in Up                                   *
      *                  *---------------------------------------------*
           if        w-tes-tip-ftz (1)    not  = zero
                     go to acc-tip-ftz-600.
           if        v-key                =    "UP  "
                     go to acc-tip-ftz-600
           else      go to acc-tip-ftz-100.
       acc-tip-ftz-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-tip-ftz-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-tip-ftz-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-tip-ftz-100.
       acc-tip-ftz-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Tipo fatturazione         *
      *    *-----------------------------------------------------------*
       vis-tip-ftz-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da trattare                   *
      *                  *---------------------------------------------*
           if        w-tes-tip-frn (1)    not  = 21
                     go to vis-tip-ftz-999.
       vis-tip-ftz-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione valore                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-ftz-lun    to   v-car                  .
           move      w-exp-tip-ftz-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      13                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-tip-ftz-tbl    to   v-txt                  .
           move      w-tes-tip-ftz (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tip-ftz-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Data ordine cliente          *
      *    *-----------------------------------------------------------*
       acc-ocl-dat-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
           if        w-tes-ocl-dat (1)    not  = zero
                     go to acc-ocl-dat-050.
      *                      *-----------------------------------------*
      *                      * Forzatura da data documento             *
      *                      *-----------------------------------------*
           move      w-tes-dat-doc        to   w-tes-ocl-dat (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-ocl-dat-000      thru vis-ocl-dat-999        .
       acc-ocl-dat-050.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-ocl-dat (1)    to   w-sav-ocl-dat          .
      *                  *---------------------------------------------*
      *                  * Se Tab in corso : a controllo valore impo-  *
      *                  * stato                                       *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-ocl-dat-400.
       acc-ocl-dat-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-ocl-dat (1)    to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-ocl-dat-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-ocl-dat-999.
       acc-ocl-dat-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-dat                to   w-tes-ocl-dat (1)      .
       acc-ocl-dat-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-ocl-dat-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-tes-ocl-dat (1)    =    w-sav-ocl-dat
                     go to acc-ocl-dat-800.
      *                      *-----------------------------------------*
      *                      * Box di avvertimento                     *
      *                      *-----------------------------------------*
           move      "Attenzione, la variazione della data ordine client
      -              "e, non avra'   "    to   w-err-box-err-msg      .
           move      "alcuna ripercussione sui prezzi presenti nelle rig
      -              "he documento ! "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       acc-ocl-dat-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-ocl-dat-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-ocl-dat-100.
       acc-ocl-dat-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Data ordine cliente       *
      *    *-----------------------------------------------------------*
       vis-ocl-dat-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-ocl-dat (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ocl-dat-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Numero ordine cliente        *
      *    *-----------------------------------------------------------*
       acc-ocl-num-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-ocl-num (1)    to   w-sav-ocl-num          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-ocl-num-400.
       acc-ocl-num-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-ocl-num (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-ocl-num-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-ocl-num-999.
       acc-ocl-num-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-ocl-num (1)      .
       acc-ocl-num-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se personalizzazione                   *
      *                  *---------------------------------------------*
           if        w-prs-cnt-rif        not  = "S"
                     go to acc-ocl-num-600.
      *                  *---------------------------------------------*
      *                  * Test se in inserimento                      *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-ocl-num-600.
      *                  *---------------------------------------------*
      *                  * Test se valore attuale come precedente      *
      *                  *---------------------------------------------*
           if        w-tes-ocl-num (1)    =    w-sav-ocl-num
                     go to acc-ocl-num-600.
      *                  *---------------------------------------------*
      *                  * Controllo se il numero ordine cliente e'    *
      *                  * gia' stato inserito nell'anno in corso      *
      *                  *---------------------------------------------*
           move      w-tes-cod-dpz        to   w-ctl-rif-arc-dpz      .
           move      w-tes-cod-arc (1)    to   w-ctl-rif-arc-cli      .
           move      w-tes-dat-doc        to   w-ctl-rif-arc-dat      .
           move      w-tes-ocl-num (1)    to   w-ctl-rif-arc-num      .
           perform   ctl-rif-arc-000      thru ctl-rif-arc-999        .
      *                  *---------------------------------------------*
      *                  * Test su esito controllo                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-ctl-rif-arc-flg    =    spaces
                     go to acc-ocl-num-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di avviso                     *
      *                      *-----------------------------------------*
           move      "Numero ordine cliente gia' inserito !             
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
       acc-ocl-num-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ocl-num-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-ocl-num-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-ocl-num-100.
       acc-ocl-num-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Numero ordine cliente     *
      *    *-----------------------------------------------------------*
       vis-ocl-num-000.
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-ocl-num (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ocl-num-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Riferimenti ordine cliente   *
      *    *-----------------------------------------------------------*
       acc-ocl-rif-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-ocl-rif-400.
       acc-ocl-rif-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-ocl-rif (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-ocl-rif-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-ocl-rif-999.
       acc-ocl-rif-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-ocl-rif (1)      .
       acc-ocl-rif-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * In presenza di 'CIG' o 'CUP' si controlla   *
      *                  * la presenza di '#'                          *
      *                  *---------------------------------------------*
           if        w-tes-ocl-rif (1)
                    (01 : 04)             not = "CIG:" and
                     w-tes-ocl-rif (1)
                    (01 : 04)             not = "CUP:" and
                     w-tes-ocl-rif (1)
                    (01 : 04)             not = "cig:" and
                     w-tes-ocl-rif (1)
                    (01 : 04)             not = "cup:"
                     go to  acc-ocl-rif-600.
      *                  *---------------------------------------------*
      *                  * Controllo                                   *
      *                  *---------------------------------------------*
           move      w-tes-ocl-rif (1)    to   w-all-str-alf          .
           move      "#"                  to   w-all-str-del          .
           perform   all-str-chr-000      thru all-str-chr-999        .
           if        w-all-str-num        not  = zero
                     go to  acc-ocl-rif-600.
      *                  *---------------------------------------------*
      *                  * Messaggio di avviso                         *
      *                  *---------------------------------------------*
           move      "Verificare la presenza del carattere '#'. I format
      -              "i accettati :   "   to   w-err-box-err-msg      .
           move      "'CIG:9999999#' oppure 'CUP:9999999#' o 'CIG:999999
      -              "9#CUP:9999999'  "   to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       acc-ocl-rif-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ocl-rif-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-ocl-rif-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-ocl-rif-100.
       acc-ocl-rif-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Riferimenti ordine cliente*
      *    *-----------------------------------------------------------*
       vis-ocl-rif-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-ocl-rif (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ocl-rif-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice responsabile ordine   *
      *    *-----------------------------------------------------------*
       acc-cod-rsp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-rsp-400.
       acc-cod-rsp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zro-ope      .
           move      w-tes-cod-rsp (1)    to   w-cod-mne-zro-cod      .
           move      09                   to   w-cod-mne-zro-lin      .
           move      30                   to   w-cod-mne-zro-pos      .
           move      09                   to   w-cod-mne-zro-dln      .
           move      37                   to   w-cod-mne-zro-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-zro-cll-000  thru cod-mne-zro-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zro-foi-000  thru cod-mne-zro-foi-999    .
       acc-cod-rsp-110.
           perform   cod-mne-zro-cll-000  thru cod-mne-zro-cll-999    .
           if        w-cod-mne-zro-ope    =    "F+"
                     go to acc-cod-rsp-115.
           if        w-cod-mne-zro-ope    =    "AC"
                     go to acc-cod-rsp-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-rsp-115.
           perform   cod-mne-zro-foi-000  thru cod-mne-zro-foi-999    .
           go to     acc-cod-rsp-110.
       acc-cod-rsp-120.
           move      w-cod-mne-zro-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-rsp-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-rsp-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-rsp (1)      .
       acc-cod-rsp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella [zro]                       *
      *                  *---------------------------------------------*
           move      w-tes-cod-rsp (1)    to   w-let-arc-zro-cod      .
           perform   let-arc-zro-000      thru let-arc-zro-999        .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valore letto                *
      *                  *---------------------------------------------*
           move      w-let-arc-zro-des    to   w-tes-cod-rsp-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-cod-rsp-des-000  thru vis-cod-rsp-des-999    .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso                       *
      *                  *---------------------------------------------*
           if        w-let-arc-zro-flg    =    spaces
                     go to acc-cod-rsp-600.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "Responsabile ordine non esistente !               
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-rsp-100.
       acc-cod-rsp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-rsp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-rsp-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-rsp-100.
       acc-cod-rsp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice responsabile or-   *
      *    * dine                                                      *
      *    *-----------------------------------------------------------*
       vis-cod-rsp-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      09                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-rsp (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-rsp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione responsabile  *
      *    * ordine                                                    *
      *    *-----------------------------------------------------------*
       vis-cod-rsp-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-tes-cod-rsp-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-rsp-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Data consegna prevista       *
      *    *-----------------------------------------------------------*
       acc-dat-cns-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-dat-cns (1)    to   w-sav-dat-cns          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-dat-cns-400.
       acc-dat-cns-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      11                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      ">"                  to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-dat-cns (1)    to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-dat-cns-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-dat-cns-999.
       acc-dat-cns-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-dat                to   w-tes-dat-cns (1)      .
       acc-dat-cns-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
           if        w-tes-dat-cns (1)    not  = zero
                     go to acc-dat-cns-500.
      *                      *-----------------------------------------*
      *                      * Forzatura da data documento             *
      *                      *-----------------------------------------*
           move      w-tes-dat-doc        to   w-tes-dat-cns (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-dat-cns-000      thru vis-dat-cns-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-dat-cns-600.
       acc-dat-cns-500.
      *                  *---------------------------------------------*
      *                  * Se valore inferiore alla data documento     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-tes-dat-cns (1)    not  < w-tes-dat-doc
                     go to acc-dat-cns-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Data consegna richiesta inferiore alla data ordine
      -              " !             "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-dat-cns-600.
       acc-dat-cns-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Forecast : oltre                         *
      *                  *---------------------------------------------*
           if        w-prs-snx-ocf        =    "S"
                     go to acc-dat-cns-800.
      *                  *---------------------------------------------*
      *                  * Test che si tratti di un Forecast           *
      *                  *---------------------------------------------*
           if        w-tes-tmo-orc-tip    =    "F"
                     go to acc-dat-cns-800.
       acc-dat-cns-620.
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-tes-dat-cns (1)    =    w-sav-dat-cns
                     go to acc-dat-cns-800.
      *                      *-----------------------------------------*
      *                      * Box di avvertimento                     *
      *                      *-----------------------------------------*
           perform   acc-dat-cns-mod-000  thru acc-dat-cns-mod-999    .
      *                      *-----------------------------------------*
      *                      * Test su scelta                          *
      *                      *-----------------------------------------*
           if        w-exp-dcn-mod-sce    =    01
                     go to acc-dat-cns-800.
      *                      *-----------------------------------------*
      *                      * Aggiornamento                           *
      *                      *-----------------------------------------*
           perform   agg-dcn-rig-000      thru agg-dcn-rig-999        .
       acc-dat-cns-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-dat-cns-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-dat-cns-100.
       acc-dat-cns-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Data consegna prevista       *
      *    *                                                           *
      *    * Routine di avviso per cambio Data consegna prevista       *
      *    *-----------------------------------------------------------*
       acc-dat-cns-mod-000.
      *              *-------------------------------------------------*
      *              * Se corpo ancora da accettare : uscita           *
      *              *-------------------------------------------------*
           if        w-cnt-sts-imp-cor    =    spaces
                     go to acc-dat-cns-mod-900.
       acc-dat-cns-mod-100.
      *              *-------------------------------------------------*
      *              * Box di avviso con conferma                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      07                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      74                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Messaggi nel box                            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "                       A T T E N Z I O N E        
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "La modifica della data di consegna richiesta potre
      -              "bbe comportare"     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "la variazione delle condizioni stabilite nelle sin
      -              "gole righe.   "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "Si desidera :"      to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Preparazione default per risposta           *
      *                  *---------------------------------------------*
           move      spaces               to   v-alf                  .
           move      zero                 to   w-exp-dcn-mod-sce      .
       acc-dat-cns-mod-120.
      *                  *---------------------------------------------*
      *                  * Accettazione risposta                       *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-dcn-mod-lun    to   v-car                  .
           move      w-exp-dcn-mod-num    to   v-ldt                  .
           move      "IPRE#"              to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      15                   to   v-lin                  .
           move      23                   to   v-pos                  .
           move      w-exp-dcn-mod-tbl    to   v-txt                  .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-exp-dcn-mod-sce    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Controllo risposta operatore                *
      *                  *---------------------------------------------*
           if        v-key                =    "EXIT"
                     move  01             to   v-num
                     go to acc-dat-cns-mod-800.
           if        v-num                not  = 01 and
                     v-num                not  = 02 and
                     v-num                not  = 03 and
                     v-num                not  = 04
                     go to acc-dat-cns-mod-120.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione risposta operatore          *
      *                  *---------------------------------------------*
           move      v-num                to   w-exp-dcn-mod-sce      .
       acc-dat-cns-mod-800.
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-dat-cns-mod-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-dat-cns-mod-999.
       acc-dat-cns-mod-999.
           exit.

      *    *===========================================================*
      *    * Routine di aggiornamento date consegna nelle righe        *
      *    *-----------------------------------------------------------*
       agg-dcn-rig-000.
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       agg-dcn-rig-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to agg-dcn-rig-900.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to agg-dcn-rig-100.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to agg-dcn-rig-100.
      *              *-------------------------------------------------*
      *              * Selezione su tipo riga                          *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to agg-dcn-rig-100.
       agg-dcn-rig-150.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione della scelta effettuata  *
      *              *-------------------------------------------------*
           if        w-exp-dcn-mod-sce    =    01
                     go to agg-dcn-rig-900
           else if   w-exp-dcn-mod-sce    =    02
                     go to agg-dcn-rig-200
           else if   w-exp-dcn-mod-sce    =    03
                     go to agg-dcn-rig-300
           else if   w-exp-dcn-mod-sce    =    04
                     go to agg-dcn-rig-400
           else      go to agg-dcn-rig-900.
       agg-dcn-rig-200.
      *              *-------------------------------------------------*
      *              * Aggiornamento data consegna prevista            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Data consegna prevista                      *
      *                  *---------------------------------------------*
           move      w-tes-dat-cns (1)    to   w-rig-dcn-prv (1)      .
      *                  *---------------------------------------------*
      *                  * Ad aggiornamento                            *
      *                  *---------------------------------------------*
           go to     agg-dcn-rig-800.
       agg-dcn-rig-300.
      *              *-------------------------------------------------*
      *              * Aggiornamento data consegna richiesta           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Data consegna richiesta                     *
      *                  *---------------------------------------------*
           move      w-tes-dat-cns (1)    to   w-rig-dcn-ric (1)      .
      *                  *---------------------------------------------*
      *                  * Ad aggiornamento                            *
      *                  *---------------------------------------------*
           go to     agg-dcn-rig-800.
       agg-dcn-rig-400.
      *              *-------------------------------------------------*
      *              * Aggiornamento di entrambe le date               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Data consegna prevista                      *
      *                  *---------------------------------------------*
           move      w-tes-dat-cns (1)    to   w-rig-dcn-prv (1)      .
      *                  *---------------------------------------------*
      *                  * Data consegna richiesta                     *
      *                  *---------------------------------------------*
           move      w-tes-dat-cns (1)    to   w-rig-dcn-ric (1)      .
      *                  *---------------------------------------------*
      *                  * Ad aggiornamento                            *
      *                  *---------------------------------------------*
           go to     agg-dcn-rig-800.
       agg-dcn-rig-800.
      *              *-------------------------------------------------*
      *              * Aggiornamento catena movimenti                  *
      *              *-------------------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-cur        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura catena                       *
      *              *-------------------------------------------------*
           go to     agg-dcn-rig-100.
       agg-dcn-rig-900.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       agg-dcn-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Data consegna prevista    *
      *    *-----------------------------------------------------------*
       vis-dat-cns-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      11                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-dat-cns (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dat-cns-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Formato di stampa data cons. *
      *    *-----------------------------------------------------------*
       acc-fds-dtc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-fds-dtc-400.
       acc-fds-dtc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-fds-dtc-lun    to   v-car                  .
           move      w-exp-fds-dtc-num    to   v-ldt                  .
           move      "GMNS#"              to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      12                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-fds-dtc-tbl    to   v-txt                  .
           move      w-tes-fds-dtc (1)    to   v-num                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-fds-dtc-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-fds-dtc-999.
       acc-fds-dtc-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-fds-dtc (1)      .
       acc-fds-dtc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-fds-dtc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-fds-dtc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-fds-dtc-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-fds-dtc-100.
       acc-fds-dtc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Formato di stampa data    *
      *    * consegna                                                  *
      *    *-----------------------------------------------------------*
       vis-fds-dtc-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-fds-dtc-lun    to   v-car                  .
           move      w-exp-fds-dtc-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      12                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-fds-dtc-tbl    to   v-txt                  .
           move      w-tes-fds-dtc (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-fds-dtc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Si/no stampa prezzi e sconti         *
      *    *-----------------------------------------------------------*
       acc-snx-sps-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-snx-sps-400.
      *                  *---------------------------------------------*
      *                  * Eventuale default                           *
      *                  *---------------------------------------------*
           if        w-tes-flg-nbx (1, 2) =    spaces and
                     w-let-arc-zoc-sns    =    "N"
                     move  "N"            to   w-tes-flg-nbx (1, 2)   .
       acc-snx-sps-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-snx-sps-lun    to   v-car                  .
           move      w-exp-snx-sps-num    to   v-ldt                  .
           move      "SN#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      12                   to   v-lin                  .
           move      78                   to   v-pos                  .
           move      w-exp-snx-sps-tbl    to   v-txt                  .
      *
           if        w-tes-flg-nbx (1, 2) =    spaces
                     move  1              to   v-num
           else if   w-tes-flg-nbx (1, 2) =    "N"
                     move  2              to   v-num
           else      move  zero           to   v-num                  .
      *
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
      *
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
      *
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-snx-sps-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-snx-sps-999.
       acc-snx-sps-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    1
                     move  spaces         to   w-tes-flg-nbx (1, 2)
           else if   v-num                =    2
                     move  "N"            to   w-tes-flg-nbx (1, 2)
           else      move  spaces         to   w-tes-flg-nbx (1, 2)   .
       acc-snx-sps-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-snx-sps-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-snx-sps-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-snx-sps-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-snx-sps-100.
       acc-snx-sps-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Si/no stampa prezzi e sconti      *
      *    *-----------------------------------------------------------*
       vis-snx-sps-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-snx-sps-lun    to   v-car                  .
           move      w-exp-snx-sps-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      12                   to   v-lin                  .
           move      78                   to   v-pos                  .
           move      w-exp-snx-sps-tbl    to   v-txt                  .
      *
           if        w-tes-flg-nbx (1, 2) =    spaces
                     move  1              to   v-num
           else if   w-tes-flg-nbx (1, 2) =    "N"
                     move  2              to   v-num
           else      move  zero           to   v-num                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-snx-sps-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo piede : Codice primo vettore           *
      *    *-----------------------------------------------------------*
       acc-cod-vet-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-vet-400.
       acc-cod-vet-100.
      *              *-------------------------------------------------*
      *              * Note operative                                  *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           move      "Indicare solo se diverso da quello abituale"
                                          to   v-not                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-vet-ope      .
           move      w-tes-cod-vet (1)    to   w-cod-mne-vet-cod      .
           move      13                   to   w-cod-mne-vet-lin      .
           move      30                   to   w-cod-mne-vet-pos      .
           move      13                   to   w-cod-mne-vet-rln      .
           move      41                   to   w-cod-mne-vet-rps      .
           move      zero                 to   w-cod-mne-vet-vln      .
           move      zero                 to   w-cod-mne-vet-vps      .
           move      zero                 to   w-cod-mne-vet-lln      .
           move      zero                 to   w-cod-mne-vet-lps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-vet-cll-000  thru cod-mne-vet-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-vet-foi-000  thru cod-mne-vet-foi-999    .
       acc-cod-vet-110.
           perform   cod-mne-vet-cll-000  thru cod-mne-vet-cll-999    .
           if        w-cod-mne-vet-ope    =    "F+"
                     go to acc-cod-vet-115.
           if        w-cod-mne-vet-ope    =    "AC"
                     go to acc-cod-vet-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-vet-115.
           perform   cod-mne-vet-foi-000  thru cod-mne-vet-foi-999    .
           go to     acc-cod-vet-110.
       acc-cod-vet-120.
           move      w-cod-mne-vet-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Cancellazione note operative attuali            *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           move      spaces               to   v-not                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-vet-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-vet-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-vet (1)      .
       acc-cod-vet-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [vet]                      *
      *                  *---------------------------------------------*
           move      w-tes-cod-vet (1)    to   w-let-arc-vet-cod      .
           perform   let-arc-vet-000      thru let-arc-vet-999        .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione descrizione                 *
      *                  *---------------------------------------------*
           move      w-let-arc-vet-rag    to   w-tes-cod-vet-des (1)  .
           perform   vis-cod-vet-des-000  thru vis-cod-vet-des-999    .
      *                  *---------------------------------------------*
      *                  * Se lettura errata                           *
      *                  *---------------------------------------------*
           if        w-let-arc-vet-flg    =    spaces
                     go to acc-cod-vet-600.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "Codice vettore non esistente !                    
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-vet-100.
       acc-cod-vet-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-vet-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-vet-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-vet-100.
       acc-cod-vet-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Codice primo vettore        *
      *    *-----------------------------------------------------------*
       vis-cod-vet-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      13                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-vet (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-vet-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Descrizione primo vettore   *
      *    *-----------------------------------------------------------*
       vis-cod-vet-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-vet-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-vet-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Tipo di evasione ordine      *
      *    *-----------------------------------------------------------*
       acc-tip-eva-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-tip-eva-400.
       acc-tip-eva-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-eva-lun    to   v-car                  .
           move      w-exp-tip-eva-num    to   v-ldt                  .
           move      "ORP#"               to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      15                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-tip-eva-tbl    to   v-txt                  .
           move      w-tes-tip-eva (1)    to   v-num                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-tip-eva-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-tip-eva-999.
       acc-tip-eva-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-tip-eva (1)      .
       acc-tip-eva-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-tip-eva-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-tip-eva-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-tip-eva-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-tip-eva-100.
       acc-tip-eva-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Tipo di evasione ordine   *
      *    *-----------------------------------------------------------*
       vis-tip-eva-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-eva-lun    to   v-car                  .
           move      w-exp-tip-eva-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      15                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-tip-eva-tbl    to   v-txt                  .
           move      w-tes-tip-eva (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tip-eva-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Priorita' di evasione ordine *
      *    *-----------------------------------------------------------*
       acc-pri-eva-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-pri-eva-400.
       acc-pri-eva-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-pri-eva (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pri-eva-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pri-eva-999.
       acc-pri-eva-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-pri-eva (1)      .
       acc-pri-eva-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
           if        w-tes-pri-eva (1)    =   spaces
                     go to acc-pri-eva-600.
           if        w-tes-pri-eva (1)    <   "A " or
                     w-tes-pri-eva (1)    >   "Z "
                     go to acc-pri-eva-100.
       acc-pri-eva-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-pri-eva-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pri-eva-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pri-eva-100.
       acc-pri-eva-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Priorita' di evasione or- *
      *    * dine                                                      *
      *    *-----------------------------------------------------------*
       vis-pri-eva-000.
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-pri-eva (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-pri-eva-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice condizioni di vendita *
      *    *-----------------------------------------------------------*
       acc-cod-cdv-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cod-cdv (1)    to   w-sav-cod-cdv          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-cdv-400.
       acc-cod-cdv-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zcv-ope      .
           move      w-tes-cod-cdv (1)    to   w-cod-mne-zcv-cod      .
           move      18                   to   w-cod-mne-zcv-lin      .
           move      30                   to   w-cod-mne-zcv-pos      .
           move      18                   to   w-cod-mne-zcv-dln      .
           move      37                   to   w-cod-mne-zcv-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-zcv-cll-000  thru cod-mne-zcv-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zcv-foi-000  thru cod-mne-zcv-foi-999    .
       acc-cod-cdv-110.
           perform   cod-mne-zcv-cll-000  thru cod-mne-zcv-cll-999    .
           if        w-cod-mne-zcv-ope    =    "F+"
                     go to acc-cod-cdv-115.
           if        w-cod-mne-zcv-ope    =    "AC"
                     go to acc-cod-cdv-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-cdv-115.
           perform   cod-mne-zcv-foi-000  thru cod-mne-zcv-foi-999    .
           go to     acc-cod-cdv-110.
       acc-cod-cdv-120.
           move      w-cod-mne-zcv-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cdv-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cdv-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-cdv (1)      .
       acc-cod-cdv-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella [zcv]                       *
      *                  *---------------------------------------------*
           move      w-tes-cod-cdv (1)    to   w-let-arc-zcv-cod      .
           perform   let-arc-zcv-000      thru let-arc-zcv-999        .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso                       *
      *                  *---------------------------------------------*
           if        w-let-arc-zcv-flg    =    spaces
                     go to acc-cod-cdv-500.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "Codice condizioni di vendita non esistente !      
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-cdv-100.
       acc-cod-cdv-500.
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
           if        w-tes-cod-cdv (1)    not  = zero
                     go to acc-cod-cdv-550.
      *                      *-----------------------------------------*
      *                      * Se valore precedente a zero : oltre     *
      *                      *-----------------------------------------*
           if        w-sav-cod-cdv        =    zero
                     go to acc-cod-cdv-600.
      *                      *-----------------------------------------*
      *                      * Altrimenti : normalizzazione e rivisua- *
      *                      * lizzazione                              *
      *                      *-----------------------------------------*
           move      spaces               to   w-tes-des-cdv (1)      .
           perform   vis-des-cdv-000      thru vis-des-cdv-999        .
           go to     acc-cod-cdv-600.
       acc-cod-cdv-550.
      *                  *---------------------------------------------*
      *                  * Se valore non a zero                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione valore letto            *
      *                      *-----------------------------------------*
           move      w-let-arc-zcv-des    to   w-tes-des-cdv (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione condizioni  *
      *                      * di vendita                              *
      *                      *-----------------------------------------*
           perform   vis-des-cdv-000      thru vis-des-cdv-999        .
       acc-cod-cdv-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-cdv-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-cdv-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-cdv-100.
       acc-cod-cdv-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice condizioni di ven- *
      *    * dita                                                      *
      *    *-----------------------------------------------------------*
       vis-cod-cdv-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      18                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-cdv (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-cdv-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Descrizione condizioni di    *
      *    * vendita                                                   *
      *    *-----------------------------------------------------------*
       acc-des-cdv-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-des-cdv (1)    to   w-sav-des-cdv          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-des-cdv-400.
       acc-des-cdv-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      03                   to   v-ldt                  .
           move      18                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-des-cdv (1)    to   v-txt                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-des-cdv-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-des-cdv-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-txt                to   w-tes-des-cdv (1)      .
       acc-des-cdv-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-des-cdv-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-des-cdv (1)    =    w-sav-des-cdv
                     go to acc-des-cdv-800.
      *                  *---------------------------------------------*
      *                  * Trattamento codice annotazioni              *
      *                  *---------------------------------------------*
           if        w-tes-cod-cdv (1)    =    zero
                     go to acc-des-cdv-800.
           move      zero                 to   w-tes-cod-cdv (1)      .
           perform   vis-cod-cdv-000      thru vis-cod-cdv-999        .
       acc-des-cdv-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-des-cdv-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-des-cdv-100.
       acc-des-cdv-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione condizioni di *
      *    * vendita                                                   *
      *    *-----------------------------------------------------------*
       vis-des-cdv-000.
           move      "DS"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      03                   to   v-ldt                  .
           move      18                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-tes-des-cdv (1)    to   v-txt                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-cdv-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Commento ad uso interno      *
      *    *-----------------------------------------------------------*
       acc-com-int-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-com-int-400.
       acc-com-int-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      03                   to   v-ldt                  .
           move      20                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-com-int (1)    to   v-txt                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-com-int-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-com-int-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-txt                to   w-tes-com-int (1)      .
       acc-com-int-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-com-int-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-com-int-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-com-int-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-com-int-100.
       acc-com-int-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Commento ad uso interno   *
      *    *-----------------------------------------------------------*
       vis-com-int-000.
           move      "DS"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      03                   to   v-ldt                  .
           move      20                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-tes-com-int (1)    to   v-txt                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-com-int-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Inoltro documenti            *
      *    *-----------------------------------------------------------*
       acc-inl-dcm-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se dipendenza cliente non esistente, modifi-*
      *                  * ca nr. elementi del pop-up di accettazione  *
      *                  *---------------------------------------------*
           if        w-tes-dpz-arc (1)    =    spaces
                     move 02              to   w-exp-inl-dcm-num
           else      move 03              to   w-exp-inl-dcm-num      .
      *                  *---------------------------------------------*
      *                  * Preparazione eventuale default              *
      *                  *---------------------------------------------*
           if        w-tes-inl-dcm (1)    =    zero
                     move  02             to   w-tes-inl-dcm (1)      .
      *                  *---------------------------------------------*
      *                  * Se Tab in corso : a controllo valore impo-  *
      *                  * stato                                       *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-inl-dcm-400.
       acc-inl-dcm-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-inl-dcm-lun    to   v-car                  .
           move      w-exp-inl-dcm-num    to   v-ldt                  .
           move      "SLD#"               to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-inl-dcm-tbl    to   v-txt                  .
           move      w-tes-inl-dcm (1)    to   v-num                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-inl-dcm-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-inl-dcm-999.
       acc-inl-dcm-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-inl-dcm (1)      .
       acc-inl-dcm-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se zero : reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-tes-inl-dcm (1)    not  = zero
                     go to acc-inl-dcm-600.
           if        v-key                =    "UP  "
                     go to acc-inl-dcm-600
           else      go to acc-inl-dcm-100.
       acc-inl-dcm-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-inl-dcm-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-inl-dcm-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-inl-dcm-100.
       acc-inl-dcm-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Inoltro documenti         *
      *    *-----------------------------------------------------------*
       vis-inl-dcm-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-inl-dcm-lun    to   v-car                  .
           move      w-exp-inl-dcm-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-inl-dcm-tbl    to   v-txt                  .
           move      w-tes-inl-dcm (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-inl-dcm-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Inoltro pagamenti            *
      *    *-----------------------------------------------------------*
       acc-inl-pgt-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-inl-pgt (1)    to    w-sav-inl-pgt         .
      *                  *---------------------------------------------*
      *                  * Se dipendenza cliente non esistente, modifi-*
      *                  * ca nr. elementi del pop-up di accettazione  *
      *                  *---------------------------------------------*
           if        w-tes-dpz-arc (1)    =    spaces
                     move 02              to   w-exp-inl-pgt-num
           else      move 03              to   w-exp-inl-pgt-num      .
      *                  *---------------------------------------------*
      *                  * Preparazione eventuale default              *
      *                  *---------------------------------------------*
           if        w-tes-inl-pgt (1)    =    zero
                     move  02             to   w-tes-inl-pgt (1)      .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-inl-pgt-400.
       acc-inl-pgt-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-inl-pgt-lun    to   v-car                  .
           move      w-exp-inl-pgt-num    to   v-ldt                  .
           move      "SLD#"               to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      06                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-inl-pgt-tbl    to   v-txt                  .
           move      w-tes-inl-pgt (1)    to   v-num                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-inl-pgt-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-inl-pgt-999.
       acc-inl-pgt-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-inl-pgt (1)      .
       acc-inl-pgt-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se zero : reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-tes-inl-pgt (1)    not  = zero
                     go to acc-inl-pgt-600.
           if        v-key                =    "UP  "
                     go to acc-inl-pgt-600
           else      go to acc-inl-pgt-100.
       acc-inl-pgt-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-inl-pgt (1)    =     w-sav-inl-pgt
                     go to acc-inl-pgt-800.
      *                  *---------------------------------------------*
      *                  * Determinazione valori testata dipendenti    *
      *                  * dall'inoltro pagamenti                      *
      *                  *---------------------------------------------*
           perform   det-vlt-ipg-000      thru det-vlt-ipg-999        .
       acc-inl-pgt-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-inl-pgt-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-inl-pgt-100.
       acc-inl-pgt-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Inoltro pagamenti         *
      *    *-----------------------------------------------------------*
       vis-inl-pgt-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-inl-pgt-lun    to   v-car                  .
           move      w-exp-inl-pgt-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      06                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-inl-pgt-tbl    to   v-txt                  .
           move      w-tes-inl-pgt (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-inl-pgt-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Sigla valuta per fatturazio- *
      *    * ne                                                        *
      *    *-----------------------------------------------------------*
       acc-sgl-vpf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-fda-vpf (1)    not  = spaces
                     go to acc-sgl-vpf-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-sav-sgl-vpf          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-sgl-vpf-400.
       acc-sgl-vpf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-zvl-ope      .
           move      w-tes-sgl-vpf (1)    to   w-cod-cod-zvl-cod      .
           move      08                   to   w-cod-cod-zvl-lin      .
           move      30                   to   w-cod-cod-zvl-pos      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
       acc-sgl-vpf-110.
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           if        w-cod-cod-zvl-ope    =    "F+"
                     go to acc-sgl-vpf-115.
           if        w-cod-cod-zvl-ope    =    "AC"
                     go to acc-sgl-vpf-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-sgl-vpf-115.
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
           go to     acc-sgl-vpf-110.
       acc-sgl-vpf-120.
           move      w-cod-cod-zvl-cod    to   v-alf                  .
       acc-sgl-vpf-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-sgl-vpf-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-sgl-vpf-999.
       acc-sgl-vpf-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-sgl-vpf (1)      .
       acc-sgl-vpf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura record [zvl]                        *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-let-arc-zvl-cod      .
           perform   let-arc-zvl-000      thru let-arc-zvl-999        .
           move      w-let-arc-zvl-des    to   w-tes-sgl-vpf-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione valuta          *
      *                  *---------------------------------------------*
           perform   vis-sgl-vpf-des-000  thru vis-sgl-vpf-des-999    .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        w-let-arc-zvl-flg    not  = spaces
                     go to acc-sgl-vpf-100.
      *                  *---------------------------------------------*
      *                  * Valore a spaces non ammesso                 *
      *                  *---------------------------------------------*
           if        w-tes-sgl-vpf (1)    =    spaces
                     go to acc-sgl-vpf-100.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione numero decimali             *
      *                  *---------------------------------------------*
           move      w-let-arc-zvl-dec    to   w-tes-dec-vpf (1)      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione tipo di cambio              *
      *                  *---------------------------------------------*
           move      w-let-arc-zvl-tdc    to   w-tes-tdc-vpf (1)      .
      *                  *---------------------------------------------*
      *                  * Determinazione coefficiente di cambio       *
      *                  *---------------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      w-tes-sgl-vpf (1)    to   w-coe-cmb-vlt-sdv      .
           move      w-tes-tdc-vpf (1)    to   w-coe-cmb-vlt-tdc      .
           move      w-tes-dat-doc        to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test su esito determinazione                *
      *                  *---------------------------------------------*
           if        w-coe-cmb-vlt-ope    =    "CC"
                     go to acc-sgl-vpf-420.
           move      "Coefficiente di cambio indeterminato !            
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-sgl-vpf-100.
       acc-sgl-vpf-420.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione coefficiente di cambio      *
      *                  *---------------------------------------------*
           move      w-coe-cmb-vlt-cdc    to   w-tes-cdc-vpf (1)      .
       acc-sgl-vpf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-sgl-vpf-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-sgl-vpf-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-sgl-vpf-100.
       acc-sgl-vpf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Sigla valuta per fattura- *
      *    * zione                                                     *
      *    *-----------------------------------------------------------*
       vis-sgl-vpf-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-sgl-vpf (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sgl-vpf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione sigla valuta  *
      *    * per fatturazione                                          *
      *    *-----------------------------------------------------------*
       vis-sgl-vpf-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-tes-sgl-vpf-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sgl-vpf-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Assoggettamento iva          *
      *    *-----------------------------------------------------------*
       acc-ass-iva-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-sav-ass-iva          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-ass-iva-400.
       acc-ass-iva-100.
      *              *-------------------------------------------------*
      *              * Editing preliminare per l'accettazione          *
      *              *-------------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zci-ope      .
           move      w-edt-iva-cie        to   w-cod-mne-zci-cod      .
           move      10                   to   w-cod-mne-zci-lin      .
           move      30                   to   w-cod-mne-zci-pos      .
           move      10                   to   w-cod-mne-zci-dln      .
           move      37                   to   w-cod-mne-zci-dps      .
           move      "<BD"                to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
       acc-ass-iva-110.
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           if        w-cod-mne-zci-ope    =    "F+"
                     go to acc-ass-iva-115.
           if        w-cod-mne-zci-ope    =    "AC"
                     go to acc-ass-iva-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-ass-iva-115.
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
           go to     acc-ass-iva-110.
       acc-ass-iva-120.
      *              *-------------------------------------------------*
      *              * Editing valore impostato                        *
      *              *-------------------------------------------------*
           move      w-cod-mne-zci-cod    to   w-edt-iva-cie          .
           perform   edt-iva-cod-000      thru edt-iva-cod-999        .
           move      w-edt-iva-cod        to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-ass-iva-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-ass-iva-999.
       acc-ass-iva-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-ass-iva (1)      .
       acc-ass-iva-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-zci-des    to   w-tes-ass-iva-des (1)  .
           if        w-tes-ass-iva (1)    =    zero
                     move  "Soggetto ad iva"
                                          to   w-tes-ass-iva-des (1)  .
      *
           if        w-tes-ass-iva (1)    =    zero and
                     w-tes-ass-iva-spl (1)
                                          =    "S"
                     move  "Scissione Pagamenti"
                                          to   w-tes-ass-iva-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-ass-iva-des-000  thru vis-ass-iva-des-999    .
      *                  *---------------------------------------------*
      *                  * Se lettura errata : reimpostazione          *
      *                  *---------------------------------------------*
           if        w-let-arc-zci-flg    not  = spaces
                     go to acc-ass-iva-100.
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : test che non sia un *
      *                  * codice Iva imponibile per la sostituzione   *
      *                  * in tutte le righe                           *
      *                  *---------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-edt-iva-cod          .
      *
           if       (w-tes-ass-iva (1)    not  = zero   ) and
                    (w-edt-iva-cod-003    not  > zero)
                     go to acc-ass-iva-500
           else      go to acc-ass-iva-600.
       acc-ass-iva-500.
      *                  *---------------------------------------------*
      *                  * Eventuale ricalcolo codici iva in riga      *
      *                  *---------------------------------------------*
           perform   rcl-civ-doc-000      thru rcl-civ-doc-999        .
      *                  *---------------------------------------------*
      *                  * Ripristino del codice Iva memorizzato       *
      *                  *---------------------------------------------*
           if       (w-tes-ass-iva (1)    not  = zero   ) and
                    (w-edt-iva-cod-003    not  > zero)
                     move  zero           to   w-tes-ass-iva (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione codice Iva impostato        *
      *                  *---------------------------------------------*
           perform   vis-ass-iva-000      thru vis-ass-iva-999        .
      *                  *---------------------------------------------*
      *                  * A rilettura tabella e visualizzazione       *
      *                  *---------------------------------------------*
           go to     acc-ass-iva-400.
       acc-ass-iva-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag per scissione pagamenti                *
      *                  *---------------------------------------------*
           if        w-tes-ass-iva-spl (1)
                                          =    "S"
                     move  "S"            to   w-tes-flg-rfp (1)      .
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-ass-iva (1)    =    w-sav-ass-iva
                     go to acc-ass-iva-800.
      *                  *---------------------------------------------*
      *                  * Eventuale ricalcolo codici iva in riga      *
      *                  *---------------------------------------------*
           perform   rcl-civ-doc-000      thru rcl-civ-doc-999        .
       acc-ass-iva-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-ass-iva-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-ass-iva-100.
       acc-ass-iva-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice di esenzione IVA   *
      *    *-----------------------------------------------------------*
       vis-ass-iva-000.
      *              *-------------------------------------------------*
      *              * Test se documento in scissione pagamenti        *
      *              *-------------------------------------------------*
           if        w-tes-ass-iva-spl (1)
                                          =    "S"
                     go to vis-ass-iva-999.
       vis-ass-iva-100.
      *              *-------------------------------------------------*
      *              * Editing preliminare                             *
      *              *-------------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      10                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-edt-iva-cie        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ass-iva-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione assoggetta-   *
      *    * mento IVA                                                 *
      *    *-----------------------------------------------------------*
       vis-ass-iva-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-tes-ass-iva-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ass-iva-des-999.
           exit.

      *    *===========================================================*
      *    * Routine di ricalcolo codici iva del documento             *
      *    *-----------------------------------------------------------*
       rcl-civ-doc-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di impossibilita' di va-   *
      *              * riazione di un codice iva                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-rcl-civ-doc-fiv      .
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se corpo ancora da accettare : no           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-cor    =    spaces
                     go to rcl-civ-doc-999.
       rcl-civ-doc-100.
      *              *-------------------------------------------------*
      *              * Box di avviso con conferma                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      07                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      74                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Messaggi nel box                            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "                       A T T E N Z I O N E        
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "La modifica appena apportata potrebbe avere delle 
      -              "ripercussioni "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "sui codici iva del documento gia' determinati.    
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "Si desidera che essi vengano ricalcolati (S/N) ? [
      -              " ]            "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Preparazione default per risposta           *
      *                  *---------------------------------------------*
           move      spaces               to   v-alf                  .
       rcl-civ-doc-120.
      *                  *---------------------------------------------*
      *                  * Accettazione risposta                       *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      59                   to   v-pos                  .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Controllo risposta operatore                *
      *                  *---------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "N"            to   v-alf
           else if   v-key                =    "DO  "
                     move  "S"            to   v-alf                  .
           if        v-alf                not  = "S" and
                     v-alf                not  = "N"
                     go to rcl-civ-doc-120.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione risposta operatore          *
      *                  *---------------------------------------------*
           move      v-alf                to   w-rcl-civ-doc-tro      .
      *                  *---------------------------------------------*
      *                  * Ripristino immagine video                   *
      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       rcl-civ-doc-200.
      *              *-------------------------------------------------*
      *              * Se risposta operatore negativa : a uscita       *
      *              *-------------------------------------------------*
           if        w-rcl-civ-doc-tro    =    "N"
                     go to rcl-civ-doc-900.
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       rcl-civ-doc-300.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to rcl-civ-doc-600.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to rcl-civ-doc-300.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to rcl-civ-doc-300.
      *              *-------------------------------------------------*
      *              * Selezione su tipo riga                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se riga di commento : riciclo               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to rcl-civ-doc-300.
       rcl-civ-doc-400.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo di modifica     *
      *              *-------------------------------------------------*
           move      w-sav-ass-iva        to   w-edt-iva-cod          .
           move      w-edt-iva-cod-003    to   w-edt-iva-wk1          .
      *
           move      w-tes-ass-iva (1)    to   w-edt-iva-cod          .
           move      w-edt-iva-cod-003    to   w-edt-iva-wk2          .
      *
           if       (w-sav-ass-iva        =    zero) and
                    (w-edt-iva-wk2        >    2 and
                     w-edt-iva-wk2        <    8   )
                     go to rcl-civ-doc-420
           else if  (w-edt-iva-wk1        >    2 and
                     w-edt-iva-wk1        <    8   ) and
                    (w-tes-ass-iva (1)    =    zero)
                     go to rcl-civ-doc-440
           else if  (w-edt-iva-wk1        >    2 and
                     w-edt-iva-wk1        <    8   ) and
                    (w-edt-iva-wk2        >    2 and
                     w-edt-iva-wk2        <    8   )
                     go to rcl-civ-doc-460.
       rcl-civ-doc-420.
      *              *-------------------------------------------------*
      *              * Se assoggettamento : da soggetto a esente       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se codice iva gia' esente : a riciclo       *
      *                  *---------------------------------------------*
           move      w-rig-coi-rig (1)    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    >    2 and
                     w-edt-iva-cod-003    <    7
                     go to rcl-civ-doc-580.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione codice iva                  *
      *                  *---------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-rig-coi-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Ad aggiornamento catena e riciclo           *
      *                  *---------------------------------------------*
           go to     rcl-civ-doc-500.
       rcl-civ-doc-440.
      *              *-------------------------------------------------*
      *              * Se assoggettamento : da esente a soggetto       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo riga        *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "P"
                     go to rcl-civ-doc-442
           else if   w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to rcl-civ-doc-450.
       rcl-civ-doc-442.
      *                  *---------------------------------------------*
      *                  * Tipo riga : Prodotto di vendita             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura archivio [dcp]                  *
      *                      *-----------------------------------------*
           move      w-rig-num-pro (1)    to   w-let-dcp-pdx-cod      .
           move      w-tes-tip-arc (1)    to   w-let-dcp-pdx-tar      .
           if        w-tes-tip-frn (1)    =    11
                     move  w-tes-cod-arc (1)
                                          to   w-let-dcp-pdx-arc
           else      move  w-tes-arc-plf (1)
                                          to   w-let-dcp-pdx-arc      .
           move      w-tes-cod-lng (1)    to   w-let-dcp-pdx-lng      .
           perform   let-dcp-pdx-000      thru let-dcp-pdx-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata o codice iva letto a  *
      *                      * zero : a riciclo con set del flag di    *
      *                      * impossibilita' di determinazione di un  *
      *                      * codice iva                              *
      *                      *-----------------------------------------*
           if        w-let-dcp-pdx-flg    not  = spaces or
                     w-let-dcp-pdx-coi    =    zero
                     move  "#"            to   w-rcl-civ-doc-fiv
                     go to rcl-civ-doc-580.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione codice iva              *
      *                      *-----------------------------------------*
           move      w-let-dcp-pdx-coi    to   w-rig-coi-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Ad aggiornamento catena e riciclo       *
      *                      *-----------------------------------------*
           go to     rcl-civ-doc-500.
       rcl-civ-doc-450.
      *                  *---------------------------------------------*
      *                  * Tipo riga : Addebito                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura archivio [zac]                  *
      *                      *-----------------------------------------*
           move      01                   to   w-let-arc-zac-tip      .
           move      w-rig-tip-rig-cac (1)
                                          to   w-let-arc-zac-cod      .
           perform   let-arc-zac-000      thru let-arc-zac-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata o codice iva letto a  *
      *                      * zero : a riciclo con set del flag di    *
      *                      * impossibilita' di determinazione di un  *
      *                      * codice iva                              *
      *                      *-----------------------------------------*
           if        w-let-arc-zac-flg    not  = spaces or
                     w-let-arc-zac-civ    =    zero
                     move  "#"            to   w-rcl-civ-doc-fiv
                     go to rcl-civ-doc-580.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione codice iva              *
      *                      *-----------------------------------------*
           move      w-let-arc-zac-civ    to   w-rig-coi-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Ad aggiornamento catena e riciclo       *
      *                      *-----------------------------------------*
           go to     rcl-civ-doc-500.
       rcl-civ-doc-460.
      *              *-------------------------------------------------*
      *              * Se assoggettamento : da esente a esente         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se codice iva soggetto : a riciclo          *
      *                  *---------------------------------------------*
           move      w-rig-coi-rig (1)    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    =    zero
                     go to rcl-civ-doc-580.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione codice iva                  *
      *                  *---------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-rig-coi-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Ad aggiornamento catena e riciclo           *
      *                  *---------------------------------------------*
           go to     rcl-civ-doc-500.
       rcl-civ-doc-500.
      *              *-------------------------------------------------*
      *              * Lettura tabella [codiva]                        *
      *              *-------------------------------------------------*
           move      w-rig-coi-rig (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
           move      w-let-arc-zci-des    to   w-rig-coi-rig-des (1)  .
      *              *-------------------------------------------------*
      *              * Aggiornamento catena movimenti                  *
      *              *-------------------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-cur        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       rcl-civ-doc-580.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura catena                       *
      *              *-------------------------------------------------*
           go to     rcl-civ-doc-300.
       rcl-civ-doc-600.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       rcl-civ-doc-700.
      *              *-------------------------------------------------*
      *              * Codici iva per piede documento                  *
      *              *-------------------------------------------------*
       rcl-civ-doc-800.
      *              *-------------------------------------------------*
      *              * Test se flag di impossibilita' di variazione di *
      *              * un codice iva attivo                            *
      *              *-------------------------------------------------*
           if        w-rcl-civ-doc-fiv    =    spaces
                     go to rcl-civ-doc-900.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "Attenzione : non e' stato possibile applicare il r
      -              "icalcolo a uno "    to   w-err-box-err-msg      .
           move      "              o piu' codici iva del documento.    
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       rcl-civ-doc-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     rcl-civ-doc-999.
       rcl-civ-doc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Contropartita vendite        *
      *    *-----------------------------------------------------------*
       acc-ctp-ven-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-ctp-ven (1)    to   w-sav-ctp-ven          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-ctp-ven-400.
       acc-ctp-ven-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-pdc-ope      .
           move      w-prs-liv-pdc        to   w-cod-mne-pdc-liv      .
           move      w-tes-ctp-ven (1)    to   w-cod-mne-pdc-cod      .
           move      11                   to   w-cod-mne-pdc-lin      .
           move      30                   to   w-cod-mne-pdc-pos      .
           move      11                   to   w-cod-mne-pdc-dln      .
           move      41                   to   w-cod-mne-pdc-dps      .
           move      "B"                  to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
       acc-ctp-ven-110.
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           if        w-cod-mne-pdc-ope    =    "F+"
                     go to acc-ctp-ven-115.
           if        w-cod-mne-pdc-ope    =    "AC"
                     go to acc-ctp-ven-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-ctp-ven-115.
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
           go to     acc-ctp-ven-110.
       acc-ctp-ven-120.
           move      w-cod-mne-pdc-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-ctp-ven-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-ctp-ven-999.
       acc-ctp-ven-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-ctp-ven (1)      .
       acc-ctp-ven-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio piano dei conti            *
      *                  *---------------------------------------------*
           move      w-tes-ctp-ven (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-tes-ctp-ven-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione sottoconto      *
      *                  *---------------------------------------------*
           perform   vis-ctp-ven-des-000  thru vis-ctp-ven-des-999    .
      *                  *---------------------------------------------*
      *                  * Se codice sottoconto non esistente : reim-  *
      *                  * postazione                                  *
      *                  *---------------------------------------------*
           if        w-let-arc-pdc-flg    not  = spaces
                     go to acc-ctp-ven-100.
       acc-ctp-ven-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-ctp-ven (1)    =    w-sav-ctp-ven
                     go to acc-ctp-ven-800.
      *                      *-----------------------------------------*
      *                      * Eventuale ricalcolo contropartite ven-  *
      *                      * dite del documento                      *
      *                      *-----------------------------------------*
           perform   rcl-ctv-doc-000      thru rcl-ctv-doc-999        .
       acc-ctp-ven-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-ctp-ven-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-ctp-ven-100.
       acc-ctp-ven-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Sottoconto contabile      *
      *    *-----------------------------------------------------------*
       vis-ctp-ven-000.
      *              *-------------------------------------------------*
      *              * Editing con appoggio a sinistra                 *
      *              *-------------------------------------------------*
           move      w-prs-liv-pdc        to   w-edt-cod-pdc-liv      .
           move      w-tes-ctp-ven (1)    to   w-edt-cod-pdc-cod      .
           move      "B"                  to   w-edt-cod-pdc-edm      .
           perform   edt-pdc-asx-000      thru edt-pdc-asx-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-edt-cod-pdc-edt    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ctp-ven-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Contropartita vendite in  *
      *    * testata                                                   *
      *    *-----------------------------------------------------------*
       vis-ctp-ven-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-ctp-ven-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ctp-ven-des-999.
           exit.

      *    *===========================================================*
      *    * Editing del codice sottoconto con appoggio a sx o dx      *
      *    *-----------------------------------------------------------*
           copy      "pgm/cge/prg/cpy/wedtpdc0.wks"                   .

      *    *===========================================================*
      *    * Subroutines per editing del codice iva                    *
      *    *-----------------------------------------------------------*
           copy      "pgm/cge/prg/cpy/wedtzci0.wks"                   .

      *    *===========================================================*
      *    * Routine di ricalcolo contropartite vendite del documento  *
      *    *-----------------------------------------------------------*
       rcl-ctv-doc-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di impossibilita' di va-   *
      *              * riazione di un codice iva                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-rcl-ctv-doc-fic      .
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se corpo ancora da accettare : no           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-cor    =    spaces
                     go to rcl-ctv-doc-999.
       rcl-ctv-doc-100.
      *              *-------------------------------------------------*
      *              * Box di avviso con conferma                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      07                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      74                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Messaggi nel box                            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "                       A T T E N Z I O N E        
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "La modifica appena apportata potrebbe avere delle 
      -              "ripercussioni "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "sulle contropartite alle vendite del documento gia
      -              "' determinate."     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "Si desidera che esse vengano ricalcolate (S/N) ? [
      -              " ]            "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Preparazione default per risposta           *
      *                  *---------------------------------------------*
           move      spaces               to   v-alf                  .
       rcl-ctv-doc-120.
      *                  *---------------------------------------------*
      *                  * Accettazione risposta                       *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      59                   to   v-pos                  .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Controllo risposta operatore                *
      *                  *---------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "N"            to   v-alf
           else if   v-key                =    "DO  "
                     move  "S"            to   v-alf                  .
           if        v-alf                not  = "S" and
                     v-alf                not  = "N"
                     go to rcl-ctv-doc-120.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione risposta operatore          *
      *                  *---------------------------------------------*
           move      v-alf                to   w-rcl-ctv-doc-tro      .
      *                  *---------------------------------------------*
      *                  * Ripristino immagine video                   *
      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       rcl-ctv-doc-200.
      *              *-------------------------------------------------*
      *              * Se risposta operatore negativa : a uscita       *
      *              *-------------------------------------------------*
           if        w-rcl-ctv-doc-tro    =    "N"
                     go to rcl-ctv-doc-900.
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       rcl-ctv-doc-300.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to rcl-ctv-doc-600.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to rcl-ctv-doc-300.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to rcl-ctv-doc-300.
      *              *-------------------------------------------------*
      *              * Selezione su tipo riga                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se riga di commento : riciclo               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to rcl-ctv-doc-300.
       rcl-ctv-doc-400.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo di modifica     *
      *              *-------------------------------------------------*
           if        w-sav-ctp-ven        =    zero   and
                     w-tes-ctp-ven (1)    not  = zero
                     go to rcl-ctv-doc-420
           else if   w-sav-ctp-ven        not  = zero and
                     w-tes-ctp-ven (1)    =    zero
                     go to rcl-ctv-doc-440
           else if   w-sav-ctp-ven        not  = zero and
                     w-tes-ctp-ven (1)    not  = zero
                     go to rcl-ctv-doc-460.
       rcl-ctv-doc-420.
      *              *-------------------------------------------------*
      *              * Se contropartita vendite : da non esistente a   *
      *              * esistente                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Bufferizzazione contropartita vendite       *
      *                  *---------------------------------------------*
           move      w-tes-ctp-ven (1)    to   w-rig-ctv-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Ad aggiornamento catena e riciclo           *
      *                  *---------------------------------------------*
           go to     rcl-ctv-doc-500.
       rcl-ctv-doc-440.
      *              *-------------------------------------------------*
      *              * Se contropartita vendite : da esistente a non   *
      *              * esistente                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo riga        *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "P"
                     go to rcl-ctv-doc-442
           else if   w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to rcl-ctv-doc-450.
       rcl-ctv-doc-442.
      *                  *---------------------------------------------*
      *                  * Tipo riga : Prodotto di vendita             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura archivio [dcp]                  *
      *                      *-----------------------------------------*
           move      w-rig-num-pro (1)    to   w-let-dcp-pdx-cod      .
           move      w-tes-tip-arc (1)    to   w-let-dcp-pdx-tar      .
           if        w-tes-tip-frn (1)    =    11
                     move  w-tes-cod-arc (1)
                                          to   w-let-dcp-pdx-arc
           else      move  w-tes-arc-plf (1)
                                          to   w-let-dcp-pdx-arc      .
           move      w-tes-cod-lng (1)    to   w-let-dcp-pdx-lng      .
           perform   let-dcp-pdx-000      thru let-dcp-pdx-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata o codice controparti- *
      *                      * ta vendite a zero : a riciclo con set   *
      *                      * del flag di impossibilita' di determi-  *
      *                      * nazione di una contropartita            *
      *                      *-----------------------------------------*
           if        w-let-dcp-pdx-flg    not  = spaces or
                     w-let-dcp-pdx-ctp    =    zero
                     move  "#"            to   w-rcl-ctv-doc-fic
                     go to rcl-ctv-doc-580.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione contropartita vendite   *
      *                      *-----------------------------------------*
           move      w-let-dcp-pdx-ctp    to   w-rig-ctv-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Ad aggiornamento catena e riciclo       *
      *                      *-----------------------------------------*
           go to     rcl-ctv-doc-500.
       rcl-ctv-doc-450.
      *                  *---------------------------------------------*
      *                  * Tipo riga : Addebito                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura archivio [zac]                  *
      *                      *-----------------------------------------*
           move      01                   to   w-let-arc-zac-tip      .
           move      w-rig-tip-rig-cac (1)
                                          to   w-let-arc-zac-cod      .
           perform   let-arc-zac-000      thru let-arc-zac-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata o codice iva letto a  *
      *                      * zero : a riciclo con set del flag di    *
      *                      * impossibilita' di determinazione di un  *
      *                      * codice iva                              *
      *                      *-----------------------------------------*
           if        w-let-arc-zac-flg    not  = spaces or
                     w-let-arc-zac-ccp    =    zero
                     move  "#"            to   w-rcl-ctv-doc-fic
                     go to rcl-ctv-doc-580.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione contropartita vendite   *
      *                      *-----------------------------------------*
           move      w-let-arc-zac-ccp    to   w-rig-ctv-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Ad aggiornamento catena e riciclo       *
      *                      *-----------------------------------------*
           go to     rcl-ctv-doc-500.
       rcl-ctv-doc-460.
      *              *-------------------------------------------------*
      *              * Se contropartita vendite : da una ad un'altra   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Bufferizzazione codice iva                  *
      *                  *---------------------------------------------*
           move      w-tes-ctp-ven (1)    to   w-rig-ctv-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Ad aggiornamento catena e riciclo           *
      *                  *---------------------------------------------*
           go to     rcl-ctv-doc-500.
       rcl-ctv-doc-500.
      *              *-------------------------------------------------*
      *              * Lettura archivio [pdc]                          *
      *              *-------------------------------------------------*
           move      w-rig-ctv-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctv-rig-des (1)  .
      *              *-------------------------------------------------*
      *              * Aggiornamento catena movimenti                  *
      *              *-------------------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-cur        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       rcl-ctv-doc-580.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura catena                       *
      *              *-------------------------------------------------*
           go to     rcl-ctv-doc-300.
       rcl-ctv-doc-600.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       rcl-ctv-doc-800.
      *              *-------------------------------------------------*
      *              * Test se flag di impossibilita' di variazione di *
      *              * un codice contropartita attivo                  *
      *              *-------------------------------------------------*
           if        w-rcl-ctv-doc-fic    =    spaces
                     go to rcl-ctv-doc-900.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "Attenzione : non e' stato possibile applicare il r
      -              "icalcolo a uno "    to   w-err-box-err-msg      .
           move      "              o piu' codici contropartita vendite 
      -              "del documento. "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       rcl-ctv-doc-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     rcl-ctv-doc-999.
       rcl-ctv-doc-999.
           exit.

      *    *===========================================================*
      *    * Routine di ricalcolo descrizioni prodotti del documento   *
      *    *-----------------------------------------------------------*
       rcl-des-doc-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se corpo ancora da accettare : no           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-cor    =    spaces
                     go to rcl-des-doc-999.
       rcl-des-doc-100.
      *              *-------------------------------------------------*
      *              * Box di avviso con conferma                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      07                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      74                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Messaggi nel box                            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "                       A T T E N Z I O N E        
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "La modifica appena apportata potrebbe avere delle 
      -              "ripercussioni "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "sulle descrizioni dei prodotti del documento gia' 
      -              "imputate.     "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "Si desidera che esse vengano rideterminate (S/N) ?
      -              " [ ]          "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Preparazione default per risposta           *
      *                  *---------------------------------------------*
           move      spaces               to   v-alf                  .
       rcl-des-doc-120.
      *                  *---------------------------------------------*
      *                  * Accettazione risposta                       *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      61                   to   v-pos                  .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Controllo risposta operatore                *
      *                  *---------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "N"            to   v-alf
           else if   v-key                =    "DO  "
                     move  "S"            to   v-alf                  .
           if        v-alf                not  = "S" and
                     v-alf                not  = "N"
                     go to rcl-des-doc-120.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione risposta operatore          *
      *                  *---------------------------------------------*
           move      v-alf                to   w-rcl-des-doc-tro      .
      *                  *---------------------------------------------*
      *                  * Ripristino immagine video                   *
      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       rcl-des-doc-200.
      *              *-------------------------------------------------*
      *              * Se risposta operatore negativa : a uscita       *
      *              *-------------------------------------------------*
           if        w-rcl-des-doc-tro    =    "N"
                     go to rcl-des-doc-900.
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       rcl-des-doc-300.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to rcl-des-doc-600.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to rcl-des-doc-300.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to rcl-des-doc-300.
      *              *-------------------------------------------------*
      *              * Selezione su tipo riga                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se riga di commento : riciclo               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to rcl-des-doc-300.
      *                  *---------------------------------------------*
      *                  * Se riga di addebito : riciclo               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to rcl-des-doc-300.
      *                  *---------------------------------------------*
      *                  * Se prodotto similare : oltre                *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to rcl-des-doc-300.
       rcl-des-doc-400.
      *              *-------------------------------------------------*
      *              * Aggiornamento descrizione prodotti              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dcp]                      *
      *                  *---------------------------------------------*
           move      w-rig-num-pro (1)    to   w-let-dcp-pdx-cod      .
           move      w-tes-tip-arc (1)    to   w-let-dcp-pdx-tar      .
           if        w-tes-tip-frn (1)    =    11
                     move  w-tes-cod-arc (1)
                                          to   w-let-dcp-pdx-arc
           else      move  w-tes-arc-plf (1)
                                          to   w-let-dcp-pdx-arc      .
           move      w-tes-cod-lng (1)    to   w-let-dcp-pdx-lng      .
           perform   let-dcp-pdx-000      thru let-dcp-pdx-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata o descrizione a spa-  *
      *                      * zi : a riciclo con set del flag di      *
      *                      * impossibilita' di determinazione della  *
      *                      * descrizione                             *
      *                      *-----------------------------------------*
           if        w-let-dcp-pdx-flg    not  = spaces or
                     w-let-dcp-pdx-des    =    spaces
                     move  "#"            to   w-rcl-des-doc-fiv
                     go to rcl-des-doc-580.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione             *
      *                      *-----------------------------------------*
           move      w-let-dcp-pdx-des    to   w-rig-des-por (1)
                                               w-rig-des-rig (1)      .
       rcl-des-doc-500.
      *              *-------------------------------------------------*
      *              * Aggiornamento catena movimenti                  *
      *              *-------------------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-cur        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       rcl-des-doc-580.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura catena                       *
      *              *-------------------------------------------------*
           go to     rcl-des-doc-300.
       rcl-des-doc-600.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       rcl-des-doc-800.
      *              *-------------------------------------------------*
      *              * Test se flag di impossibilita' di variazione di *
      *              * un codice contropartita attivo                  *
      *              *-------------------------------------------------*
           if        w-rcl-des-doc-fiv    =    spaces
                     go to rcl-des-doc-900.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "Attenzione : non e' stato possibile applicare la v
      -              "ariazione a una"    to   w-err-box-err-msg      .
           move      "             o piu' descrizioni prodotti.         
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       rcl-des-doc-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     rcl-des-doc-999.
       rcl-des-doc-999.
           exit.

      *    *===========================================================*
      *    * Routine di ricalcolo listino prodotti del documento       *
      *    *-----------------------------------------------------------*
       rcl-lst-ven-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se corpo ancora da accettare : no           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-cor    =    spaces
                     go to rcl-lst-ven-999.
       rcl-lst-ven-100.
      *              *-------------------------------------------------*
      *              * Box di avviso con conferma                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      07                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      74                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Messaggi nel box                            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "                       A T T E N Z I O N E        
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "La modifica appena apportata potrebbe avere delle 
      -              "ripercussioni "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "sui prezzi di listino dei prodotti del documento g
      -              "ia' imputati. "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "Si desidera che essi vengano rideterminati (S/N) ?
      -              " [ ]          "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Preparazione default per risposta           *
      *                  *---------------------------------------------*
           move      spaces               to   v-alf                  .
       rcl-lst-ven-120.
      *                  *---------------------------------------------*
      *                  * Accettazione risposta                       *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      61                   to   v-pos                  .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Controllo risposta operatore                *
      *                  *---------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "N"            to   v-alf
           else if   v-key                =    "DO  "
                     move  "S"            to   v-alf                  .
           if        v-alf                not  = "S" and
                     v-alf                not  = "N"
                     go to rcl-lst-ven-120.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione risposta operatore          *
      *                  *---------------------------------------------*
           move      v-alf                to   w-rcl-lst-ven-tro      .
      *                  *---------------------------------------------*
      *                  * Ripristino immagine video                   *
      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       rcl-lst-ven-200.
      *              *-------------------------------------------------*
      *              * Se risposta operatore negativa : a uscita       *
      *              *-------------------------------------------------*
           if        w-rcl-lst-ven-tro    =    "N"
                     go to rcl-lst-ven-900.
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       rcl-lst-ven-300.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to rcl-lst-ven-600.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to rcl-lst-ven-300.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to rcl-lst-ven-300.
      *              *-------------------------------------------------*
      *              * Selezione su tipo riga                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se riga di commento : riciclo               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to rcl-lst-ven-300.
      *                  *---------------------------------------------*
      *                  * Se riga di addebito : riciclo               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to rcl-lst-ven-300.
      *                  *---------------------------------------------*
      *                  * Se prodotto similare : oltre                *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to rcl-lst-ven-300.
       rcl-lst-ven-400.
      *              *-------------------------------------------------*
      *              * Aggiornamento prezzi prodotti                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione prezzo di vendita            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura archivio [dcp]                  *
      *                      *-----------------------------------------*
           move      w-rig-num-pro (1)    to   w-let-dcp-pdx-cod      .
           move      w-tes-tip-arc (1)    to   w-let-dcp-pdx-tar      .
           if        w-tes-tip-frn (1)    =    11
                     move  w-tes-cod-arc (1)
                                          to   w-let-dcp-pdx-arc
           else      move  w-tes-arc-plf (1)
                                          to   w-let-dcp-pdx-arc      .
           move      w-tes-cod-lng (1)    to   w-let-dcp-pdx-lng      .
           perform   let-dcp-pdx-000      thru let-dcp-pdx-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata o codice iva letto a  *
      *                      * zero : a riciclo con set del flag di    *
      *                      * impossibilita' di determinazione di un  *
      *                      * codice iva                              *
      *                      *-----------------------------------------*
           if        w-let-dcp-pdx-flg    not  = spaces or
                     w-let-dcp-pdx-coi    =    zero
                     move  "#"            to   w-rcl-civ-doc-fiv
                     go to rcl-lst-ven-580.
      *                      *-----------------------------------------*
      *                      * Preparazione link-area                  *
      *                      *-----------------------------------------*
           move      "PV"                 to   d-prz-ven-tip-ope      .
           if        w-tes-tip-frn (1)    =    11
                     move  w-tes-cod-arc (1)
                                          to   d-prz-ven-cod-cli
           else      move  w-tes-arc-plf (1)
                                          to   d-prz-ven-cod-cli      .
           move      w-rig-sgl-vpp (1)    to   d-prz-ven-sgl-vpp      .
           move      w-rig-dec-vpp (1)    to   d-prz-ven-dec-vpp      .
           move      w-rig-num-pro (1)    to   d-prz-ven-num-pro      .
           move      w-tes-cod-lst (1)    to   d-prz-ven-cod-lst      .
           move      w-let-dcp-pdx-plb    to   d-prz-ven-prz-lsb      .
           move      w-let-dcp-pdx-vlb    to   d-prz-ven-sgl-vlb      .
           move      w-let-dcp-pdx-dlb    to   d-prz-ven-dec-vlb      .
           move      spaces               to   d-prz-ven-tfu-prz      .
           move      w-tes-dat-doc        to   d-prz-ven-dat-rfp      .
           move      w-rig-qta-ord (1)    to   d-prz-ven-qta-rif      .
      *                      *-----------------------------------------*
      *                      * Richiamo del sottoprogramma             *
      *                      *-----------------------------------------*
           perform   det-prz-ven-cll-000  thru det-prz-ven-cll-999    .
      *                      *-----------------------------------------*
      *                      * Memorizzazione valore determinato       *
      *                      *-----------------------------------------*
           move      d-prz-ven-prz-ven    to   w-rig-prz-ven (1)      .
       rcl-lst-ven-420.
      *                  *---------------------------------------------*
      *                  * Prezzo lordo standard                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-rig-prz-ven (1)    to   w-rig-prz-lrs (1)      .
       rcl-lst-ven-440.
      *                  *---------------------------------------------*
      *                  * Prezzo netto standard                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-rig-prz-ven (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       rcl-lst-ven-460.
      *                  *---------------------------------------------*
      *                  * Importo in riga                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
       rcl-lst-ven-480.
      *                  *---------------------------------------------*
      *                  * Provvigioni in riga                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da trattare                     *
      *                      *-----------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to rcl-lst-ven-500.
      *                      *-----------------------------------------*
      *                      * Se flag significativita' provvigioni    *
      *                      * per il documento indica 'No' o 'A for-  *
      *                      * fait' : No provvigioni in riga          *
      *                      *-----------------------------------------*
           if        w-tes-fsp-doc (1)    =    02 or
                     w-tes-fsp-doc (1)    =    03
                     move  02             to   w-rig-fsp-rig (1)
                     go to rcl-lst-ven-500.
      *                      *-----------------------------------------*
      *                      * Se flag significativita' provvigioni    *
      *                      * per il documento indica 'A forfait' in  *
      *                      * % : Forzatura provvigioni in riga       *
      *                      *-----------------------------------------*
           if        w-tes-fsp-doc (1)    =    04
                     move   03            to   w-rig-fsp-rig (1)
                     divide 100           into w-tes-pvf-age (1)
                                        giving w-rig-ppv-rig (1, 1)
                     go to rcl-lst-ven-500.
      *                      *-----------------------------------------*
      *                      * Default per provvigioni in riga : Si    *
      *                      *-----------------------------------------*
           move      01                   to   w-rig-fsp-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-ppv-rig-000      thru det-ppv-rig-999        .
       rcl-lst-ven-500.
      *              *-------------------------------------------------*
      *              * Aggiornamento catena movimenti                  *
      *              *-------------------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-cur        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       rcl-lst-ven-580.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura catena                       *
      *              *-------------------------------------------------*
           go to     rcl-lst-ven-300.
       rcl-lst-ven-600.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       rcl-lst-ven-800.
       rcl-lst-ven-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     rcl-lst-ven-999.
       rcl-lst-ven-999.
           exit.

      *    *===========================================================*
      *    * Routine di ricalcolo sconti in riga del documento         *
      *    *-----------------------------------------------------------*
       rcl-sco-rig-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se corpo ancora da accettare : no           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-cor    =    spaces
                     go to rcl-sco-rig-999.
       rcl-sco-rig-100.
      *              *-------------------------------------------------*
      *              * Box di avviso con conferma                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      07                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      74                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Messaggi nel box                            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "                       A T T E N Z I O N E        
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "La modifica appena apportata potrebbe avere delle 
      -              "ripercussioni "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "sugli sconti in riga gia' determinati.            
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "Si desidera che essi vengano ricalcolati (S/N) ? [
      -              " ]            "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Preparazione default per risposta           *
      *                  *---------------------------------------------*
           move      spaces               to   v-alf                  .
       rcl-sco-rig-120.
      *                  *---------------------------------------------*
      *                  * Accettazione risposta                       *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      59                   to   v-pos                  .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Controllo risposta operatore                *
      *                  *---------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "N"            to   v-alf
           else if   v-key                =    "DO  "
                     move  "S"            to   v-alf                  .
           if        v-alf                not  = "S" and
                     v-alf                not  = "N"
                     go to rcl-sco-rig-120.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione risposta operatore          *
      *                  *---------------------------------------------*
           move      v-alf                to   w-rcl-sco-rig-tro      .
      *                  *---------------------------------------------*
      *                  * Ripristino immagine video                   *
      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       rcl-sco-rig-200.
      *              *-------------------------------------------------*
      *              * Se risposta operatore negativa : a uscita       *
      *              *-------------------------------------------------*
           if        w-rcl-sco-rig-tro    =    "N"
                     go to rcl-sco-rig-900.
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       rcl-sco-rig-300.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to rcl-sco-rig-600.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to rcl-sco-rig-300.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to rcl-sco-rig-300.
      *              *-------------------------------------------------*
      *              * Selezione su tipo riga                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se riga di commento : riciclo               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to rcl-sco-rig-300.
      *                  *---------------------------------------------*
      *                  * Se riga di addebito : riciclo               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to rcl-sco-rig-300.
      *                  *---------------------------------------------*
      *                  * Se prodotto similare : oltre                *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to rcl-sco-rig-300.
       rcl-sco-rig-400.
      *              *-------------------------------------------------*
      *              * Aggiornamento sconti prodotti                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Percentuali di sconto in riga da categoria  *
      *                  * sconto in riga cliente                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      "SR"                 to   d-per-scr-tip-ope      .
           move      w-rig-psr-aap (1, 1) to   d-per-scr-psr-pro (1)  .
           move      w-rig-psr-aap (1, 2) to   d-per-scr-psr-pro (2)  .
           move      w-rig-psr-aap (1, 3) to   d-per-scr-psr-pro (3)  .
           move      w-rig-psr-aap (1, 4) to   d-per-scr-psr-pro (4)  .
           move      w-rig-psr-aap (1, 5) to   d-per-scr-psr-pro (5)  .
           move      w-rig-csr-aap (1)    to   d-per-scr-csr-pro      .
           move      w-tes-psr-aac (1, 1) to   d-per-scr-psr-cli (1)  .
           move      w-tes-psr-aac (1, 2) to   d-per-scr-psr-cli (2)  .
           move      w-tes-psr-aac (1, 3) to   d-per-scr-psr-cli (3)  .
           move      w-tes-psr-aac (1, 4) to   d-per-scr-psr-cli (4)  .
           move      w-tes-psr-aac (1, 5) to   d-per-scr-psr-cli (5)  .
           move      w-tes-csr-aac (1)    to   d-per-scr-csr-cli      .
           if        w-tes-tip-frn (1)    =    11
                     move  w-tes-cod-arc (1)
                                          to   d-per-scr-cod-cli
           else      move  w-tes-arc-plf (1)
                                          to   d-per-scr-cod-cli      .
           move      w-tes-cod-lst (1)    to   d-per-scr-cod-lst      .
           move      w-rig-sgl-vpp (1)    to   d-per-scr-sgl-vpf      .
           move      w-rig-num-pro (1)    to   d-per-scr-num-pro      .
           move      w-tes-dat-doc        to   d-per-scr-dat-rif      .
      *                      *-----------------------------------------*
      *                      * Richiamo del sottoprogramma             *
      *                      *-----------------------------------------*
           move      "pgm/fat/prg/obj/dperscr0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-per-scr              .
      *                      *-----------------------------------------*
      *                      * Memorizzazione valori determinati       *
      *                      *-----------------------------------------*
           move      d-per-scr-per-scr (1)
                                          to   w-rig-per-scr (1, 1)   .
           move      d-per-scr-per-scr (2)
                                          to   w-rig-per-scr (1, 2)   .
           move      d-per-scr-per-scr (3)
                                          to   w-rig-per-scr (1, 3)   .
           move      d-per-scr-per-scr (4)
                                          to   w-rig-per-scr (1, 4)   .
           move      d-per-scr-per-scr (5)
                                          to   w-rig-per-scr (1, 5)   .
      *                  *---------------------------------------------*
      *                  * Determinazione prezzo netto                 *
      *                  *---------------------------------------------*
           move      w-rig-prz-ven (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       rcl-sco-rig-450.
      *                  *---------------------------------------------*
      *                  * Importo in riga                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
       rcl-sco-rig-480.
      *                  *---------------------------------------------*
      *                  * Provvigioni in riga                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da trattare                     *
      *                      *-----------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to rcl-sco-rig-500.
      *                      *-----------------------------------------*
      *                      * Se flag significativita' provvigioni    *
      *                      * per il documento indica 'No' o 'A for-  *
      *                      * fait' : No provvigioni in riga          *
      *                      *-----------------------------------------*
           if        w-tes-fsp-doc (1)    =    02 or
                     w-tes-fsp-doc (1)    =    03
                     move  02             to   w-rig-fsp-rig (1)
                     go to rcl-sco-rig-500.
      *                      *-----------------------------------------*
      *                      * Se flag significativita' provvigioni    *
      *                      * per il documento indica 'A forfait' in  *
      *                      * % : Forzatura provvigioni in riga       *
      *                      *-----------------------------------------*
           if        w-tes-fsp-doc (1)    =    04
                     move   03            to   w-rig-fsp-rig (1)
                     divide 100           into w-tes-pvf-age (1)
                                        giving w-rig-ppv-rig (1, 1)
                     go to rcl-sco-rig-500.
      *                      *-----------------------------------------*
      *                      * Default per provvigioni in riga : Si    *
      *                      *-----------------------------------------*
           move      01                   to   w-rig-fsp-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-ppv-rig-000      thru det-ppv-rig-999        .
       rcl-sco-rig-500.
      *              *-------------------------------------------------*
      *              * Aggiornamento catena movimenti                  *
      *              *-------------------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-cur        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       rcl-sco-rig-580.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura catena                       *
      *              *-------------------------------------------------*
           go to     rcl-sco-rig-300.
       rcl-sco-rig-600.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       rcl-sco-rig-800.
       rcl-sco-rig-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     rcl-sco-rig-999.
       rcl-sco-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Fatturazione separata per il *
      *    * documento                                                 *
      *    *-----------------------------------------------------------*
       acc-fat-sep-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione eventuale default              *
      *                  *---------------------------------------------*
           if        w-tes-fat-sep (1)    =    spaces
                     move  "N"            to   w-tes-fat-sep (1)
                     perform vis-fat-sep-000
                                          thru vis-fat-sep-999        .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-fat-sep-400.
       acc-fat-sep-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-fat-sep-lun    to   v-car                  .
           move      w-exp-fat-sep-num    to   v-ldt                  .
           move      "NS#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      13                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-fat-sep-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           if        w-tes-fat-sep (1)    =    "N"
                     move  01             to   v-num
           else if   w-tes-fat-sep (1)    =    "S"
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-fat-sep-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-fat-sep-999.
       acc-fat-sep-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    01
                     move  "N"            to   w-tes-fat-sep (1)
           else if   v-num                =    02
                     move  "S"            to   w-tes-fat-sep (1)
           else      move  spaces         to   w-tes-fat-sep (1)      .
       acc-fat-sep-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a spaces non ammesso, a meno che     *
      *                  * non si sia in Up                            *
      *                  *---------------------------------------------*
           if        w-tes-fat-sep (1)    not  = spaces
                     go to acc-fat-sep-500.
           if        v-key                =    "UP  "
                     go to acc-fat-sep-600
           else      go to acc-fat-sep-100.
       acc-fat-sep-500.
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
           if        w-tes-fat-sep (1)    not  = "S" and
                     w-tes-fat-sep (1)    not  = "N"
                     go to acc-fat-sep-100.
       acc-fat-sep-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-fat-sep-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-fat-sep-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-fat-sep-100.
       acc-fat-sep-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Fatturazione separata per *
      *    * il documento                                              *
      *    *-----------------------------------------------------------*
       vis-fat-sep-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione                             *
      *              *-------------------------------------------------*
       vis-fat-sep-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione valore                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-fat-sep-lun    to   v-car                  .
           move      w-exp-fat-sep-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      13                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-fat-sep-tbl    to   v-txt                  .
           if        w-tes-fat-sep (1)    =    "N"
                     move  01             to   v-num
           else if   w-tes-fat-sep (1)    =    "S"
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-fat-sep-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Voce descrittiva ennesima in *
      *    *                              funzione di w-acc-voc-des-ctr*
      *    *-----------------------------------------------------------*
       acc-voc-des-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-vde-fat-nvt    =    zero
                     go to acc-voc-des-999.
      *                  *---------------------------------------------*
      *                  * Preparazione indice per la voce             *
      *                  *---------------------------------------------*
           move      w-prs-vde-fat-npt
                    (w-acc-voc-des-ctr)   to   w-acc-voc-des-inx      .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-voc-des-400.
       acc-voc-des-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-zvf-ope      .
           move      w-acc-voc-des-inx    to   w-cod-cod-zvf-voc      .
           move      "I  "                to   w-cod-cod-zvf-lng      .
           move      w-tes-voc-des
                    (1, w-acc-voc-des-inx)
                                          to   w-cod-cod-zvf-cod      .
           add       15
                     w-acc-voc-des-ctr  giving w-cod-cod-zvf-lin      .
           move      30                   to   w-cod-cod-zvf-pos      .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-zvf-cll-000  thru cod-cod-zvf-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-zvf-foi-000  thru cod-cod-zvf-foi-999    .
       acc-voc-des-110.
           perform   cod-cod-zvf-cll-000  thru cod-cod-zvf-cll-999    .
           if        w-cod-cod-zvf-ope    =    "F+"
                     go to acc-voc-des-115.
           if        w-cod-cod-zvf-ope    =    "AC"
                     go to acc-voc-des-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-voc-des-115.
           perform   cod-cod-zvf-foi-000  thru cod-cod-zvf-foi-999    .
           go to     acc-voc-des-110.
       acc-voc-des-120.
           move      w-cod-cod-zvf-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-voc-des-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-voc-des-999.
       acc-voc-des-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-voc-des
                                              (1, w-acc-voc-des-inx)  .
       acc-voc-des-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [zvf]                      *
      *                  *---------------------------------------------*
           move      w-acc-voc-des-inx    to   w-let-arc-zvf-num      .
           move      w-tes-voc-des
                    (1, w-acc-voc-des-inx)
                                          to   w-let-arc-zvf-cod      .
           perform   let-arc-zvf-000      thru let-arc-zvf-999        .
           move      w-let-arc-zvf-des    to   w-tes-voc-des-des
                                              (1, w-acc-voc-des-inx)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           move      w-acc-voc-des-ctr    to   w-vis-voc-des-ctr      .
           perform   vis-voc-des-des-000  thru vis-voc-des-des-999    .
      *                  *---------------------------------------------*
      *                  * Se record non esistente : reimpostazione    *
      *                  *---------------------------------------------*
           if        w-let-arc-zvf-flg    not  = spaces
                     go to acc-voc-des-100.
       acc-voc-des-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-voc-des-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-voc-des-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-voc-des-100.
       acc-voc-des-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Voce descrittiva ennesima *
      *    * in funzione di w-vis-voc-des-ctr                          *
      *    *-----------------------------------------------------------*
       vis-voc-des-000.
      *              *-------------------------------------------------*
      *              * Preparazione indice per la voce                 *
      *              *-------------------------------------------------*
           move      w-prs-vde-fat-npt
                    (w-vis-voc-des-ctr)   to   w-vis-voc-des-inx      .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           add       15
                     w-vis-voc-des-ctr  giving v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-voc-des
                    (1, w-vis-voc-des-inx)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-voc-des-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione voce descrit- *
      *    * tiva ennesima in funzione di w-vis-voc-des-ctr            *
      *    *-----------------------------------------------------------*
       vis-voc-des-des-000.
      *              *-------------------------------------------------*
      *              * Preparazione indice per la voce                 *
      *              *-------------------------------------------------*
           move      w-prs-vde-fat-npt
                    (w-vis-voc-des-ctr)   to   w-vis-voc-des-inx      .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      25                   to   v-car                  .
           add       15
                     w-vis-voc-des-ctr  giving v-lin                  .
           move      35                   to   v-pos                  .
           move      w-tes-voc-des-des
                    (1, w-vis-voc-des-inx)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-voc-des-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice listino               *
      *    *-----------------------------------------------------------*
       acc-cod-lst-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cod-lst (1)    to   w-sav-cod-lst          .
      *                  *---------------------------------------------*
      *                  * Se Tab in corso : a controllo valore impo-  *
      *                  * stato                                       *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-lst-400.
       acc-cod-lst-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-lst-ope      .
           move      w-tes-cod-lst (1)    to   w-cod-cod-lst-cod      .
           move      05                   to   w-cod-cod-lst-lin      .
           move      30                   to   w-cod-cod-lst-pos      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-zls-cll-000  thru cod-cod-zls-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-zls-foi-000  thru cod-cod-zls-foi-999    .
       acc-cod-lst-110.
           perform   cod-cod-zls-cll-000  thru cod-cod-zls-cll-999    .
           if        w-cod-cod-lst-ope    =    "F+"
                     go to acc-cod-lst-115.
           if        w-cod-cod-lst-ope    =    "AC"
                     go to acc-cod-lst-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-lst-115.
           perform   cod-cod-zls-foi-000  thru cod-cod-zls-foi-999    .
           go to     acc-cod-lst-110.
       acc-cod-lst-120.
           move      w-cod-cod-lst-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-lst-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-lst-999.
       acc-cod-lst-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-cod-lst (1)      .
       acc-cod-lst-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [zls]                      *
      *                  *---------------------------------------------*
           move      w-tes-cod-lst (1)    to   w-let-arc-zls-cod      .
           perform   let-arc-zls-000      thru let-arc-zls-999        .
           move      w-let-arc-zls-des    to   w-tes-cod-lst-des (1)  .
           move      w-let-arc-zls-drg    to   w-tes-cod-lst-drg (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-lst-000      thru vis-des-lst-999        .
           perform   vis-drg-lst-000      thru vis-drg-lst-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-zls-flg    not  = spaces
                     go to acc-cod-lst-100.
       acc-cod-lst-430.
      *                  *---------------------------------------------*
      *                  * Se listino di lavoro : messaggio e reimpo-  *
      *                  * stazione                                    *
      *                  *---------------------------------------------*
           if        w-let-arc-zls-wrk    =    spaces
                     go to acc-cod-lst-440.
           move      "Codice Listino corrispondente ad un Listino di lav
      -              "oro !          "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-cod-lst-100.
       acc-cod-lst-440.
      *                  *---------------------------------------------*
      *                  * Controllo valuta del listino con quella del *
      *                  * documento                                   *
      *                  *---------------------------------------------*
           if        w-tes-cod-lst (1)    =    spaces
                     go to acc-cod-lst-500.
           if        w-let-arc-zls-vlt    =    w-tes-sgl-vpf (1)
                     go to acc-cod-lst-500.
      *                      *-----------------------------------------*
      *                      * Se incompatibile : messaggio di errore  *
      *                      *-----------------------------------------*
           move      "Listino incompatibile in termini di sigla valuta !
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-cod-lst-100.
       acc-cod-lst-500.
       acc-cod-lst-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se valore variato                      *
      *                  *---------------------------------------------*
           if        w-tes-cod-lst (1)    =    w-sav-cod-lst
                     go to acc-cod-lst-800.
      *                  *---------------------------------------------*
      *                  * Ricalcolo listino prodotti del documento    *
      *                  *---------------------------------------------*
           perform   rcl-lst-ven-000      thru rcl-lst-ven-999        .
       acc-cod-lst-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-lst-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-lst-100.
       acc-cod-lst-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice listino            *
      *    *-----------------------------------------------------------*
       vis-cod-lst-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-lst (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-lst-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione listino       *
      *    *-----------------------------------------------------------*
       vis-des-lst-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-tes-cod-lst-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-lst-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Direttive generali listino        *
      *    *-----------------------------------------------------------*
       vis-drg-lst-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      61                   to   v-pos                  .
           if        w-tes-cod-lst-drg (1)
                                          =    "K"
                     move  "(Prezzi per 1000)   "
                                          to   v-alf
           else      move  spaces         to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-drg-lst-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo chiave : Codice lingua                 *
      *    *-----------------------------------------------------------*
       acc-cod-lng-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cod-lng (1)    to    w-sav-cod-lng         .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-lng-400.
       acc-cod-lng-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-zln-ope      .
           move      w-tes-cod-lng (1)    to   w-cod-cod-zln-cod      .
           move      06                   to   w-cod-cod-zln-lin      .
           move      30                   to   w-cod-cod-zln-pos      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-zln-cll-000  thru cod-cod-zln-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-zln-foi-000  thru cod-cod-zln-foi-999    .
       acc-cod-lng-110.
           perform   cod-cod-zln-cll-000  thru cod-cod-zln-cll-999    .
           if        w-cod-cod-zln-ope    =    "F+"
                     go to acc-cod-lng-115.
           if        w-cod-cod-zln-ope    =    "AC"
                     go to acc-cod-lng-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-lng-115.
           perform   cod-cod-zln-foi-000  thru cod-cod-zln-foi-999    .
           go to     acc-cod-lng-110.
       acc-cod-lng-120.
           move      w-cod-cod-zln-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-lng-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-lng-999.
       acc-cod-lng-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-cod-lng (1)      .
       acc-cod-lng-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura file [zln]                          *
      *                  *---------------------------------------------*
           move      w-tes-cod-lng (1)    to   w-let-arc-zln-cod      .
           perform   let-arc-zln-000      thru let-arc-zln-999        .
           move      w-let-arc-zln-des    to   w-tes-cod-lng-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-lng-000      thru vis-des-lng-999        .
      *                  *---------------------------------------------*
      *                  * Test sul flag                               *
      *                  *---------------------------------------------*
           if        w-let-arc-zln-flg    not  = spaces
                     go to acc-cod-lng-100.
      *                  *---------------------------------------------*
      *                  * Se valore a spaces : reimpostazione         *
      *                  *---------------------------------------------*
           if        w-tes-cod-lng (1)    not  = spaces
                     go to acc-cod-lng-600.
           go to     acc-cod-lng-100.
       acc-cod-lng-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se valore variato                      *
      *                  *---------------------------------------------*
           if        w-tes-cod-lng (1)    =    w-sav-cod-lng
                     go to acc-cod-lng-800.
      *                  *---------------------------------------------*
      *                  * Ricalcolo descrizione prodotti del documen- *
      *                  * to                                          *
      *                  *---------------------------------------------*
           perform   rcl-des-doc-000      thru rcl-des-doc-999        .
       acc-cod-lng-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-lng-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-lng-100.
       acc-cod-lng-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo chiave : Codice lingua              *
      *    *-----------------------------------------------------------*
       vis-cod-lng-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-lng (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-lng-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione lingua        *
      *    *-----------------------------------------------------------*
       vis-des-lng-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-tes-cod-lng-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-lng-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Categoria sconto in riga     *
      *    *-----------------------------------------------------------*
       acc-csr-aac-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-csr-aac (1)    to   w-sav-csr-aac          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-csr-aac-400.
       acc-csr-aac-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cmn-zcs-002-ope      .
           move      w-tes-csr-aac (1)    to   w-cmn-zcs-002-cod      .
           move      08                   to   w-cmn-zcs-002-lin      .
           move      30                   to   w-cmn-zcs-002-pos      .
           move      08                   to   w-cmn-zcs-002-dln      .
           move      37                   to   w-cmn-zcs-002-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cmn-zcs-002-cll-000  thru cmn-zcs-002-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cmn-zcs-002-foi-000  thru cmn-zcs-002-foi-999    .
       acc-csr-aac-110.
           perform   cmn-zcs-002-cll-000  thru cmn-zcs-002-cll-999    .
           if        w-cmn-zcs-002-ope    =    "F+"
                     go to acc-csr-aac-115.
           if        w-cmn-zcs-002-ope    =    "AC"
                     go to acc-csr-aac-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-csr-aac-115.
           perform   cmn-zcs-002-foi-000  thru cmn-zcs-002-foi-999    .
           go to     acc-csr-aac-110.
       acc-csr-aac-120.
           move      w-cmn-zcs-002-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-csr-aac-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-csr-aac-999.
       acc-csr-aac-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-csr-aac (1)      .
       acc-csr-aac-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      02                   to   w-let-arc-zcs-tip      .
           move      w-tes-csr-aac (1)    to   w-let-arc-zcs-cod      .
           perform   let-arc-zcs-000      thru let-arc-zcs-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-zcs-des    to   w-tes-csr-aac-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-csr-000      thru vis-des-csr-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-zcs-flg    not  = spaces
                     go to acc-csr-aac-100.
       acc-csr-aac-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Memorizzazione % di sconto associate        *
      *                  *---------------------------------------------*
           move      w-let-arc-zcs-per (1)
                                          to   w-tes-psr-acc (1, 1)   .
           move      w-let-arc-zcs-per (2)
                                          to   w-tes-psr-acc (1, 2)   .
           move      w-let-arc-zcs-per (3)
                                          to   w-tes-psr-acc (1, 3)   .
           move      w-let-arc-zcs-per (4)
                                          to   w-tes-psr-acc (1, 4)   .
           move      w-let-arc-zcs-per (5)
                                          to   w-tes-psr-acc (1, 5)   .
      *                  *---------------------------------------------*
      *                  * Test se valore variato                      *
      *                  *---------------------------------------------*
           if        w-tes-csr-aac (1)    =    w-sav-csr-aac
                     go to acc-csr-aac-800.
      *                  *---------------------------------------------*
      *                  * Ricalcolo sconti                            *
      *                  *---------------------------------------------*
           perform   rcl-sco-rig-000      thru rcl-sco-rig-999        .
       acc-csr-aac-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-csr-aac-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-csr-aac-100.
       acc-csr-aac-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Categoria sconto in riga  *
      *    *-----------------------------------------------------------*
       vis-csr-aac-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      08                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-csr-aac (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-csr-aac-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione categoria     *
      *    * sconto in riga                                            *
      *    *-----------------------------------------------------------*
       vis-des-csr-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-tes-csr-aac-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-csr-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Categoria sconto in chiusura *
      *    *-----------------------------------------------------------*
       acc-csc-aac-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-csc-aac-400.
       acc-csc-aac-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cmn-zcs-001-ope      .
           move      w-tes-csc-aac (1)    to   w-cmn-zcs-001-cod      .
           move      09                   to   w-cmn-zcs-001-lin      .
           move      30                   to   w-cmn-zcs-001-pos      .
           move      09                   to   w-cmn-zcs-001-dln      .
           move      37                   to   w-cmn-zcs-001-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cmn-zcs-001-cll-000  thru cmn-zcs-001-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cmn-zcs-001-foi-000  thru cmn-zcs-001-foi-999    .
       acc-csc-aac-110.
           perform   cmn-zcs-001-cll-000  thru cmn-zcs-001-cll-999    .
           if        w-cmn-zcs-001-ope    =    "F+"
                     go to acc-csc-aac-115.
           if        w-cmn-zcs-001-ope    =    "AC"
                     go to acc-csc-aac-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-csc-aac-115.
           perform   cmn-zcs-001-foi-000  thru cmn-zcs-001-foi-999    .
           go to     acc-csc-aac-110.
       acc-csc-aac-120.
           move      w-cmn-zcs-001-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-csc-aac-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-csc-aac-999.
       acc-csc-aac-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-csc-aac (1)      .
       acc-csc-aac-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      01                   to   w-let-arc-zcs-tip      .
           move      w-tes-csc-aac (1)    to   w-let-arc-zcs-cod      .
           perform   let-arc-zcs-000      thru let-arc-zcs-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-zcs-des    to   w-tes-csc-aac-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-csc-000      thru vis-des-csc-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-zcs-flg    not  = spaces
                     go to acc-csc-aac-100.
       acc-csc-aac-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Memorizzazione % di sconto associata alla   *
      *                  * categoria                                   *
      *                  *---------------------------------------------*
           move      w-let-arc-zcs-per (1)
                                          to   w-tes-psc-acc (1)      .
      *                  *---------------------------------------------*
      *                  * Determinazione % sconto in chiusura         *
      *                  *---------------------------------------------*
           perform   det-per-scc-000      thru det-per-scc-999        .
       acc-csc-aac-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-csc-aac-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-csc-aac-100.
       acc-csc-aac-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Categoria sconto chiusura *
      *    *-----------------------------------------------------------*
       vis-csc-aac-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      09                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-csc-aac (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-csc-aac-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione categoria     *
      *    * sconto chiusura                                           *
      *    *-----------------------------------------------------------*
       vis-des-csc-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-tes-csc-aac-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-csc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice agente                *
      *    *-----------------------------------------------------------*
       acc-cod-age-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cod-age (1)    to   w-sav-cod-age          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-age-400.
       acc-cod-age-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-age-ope      .
           move      w-tes-cod-age (1)    to   w-cod-mne-age-cod      .
           move      12                   to   w-cod-mne-age-lin      .
           move      30                   to   w-cod-mne-age-pos      .
           move      12                   to   w-cod-mne-age-nln      .
           move      41                   to   w-cod-mne-age-nps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-age-cll-000  thru cod-mne-age-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-age-foi-000  thru cod-mne-age-foi-999    .
       acc-cod-age-110.
           perform   cod-mne-age-cll-000  thru cod-mne-age-cll-999    .
           if        w-cod-mne-age-ope    =    "F+"
                     go to acc-cod-age-115.
           if        w-cod-mne-age-ope    =    "AC"
                     go to acc-cod-age-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-age-115.
           perform   cod-mne-age-foi-000  thru cod-mne-age-foi-999    .
           go to     acc-cod-age-110.
       acc-cod-age-120.
           move      w-cod-mne-age-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-age-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-age-999.
       acc-cod-age-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-age (1)      .
       acc-cod-age-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [age]                      *
      *                  *---------------------------------------------*
           move      w-tes-cod-age (1)    to   w-let-arc-age-cod      .
           perform   let-arc-age-000      thru let-arc-age-999        .
           move      w-let-arc-age-rag    to   w-tes-cod-age-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-age-000      thru vis-des-age-999        .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-age-flg    not  = spaces
                     go to acc-cod-age-100.
       acc-cod-age-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale non esistente             *
      *                  *---------------------------------------------*
           if        w-tes-cod-age (1)    not  = zero
                     go to acc-cod-age-700.
      *                      *-----------------------------------------*
      *                      * Trattamento flag di significativita'    *
      *                      * provvigioni per il documento            *
      *                      *-----------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     move  02             to   w-tes-fsp-doc (1)
                     go to acc-cod-age-610.
           if        w-tes-fsp-doc (1)    =    02
                     go to acc-cod-age-610.
           move      02                   to   w-tes-fsp-doc (1)      .
           perform   vis-fsp-doc-000      thru vis-fsp-doc-999        .
      *                      *-----------------------------------------*
      *                      * Normalizzazione dati provvigionali ri-  *
      *                      * ghe corpo                               *
      *                      *-----------------------------------------*
           perform   nor-dpv-rig-000      thru nor-dpv-rig-999        .
       acc-cod-age-610.
      *                      *-----------------------------------------*
      *                      * Trattamento tipo vendita per l'agente   *
      *                      *-----------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     move  zero           to   w-tes-tip-vpa (1)
                     go to acc-cod-age-620.
           if        w-tes-tip-vpa (1)    =    zero
                     go to acc-cod-age-620.
           move      zero                 to   w-tes-tip-vpa (1)      .
           perform   vis-tip-vpa-000      thru vis-tip-vpa-999        .
       acc-cod-age-620.
      *                      *-----------------------------------------*
      *                      * Trattamento importo provvigioni a for-  *
      *                      * fait per il documento                   *
      *                      *-----------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-cod-age-630.
           if        w-tes-pvf-age (1)    =    zero
                     go to acc-cod-age-630.
           move      zero                 to   w-tes-pvf-age (1)      .
           perform   vis-pvf-age-000      thru vis-pvf-age-999        .
       acc-cod-age-630.
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-cod-age-800.
       acc-cod-age-700.
      *                  *---------------------------------------------*
      *                  * Se valore attuale esistente                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore attuale come precedente : ol- *
      *                      * tre                                     *
      *                      *-----------------------------------------*
           if        w-tes-cod-age (1)    =    w-sav-cod-age
                     go to acc-cod-age-800.
       acc-cod-age-710.
      *                      *-----------------------------------------*
      *                      * Trattamento categoria provvigioni asso- *
      *                      * ciata all'agente                        *
      *                      *-----------------------------------------*
           move      w-let-arc-age-cpv    to   w-tes-cpv-aaa (1)      .
       acc-cod-age-720.
      *                      *-----------------------------------------*
      *                      * Trattamento percentuali di provvigione  *
      *                      * associate all'agente                    *
      *                      *-----------------------------------------*
           move      w-let-arc-age-ppv (1)
                                          to   w-tes-ppv-aaa (1, 1)   .
           move      w-let-arc-age-ppv (2)
                                          to   w-tes-ppv-aaa (1, 2)   .
           move      w-let-arc-age-ppv (3)
                                          to   w-tes-ppv-aaa (1, 3)   .
       acc-cod-age-730.
      *                      *-----------------------------------------*
      *                      * Eventuale ricalcolo dati provvigionali  *
      *                      * in riga                                 *
      *                      *-----------------------------------------*
           perform   rcl-dpv-rig-000      thru rcl-dpv-rig-999        .
       acc-cod-age-740.
      *                      *-----------------------------------------*
      *                      * Trattamento contropartita vendite       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se contropartita vendite associata  *
      *                          * all'agente a zero : oltre           *
      *                          *-------------------------------------*
           if        w-let-arc-age-ctv    =    zero
                     go to acc-cod-age-750.
      *                          *-------------------------------------*
      *                          * Salvataggio contropartita vendite   *
      *                          * attuale                             *
      *                          *-------------------------------------*
           move      w-tes-ctp-ven (1)    to   w-sav-ctp-ven          .
      *                          *-------------------------------------*
      *                          * Bufferizzazione contropartita ven-  *
      *                          * dite associata all'agente           *
      *                          *-------------------------------------*
           move      w-let-arc-age-ctv    to   w-tes-ctp-ven (1)      .
           move      w-tes-ctp-ven (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-tes-ctp-ven-des (1)  .
      *                          *-------------------------------------*
      *                          * Ricalcolo contropartite vendite del *
      *                          * documento                           *
      *                          *-------------------------------------*
           perform   rcl-ctv-doc-000      thru rcl-ctv-doc-999        .
       acc-cod-age-750.
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-cod-age-800.
       acc-cod-age-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-age-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-age-100.
       acc-cod-age-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice agente             *
      *    *-----------------------------------------------------------*
       vis-cod-age-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      12                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<B"                 to   v-edm                  .
           move      w-tes-cod-age (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-age-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione agente        *
      *    *-----------------------------------------------------------*
       vis-des-age-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-age-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-age-999.
           exit.

      *    *===========================================================*
      *    * Routine di normalizzazione dati provvigionali nelle righe *
      *    *-----------------------------------------------------------*
       nor-dpv-rig-000.
      *              *-------------------------------------------------*
      *              * Se corpo ancora da accettare : uscita           *
      *              *-------------------------------------------------*
           if        w-cnt-sts-imp-cor    =    spaces
                     go to nor-dpv-rig-999.
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       nor-dpv-rig-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to nor-dpv-rig-900.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to nor-dpv-rig-100.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to nor-dpv-rig-100.
      *              *-------------------------------------------------*
      *              * Selezione su tipo riga                          *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to nor-dpv-rig-100.
       nor-dpv-rig-150.
      *              *-------------------------------------------------*
      *              * Normalizzazione valori di accettazione provvi-  *
      *              * gioni in riga                                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del flag di testata  *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    =    04
                     go to nor-dpv-rig-400.
       nor-dpv-rig-200.
      *                  *---------------------------------------------*
      *                  * Se flag a 02 o 03                           *
      *                  *---------------------------------------------*
           move      02                   to   w-rig-fsp-rig (1)      .
           move      zero                 to   w-rig-ppv-rig (1, 1)   .
           move      zero                 to   w-rig-ppv-rig (1, 2)   .
           move      zero                 to   w-rig-ppv-rig (1, 3)   .
           move      zero                 to   w-rig-pvf-rig (1)      .
           go to     nor-dpv-rig-800.
       nor-dpv-rig-400.
      *                  *---------------------------------------------*
      *                  * Se flag a 04                                *
      *                  *---------------------------------------------*
           move      03                   to   w-rig-fsp-rig (1)      .
           move      zero                 to   w-rig-ppv-rig (1, 1)   .
           move      zero                 to   w-rig-ppv-rig (1, 2)   .
           move      zero                 to   w-rig-ppv-rig (1, 3)   .
           move      zero                 to   w-rig-pvf-rig (1)      .
           go to     nor-dpv-rig-800.
       nor-dpv-rig-800.
      *              *-------------------------------------------------*
      *              * Aggiornamento catena movimenti                  *
      *              *-------------------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-cur        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura catena                       *
      *              *-------------------------------------------------*
           go to     nor-dpv-rig-100.
       nor-dpv-rig-900.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       nor-dpv-rig-999.
           exit.

      *    *===========================================================*
      *    * Routine di ricalcolo indicatore in riga di ordine da      *
      *    * verificare                                                *
      *    *-----------------------------------------------------------*
       rcl-oav-rig-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se corpo ancora da accettare : no           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-cor    =    spaces
                     go to rcl-oav-rig-999.
      *                  *---------------------------------------------*
      *                  * Test se personalizzazione lo prevede        *
      *                  *---------------------------------------------*
           if        w-prs-snx-oav-snx    =    "N"
                     go to rcl-oav-rig-999.
       rcl-oav-rig-100.
      *              *-------------------------------------------------*
      *              * Box di avviso con conferma                      *
      *              *                                                 *
      *              * Attualmente non previsto                        *
      *              *-------------------------------------------------*
       rcl-oav-rig-200.
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       rcl-oav-rig-300.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to rcl-oav-rig-900.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to rcl-oav-rig-300.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to rcl-oav-rig-300.
       rcl-oav-rig-400.
      *              *-------------------------------------------------*
      *              * Selezione su tipo riga                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se riga di commento : riciclo               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to rcl-oav-rig-300.
      *                  *---------------------------------------------*
      *                  * Se riga di addebito : riciclo               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to rcl-oav-rig-300.
      *                  *---------------------------------------------*
      *                  * Se prodotto similare : riciclo              *
      *                  *---------------------------------------------*
______*    if        w-rig-tip-rig-tfu (1)
______*                                   =    "N"
______*              go to rcl-oav-rig-300.
       rcl-oav-rig-500.
      *              *-------------------------------------------------*
      *              * Flag di verifica ordine                         *
      *              *-------------------------------------------------*
           move      w-tes-flg-nbx (1, 1)
                                          to   w-rig-flg-nbx (1, 1)   .
       rcl-oav-rig-800.
      *              *-------------------------------------------------*
      *              * Aggiornamento catena movimenti                  *
      *              *-------------------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-cur        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura catena                       *
      *              *-------------------------------------------------*
           go to     rcl-oav-rig-300.
       rcl-oav-rig-900.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       rcl-oav-rig-999.
           exit.

      *    *===========================================================*
      *    * Routine di ricalcolo dati provvigionali in riga           *
      *    *-----------------------------------------------------------*
       rcl-dpv-rig-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se corpo ancora da accettare : no           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-cor    =    spaces
                     go to rcl-dpv-rig-999.
      *                  *---------------------------------------------*
      *                  * Test se gestione agenti attiva              *
      *                  *---------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to rcl-dpv-rig-999.
      *                  *---------------------------------------------*
      *                  * Test se flag significativita' provvigioni   *
      *                  * per il documento indica 'No' o 'A forfait'  *
      *                  * per importo                                 *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    =    02 or
                     w-tes-fsp-doc (1)    =    03
                     go to rcl-dpv-rig-999.
       rcl-dpv-rig-100.
      *              *-------------------------------------------------*
      *              * Box di avviso con conferma                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      07                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      74                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Messaggi nel box                            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "                       A T T E N Z I O N E        
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "La modifica appena apportata potrebbe avere delle 
      -              "ripercussioni "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "sulle provvigioni in riga gia' determinate.       
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "Si desidera che esse vengano ricalcolate (S/N) ? [
      -              " ]            "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Preparazione default per risposta           *
      *                  *---------------------------------------------*
           move      spaces               to   v-alf                  .
       rcl-dpv-rig-120.
      *                  *---------------------------------------------*
      *                  * Accettazione risposta                       *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      59                   to   v-pos                  .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Controllo risposta operatore                *
      *                  *---------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "N"            to   v-alf
           else if   v-key                =    "DO  "
                     move  "S"            to   v-alf                  .
           if        v-alf                not  = "S" and
                     v-alf                not  = "N"
                     go to rcl-dpv-rig-120.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione risposta operatore          *
      *                  *---------------------------------------------*
           move      v-alf                to   w-rcl-dpv-rig-tro      .
      *                  *---------------------------------------------*
      *                  * Ripristino immagine video                   *
      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       rcl-dpv-rig-200.
      *              *-------------------------------------------------*
      *              * Se risposta operatore negativa : uscita         *
      *              *-------------------------------------------------*
           if        w-rcl-dpv-rig-tro    =    "N"
                     go to rcl-dpv-rig-999.
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       rcl-dpv-rig-300.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to rcl-dpv-rig-900.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to rcl-dpv-rig-300.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to rcl-dpv-rig-300.
       rcl-dpv-rig-400.
      *              *-------------------------------------------------*
      *              * Selezione su tipo riga                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se riga di commento : riciclo               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to rcl-dpv-rig-300.
      *                  *---------------------------------------------*
      *                  * Se riga di addebito : riciclo               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to rcl-dpv-rig-300.
      *                  *---------------------------------------------*
      *                  * Se prodotto similare : riciclo              *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to rcl-dpv-rig-300.
       rcl-dpv-rig-500.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del flag di testata      *
      *              *-------------------------------------------------*
           if        w-tes-fsp-doc (1)    =    04
                     go to rcl-dpv-rig-700.
       rcl-dpv-rig-600.
      *              *-------------------------------------------------*
      *              * Flag di significativita' provvigioni forzato a  *
      *              * 01, cioe' Si provvigioni                        *
      *              *-------------------------------------------------*
           move      01                   to   w-rig-fsp-rig (1)      .
      *              *-------------------------------------------------*
      *              * Richiamo routine di determinazione provvigioni  *
      *              *-------------------------------------------------*
           perform   det-ppv-rig-000      thru det-ppv-rig-999        .
           go to     rcl-dpv-rig-800.
       rcl-dpv-rig-700.
      *              *-------------------------------------------------*
      *              * Flag di significativita' provvigioni forzato a  *
      *              * 03, cioe' Speciali                              *
      *              *-------------------------------------------------*
           move      03                   to   w-rig-fsp-rig (1)      .
      *              *-------------------------------------------------*
      *              * % in riga uguale a % a forfait                  *
      *              *-------------------------------------------------*
           divide    100                  into w-tes-pvf-age (1)
                                        giving w-rig-ppv-rig (1, 1)   .
           move      zero                 to   w-rig-ppv-rig (1, 2)   .
           move      zero                 to   w-rig-ppv-rig (1, 3)   .
           move      zero                 to   w-rig-pvf-rig (1)      .
           go to     rcl-dpv-rig-800.
       rcl-dpv-rig-800.
      *              *-------------------------------------------------*
      *              * Aggiornamento catena movimenti                  *
      *              *-------------------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-cur        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura catena                       *
      *              *-------------------------------------------------*
           go to     rcl-dpv-rig-300.
       rcl-dpv-rig-900.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       rcl-dpv-rig-999.
           exit.

      *    *===========================================================*
      *    * Routine di ricalcolo dati legati al listino in riga       *
      *    *                                                           *
      *    * N.B. : attualmente non e' possibile il ricalcolo          *
      *    *-----------------------------------------------------------*
       rcl-lst-rig-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
       rcl-lst-rig-100.
      *              *-------------------------------------------------*
      *              * Box di avviso                                   *
      *              *-------------------------------------------------*
           move      "Il codice listino non e' piu' modificabile in quan
      -              "to sono gia'   "    to   w-err-box-err-msg      .
           move      "state impostate alcune righe documento !          
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       rcl-lst-rig-900.
      *              *-------------------------------------------------*
      *              * Box di avviso con conferma                      *
      *              *-------------------------------------------------*
           go to     rcl-lst-rig-999.
       rcl-lst-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Flag di significativita' da- *
      *    * ti provvigionali per il documento                         *
      *    *-----------------------------------------------------------*
       acc-fsp-doc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da trattare                   *
      *                  *---------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     move  02             to   w-tes-fsp-doc (1)
                     go to acc-fsp-doc-999.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-cod-age (1)    =    zero
                     go to acc-fsp-doc-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-fsp-doc (1)    to    w-sav-fsp-doc         .
      *                  *---------------------------------------------*
      *                  * Preparazione eventuale default              *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    not  = zero
                     go to acc-fsp-doc-050.
           move      01                   to   w-tes-fsp-doc (1)      .
           perform   vis-fsp-doc-000      thru vis-fsp-doc-999        .
       acc-fsp-doc-050.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-fsp-doc-400.
       acc-fsp-doc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-fsp-doc-lun    to   v-car                  .
           move      w-exp-fsp-doc-num    to   v-ldt                  .
           move      "SNIP#"              to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      14                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-fsp-doc-tbl    to   v-txt                  .
           move      w-tes-fsp-doc (1)    to   v-num                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-fsp-doc-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-fsp-doc-999.
       acc-fsp-doc-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-fsp-doc (1)      .
       acc-fsp-doc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    not  = zero
                     go to acc-fsp-doc-500.
           if        v-key                =    "UP  "
                     go to acc-fsp-doc-600
           else      go to acc-fsp-doc-100.
       acc-fsp-doc-500.
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    >    w-exp-fsp-doc-num
                     go to acc-fsp-doc-100.
       acc-fsp-doc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    =    w-sav-fsp-doc
                     go to acc-fsp-doc-800.
      *                  *---------------------------------------------*
      *                  * Trattamento tipo vendita per l'agente       *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    not  = 02
                     go to acc-fsp-doc-620.
           if        w-tes-tip-vpa (1)    =    zero
                     go to acc-fsp-doc-620.
           move      zero                 to   w-tes-tip-vpa (1)      .
           perform   vis-tip-vpa-000      thru vis-tip-vpa-999        .
       acc-fsp-doc-620.
      *                  *---------------------------------------------*
      *                  * Trattamento importo provvigioni a forfait   *
      *                  * per il documento                            *
      *                  *---------------------------------------------*
           if        w-tes-pvf-age (1)    =    zero
                     go to acc-fsp-doc-700.
           move      zero                 to   w-tes-pvf-age (1)      .
           perform   vis-pvf-age-000      thru vis-pvf-age-999        .
       acc-fsp-doc-700.
      *                  *---------------------------------------------*
      *                  * Trattamento dati provvigionali in riga      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del valore       *
      *                      *-----------------------------------------*
           if        w-tes-fsp-doc (1)    =    01
                     go to acc-fsp-doc-710
           else if   w-tes-fsp-doc (1)    =    02
                     go to acc-fsp-doc-720
           else if   w-tes-fsp-doc (1)    =    03
                     go to acc-fsp-doc-730
           else if   w-tes-fsp-doc (1)    =    04
                     go to acc-fsp-doc-740.
       acc-fsp-doc-710.
      *                      *-----------------------------------------*
      *                      * Se valore a 01, Si da righe documento   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Ricalcolo dati provvigionali in ri- *
      *                          * ga                                  *
      *                          *-------------------------------------*
           perform   rcl-dpv-rig-000      thru rcl-dpv-rig-999        .
           go to     acc-fsp-doc-800.
       acc-fsp-doc-720.
      *                      *-----------------------------------------*
      *                      * Se valore a 02, No provvigioni          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione dati provvigionali  *
      *                          * in righe corpo                      *
      *                          *-------------------------------------*
           perform   nor-dpv-rig-000      thru nor-dpv-rig-999        .
           go to     acc-fsp-doc-800.
       acc-fsp-doc-730.
      *                      *-----------------------------------------*
      *                      * Se valore a 03, A forfait               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione dati provvigionali  *
      *                          * in righe corpo                      *
      *                          *-------------------------------------*
           perform   nor-dpv-rig-000      thru nor-dpv-rig-999        .
           go to     acc-fsp-doc-800.
       acc-fsp-doc-740.
      *                      *-----------------------------------------*
      *                      * Se valore a 04, A forfait in %          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione dati provvigionali  *
      *                          * in righe corpo                      *
      *                          *-------------------------------------*
           perform   nor-dpv-rig-000      thru nor-dpv-rig-999        .
           go to     acc-fsp-doc-800.
       acc-fsp-doc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-fsp-doc-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-fsp-doc-100.
       acc-fsp-doc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Flag di significativita'  *
      *    * dati provvigionali per il documento                       *
      *    *-----------------------------------------------------------*
       vis-fsp-doc-000.
      *              *-------------------------------------------------*
      *              * Test se campo da trattare                       *
      *              *-------------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to vis-fsp-doc-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione campo                           *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-fsp-doc-lun    to   v-car                  .
           move      w-exp-fsp-doc-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      14                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-fsp-doc-tbl    to   v-txt                  .
           move      w-tes-fsp-doc (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-fsp-doc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Tipo vendita per l'agente    *
      *    *-----------------------------------------------------------*
       acc-tip-vpa-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da trattare                   *
      *                  *---------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-tip-vpa-999.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    =    02
                     go to acc-tip-vpa-999.
           if        w-tes-cod-age (1)    =    zero
                     go to acc-tip-vpa-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-tip-vpa (1)    to   w-sav-tip-vpa          .
      *                  *---------------------------------------------*
      *                  * Preparazione eventuale default              *
      *                  *---------------------------------------------*
           if        w-tes-tip-vpa (1)    not  = zero
                     go to acc-tip-vpa-050.
           move      01                   to   w-tes-tip-vpa (1)      .
           perform   vis-tip-vpa-000      thru vis-tip-vpa-999        .
       acc-tip-vpa-050.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-tip-vpa-400.
       acc-tip-vpa-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-vpa-lun    to   v-car                  .
           move      w-exp-tip-vpa-num    to   v-ldt                  .
           move      "DI#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      16                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-tip-vpa-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-tip-vpa (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-tip-vpa-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-tip-vpa-999.
       acc-tip-vpa-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-tip-vpa (1)      .
       acc-tip-vpa-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-tes-tip-vpa (1)    not  = zero
                     go to acc-tip-vpa-500.
           if        v-key                =    "UP  "
                     go to acc-tip-vpa-600
           else      go to acc-tip-vpa-100.
       acc-tip-vpa-500.
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
           if        w-tes-tip-vpa (1)    >    w-exp-tip-vpa-num
                     go to acc-tip-vpa-100.
       acc-tip-vpa-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-tip-vpa (1)    =    w-sav-tip-vpa
                     go to acc-tip-vpa-800.
      *                  *---------------------------------------------*
      *                  * Se valore attuale a zero : oltre            *
      *                  *---------------------------------------------*
           if        w-tes-tip-vpa (1)    =    zero
                     go to acc-tip-vpa-800.
      *                  *---------------------------------------------*
      *                  * Ricalcolo dati provvigionali in riga        *
      *                  *---------------------------------------------*
           perform   rcl-dpv-rig-000      thru rcl-dpv-rig-999        .
       acc-tip-vpa-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-tip-vpa-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-tip-vpa-100.
       acc-tip-vpa-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Tipo vendita per l'agente *
      *    *-----------------------------------------------------------*
       vis-tip-vpa-000.
      *              *-------------------------------------------------*
      *              * Test se campo da trattare                       *
      *              *-------------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to vis-tip-vpa-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione campo                           *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-vpa-lun    to   v-car                  .
           move      w-exp-tip-vpa-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      16                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-tip-vpa-tbl    to   v-txt                  .
           move      w-tes-tip-vpa (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tip-vpa-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Importo o % provvigioni a    *
      *    *                              forfait per l'agente         *
      *    *-----------------------------------------------------------*
       acc-pvf-age-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da trattare                   *
      *                  *---------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-pvf-age-999.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    not  = 03 and
                     w-tes-fsp-doc (1)    not  = 04
                     go to acc-pvf-age-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-pvf-age (1)    to   w-sav-pvf-age          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-pvf-age-400.
       acc-pvf-age-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
      *
           if        w-tes-fsp-doc (1)    =    03
                     move  11             to   v-car
                     move  c-dec          to   v-dec
           else      move  04             to   v-car
                     move  2              to   v-dec                  .
      *
           move      spaces               to   v-sgn                  .
           move      18                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<BG"                to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-pvf-age (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pvf-age-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pvf-age-999.
       acc-pvf-age-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-pvf-age (1)      .
       acc-pvf-age-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-tes-pvf-age (1)    not  = zero
                     go to acc-pvf-age-600.
           if        v-key                =    "UP  "
                     go to acc-pvf-age-600
           else      go to acc-pvf-age-100.
       acc-pvf-age-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-pvf-age (1)    =    w-sav-pvf-age
                     go to acc-pvf-age-800.
      *                  *---------------------------------------------*
      *                  * Ricalcolo dati provvigionali in riga se     *
      *                  * forfait in testata in %                     *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    not  = 04
                     go to acc-pvf-age-800.
           perform   rcl-dpv-rig-000      thru rcl-dpv-rig-999        .
       acc-pvf-age-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pvf-age-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pvf-age-100.
       acc-pvf-age-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Importo o % provvigioni a forfait *
      *    *                         per l'agente                      *
      *    *-----------------------------------------------------------*
       vis-pvf-age-000.
      *              *-------------------------------------------------*
      *              * Test se campo da trattare                       *
      *              *-------------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to vis-pvf-age-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione campo                           *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
      *
           if        w-tes-fsp-doc (1)    =    03
                     move  11             to   v-car
                     move  c-dec          to   v-dec
           else      move  04             to   v-car
                     move  2              to   v-dec                  .
      *
           move      spaces               to   v-sgn                  .
           move      18                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<BG"                to   v-edm                  .
           move      w-tes-pvf-age (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-pvf-age-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice pagamento             *
      *    *-----------------------------------------------------------*
       acc-cod-fop-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio percentuale di sconto pagamento *
      *                  * associata alla forma di pagamento           *
      *                  *---------------------------------------------*
           move      w-tes-scp-aap (1)    to   w-sav-scp-aap          .
      *                  *---------------------------------------------*
      *                  * Se Tab in corso : a controllo valore impo-  *
      *                  * stato                                       *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-fop-400.
       acc-cod-fop-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zfp-ope      .
           move      w-tes-cod-fop (1)    to   w-cod-mne-zfp-cod      .
           move      05                   to   w-cod-mne-zfp-lin      .
           move      30                   to   w-cod-mne-zfp-pos      .
           move      05                   to   w-cod-mne-zfp-dln      .
           move      41                   to   w-cod-mne-zfp-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-zfp-cll-000  thru cod-mne-zfp-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zfp-foi-000  thru cod-mne-zfp-foi-999    .
       acc-cod-fop-110.
           perform   cod-mne-zfp-cll-000  thru cod-mne-zfp-cll-999    .
           if        w-cod-mne-zfp-ope    =    "F+"
                     go to acc-cod-fop-115.
           if        w-cod-mne-zfp-ope    =    "AC"
                     go to acc-cod-fop-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-fop-115.
           perform   cod-mne-zfp-foi-000  thru cod-mne-zfp-foi-999    .
           go to     acc-cod-fop-110.
       acc-cod-fop-120.
           move      w-cod-mne-zfp-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-fop-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-fop-999.
       acc-cod-fop-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-fop (1)      .
       acc-cod-fop-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [zfp]                      *
      *                  *---------------------------------------------*
           move      w-tes-cod-fop (1)    to   w-let-arc-zfp-cod      .
           perform   let-arc-zfp-000      thru let-arc-zfp-999        .
           move      w-let-arc-zfp-des    to   w-tes-cod-fop-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-fop-000      thru vis-des-fop-999        .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-zfp-flg    not  = spaces
                     go to acc-cod-fop-100.
      *                  *---------------------------------------------*
      *                  * Determinazione valori testata indotti da    *
      *                  * record [zfp]                                *
      *                  *---------------------------------------------*
           perform   det-vlt-zfp-000      thru det-vlt-zfp-999        .
       acc-cod-fop-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione sconto pagamento            *
      *                  *---------------------------------------------*
           perform   vis-scp-aap-000      thru vis-scp-aap-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento % sconto pagamento per piede    *
      *                  *---------------------------------------------*
           if        w-sav-scp-aap        =    w-tes-scp-aap (1)
                     go to acc-cod-fop-610.
           move      w-tes-scp-aap (1)    to   w-pie-per-scp (1)      .
           move      zero                 to   w-pie-tot-scp (1)      .
       acc-cod-fop-610.
      *                  *---------------------------------------------*
      *                  * Trattamento codice nostra banca per bonifi- *
      *                  * co                                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se da trattare                          *
      *                      *-----------------------------------------*
           if        w-tes-snx-nsb (1)    not  = "S"
                     go to acc-cod-fop-615.
           if        w-tes-nos-ban (1)    not  = spaces
                     go to acc-cod-fop-620.
           move      w-tes-nsb-aac (1)    to   w-tes-nos-ban (1)      .
           perform   vis-nos-ban-000      thru vis-nos-ban-999        .
           move      02                   to   w-let-arc-cbp-tip      .
           move      w-tes-nos-ban (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
           move      w-let-arc-cbp-des    to   w-tes-nos-ban-des (1)  .
           perform   vis-nos-ban-des-000  thru vis-nos-ban-des-999    .
           go to     acc-cod-fop-620.
       acc-cod-fop-615.
      *                      *-----------------------------------------*
      *                      * Se non da trattare                      *
      *                      *-----------------------------------------*
           if        w-tes-nos-ban (1)    =    spaces
                     go to acc-cod-fop-620.
           move      spaces               to   w-tes-nos-ban (1)      .
           move      spaces               to   w-tes-nos-ban-des (1)  .
           perform   vis-nos-ban-000      thru vis-nos-ban-999        .
           perform   vis-nos-ban-des-000  thru vis-nos-ban-des-999    .
           go to     acc-cod-fop-620.
       acc-cod-fop-620.
      *                  *---------------------------------------------*
      *                  * Trattamento codice nostro c/c postale per   *
      *                  * pagamento                                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se da trattare                          *
      *                      *-----------------------------------------*
           if        w-tes-snx-ncp (1)    not  = "S"
                     go to acc-cod-fop-625.
           if        w-tes-nos-ccp (1)    not  = spaces
                     go to acc-cod-fop-630.
           move      w-tes-ncp-aac (1)    to   w-tes-nos-ccp (1)      .
           perform   vis-nos-ccp-000      thru vis-nos-ccp-999        .
           move      03                   to   w-let-arc-cbp-tip      .
           move      w-tes-nos-ccp (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
           move      w-let-arc-cbp-des    to   w-tes-nos-ccp-des (1)  .
           perform   vis-nos-ccp-des-000  thru vis-nos-ccp-des-999    .
           go to     acc-cod-fop-630.
       acc-cod-fop-625.
      *                      *-----------------------------------------*
      *                      * Se non da trattare                      *
      *                      *-----------------------------------------*
           if        w-tes-nos-ccp (1)    =    spaces
                     go to acc-cod-fop-630.
           move      spaces               to   w-tes-nos-ccp (1)      .
           move      spaces               to   w-tes-nos-ccp-des (1)  .
           perform   vis-nos-ccp-000      thru vis-nos-ccp-999        .
           perform   vis-nos-ccp-des-000  thru vis-nos-ccp-des-999    .
           go to     acc-cod-fop-630.
       acc-cod-fop-630.
      *                  *---------------------------------------------*
      *                  * Trattamento codici Abi e Cab                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se da trattare                          *
      *                      *-----------------------------------------*
           if        w-tes-snx-abi (1)    not  = "S"
                     go to acc-cod-fop-635.
           if        w-tes-cod-abi (1)    not  = zero
                     go to acc-cod-fop-640.
           perform   det-vlt-ipg-000      thru det-vlt-ipg-999        .
           move      w-tes-cod-abi (1)    to   w-let-arc-axi-cod      .
           perform   let-arc-axi-000      thru let-arc-axi-999        .
           move      w-let-arc-axi-den    to   w-tes-cod-abi-den (1)  .
           perform   vis-cod-abi-000      thru vis-cod-abi-999        .
           perform   vis-den-abi-000      thru vis-den-abi-999        .
           move      w-tes-cod-abi (1)    to   w-let-arc-axs-abi      .
           move      w-tes-cod-cab (1)    to   w-let-arc-axs-cab      .
           perform   let-arc-axs-000      thru let-arc-axs-999        .
           move      w-let-arc-axs-den    to   w-tes-cod-cab-den (1)  .
           perform   vis-cod-cab-000      thru vis-cod-cab-999        .
           perform   vis-den-cab-000      thru vis-den-cab-999        .
           go to     acc-cod-fop-640.
       acc-cod-fop-635.
      *                      *-----------------------------------------*
      *                      * Se non da trattare                      *
      *                      *-----------------------------------------*
           if        w-tes-cod-abi (1)    =    zero
                     go to acc-cod-fop-640.
           move      zero                 to   w-tes-cod-abi (1)      .
           move      spaces               to   w-tes-cod-abi-den (1)  .
           perform   vis-cod-abi-000      thru vis-cod-abi-999        .
           perform   vis-den-abi-000      thru vis-den-abi-999        .
           move      zero                 to   w-tes-cod-cab (1)      .
           move      spaces               to   w-tes-cod-cab-den (1)  .
           perform   vis-cod-cab-000      thru vis-cod-cab-999        .
           perform   vis-den-cab-000      thru vis-den-cab-999        .
           go to     acc-cod-fop-640.
       acc-cod-fop-640.
      *                  *---------------------------------------------*
      *                  * Trattamento c/c di appoggio cliente         *
      *                  *---------------------------------------------*
           if        w-tes-snx-rid (1)    =    spaces   and
                     w-tes-ccc-app (1)    not  = spaces
                     move  spaces         to   w-tes-ccc-app (1)
                     perform vis-ccc-app-000
                                          thru vis-ccc-app-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento data scadenza pagamento manuale *
      *                  *---------------------------------------------*
           if        w-tes-snx-spm (1)    =    spaces and
                     w-tes-pag-dsm (1)    not  = zero
                     move  zero           to   w-tes-pag-dsm (1)
                     perform vis-pag-dsm-000
                                          thru vis-pag-dsm-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento quota a forfait                 *
      *                  *---------------------------------------------*
           if        w-tes-snx-qaf (1)    =    spaces and
                     w-tes-pag-qaf (1)    not  = zero
                     move  zero           to   w-tes-pag-qaf (1)
                     perform vis-pag-qaf-000
                                          thru vis-pag-qaf-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento acconto                         *
      *                  *---------------------------------------------*
           if        w-tes-snx-act (1)    =    spaces and
                     w-tes-pag-act (1)    not  = zero
                     move  zero           to   w-tes-pag-act (1)
                     perform vis-pag-act-000
                                          thru vis-pag-act-999        .
       acc-cod-fop-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-fop-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-fop-100.
       acc-cod-fop-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice forma di pagamento *
      *    *-----------------------------------------------------------*
       vis-cod-fop-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-fop (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-fop-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione forma di paga-*
      *    * mento                                                     *
      *    *-----------------------------------------------------------*
       vis-des-fop-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-fop-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-fop-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : % sconto pagamento        *
      *    *-----------------------------------------------------------*
       vis-scp-aap-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      06                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<BD"                to   v-edm                  .
           move      w-tes-scp-aap (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-scp-aap-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice ABI banca d'appoggio  *
      *    *-----------------------------------------------------------*
       acc-cod-abi-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
            if       w-tes-snx-abi (1)    =    spaces
                     go to acc-cod-abi-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cod-abi (1)    to   w-sav-cod-abi          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-abi-400.
       acc-cod-abi-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-abi-ope      .
           move      w-tes-cod-abi (1)    to   w-cod-mne-abi-cod      .
           move      08                   to   w-cod-mne-abi-lin      .
           move      30                   to   w-cod-mne-abi-pos      .
           move      08                   to   w-cod-mne-abi-dln      .
           move      41                   to   w-cod-mne-abi-dps      .
           move      "9B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-abi-cll-000  thru cod-mne-abi-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-abi-foi-000  thru cod-mne-abi-foi-999    .
       acc-cod-abi-110.
           perform   cod-mne-abi-cll-000  thru cod-mne-abi-cll-999    .
           if        w-cod-mne-abi-ope    =    "F+"
                     go to acc-cod-abi-115.
           if        w-cod-mne-abi-ope    =    "AC"
                     go to acc-cod-abi-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-abi-115.
           perform   cod-mne-abi-foi-000  thru cod-mne-abi-foi-999    .
           go to     acc-cod-abi-110.
       acc-cod-abi-120.
           move      w-cod-mne-abi-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-abi-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-abi-999.
       acc-cod-abi-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-abi (1)      .
       acc-cod-abi-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura anagrafica istituti                 *
      *                  *---------------------------------------------*
           move      w-tes-cod-abi (1)    to   w-let-arc-axi-cod      .
           perform   let-arc-axi-000      thru let-arc-axi-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione denominazione                *
      *                  *---------------------------------------------*
           move      w-let-arc-axi-den    to   w-tes-cod-abi-den (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione denominazione               *
      *                  *---------------------------------------------*
           perform   vis-den-abi-000      thru vis-den-abi-999        .
      *                  *---------------------------------------------*
      *                  * Test su flag di uscita da lettura           *
      *                  *---------------------------------------------*
           if        w-let-arc-axi-flg    not  = spaces
                     go to acc-cod-abi-100.
       acc-cod-abi-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se variato codice ABI                       *
      *                  *---------------------------------------------*
           if        w-tes-cod-abi (1)    =    w-sav-cod-abi
                     go to acc-cod-abi-800.
           if        w-tes-cod-cab (1)    =    zero
                     go to acc-cod-abi-800.
      *                      *-----------------------------------------*
      *                      * Normalizzazione dati sportello CAB      *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-cod-cab (1)      .
           move      spaces               to   w-tes-cod-cab-den (1)  .
      *                      *-----------------------------------------*
      *                      * Visualizzazione dati sportello CAB      *
      *                      *-----------------------------------------*
           perform   vis-cod-cab-000      thru vis-cod-cab-999        .
           perform   vis-den-cab-000      thru vis-den-cab-999        .
       acc-cod-abi-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-abi-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-abi-100.
       acc-cod-abi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice ABI banca          *
      *    *-----------------------------------------------------------*
       vis-cod-abi-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9B"                 to   v-edm                  .
           move      08                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-abi (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-abi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Denominazione banca       *
      *    *-----------------------------------------------------------*
       vis-den-abi-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-abi-den (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-den-abi-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice CAB                   *
      *    *-----------------------------------------------------------*
       acc-cod-cab-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-cod-abi (1)    =    zero
                     go to acc-cod-cab-999.
            if       w-tes-snx-abi (1)    =    spaces
                     go to acc-cod-cab-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-cab-400.
       acc-cod-cab-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-cab-ope      .
           move      w-tes-cod-abi (1)    to   w-cod-mne-cab-abi      .
           move      w-tes-cod-cab (1)    to   w-cod-mne-cab-cab      .
           move      09                   to   w-cod-mne-cab-lin      .
           move      30                   to   w-cod-mne-cab-pos      .
           move      09                   to   w-cod-mne-cab-dln      .
           move      41                   to   w-cod-mne-cab-dps      .
           move      "9B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-cab-cll-000  thru cod-mne-cab-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-cab-foi-000  thru cod-mne-cab-foi-999    .
       acc-cod-cab-110.
           perform   cod-mne-cab-cll-000  thru cod-mne-cab-cll-999    .
           if        w-cod-mne-cab-ope    =    "F+"
                     go to acc-cod-cab-115.
           if        w-cod-mne-cab-ope    =    "AC"
                     go to acc-cod-cab-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-cab-115.
           perform   cod-mne-cab-foi-000  thru cod-mne-cab-foi-999    .
           go to     acc-cod-cab-110.
       acc-cod-cab-120.
           move      w-cod-mne-cab-cab    to   v-num                  .
       acc-cod-cab-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cab-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cab-999.
       acc-cod-cab-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-cab (1)      .
       acc-cod-cab-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      w-tes-cod-abi (1)    to   w-let-arc-axs-abi      .
           move      w-tes-cod-cab (1)    to   w-let-arc-axs-cab      .
           perform   let-arc-axs-000      thru let-arc-axs-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-axs-den    to   w-tes-cod-cab-den (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-den-cab-000      thru vis-den-cab-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-axs-flg    not  = spaces
                     go to acc-cod-cab-100.
       acc-cod-cab-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-cab-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-cab-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-cab-100.
       acc-cod-cab-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice CAB                *
      *    *-----------------------------------------------------------*
       vis-cod-cab-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9B"                 to   v-edm                  .
           move      09                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-cab (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-cab-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Denominazione sportello   *
      *    *-----------------------------------------------------------*
       vis-den-cab-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      30                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-cab-den (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-den-cab-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Conto corrente del cliente   *
      *    *-----------------------------------------------------------*
       acc-ccc-app-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-snx-rid (1)    =    spaces
                     go to acc-ccc-app-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-ccc-app-400.
       acc-ccc-app-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-ccc-app (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-ccc-app-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-ccc-app-999.
       acc-ccc-app-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-ccc-app (1)      .
       acc-ccc-app-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-ccc-app-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ccc-app-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-ccc-app-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-ccc-app-100.
       acc-ccc-app-999.
           exit.

