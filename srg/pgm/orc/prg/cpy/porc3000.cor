      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-flg-xb2-999.
      *              *-------------------------------------------------*
      *              * Se Pf4 : come Down                              *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "DOWN"         to   v-key                  .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-flg-nbx (1, 2)   .
       acc-flg-xb2-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-flg-xb2-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
