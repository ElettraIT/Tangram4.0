           if        w-prs-sna-flg-xbr (3)
                                          =    spaces
                     go to vis-flg-xb3-999.
       vis-flg-xb3-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      60                   to   v-pos                  .
           move      w-rig-flg-nbx (1, 3) to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-flg-xb3-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione Quantita' per confezione                  *
      *    *-----------------------------------------------------------*
       vis-qta-cfz-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
      *                   *--------------------------------------------*
      *                   * Normalizzazione preliminare                *
      *                   *--------------------------------------------*
           move      spaces               to   w-all-str-alf          .
      *                   *--------------------------------------------*
      *                   * Test su tipo riga                          *
      *                   *--------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to vis-qta-cfz-300.
           if        w-rig-tip-rig-tfu (1)
                                          not  = spaces
                     go to vis-qta-cfz-300.
      *                   *--------------------------------------------*
      *                   * Test su valori                             *
      *                   *--------------------------------------------*
           if        w-rig-tip-cfz (1)    =    zero or
                     w-rig-qta-cfz (1)    =    zero
                     move  spaces         to   w-all-str-alf
                     go to vis-qta-cfz-300.
       vis-qta-cfz-100.
      *              *-------------------------------------------------*
      *              * Editing                                         *
      *              *-------------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      03                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BGD"               to   v-edm                  .
           move      w-rig-qta-cfz (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Concatenamento con prompt                       *
      *              *-------------------------------------------------*
           move      02                   to   w-all-str-num          .
           move      18                   to   w-all-str-lun          .
           if        w-rig-qta-cfz (1)    =    zero
                     move  spaces         to   w-all-str-cat (1)
           else      move  "Confez.:"     to   w-all-str-cat (1)      .
           if        w-rig-qta-cfz (1)    =    zero
                     move  spaces         to   w-all-str-cat (2)
           else      move  v-edt          to   w-all-str-cat (2)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
       vis-qta-cfz-300.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      63                   to   v-pos                  .
           move      w-all-str-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       vis-qta-cfz-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Sigla valuta per il prez- *
      *    * zo di vendita                                             *
      *    *-----------------------------------------------------------*
       acc-sgl-vpp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione per gestione  *
      *                      * valuta per il prezzo                    *
      *                      *-----------------------------------------*
           if        w-prs-ges-vpp        =    zero
                     go to acc-sgl-vpp-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-sgl-vpp-999.
      *                      *-----------------------------------------*
      *                      * Salvataggio valore precedente           *
      *                      *-----------------------------------------*
           move      w-rig-sgl-vpp (1)    to   w-sav-sgl-vpp          .
       acc-sgl-vpp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-zvl-ope      .
           move      w-rig-sgl-vpp (1)    to   w-cod-cod-zvl-cod      .
           move      16                   to   w-cod-cod-zvl-lin      .
           move      15                   to   w-cod-cod-zvl-pos      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
       acc-sgl-vpp-110.
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           if        w-cod-cod-zvl-ope    =    "F+"
                     go to acc-sgl-vpp-115.
           if        w-cod-cod-zvl-ope    =    "AC"
                     go to acc-sgl-vpp-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-sgl-vpp-115.
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
           go to     acc-sgl-vpp-110.
       acc-sgl-vpp-120.
           move      w-cod-cod-zvl-cod    to   v-alf                  .
       acc-sgl-vpp-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-sgl-vpp-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-sgl-vpp-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "sgl-vpp"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-sgl-vpp (1)      .
       acc-sgl-vpp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura record [zvl]                        *
      *                  *---------------------------------------------*
           move      w-rig-sgl-vpp (1)    to   w-let-arc-zvl-cod      .
           perform   let-arc-zvl-000      thru let-arc-zvl-999        .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        w-let-arc-zvl-flg    not  = spaces
                     go to acc-sgl-vpp-100.
      *                  *---------------------------------------------*
      *                  * Valore a spaces non ammesso                 *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpp (1)    =    spaces
                     go to acc-sgl-vpp-100.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valori connessi             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda che la sigla valu- *
      *                      * ta per il prezzo sia uguale a quella di *
      *                      * fatturazione o no                       *
      *                      *-----------------------------------------*
           if        w-rig-sgl-vpp (1)    =    w-tes-sgl-vpf (1)
                     go to acc-sgl-vpp-420
           else      go to acc-sgl-vpp-440.
       acc-sgl-vpp-420.
      *                      *-----------------------------------------*
      *                      * Se sigla valuta per il prezzo uguale a  *
      *                      * quella di fatturazione                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Bufferizzazione numero decimali     *
      *                          *-------------------------------------*
           move      w-tes-dec-vpf (1)    to   w-rig-dec-vpp (1)      .
      *                          *-------------------------------------*
      *                          * Bufferizzazione tipo di cambio      *
      *                          *-------------------------------------*
           move      w-tes-tdc-vpf (1)    to   w-rig-tdc-vpp (1)      .
      *                          *-------------------------------------*
      *                          * Bufferizzazione coefficiente di     *
      *                          * cambio della valuta di fatturazione *
      *                          *-------------------------------------*
           move      w-tes-cdc-vpf (1)    to   w-rig-cdc-vpp (1)      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-sgl-vpp-600.
       acc-sgl-vpp-440.
      *                      *-----------------------------------------*
      *                      * Se sigla valuta per il prezzo diversa   *
      *                      * da quella di fatturazione               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Bufferizzazione numero decimali     *
      *                          *-------------------------------------*
           move      w-let-arc-zvl-dec    to   w-rig-dec-vpp (1)      .
      *                          *-------------------------------------*
      *                          * Bufferizzazione tipo di cambio      *
      *                          *-------------------------------------*
           move      w-let-arc-zvl-tdc    to   w-rig-tdc-vpp (1)      .
      *                          *-------------------------------------*
      *                          * Determinazione coefficiente di cam- *
      *                          * bio                                 *
      *                          *-------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      w-rig-sgl-vpp (1)    to   w-coe-cmb-vlt-sdv      .
           move      w-rig-tdc-vpp (1)    to   w-coe-cmb-vlt-tdc      .
           move      w-tes-dat-doc        to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                          *-------------------------------------*
      *                          * Test su esito determinazione        *
      *                          *-------------------------------------*
           if        w-coe-cmb-vlt-ope    =    "CC"
                     go to acc-sgl-vpp-442.
           move      "Coefficiente di cambio indeterminato !            
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-sgl-vpp-100.
       acc-sgl-vpp-442.
      *                          *-------------------------------------*
      *                          * Bufferizzazione coefficiente di     *
      *                          * cambio                              *
      *                          *-------------------------------------*
           move      w-coe-cmb-vlt-cdc    to   w-rig-cdc-vpp (1)      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-sgl-vpp-600.
       acc-sgl-vpp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpp (1)    =    w-sav-sgl-vpp
                     go to acc-sgl-vpp-800.
      *                  *---------------------------------------------*
      *                  * Prezzo di vendita                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-sgl-vpp-620.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-prz-ven-000      thru det-prz-ven-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-prz-ven-000      thru vis-prz-ven-999        .
       acc-sgl-vpp-620.
      *                  *---------------------------------------------*
      *                  * Sconti in riga                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-sgl-vpp-640.
      *                      *-----------------------------------------*
      *                      * Determinazione percentuali di sconto in *
      *                      * riga                                    *
      *                      *-----------------------------------------*
           perform   det-psr-rig-000      thru det-psr-rig-999        .
      *                      *-----------------------------------------*
      *                      * Memorizzazione valori determinati       *
      *                      *-----------------------------------------*
           move      d-per-scr-per-scr (1)
                                          to   w-rig-per-scr (1, 1)   .
           move      d-per-scr-per-scr (2)
                                          to   w-rig-per-scr (1, 2)   .
           move      d-per-scr-per-scr (3)
                                          to   w-rig-per-scr (1, 3)   .
           move      d-per-scr-per-scr (4)
                                          to   w-rig-per-scr (1, 4)   .
           move      d-per-scr-per-scr (5)
                                          to   w-rig-per-scr (1, 5)   .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
       acc-sgl-vpp-640.
      *                  *---------------------------------------------*
      *                  * Prezzo netto                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      w-rig-prz-ven (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       acc-sgl-vpp-660.
      *                  *---------------------------------------------*
      *                  * Provvigioni in riga                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-sgl-vpp-680.
      *                      *-----------------------------------------*
      *                      * Test se da trattare                     *
      *                      *-----------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-sgl-vpp-680.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-ppv-rig-000      thru det-ppv-rig-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-fsp-rig-000      thru vis-fsp-rig-999        .
           perform   vis-ppv-rig-000      thru vis-ppv-rig-999        .
       acc-sgl-vpp-680.
      *                  *---------------------------------------------*
      *                  * Importo in riga                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-sgl-vpp-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-sgl-vpp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-sgl-vpp-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-sgl-vpp-100.
       acc-sgl-vpp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Sigla valuta per il prezzo di     *
      *    * vendita                                                   *
      *    *-----------------------------------------------------------*
       vis-sgl-vpp-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      15                   to   v-pos                  .
           move      w-rig-sgl-vpp (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sgl-vpp-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Prezzo di vendita         *
      *    *-----------------------------------------------------------*
       acc-prz-ven-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo archivio                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    =    "D"
                     go to acc-prz-ven-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-prz-ven-999.
      *                  *---------------------------------------------*
      *                  * Eventuale forzatura del tasto Pf3 per fare  *
      *                  * in modo di accettare il prezzo lordo stan-  *
      *                  * dard                                        *
      *                  *---------------------------------------------*
           if       (w-prs-cnt-prz-lrs    =    "I" or
                     w-prs-cnt-prz-lrs    =    "J"  ) and
                     w-rig-prz-lrs (1)    =    zero
                     move  spaces         to   v-mod
                     move  "[3] "         to   v-key
                     go to acc-prz-ven-220.
       acc-prz-ven-050.
      *                  *---------------------------------------------*
      *                  * Salvataggio valori precedenti               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Prezzo di vendita                       *
      *                      *-----------------------------------------*
           move      w-rig-prz-ven (1)    to   w-sav-prz-ven          .
      *                      *-----------------------------------------*
      *                      * Percentuali di sconto in riga           *
      *                      *-----------------------------------------*
           move      w-rig-per-scr (1, 1) to   w-sav-per-scr (1)      .
           move      w-rig-per-scr (1, 2) to   w-sav-per-scr (2)      .
           move      w-rig-per-scr (1, 3) to   w-sav-per-scr (3)      .
           move      w-rig-per-scr (1, 4) to   w-sav-per-scr (4)      .
           move      w-rig-per-scr (1, 5) to   w-sav-per-scr (5)      .
       acc-prz-ven-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-rig-dec-vpp (1)    to   v-dec                  .
           add       w-rig-dec-prz (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      16                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[1] "               to   v-pfk (14)             .
           if        w-prs-cnt-prz-lrs    =    "I" or
                     w-prs-cnt-prz-lrs    =    "J"
                     move  "[3] "         to   v-pfk (16)             .
           move      w-rig-prz-ven (1)    to   v-num                  .
           move      "[4] "               to   v-pfk (17)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-prz-ven-200.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-prz-ven-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-prz-ven-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "prz-ven"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
       acc-prz-ven-220.
      *              *-------------------------------------------------*
      *              * Se Pf3                                          *
      *              *-------------------------------------------------*
           if        v-key                not  = "[3] "
                     go to acc-prz-ven-300.
      *                  *---------------------------------------------*
      *                  * Se campo d'impostazione variato : reimpo-   *
      *                  * stazione                                    *
      *                  *---------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-prz-ven-100.
      *                  *---------------------------------------------*
      *                  * Accettazione prezzo lordo standard          *
      *                  *---------------------------------------------*
           perform   acc-prz-lrs-000      thru acc-prz-lrs-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-prz-ven-999.
      *                  *---------------------------------------------*
      *                  * A pre-accettazione e reimpostazione         *
      *                  *---------------------------------------------*
           go to     acc-prz-ven-050.
       acc-prz-ven-300.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-prz-ven (1)      .
       acc-prz-ven-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Up e valore a zero : controllo superato  *
      *                  *---------------------------------------------*
           if        w-rig-prz-ven (1)    =    zero   and
                     v-key                =    "UP  "
                     go to acc-prz-ven-500.
      *                  *---------------------------------------------*
      *                  * Eventuale controllo di esistenza            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-prz-ven-500.
      *                      *-----------------------------------------*
      *                      * Test se da eseguire                     *
      *                      *-----------------------------------------*
           if        w-prs-cnt-prz-ven    =    "N"
                     go to acc-prz-ven-500.
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-rig-prz-ven (1)    not  = zero
                     go to acc-prz-ven-500.
      *                      *-----------------------------------------*
      *                      * A reimpostazione o continuazione a se-  *
      *                      * conda della personalizzazione           *
      *                      *-----------------------------------------*
           if        w-prs-cnt-prz-ven    =    "S"
                     go to acc-prz-ven-100
           else if   w-prs-cnt-prz-ven    =    "M"
                     go to acc-prz-ven-500.
       acc-prz-ven-500.
      *                  *---------------------------------------------*
      *                  * Altri controlli eventuali                   *
      *                  *---------------------------------------------*
       acc-prz-ven-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Pf1                                      *
      *                  *---------------------------------------------*
           if        v-key                not  = "[1] "
                     go to acc-prz-ven-610.
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda della personaliz-  *
      *                      * zazione sulle modalita' di accettazione *
      *                      * prezzo                                  *
      *                      *-----------------------------------------*
           if        w-prs-mac-prz        =    zero
                     go to acc-prz-ven-602
           else if   w-prs-mac-prz        =    01
                     go to acc-prz-ven-604.
       acc-prz-ven-602.
      *                      *-----------------------------------------*
      *                      * Se modalita' di accettazione prezzo :   *
      *                      * Normale, azzeramento delle percentuali  *
      *                      * di sconto                               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se percentuali di sconto gia' tutte *
      *                          * a zero : nessuna azione             *
      *                          *-------------------------------------*
           if        w-rig-per-scr (1, 1) =    zero and
                     w-rig-per-scr (1, 2) =    zero and
                     w-rig-per-scr (1, 3) =    zero and
                     w-rig-per-scr (1, 4) =    zero and
                     w-rig-per-scr (1, 5) =    zero
                     go to acc-prz-ven-610.
      *                          *-------------------------------------*
      *                          * Normalizzazione                     *
      *                          *-------------------------------------*
           move      zero                 to   w-rig-per-scr (1, 1)   .
           move      zero                 to   w-rig-per-scr (1, 2)   .
           move      zero                 to   w-rig-per-scr (1, 3)   .
           move      zero                 to   w-rig-per-scr (1, 4)   .
           move      zero                 to   w-rig-per-scr (1, 5)   .
      *                          *-------------------------------------*
      *                          * Visualizzazione                     *
      *                          *-------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-prz-ven-610.
       acc-prz-ven-604.
      *                      *-----------------------------------------*
      *                      * Se modalita' di accettazione prezzo :   *
      *                      * 01, nessuna azione                      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-prz-ven-610.
       acc-prz-ven-610.
      *                  *---------------------------------------------*
      *                  * Trattamento percentuali di sconto in fun-   *
      *                  * zione della eventuale personalizzazione     *
      *                  * sulla modalita' di accettazione prezzo      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prezzo invariato : nessun trattamen- *
      *                      * to                                      *
      *                      *-----------------------------------------*
           if        w-rig-prz-ven (1)    =    w-sav-prz-ven
                     go to acc-prz-ven-615.
      *                      *-----------------------------------------*
      *                      * Se personalizzazione sulla modalita' di *
      *                      * accettazione prezzo non e' a valore 01, *
      *                      * nessun trattamento                      *
      *                      *-----------------------------------------*
           if        w-prs-mac-prz        not  = 01
                     go to acc-prz-ven-615.
      *                      *-----------------------------------------*
      *                      * Se Pf1 : nessun trattamento             *
      *                      *-----------------------------------------*
           if        v-key                =    "[1] "
                     go to acc-prz-ven-615.
      *                      *-----------------------------------------*
      *                      * Se percentuali di sconto gia' tutte a   *
      *                      * zero : nessuna azione                   *
      *                      *-----------------------------------------*
           if        w-rig-per-scr (1, 1) =    zero and
                     w-rig-per-scr (1, 2) =    zero and
                     w-rig-per-scr (1, 3) =    zero and
                     w-rig-per-scr (1, 4) =    zero and
                     w-rig-per-scr (1, 5) =    zero
                     go to acc-prz-ven-615.
      *                      *-----------------------------------------*
      *                      * Normalizzazione                         *
      *                      *-----------------------------------------*
           move      zero                 to   w-rig-per-scr (1, 1)   .
           move      zero                 to   w-rig-per-scr (1, 2)   .
           move      zero                 to   w-rig-per-scr (1, 3)   .
           move      zero                 to   w-rig-per-scr (1, 4)   .
           move      zero                 to   w-rig-per-scr (1, 5)   .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
       acc-prz-ven-615.
      *                  *---------------------------------------------*
      *                  * Se valori attuali come precedenti : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-prz-ven (1)    =    w-sav-prz-ven     and
                     w-rig-per-scr (1, 1) =    w-sav-per-scr (1) and
                     w-rig-per-scr (1, 2) =    w-sav-per-scr (2) and
                     w-rig-per-scr (1, 3) =    w-sav-per-scr (3) and
                     w-rig-per-scr (1, 4) =    w-sav-per-scr (4) and
                     w-rig-per-scr (1, 5) =    w-sav-per-scr (5)
                     go to acc-prz-ven-800.
       acc-prz-ven-620.
      *                  *---------------------------------------------*
      *                  * Determinazione prezzo netto                 *
      *                  *---------------------------------------------*
           move      w-rig-prz-ven (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       acc-prz-ven-640.
      *                  *---------------------------------------------*
      *                  * Provvigioni in riga                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-prz-ven-680.
      *                      *-----------------------------------------*
      *                      * Test se da trattare                     *
      *                      *-----------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-prz-ven-680.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-ppv-rig-000      thru det-ppv-rig-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-fsp-rig-000      thru vis-fsp-rig-999        .
           perform   vis-ppv-rig-000      thru vis-ppv-rig-999        .
       acc-prz-ven-680.
      *                  *---------------------------------------------*
      *                  * Importo in riga                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-prz-ven-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-prz-ven-750.
      *              *-------------------------------------------------*
      *              * Eventuale box per variazione prezzo             *
      *              * ___ DA IMPLEMENTARE ___                         *
      *              *-------------------------------------------------*
       acc-prz-ven-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-prz-ven-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-prz-ven-100.
       acc-prz-ven-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Prezzo di vendita                 *
      *    *-----------------------------------------------------------*
       vis-prz-ven-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-rig-dec-vpp (1)    to   v-dec                  .
           add       w-rig-dec-prz (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      16                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-prz-ven (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-prz-ven-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Prezzo lordo standard     *
      *    *-----------------------------------------------------------*
       acc-prz-lrs-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo archivio                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    =    "D"
                     go to acc-prz-lrs-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-prz-lrs-999.
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-prz-lrs-999.
      *                      *-----------------------------------------*
      *                      * Test se consentito dalla personalizza-  *
      *                      * zione                                   *
      *                      *-----------------------------------------*
           if       (w-prs-cnt-prz-lrs    =    "I"   ) or
                    (w-prs-cnt-prz-lrs    =    "J" and
                     w-rig-prz-lrs (1)    =    zero  )
                     go to acc-prz-lrs-050
           else      go to acc-prz-lrs-999.
       acc-prz-lrs-050.
      *                  *---------------------------------------------*
      *                  * Salvataggio valori precedenti               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Prezzo lordo standard                   *
      *                      *-----------------------------------------*
           move      w-rig-prz-lrs (1)    to   w-sav-prz-lrs          .
      *                      *-----------------------------------------*
      *                      * Prezzo netto standard                   *
      *                      *-----------------------------------------*
           move      w-rig-prz-nts (1)    to   w-sav-prz-nts          .
      *                  *---------------------------------------------*
      *                  * Preparazione box per accettazione           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Salvataggio immagine video              *
      *                      *-----------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Video in Off                            *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Box                                     *
      *                      *-----------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      15                   to   v-lin                  .
           move      35                   to   v-pos                  .
           move      17                   to   v-lto                  .
           move      68                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Prompt per prezzo di listino            *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      36                   to   v-pos                  .
           move      "Prezzo di listino :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Video in On                             *
      *                      *-----------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-prz-lrs-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-rig-dec-vps (1)    to   v-dec                  .
           add       w-rig-dec-prz (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      16                   to   v-lin                  .
           move      56                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      w-rig-prz-lrs (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     perform acc-prz-lrs-900
                                          thru acc-prz-lrs-909
                     go to acc-prz-lrs-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     perform acc-prz-lrs-900
                                          thru acc-prz-lrs-909
                     go to acc-prz-lrs-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-prz-lrs (1)      .
       acc-prz-lrs-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-rig-prz-lrs (1)    not  = zero
                     go to acc-prz-lrs-600.
           if        v-key                =    "UP  "
                     go to acc-prz-lrs-600
           else      go to acc-prz-lrs-100.
       acc-prz-lrs-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Esecuzione subroutine per ripristino imma-  *
      *                  * gine video                                  *
      *                  *---------------------------------------------*
           perform   acc-prz-lrs-900      thru acc-prz-lrs-909        .
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-prz-lrs (1)    =    w-sav-prz-lrs
                     go to acc-prz-lrs-800.
       acc-prz-lrs-620.
      *                  *---------------------------------------------*
      *                  * Trattamento prezzo netto standard           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda che il lordo stan- *
      *                      * dard precedente sia a zero o no         *
      *                      *-----------------------------------------*
           if        w-sav-prz-lrs        =    zero
                     go to acc-prz-lrs-622
           else      go to acc-prz-lrs-624.
       acc-prz-lrs-622.
      *                      *-----------------------------------------*
      *                      * Se prezzo lordo standard precedente a   *
      *                      * zero                                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione sconti in riga       *
      *                          *-------------------------------------*
           perform   det-psr-rig-000      thru det-psr-rig-999        .
      *                          *-------------------------------------*
      *                          * Determinazione prezzo netto stan-   *
      *                          * dard                                *
      *                          *-------------------------------------*
           move      w-rig-prz-lrs (1)    to   w-cal-prz-net-prz      .
           move      d-per-scr-per-scr (1)
                                          to   w-cal-prz-net-psc (1)  .
           move      d-per-scr-per-scr (2)
                                          to   w-cal-prz-net-psc (2)  .
           move      d-per-scr-per-scr (3)
                                          to   w-cal-prz-net-psc (3)  .
           move      d-per-scr-per-scr (4)
                                          to   w-cal-prz-net-psc (4)  .
           move      d-per-scr-per-scr (5)
                                          to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-nts (1)      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-prz-lrs-630.
       acc-prz-lrs-624.
      *                      *-----------------------------------------*
      *                      * Se prezzo lordo standard precedente di- *
      *                      * verso da zero                           *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione prezzo netto in base *
      *                          * al lordo e netto standard preceden- *
      *                          * ti                                  *
      *                          *-------------------------------------*
           multiply  w-sav-prz-nts        by   w-rig-prz-lrs (1)
                                        giving w-acc-prz-lrs-n17      .
           divide    w-sav-prz-lrs        into w-acc-prz-lrs-n17
                                        giving w-rig-prz-nts (1)
                                               rounded                .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-prz-lrs-630.
       acc-prz-lrs-630.
      *                  *---------------------------------------------*
      *                  * Prezzo di vendita, prezzo netto e importo   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prezzo di vendita diverso dal prezzo *
      *                      * lordo standard precedente : oltre       *
      *                      *-----------------------------------------*
           if        w-rig-prz-ven (1)    not  = w-sav-prz-lrs
                     go to acc-prz-lrs-680.
      *                      *-----------------------------------------*
      *                      * Prezzo di vendita                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Forzatura al prezzo lordo standard  *
      *                          * attuale                             *
      *                          *-------------------------------------*
           move      w-rig-prz-lrs (1)    to   w-rig-prz-ven (1)      .
      *                          *-------------------------------------*
      *                          * Visualizzazione                     *
      *                          *-------------------------------------*
           perform   vis-prz-ven-000      thru vis-prz-ven-999        .
       acc-prz-lrs-632.
      *                      *-----------------------------------------*
      *                      * Prezzo netto                            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione                      *
      *                          *-------------------------------------*
           move      w-rig-prz-ven (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       acc-prz-lrs-634.
      *                      *-----------------------------------------*
      *                      * Importo in riga                         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione                      *
      *                          *-------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                          *-------------------------------------*
      *                          * Visualizzazione                     *
      *                          *-------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-prz-lrs-680.
      *                  *---------------------------------------------*
      *                  * Provvigioni in riga                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da trattare                     *
      *                      *-----------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-prz-lrs-700.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-ppv-rig-000      thru det-ppv-rig-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-fsp-rig-000      thru vis-fsp-rig-999        .
           perform   vis-ppv-rig-000      thru vis-ppv-rig-999        .
       acc-prz-lrs-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-prz-lrs-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-prz-lrs-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-prz-lrs-100.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-prz-lrs-999.
       acc-prz-lrs-900.
      *              *=================================================*
      *              * Subroutine interna per ripristino immagine vi-  *
      *              * deo                                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino immagine video                   *
      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-prz-lrs-909.
           exit.
       acc-prz-lrs-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione Lotto di vendita                          *
      *    *-----------------------------------------------------------*
       vis-lot-ven-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
      *                   *--------------------------------------------*
      *                   * Test se attivo legame valutario            *
      *                   *--------------------------------------------*
           if        w-tes-mac-lvl (1)    not  = zero
                     go to vis-lot-ven-999.
      *                   *--------------------------------------------*
      *                   * Test su tipo riga                          *
      *                   *--------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to vis-lot-ven-300.
      *                   *--------------------------------------------*
      *                   * Test su valori                             *
      *                   *--------------------------------------------*
           if        w-rig-lot-ven (1)    =    zero
                     move  spaces         to   w-all-str-alf
                     go to vis-lot-ven-300.
       vis-lot-ven-100.
      *              *-------------------------------------------------*
      *              * Editing                                         *
      *              *-------------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      03                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BGD"               to   v-edm                  .
           move      w-rig-lot-ven (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Concatenamento con prompt                       *
      *              *-------------------------------------------------*
           move      02                   to   w-all-str-num          .
           move      18                   to   w-all-str-lun          .
           if        w-rig-lot-ven (1)    =    zero
                     move  spaces         to   w-all-str-cat (1)
           else      move  "Lotto  :"     to   w-all-str-cat (1)      .
           if        w-rig-lot-ven (1)    =    zero
                     move  spaces         to   w-all-str-cat (2)
           else      move  v-edt          to   w-all-str-cat (2)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
       vis-lot-ven-300.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      63                   to   v-pos                  .
           move      w-all-str-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       vis-lot-ven-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Sigla valuta per legame   *
      *    * valutario                                                 *
      *    *-----------------------------------------------------------*
       acc-sgl-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo archivio                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    =    "D"
                     go to acc-sgl-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su momento di applicazione cambio  *
      *                      * per legame valutario                    *
      *                      *-----------------------------------------*
           if        w-tes-mac-lvl (1)    =    zero
                     go to acc-sgl-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-sgl-vpl-999.
      *                      *-----------------------------------------*
      *                      * Salvataggio valore precedente           *
      *                      *-----------------------------------------*
           move      w-rig-sgl-vpl (1)    to   w-sav-sgl-vpl          .
       acc-sgl-vpl-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-zvl-ope      .
           move      w-rig-sgl-vpl (1)    to   w-cod-cod-zvl-cod      .
           move      16                   to   w-cod-cod-zvl-lin      .
           move      54                   to   w-cod-cod-zvl-pos      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
       acc-sgl-vpl-110.
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           if        w-cod-cod-zvl-ope    =    "F+"
                     go to acc-sgl-vpl-115.
           if        w-cod-cod-zvl-ope    =    "AC"
                     go to acc-sgl-vpl-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-sgl-vpl-115.
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
           go to     acc-sgl-vpl-110.
       acc-sgl-vpl-120.
           move      w-cod-cod-zvl-cod    to   v-alf                  .
       acc-sgl-vpl-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-sgl-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-sgl-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "sgl-vpl"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-sgl-vpl (1)      .
       acc-sgl-vpl-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura record [zvl]                        *
      *                  *---------------------------------------------*
           move      w-rig-sgl-vpl (1)    to   w-let-arc-zvl-cod      .
           perform   let-arc-zvl-000      thru let-arc-zvl-999        .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        w-let-arc-zvl-flg    not  = spaces
                     go to acc-sgl-vpl-100.
      *                  *---------------------------------------------*
      *                  * Controllo che non sia uguale alla valuta    *
      *                  * per fatturazione                            *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpl (1)    not  = w-tes-sgl-vpf (1)
                     go to acc-sgl-vpl-500.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "La valuta di riferimento per legame valutario non 
      -              "puo' essere    "    to   w-err-box-err-msg      .
           move      "uguale alla valuta per fatturazione del documento 
      -              "!              "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-sgl-vpl-100.
       acc-sgl-vpl-500.
      *                  *---------------------------------------------*
      *                  * Controllo che non sia uguale alla valuta    *
      *                  * per il prezzo                               *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpl (1)    not  = w-rig-sgl-vpp (1)
                     go to acc-sgl-vpl-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "La valuta di riferimento per legame valutario non 
      -              "puo' essere    "    to   w-err-box-err-msg      .
           move      "uguale alla valuta per l'espressione del prezzo ! 
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-sgl-vpl-100.
       acc-sgl-vpl-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpl (1)    =    w-sav-sgl-vpl
                     go to acc-sgl-vpl-800.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda che il valore sia esi- *
      *                  * stente o no                                 *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to acc-sgl-vpl-620
           else      go to acc-sgl-vpl-640.
       acc-sgl-vpl-620.
      *                  *---------------------------------------------*
      *                  * Se valore non esistente                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione valori connessi         *
      *                      *-----------------------------------------*
           move      zero                 to   w-rig-dec-vpl (1)      .
           move      spaces               to   w-rig-tdc-vpl (1)      .
           move      zero                 to   w-rig-prz-vpl (1)      .
           move      zero                 to   w-rig-cdc-vpl (1)      .
           move      zero                 to   w-rig-ccr-vpl (1)      .
           move      zero                 to   w-rig-plm-vpl (1)      .
           move      spaces               to   w-rig-tlm-vpl (1)      .
           move      spaces               to   w-rig-map-vpl (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione valori connessi         *
      *                      *-----------------------------------------*
           perform   vis-ccr-vpl-000      thru vis-ccr-vpl-999        .
           perform   vis-plm-vpl-000      thru vis-plm-vpl-999        .
           perform   vis-tlm-vpl-000      thru vis-tlm-vpl-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-sgl-vpl-700.
       acc-sgl-vpl-640.
      *                  *---------------------------------------------*
      *                  * Se valore esistente                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione valori connessi         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Bufferizzazione numero decimali     *
      *                          *-------------------------------------*
           move      w-let-arc-zvl-dec    to   w-rig-dec-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Bufferizzazione tipo di cambio      *
      *                          *-------------------------------------*
           move      w-let-arc-zvl-tdc    to   w-rig-tdc-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Prezzo di riferimento               *
      *                          *-------------------------------------*
           move      w-rig-prz-ven (1)    to   w-rig-prz-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Determinazione coefficiente di cam- *
      *                          * bio                                 *
      *                          *-------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      w-rig-sgl-vpl (1)    to   w-coe-cmb-vlt-sdv      .
           move      w-rig-tdc-vpl (1)    to   w-coe-cmb-vlt-tdc      .
           move      w-tes-dat-doc        to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                          *-------------------------------------*
      *                          * Test su esito determinazione        *
      *                          *-------------------------------------*
           if        w-coe-cmb-vlt-ope    =    "CC"
                     go to acc-sgl-vpl-642.
           move      "Coefficiente di cambio indeterminato !            
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-sgl-vpl-100.
       acc-sgl-vpl-642.
      *                          *-------------------------------------*
      *                          * Bufferizzazione coefficiente di     *
      *                          * cambio                              *
      *                          *-------------------------------------*
           move      w-coe-cmb-vlt-cdc    to   w-rig-cdc-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Coefficiente di cambio di riferi-   *
      *                          * mento                               *
      *                          *-------------------------------------*
           move      zero                 to   w-rig-ccr-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Percentuale di limitazione          *
      *                          *-------------------------------------*
           move      zero                 to   w-rig-plm-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Tipo di limitazione                 *
      *                          *-------------------------------------*
           move      spaces               to   w-rig-tlm-vpl (1)      .
      *                          *-------------------------------------*
      *                          * Momento di applicazione cambio      *
      *                          *-------------------------------------*
           if        w-tes-mac-lvl (1)    =    11
                     move  "B"            to   w-rig-map-vpl (1)
           else if   w-tes-mac-lvl (1)    =    21
                     move  "F"            to   w-rig-map-vpl (1)      .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-sgl-vpl-700.
       acc-sgl-vpl-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-sgl-vpl-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-sgl-vpl-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-sgl-vpl-100.
       acc-sgl-vpl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Sigla valuta per legame valutario *
      *    *-----------------------------------------------------------*
       vis-sgl-vpl-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      54                   to   v-pos                  .
           move      w-rig-sgl-vpl (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sgl-vpl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Coefficiente di cambio di *
      *    * riferimento per legame valutario                          *
      *    *-----------------------------------------------------------*
       acc-ccr-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo archivio                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    =    "D"
                     go to acc-ccr-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su momento di applicazione cambio  *
      *                      * per legame valutario                    *
      *                      *-----------------------------------------*
           if        w-tes-mac-lvl (1)    =    zero
                     go to acc-ccr-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-ccr-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su sigla valuta per legame valuta- *
      *                      * rio                                     *
      *                      *-----------------------------------------*
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to acc-ccr-vpl-999.
       acc-ccr-vpl-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-coe-cmb-vlt-ope      .
           move      w-rig-sgl-vpl (1)    to   w-coe-cmb-vlt-sdv      .
           move      w-rig-tdc-vpl (1)    to   w-coe-cmb-vlt-tdc      .
           move      zero                 to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           move      "N"                  to   w-coe-cmb-vlt-snd      .
           move      w-rig-ccr-vpl (1)    to   w-coe-cmb-vlt-cdc      .
           move      16                   to   w-coe-cmb-vlt-lin      .
           move      58                   to   w-coe-cmb-vlt-pos      .
           move      zero                 to   w-coe-cmb-vlt-dln      .
           move      zero                 to   w-coe-cmb-vlt-dps      .
           move      "BD"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   coe-cmb-vlt-foi-000  thru coe-cmb-vlt-foi-999    .
       acc-ccr-vpl-110.
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
           if        w-coe-cmb-vlt-ope    =    "F+"
                     go to acc-ccr-vpl-115.
           if        w-coe-cmb-vlt-ope    =    "AC"
                     go to acc-ccr-vpl-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-ccr-vpl-115.
           perform   coe-cmb-vlt-foi-000  thru coe-cmb-vlt-foi-999    .
           go to     acc-ccr-vpl-110.
       acc-ccr-vpl-120.
           move      w-coe-cmb-vlt-cdc    to   v-num                  .
       acc-ccr-vpl-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-ccr-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-ccr-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "ccr-vpl"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-ccr-vpl (1)      .
       acc-ccr-vpl-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-rig-ccr-vpl (1)    not  = zero
                     go to acc-ccr-vpl-600.
           if        v-key                =    "UP  "
                     go to acc-ccr-vpl-600
           else      go to acc-ccr-vpl-100.
       acc-ccr-vpl-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ccr-vpl-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-ccr-vpl-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-ccr-vpl-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-ccr-vpl-100.
       acc-ccr-vpl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Coefficiente di cambio di riferi- *
      *    * mento per legame valutario                                *
      *    *-----------------------------------------------------------*
       vis-ccr-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da visualizzare               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo archivio                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    =    "D"
                     go to vis-ccr-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su momento di applicazione cambio  *
      *                      * per legame valutario                    *
      *                      *-----------------------------------------*
           if        w-tes-mac-lvl (1)    =    zero
                     go to vis-ccr-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to vis-ccr-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su sigla valuta per legame valuta- *
      *                      * rio                                     *
      *                      *-----------------------------------------*
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to vis-ccr-vpl-999.
       vis-ccr-vpl-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      05                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      16                   to   v-lin                  .
           move      58                   to   v-pos                  .
           move      w-rig-ccr-vpl (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ccr-vpl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Percentuale di limitazio- *
      *    * ne per legame valutario                                   *
      *    *-----------------------------------------------------------*
       acc-plm-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo archivio                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    =    "D"
                     go to acc-plm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su momento di applicazione cambio  *
      *                      * per legame valutario                    *
      *                      *-----------------------------------------*
           if        w-tes-mac-lvl (1)    =    zero
                     go to acc-plm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-plm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su sigla valuta per legame valuta- *
      *                      * rio                                     *
      *                      *-----------------------------------------*
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to acc-plm-vpl-999.
       acc-plm-vpl-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      16                   to   v-lin                  .
           move      75                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-plm-vpl (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-plm-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-plm-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "plm-vpl"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
       acc-plm-vpl-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-plm-vpl (1)      .
       acc-plm-vpl-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-plm-vpl-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
           if        w-rig-plm-vpl (1)    not  = zero
                     go to acc-plm-vpl-700.
      *                  *---------------------------------------------*
      *                  * Normalizzazione tipo di limitazione per le- *
      *                  * game valutario                              *
      *                  *---------------------------------------------*
           if        w-rig-tlm-vpl (1)    not  = spaces
                     move  spaces         to   w-rig-tlm-vpl (1)
                     perform vis-tlm-vpl-000
                                          thru vis-tlm-vpl-999        .
       acc-plm-vpl-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-plm-vpl-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-plm-vpl-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-plm-vpl-100.
       acc-plm-vpl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga corpo : Percentuale di   *
      *    * limitazione per legame valutario                          *
      *    *-----------------------------------------------------------*
       vis-plm-vpl-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      16                   to   v-lin                  .
           move      75                   to   v-pos                  .
           move      w-rig-plm-vpl (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-plm-vpl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Tipo di limitazione per   *
      *    * legame valutario                                          *
      *    *-----------------------------------------------------------*
       acc-tlm-vpl-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo archivio                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    =    "D"
                     go to acc-tlm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su momento di applicazione cambio  *
      *                      * per legame valutario                    *
      *                      *-----------------------------------------*
           if        w-tes-mac-lvl (1)    =    zero
                     go to acc-tlm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-tlm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su sigla valuta per legame valuta- *
      *                      * rio                                     *
      *                      *-----------------------------------------*
           if        w-rig-sgl-vpl (1)    =    spaces
                     go to acc-tlm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Test su percentuale di limitazione per  *
      *                      * legame valutario                        *
      *                      *-----------------------------------------*
           if        w-rig-plm-vpl (1)    =    zero
                     go to acc-tlm-vpl-999.
      *                      *-----------------------------------------*
      *                      * Preparazione valore di default          *
      *                      *-----------------------------------------*
           if        w-rig-tlm-vpl (1)    =    spaces
                     move  "T"            to   w-rig-tlm-vpl (1)      .
       acc-tlm-vpl-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      80                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-tlm-vpl (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-tlm-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-tlm-vpl-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "tlm-vpl"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
       acc-tlm-vpl-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-tlm-vpl (1)      .
       acc-tlm-vpl-300.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-tlm-vpl-400.
      *                  *---------------------------------------------*
      *                  * Find per note operative                     *
      *                  *---------------------------------------------*
           move      w-rig-tlm-vpl (1)    to   w-fnd-tlm-vpl-tlm      .
           perform   fnd-tlm-vpl-000      thru fnd-tlm-vpl-999        .
           move      w-fnd-tlm-vpl-tlm    to   w-rig-tlm-vpl (1)      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione function-key                *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-tlm-vpl-100.
       acc-tlm-vpl-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a spaces non ammesso, a meno che non *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-rig-tlm-vpl (1)    not  = spaces
                     go to acc-tlm-vpl-500.
           if        v-key                =    "UP  "
                     go to acc-tlm-vpl-600
           else      go to acc-tlm-vpl-100.
       acc-tlm-vpl-500.
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
           if        w-rig-tlm-vpl (1)    not  = "T" and
                     w-rig-tlm-vpl (1)    not  = "F" and
                     w-rig-tlm-vpl (1)    not  = "M"
                     go to acc-tlm-vpl-100.
       acc-tlm-vpl-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-tlm-vpl-700.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-tlm-vpl-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-tlm-vpl-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-tlm-vpl-100.
       acc-tlm-vpl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga corpo : Tipo di limita-  *
      *    * zione per legame valutario                                *
      *    *-----------------------------------------------------------*
       vis-tlm-vpl-000.
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      80                   to   v-pos                  .
           move      w-rig-tlm-vpl (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tlm-vpl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Percentuali sconto in riga           *
      *    *-----------------------------------------------------------*
       acc-per-scr-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo archivio                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    =    "D"
                     go to acc-per-scr-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-per-scr-999.
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione relativa al   *
      *                      * tipo accettazione percentuali di sconto *
      *                      * in riga                                 *
      *                      *-----------------------------------------*
           if        w-prs-tac-psr        =    99
                     go to acc-per-scr-999.
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore 01..05           *
      *                  *---------------------------------------------*
           move      01                   to   w-acc-per-scr-ctr      .
       acc-per-scr-100.
      *              *-------------------------------------------------*
      *              * Salvataggio valore precedente                   *
      *              *-------------------------------------------------*
           move      w-rig-per-scr
                    (1, w-acc-per-scr-ctr)
                                          to   w-sav-per-scr
                                              (w-acc-per-scr-ctr)     .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      17                   to   v-lin                  .
           move      w-acc-per-scr-ctr    to   v-pos                  .
           if        w-acc-per-scr-ctr    >    5
                     subtract  5          from v-pos                  .
           multiply  05                   by   v-pos                  .
           add       16                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "TAB "               to   v-pfk (10)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[1] "               to   v-pfk (14)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-per-scr
                    (1, w-acc-per-scr-ctr)
                                          to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-per-scr-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-per-scr-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "per-scr"      to   w-dup-vri-pre-ncd
                     move  w-acc-per-scr-ctr
                                          to   w-dup-vri-pre-ctr
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999
                     move  "TAB "         to   v-key                  .
       acc-per-scr-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-per-scr
                                              (1, w-acc-per-scr-ctr)  .
       acc-per-scr-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-per-scr-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-per-scr
                    (1, w-acc-per-scr-ctr)
                                          =    w-sav-per-scr
                                              (w-acc-per-scr-ctr)
                     go to acc-per-scr-700.
       acc-per-scr-620.
      *                  *---------------------------------------------*
      *                  * Determinazione prezzo netto                 *
      *                  *---------------------------------------------*
           move      w-rig-prz-ven (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       acc-per-scr-640.
      *                  *---------------------------------------------*
      *                  * Provvigioni in riga                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-per-scr-660.
      *                      *-----------------------------------------*
      *                      * Test se da trattare                     *
      *                      *-----------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-per-scr-660.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-ppv-rig-000      thru det-ppv-rig-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-fsp-rig-000      thru vis-fsp-rig-999        .
           perform   vis-ppv-rig-000      thru vis-ppv-rig-999        .
       acc-per-scr-660.
      *                  *---------------------------------------------*
      *                  * Importo in riga                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-per-scr-680.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-per-scr-700.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione dell'impostazione        *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-per-scr-710
           else if   v-key                =    "DOWN"
                     go to acc-per-scr-720
           else if   v-key                =    "TAB "
                     go to acc-per-scr-740
           else if   v-key                =    "[1] "
                     go to acc-per-scr-730
           else if   v-key                =    "DO  "
                     go to acc-per-scr-800
           else      go to acc-per-scr-720.
       acc-per-scr-710.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        w-acc-per-scr-ctr    =    1
                     go to acc-per-scr-999.
           subtract  1                    from w-acc-per-scr-ctr      .
           go to     acc-per-scr-100.
       acc-per-scr-720.
      *              *-------------------------------------------------*
      *              * Se Down o Return                                *
      *              *-------------------------------------------------*
           go to     acc-per-scr-999.
       acc-per-scr-730.
      *              *-------------------------------------------------*
      *              * Se Pf1                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Aggiornamento prezzo di vendita             *
      *                  *---------------------------------------------*
           move      w-rig-prz-net (1)    to   w-rig-prz-ven (1)      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione percentuali di sconto in    *
      *                  * riga                                        *
      *                  *---------------------------------------------*
           move      zero                 to   w-rig-per-scr (1, 1)   .
           move      zero                 to   w-rig-per-scr (1, 2)   .
           move      zero                 to   w-rig-per-scr (1, 3)   .
           move      zero                 to   w-rig-per-scr (1, 4)   .
           move      zero                 to   w-rig-per-scr (1, 5)   .
      *                  *---------------------------------------------*
      *                  * Visualizzazione prezzo di vendita           *
      *                  *---------------------------------------------*
           perform   vis-prz-ven-000      thru vis-prz-ven-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione percentuali di sconto in    *
      *                  * riga                                        *
      *                  *---------------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
      *                  *---------------------------------------------*
      *                  * Provvigioni in riga                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se prodotto similare : oltre            *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-per-scr-735.
      *                      *-----------------------------------------*
      *                      * Test se da trattare                     *
      *                      *-----------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-per-scr-735.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-ppv-rig-000      thru det-ppv-rig-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-fsp-rig-000      thru vis-fsp-rig-999        .
           perform   vis-ppv-rig-000      thru vis-ppv-rig-999        .
       acc-per-scr-735.
      *                  *---------------------------------------------*
      *                  * Uscita come per Down                        *
      *                  *---------------------------------------------*
           go to     acc-per-scr-999.
       acc-per-scr-740.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        w-acc-per-scr-ctr        =    05
                     go to acc-per-scr-999.
      *                  *---------------------------------------------*
      *                  * Incremento contatore                        *
      *                  *---------------------------------------------*
           add       1                    to   w-acc-per-scr-ctr      .
           go to     acc-per-scr-100.
       acc-per-scr-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-per-scr-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-per-scr-100.
       acc-per-scr-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Percentuali di sconto in riga     *
      *    *-----------------------------------------------------------*
       vis-per-scr-000.
           move      zero                 to   w-vis-per-scr-ctr      .
       vis-per-scr-200.
           add       1                    to   w-vis-per-scr-ctr      .
           if        w-vis-per-scr-ctr    >    5
                     go to vis-per-scr-999.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      17                   to   v-lin                  .
           move      w-vis-per-scr-ctr    to   v-pos                  .
           multiply  05                   by   v-pos                  .
           add       16                   to   v-pos                  .
           move      w-rig-per-scr 
                    (1, w-vis-per-scr-ctr)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     vis-per-scr-200.
       vis-per-scr-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Importo in riga           *
      *    *-----------------------------------------------------------*
       acc-imp-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo archivio                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    =    "D"
                     go to acc-imp-rig-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "A"
                     go to acc-imp-rig-999.
       acc-imp-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      18                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-imp-rig (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-imp-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-imp-rig-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "imp-rig"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-imp-rig (1)      .
       acc-imp-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a zero : reimpostazione a meno    *
      *                  * che non si sia in Up                        *
      *                  *---------------------------------------------*
           if        w-rig-imp-rig (1)    not  = zero
                     go to acc-imp-rig-600.
           if        v-key                =    "UP  "
                     go to acc-imp-rig-600
           else      go to acc-imp-rig-100.
       acc-imp-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-imp-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-imp-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-imp-rig-100.
       acc-imp-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Importo in riga                   *
      *    *-----------------------------------------------------------*
       vis-imp-rig-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      18                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-imp-rig (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-imp-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Data consegna richiesta   *
      *    *-----------------------------------------------------------*
       acc-dcn-ric-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-dcn-ric-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-dcn-ric (1)    to   w-sav-dcn-ric          .
       acc-dcn-ric-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      ">"                  to   v-edm                  .
           move      19                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-dcn-ric (1)    to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-dcn-ric-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-dcn-ric-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "dcn-ric"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-dat                to   w-rig-dcn-ric (1)      .
       acc-dcn-ric-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-rig-dcn-ric (1)    not  = zero
                     go to acc-dcn-ric-500.
      *                      *-----------------------------------------*
      *                      * Forzatura da data documento             *
      *                      *-----------------------------------------*
           move      w-tes-dat-doc        to   w-rig-dcn-ric (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-dcn-ric-000      thru vis-dcn-ric-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-dcn-ric-600.
       acc-dcn-ric-500.
      *                  *---------------------------------------------*
      *                  * Se valore inferiore alla data documento     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-rig-dcn-ric (1)    not  < w-tes-dat-doc
                     go to acc-dcn-ric-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Data consegna richiesta inferiore alla data ordine
      -              " !             "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-dcn-ric-600.
       acc-dcn-ric-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-dcn-ric (1)    =    w-sav-dcn-ric
                     go to acc-dcn-ric-800.
      *                  *---------------------------------------------*
      *                  * Trattamento data consegna prevista          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga gia' confermata : oltre         *
      *                      *-----------------------------------------*
           if        w-rig-flg-cnf (1)    not  = spaces
                     go to acc-dcn-ric-800.
      *                      *-----------------------------------------*
      *                      * Se data consegna prevista diversa da    *
      *                      * data consegna richiesta precedente: ol- *
      *                      * tre                                     *
      *                      *-----------------------------------------*
           if        w-rig-dcn-prv (1)    not  = w-sav-dcn-ric
                     go to acc-dcn-ric-800.
      *                      *-----------------------------------------*
      *                      * Trattamento                             *
      *                      *-----------------------------------------*
           move      w-rig-dcn-ric (1)    to   w-rig-dcn-prv (1)      .
           perform   vis-dcn-prv-000      thru vis-dcn-prv-999        .
       acc-dcn-ric-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-dcn-ric-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-dcn-ric-100.
       acc-dcn-ric-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Data consegna richiesta           *
      *    *-----------------------------------------------------------*
       vis-dcn-ric-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      ">"                  to   v-edm                  .
           move      19                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-dcn-ric (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dcn-ric-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Data consegna prevista    *
      *    *-----------------------------------------------------------*
       acc-dcn-prv-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-dcn-prv-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-dcn-prv (1)    to   w-sav-dcn-prv          .
       acc-dcn-prv-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      ">"                  to   v-edm                  .
           move      19                   to   v-lin                  .
           move      40                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-dcn-prv (1)    to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-dcn-prv-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-dcn-prv-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "dcn-prv"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-dat                to   w-rig-dcn-prv (1)      .
       acc-dcn-prv-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-rig-dcn-prv (1)    not  = zero
                     go to acc-dcn-prv-500.
      *                      *-----------------------------------------*
      *                      * Forzatura da data consegna richiesta    *
      *                      *-----------------------------------------*
           move      w-rig-dcn-ric (1)    to   w-rig-dcn-prv (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-dcn-prv-000      thru vis-dcn-prv-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-dcn-prv-600.
       acc-dcn-prv-500.
      *                  *---------------------------------------------*
      *                  * Se valore inferiore alla data documento     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-rig-dcn-prv (1)    not  < w-tes-dat-doc
                     go to acc-dcn-prv-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Data consegna prevista inferiore alla data ordine 
      -              "!              "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-dcn-prv-600.
       acc-dcn-prv-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-dcn-prv (1)    =    w-sav-dcn-prv
                     go to acc-dcn-prv-800.
      *                  *---------------------------------------------*
      *                  * Test su personalizzazione                   *
      *                  *---------------------------------------------*
           if        w-prs-dcn-prv        not  = "S"
                     go to acc-dcn-prv-800.
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           perform   det-prz-ven-000      thru det-prz-ven-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           perform   vis-prz-ven-000      thru vis-prz-ven-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione prezzo netto                 *
      *                  *---------------------------------------------*
           move      w-rig-prz-ven (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
      *                  *---------------------------------------------*
      *                  * Determinazione importo in riga              *
      *                  *---------------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione importo in riga             *
      *                  *---------------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-dcn-prv-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-dcn-prv-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-dcn-prv-100.
       acc-dcn-prv-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Data consegna prevista            *
      *    *-----------------------------------------------------------*
       vis-dcn-prv-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      ">"                  to   v-edm                  .
           move      19                   to   v-lin                  .
           move      40                   to   v-pos                  .
           move      w-rig-dcn-prv (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dcn-prv-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Flag di conferma          *
      *    *-----------------------------------------------------------*
       acc-flg-cnf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-flg-cnf-999.
       acc-flg-cnf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      50                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-flg-cnf (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-flg-cnf-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-flg-cnf-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "flg-cnf"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-flg-cnf (1)      .
       acc-flg-cnf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-flg-cnf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-flg-cnf-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-flg-cnf-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-flg-cnf-100.
       acc-flg-cnf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Flag di conferma                  *
      *    *-----------------------------------------------------------*
       vis-flg-cnf-000.
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      50                   to   v-pos                  .
           move      w-rig-flg-cnf (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-flg-cnf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Flag di significativita'  *
      *    * provvigioni in riga                                       *
      *    *-----------------------------------------------------------*
       acc-fsp-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-fsp-rig-999.
           if        w-tes-fsp-doc (1)    =    02 or
                     w-tes-fsp-doc (1)    =    03
                     go to acc-fsp-rig-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-fsp-rig-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-fsp-rig (1)    to    w-sav-fsp-rig         .
      *                  *---------------------------------------------*
      *                  * Eventuale aggiustamento pop-up nel caso di  *
      *                  * righe di tipo 'A' o 'PN'                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Salvataggio tabella pop-up attuale      *
      *                      *-----------------------------------------*
           move      w-exp-fsp-rig-tbl    to   w-exp-fsp-rig-svt      .
      *                      *-----------------------------------------*
      *                      * Test se da eseguire                     *
      *                      *-----------------------------------------*
           if       (w-rig-tip-rig-tpr (1)
                                          =    "A"   ) or
                    (w-rig-tip-rig-tpr (1)
                                          =    "P" and
                     w-rig-tip-rig-tfu (1)
                                          =    "N"   )
                     go to acc-fsp-rig-050
           else      go to acc-fsp-rig-100.
       acc-fsp-rig-050.
      *                      *-----------------------------------------*
      *                      * Modifica al numero elementi del pop-up  *
      *                      *-----------------------------------------*
           move      02                   to   w-exp-fsp-rig-num      .
      *                      *-----------------------------------------*
      *                      * Spostamento 2. elemento nel 1.          *
      *                      *-----------------------------------------*
           move      w-exp-fsp-rig-ele (2)
                                          to   w-exp-fsp-rig-ele (1)  .
      *                      *-----------------------------------------*
      *                      * Spostamento 3. elemento nel 2.          *
      *                      *-----------------------------------------*
           move      w-exp-fsp-rig-ele (3)
                                          to   w-exp-fsp-rig-ele (2)  .
       acc-fsp-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-fsp-rig-lun    to   v-car                  .
           move      w-exp-fsp-rig-num    to   v-ldt                  .
           move      "SNX#"               to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      18                   to   v-lin                  .
           move      66                   to   v-pos                  .
           move      w-exp-fsp-rig-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
      *                  *---------------------------------------------*
      *                  * Valore di accettazione                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda sel tipo riga      *
      *                      *-----------------------------------------*
           if       (w-rig-tip-rig-tpr (1)
                                          =    "A"   ) or
                    (w-rig-tip-rig-tpr (1)
                                          =    "P" and
                     w-rig-tip-rig-tfu (1)
                                          =    "N"   )
                     go to acc-fsp-rig-120
           else      go to acc-fsp-rig-140.
       acc-fsp-rig-120.
      *                      *-----------------------------------------*
      *                      * Se riga di tipo 'A' o 'PN'              *
      *                      *-----------------------------------------*
           if        w-rig-fsp-rig (1)    =    02
                     move  01             to   v-num
           else if   w-rig-fsp-rig (1)    =    03
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
           go to     acc-fsp-rig-180.
       acc-fsp-rig-140.
      *                      *-----------------------------------------*
      *                      * Se riga di tipo 'P'                     *
      *                      *-----------------------------------------*
           move      w-rig-fsp-rig (1)    to   v-num                  .
           go to     acc-fsp-rig-180.
       acc-fsp-rig-180.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-fsp-rig-185.
      *              *-------------------------------------------------*
      *              * Ripristino                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino tabella pop-up precedentemente   *
      *                  * salvata                                     *
      *                  *---------------------------------------------*
           move      w-exp-fsp-rig-svt    to   w-exp-fsp-rig-tbl      .
      *                  *---------------------------------------------*
      *                  * Ripristino elementi pop-up a 3              *
      *                  *---------------------------------------------*
           move      03                   to   w-exp-fsp-rig-num      .
       acc-fsp-rig-190.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-fsp-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-fsp-rig-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "fsp-rig"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
       acc-fsp-rig-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del tipo riga          *
      *                  *---------------------------------------------*
           if       (w-rig-tip-rig-tpr (1)
                                          =    "A"   ) or
                    (w-rig-tip-rig-tpr (1)
                                          =    "P" and
                     w-rig-tip-rig-tfu (1)
                                          =    "N"   )
                     go to acc-fsp-rig-220
           else      go to acc-fsp-rig-240.
       acc-fsp-rig-220.
      *                      *-----------------------------------------*
      *                      * Se riga di tipo 'A' o 'PN'              *
      *                      *-----------------------------------------*
           if        v-num                =    01
                     move  02             to   w-rig-fsp-rig (1)
           else if   v-num                =    02
                     move  03             to   w-rig-fsp-rig (1)
           else      move  zero           to   w-rig-fsp-rig (1)      .
           go to     acc-fsp-rig-400.
       acc-fsp-rig-240.
      *                      *-----------------------------------------*
      *                      * Se riga di tipo 'P'                     *
      *                      *-----------------------------------------*
           move      v-num                to   w-rig-fsp-rig (1)      .
           go to     acc-fsp-rig-400.
       acc-fsp-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-rig-fsp-rig (1)    not  = zero
                     go to acc-fsp-rig-500.
           if        v-key                =    "UP  "
                     go to acc-fsp-rig-600
           else      go to acc-fsp-rig-100.
       acc-fsp-rig-500.
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
           if        w-rig-fsp-rig (1)    not  = 01 and
                     w-rig-fsp-rig (1)    not  = 02 and
                     w-rig-fsp-rig (1)    not  = 03
                     go to acc-fsp-rig-100.
       acc-fsp-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-fsp-rig (1)    =    w-sav-fsp-rig
                     go to acc-fsp-rig-800.
      *                  *---------------------------------------------*
      *                  * Trattamento percentuali di provvigione in   *
      *                  * riga                                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del valore at-   *
      *                      * tuale                                   *
      *                      *-----------------------------------------*
           if        w-rig-fsp-rig (1)    =    01
                     go to acc-fsp-rig-602
           else if   w-rig-fsp-rig (1)    =    02
                     go to acc-fsp-rig-604
           else if   w-rig-fsp-rig (1)    =    03
                     go to acc-fsp-rig-606
           else      go to acc-fsp-rig-610.
       acc-fsp-rig-602.
      *                      *-----------------------------------------*
      *                      * Se valore attuale : Si                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione provvigioni in riga  *
      *                          *-------------------------------------*
           perform   det-ppv-rig-000      thru det-ppv-rig-999        .
      *                          *-------------------------------------*
      *                          * Visualizzazione provvigioni in riga *
      *                          *-------------------------------------*
           perform   vis-fsp-rig-000      thru vis-fsp-rig-999        .
           perform   vis-ppv-rig-000      thru vis-ppv-rig-999        .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-fsp-rig-610.
       acc-fsp-rig-604.
      *                      *-----------------------------------------*
      *                      * Se valore attuale : No                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione percentuali         *
      *                          *-------------------------------------*
           move      zero                 to   w-rig-ppv-rig (1, 1)   .
           move      zero                 to   w-rig-ppv-rig (1, 2)   .
           move      zero                 to   w-rig-ppv-rig (1, 3)   .
           perform   vis-ppv-rig-000      thru vis-ppv-rig-999        .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-fsp-rig-610.
       acc-fsp-rig-606.
      *                      *-----------------------------------------*
      *                      * Se valore attuale : Speciali            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-fsp-rig-610.
       acc-fsp-rig-610.
      *                  *---------------------------------------------*
      *                  * Trattamento importo provvigioni a forfait   *
      *                  * per la riga                                 *
      *                  *---------------------------------------------*
           if        w-rig-fsp-rig (1)    =    03
                     go to acc-fsp-rig-700.
           if        w-rig-pvf-rig (1)    =    zero
                     go to acc-fsp-rig-700.
           move      zero                 to   w-rig-pvf-rig (1)      .
           perform   vis-pvf-rig-000      thru vis-pvf-rig-999        .
       acc-fsp-rig-700.
      *                  *---------------------------------------------*
      *                  * Eventuale messaggio se impostate in testata *
      *                  * provvigioni a forfait                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-tes-fsp-doc (1)    =    01
                     go to acc-fsp-rig-800.
           if        w-rig-fsp-rig (1)    =    03
                     go to acc-fsp-rig-800.
      *                      *-----------------------------------------*
      *                      * Messaggio di avviso                     *
      *                      *-----------------------------------------*
           move      "ATTENZIONE : la variazione apportata potrebbe non 
      -              "essere compa-  "    to   w-err-box-err-msg      .
           move      "tibile con l'indicatore provvigionale del document
      -              "o !            "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       acc-fsp-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-fsp-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-fsp-rig-100.
       acc-fsp-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo riga corpo : Flag di significativi- *
      *    * ta' provvigioni in riga                                   *
      *    *-----------------------------------------------------------*
       vis-fsp-rig-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to vis-fsp-rig-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-fsp-rig-lun    to   v-car                  .
           move      w-exp-fsp-rig-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      18                   to   v-lin                  .
           move      66                   to   v-pos                  .
           move      w-exp-fsp-rig-tbl    to   v-txt                  .
           move      w-rig-fsp-rig (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-fsp-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Percentuali di provvigio- *
      *    *                                 ne in riga                *
      *    *-----------------------------------------------------------*
       acc-ppv-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo archivio                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    =    "D"
                     go to acc-ppv-rig-999.
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-ppv-rig-999.
           if        w-tes-fsp-doc (1)    =    02 or
                     w-tes-fsp-doc (1)    =    03
                     go to acc-ppv-rig-999.
           if        w-rig-fsp-rig (1)    not  = 03
                     go to acc-ppv-rig-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-ppv-rig-999.
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore 01..03           *
      *                  *---------------------------------------------*
           move      01                   to   w-acc-ppv-rig-ctr      .
       acc-ppv-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      19                   to   v-lin                  .
           if        w-acc-ppv-rig-ctr    =    1
                     move  66             to   v-pos
           else if   w-acc-ppv-rig-ctr    =    2
                     move  71             to   v-pos
           else if   w-acc-ppv-rig-ctr    =    3
                     move  76             to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "TAB "               to   v-pfk (10)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-ppv-rig
                    (1, w-acc-ppv-rig-ctr)
                                          to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-ppv-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-ppv-rig-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "ppv-rig"      to   w-dup-vri-pre-ncd
                     move  w-acc-ppv-rig-ctr
                                          to   w-dup-vri-pre-ctr
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
       acc-ppv-rig-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-ppv-rig
                                              (1, w-acc-ppv-rig-ctr)  .
       acc-ppv-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-ppv-rig-420.
      *                  *---------------------------------------------*
      *                  * Eventuale messaggio se impostate in testata *
      *                  * provvigioni a forfait                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-tes-fsp-doc (1)    not  = 04
                     go to acc-ppv-rig-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di avviso                     *
      *                      *-----------------------------------------*
           move      "ATTENZIONE : una eventuale variazione a questo cam
      -              "po, potrebbe   "    to   w-err-box-err-msg      .
           move      "non coincidere con quanto indicato in testata del 
      -              "documento !    "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       acc-ppv-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Trattamento provvigione a forfait in riga   *
      *                  *---------------------------------------------*
           if        w-rig-ppv-rig
                    (1, w-acc-ppv-rig-ctr)
                                          =    zero
                     go to acc-ppv-rig-620.
           if        w-rig-pvf-rig (1)    =    zero
                     go to acc-ppv-rig-620.
           move      zero                 to   w-rig-pvf-rig (1)      .
           perform   vis-pvf-rig-000      thru vis-pvf-rig-999        .
       acc-ppv-rig-620.
      *                  *---------------------------------------------*
      *                  * Trattamento sequenza di impostazione        *
      *                  *---------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-ppv-rig-650
           else if   v-key                =    "DOWN"
                     go to acc-ppv-rig-700
           else if   v-key                =    "TAB "
                     go to acc-ppv-rig-710
           else if   v-key                =    "DO  "
                     go to acc-ppv-rig-800
           else      go to acc-ppv-rig-700.
       acc-ppv-rig-650.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        w-acc-ppv-rig-ctr    =    1
                     go to acc-ppv-rig-999.
           subtract  1                    from w-acc-ppv-rig-ctr      .
           go to     acc-ppv-rig-100.
       acc-ppv-rig-700.
      *              *-------------------------------------------------*
      *              * Se Down o Return                                *
      *              *-------------------------------------------------*
           go to     acc-ppv-rig-999.
       acc-ppv-rig-710.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        w-acc-ppv-rig-ctr        =    03
                     go to acc-ppv-rig-999.
      *                  *---------------------------------------------*
      *                  * Incremento contatore                        *
      *                  *---------------------------------------------*
           add       1                    to   w-acc-ppv-rig-ctr      .
           go to     acc-ppv-rig-100.
       acc-ppv-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-ppv-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-ppv-rig-100.
       acc-ppv-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Percentuali di provvigione in ri- *
      *    *                         ga                                *
      *    *-----------------------------------------------------------*
       vis-ppv-rig-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se gestione agenti si/no attiva             *
      *                  *---------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to vis-ppv-rig-999.
      *                  *---------------------------------------------*
      *                  * Se personalizzazione specifica lo consente  *
      *                  *---------------------------------------------*
           if        w-prs-snx-vpp        not  = "N"
                     go to vis-ppv-rig-100.
      *                      *-----------------------------------------*
      *                      * Solo se provvigioni 'normali'           *
      *                      *-----------------------------------------*
           if        w-rig-fsp-rig (1)    not  = 01
                     go to vis-ppv-rig-100
           else      go to vis-ppv-rig-999.
       vis-ppv-rig-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      zero                 to   w-acc-ppv-rig-ctr      .
       vis-ppv-rig-200.
           add       1                    to   w-acc-ppv-rig-ctr      .
           if        w-acc-ppv-rig-ctr    >    3
                     go to vis-ppv-rig-999.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      19                   to   v-lin                  .
           if        w-acc-ppv-rig-ctr    =    1
                     move  66             to   v-pos
           else if   w-acc-ppv-rig-ctr    =    2
                     move  71             to   v-pos
           else if   w-acc-ppv-rig-ctr    =    3
                     move  76             to   v-pos                  .
           move      w-rig-ppv-rig 
                    (1, w-acc-ppv-rig-ctr)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           go to     vis-ppv-rig-200.
       vis-ppv-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Provvigioni a forfait in  *
      *    * riga                                                      *
      *    *-----------------------------------------------------------*
       acc-pvf-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo archivio                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    =    "D"
                     go to acc-pvf-rig-999.
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-pvf-rig-999.
           if        w-tes-fsp-doc (1)    not  = 01
                     go to acc-pvf-rig-999.
           if        w-rig-fsp-rig (1)    not  = 03
                     go to acc-pvf-rig-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-pvf-rig-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-pvf-rig (1)    to    w-sav-pvf-rig         .
       acc-pvf-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      20                   to   v-lin                  .
           move      66                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-pvf-rig (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-pvf-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-pvf-rig-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "pvf-rig"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-pvf-rig (1)      .
       acc-pvf-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-pvf-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-pvf-rig (1)    =    w-sav-pvf-rig
                     go to acc-pvf-rig-800.
      *                  *---------------------------------------------*
      *                  * Se valore a zero : oltre                    *
      *                  *---------------------------------------------*
           if        w-rig-pvf-rig (1)    =    zero
                     go to acc-pvf-rig-800.
      *                  *---------------------------------------------*
      *                  * Trattamento percentuali di provvigione in   *
      *                  * riga                                        *
      *                  *---------------------------------------------*
           if        w-rig-ppv-rig (1, 1) =    zero and
                     w-rig-ppv-rig (1, 2) =    zero and
                     w-rig-ppv-rig (1, 3) =    zero
                     go to acc-pvf-rig-800.
           move      zero                 to   w-rig-ppv-rig (1, 1)   .
           move      zero                 to   w-rig-ppv-rig (1, 2)   .
           move      zero                 to   w-rig-ppv-rig (1, 3)   .
           perform   vis-ppv-rig-000      thru vis-ppv-rig-999        .
       acc-pvf-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-pvf-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-pvf-rig-100.
       acc-pvf-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Provvigioni a forfait in riga     *
      *    *-----------------------------------------------------------*
       vis-pvf-rig-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to vis-pvf-rig-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      20                   to   v-lin                  .
           move      66                   to   v-pos                  .
           move      w-rig-pvf-rig (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-pvf-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice iva                *
      *    *-----------------------------------------------------------*
       acc-coi-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo archivio                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    =    "D"
                     go to acc-coi-rig-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-coi-rig-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-coi-rig-100.
       acc-coi-rig-100.
      *              *-------------------------------------------------*
      *              * Editing preliminare per l'accettazione          *
      *              *-------------------------------------------------*
           move      w-rig-coi-rig (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zci-ope      .
           move      w-edt-iva-cie        to   w-cod-mne-zci-cod      .
           move      20                   to   w-cod-mne-zci-lin      .
           move      21                   to   w-cod-mne-zci-pos      .
           move      20                   to   w-cod-mne-zci-dln      .
           move      32                   to   w-cod-mne-zci-dps      .
           move      "<BD"                to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
       acc-coi-rig-110.
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           if        w-cod-mne-zci-ope    =    "F+"
                     go to acc-coi-rig-115.
           if        w-cod-mne-zci-ope    =    "AC"
                     go to acc-coi-rig-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-coi-rig-115.
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
           go to     acc-coi-rig-110.
       acc-coi-rig-120.
      *              *-------------------------------------------------*
      *              * Editing valore impostato                        *
      *              *-------------------------------------------------*
           move      w-cod-mne-zci-cod    to   w-edt-iva-cie          .
           perform   edt-iva-cod-000      thru edt-iva-cod-999        .
           move      w-edt-iva-cod        to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-coi-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-coi-rig-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "coi-rig"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
       acc-coi-rig-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-coi-rig (1)      .
       acc-coi-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Richiamo routine di controllo codice iva    *
      *                  *---------------------------------------------*
           move      w-rig-coi-rig (1)    to   d-imp-iva-cod-iva      .
           move      "1"                  to   d-imp-iva-tip-iva      .
           move      spaces               to   d-imp-iva-tip-ctl      .
           perform   ctl-cod-iva-000      thru ctl-cod-iva-999        .
      *                  *---------------------------------------------*
      *                  * Se errore : messaggio e reimpostazione      *
      *                  *---------------------------------------------*
           if        d-imp-iva-exi-sts    =    spaces
                     go to acc-coi-rig-500.
      *                  *---------------------------------------------*
      *                  * Messaggio di avviso                         *
      *                  *---------------------------------------------*
           move      d-imp-iva-msg-exi    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-coi-rig-100.
       acc-coi-rig-500.
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-ctl-coi-rig-des    to   w-rig-coi-rig-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-cir-000      thru vis-des-cir-999        .
      *                  *---------------------------------------------*
      *                  * Se codice iva a zero : reimpostazione a meno*
      *                  * che non si sia su Up                        *
      *                  *---------------------------------------------*
           if        w-rig-coi-rig (1)    not  = zero
                     go to acc-coi-rig-600.
           if        v-key                =    "UP  "
                     go to acc-coi-rig-600
           else      go to acc-coi-rig-100.
       acc-coi-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-coi-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-coi-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-coi-rig-100.
       acc-coi-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice iva                *
      *    *-----------------------------------------------------------*
       vis-coi-rig-000.
      *              *-------------------------------------------------*
      *              * Editing preliminare                             *
      *              *-------------------------------------------------*
           move      w-rig-coi-rig (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      20                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-edt-iva-cie        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-coi-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione codice IVA    *
      *    *-----------------------------------------------------------*
       vis-des-cir-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           move      w-rig-coi-rig (1)    to   w-edt-iva-cod          .
           if        w-edt-iva-cod-003    =    zero
                     go to vis-des-cir-999.
       vis-des-cir-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      15                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      32                   to   v-pos                  .
           move      w-rig-coi-rig-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-cir-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice contropartita      *
      *    *-----------------------------------------------------------*
       acc-ctv-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo archivio                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-arc (1)    =    "D"
                     go to acc-ctv-rig-999.
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-ctv-rig-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-ctv-rig-100.
           if        w-tes-ctp-ven (1)    not  = zero
                     go to acc-ctv-rig-999.
       acc-ctv-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-pdc-ope      .
           move      w-prs-liv-pdc        to   w-cod-mne-pdc-liv      .
           move      w-rig-ctv-rig (1)    to   w-cod-mne-pdc-cod      .
           move      21                   to   w-cod-mne-pdc-lin      .
           move      21                   to   w-cod-mne-pdc-pos      .
           move      21                   to   w-cod-mne-pdc-dln      .
           move      32                   to   w-cod-mne-pdc-dps      .
           move      "B"                  to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
       acc-ctv-rig-110.
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           if        w-cod-mne-pdc-ope    =    "F+"
                     go to acc-ctv-rig-115.
           if        w-cod-mne-pdc-ope    =    "AC"
                     go to acc-ctv-rig-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-ctv-rig-115.
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
           go to     acc-ctv-rig-110.
       acc-ctv-rig-120.
           move      w-cod-mne-pdc-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-ctv-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-ctv-rig-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "ctv-rig"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
       acc-ctv-rig-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-ctv-rig (1)      .
       acc-ctv-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio piano dei conti            *
      *                  *---------------------------------------------*
           move      w-rig-ctv-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctv-rig-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione sottoconto      *
      *                  *---------------------------------------------*
           perform   vis-des-cvr-000      thru vis-des-cvr-999        .
      *                  *---------------------------------------------*
      *                  * Se codice sottoconto non esistente : reim-  *
      *                  * postazione                                  *
      *                  *---------------------------------------------*
           if        w-let-arc-pdc-flg    not  = spaces
                     go to acc-ctv-rig-100.
      *                  *---------------------------------------------*
      *                  * Se valore a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-rig-ctv-rig (1)    =    zero
                     go to acc-ctv-rig-100.
       acc-ctv-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ctv-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-ctv-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-ctv-rig-100.
       acc-ctv-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Contropartita vendite in  *
      *    * riga                                                      *
      *    *-----------------------------------------------------------*
       vis-ctv-rig-000.
      *              *-------------------------------------------------*
      *              * Editing con appoggio a sinistra                 *
      *              *-------------------------------------------------*
           move      w-prs-liv-pdc        to   w-edt-cod-pdc-liv      .
           move      w-rig-ctv-rig (1)    to   w-edt-cod-pdc-cod      .
           move      "B"                  to   w-edt-cod-pdc-edm      .
           perform   edt-pdc-asx-000      thru edt-pdc-asx-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-edt-cod-pdc-edt    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ctv-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione contropartita *
      *    * vendite in riga                                           *
      *    *-----------------------------------------------------------*
       vis-des-cvr-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      32                   to   v-pos                  .
           move      w-rig-ctv-rig-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-cvr-999.
           exit.

      *    *===========================================================*
      *    * Duplicazione valore della riga precedente                 *
      *    *-----------------------------------------------------------*
       dup-vri-pre-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione function-key                    *
      *              *-------------------------------------------------*
           move      spaces               to   v-key                  .
      *              *-------------------------------------------------*
      *              * Se su prima riga di accettazione : uscita       *
      *              *-------------------------------------------------*
           if        w-cnt-cor-nrg-dac    =    1
                     go to dup-vri-pre-999.
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Lettura record catena precedente                *
      *              *-------------------------------------------------*
           move      "RD"                 to   w-cat-rig-ope          .
           subtract  1                    from w-cnt-cor-nrg-dac
                                        giving w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
       dup-vri-pre-100.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valore campo riga precedente in *
      *              * area v                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del nome campo da    *
      *                  * duplicare                                   *
      *                  *---------------------------------------------*
           if        w-dup-vri-pre-ncd    =    "cod-aoc"
                     move  w-rig-tip-rig-cac (1)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "cod-pro"
                     move  w-rig-alf-pro (1)
                                          to   v-alf
                     move  w-rig-num-pro (1)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "cop-scl"
                     move  w-rig-cop-scl (1)
                                          to   v-alf
      *
           else if   w-dup-vri-pre-ncd    =    "des-rig"
                     move  w-rig-des-rig (1)
                                          to   v-txt
      *
           else if   w-dup-vri-pre-ncd    =    "qta-ord"
                     move  w-rig-qta-ord (1)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "qta-a02"
                     move  w-rig-qta-a02 (1)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "sgl-vpp"
                     move  w-rig-sgl-vpp (1)
                                          to   v-alf
      *
           else if   w-dup-vri-pre-ncd    =    "prz-ven"
                     move  w-rig-prz-ven (1)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "sgl-vpl"
                     move  w-rig-sgl-vpl (1)
                                          to   v-alf
      *
           else if   w-dup-vri-pre-ncd    =    "ccr-vpl"
                     move  w-rig-ccr-vpl (1)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "plm-vpl"
                     move  w-rig-plm-vpl (1)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "tlm-vpl"
                     move  w-rig-tlm-vpl (1)
                                          to   v-alf
      *
           else if   w-dup-vri-pre-ncd    =    "per-scr"
                     move  w-rig-per-scr
                    (1, w-dup-vri-pre-ctr)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "imp-rig"
                     move  w-rig-imp-rig (1)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "dcn-ric"
                     move  w-rig-dcn-ric (1)
                                          to   v-dat
      *
           else if   w-dup-vri-pre-ncd    =    "dcn-prv"
                     move  w-rig-dcn-prv (1)
                                          to   v-dat
      *
           else if   w-dup-vri-pre-ncd    =    "flg-cnf"
                     move  w-rig-flg-cnf (1)
                                          to   v-alf
      *
           else if   w-dup-vri-pre-ncd    =    "fsp-rig"
                     move  w-rig-fsp-rig (1)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "ppv-rig"
                     move  w-rig-ppv-rig
                    (1, w-dup-vri-pre-ctr)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "pvf-rig"
                     move  w-rig-pvf-rig (1)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "coi-rig"
                     move  w-rig-coi-rig (1)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "ctv-rig"
                     move  w-rig-ctv-rig (1)
                                          to   v-num
      *
           else      go to dup-vri-pre-150.
       dup-vri-pre-150.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       dup-vri-pre-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valore campo riga attuale da    *
      *              * area v                                          *
      *              *-------------------------------------------------*
           if        w-dup-vri-pre-ncd    =    "cod-aoc"
                     move  v-num          to   w-rig-tip-rig-cac (1)
      *
           else if   w-dup-vri-pre-ncd    =    "cod-pro"
                     move  v-alf          to   w-rig-alf-pro (1)
                     move  v-num          to   w-rig-num-pro (1)
      *
           else if   w-dup-vri-pre-ncd    =    "cop-scl"
                     move  v-alf          to   w-rig-cop-scl (1)
      *
           else if   w-dup-vri-pre-ncd    =    "des-rig"
                     move  v-txt          to   w-rig-des-rig (1)
      *
           else if   w-dup-vri-pre-ncd    =    "qta-ord"
                     move  v-num          to   w-rig-qta-ord (1)
      *
           else if   w-dup-vri-pre-ncd    =    "sgl-vpp"
                     move  v-alf          to   w-rig-sgl-vpp (1)
      *
           else if   w-dup-vri-pre-ncd    =    "prz-ven"
                     move  v-num          to   w-rig-prz-ven (1)
      *
           else if   w-dup-vri-pre-ncd    =    "sgl-vpl"
                     move  v-alf          to   w-rig-sgl-vpl (1)
      *
           else if   w-dup-vri-pre-ncd    =    "ccr-vpl"
                     move  v-num          to   w-rig-ccr-vpl (1)
      *
           else if   w-dup-vri-pre-ncd    =    "plm-vpl"
                     move  v-num          to   w-rig-plm-vpl (1)
      *
           else if   w-dup-vri-pre-ncd    =    "tlm-vpl"
                     move  v-alf          to   w-rig-tlm-vpl (1)
      *
           else if   w-dup-vri-pre-ncd    =    "per-scr"
                     move  v-num          to   w-rig-per-scr
                                              (1, w-dup-vri-pre-ctr)
      *
           else if   w-dup-vri-pre-ncd    =    "imp-rig"
                     move  v-num          to   w-rig-imp-rig (1)
      *
           else if   w-dup-vri-pre-ncd    =    "dcn-ric"
                     move  v-dat          to   w-rig-dcn-ric (1)
      *
           else if   w-dup-vri-pre-ncd    =    "dcn-prv"
                     move  v-dat          to   w-rig-dcn-prv (1)
      *
           else if   w-dup-vri-pre-ncd    =    "flg-cnf"
                     move  v-alf          to   w-rig-flg-cnf (1)
      *
           else if   w-dup-vri-pre-ncd    =    "fsp-rig"
                     move  v-num          to   w-rig-fsp-rig (1)
      *
           else if   w-dup-vri-pre-ncd    =    "ppv-rig"
                     move  v-num          to   w-rig-ppv-rig
                                              (1, w-dup-vri-pre-ctr)
      *
           else if   w-dup-vri-pre-ncd    =    "pvf-rig"
                     move  v-num          to   w-rig-pvf-rig (1)
      *
           else if   w-dup-vri-pre-ncd    =    "coi-rig"
                     move  v-num          to   w-rig-coi-rig (1)
      *
           else if   w-dup-vri-pre-ncd    =    "ctv-rig"
                     move  v-num          to   w-rig-ctv-rig (1)
      *
           else      go to dup-vri-pre-300.
       dup-vri-pre-300.
      *              *-------------------------------------------------*
      *              * Visualizzazione valore campo attuale            *
      *              *-------------------------------------------------*
           if        w-dup-vri-pre-ncd    =    "cod-aoc"
                     perform vis-cod-aoc-000
                                          thru vis-cod-aoc-999
      *
           else if   w-dup-vri-pre-ncd    =    "cod-pro"
                     perform vis-cod-pro-000
                                          thru vis-cod-pro-999
      *
           else if   w-dup-vri-pre-ncd    =    "cop-scl"
                     perform vis-cop-scl-000
                                          thru vis-cop-scl-999
      *
           else if   w-dup-vri-pre-ncd    =    "des-rig"
                     perform vis-des-rig-000
                                          thru vis-des-rig-999
      *
           else if   w-dup-vri-pre-ncd    =    "qta-ord"
                     perform vis-qta-ord-000
                                          thru vis-qta-ord-999
      *
           else if   w-dup-vri-pre-ncd    =    "sgl-vpp"
                     perform vis-sgl-vpp-000
                                          thru vis-sgl-vpp-999
      *
           else if   w-dup-vri-pre-ncd    =    "prz-ven"
                     perform vis-prz-ven-000
                                          thru vis-prz-ven-999
      *
           else if   w-dup-vri-pre-ncd    =    "sgl-vpl"
                     perform vis-sgl-vpl-000
                                          thru vis-sgl-vpl-999
      *
           else if   w-dup-vri-pre-ncd    =    "ccr-vpl"
                     perform vis-ccr-vpl-000
                                          thru vis-ccr-vpl-999
      *
           else if   w-dup-vri-pre-ncd    =    "plm-vpl"
                     perform vis-plm-vpl-000
                                          thru vis-plm-vpl-999
      *
           else if   w-dup-vri-pre-ncd    =    "tlm-vpl"
                     perform vis-tlm-vpl-000
                                          thru vis-tlm-vpl-999
      *
           else if   w-dup-vri-pre-ncd    =    "per-scr"
                     perform vis-per-scr-000
                                          thru vis-per-scr-999
                     move  w-rig-per-scr
                    (1, w-dup-vri-pre-ctr)
                                          to   v-num
      *
           else if   w-dup-vri-pre-ncd    =    "imp-rig"
                     perform vis-imp-rig-000
                                          thru vis-imp-rig-999
      *
           else if   w-dup-vri-pre-ncd    =    "dcn-ric"
                     perform vis-dcn-ric-000
                                          thru vis-dcn-ric-999
      *
           else if   w-dup-vri-pre-ncd    =    "dcn-prv"
                     perform vis-dcn-prv-000
                                          thru vis-dcn-prv-999
      *
           else if   w-dup-vri-pre-ncd    =    "flg-cnf"
                     perform vis-flg-cnf-000
                                          thru vis-flg-cnf-999
      *
           else if   w-dup-vri-pre-ncd    =    "fsp-rig"
                     perform vis-fsp-rig-000
                                          thru vis-fsp-rig-999
      *
           else if   w-dup-vri-pre-ncd    =    "ppv-rig"
                     perform vis-ppv-rig-000
                                          thru vis-ppv-rig-999
      *
           else if   w-dup-vri-pre-ncd    =    "pvf-rig"
                     perform vis-pvf-rig-000
                                          thru vis-pvf-rig-999
      *
           else if   w-dup-vri-pre-ncd    =    "coi-rig"
                     perform vis-coi-rig-000
                                          thru vis-coi-rig-999
      *
           else if   w-dup-vri-pre-ncd    =    "ctv-rig"
                     perform vis-ctv-rig-000
                                          thru vis-ctv-rig-999
      *
           else      go to dup-vri-pre-400.
       dup-vri-pre-400.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     dup-vri-pre-999.
       dup-vri-pre-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Presa visione per riga corpo *
      *    *-----------------------------------------------------------*
       acc-pre-vrc-000.
      *              *-------------------------------------------------*
      *              * Prompt per accettazione presa visione riga      *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      78                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      21                   to   v-lin                  .
           move      79                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-pre-vrc-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-pre-vrc-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-pre-vrc-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-pre-vrc-000.
       acc-pre-vrc-999.
           exit.

      *    *===========================================================*
      *    * Determinazione prezzo di vendita                          *
      *    *-----------------------------------------------------------*
       det-prz-ven-000.
      *              *-------------------------------------------------*
      *              * Preparazione parametri                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo operazione                             *
      *                  *---------------------------------------------*
           move      "PV"                 to   d-prz-ven-tip-ope      .
      *                  *---------------------------------------------*
      *                  * Codice Cliente                              *
      *                  *---------------------------------------------*
           if        w-tes-tip-frn (1)    =    11
                     move  w-tes-cod-arc (1)
                                          to   d-prz-ven-cod-cli
           else      move  w-tes-arc-plf (1)
                                          to   d-prz-ven-cod-cli      .
      *                  *---------------------------------------------*
      *                  * Valuta                                      *
      *                  *---------------------------------------------*
           move      w-rig-sgl-vpp (1)    to   d-prz-ven-sgl-vpp      .
           move      w-rig-dec-vpp (1)    to   d-prz-ven-dec-vpp      .
      *                  *---------------------------------------------*
      *                  * Codice numerico prodotto                    *
      *                  *---------------------------------------------*
           move      w-rig-num-pro (1)    to   d-prz-ven-num-pro      .
      *                  *---------------------------------------------*
      *                  * Codice listino                              *
      *                  *---------------------------------------------*
           move      w-tes-cod-lst (1)    to   d-prz-ven-cod-lst      .
      *                  *---------------------------------------------*
      *                  * Listino Base                                *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-plb    to   d-prz-ven-prz-lsb      .
           move      w-let-dcp-pdx-vlb    to   d-prz-ven-sgl-vlb      .
           move      w-let-dcp-pdx-dlb    to   d-prz-ven-dec-vlb      .
      *                  *---------------------------------------------*
      *                  * Tipo determinazione (da personalizzazioni)  *
      *                  *---------------------------------------------*
           move      spaces               to   d-prz-ven-tfu-prz      .
       det-prz-ven-200.
      *                  *---------------------------------------------*
      *                  * Data per la determinazione                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Data ordine o data documento            *
      *                      *-----------------------------------------*
           if        w-tes-ocl-dat (1)    not  = zero
                     move  w-tes-ocl-dat (1)
                                          to   d-prz-ven-dat-rfp
           else      move  w-tes-dat-doc  to   d-prz-ven-dat-rfp      .
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione relativa alla *
      *                      * data da considerare                     *
      *                      *-----------------------------------------*
           if        w-prs-cnt-dat-rif    not  = "P"
                     go to det-prz-ven-300.
           if        w-rig-dcn-prv (1)    not  = zero
                     move  w-rig-dcn-prv (1)
                                          to   d-prz-ven-dat-rfp      .
       det-prz-ven-300.
      *                  *---------------------------------------------*
      *                  * Quantita' di riferimento                    *
      *                  *---------------------------------------------*
           move      w-rig-qta-ord (1)    to   d-prz-ven-qta-rif      .
       det-prz-ven-500.
      *              *-------------------------------------------------*
      *              * Richiamo del sottoprogramma                     *
      *              *-------------------------------------------------*
           perform   det-prz-ven-cll-000  thru det-prz-ven-cll-999    .
      *              *-------------------------------------------------*
      *              * Memorizzazione valore determinato               *
      *              *-------------------------------------------------*
           move      d-prz-ven-prz-ven    to   w-rig-prz-ven (1)      .
       det-prz-ven-999.
           exit.


