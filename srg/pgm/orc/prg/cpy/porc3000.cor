      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale pre-cablaggio della riga          *
      *                  *---------------------------------------------*
           if        w-cnt-pcr-rec-flg    =    spaces
                     go to acc-tip-rig-025.
      *                  *---------------------------------------------*
      *                  * Subroutine di pre-cablaggio della riga      *
      *                  *---------------------------------------------*
           perform   acc-tip-rig-pcr-000  thru acc-tip-rig-pcr-999    .
      *                  *---------------------------------------------*
      *                  * Normalizzazione function-key                *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     acc-tip-rig-425.
       acc-tip-rig-025.
      *                  *---------------------------------------------*
      *                  * Eventuale preparazione del default          *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig (1)    not  = spaces
                     go to acc-tip-rig-050.
           if        w-tes-tmo-orc-dtr    not  = spaces
                     if    w-tes-tmo-orc-dtr
                                          =    "-----"
                           move  spaces   to   w-rig-tip-rig (1)
                           go to acc-tip-rig-050
                     else  move  w-tes-tmo-orc-dtr
                                          to   w-rig-tip-rig (1)
                           go to acc-tip-rig-050.
           move      "P"                  to   w-rig-tip-rig (1)      .
       acc-tip-rig-050.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-tip-rig (1)    to   w-sav-tip-rig          .
       acc-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino valore precedente                *
      *                  *---------------------------------------------*
           move      w-sav-tip-rig        to   w-rig-tip-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Parametri generici                          *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      21                   to   v-pos                  .
      *                  *---------------------------------------------*
      *                  * Tasti funzione                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Up   : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "UP  "               to   v-pfk (01)             .
      *                      *-----------------------------------------*
      *                      * Down : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "DOWN"         to   v-pfk (02)             .
      *                      *-----------------------------------------*
      *                      * Find : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "FIND"               to   v-pfk (03)             .
      *                      *-----------------------------------------*
      *                      * Insr : sempre ammesso, a meno che non   *
      *                      *        si sia in un record New oppure   *
      *                      *        manchi spazio per l'inserimento  *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces and
                     w-cat-rig-ins        =    spaces
                     move  "INSR"         to   v-pfk (04)             .
      *                      *-----------------------------------------*
      *                      * Do   : sempre ammesso, purche' sia con- *
      *                      *        cesso dallo status delle impo-   *
      *                      *        stazioni; eventualmente disat-   *
      *                      *        tivato dal richiamo della sub-   *
      *                      *        routine di accettazione          *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
      *                      *-----------------------------------------*
      *                      * Remv : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "REMV"               to   v-pfk (06)             .
      *                      *-----------------------------------------*
      *                      * Prsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "PRSC"               to   v-pfk (07)             .
      *                      *-----------------------------------------*
      *                      * Nxsc : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "NXSC"         to   v-pfk (08)             .
      *                      *-----------------------------------------*
      *                      * Back : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sulla prima riga     *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    not  = 1
                     move  "BACK"         to   v-pfk (09)             .
      *                      *-----------------------------------------*
      *                      * Tab  : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'ultima riga e   *
      *                      *        che questa sia in Append         *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces or
                     w-cat-rig-lst        =    spaces
                     move  "TAB "         to   v-pfk (10)             .
      *                      *-----------------------------------------*
      *                      * Slct : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'unica riga      *
      *                      *-----------------------------------------*
           if        w-cat-rig-max        not  = 1
                     move  "SLCT"         to   v-pfk (11)             .
      *                      *-----------------------------------------*
      *                      * Pf1  : ammesso solo se si e' sull'ulti- *
      *                      *        ma riga e che questa sia in Ap-  *
      *                      *        pend                             *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces and
                     w-cat-rig-lst        not  = spaces
                     move  "[1] "         to   v-pfk (14)             .
      *                      *-----------------------------------------*
      *                      * Pf2  : ammesso solo se si e' sull'ulti- *
      *                      *        ma riga e che questa sia in Ap-  *
      *                      *        pend e che sia attiva la perso-  *
      *                      *        nalizzazione per 'forecast'      *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces and
                     w-cat-rig-lst        not  = spaces
                     move  "[2] "         to   v-pfk (15)             .
           if        w-prs-snx-ocf        not  = "S"
                     move  spaces         to   v-pfk (15)             .
      *                      *-----------------------------------------*
      *                      * Pf3  : ammesso solo se si e' sull'ulti- *
      *                      *        ma riga e che questa sia in Ap-  *
      *                      *        pend                             *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces and
                     w-cat-rig-lst        not  = spaces
                     move  "[3] "         to   v-pfk (16)             .
      *                      *-----------------------------------------*
      *                      * Pf4  : ammesso solo se si e' su di un   *
      *                      *        record New, a meno che non si    *
      *                      *        sia sulla prima riga             *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces and
                     w-cnt-cor-nrg-dac    not  = 1
                     move  "[4] "         to   v-pfk (17)             .
      *                      *-----------------------------------------*
      *                      * Valore di accettazione                  *
      *                      *-----------------------------------------*
           move      w-rig-tip-rig (1)    to   v-alf                  .
       acc-tip-rig-200.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine di accettazione     *
      *                      *-----------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Return                                       *
      *              *-------------------------------------------------*
           if        v-key                =    spaces
                     go to acc-tip-rig-400.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-tip-rig-250.
      *                  *---------------------------------------------*
      *                  * Test se ricerca per prodotto                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga nuova : find su tipi riga       *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to acc-tip-rig-220.
           if        v-alf                =    spaces
                     go to acc-tip-rig-220.
           move      v-alf                to   w-ctl-tip-rig-tri      .
           perform   ctl-tip-rig-000      thru ctl-tip-rig-999        .
           if        w-ctl-tip-rig-flg    = spaces
                     go to acc-tip-rig-220.
      *                  *---------------------------------------------*
      *                  * Find su righe per codice prodotto           *
      *                  *---------------------------------------------*
           move      v-alf                to   w-fnd-mag-rig-alf      .
           move      w-cat-rig-cur        to   w-fnd-mag-rig-cur      .
           perform   fnd-mag-rig-000      thru fnd-mag-rig-999        .
           if        w-fnd-mag-rig-num    =    zero
                     go to acc-tip-rig-100.
           move      w-fnd-mag-rig-num    to   w-cnt-slc-rap-num      .
           go to     acc-tip-rig-320.
       acc-tip-rig-220.
      *                  *---------------------------------------------*
      *                  * Find su tipi riga                           *
      *                  *---------------------------------------------*
           perform   fnd-tip-rig-000      thru fnd-tip-rig-999        .
           if        w-fnd-tip-rig-sel    not  = spaces
                     go to acc-tip-rig-100.
           move      w-fnd-tip-rig-tri    to   w-rig-tip-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione tipo riga                   *
      *                  *---------------------------------------------*
           perform   vis-tip-rig-000      thru vis-tip-rig-999        .
           move      spaces               to   v-key                  .
           go to     acc-tip-rig-425.
       acc-tip-rig-250.
      *              *-------------------------------------------------*
      *              * Se Slct                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "SLCT"
                     go to acc-tip-rig-300
           else      go to acc-tip-rig-350.
       acc-tip-rig-300.
      *                  *---------------------------------------------*
      *                  * Conversione numero riga impostato in forma- *
      *                  * to numerico                                 *
      *                  *---------------------------------------------*
           move      v-alf                to   w-cnt-slc-rap-alf      .
           move      zero                 to   w-cnt-slc-rap-num      .
           move      6                    to   w-cnt-wrk-ctr-001      .
           move      5                    to   w-cnt-wrk-ctr-002      .
       acc-tip-rig-310.
           subtract  1                    from w-cnt-wrk-ctr-001      .
           if        w-cnt-wrk-ctr-001   =    zero
                     go to acc-tip-rig-320.
           if        w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   <    "0"   or
                     w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   >    "9"
                     go to acc-tip-rig-310.
           move      w-cnt-slc-rap-chr
                    (w-cnt-wrk-ctr-001)   to   w-cnt-slc-rap-cif
                                              (w-cnt-wrk-ctr-002)     .
           subtract  1                    from w-cnt-wrk-ctr-002      .
           go to     acc-tip-rig-310.
       acc-tip-rig-320.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato minore di 1 o mag- *
      *                  * maggiore del massimo : reimpostazione       *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    zero       or
                     w-cnt-slc-rap-num    >    w-cat-rig-max
                     go to acc-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Se numero riga impostato pari a numero riga *
      *                  * attuale : reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-cnt-slc-rap-num    =    w-cnt-cor-nrg-dac
                     go to acc-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Preparazione parametri e uscita             *
      *                  *---------------------------------------------*
           move      w-cnt-slc-rap-num    to   w-cnt-slc-num-rig      .
           move      "."                  to   w-cnt-tus-acc-rig      .
           go to     acc-tip-rig-999.
       acc-tip-rig-350.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se premuto un altro tasto funzione non deve es- *
      *              * sere avvenuta variazione del campo d'impostaz.  *
      *              *-------------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     move  "U"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Down                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DOWN"
                     move  "D"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-tip-rig-999
                     else    go to acc-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Se Insr                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "INSR"
                     move  "I"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "TAB "
                     move  "T"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Back                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "BACK"
                     move  "B"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Nxsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     move  "N"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Prsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "PRSC"
                     move  "P"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Pf1                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[1] "
                     move  "1"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Pf2                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[2] "
                     move  "2"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Pf3                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[3] "
                     move  "3"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "4"            to   w-cnt-tus-acc-rig
                     go to acc-tip-rig-999.
       acc-tip-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore in campo di destinazione             *
      *                  *---------------------------------------------*
           move      v-alf                to   w-rig-tip-rig (1)      .
       acc-tip-rig-425.
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controllo tipo riga impostato           *
      *                      *-----------------------------------------*
           move      w-rig-tip-rig (1)    to   w-ctl-tip-rig-tri      .
           perform   ctl-tip-rig-000      thru ctl-tip-rig-999        .
           if        w-ctl-tip-rig-flg    not  = spaces
                     go to acc-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Se impostazione a vuoto                     *
      *                  *    - se in Append : come Down purche' non   *
      *                  *                     ci siano zero righe     *
      *                  *    - altrimenti   : reimpostazione          *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     if    w-cat-rig-new  not  = spaces and
                           w-cat-rig-lst  not  = spaces and
                           w-cnt-sts-imp-cor
                                          not  = spaces
                           move  "D"      to   w-cnt-tus-acc-rig
                           go to acc-tip-rig-999
                     else  go to acc-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Se record non New non si ammette la modifi- *
      *                  * ca del valore                               *
      *                  *---------------------------------------------*
           if        w-cat-rig-new        =    spaces and
                     v-mod                not  = spaces
                     go to acc-tip-rig-100.
       acc-tip-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione tipo codice di magazzino     *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "P"
                     move  01             to   w-rig-tip-mag (1)
           else if   w-rig-tip-rig-tpr (1)
                                          =    "S"
                     move  02             to   w-rig-tip-mag (1)
           else if   w-rig-tip-rig-tpr (1)
                                          =    "M"
                     move  03             to   w-rig-tip-mag (1)
           else      move  zero           to   w-rig-tip-mag (1)      .
      *                  *---------------------------------------------*
      *                  * Eventuale forzatura codice iva              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Solo per tipo prodotto P                *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P"
                     go to acc-tip-rig-620.
      *                      *-----------------------------------------*
      *                      * Solo se riga 'New'                      *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to acc-tip-rig-620.
      *                      *-----------------------------------------*
      *                      * Solo se presente un titolo di esenzione *
      *                      * in testata                              *
      *                      *-----------------------------------------*
           if        w-tes-ass-iva (1)    =    zero or
                     w-tes-ass-iva-spl (1)
                                          =    "S"
                     go to acc-tip-rig-620.
      *                      *-----------------------------------------*
      *                      * Esecuzione                              *
      *                      *-----------------------------------------*
           move      w-tes-ass-iva (1)    to   w-rig-coi-rig (1)      .
           perform   vis-coi-rig-000      thru vis-coi-rig-999        .
           move      w-tes-ass-iva-des (1)
                                          to   w-rig-coi-rig-des (1)  .
           perform   vis-des-cir-000      thru vis-des-cir-999        .
       acc-tip-rig-620.
      *                  *---------------------------------------------*
      *                  * Eventuale forzatura contropartita vendite   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Solo per tipo prodotto P                *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P"
                     go to acc-tip-rig-700.
           if        w-tes-ctp-ven (1)    =    zero
                     go to acc-tip-rig-700.
           move      w-tes-ctp-ven (1)    to   w-rig-ctv-rig (1)      .
           perform   vis-ctv-rig-000      thru vis-ctv-rig-999        .
           move      w-tes-ctp-ven-des (1)
                                          to   w-rig-ctv-rig-des (1)  .
           perform   vis-des-cvr-000      thru vis-des-cvr-999        .
       acc-tip-rig-700.
      *                  *---------------------------------------------*
      *                  * Preparazione e visualizzazione eventuale    *
      *                  * default per data consegna richiesta         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Solo per tipo prodotto diverso da C     *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-tip-rig-720.
           if        w-rig-dcn-ric (1)    not  = zero
                     go to acc-tip-rig-720.
           move      w-tes-dat-cns (1)    to   w-rig-dcn-ric (1)      .
           perform   vis-dcn-ric-000      thru vis-dcn-ric-999        .
       acc-tip-rig-720.
      *                  *---------------------------------------------*
      *                  * Preparazione e visualizzazione eventuale    *
      *                  * default per data consegna prevista          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Solo per tipo prodotto diverso da C     *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-tip-rig-740.
           if        w-rig-dcn-prv (1)    not  = zero
                     go to acc-tip-rig-740.
           move      w-rig-dcn-ric (1)    to   w-rig-dcn-prv (1)      .
           perform   vis-dcn-prv-000      thru vis-dcn-prv-999        .
       acc-tip-rig-740.
      *                  *---------------------------------------------*
      *                  * Visualizzazione prompt per codice prodotto  *
      *                  *---------------------------------------------*
           perform   pmt-cod-pro-000      thru pmt-cod-pro-999        .
       acc-tip-rig-800.
       acc-tip-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Tipo riga                         *
      *    *-----------------------------------------------------------*
       vis-tip-rig-000.
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-tip-rig (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tip-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione primo campo riga corpo espansa : tipo riga   *
      *    *                                                           *
      *    * Subroutine di pre-cablaggio                               *
      *    *-----------------------------------------------------------*
       acc-tip-rig-pcr-000.
      *              *-------------------------------------------------*
      *              * Operazioni preliminari                          *
      *              *-------------------------------------------------*
       acc-tip-rig-pcr-100.
      *              *-------------------------------------------------*
      *              * Pre-cablaggio valori                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo riga                                   *
      *                  *---------------------------------------------*
           move      "PN   "              to   w-rig-tip-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Codice addebito o commento                  *
      *                  *---------------------------------------------*
           move      w-sav-rig-prc-add    to   w-rig-tip-rig-cac (1)  .
      *                  *---------------------------------------------*
      *                  * Codice prodotto                             *
      *                  *---------------------------------------------*
           move      w-sav-rig-prc-pro    to   w-rig-num-pro (1)      .
      *                  *---------------------------------------------*
      *                  * Descrizione riga                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura archivio [zac]                  *
      *                      *-----------------------------------------*
           move      01                   to   w-let-arc-zac-tip      .
           move      w-rig-tip-rig-cac (1)
                                          to   w-let-arc-zac-cod      .
           perform   let-arc-zac-000      thru let-arc-zac-999        .
           move      w-let-arc-zac-des    to   w-rig-des-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Quantita'                                   *
      *                  *---------------------------------------------*
           move      w-sav-rig-prc-qta    to   w-rig-qta-ord (1)      .
      *                  *---------------------------------------------*
      *                  * Prezzo unitario                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           move      "EC"                 to   d-prz-ven-tip-ope      .
           move      w-sav-rig-prc-pro    to   d-prz-ven-num-pro      .
      *                      *-----------------------------------------*
      *                      * Richiamo del sottoprogramma             *
      *                      *-----------------------------------------*
           perform   det-prz-ven-cll-000  thru det-prz-ven-cll-999    .
      *                      *-----------------------------------------*
      *                      * Memorizzazione valore determinato       *
      *                      *-----------------------------------------*
           move      d-prz-ven-prz-ven    to   w-rig-prz-ven (1)      .
           move      w-rig-prz-ven (1)    to   w-rig-prz-net (1)      .
      *                      *-----------------------------------------*
      *                      * Valuta per il prezzo                    *
      *                      *-----------------------------------------*
           move      c-sgl                to   w-rig-sgl-vpp (1)      .
           move      c-dec                to   w-rig-dec-vpp (1)      .
           move      c-tdc                to   w-rig-tdc-vpp (1)      .
           move      c-cdc                to   w-rig-cdc-vpp (1)      .
      *                  *---------------------------------------------*
      *                  * Determinazione importo in riga              *
      *                  *---------------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                  *---------------------------------------------*
      *                  * Codice Iva                                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se esiste un titolo di esenzione in te- *
      *                      * stata e il codice iva letto e' un impo- *
      *                      * nibile si forza il titolo di esenzione  *
      *                      * di testata, altrimento si forza il co-  *
      *                      * dice iva letto                          *
      *                      *-----------------------------------------*
           if        w-tes-ass-iva (1)    not  = zero and
                     w-let-arc-zac-civ    <    00100
                     move  w-tes-ass-iva (1)
                                          to   w-rig-coi-rig (1)
           else      move  w-let-arc-zac-civ
                                          to   w-rig-coi-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Lettura tabella [codiva]                *
      *                      *-----------------------------------------*
           move      w-rig-coi-rig (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
           move      w-let-arc-zci-des    to   w-rig-coi-rig-des (1)  .
      *                  *---------------------------------------------*
      *                  * Contropartita                               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura archivio [pdc]                  *
      *                      *-----------------------------------------*
           move      w-let-arc-zac-ccp    to   w-rig-ctv-rig (1)      .
           move      w-rig-ctv-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctv-rig-des (1)  .
      *                  *---------------------------------------------*
      *                  * No provvigioni                              *
      *                  *---------------------------------------------*
           move      02                   to   w-rig-fsp-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Eventuali parametri 'forecast'              *
      *                  *---------------------------------------------*
           move      w-sav-rig-prc-flf    to   w-rig-flg-frc (1)      .
           move      w-sav-rig-prc-ptf    to   w-rig-prt-frc (1)      .
           move      w-sav-rig-prc-prf    to   w-rig-prg-frc (1)      .
       acc-tip-rig-pcr-400.
      *              *-------------------------------------------------*
      *              * Visualizzazione valori pre-cablati              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo riga                                   *
      *                  *---------------------------------------------*
           perform   vis-tip-rig-000      thru vis-tip-rig-999        .
      *                  *---------------------------------------------*
      *                  * Codice addebito o commento                  *
      *                  *---------------------------------------------*
           perform   vis-cod-aoc-000      thru vis-cod-aoc-999        .
      *                  *---------------------------------------------*
      *                  * Descrizione riga                            *
      *                  *---------------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
      *                  *---------------------------------------------*
      *                  * Quantita' ordinata                          *
      *                  *---------------------------------------------*
           perform   vis-qta-ord-000      thru vis-qta-ord-999        .
      *                  *---------------------------------------------*
      *                  * Prezzo di vendita                           *
      *                  *---------------------------------------------*
           perform   vis-prz-ven-000      thru vis-prz-ven-999        .
      *                  *---------------------------------------------*
      *                  * Importo in riga                             *
      *                  *---------------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
      *                  *---------------------------------------------*
      *                  * Codice Iva                                  *
      *                  *---------------------------------------------*
           perform   vis-coi-rig-000      thru vis-coi-rig-999        .
           perform   vis-des-cir-000      thru vis-des-cir-999        .
      *                  *---------------------------------------------*
      *                  * Contropartita                               *
      *                  *---------------------------------------------*
           perform   vis-ctv-rig-000      thru vis-ctv-rig-999        .
           perform   vis-des-cvr-000      thru vis-des-cvr-999        .
       acc-tip-rig-pcr-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
       acc-tip-rig-pcr-999.
           exit.

      *    *===========================================================*
      *    * Ricerca riga da codice di magazzino                       *
      *    *-----------------------------------------------------------*
       fnd-mag-rig-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore di uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-fnd-mag-rig-num      .
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      w-fnd-mag-rig-cur    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       fnd-mag-rig-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to fnd-mag-rig-900.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to fnd-mag-rig-100.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to fnd-mag-rig-100.
       fnd-mag-rig-200.
      *              *-------------------------------------------------*
      *              * Confronto con il numero riga in corso di trat-  *
      *              * tamento                                         *
      *              *-------------------------------------------------*
           if        w-fnd-mag-rig-cur    =    w-cat-rig-cur
                     go to fnd-mag-rig-100.
      *              *-------------------------------------------------*
      *              * Confronto con il codice alfanumerico contenuto  *
      *              * nella riga                                      *
      *              *-------------------------------------------------*
           if        w-fnd-mag-rig-alf    not  = w-rig-alf-pro (1)
                     go to fnd-mag-rig-100.
      *              *-------------------------------------------------*
      *              * Riga trovata in campo di comodo                 *
      *              *-------------------------------------------------*
           move      w-cat-rig-cur        to   w-fnd-mag-rig-num      .
       fnd-mag-rig-900.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       fnd-mag-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice addebito o commen- *
      *    *                                 to                        *
      *    *-----------------------------------------------------------*
       acc-cod-aoc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale cablaggio della riga              *
      *                  *---------------------------------------------*
           if        w-cnt-pcr-rec-flg    =    spaces
                     go to acc-cod-aoc-025
           else      go to acc-cod-aoc-999.
       acc-cod-aoc-025.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "C" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "A"
                     go to acc-cod-aoc-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-tip-rig-cac (1)
                                          to   w-sav-cod-aoc          .
       acc-cod-aoc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zac-ope      .
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     move  01             to   w-cod-mne-zac-tip
           else      move  02             to   w-cod-mne-zac-tip      .
           move      w-rig-tip-rig-cac (1)
                                          to   w-cod-mne-zac-cod      .
           move      14                   to   w-cod-mne-zac-lin      .
           move      21                   to   w-cod-mne-zac-pos      .
           move      16                   to   w-cod-mne-zac-dln      .
           move      21                   to   w-cod-mne-zac-dps      .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "<B"                 to   v-edm                  .
           perform   cod-mne-zac-cll-000  thru cod-mne-zac-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zac-foi-000  thru cod-mne-zac-foi-999    .
       acc-cod-aoc-110.
           perform   cod-mne-zac-cll-000  thru cod-mne-zac-cll-999    .
           if        w-cod-mne-zac-ope    =    "F+"
                     go to acc-cod-aoc-115.
           if        w-cod-mne-zac-ope    =    "AC"
                     go to acc-cod-aoc-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-aoc-115.
           perform   cod-mne-zac-foi-000  thru cod-mne-zac-foi-999    .
           go to     acc-cod-aoc-110.
       acc-cod-aoc-120.
           move      w-cod-mne-zac-cod    to   v-num                  .
       acc-cod-aoc-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cod-aoc-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cod-aoc-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-tip-rig-cac (1)  .
       acc-cod-aoc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [zac]                      *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     move  01             to   w-let-arc-zac-tip
           else      move  02             to   w-let-arc-zac-tip      .
           move      w-rig-tip-rig-cac (1)
                                          to   w-let-arc-zac-cod      .
           perform   let-arc-zac-000      thru let-arc-zac-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato                            *
      *                  *---------------------------------------------*
           if        w-let-arc-zac-flg    =    spaces
                     go to acc-cod-aoc-600.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     move  "Codice commento non esistente !             
      -              "               "    to   w-err-box-err-msg
           else      move  "Codice addebito non esistente !             
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-aoc-100.
       acc-cod-aoc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-cac (1)
                                          =    w-sav-cod-aoc
                     go to acc-cod-aoc-800.
       acc-cod-aoc-610.
      *                  *---------------------------------------------*
      *                  * Descrizione addebito o commento             *
      *                  *---------------------------------------------*
           move      w-let-arc-zac-des    to   w-rig-des-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione             *
      *                      *-----------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
       acc-cod-aoc-620.
      *                  *---------------------------------------------*
      *                  * Se tipo riga 'C' : oltre                    *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-cod-aoc-800.
       acc-cod-aoc-630.
      *                  *---------------------------------------------*
      *                  * Flag di significativita' provvigioni in ri- *
      *                  * ga : No provvigioni                         *
      *                  *---------------------------------------------*
           if        w-rig-fsp-rig (1)    =    zero
                     move  02             to   w-rig-fsp-rig (1)
                     perform vis-fsp-rig-000
                                          thru vis-fsp-rig-999        .
       acc-cod-aoc-640.
      *                  *---------------------------------------------*
      *                  * Codice iva                                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Solo se riga 'New'                      *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to acc-cod-aoc-650.
      *                      *-----------------------------------------*
      *                      * Se esiste un titolo di esenzione in te- *
      *                      * stata e il codice iva letto e' un impo- *
      *                      * nibile si forza il titolo di esenzione  *
      *                      * di testata, altrimento si forza il co-  *
      *                      * dice iva letto                          *
      *                      *-----------------------------------------*
           if        w-tes-ass-iva (1)    not  = zero and
                     w-let-arc-zac-civ    <    00100
                     move  w-tes-ass-iva (1)
                                          to   w-rig-coi-rig (1)
           else      move  w-let-arc-zac-civ
                                          to   w-rig-coi-rig (1)      .
      *
           if        w-tes-ass-iva-spl (1)
                                          =    "S"
                     move  w-let-arc-zac-civ
                                          to   w-rig-coi-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Lettura tabella [codiva]                *
      *                      *-----------------------------------------*
           move      w-rig-coi-rig (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
           move      w-let-arc-zci-des    to   w-rig-coi-rig-des (1)  .
      *                      *-----------------------------------------*
      *                      * Visualizzazione codice e descrizione i- *
      *                      * va                                      *
      *                      *-----------------------------------------*
           perform   vis-coi-rig-000      thru vis-coi-rig-999        .
           perform   vis-des-cir-000      thru vis-des-cir-999        .
       acc-cod-aoc-650.
      *                  *---------------------------------------------*
      *                  * Contropartita vendite in  riga              *
      *                  *---------------------------------------------*
           move      w-let-arc-zac-ccp    to   w-rig-ctv-rig (1)      .
           perform   vis-ctv-rig-000      thru vis-ctv-rig-999        .
           move      w-rig-ctv-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctv-rig-des (1)  .
           perform   vis-des-cvr-000      thru vis-des-cvr-999        .
       acc-cod-aoc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cod-aoc-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-cod-aoc-100.
       acc-cod-aoc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo riga corpo : Codice addebito o com- *
      *    *                                    mento                  *
      *    *-----------------------------------------------------------*
       vis-cod-aoc-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "C" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "A"
                     go to vis-cod-aoc-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      14                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-tip-rig-cac (1)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-aoc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice prodotto           *
      *    *-----------------------------------------------------------*
       acc-cod-pro-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo riga                       *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-cod-pro-999.
      *                      *-----------------------------------------*
      *                      * Test se riga 'new'                      *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to acc-cod-pro-999.
       acc-cod-pro-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo magazzino   *
      *                  * indicato nel tipo riga                      *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "P"
                     perform   acc-cod-dcp-000
                                          thru acc-cod-dcp-999        .
       acc-cod-pro-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice prodotto                   *
      *    *-----------------------------------------------------------*
       vis-cod-pro-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to vis-cod-pro-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-alf-pro (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-pro-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice prodotto per il cliente       *
      *    *-----------------------------------------------------------*
       acc-cop-scl-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se lo prevedono le personalizzazioni   *
      *                  *---------------------------------------------*
           if        w-prs-snx-cop-scl    not  = "S"
                     go to acc-cop-scl-999.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-cop-scl-999.
       acc-cop-scl-100.
      *              *-------------------------------------------------*
      *              * Prompt                                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      63                   to   v-pos                  .
           move      "[C]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      67                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-cop-scl (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cop-scl-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cop-scl-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "cop-scl"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-cop-scl (1)      .
       acc-cop-scl-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test che non ci siano blanks embedded       *
      *                  *---------------------------------------------*
           move      w-rig-cop-scl (1)    to   w-all-str-alf          .
           move      14                   to   w-all-str-lun          .
           perform   all-str-ble-000      thru all-str-ble-999        .
           if        w-all-str-flg        not  = spaces
                     go to acc-cop-scl-100.
       acc-cop-scl-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Prompt                                      *
      *                  *---------------------------------------------*
           perform   pmt-cop-scl-000      thru pmt-cop-scl-999        .
       acc-cop-scl-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cop-scl-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-cop-scl-100.
       acc-cop-scl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice prodotto secondo il clien- *
      *    * te                                                        *
      *    *-----------------------------------------------------------*
       vis-cop-scl-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to vis-cop-scl-999.
           if        w-rig-cop-scl (1)    =    spaces
                     go to vis-cop-scl-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Prompt                                      *
      *                  *---------------------------------------------*
           perform   pmt-cop-scl-000      thru pmt-cop-scl-999        .
      *                  *---------------------------------------------*
      *                  * Valore                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      67                   to   v-pos                  .
           move      w-rig-cop-scl (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cop-scl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice prodotto [dcp]     *
      *    *-----------------------------------------------------------*
       acc-cod-dcp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore numerico precedente      *
      *                  *---------------------------------------------*
           move      w-rig-num-pro (1)    to   w-sav-num-pro          .
       acc-cod-dcp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-dcp-ope      .
           move      "A"                  to   w-cod-cod-dcp-tac      .
           move      w-rig-num-pro (1)    to   w-cod-cod-dcp-num      .
           move      w-rig-alf-pro (1)    to   w-cod-cod-dcp-alf      .
           move      14                   to   w-cod-cod-dcp-lin      .
           move      21                   to   w-cod-cod-dcp-pos      .
           move      14                   to   w-cod-cod-dcp-dln      .
           move      36                   to   w-cod-cod-dcp-dps      .
           move      spaces               to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           perform   cod-cod-dcp-cll-000  thru cod-cod-dcp-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-dcp-foi-000  thru cod-cod-dcp-foi-999    .
       acc-cod-dcp-110.
           perform   cod-cod-dcp-cll-000  thru cod-cod-dcp-cll-999    .
           if        w-cod-cod-dcp-ope    =    "F+"
                     go to acc-cod-dcp-115.
           if        w-cod-cod-dcp-ope    =    "AC"
                     go to acc-cod-dcp-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-dcp-115.
           perform   cod-cod-dcp-foi-000  thru cod-cod-dcp-foi-999    .
           go to     acc-cod-dcp-110.
       acc-cod-dcp-120.
           move      w-cod-cod-dcp-alf    to   v-alf                  .
           move      w-cod-cod-dcp-num    to   v-num                  .
       acc-cod-dcp-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dcp-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-cod-dcp-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "cod-pro"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-alf-pro (1)      .
           move      v-num                to   w-rig-num-pro (1)      .
       acc-cod-dcp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dcp]                      *
      *                  *---------------------------------------------*
           move      w-rig-num-pro (1)    to   w-let-dcp-pdx-cod      .
           move      w-tes-tip-arc (1)    to   w-let-dcp-pdx-tar      .
           if        w-tes-tip-frn (1)    =    11
                     move  w-tes-cod-arc (1)
                                          to   w-let-dcp-pdx-arc
           else      move  w-tes-arc-plf (1)
                                          to   w-let-dcp-pdx-arc      .
           move      w-tes-cod-lng (1)    to   w-let-dcp-pdx-lng      .
           perform   let-dcp-pdx-000      thru let-dcp-pdx-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-dcp-pdx-flg    not  = spaces
                     go to acc-cod-dcp-100.
      *                  *---------------------------------------------*
      *                  * Se codice a zero : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-rig-num-pro (1)    =    zero
                     go to acc-cod-dcp-100.
       acc-cod-dcp-450.
      *                  *---------------------------------------------*
      *                  * Test su status commerciale del prodotto     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se la personalizzazione lo esige   *
      *                      *-----------------------------------------*
           if        w-prs-ttd-sts-dcp    =    "N"
                     go to acc-cod-dcp-600.
      *                      *-----------------------------------------*
      *                      * Se status normale : ad uscita           *
      *                      *-----------------------------------------*
           if        w-let-dcp-pdx-tus    =    01
                     go to acc-cod-dcp-600.
      *                      *-----------------------------------------*
      *                      * Se status non normale : box specifico   *
      *                      * per lo status commerciale               *
      *                      *-----------------------------------------*
           perform   acc-cod-dcp-bsp-000  thru acc-cod-dcp-bsp-999    .
      *                      *-----------------------------------------*
      *                      * Tipo di uscita a seconda della persona- *
      *                      * lizzazione                              *
      *                      *-----------------------------------------*
           if        w-prs-ttd-sts-dcp    =    "B"
                     go to acc-cod-dcp-100
           else      go to acc-cod-dcp-600.
       acc-cod-dcp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-num-pro (1)    =    w-sav-num-pro
                     go to acc-cod-dcp-800.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione dati                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Subroutine                              *
      *                      *-----------------------------------------*
           perform   acc-cod-dcp-buf-000  thru acc-cod-dcp-buf-999    .
      *                      *-----------------------------------------*
      *                      * Test sul flag di uscita                 *
      *                      *-----------------------------------------*
           if        w-acc-cod-pro-flg    not  = spaces
                     go to acc-cod-dcp-100.
       acc-cod-dcp-780.
      *              *-------------------------------------------------*
      *              * Visualizzazione note in righe documento         *
      *              *-------------------------------------------------*
           move      "NT"                 to   w-vis-not-rgd-top      .
           perform   vis-not-rgd-000      thru vis-not-rgd-999        .
       acc-cod-dcp-790.
      *              *-------------------------------------------------*
      *              * Eventuale indicazione per 'forecast'            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su personalizzazione                   *
      *                  *---------------------------------------------*
           if        w-prs-snx-ocf        not  = "S"
                     go to acc-cod-dcp-800.
      *                  *---------------------------------------------*
      *                  * Test su tipo ordine                         *
      *                  *---------------------------------------------*
           if        w-tes-tmo-orc-tip    =    "F"
                     go to acc-cod-dcp-800.
      *                  *---------------------------------------------*
      *                  * Subroutine                                  *
      *                  *---------------------------------------------*
           perform   acc-cod-dcp-frc-000  thru acc-cod-dcp-frc-999    .
      *                  *---------------------------------------------*
      *                  * Test su flag di uscita                      *
      *                  *---------------------------------------------*
           if        w-det-ord-frc-flg    =    spaces
                     go to acc-cod-dcp-800.
      *                  *---------------------------------------------*
      *                  * Editing numero progressivo del numero docu- *
      *                  * mento letto                                 *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      "<B"                 to   v-edm                  .
           move      w-det-ord-frc-doc    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Messaggio di avviso                         *
      *                  *---------------------------------------------*
           move      spaces               to   w-err-box-err-msg      .
           string    "Prodotto con ordini 'forecast' inevasi ! ("
                                delimited by   size
                     w-det-ord-frc-tip
                                delimited by   spaces
                     " "        delimited by   size
                     v-edt      delimited by   spaces
                     ")"        delimited by   size
                                          into w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     acc-cod-dcp-800.
       acc-cod-dcp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-cod-dcp-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-cod-dcp-100.
       acc-cod-dcp-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice prodotto [dcp]     *
      *    *                                                           *
      *    * Bufferizzazione valori associati al record [dcp]          *
      *    *-----------------------------------------------------------*
       acc-cod-dcp-buf-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di reimpostazione          *
      *              *-------------------------------------------------*
           move      spaces               to   w-acc-cod-pro-flg      .
       acc-cod-dcp-buf-010.
      *              *-------------------------------------------------*
      *              * Se prodotto similare : oltre                    *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dcp-buf-100.
       acc-cod-dcp-buf-025.
      *              *-------------------------------------------------*
      *              * Categorie sconto e provvigioni                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Categoria di sconto in riga associata al    *
      *                  * prodotto                                    *
      *                  *---------------------------------------------*
           move      rf-dcp-cat-scr       to   w-rig-csr-aap (1)      .
      *                  *---------------------------------------------*
      *                  * Percentuali di sconto in riga associate al  *
      *                  * prodotto                                    *
      *                  *---------------------------------------------*
           move      rf-dcp-per-scr (1)   to   w-rig-psr-aap (1, 1)   .
           move      rf-dcp-per-scr (2)   to   w-rig-psr-aap (1, 2)   .
           move      rf-dcp-per-scr (3)   to   w-rig-psr-aap (1, 3)   .
           move      rf-dcp-per-scr (4)   to   w-rig-psr-aap (1, 4)   .
           move      rf-dcp-per-scr (5)   to   w-rig-psr-aap (1, 5)   .
      *                  *---------------------------------------------*
      *                  * Categoria di provvigione associata al pro-  *
      *                  * dotto                                       *
      *                  *---------------------------------------------*
           move      rf-dcp-cat-pvg       to   w-rig-cpv-aap (1)      .
      *                  *---------------------------------------------*
      *                  * Percentuali di provvigione associate al     *
      *                  * prodotto                                    *
      *                  *---------------------------------------------*
           move      rf-dcp-per-pvg (1)   to   w-rig-ppv-aap (1, 1)   .
           move      rf-dcp-per-pvg (2)   to   w-rig-ppv-aap (1, 2)   .
           move      rf-dcp-per-pvg (3)   to   w-rig-ppv-aap (1, 3)   .
       acc-cod-dcp-buf-050.
      *              *-------------------------------------------------*
      *              * Descrizione prodotto                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Bufferizzazione descrizione prodotto ad uso *
      *                  * interno                                     *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-dui    to   w-rig-des-int (1)      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione descrizione prodotto origi- *
      *                  * nale                                        *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-des    to   w-rig-des-por (1)      .
      *                  *---------------------------------------------*
      *                  * Memorizzazione nuova descrizione            *
      *                  *---------------------------------------------*
           move      w-rig-des-por (1)    to   w-rig-des-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione prodotto        *
      *                  *---------------------------------------------*
           perform   vis-des-rig-000      thru vis-des-rig-999        .
       acc-cod-dcp-buf-075.
      *              *-------------------------------------------------*
      *              * Codice prodotto secondo il cliente              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Memorizzazione                              *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-cpc    to   w-rig-cop-scl (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           perform   vis-cop-scl-000      thru vis-cop-scl-999        .
       acc-cod-dcp-buf-100.
      *              *-------------------------------------------------*
      *              * Tipo prodotto                                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Memorizzazione                              *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-tpr    to   w-rig-tip-pro (1)      .
       acc-cod-dcp-buf-125.
      *              *-------------------------------------------------*
      *              * Unita' di misura                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Memorizzazione                              *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-umi    to   w-rig-umi-ven (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           perform   vis-umi-ven-000      thru vis-umi-ven-999        .
       acc-cod-dcp-buf-150.
      *              *-------------------------------------------------*
      *              * Tipo esposizione riga in fattura                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Memorizzazione                              *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-epz    to   w-rig-epz-rgf (1)      .
       acc-cod-dcp-buf-200.
      *              *-------------------------------------------------*
      *              * Se prodotto similare : oltre                    *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dcp-buf-300.
       acc-cod-dcp-buf-225.
      *              *-------------------------------------------------*
      *              * Confezione                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Memorizzazione                              *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-tcf    to   w-rig-tip-cfz (1)      .
           move      w-let-dcp-pdx-qcf    to   w-rig-qta-cfz (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           perform   vis-qta-cfz-000      thru vis-qta-cfz-999        .
       acc-cod-dcp-buf-250.
      *              *-------------------------------------------------*
      *              * Lotto di vendita                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Memorizzazione                              *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-ldv    to   w-rig-lot-ven (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           perform   vis-lot-ven-000      thru vis-lot-ven-999        .
       acc-cod-dcp-buf-275.
      *              *-------------------------------------------------*
      *              * Addebito legato al prodotto                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Memorizzazione                              *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-add    to   w-rig-add-pro (1)      .
       acc-cod-dcp-buf-300.
      *              *-------------------------------------------------*
      *              * Decimali quantita'                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Memorizzazione                              *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-deq    to   w-rig-dec-qta (1)      .
       acc-cod-dcp-buf-325.
      *              *-------------------------------------------------*
      *              * Decimali prezzo                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Memorizzazione                              *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-dep    to   w-rig-dec-prz (1)      .
       acc-cod-dcp-buf-350.
      *              *-------------------------------------------------*
      *              * Sigla valuta per il prezzo di vendita           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Memorizzazione                              *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-rig-sgl-vpp (1)      .
           move      w-tes-dec-vpf (1)    to   w-rig-dec-vpp (1)      .
           move      w-tes-tdc-vpf (1)    to   w-rig-tdc-vpp (1)      .
           move      w-tes-cdc-vpf (1)    to   w-rig-cdc-vpp (1)      .
           perform   vis-sgl-vpp-000      thru vis-sgl-vpp-999        .
       acc-cod-dcp-buf-375.
      *              *-------------------------------------------------*
      *              * Se prodotto similare : oltre                    *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dcp-buf-600.
       acc-cod-dcp-buf-400.
      *              *-------------------------------------------------*
      *              * Prezzo di vendita                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           perform   det-prz-ven-000      thru det-prz-ven-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           perform   vis-prz-ven-000      thru vis-prz-ven-999        .
       acc-cod-dcp-buf-425.
      *              *-------------------------------------------------*
      *              * Sigla valuta per i prezzi standard              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Memorizzazione                              *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-rig-sgl-vps (1)      .
           move      w-tes-dec-vpf (1)    to   w-rig-dec-vps (1)      .
           move      w-tes-tdc-vpf (1)    to   w-rig-tdc-vps (1)      .
           move      w-tes-cdc-vpf (1)    to   w-rig-cdc-vps (1)      .
       acc-cod-dcp-buf-450.
      *              *-------------------------------------------------*
      *              * Prezzo lordo standard                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           move      w-rig-prz-ven (1)    to   w-rig-prz-lrs (1)      .
      *                  *---------------------------------------------*
      *                  * Eventuale controllo di esistenza            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da eseguire                     *
      *                      *-----------------------------------------*
           if        w-prs-cnt-prz-lrs    =    "N"
                     go to acc-cod-dcp-buf-500.
      *                      *-----------------------------------------*
      *                      * Test se da listino base                 *
      *                      *-----------------------------------------*
           if        w-prs-cnt-prz-lsu    =    "B"
                     move  d-prz-ven-prz-bas
                                          to   w-rig-prz-lrs (1)
                     go to acc-cod-dcp-buf-500.
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-rig-prz-lrs (1)    not  = zero
                     go to acc-cod-dcp-buf-500.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Prezzo di listino non esistente !                 
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione o continuazione a      *
      *                      * seconda della personalizzazione         *
      *                      *-----------------------------------------*
           if        w-prs-cnt-prz-lrs    =    "S"
                     move  "#"            to   w-acc-cod-pro-flg
                     go to acc-cod-dcp-buf-900.
       acc-cod-dcp-buf-500.
      *              *-------------------------------------------------*
      *              * Sconti in riga                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           perform   det-psr-rig-000      thru det-psr-rig-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione                              *
      *                  *---------------------------------------------*
           move      d-per-scr-per-scr (1)
                                          to   w-rig-per-scr (1, 1)   .
           move      d-per-scr-per-scr (2)
                                          to   w-rig-per-scr (1, 2)   .
           move      d-per-scr-per-scr (3)
                                          to   w-rig-per-scr (1, 3)   .
           move      d-per-scr-per-scr (4)
                                          to   w-rig-per-scr (1, 4)   .
           move      d-per-scr-per-scr (5)
                                          to   w-rig-per-scr (1, 5)   .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           perform   vis-per-scr-000      thru vis-per-scr-999        .
       acc-cod-dcp-buf-550.
      *              *-------------------------------------------------*
      *              * Prezzo netto standard                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           move      w-rig-prz-lrs (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-nts (1)      .
       acc-cod-dcp-buf-600.
      *              *-------------------------------------------------*
      *              * Prezzo netto                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           move      w-rig-prz-ven (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
       acc-cod-dcp-buf-625.
      *              *-------------------------------------------------*
      *              * Tipo esposizione prezzi e sconti                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           move      w-tes-epz-pes (1)    to   w-rig-epz-pes (1)      .
       acc-cod-dcp-buf-650.
      *              *-------------------------------------------------*
      *              * Costo di riferimento                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se prodotto similare : oltre                *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to acc-cod-dcp-buf-675.
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           perform   det-cos-rif-000      thru det-cos-rif-999        .
      *                  *---------------------------------------------*
      *                  * Test su flag di uscita                      *
      *                  *---------------------------------------------*
           if        w-det-cos-rif-flg    not  = spaces
                     move  "#"            to   w-acc-cod-pro-flg
                     go to acc-cod-dcp-buf-900.
       acc-cod-dcp-buf-675.
      *              *-------------------------------------------------*
      *              * Provvigioni in riga                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da trattare                         *
      *                  *---------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-cod-dcp-buf-700.
      *                  *---------------------------------------------*
      *                  * Se flag significativita' provvigioni        *
      *                  * per il documento indica 'No' o 'A forfait': *
      *                  * no provvigioni in riga                      *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    =    02 or
                     w-tes-fsp-doc (1)    =    03
                     move  02             to   w-rig-fsp-rig (1)
                     go to acc-cod-dcp-buf-685.
      *                  *---------------------------------------------*
      *                  * Se flag significativita' provvigioni per il *
      *                  * documento indica 'A forfait' in  % :        *
      *                  * forzatura provvigioni in riga               *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    =    04
                     move   03            to   w-rig-fsp-rig (1)
                     divide 100           into w-tes-pvf-age (1)
                                        giving w-rig-ppv-rig (1, 1)
                     go to acc-cod-dcp-buf-685.
      *                  *---------------------------------------------*
      *                  * Se prodotto similare : No provvigioni       *
      *                  * in riga                                     *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     move  02             to   w-rig-fsp-rig (1)
                     go to acc-cod-dcp-buf-685.
      *                  *---------------------------------------------*
      *                  * Default per provvigioni in riga : Si        *
      *                  *---------------------------------------------*
           move      01                   to   w-rig-fsp-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           perform   det-ppv-rig-000      thru det-ppv-rig-999        .
       acc-cod-dcp-buf-685.
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           perform   vis-fsp-rig-000      thru vis-fsp-rig-999        .
           perform   vis-ppv-rig-000      thru vis-ppv-rig-999        .
       acc-cod-dcp-buf-700.
      *              *-------------------------------------------------*
      *              * Codice iva                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-tes-ass-iva-spl (1)
                                          =    "S"
                     go to acc-cod-dcp-buf-710.
           if        w-tes-ass-iva (1)    not  = zero
                     go to acc-cod-dcp-buf-725.
       acc-cod-dcp-buf-710.
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-coi    to   w-rig-coi-rig (1)      .
           perform   vis-coi-rig-000      thru vis-coi-rig-999        .
           move      w-rig-coi-rig (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
           move      w-let-arc-zci-des    to   w-rig-coi-rig-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           perform   vis-des-cir-000      thru vis-des-cir-999        .
       acc-cod-dcp-buf-725.
      *              *-------------------------------------------------*
      *              * Contropartita vendite in  riga                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        w-tes-ctp-ven (1)    not  = zero
                     go to acc-cod-dcp-buf-750.
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-ctp    to   w-rig-ctv-rig (1)      .
           perform   vis-ctv-rig-000      thru vis-ctv-rig-999        .
           move      w-rig-ctv-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctv-rig-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           perform   vis-des-cvr-000      thru vis-des-cvr-999        .
       acc-cod-dcp-buf-750.
      *              *-------------------------------------------------*
      *              * Disponibilita'                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da trattare                         *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P"
                     go to acc-cod-dcp-buf-800.
           if        w-rig-tip-rig-tfu (1)
                                          not  = spaces
                     go to acc-cod-dcp-buf-800.
           if        w-prs-tvn-rgd        not  = 11
                     go to acc-cod-dcp-buf-800.
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *                                             *
      *                  * Attualmente si forza la Sede mentre la      *
      *                  * logica prevederebbe di determinare la       *
      *                  * disponibilita' della dipendenza             *
      *                  *---------------------------------------------*
           move      "DT"                 to   d-buf-fod-tip-ope      .
           move      w-def-dat-att        to   d-buf-fod-dat-ela      .
      *
           if        w-tes-tmo-orc-tar    =    "D"
                     move  w-tes-cod-arc (1)
                                          to   d-buf-fod-cod-dpz
           else      move  w-tes-cod-dpz  to   d-buf-fod-cod-dpz      .
      *
           move      w-tes-cod-dpz        to   d-buf-fod-cod-dpz      .
      *
           move      01                   to   d-buf-fod-tip-mag      .
           move      w-rig-num-pro (1)    to   d-buf-fod-num-mag      .
           move      01                   to   d-buf-fod-tip-crg      .
           move      01                   to   d-buf-fod-snx-oav      .
           perform   det-buf-fod-cll-000  thru det-buf-fod-cll-999    .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione disponibilita'              *
      *                  *---------------------------------------------*
           move      d-buf-fod-qtt-fod    to   w-rig-qta-dsp (1)      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione quantita' in ordine a for-  *
      *                  * nitori                                      *
      *                  *---------------------------------------------*
           move      d-buf-fod-qta-oaf    to   w-rig-qta-orf (1)      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione orizzonte temporale         *
      *                  *---------------------------------------------*
           move      d-buf-fod-dot-eff    to   w-rig-dcn-orf (1)      .
       acc-cod-dcp-buf-760.
      *              *-------------------------------------------------*
      *              * Determinazione ordinato dipendenza              *
      *              *                                                 *
      *              * Solo se dipendenza e ordine pro-forma           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se dipendenza                          *
      *                  *---------------------------------------------*
           if        w-tes-cod-dpz        =    01
                     go to acc-cod-dcp-buf-800.
           if        w-tes-tip-ord (1)    not  = "P"
                     go to acc-cod-dcp-buf-800.
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           move      "DO"                 to   d-buf-fod-tip-ope      .
           move      w-def-dat-att        to   d-buf-fod-dat-ela      .
           move      01                   to   d-buf-fod-tip-mag      .
           move      w-rig-num-pro (1)    to   d-buf-fod-num-mag      .
           move      w-tes-cod-dpz        to   d-buf-fod-cod-dpz      .
           perform   det-buf-fod-cll-000  thru det-buf-fod-cll-999    .
      *              *-------------------------------------------------*
      *              * Bufferizzazione quantita' in ordine alla Sede   *
      *              *-------------------------------------------------*
           move      d-buf-fod-qta-oaf    to   w-rig-qta-odp (1)      .
       acc-cod-dcp-buf-800.
      *              *-------------------------------------------------*
      *              * Direttive per prezzo                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su direttive generali listino          *
      *                  *---------------------------------------------*
           if        w-tes-cod-lst-drg (1)
                                          not  = spaces and
                     w-tes-cod-lst-drg (1)
                                          not  = "M"    and
                     w-tes-cod-lst-drg (1)
                                          not  = "S"
                     go to acc-cod-dcp-buf-880.
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-dir    to   w-rig-flg-puq (1)      .
      *                  *---------------------------------------------*
      *                  * Test su flag prezzo relativo a quantita'    *
      *                  *---------------------------------------------*
           if        w-rig-flg-puq (1)    =    spaces
                     go to acc-cod-dcp-buf-880
           else if   w-rig-flg-puq (1)    =    "D"
                     go to acc-cod-dcp-buf-810
           else if   w-rig-flg-puq (1)    =    "C"
                     go to acc-cod-dcp-buf-820
           else if   w-rig-flg-puq (1)    =    "K"
                     go to acc-cod-dcp-buf-830
           else      go to acc-cod-dcp-buf-880.
       acc-cod-dcp-buf-810.
      *                  *---------------------------------------------*
      *                  * Prezzo per 10 unita'                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Attivazione seconda quantita'           *
      *                      *-----------------------------------------*
           move      1                    to   w-rig-snx-2qt (1)      .
           move      1                    to   w-rig-dec-2qt (1)      .
      *                      *-----------------------------------------*
      *                      * Prompt per il prezzo                    *
      *                      *-----------------------------------------*
           perform   pmt-prz-ven-000      thru pmt-prz-ven-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-cod-dcp-buf-880.
       acc-cod-dcp-buf-820.
      *                  *---------------------------------------------*
      *                  * Prezzo per 100 unita'                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Attivazione seconda quantita'           *
      *                      *-----------------------------------------*
           move      1                    to   w-rig-snx-2qt (1)      .
           move      2                    to   w-rig-dec-2qt (1)      .
      *                      *-----------------------------------------*
      *                      * Prompt per il prezzo                    *
      *                      *-----------------------------------------*
           perform   pmt-prz-ven-000      thru pmt-prz-ven-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-cod-dcp-buf-880.
       acc-cod-dcp-buf-830.
      *                  *---------------------------------------------*
      *                  * Prezzo per 1000 unita'                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Attivazione seconda quantita'           *
      *                      *-----------------------------------------*
           move      1                    to   w-rig-snx-2qt (1)      .
           move      3                    to   w-rig-dec-2qt (1)      .
      *                      *-----------------------------------------*
      *                      * Prompt per il prezzo                    *
      *                      *-----------------------------------------*
           perform   pmt-prz-ven-000      thru pmt-prz-ven-999        .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-cod-dcp-buf-880.
       acc-cod-dcp-buf-880.
       acc-cod-dcp-buf-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-cod-dcp-buf-999.
       acc-cod-dcp-buf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice prodotto [dcp]     *
      *    *                                                           *
      *    * Box di errore emesso in funzione dello status commerciale *
      *    * del prodotto, se diverso da 'normale'                     *
      *    *-----------------------------------------------------------*
       acc-cod-dcp-bsp-000.
      *              *-------------------------------------------------*
      *              * Messaggio di errore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio del video attuale               *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      20                   to   v-lto                  .
           move      08                   to   v-pos                  .
           move      73                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-dcp-bsp-200.
      *                  *---------------------------------------------*
      *                  * Messaggi entro il box                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Titolo centrale                         *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "                     A T T E N Z I O N E          
      -              "            "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 1                        *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "Per il prodotto impostato si rileva la seguente co
      -              "ndizione :  "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Preparazione riga messaggio 2           *
      *                      *-----------------------------------------*
           if        w-let-dcp-pdx-tus    =    11
                     move  "[Prodotto ad esaurimento]                   
      -                    "                  "
                                          to   v-alf
           else if   w-let-dcp-pdx-tus    =    21
                     move  "[Sostituito da ns. nuovo prodotto]          
      -                    "                  "
                                          to   v-alf
           else if   w-let-dcp-pdx-tus    =    51
                     move  "[Cessata commercializzazione]               
      -                    "                  "
                                          to   v-alf
           else if   w-let-dcp-pdx-tus    =    52
                     move  "[Cessata commercializzazione, ma sostituito 
      -                    "da ns. prodotto]  "
                                          to   v-alf
           else if   w-let-dcp-pdx-tus    =    71
                     move  "[Obsoleto]                                  
      -                    "                  "
                                          to   v-alf
           else if   w-let-dcp-pdx-tus    =    72
                     move  "[Obsoleto, ma sostituito da ns. nuovo prodot
      -                    "to]               "
                                          to   v-alf
           else      move  "(status non determinato)                    
      -                    "                  "
                                          to   v-alf                  .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 2                        *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      10                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 3                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da emettere                 *
      *                          *-------------------------------------*
           if        w-let-dcp-pdx-tud    =    zero
                     go to acc-cod-dcp-bsp-300.
      *                          *-------------------------------------*
      *                          * Emissione                           *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "La determinazione di tale condizione risale al :  
      -              "            "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Data di rilevamento status          *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      15                   to   v-lin                  .
           move      59                   to   v-pos                  .
           move      w-let-dcp-pdx-tud    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-dcp-bsp-300.
      *                      *-----------------------------------------*
      *                      * Righe messaggio 4 e 5                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da emettere                 *
      *                          *-------------------------------------*
           if        w-let-dcp-pdx-tuc    =    zero
                     go to acc-cod-dcp-bsp-600.
      *                          *-------------------------------------*
      *                          * Emissione                           *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "Il prodotto utilizzabile in alternativa e' il segu
      -              "ente :       "      to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Codice prodotto alternativo         *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Lettura record [dcp]            *
      *                              *---------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      w-let-dcp-pdx-tuc    to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
           if        f-sts                not  = e-not-err
                     move  spaces         to   rf-dcp-alf-pro
                     move  all "."        to   rf-dcp-des-pro         .
      *                              *---------------------------------*
      *                              * Visualizzazione codice prodotto *
      *                              *---------------------------------*

           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      rf-dcp-alf-pro       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Visualizzazione descrizione     *
      *                              *---------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      rf-dcp-des-pro       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Lettura record [dcp] di ripris- *
      *                              * tino                            *
      *                              *---------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      w-let-dcp-pdx-cod    to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
       acc-cod-dcp-bsp-600.
      *                      *-----------------------------------------*
      *                      * Prompt per presa visione                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      69                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-dcp-bsp-800.
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      19                   to   v-lin                  .
           move      70                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-dcp-bsp-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Codice prodotto [dcp]     *
      *    *                                                           *
      *    * Eventuale segnalazione 'forecast' aperti                  *
      *    *-----------------------------------------------------------*
       acc-cod-dcp-frc-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-ord-frc-flg      .
           move      spaces               to   w-det-ord-frc-tip      .
           move      zero                 to   w-det-ord-frc-doc      .
       acc-cod-dcp-frc-100.
      *              *-------------------------------------------------*
      *              * Start su file [ocr] : righe ordini              *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "MAGDAT    "         to   f-key                  .
           move      w-tes-cod-dpz        to   rf-ocr-cod-dpz         .
           move      01                   to   rf-ocr-tip-mag         .
           move      w-rig-num-pro (1)    to   rf-ocr-num-pro         .
           move      zero                 to   rf-ocr-dat-doc         .
           move      zero                 to   rf-ocr-num-doc         .
           move      zero                 to   rf-ocr-num-prt         .
           move      zero                 to   rf-ocr-num-prg         .
           move      "pgm/orc/fls/ioc/obj/iofocr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocr                 .
      *                  *---------------------------------------------*
      *                  * Esito della start                           *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to acc-cod-dcp-frc-900.
       acc-cod-dcp-frc-200.
      *              *-------------------------------------------------*
      *              * Read-next su file [ocr]                         *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofocr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocr                 .
      *                  *---------------------------------------------*
      *                  * Esito della read-next                       *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to acc-cod-dcp-frc-900.
       acc-cod-dcp-frc-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-ocr-cod-dpz       not  = w-tes-cod-dpz     or
                     rf-ocr-tip-mag       not  = 01                or
                     rf-ocr-num-pro       not  = w-rig-num-pro (1)
                     go to acc-cod-dcp-frc-900.
       acc-cod-dcp-frc-400.
      *              *-------------------------------------------------*
      *              * Selezioni sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su cliente                             *
      *                  *---------------------------------------------*
           if        rf-ocr-cod-arc       not  = w-tes-cod-arc (1)
                     go to acc-cod-dcp-frc-200.
      *                  *---------------------------------------------*
      *                  * Test se riga di Commento                    *
      *                  *---------------------------------------------*
           if        rf-ocr-tip-rig
                    (1 : 1)               =    "C"
                     go to acc-cod-dcp-frc-200.
      *                  *---------------------------------------------*
      *                  * Test se 'forecast'                          *
      *                  *---------------------------------------------*
           if        rf-ocr-tip-ord       not  = "F"
                     go to acc-cod-dcp-frc-200.
      *                  *---------------------------------------------*
      *                  * Determinazione evasione                     *
      *                  *---------------------------------------------*
           move      "DT"                 to   d-qev-roc-tip-ope      .
           perform   det-qev-roc-cll-000  thru det-qev-roc-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test se inevaso                             *
      *                  *---------------------------------------------*
           if        d-qev-roc-qta-dev    not  > zero
                     go to acc-cod-dcp-frc-200.
       acc-cod-dcp-frc-600.
      *              *-------------------------------------------------*
      *              * Bufferizzazioni                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo documento                              *
      *                  *---------------------------------------------*
           move      rf-ocr-tmo-orc       to   w-det-ord-frc-tip      .
      *                  *---------------------------------------------*
      *                  * Numero documento                            *
      *                  *---------------------------------------------*
           move      rf-ocr-num-doc       to   w-cdn-oct-wan-num      .
           move      w-cdn-oct-wan-saa    to   w-det-ord-frc-saa      .
           move      w-cdn-oct-wan-prg    to   w-det-ord-frc-prg      .
      *                  *---------------------------------------------*
      *                  * Flag di uscita                              *
      *                  *---------------------------------------------*
           move      "#"                  to   w-det-ord-frc-flg      .
       acc-cod-dcp-frc-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-cod-dcp-frc-999.
       acc-cod-dcp-frc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Unita' di misura                  *
      *    *-----------------------------------------------------------*
       vis-umi-ven-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      15                   to   v-pos                  .
           move      w-rig-umi-ven (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-umi-ven-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Descrizione in riga       *
      *    *-----------------------------------------------------------*
       acc-des-rig-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-des-rig (1)    to   w-sav-des-rig          .
       acc-des-rig-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      10                   to   v-ldt                  .
           move      14                   to   v-lin                  .
           move      36                   to   v-pos                  .
           move      "DOWN"               to   v-pfk (02)             .
      *
           if        w-rig-tip-rig-tpr (1)
                                          =    "P" and
                     w-rig-tip-rig-tfu (1)
                                          =    spaces
                     move  "INSR"         to   v-pfk (04)             .
      *
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-des-rig (1)    to   v-txt                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-des-rig-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-des-rig-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "des-rig"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-txt                to   w-rig-des-rig (1)      .
       acc-des-rig-300.
      *              *-------------------------------------------------*
      *              * Se Insr                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "INSR"
                     go to acc-des-rig-400.
      *                  *---------------------------------------------*
      *                  * Insr su archivio [pdx]                      *
      *                  *---------------------------------------------*
           move      w-rig-num-pro (1)    to   w-ins-arc-pdx-cnp      .
           move      w-tes-tip-arc (1)    to   w-ins-arc-pdx-tar      .
           if        w-tes-tip-frn (1)    =    11
                     move  w-tes-cod-arc (1)
                                          to   w-ins-arc-pdx-arc
           else      move  w-tes-arc-plf (1)
                                          to   w-ins-arc-pdx-arc      .
           perform   ins-arc-pdx-000      thru ins-arc-pdx-999        .
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dcp]                      *
      *                  *---------------------------------------------*
           move      w-rig-num-pro (1)    to   w-let-dcp-pdx-cod      .
           move      w-tes-tip-arc (1)    to   w-let-dcp-pdx-tar      .
           if        w-tes-tip-frn (1)    =    11
                     move  w-tes-cod-arc (1)
                                          to   w-let-dcp-pdx-arc
           else      move  w-tes-arc-plf (1)
                                          to   w-let-dcp-pdx-arc      .
           move      w-tes-cod-lng (1)    to   w-let-dcp-pdx-lng      .
           perform   let-dcp-pdx-000      thru let-dcp-pdx-999        .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda che la descrizione in  *
      *                  * riga attuale sia uguale o meno a quella del *
      *                  * prodotto                                    *
      *                  *---------------------------------------------*
           if        w-rig-des-rig (1)    =    w-rig-des-por (1)
                     go to acc-des-rig-310
           else      go to acc-des-rig-320.
       acc-des-rig-310.
      *                  *---------------------------------------------*
      *                  * Se descrizione in riga attuale pari a quel- *
      *                  * la del prodotto                             *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-des    to   w-rig-des-por (1)
                                               w-rig-des-rig (1)      .
           perform   vis-des-rig-000      thru vis-des-rig-999        .
           go to     acc-des-rig-350.
       acc-des-rig-320.
      *                  *---------------------------------------------*
      *                  * Se descrizione in riga attuale diversa da   *
      *                  * quella del prodotto                         *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-des    to   w-rig-des-por (1)      .
           go to     acc-des-rig-350.
       acc-des-rig-350.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione codice prodotto secondo il  *
      *                  * cliente                                     *
      *                  *---------------------------------------------*
           move      w-let-dcp-pdx-cpc    to   w-rig-cop-scl (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione codice prodotto secondo il  *
      *                  * cliente                                     *
      *                  *---------------------------------------------*
           perform   vis-cop-scl-000      thru vis-cop-scl-999        .
      *                  *---------------------------------------------*
      *                  * Normalizzazione function-key                *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-des-rig-100.
       acc-des-rig-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a spazi ammesso solo per tipi riga   *
      *                  * 'C', a meno che non si sia in Up            *
      *                  *---------------------------------------------*
           if        w-rig-des-rig (1)    not  = spaces
                     go to acc-des-rig-600.
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to acc-des-rig-600.
           if        v-key                =    "UP  "
                     go to acc-des-rig-600
           else      go to acc-des-rig-100.
       acc-des-rig-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-des-rig (1)    =    w-sav-des-rig
                     go to acc-des-rig-800.
      *                  *---------------------------------------------*
      *                  * Determinazione flag di estensione alla de-  *
      *                  * scrizione                                   *
      *                  *---------------------------------------------*
           perform   det-des-ext-000      thru det-des-ext-999        .
       acc-des-rig-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-des-rig-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-des-rig-100.
       acc-des-rig-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Descrizione in riga               *
      *    *-----------------------------------------------------------*
       vis-des-rig-000.
           move      "DS"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      10                   to   v-ldt                  .
           move      14                   to   v-lin                  .
           move      36                   to   v-pos                  .
           move      w-rig-des-rig (1)    to   v-txt                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Quantita' ordinata        *
      *    *-----------------------------------------------------------*
       acc-qta-ord-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-qta-ord-999.
       acc-qta-ord-050.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-qta-ord (1)    to   w-sav-qta-ord          .
      *                  *---------------------------------------------*
      *                  * Eventuale valore di default                 *
      *                  *---------------------------------------------*
           if        w-tes-tip-ord (1)    =    "C" and
                     w-rig-qta-ord (1)    =    zero
                     move  1              to   w-rig-qta-ord (1)      .
       acc-qta-ord-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      w-rig-dec-qta (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<GB"                to   v-edm                  .
           move      15                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-qta-ord (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-qta-ord-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-qta-ord-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "qta-ord"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-qta-ord (1)      .
       acc-qta-ord-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-qta-ord (1)    =    w-sav-qta-ord
                     go to acc-qta-ord-800.
      *                  *---------------------------------------------*
      *                  * Subroutine di trattamento lotto di vendita  *
      *                  *---------------------------------------------*
           perform   acc-qta-ord-ldv-000  thru acc-qta-ord-ldv-999    .
      *                      *-----------------------------------------*
      *                      * Test sul flag di uscita                 *
      *                      *-----------------------------------------*
           if        w-acc-qta-ord-flg    not  = spaces
                     go to acc-qta-ord-100.
      *                  *---------------------------------------------*
      *                  * Subroutine di trattamento eventuale pro-    *
      *                  * venienza da ordine 'forecast'               *
      *                  *---------------------------------------------*
           perform   acc-qta-ord-pof-000  thru acc-qta-ord-pof-999    .
      *                  *---------------------------------------------*
      *                  * Ricalcolo del prezzo di vendita             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione               *
      *                      *-----------------------------------------*
           if        w-prs-mac-prz        not  = 02
                     go to acc-qta-ord-600.
      *                      *-----------------------------------------*
      *                      * Determinazione                          *
      *                      *-----------------------------------------*
           perform   det-prz-ven-000      thru det-prz-ven-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           perform   vis-prz-ven-000      thru vis-prz-ven-999        .
       acc-qta-ord-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Trattamento quantita' secondaria            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se trattamento necessario          *
      *                      *-----------------------------------------*
           if        w-rig-snx-2qt (1)    not  = 1
                     go to acc-qta-ord-700.
      *                      *-----------------------------------------*
      *                      * Determinazione quantita' secondaria     *
      *                      *-----------------------------------------*
           move      w-rig-qta-ord (1)    to   w-det-qta-a02-qim      .
           move      w-rig-dec-2qt (1)    to   w-det-qta-a02-ndu      .
      *
           if        w-rig-flg-puq (1)    =    "D"
                     move  10             to   w-det-qta-a02-cmu
           else if   w-rig-flg-puq (1)    =    "C"
                     move  100            to   w-det-qta-a02-cmu
           else if   w-rig-flg-puq (1)    =    "K"
                     move  1000           to   w-det-qta-a02-cmu
           else      move  1              to   w-det-qta-a02-cmu      .
      *
           move      1                    to   w-det-qta-a02-cdu      .
           perform   det-qta-a02-000      thru det-qta-a02-999        .
           move      w-det-qta-a02-qts    to   w-rig-qta-a02 (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione seconda quantita'       *
      *                      *-----------------------------------------*
           perform   vis-qta-a02-000      thru vis-qta-a02-999        .
       acc-qta-ord-700.
      *                  *---------------------------------------------*
      *                  * Determinazione prezzo netto                 *
      *                  *---------------------------------------------*
           move      w-rig-prz-ven (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
      *                  *---------------------------------------------*
      *                  * Determinazione importo in riga              *
      *                  *---------------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione importo in riga             *
      *                  *---------------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-qta-ord-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-qta-ord-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-qta-ord-100.
       acc-qta-ord-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Quantita' ordinata                *
      *    *-----------------------------------------------------------*
       vis-qta-ord-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      w-rig-dec-qta (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<GB"                to   v-edm                  .
           move      15                   to   v-lin                  .
           move      21                   to   v-pos                  .
           move      w-rig-qta-ord (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-qta-ord-999.
           exit.

      *    *===========================================================*
      *    * Accettazione : Seconda quantita'                          *
      *    *-----------------------------------------------------------*
       acc-qta-a02-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * ATTUALMENTE MAI ACCETTATA                   *
      *                  *---------------------------------------------*
           go to     acc-qta-a02-999.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-snx-2qt (1)    not  = 1
                     go to acc-qta-a02-999.
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to acc-qta-a02-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-qta-a02 (1)    to   w-sav-qta-a02          .
       acc-qta-a02-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompt                          *
      *              *-------------------------------------------------*
           perform   pmt-qta-a02-000      thru pmt-qta-a02-999        .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      w-rig-dec-2qt (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<GB"                to   v-edm                  .
           move      15                   to   v-lin                  .
           move      40                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-qta-a02 (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-qta-a02-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-qta-a02-999.
      *              *-------------------------------------------------*
      *              * Se Pf4                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "qta-a02"      to   w-dup-vri-pre-ncd
                     perform dup-vri-pre-000
                                          thru dup-vri-pre-999        .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-qta-a02 (1)      .
       acc-qta-a02-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-rig-qta-a02 (1)    =    w-sav-qta-a02
                     go to acc-qta-a02-800.
       acc-qta-a02-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione seconda quantita'           *
      *                  *---------------------------------------------*
           perform   vis-qta-a02-000      thru vis-qta-a02-999        .
       acc-qta-a02-700.
      *                  *---------------------------------------------*
      *                  * Determinazione prezzo netto                 *
      *                  *---------------------------------------------*
           move      w-rig-prz-ven (1)    to   w-cal-prz-net-prz      .
           move      w-rig-per-scr (1, 1) to   w-cal-prz-net-psc (1)  .
           move      w-rig-per-scr (1, 2) to   w-cal-prz-net-psc (2)  .
           move      w-rig-per-scr (1, 3) to   w-cal-prz-net-psc (3)  .
           move      w-rig-per-scr (1, 4) to   w-cal-prz-net-psc (4)  .
           move      w-rig-per-scr (1, 5) to   w-cal-prz-net-psc (5)  .
           perform   cal-prz-net-000      thru cal-prz-net-999        .
           move      w-cal-prz-net-prz    to   w-rig-prz-net (1)      .
      *                  *---------------------------------------------*
      *                  * Determinazione importo in riga              *
      *                  *---------------------------------------------*
           perform   det-imp-rig-000      thru det-imp-rig-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione importo in riga             *
      *                  *---------------------------------------------*
           perform   vis-imp-rig-000      thru vis-imp-rig-999        .
       acc-qta-a02-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-qta-a02-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-qta-a02-100.
       acc-qta-a02-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione : Seconda quantita'                       *
      *    *-----------------------------------------------------------*
       vis-qta-a02-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *                                                 *
      *              * N.B.: attualmente inibito                       *
      *              *-------------------------------------------------*
           go to     vis-qta-a02-999.
      *
           if        w-rig-snx-2qt (1)    not  = 1
                     go to vis-qta-a02-999.
       vis-qta-a02-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
       vis-qta-a02-200.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del valore da editare  *
      *                  *---------------------------------------------*
           if        w-rig-qta-a02 (1)    =    zero
                     go to vis-qta-a02-300
           else      go to vis-qta-a02-400.
       vis-qta-a02-300.
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Visualizzazione a spaces                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     vis-qta-a02-999.
       vis-qta-a02-400.
      *                  *---------------------------------------------*
      *                  * Se valore diverso da zero                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing quantita'                       *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      w-rig-dec-2qt (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<GB"                to   v-edm                  .
           move      w-rig-qta-a02 (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Composizione area editata completa      *
      *                      *-----------------------------------------*
           move      18                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
      *
           if        w-rig-flg-puq (1)    =    "D"
                     move  "(DEC"         to   w-all-str-cat (1)
           else if   w-rig-flg-puq (1)    =    "C"
                     move  "(CEN"         to   w-all-str-cat (1)
           else if   w-rig-flg-puq (1)    =    "K"
                     move  "(MGL"         to   w-all-str-cat (1)
           else      move  "(MGL"         to   w-all-str-cat (1)      .
      *
           move      v-edt                to   w-all-str-cat (2)      .
           move      ")"                  to   w-all-str-cat (3)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione                         *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      35                   to   v-pos                  .
           move      w-all-str-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     vis-qta-a02-999.
       vis-qta-a02-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Quantita' di vendita      *
      *    *                                 addizionale per moltipli- *
      *    *                                 cazione con lotto di ven- *
      *    *                                 dita                      *
      *    *-----------------------------------------------------------*
       acc-qta-add-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-qta-add-010.
      *                  *---------------------------------------------*
      *                  * Box di accettazione                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Salvataggio immagine video              *
      *                      *-----------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Video in Off                            *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Box                                     *
      *                      *-----------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      15                   to   v-lin                  .
           move      35                   to   v-pos                  .
           move      17                   to   v-lto                  .
           move      68                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Prompt per quantita' addizionale        *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      19                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      36                   to   v-pos                  .
           move      "Quantita' x lotto :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Video in On                             *
      *                      *-----------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-qta-add-050.
      *                  *---------------------------------------------*
      *                  * Quantita' di vendita in quantita' addizio-  *
      *                  * nale                                        *
      *                  *---------------------------------------------*
           move      w-rig-qta-ord (1)    to   w-rig-qta-add (1)      .
      *                  *---------------------------------------------*
      *                  * Moltiplicazione                             *
      *                  *---------------------------------------------*
           multiply  w-rig-lot-ven (1)    by   w-rig-qta-add (1)
                                        giving w-rig-qta-add (1)      .
       acc-qta-add-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      w-rig-dec-qta (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      16                   to   v-lin                  .
           move      56                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[1] "               to   v-pfk (14)             .
           move      w-rig-qta-add (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-qta-add-900.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-qta-add-900.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-qta-add (1)      .
       acc-qta-add-200.
      *              *-------------------------------------------------*
      *              * Se Pf1                                          *
      *              *-------------------------------------------------*
           if        v-key                not  = "[1] "
                     go to acc-qta-add-400.
           if        w-rig-qta-add (1)    =    zero
                     go to acc-qta-add-400.
      *                  *---------------------------------------------*
      *                  * Quantita' addizionale in quantita' in       *
      *                  * ordine                                      *
      *                  *---------------------------------------------*
           move      w-rig-qta-add (1)    to   w-rig-qta-ord (1)      .
       acc-qta-add-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-qta-add-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-qta-add-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-qta-add-900
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-qta-add-100.
       acc-qta-add-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino immagine video                   *
      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     acc-qta-add-999.
       acc-qta-add-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Quantita' ordinata        *
      *    *                                                           *
      *    * Subroutine di trattamento lotto di vendita in relazione   *
      *    * alla quantita'                                            *
      *    *-----------------------------------------------------------*
       acc-qta-ord-ldv-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-acc-qta-ord-flg      .
      *              *-------------------------------------------------*
      *              * Se lotto di vendita a zero : uscita             *
      *              *-------------------------------------------------*
           if        w-rig-lot-ven (1)    =    zero
                     go to acc-qta-ord-ldv-800.
      *              *-------------------------------------------------*
      *              * Se quantita' ordinata a zero : uscita           *
      *              *-------------------------------------------------*
           if        w-rig-qta-ord (1)    =    zero
                     go to acc-qta-ord-ldv-800.
      *              *-------------------------------------------------*
      *              * Se quantita' ordinata gia' impostata preceden-  *
      *              * temente : uscita                                *
      *              *-------------------------------------------------*
           if        w-sav-qta-ord        not  = zero
                     go to acc-qta-ord-ldv-800.
       acc-qta-ord-ldv-010.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione della personalizzazione  *
      *              *-------------------------------------------------*
           if        w-prs-tdt-ldv        =    "N"
                     go to acc-qta-ord-ldv-100
           else if   w-prs-tdt-ldv        =    "A"
                     go to acc-qta-ord-ldv-200
           else if   w-prs-tdt-ldv        =    "M"
                     go to acc-qta-ord-ldv-300
           else if   w-prs-tdt-ldv        =    "B"
                     go to acc-qta-ord-ldv-300
           else if   w-prs-tdt-ldv        =    "*"
                     go to acc-qta-ord-ldv-400
           else      go to acc-qta-ord-ldv-800.
       acc-qta-ord-ldv-100.
      *              *-------------------------------------------------*
      *              * Se nessun trattamento                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ad uscita per fine trattamento regolare     *
      *                  *---------------------------------------------*
           go to     acc-qta-ord-ldv-800.
       acc-qta-ord-ldv-200.
      *              *-------------------------------------------------*
      *              * Se arrotondamento                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale aggiustamento quantita' ordinata  *
      *                  * al lotto di vendita superiore               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controllo che quantita' ordinata sia    *
      *                      * multiplo del lotto di vendita           *
      *                      *-----------------------------------------*
           divide    w-rig-lot-ven (1)    into w-rig-qta-ord (1)
                                        giving w-acc-qta-ord-wpq
                                     remainder w-acc-qta-ord-wpr      .
           if        w-acc-qta-ord-r2a    not  = zero
                     go to acc-qta-ord-ldv-220.
           if        w-rig-dec-qta (1)    =    zero
                     if    w-acc-qta-ord-r1b
                                          not  = zero or
                           w-acc-qta-ord-r2b
                                          not  = zero or
                           w-acc-qta-ord-r1c
                                          not  = zero or
                           w-acc-qta-ord-r2c
                                          not  = zero or
                           w-acc-qta-ord-r1d
                                          not  = zero or
                           w-acc-qta-ord-r2d
                                          not  = zero
                           go to acc-qta-ord-ldv-220
                      else go to acc-qta-ord-ldv-800.
           if        w-rig-dec-qta (1)    =    1
                     if    w-acc-qta-ord-r1c
                                          not  = zero or
                           w-acc-qta-ord-r2c
                                          not  = zero or
                           w-acc-qta-ord-r1d
                                          not  = zero or
                           w-acc-qta-ord-r2d
                                          not  = zero
                           go to acc-qta-ord-ldv-220
                      else go to acc-qta-ord-ldv-800.
           if        w-rig-dec-qta (1)    =    2
                     if    w-acc-qta-ord-r1d
                                          not  = zero or
                           w-acc-qta-ord-r2d
                                          not  = zero
                           go to acc-qta-ord-ldv-220
                      else go to acc-qta-ord-ldv-800.
           go to     acc-qta-ord-ldv-800.
       acc-qta-ord-ldv-220.
      *                      *-----------------------------------------*
      *                      * Aggiustamento quantita' ordinata        *
      *                      *-----------------------------------------*
           add       1                    to   w-acc-qta-ord-r1a      .
           multiply  w-rig-lot-ven (1)    by   w-acc-qta-ord-r1a
                                        giving w-rig-qta-ord (1)      .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione quantita' ordinata    *
      *                      *-----------------------------------------*
           perform   vis-qta-ord-000      thru vis-qta-ord-999        .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     acc-qta-ord-ldv-800.
       acc-qta-ord-ldv-300.
      *              *-------------------------------------------------*
      *              * Se messaggio di avviso                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Confronto tra la quantita' ordinata e il    *
      *                  * lotto di vendita                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controllo che quantita' ordinata sia    *
      *                      * multiplo del lotto di vendita           *
      *                      *-----------------------------------------*
           divide    w-rig-lot-ven (1)    into w-rig-qta-ord (1)
                                        giving w-acc-qta-ord-wpq
                                     remainder w-acc-qta-ord-wpr      .
           if        w-acc-qta-ord-r2a    not  = zero
                     go to acc-qta-ord-ldv-320.
           if        w-rig-dec-qta (1)    =    zero
                     if    w-acc-qta-ord-r1b
                                          not  = zero or
                           w-acc-qta-ord-r2b
                                          not  = zero or
                           w-acc-qta-ord-r1c
                                          not  = zero or
                           w-acc-qta-ord-r2c
                                          not  = zero or
                           w-acc-qta-ord-r1d
                                          not  = zero or
                           w-acc-qta-ord-r2d
                                          not  = zero
                           go to acc-qta-ord-ldv-320
                      else go to acc-qta-ord-ldv-800.
           if        w-rig-dec-qta (1)    =    1
                     if    w-acc-qta-ord-r1c
                                          not  = zero or
                           w-acc-qta-ord-r2c
                                          not  = zero or
                           w-acc-qta-ord-r1d
                                          not  = zero or
                           w-acc-qta-ord-r2d
                                          not  = zero
                           go to acc-qta-ord-ldv-320
                      else go to acc-qta-ord-ldv-800.
           if        w-rig-dec-qta (1)    =    2
                     if    w-acc-qta-ord-r1d
                                          not  = zero or
                           w-acc-qta-ord-r2d
                                          not  = zero
                           go to acc-qta-ord-ldv-320
                      else go to acc-qta-ord-ldv-800.
           go to     acc-qta-ord-ldv-800.
       acc-qta-ord-ldv-320.
      *                  *---------------------------------------------*
      *                  * Messaggio di avviso                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing del lotto di vendita            *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      03                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BGD"               to   v-edm                  .
           move      w-rig-lot-ven (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Composizione messaggio di avviso        *
      *                      *-----------------------------------------*
           move      spaces               to   w-err-box-err-msg      .
           string    "Lotto di vendita del prodotto : "
                                delimited by size
                     v-edt      delimited by spaces
                                          into w-err-box-err-msg      .
      *                  *---------------------------------------------*
      *                  * Ad uscita con emissione messaggio di avviso *
      *                  * ed eventuale blocco a seconda della perso-  *
      *                  * nalizzazione                                *
      *                  *---------------------------------------------*
           if        w-prs-tdt-ldv        =    "M"
                     go to acc-qta-ord-ldv-950
           else      go to acc-qta-ord-ldv-900.
       acc-qta-ord-ldv-400.
      *              *-------------------------------------------------*
      *              * Se moltiplicazione della quantita' per il lotto *
      *              * di vendita                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Accettazione addizionale della quantita'    *
      *                  * da sottoporre a moltiplicazione             *
      *                  *---------------------------------------------*
           perform   acc-qta-add-000      thru acc-qta-add-999        .
      *                  *---------------------------------------------*
      *                  * Rivisualizzazione quantita' in ordine       *
      *                  *---------------------------------------------*
           perform   vis-qta-ord-000      thru vis-qta-ord-999        .
      *                  *---------------------------------------------*
      *                  * Ad uscita per fine trattamento regolare     *
      *                  *---------------------------------------------*
           go to     acc-qta-ord-ldv-800.
       acc-qta-ord-ldv-800.
      *              *-------------------------------------------------*
      *              * Uscita per fine trattamento regolare            *
      *              *-------------------------------------------------*
           go to     acc-qta-ord-ldv-999.
       acc-qta-ord-ldv-900.
      *              *-------------------------------------------------*
      *              * Uscita per fine trattamento con messaggio e con *
      *              * blocco                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita                              *
      *                  *---------------------------------------------*
           move      "#"                  to   w-acc-qta-ord-flg      .
      *                  *---------------------------------------------*
      *                  * Ad uscita per fine trattamento con messag-  *
      *                  * gio                                         *
      *                  *---------------------------------------------*
           go to     acc-qta-ord-ldv-950.
       acc-qta-ord-ldv-950.
      *              *-------------------------------------------------*
      *              * Uscita per fine trattamento con messaggio       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio                         *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     acc-qta-ord-ldv-999.
       acc-qta-ord-ldv-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Quantita' ordinata        *
      *    *                                                           *
      *    * Subroutine di trattamento eventuale provenienza da ordine *
      *    * 'forecast'                                                *
      *    *-----------------------------------------------------------*
       acc-qta-ord-pof-000.
      *              *-------------------------------------------------*
      *              * Test su personalizzazione                       *
      *              *-------------------------------------------------*
           if        w-prs-snx-ocf        not  = "S"
                     go to acc-qta-ord-pof-900.
      *              *-------------------------------------------------*
      *              * Test su tipo ordine in corso di trattamento     *
      *              *-------------------------------------------------*
           if        w-tes-tmo-orc-tip    =    "F"
                     go to acc-qta-ord-pof-900.
      *              *-------------------------------------------------*
      *              * Test su quantita' impostata                     *
      *              *-------------------------------------------------*
           if        w-rig-qta-ord (1)    =    zero
                     go to acc-qta-ord-pof-900.
      *              *-------------------------------------------------*
      *              * Test se la riga in corso di trattamento, pro-   *
      *              * viene da un ordine 'forecast'                   *
      *              *-------------------------------------------------*
           if        w-rig-flg-frc (1)    =    spaces or
                     w-rig-prt-frc (1)    =    zero   or
                     w-rig-prg-frc (1)    =    zero
                     go to acc-qta-ord-pof-900.
       acc-qta-ord-pof-100.
      *              *-------------------------------------------------*
      *              * Lettura della riga ordine 'forecast' per veri-  *
      *              * ficare la quantita' in ordine                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [ocr]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofocr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocr                 .
      *                  *---------------------------------------------*
      *                  * Lettura record [ocr]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-rig-prt-frc (1)    to   rf-ocr-num-prt         .
           move      w-rig-prg-frc (1)    to   rf-ocr-num-prg         .
           move      "pgm/orc/fls/ioc/obj/iofocr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocr                 .
      *                  *---------------------------------------------*
      *                  * Se record [ocr] non trovato : ad uscita     *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to acc-qta-ord-pof-900.
       acc-qta-ord-pof-200.
      *              *-------------------------------------------------*
      *              * Confronto con la quantita' letta                *
      *              *-------------------------------------------------*
           if        w-rig-qta-ord (1)    not  < rf-ocr-qta-ord
                     go to acc-qta-ord-pof-900.
       acc-qta-ord-pof-300.
      *              *-------------------------------------------------*
      *              * Messaggio di avviso                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing quantita' letta                     *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      w-rig-dec-2qt (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "<GB"                to   v-edm                  .
           move      rf-ocr-qta-ord       to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Composizione messaggio di avviso            *
      *                  *---------------------------------------------*
           move      "Questa riga e' relativa ad un ordine 'forecast' co
      -              "n la seguente  "    to   w-err-box-err-msg      .
      *
           move      spaces               to   w-err-box-err-m02      .
           string    "quantita' : "
                                delimited by size
                     v-edt      delimited by spaces
                                          into w-err-box-err-m02      .
      *                  *---------------------------------------------*
      *                  * Ad uscita con messaggio                     *
      *                  *---------------------------------------------*
           go to     acc-qta-ord-pof-950.
       acc-qta-ord-pof-900.
      *              *-------------------------------------------------*
      *              * Uscita senza alcuna azione                      *
      *              *-------------------------------------------------*
           go to     acc-qta-ord-pof-999.
       acc-qta-ord-pof-950.
      *              *-------------------------------------------------*
      *              * Uscita per fine trattamento con messaggio       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio                         *
      *                  *---------------------------------------------*
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     acc-qta-ord-pof-999.
       acc-qta-ord-pof-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga corpo : Flag non bloccante 1      *
      *    *-----------------------------------------------------------*
       acc-flg-xb1-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-sna-flg-xbr (1)
                                          =    spaces
                     go to acc-flg-xb1-999.
       acc-flg-xb1-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompt                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      53                   to   v-pos                  .
           move      "( )"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      54                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO"                 to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           move      "[4] "               to   v-pfk (17)             .
           move      w-rig-flg-nbx (1, 1) to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-flg-xb1-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-flg-xb1-999.
      *              *-------------------------------------------------*
      *              * Se Pf4 : come Down                              *
      *              *-------------------------------------------------*
           if        v-key                =    "[4] "
                     move  "DOWN"         to   v-key                  .
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-flg-nbx (1, 1)   .
       acc-flg-xb1-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-flg-xb1-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione prompt                      *
      *                  *---------------------------------------------*
           perform   pmt-flg-xb1-000      thru pmt-flg-xb1-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione valore                      *
      *                  *---------------------------------------------*
           perform   vis-flg-xb1-000      thru vis-flg-xb1-999        .
       acc-flg-xb1-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-flg-xb1-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-flg-xb1-100.
       acc-flg-xb1-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Flag non bloccante 1              *
      *    *-----------------------------------------------------------*
       vis-flg-xb1-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da visualizzare               *
      *                  *---------------------------------------------*
           if        w-prs-sna-flg-xbr (1)
                                          =    spaces
                     go to vis-flg-xb1-999.
       vis-flg-xb1-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      54                   to   v-pos                  .
           move      w-rig-flg-nbx (1, 1) to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-flg-xb1-999.
