      *    *===========================================================*
      *    * Accettazione corpo a partire dalla riga con numero d'or-  *
      *    * dine : w-cnt-cor-nrg-dac                                  *
      *    *                                                           *
      *    * --------------------------------------------------------- *
      *    * Moduli richiamati da tasti funzione                       *
      *    *                                                           *
      *    * - Pf1    : 'porc300b' - Duplicazione da ordine fornitore  *
      *    * - Pf2    : 'porc300f' - Evasione ordini 'forecast'        *
      *    * - Pf3    : 'porc300e' - Duplicazione da altro ordine      *
      *    *-----------------------------------------------------------*
       acc-cor-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione tipo uscita da corpo            *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-cor      .
       acc-cor-reg-005.
      *              *-------------------------------------------------*
      *              * Richiamo funzione di duplicazione righe ordine  *
      *              * fornitore con 'pf1'                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su flag di duplicazione righe ordine   *
      *                  *---------------------------------------------*
           if        l-dup-rof-flg-orf    =    spaces
                     go to acc-cor-reg-010.
      *                  *---------------------------------------------*
      *                  * Normalizzazione flag di duplicazione righe  *
      *                  * da ordine                                   *
      *                  *---------------------------------------------*
           move      spaces               to   l-dup-rof-flg-orf      .
      *                  *---------------------------------------------*
      *                  * Richiamo funzione di saldaconto             *
      *                  *---------------------------------------------*
           move      "SC"                 to   l-dup-rof-tip-ope      .
           move      "pgm/orc/prg/obj/porc300b"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using l-dup-rof
                                               w-prs
                                               w-tes
                                               w-pie
                                               w-rig
                                               w-cat-rig              .
      *                  *---------------------------------------------*
      *                  * Test su esito richiamo                      *
      *                  *---------------------------------------------*
           if        l-dup-rof-exi-sts    not  = spaces
                     go to acc-cor-reg-010.
      *                  *---------------------------------------------*
      *                  * Richiamo funzione di caricamento righe in   *
      *                  * catena                                      *
      *                  *---------------------------------------------*
           move      "CC"                 to   l-dup-rof-tip-ope      .
           move      "pgm/orc/prg/obj/porc300b"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using l-dup-rof
                                               w-prs
                                               w-tes
                                               w-pie
                                               w-rig
                                               w-cat-rig              .
       acc-cor-reg-010.
      *              *-------------------------------------------------*
      *              * Richiamo funzione di duplicazione righe ordine  *
      *              * 'pf3'                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su flag di duplicazione righe ordine   *
      *                  *---------------------------------------------*
           if        l-dup-rdo-flg-orc    =    spaces
                     go to acc-cor-reg-015.
      *                  *---------------------------------------------*
      *                  * Normalizzazione flag di duplicazione righe  *
      *                  * da ordine                                   *
      *                  *---------------------------------------------*
           move      spaces               to   l-dup-rdo-flg-orc      .
      *                  *---------------------------------------------*
      *                  * Richiamo funzione di saldaconto             *
      *                  *---------------------------------------------*
           move      "SC"                 to   l-dup-rdo-tip-ope      .
           move      "pgm/orc/prg/obj/porc300e"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using l-dup-rdo
                                               w-prs
                                               w-tes
                                               w-pie
                                               w-rig
                                               w-cat-rig              .
      *                  *---------------------------------------------*
      *                  * Test su esito richiamo                      *
      *                  *---------------------------------------------*
           if        l-dup-rdo-exi-sts    not  = spaces
                     go to acc-cor-reg-015.
      *                  *---------------------------------------------*
      *                  * Richiamo funzione di caricamento righe in   *
      *                  * catena                                      *
      *                  *---------------------------------------------*
           move      "CC"                 to   l-dup-rdo-tip-ope      .
           move      "pgm/orc/prg/obj/porc300e"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using l-dup-rdo
                                               w-prs
                                               w-tes
                                               w-pie
                                               w-rig
                                               w-cat-rig              .
       acc-cor-reg-015.
      *              *-------------------------------------------------*
      *              * Richiamo funzione di evasione righe 'forecast'  *
      *              * 'pf2'                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su personalizzazione                   *
      *                  *---------------------------------------------*
           if        w-prs-snx-ocf        not  = "S"
                     go to acc-cor-reg-020.
      *                  *---------------------------------------------*
      *                  * Test su flag di evasione righe 'forecast'   *
      *                  *---------------------------------------------*
           if        l-eva-frc-flg-orc    =    spaces
                     go to acc-cor-reg-020.
      *                  *---------------------------------------------*
      *                  * Normalizzazione flag di duplicazione righe  *
      *                  * da ordine                                   *
      *                  *---------------------------------------------*
           move      spaces               to   l-eva-frc-flg-orc      .
      *                  *---------------------------------------------*
      *                  * Richiamo funzione di saldaconto             *
      *                  *---------------------------------------------*
           move      "SC"                 to   l-eva-frc-tip-ope      .
           move      "pgm/orc/prg/obj/porc300f"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using l-eva-frc
                                               w-prs
                                               w-tes
                                               w-pie
                                               w-rig
                                               w-cat-rig              .
      *                  *---------------------------------------------*
      *                  * Test su esito richiamo                      *
      *                  *---------------------------------------------*
           if        l-eva-frc-exi-sts    not  = spaces
                     go to acc-cor-reg-020.
      *                  *---------------------------------------------*
      *                  * Richiamo funzione di caricamento righe in   *
      *                  * catena                                      *
      *                  *---------------------------------------------*
           move      "CC"                 to   l-eva-frc-tip-ope      .
           move      "pgm/orc/prg/obj/porc300f"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using l-eva-frc
                                               w-prs
                                               w-tes
                                               w-pie
                                               w-rig
                                               w-cat-rig              .
       acc-cor-reg-020.
      *              *-------------------------------------------------*
      *              * Confronto tra numero d'ordine riga da accettare *
      *              * e numero d'ordine dell'ultima riga              *
      *              *-------------------------------------------------*
           if        w-cnt-cor-nrg-dac    not  > w-cat-rig-max
                     go to acc-cor-reg-025.
      *              *-------------------------------------------------*
      *              * Se oltre numero riga massimo e Append non pos-  *
      *              * sibile si esce con status di uscita "+"         *
      *              *-------------------------------------------------*
           if        w-cat-rig-app        not  = spaces
                     move  "+"            to   w-cnt-tus-acc-cor
                     go to acc-cor-reg-997.
      *              *-------------------------------------------------*
      *              * Se oltre numero riga massimo e Append possibile *
      *              * si esegue l'operazione di Append                *
      *              *-------------------------------------------------*
           move      w-cat-rig-max        to   w-cnt-cor-nrg-dac      .
           add       1                    to   w-cnt-cor-nrg-dac      .
           move      "AP"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       acc-cor-reg-025.
      *              *-------------------------------------------------*
      *              * Video in 'OFF'                                  *
      *              *-------------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Prompts per corpo                               *
      *              *-------------------------------------------------*
           if        w-cnt-sts-pmt-cor    =    spaces
                     perform pmt-cor-reg-000
                                          thru pmt-cor-reg-999
                     move    "#"          to   w-cnt-sts-pmt-cor      .
      *              *-------------------------------------------------*
      *              * Visualizzazione dati corpo                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione nr pagina da visualizzare    *
      *                  *---------------------------------------------*
           move      w-cnt-cor-nrg-dac    to   w-cnt-cor-nrp-dav      .
           add       w-lin-num-lin-vis    to   w-cnt-cor-nrp-dav      .
           subtract  1                    from w-cnt-cor-nrp-dav      .
           divide    w-lin-num-lin-vis    into w-cnt-cor-nrp-dav      .
      *                  *---------------------------------------------*
      *                  * Se non e' visualizzata nessuna pagina corpo *
      *                  * o una pagina corpo diversa da quella da vi- *
      *                  * sualizzare si procede alla visualizzazione  *
      *                  *---------------------------------------------*
           if        w-cnt-sts-vis-cor    =    spaces           or
                     w-cnt-cor-nrp-vis    not  = w-cnt-cor-nrp-dav
                     perform vis-cor-reg-000
                                          thru vis-cor-reg-999
                     move    "#"          to   w-cnt-sts-vis-cor
                     move    w-cnt-cor-nrp-dav
                                          to   w-cnt-cor-nrp-vis      .
      *              *-------------------------------------------------*
      *              * Lettura riga da catena                          *
      *              *-------------------------------------------------*
           move      "RD"                 to   w-cat-rig-ope          .
           move      w-cnt-cor-nrg-dac    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se riga nuova si normalizza il corpo            *
      *              *-------------------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to acc-cor-reg-050.
           perform   nor-nok-rig-000      thru nor-nok-rig-999        .
           move      w-rig-val-aep (1)    to   w-rig-val-aep (2)      .
       acc-cor-reg-050.
      *              *-------------------------------------------------*
      *              * Routine pre-accettazione riga corpo             *
      *              *-------------------------------------------------*
           perform   pre-rig-cor-000      thru pre-rig-cor-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione prompts per riga d'accettazione *
      *              *-------------------------------------------------*
           perform   pmt-rig-cor-000      thru pmt-rig-cor-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione dati per riga di accettazione   *
      *              *-------------------------------------------------*
           perform   vis-rig-cor-000      thru vis-rig-cor-999        .
      *              *-------------------------------------------------*
      *              * Video in 'ON'                                   *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Flag di status impostazione corpo               *
      *              *-------------------------------------------------*
           if        w-cat-rig-max        =    zero
                     move  spaces         to   w-cnt-sts-imp-cor
           else      move  "#"            to   w-cnt-sts-imp-cor      .
           if        w-cat-rig-max        =    1        and
                     w-cat-rig-new        not  = spaces and
                     w-cat-rig-lst        not  = spaces
                     move  spaces         to   w-cnt-sts-imp-cor      .
      *              *-------------------------------------------------*
      *              * Flag di status impostione riga attuale          *
      *              *-------------------------------------------------*
           if        w-cat-rig-new        =    spaces
                     move  "#"            to   w-cnt-sts-imp-rig
           else      move  spaces         to   w-cnt-sts-imp-rig      .
      *              *-------------------------------------------------*
      *              * Indicatore linea in corso di trattamento        *
      *              *-------------------------------------------------*
           move      "I"                  to   w-cnt-cor-tvi-rig      .
           move      w-cnt-cor-nrg-dac    to   w-cnt-cor-nrg-dav      .
           perform   vis-lin-cor-000      thru vis-lin-cor-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazione tipo uscita da riga corpo       *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-rig      .
       acc-cor-reg-100.
      *              *-------------------------------------------------*
      *              * Accettazioni                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo impostazione : primo campo riga corpo  *
      *                  *---------------------------------------------*
           move      "C"                  to   w-cnt-mfu-tip-imp      .
      *                  *---------------------------------------------*
      *                  * Accettazione tipo riga                      *
      *                  *---------------------------------------------*
           perform   acc-tip-rig-000      thru acc-tip-rig-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-925.
      *                  *---------------------------------------------*
      *                  * Tipo impostazione : altri campi riga corpo  *
      *                  *---------------------------------------------*
           move      "R"                  to   w-cnt-mfu-tip-imp      .
       acc-cor-reg-200.
      *                  *---------------------------------------------*
      *                  * Normalizzazione func-key di impostazione    *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Eventuale pre-cablaggio della riga          *
      *                  *---------------------------------------------*
           if        w-cnt-pcr-rec-flg    not  = spaces
                     move  spaces         to   w-cnt-pcr-rec-flg
                     go to acc-cor-reg-800.
      *                  *---------------------------------------------*
      *                  * Accettazione codice addebito o commento     *
      *                  *---------------------------------------------*
           perform   acc-cod-aoc-000      thru acc-cod-aoc-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
      *                  *---------------------------------------------*
      *                  * Accettazione codice prodotto                *
      *                  *---------------------------------------------*
           perform   acc-cod-pro-000      thru acc-cod-pro-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
       acc-cor-reg-205.
      *                  *---------------------------------------------*
      *                  * Accettazione codice prodotto per il cliente *
      *                  *---------------------------------------------*
           perform   acc-cop-scl-000      thru acc-cop-scl-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-200.
      *                  *---------------------------------------------*
      *                  * Ad accettazione quantita' ordinata se :     *
      *                  * - Tipo prodotto P e tipo funzionamento spazi*
      *                  * a meno che la descrizione sia a spazi       *
      *                  *---------------------------------------------*
           if        w-rig-des-rig (1)    =    spaces
                     go to acc-cor-reg-210.
           if        w-rig-tip-rig-tpr (1)
                                          =    "P" and
                     w-rig-tip-rig-tfu (1)
                                          =    spaces
                     go to acc-cor-reg-220.
       acc-cor-reg-210.
      *                  *---------------------------------------------*
      *                  * Accettazione descrizione per la riga        *
      *                  *---------------------------------------------*
           perform   acc-des-rig-000      thru acc-des-rig-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-200.
       acc-cor-reg-220.
      *                  *---------------------------------------------*
      *                  * Accettazione quantita' ordinata             *
      *                  *---------------------------------------------*
           perform   acc-qta-ord-000      thru acc-qta-ord-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-210.
       acc-cor-reg-222.
      *                  *---------------------------------------------*
      *                  * Accettazione seconda quantita'              *
      *                  *---------------------------------------------*
           perform   acc-qta-a02-000      thru acc-qta-a02-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-220.
      *                  *---------------------------------------------*
      *                  * Ad accettazione prezzo di vendita           *
      *                  *---------------------------------------------*
           go to     acc-cor-reg-240.
       acc-cor-reg-224.
      *                  *---------------------------------------------*
      *                  * Flag non bloccante 1                        *
      *                  *---------------------------------------------*
           perform   acc-flg-xb1-000      thru acc-flg-xb1-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-220.
       acc-cor-reg-226.
      *                  *---------------------------------------------*
      *                  * Flag non bloccante 2                        *
      *                  *---------------------------------------------*
           perform   acc-flg-xb2-000      thru acc-flg-xb2-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-224.
       acc-cor-reg-228.
      *                  *---------------------------------------------*
      *                  * Flag non bloccante 3                        *
      *                  *---------------------------------------------*
           perform   acc-flg-xb3-000      thru acc-flg-xb3-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-226.
      *                  *---------------------------------------------*
      *                  * Ad accettazione prezzo di vendita           *
      *                  *---------------------------------------------*
           go to     acc-cor-reg-240.
       acc-cor-reg-230.
      *                  *---------------------------------------------*
      *                  * Accettazione sigla valuta per il prezzo     *
      *                  *---------------------------------------------*
           perform   acc-sgl-vpp-000      thru acc-sgl-vpp-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-224.
       acc-cor-reg-240.
      *                  *---------------------------------------------*
      *                  * Accettazione prezzo di vendita              *
      *                  *---------------------------------------------*
           perform   acc-prz-ven-000      thru acc-prz-ven-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-230.
       acc-cor-reg-250.
      *                  *---------------------------------------------*
      *                  * Accettazione sigla valuta per legame valu-  *
      *                  * tario                                       *
      *                  *---------------------------------------------*
           perform   acc-sgl-vpl-000      thru acc-sgl-vpl-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-240.
       acc-cor-reg-260.
      *                  *---------------------------------------------*
      *                  * Accettazione coefficiente di cambio di ri-  *
      *                  * ferimento per legame valutario              *
      *                  *---------------------------------------------*
           perform   acc-ccr-vpl-000      thru acc-ccr-vpl-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-250.
       acc-cor-reg-270.
      *                  *---------------------------------------------*
      *                  * Accettazione percentuale di limitazione per *
      *                  * legame valutario                            *
      *                  *---------------------------------------------*
           perform   acc-plm-vpl-000      thru acc-plm-vpl-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-260.
       acc-cor-reg-280.
      *                  *---------------------------------------------*
      *                  * Accettazione tipo di limitazione per legame *
      *                  * valutario                                   *
      *                  *---------------------------------------------*
           perform   acc-tlm-vpl-000      thru acc-tlm-vpl-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-270.
       acc-cor-reg-290.
      *                  *---------------------------------------------*
      *                  * Accettazione percentuali sconto in riga     *
      *                  *---------------------------------------------*
           perform   acc-per-scr-000      thru acc-per-scr-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-280.
       acc-cor-reg-300.
      *                  *---------------------------------------------*
      *                  * Accettazione importo in riga                *
      *                  *---------------------------------------------*
           perform   acc-imp-rig-000      thru acc-imp-rig-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-290.
       acc-cor-reg-310.
      *                  *---------------------------------------------*
      *                  * Accettazione data consegna richiesta        *
      *                  *---------------------------------------------*
           perform   acc-dcn-ric-000      thru acc-dcn-ric-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-300.
       acc-cor-reg-320.
      *                  *---------------------------------------------*
      *                  * Accettazione data consegna prevista         *
      *                  *---------------------------------------------*
           perform   acc-dcn-prv-000      thru acc-dcn-prv-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-310.
       acc-cor-reg-330.
      *                  *---------------------------------------------*
      *                  * Accettazione flag di conferma               *
      *                  *---------------------------------------------*
           perform   acc-flg-cnf-000      thru acc-flg-cnf-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-320.
       acc-cor-reg-340.
      *                  *---------------------------------------------*
      *                  * Flag di significativita' provvigioni in ri- *
      *                  * ga                                          *
      *                  *---------------------------------------------*
           perform   acc-fsp-rig-000      thru acc-fsp-rig-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-320.
       acc-cor-reg-350.
      *                  *---------------------------------------------*
      *                  * Accettazione percentuali di provvigione in  *
      *                  * riga                                        *
      *                  *---------------------------------------------*
           perform   acc-ppv-rig-000      thru acc-ppv-rig-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-340.
       acc-cor-reg-360.
      *                  *---------------------------------------------*
      *                  * Accettazione importo provvigione a forfait  *
      *                  * in riga                                     *
      *                  *---------------------------------------------*
           perform   acc-pvf-rig-000      thru acc-pvf-rig-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-350.
       acc-cor-reg-370.
      *                  *---------------------------------------------*
      *                  * Accettazione codice iva                     *
      *                  *---------------------------------------------*
           perform   acc-coi-rig-000      thru acc-coi-rig-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-360.
       acc-cor-reg-380.
      *                  *---------------------------------------------*
      *                  * Accettazione codice contropartita in riga   *
      *                  *---------------------------------------------*
           perform   acc-ctv-rig-000      thru acc-ctv-rig-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-370.
       acc-cor-reg-700.
      *                  *---------------------------------------------*
      *                  * Presa visione per riga corpo                *
      *                  *---------------------------------------------*
           perform   acc-pre-vrc-000      thru acc-pre-vrc-999        .
           if        w-cnt-tus-acc-rig    not  = spaces
                     go to acc-cor-reg-900.
           if        v-key                =    "UP  "
                     go to acc-cor-reg-380.
       acc-cor-reg-800.
      *              *-------------------------------------------------*
      *              * Controllo finale su riga impostata              *
      *              *-------------------------------------------------*
           perform   cnt-tdo-rig-000      thru cnt-tdo-rig-999        .
           if        w-cnt-tdo-rig-flg    not  = spaces
                     move  spaces         to   w-cnt-tdo-rig-flg
                     move  "UP  "         to   v-key
                     go to acc-cor-reg-210.
       acc-cor-reg-900.
      *              *-------------------------------------------------*
      *              * Tests per uscita significativa da interno riga  *
      *              *-------------------------------------------------*
           if        w-cnt-tus-acc-rig    =    spaces or
                     w-cnt-tus-acc-rig    =    "S"
                     go to acc-cor-reg-905
           else if   w-cnt-tus-acc-rig    =    "R"
                     go to acc-cor-reg-910.
      *                  *---------------------------------------------*
      *                  * Se Exit da interno riga                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga New funzionamento come per Remv *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to acc-cor-reg-915.
      *                      *-----------------------------------------*
      *                      * Se riga non New                         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Visualizzazione numero riga         *
      *                          *-------------------------------------*
           move      "N"                  to   w-cnt-cor-tvi-rig      .
           move      w-cnt-cor-nrg-dac    to   w-cnt-cor-nrg-dav      .
           perform   vis-lin-cor-000      thru vis-lin-cor-999        .
           go to     acc-cor-reg-000.
       acc-cor-reg-905.
      *                  *---------------------------------------------*
      *                  * Se Do da interno riga                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se record di tipo New attribuzione del  *
      *                      * numero progressivo per la riga          *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to acc-cor-reg-907.
           perform   prg-rig-cor-000      thru prg-rig-cor-999        .
       acc-cor-reg-907.
      *                      *-----------------------------------------*
      *                      * Routine post-accettazione riga          *
      *                      *-----------------------------------------*
           move      "+"                  to   w-cnt-cor-tip-agg      .
           perform   pos-rig-cor-000      thru pos-rig-cor-999        .
      *                      *-----------------------------------------*
      *                      * Update riga in catena movimenti         *
      *                      *-----------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cnt-cor-nrg-dac    to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                      *-----------------------------------------*
      *                      * Visualizzazione linea corpo             *
      *                      *-----------------------------------------*
           move      "R"                  to   w-cnt-cor-tvi-rig      .
           move      w-cnt-cor-nrg-dac    to   w-cnt-cor-nrg-dav      .
           perform   vis-lin-cor-000      thru vis-lin-cor-999        .
      *                      *-----------------------------------------*
      *                      * Incremento del numero d'ordine della    *
      *                      * riga da accettare                       *
      *                      *-----------------------------------------*
           add       1                    to   w-cnt-cor-nrg-dac      .
           go to     acc-cor-reg-000.
       acc-cor-reg-910.
      *                  *---------------------------------------------*
      *                  * Se Remv da interno riga                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga non new : routine post-accetta- *
      *                      * zione riga                              *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to acc-cor-reg-915.
           move      "-"                  to   w-cnt-cor-tip-agg      .
           perform   pos-rig-cor-000      thru pos-rig-cor-999        .
       acc-cor-reg-915.
      *                      *-----------------------------------------*
      *                      * Visualizzazione numero riga a spaces se *
      *                      * si e' in Append                         *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces and
                     w-cat-rig-lst        not  = spaces
                     move    "S"          to   w-cnt-cor-tvi-rig
                     move    w-cnt-cor-nrg-dac
                                          to   w-cnt-cor-nrg-dav
                     perform vis-lin-cor-000
                                          thru vis-lin-cor-999        .
      *                      *-----------------------------------------*
      *                      * Numero pagina attualmente  visualizzata *
      *                      * a zero per forzare la rivisualizzazione *
      *                      * a meno che non si sia in Append         *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces or
                     w-cat-rig-lst        =    spaces
                     move  zero           to   w-cnt-cor-nrp-vis      .
      *                      *-----------------------------------------*
      *                      * Rimozione record dalla catena           *
      *                      *-----------------------------------------*
           move      "RM"                 to   w-cat-rig-ope          .
           move      w-cnt-cor-nrg-dac    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                      *-----------------------------------------*
      *                      * Segnale di almeno una modifica          *
      *                      *-----------------------------------------*
           move      "#"                  to   w-cnt-acc-flg-aum      .
           go to     acc-cor-reg-000.
       acc-cor-reg-925.
      *              *-------------------------------------------------*
      *              * Tests per uscita significativa dal primo campo  *
      *              * di impostazione della riga                      *
      *              *-------------------------------------------------*
           if        w-cnt-tus-acc-rig    =    "U"
                     go to acc-cor-reg-935
           else if   w-cnt-tus-acc-rig    =    "D"
                     go to acc-cor-reg-940
           else if   w-cnt-tus-acc-rig    =    "S"
                     go to acc-cor-reg-945
           else if   w-cnt-tus-acc-rig    =    "X"
                     go to acc-cor-reg-950
           else if   w-cnt-tus-acc-rig    =    "I"
                     go to acc-cor-reg-955
           else if   w-cnt-tus-acc-rig    =    "R"
                     go to acc-cor-reg-960
           else if   w-cnt-tus-acc-rig    =    "T"
                     go to acc-cor-reg-965
           else if   w-cnt-tus-acc-rig    =    "B"
                     go to acc-cor-reg-970
           else if   w-cnt-tus-acc-rig    =    "N"
                     go to acc-cor-reg-975
           else if   w-cnt-tus-acc-rig    =    "P"
                     go to acc-cor-reg-980
           else if   w-cnt-tus-acc-rig    =    "."
                     go to acc-cor-reg-985
           else if   w-cnt-tus-acc-rig    =    "1"
                     go to acc-cor-reg-988
           else if   w-cnt-tus-acc-rig    =    "2"
                     go to acc-cor-reg-988b
           else if   w-cnt-tus-acc-rig    =    "4"
                     go to acc-cor-reg-990
           else if   w-cnt-tus-acc-rig    =    "3"
                     go to acc-cor-reg-995.
       acc-cor-reg-930.
      *                  *---------------------------------------------*
      *                  * Se Exit da primo campo di impostazione riga *
      *                  *---------------------------------------------*
           move      "E"                  to   w-cnt-tus-acc-cor      .
           go to     acc-cor-reg-997.
       acc-cor-reg-935.
      *                  *---------------------------------------------*
      *                  * Se Up da primo campo di impostazione riga   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se record New                           *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to acc-cor-reg-936.
      *                          *-------------------------------------*
      *                          * Visualizzazione del numero riga a   *
      *                          * spaces se si e' in Append           *
      *                          *-------------------------------------*
           if        w-cat-rig-new        not  = spaces and
                     w-cat-rig-lst        not  = spaces
                     move    "S"          to   w-cnt-cor-tvi-rig
                     move    w-cnt-cor-nrg-dac
                                          to   w-cnt-cor-nrg-dav
                     perform vis-lin-cor-000
                                          thru vis-lin-cor-999        .
      *                          *-------------------------------------*
      *                          * Numero pagina attualmente visualiz- *
      *                          * zata a zero per forzare la rivisua- *
      *                          * lizzazione,  a meno che non si sia  *
      *                          * in Append                           *
      *                          *-------------------------------------*
           if        w-cat-rig-new        =    spaces or
                     w-cat-rig-lst        =    spaces
                     move  zero           to   w-cnt-cor-nrp-vis      .
      *                          *-------------------------------------*
      *                          * Rimozione record dalla catena       *
      *                          *-------------------------------------*
           move      "RM"                 to   w-cat-rig-ope          .
           move      w-cnt-cor-nrg-dac    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
           go to     acc-cor-reg-937.
       acc-cor-reg-936.
      *                      *-----------------------------------------*
      *                      * Se record non New                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Visualizzazione del numero riga     *
      *                          *-------------------------------------*
           move      "N"                  to   w-cnt-cor-tvi-rig      .
           move      w-cnt-cor-nrg-dac    to   w-cnt-cor-nrg-dav      .
           perform   vis-lin-cor-000      thru vis-lin-cor-999        .
       acc-cor-reg-937.
      *                          *-------------------------------------*
      *                          * Se si e' sulla riga numero 1        *
      *                          *-------------------------------------*
           if        w-cnt-cor-nrg-dac    =    1
                     move  "-"            to   w-cnt-tus-acc-cor
                     go to acc-cor-reg-997.
      *                          *-------------------------------------*
      *                          * Se non si e' sulla riga numero 1    *
      *                          *-------------------------------------*
           subtract  1                    from w-cnt-cor-nrg-dac      .
           go to     acc-cor-reg-000.
       acc-cor-reg-940.
      *                  *---------------------------------------------*
      *                  * Se Down da primo campo di impostazione riga *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se record New                           *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to acc-cor-reg-941.
      *                          *-------------------------------------*
      *                          * Se si e' in Append si prepara il    *
      *                          * tipo uscita "+" e si visualizza il  *
      *                          * numero riga a spaces                *
      *                          *-------------------------------------*
           if        w-cat-rig-new        not  = spaces and
                     w-cat-rig-lst        not  = spaces
                     move    "+"          to   w-cnt-tus-acc-cor
                     move    "S"          to   w-cnt-cor-tvi-rig
                     move    w-cnt-cor-nrg-dac
                                          to   w-cnt-cor-nrg-dav
                     perform vis-lin-cor-000
                                          thru vis-lin-cor-999
      *                          *-------------------------------------*
      *                          * Altrimenti si prepara il numero pa- *
      *                          * gina attualmente visualizzata a ze- *
      *                          * ro per forzare la rivisualizzazione *
      *                          *-------------------------------------*
           else      move  zero           to   w-cnt-cor-nrp-vis      .
      *                          *-------------------------------------*
      *                          * Rimozione record dalla catena       *
      *                          *-------------------------------------*
           move      "RM"                 to   w-cat-rig-ope          .
           move      w-cnt-cor-nrg-dac    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                          *-------------------------------------*
      *                          * Se si era in Append : uscita        *
      *                          *-------------------------------------*
           if        w-cnt-tus-acc-cor    =    "+"
                     go to acc-cor-reg-997
      *                          *-------------------------------------*
      *                          * Altrimenti : riciclo                *
      *                          *-------------------------------------*
           else      go to acc-cor-reg-000.
       acc-cor-reg-941.
      *                      *-----------------------------------------*
      *                      * Se record non New                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Visualizzazione del numero riga     *
      *                          *-------------------------------------*
           move      "N"                  to   w-cnt-cor-tvi-rig      .
           move      w-cnt-cor-nrg-dac    to   w-cnt-cor-nrg-dav      .
           perform   vis-lin-cor-000      thru vis-lin-cor-999        .
      *                          *-------------------------------------*
      *                          * Incremento del numero riga          *
      *                          *-------------------------------------*
           add       1                    to   w-cnt-cor-nrg-dac      .
           go to     acc-cor-reg-000.
       acc-cor-reg-945.
      *                  *---------------------------------------------*
      *                  * Se Do da primo campo di impostazione riga   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se record New                           *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces
