           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      w-prn-ini-lr2-pnt    to   p-car                  .
           move      p-lnr                to   p-lin                  .
           divide    2                    into w-prn-ini-lr2-ctr
                                        giving p-pos                  .
           add       35                   to   p-pos                  .
           move      w-prn-ini-lr2-x63    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
