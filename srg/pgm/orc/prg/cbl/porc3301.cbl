      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [ocr]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofocr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocr                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-tot-doc-900.
       det-tot-doc-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-ocr-num-prt       not  = w-rot-l01-num-prt
                     go to det-tot-doc-900.
       det-tot-doc-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo riga in comodo ridefinito              *
      *                  *---------------------------------------------*
           move      rf-ocr-tip-rig       to   w-stp-srt-inp-wtr      .
      *                  *---------------------------------------------*
      *                  * Se tipo riga 'C' o 'A' : riciclo            *
      *                  *---------------------------------------------*
           if        w-stp-srt-inp-wtp    =    "C" or
                     w-stp-srt-inp-wtp    =    "A"
                     go to det-tot-doc-200.
       det-tot-doc-600.
      *              *-------------------------------------------------*
      *              * Bufferizzazione delle quantita'                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione inevaso                      *
      *                  *---------------------------------------------*
           move      "DT"                 to   d-qev-roc-tip-ope      .
           perform   det-qev-roc-cll-000  thru det-qev-roc-cll-999    .
      *                  *---------------------------------------------*
      *                  * Valore inevaso                              *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-tot-doc-imp      .
           multiply  d-qev-roc-qta-dev    by   rf-ocr-prz-net
                                        giving w-det-tot-doc-imp      .
           add       w-det-tot-doc-imp    to   w-det-tot-doc-ine      .
      *                  *---------------------------------------------*
      *                  * Valore in ordine                            *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-tot-doc-imp      .
           multiply  rf-ocr-qta-ord       by   rf-ocr-prz-net
                                        giving w-det-tot-doc-imp      .
           add       w-det-tot-doc-imp    to   w-det-tot-doc-tot      .
       det-tot-doc-800.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     det-tot-doc-200.
       det-tot-doc-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-tot-doc-999.
       det-tot-doc-999.
           exit.

      *    *===========================================================*
      *    * Determinazione % di variazione                            *
      *    *-----------------------------------------------------------*
       det-per-var-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valori in output                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-per-var-per      .
       det-per-var-100.
      *              *-------------------------------------------------*
      *              * Test preliminari                                *
      *              *-------------------------------------------------*
           if        w-det-per-var-v01    =    zero or
                     w-det-per-var-v02    =    zero
                     go to det-per-var-900.
           if        w-det-per-var-v01    >    zero and
                     w-det-per-var-v02    <    zero
                     go to det-per-var-900.
           if        w-det-per-var-v01    <    zero and
                     w-det-per-var-v02    >    zero
                     go to det-per-var-900.
       det-per-var-200.
      *              *-------------------------------------------------*
      *              * Calcolo                                         *
      *              *-------------------------------------------------*
           divide    w-det-per-var-v01    into w-det-per-var-v02
                                        giving w-det-per-var-per      .
           multiply  100                  by   w-det-per-var-per      .
       det-per-var-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-per-var-999.
       det-per-var-999.
           exit.

