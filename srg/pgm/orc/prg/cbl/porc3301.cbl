           move      "<D"                 to   p-edm                  .
           move      srt-plm-vpl          to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                              *---------------------------------*
      *                              * String                          *
      *                              *---------------------------------*
           string    p-edt
                                delimited by   spaces
                     "%"        delimited by   size
                                          into w-stp-cor-doc-x40
                                  with pointer w-stp-cor-doc-pnt      .
       prn-liv-det-lgv-400.
      *                          *-------------------------------------*
      *                          * Tipo di limitazione                 *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Deviazione in funzione del va-  *
      *                              * lore                            *
      *                              *---------------------------------*
           if        srt-tlm-vpl          =    "T"
                     go to prn-liv-det-lgv-420
           else if   srt-tlm-vpl          =    "F"
                     go to prn-liv-det-lgv-440
           else if   srt-tlm-vpl          =    "M"
                     go to prn-liv-det-lgv-460
           else      go to prn-liv-det-lgv-500.
       prn-liv-det-lgv-420.
      *                          *-------------------------------------*
      *                          * Tipo di limitazione : Tolleranza    *
      *                          *-------------------------------------*
           go to     prn-liv-det-lgv-500.
       prn-liv-det-lgv-440.
      *                          *-------------------------------------*
      *                          * Tipo di limitazione : Franchigia    *
      *                          *-------------------------------------*
           string    " Fr."
                                delimited by   size
                                          into w-stp-cor-doc-x40
                                  with pointer w-stp-cor-doc-pnt      .
           go to     prn-liv-det-lgv-500.
       prn-liv-det-lgv-460.
      *                          *-------------------------------------*
      *                          * Tipo di limitazione : Tetto massimo *
      *                          *-------------------------------------*
           string    " Max"
                                delimited by   size
                                          into w-stp-cor-doc-x40
                                  with pointer w-stp-cor-doc-pnt      .
           go to     prn-liv-det-lgv-500.
       prn-liv-det-lgv-500.
      *                  *---------------------------------------------*
      *                  * Stampa stringa                              *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      40                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      016                  to   p-pos                  .
           move      w-stp-cor-doc-x40    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       prn-liv-det-lgv-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     prn-liv-det-lgv-999.
       prn-liv-det-lgv-999.
           exit.

      *    *===========================================================*
      *    * Stampa valori totali                                      *
      *    *-----------------------------------------------------------*
       stp-val-tot-000.
      *              *-------------------------------------------------*
      *              * Composizione stringa                            *
      *              *-------------------------------------------------*
           move      spaces               to   w-stp-val-tot-x60      .
           move      1                    to   w-stp-val-tot-pnt      .
      *              *-------------------------------------------------*
      *              * Prompt                                          *
      *              *-------------------------------------------------*
           string    w-stp-val-tot-pmt
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
      *              *-------------------------------------------------*
      *              * Allineamento all'ultimo non-blank               *
      *              *-------------------------------------------------*
           move      zero                 to   w-stp-val-tot-ctr      .
           inspect   w-stp-val-tot-x60    
                                      tallying w-stp-val-tot-ctr
                                          for  trailing spaces        .
           subtract  w-stp-val-tot-ctr    from 60
                                        giving w-stp-val-tot-pnt      .
           add       1                    to   w-stp-val-tot-pnt      .
      *              *-------------------------------------------------*
      *              * Totale documento in valuta base se documento in *
      *              * valuta                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da stampare                         *
      *                  *---------------------------------------------*
           if        w-stp-val-tot-vlt    =    c-sgl
                     go to stp-val-tot-100.
           if        w-stp-val-tot-tot    =    zero
                     go to stp-val-tot-100.
      *                  *---------------------------------------------*
      *                  * Editing                                     *
      *                  *---------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           move      11                   to   p-car                  .
           move      c-dec                to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      "G<"                 to   p-edm                  .
           move      w-stp-val-tot-tot    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * String                                      *
      *                  *---------------------------------------------*
           string    " ("
                                delimited by   size
                     c-sgl
                                delimited by   size
                     " "
                                delimited by   size
                     p-edt
                                delimited by   spaces
                     ")"
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
       stp-val-tot-100.
      *              *-------------------------------------------------*
      *              * Due punti di separazione                        *
      *              *-------------------------------------------------*
           string    " : "
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda che il documento sia in    *
      *              * valuta o no                                     *
      *              *-------------------------------------------------*
           if        w-stp-val-tot-vlt    not  = c-sgl
                     go to stp-val-tot-200
           else      go to stp-val-tot-300.
       stp-val-tot-200.
      *              *-------------------------------------------------*
      *              * Se documento in valuta                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Sigla valuta                                *
      *                  *---------------------------------------------*
           string    w-stp-val-tot-vlt
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
      *                  *---------------------------------------------*
      *                  * Totale in valuta                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing                                 *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           if        w-stp-val-tot-tiv    >    999999999 or
                     w-stp-val-tot-tiv    <   -999999999
                     move  11             to   p-car
           else      move  09             to   p-car                  .
           move      w-stp-val-tot-dcv    to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           if        w-stp-val-tot-tiv    >    999999999 or
                     w-stp-val-tot-tiv    <   -999999999
                     move  spaces         to   p-edm
           else      move  "G"            to   p-edm                  .
           move      w-stp-val-tot-tiv    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * String                                  *
      *                      *-----------------------------------------*
           string    p-edt
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
      *                  *---------------------------------------------*
      *                  * A stampa stringa composta                   *
      *                  *---------------------------------------------*
           go to     stp-val-tot-500.
       stp-val-tot-300.
      *              *-------------------------------------------------*
      *              * Se documento in valuta base                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Totale in valuta base                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing                                 *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           if        w-stp-val-tot-tot    >    999999999 or
                     w-stp-val-tot-tot    <   -999999999
                     move  11             to   p-car
           else      move  09             to   p-car                  .
           move      c-dec                to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           if        w-stp-val-tot-tot    >    999999999 or
                     w-stp-val-tot-tot    <   -999999999
                     move  spaces         to   p-edm
           else      move  "G"            to   p-edm                  .
           move      w-stp-val-tot-tot    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * String                                  *
      *                      *-----------------------------------------*
           string    p-edt
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
      *                  *---------------------------------------------*
      *                  * A stampa stringa composta                   *
      *                  *---------------------------------------------*
           go to     stp-val-tot-500.
       stp-val-tot-500.
      *              *-------------------------------------------------*
      *              * Riposizionamento puntatore                      *
      *              *-------------------------------------------------*
           move      zero                 to   w-stp-val-tot-ctr      .
           inspect   w-stp-val-tot-x60    
                                      tallying w-stp-val-tot-ctr
                                          for  trailing spaces        .
           subtract  w-stp-val-tot-ctr    from 60
                                        giving w-stp-val-tot-pnt      .
           add       1                    to   w-stp-val-tot-pnt      .
      *              *-------------------------------------------------*
      *              * Stampa stringa composta                         *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      w-stp-val-tot-pnt    to   p-car                  .
           move      p-lnr                to   p-lin                  .
           subtract  w-stp-val-tot-pnt    from 123
                                        giving p-pos                  .
           add       2                    to   p-pos                  .
           move      w-stp-val-tot-x60    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-val-tot-999.
           exit.

      *    *===========================================================*
      *    * Intestazione foglio                                       *
      *    *-----------------------------------------------------------*
       int-pag-sta-000.
      *              *-------------------------------------------------*
      *              * Preparazione parametri intestazione standard    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Composizione titolo                         *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-tit-des-tit      .
           move      1                    to   w-int-pag-sta-pnt      .
      *
           string    "PORTAFOGLIO ORDINI"
                                delimited by   size
                                          into w-cnt-tit-des-tit
                                  with pointer w-int-pag-sta-pnt      .
      *
           if        rr-sts-orc           =   01
                     move  " DA EVADERE"  to  w-int-pag-sta-x30
           else if   rr-sts-orc           =   02
                     move  " IN CORSO DI SPEDIZIONE"
                                          to  w-int-pag-sta-x30
           else if   rr-sts-orc           =   03
                     move  " EVASI"
                                          to  w-int-pag-sta-x30
           else if   rr-sts-orc           =   04
                     move  spaces         to  w-int-pag-sta-x30       .
      *
           string    w-int-pag-sta-x30
                                delimited by   size
                                          into w-cnt-tit-des-tit
                                  with pointer w-int-pag-sta-pnt      .
      *
           move      zero                 to   w-int-pag-sta-ctr      .
           inspect   w-cnt-tit-des-tit    
                                      tallying w-int-pag-sta-ctr
                                          for  trailing spaces        .
           subtract  w-int-pag-sta-ctr    from 80
                                        giving w-int-pag-sta-pnt      .
           add       1                    to   w-int-pag-sta-pnt      .
      *
           string    " PER CLIENTE"
                                delimited by   size
                                          into w-cnt-tit-des-tit
                                  with pointer w-int-pag-sta-pnt      .
      *
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-cnt-tit-dat-stp      .
           move      p-pag                to   w-cnt-tit-num-pag      .
           add       1                    to   w-cnt-tit-num-pag      .
      *              *-------------------------------------------------*
