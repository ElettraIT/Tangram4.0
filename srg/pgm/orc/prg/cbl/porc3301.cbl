      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Interlinea                              *
      *                      *-----------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Stampa                                  *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      12                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      112                  to   p-pos                  .
           move      "============"       to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Totale generale                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Interlinea                              *
      *                      *-----------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Richiamo routine per stampa valori      *
      *                      *-----------------------------------------*
           move      "Totale generale   " to   w-stp-val-tot-pmt      .
           if        w-tot-gen-vpf        =    spaces
                     move  c-sgl          to   w-stp-val-tot-vlt
           else      move  w-tot-gen-vpf  to   w-stp-val-tot-vlt
                     move  w-tot-gen-dpf  to   w-stp-val-tot-dcv      .
           move      w-tot-gen-tot        to   w-stp-val-tot-tot      .
           move      w-tot-gen-tiv        to   w-stp-val-tot-tiv      .
           perform   stp-val-tot-000      thru stp-val-tot-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione % di variazione valore   *
      *                      *-----------------------------------------*
           if        w-tot-gen-tvi        =    w-tot-gen-tvo
                     go to prn-fin-cic-600.
      *
           move      w-tot-gen-tvo        to   w-det-per-var-v01      .
           move      w-tot-gen-tvi        to   w-det-per-var-v02      .
           perform   det-per-var-000      thru det-per-var-999        .
      *
           if        w-det-per-var-per    <    1   and
                     w-det-per-var-per    >   -1
                     go to prn-fin-cic-600.
      *
           if        w-det-per-var-per    <   -100  or
                     w-det-per-var-per    >   100
                     move  100            to   w-det-per-var-per      .
      *                      *-----------------------------------------*
      *                      * Editing % delta                         *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      03                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<B"                 to   p-edm                  .
           move      w-det-per-var-per    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
