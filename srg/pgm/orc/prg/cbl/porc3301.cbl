      *    *===========================================================*
      *    * Determinazione descrizione riga ordine                    *
      *    *                                                           *
      *    * Input  :                                                  *
      *    *                                                           *
      *    *    - Record di [ocr] relativo alla riga ordine cliente a  *
      *    *      disposizione in rf-ocr                               *
      *    *                                                           *
      *    *    - Record di [dcc] relativo alla riga ordine cliente    *
      *    *                                                           *
      *    * Output :                                                  *
      *    *                                                           *
      *    *    - w-det-des-rig-des : Descrizione riga ordine          *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       det-des-rig-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore in uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-des-rig-des      .
       det-des-rig-010.
      *              *-------------------------------------------------*
      *              * Lettura preliminare estensione in file [ocx]    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [ocx]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofocx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocx                 .
      *                  *---------------------------------------------*
      *                  * Lettura file [ocx]                          *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-ocr-num-prt       to   rf-ocx-num-prt         .
           move      rf-ocr-num-prg       to   rf-ocx-num-prg         .
           move      11                   to   rf-ocx-tip-rec         .
           move      "pgm/orc/fls/ioc/obj/iofocx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocx                 .
      *
           if        f-sts                not  = e-not-err
                     go to det-des-rig-050.
      *
           move      rf-ocx-des-400       to   w-det-des-rig-des      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-des-rig-999.
       det-des-rig-050.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del flag di estensione   *
      *              * alla descrizione                                *
      *              *-------------------------------------------------*
           if        rf-ocr-des-ext       =    0
                     go to det-des-rig-100
           else if   rf-ocr-des-ext       =    1
                     go to det-des-rig-200
           else if   rf-ocr-des-ext       =    2
                     go to det-des-rig-300.
       det-des-rig-100.
      *              *-------------------------------------------------*
      *              * Se nessuna estensione : bufferizzazione descri- *
      *              * zione contenuta nel record [ocr]                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Descrizione                                 *
      *                  *---------------------------------------------*
           move      rf-ocr-des-rig       to   w-det-des-rig-des      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-des-rig-999.
       det-des-rig-200.
      *              *-------------------------------------------------*
      *              * Se estensione nel file [ocx]                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-des-rig-999.
       det-des-rig-300.
      *              *-------------------------------------------------*
      *              * Se estensione nel file [pdx]                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tentativo di lettura di una descrizione     *
      *                  * legata al cliente                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura archivio [pdx]                  *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "TRCLNG"             to   f-key                  .
           move      03                   to   rf-pdx-tip-rec         .
           move      rf-ocr-cod-arc       to   rf-pdx-cod-arc         .
           move      spaces               to   rf-pdx-cod-lng         .
           move      rf-ocr-num-pro       to   rf-pdx-cod-num         .
           move      spaces               to   rf-pdx-for-mat         .
           move      zero                 to   rf-pdx-num-prg         .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
      *                      *-----------------------------------------*
      *                      * Test su esito operazione                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-des-rig-305.
      *                      *-----------------------------------------*
      *                      * Se record trovato : bufferizzazione de- *
      *                      * scrizione e uscita                      *
      *                      *-----------------------------------------*
           move      rf-pdx-des-pro       to   w-det-des-rig-des      .
           go to     det-des-rig-999.
       det-des-rig-305.
      *                  *---------------------------------------------*
      *                  * Se codice lingua 'I  '                      *
      *                  *---------------------------------------------*
           if        rf-ocr-cod-lng       not  = "I  "
                     go to det-des-rig-350.
       det-des-rig-310.
      *                      *-----------------------------------------*
      *                      * Lettura archivio [pdx]                  *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "TRCLNG"             to   f-key                  .
           move      01                   to   rf-pdx-tip-rec         .
           move      zero                 to   rf-pdx-cod-arc         .
           move      "I  "                to   rf-pdx-cod-lng         .
           move      rf-ocr-num-pro       to   rf-pdx-cod-num         .
           move      spaces               to   rf-pdx-for-mat         .
           move      01                   to   rf-pdx-num-prg         .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
           if        f-sts                not  = e-not-err
                     move  all "."        to   rf-pdx-des-pro         .
           move      rf-pdx-des-pro       to   w-det-des-rig-des      .
           go to     det-des-rig-999.
       det-des-rig-350.
      *                  *---------------------------------------------*
      *                  * Se codice lingua diverso da 'I  '           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tentativo di lettura file [pdx] per de- *
      *                      * scrizione in lingua estera              *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "TRCLNG"             to   f-key                  .
           move      02                   to   rf-pdx-tip-rec         .
           move      zero                 to   rf-pdx-cod-arc         .
           move      rf-ocr-cod-lng       to   rf-pdx-cod-lng         .
           move      rf-ocr-num-pro       to   rf-pdx-cod-num         .
           move      spaces               to   rf-pdx-for-mat         .
           move      01                   to   rf-pdx-num-prg         .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
           if        f-sts                not  = e-not-err
                     go to det-des-rig-310.
           move      rf-pdx-des-pro       to   w-det-des-rig-des      .
           go to     det-des-rig-999.
       det-des-rig-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale documento                           *
      *    *                                                           *
      *    * Ciclo di scansione delle righe ordine per determinare i   *
      *    * valori di inevasione per confronto tra i valori           *
      *    *-----------------------------------------------------------*
       det-tot-doc-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valori di uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-doc-tot      .
           move      zero                 to   w-det-tot-doc-ine      .
       det-tot-doc-100.
