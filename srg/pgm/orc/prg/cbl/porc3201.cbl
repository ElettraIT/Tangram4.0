           move      w-ref-int-frm-ctr    to   s-num                  .
           move      "pgm/orc/mov/orc320[int-frm]"
                                          to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
