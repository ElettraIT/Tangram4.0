      *                  * Bufferizzazione prezzo netto contenuto nel  *
      *                  * record                                      *
      *                  *---------------------------------------------*
           move      rf-ocr-prz-net       to   w-stp-srt-inp-prz      .
       stp-srt-inp-320.
      *              *-------------------------------------------------*
      *              * Determinazione importo residuo nella valuta di  *
      *              * fatturazione                                    *
      *              *-------------------------------------------------*
           perform   stp-srt-inp-irs-000  thru stp-srt-inp-irs-999    .
       stp-srt-inp-340.
      *              *-------------------------------------------------*
      *              * Preparazione record di Sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione iniziale                    *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Chiave di sort                              *
      *                  *---------------------------------------------*
           move      rf-ocr-dat-doc       to   srt-dat-doc            .
           move      rf-ocr-num-doc       to   srt-num-doc            .
           move      rf-ocr-num-prt       to   srt-num-prt            .
      *
           if        rr-ord-rig           =    01
                     move  spaces         to   srt-ubi-key
                     move  spaces         to   srt-alf-key
           else if   rr-ord-rig           =    02
                     move  d-prm-ubi-ubi-lit
                                          to   srt-ubi-key
                     move  rf-ocr-alf-pro to   srt-alf-key
           else if   rr-ord-rig           =    03
                     move  spaces         to   srt-ubi-key
                     move  rf-ocr-alf-pro to   srt-alf-key
           else if   rr-ord-rig           =    04
                     move  spaces         to   srt-ubi-key
                     move  rf-dcp-syn-pro to   srt-alf-key
           else      move  spaces         to   srt-ubi-key
                     move  spaces         to   srt-alf-key            .
      *
           move      rf-ocr-num-prg       to   srt-num-prg            .
      *                  *---------------------------------------------*
      *                  * Dati di sort                                *
      *                  *---------------------------------------------*
           move      rf-ocr-cop-scl       to   srt-cop-scl            .
           move      rf-ocr-sgl-vpf       to   srt-sgl-vpf            .
           move      rf-ocr-dec-vpf       to   srt-dec-vpf            .
           move      rf-ocr-tdc-vpf       to   srt-tdc-vpf            .
           move      rf-ocr-cdc-vpf       to   srt-cdc-vpf            .
           move      rf-ocr-tip-arc       to   srt-tip-arc            .
           move      rf-ocr-cod-arc       to   srt-cod-arc            .
           move      rf-ocr-dpz-arc       to   srt-dpz-arc            .
           move      w-stp-srt-inp-rag    to   srt-rag-soc            .
           move      rf-ocr-ocl-dat       to   srt-ocl-dat            .
           move      rf-ocr-ocl-num       to   srt-ocl-num            .
           move      rf-ocr-dcn-prv       to   srt-dcn-prv            .
           move      rf-ocr-alf-pro       to   srt-alf-pro            .
           move      rf-ocr-num-pro       to   srt-num-pro            .
           move      rf-dcp-syn-pro       to   srt-syn-pro            .
           move      d-prm-ubi-ubi-lit    to   srt-prm-ubi            .
           if        w-stp-srt-inp-wtf    =    "N"
                     move  spaces         to   srt-alf-pro            .
           move      w-det-des-rig-des    to   srt-des-rig            .
           move      rf-ocr-tmo-orc       to   srt-tip-mov            .
           move      rf-ocr-sgl-vpp       to   srt-sgl-vpp            .
           move      rf-ocr-dec-vpp       to   srt-dec-vpp            .
           move      rf-ocr-dec-prz       to   srt-dec-prz            .
           move      w-stp-srt-inp-prz    to   srt-prz-net            .
           move      w-stp-srt-inp-ipr    to   srt-imp-res            .
           move      d-qev-roc-qta-ord    to   srt-qta-ord            .
           move      d-qev-roc-qta-gsp    to   srt-qta-gsp            .
           move      d-qev-roc-qta-ics    to   srt-qta-ics            .
           move      d-qev-roc-qta-dev    to   srt-qta-dev            .
      *                      *-----------------------------------------*
      *                      * Se riga di addebito : normalizzazione   *
      *                      *-----------------------------------------*
           if        w-stp-srt-inp-wtp    =    "A"
                     move  zero           to   srt-qta-ord
                     move  zero           to   srt-qta-gsp
                     move  zero           to   srt-qta-ics
                     move  zero           to   srt-qta-dev
                     move  spaces         to   srt-sgl-vpl
                     move  zero           to   srt-dec-vpl
                     move  spaces         to   srt-tdc-vpl
                     move  zero           to   srt-prz-vpl
                     move  zero           to   srt-cdc-vpl
                     move  zero           to   srt-ccr-vpl
                     move  zero           to   srt-plm-vpl
                     move  spaces         to   srt-tlm-vpl
                     move  spaces         to   srt-map-vpl
                     go to stp-srt-inp-380.
      *                      *-----------------------------------------*
      *                      * Legame valutario                        *
      *                      *-----------------------------------------*
           move      rf-ocr-sgl-vpl       to   srt-sgl-vpl            .
           move      rf-ocr-dec-vpl       to   srt-dec-vpl            .
           move      rf-ocr-tdc-vpl       to   srt-tdc-vpl            .
           move      rf-ocr-prz-vpl       to   srt-prz-vpl            .
           move      rf-ocr-cdc-vpl       to   srt-cdc-vpl            .
           move      rf-ocr-ccr-vpl       to   srt-ccr-vpl            .
           move      rf-ocr-plm-vpl       to   srt-plm-vpl            .
           move      rf-ocr-tlm-vpl       to   srt-tlm-vpl            .
           move      rf-ocr-map-vpl       to   srt-map-vpl            .
       stp-srt-inp-380.
      *                      *-----------------------------------------*
      *                      * Flag di prezzo per quantita'            *
      *                      *-----------------------------------------*
           move      rf-ocr-flg-puq       to   srt-flg-puq            .
       stp-srt-inp-700.
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale record [ocr]     *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Subroutine per il test sul massimo                        *
      *    *-----------------------------------------------------------*
       stp-srt-inp-max-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-stp-srt-inp-max      .
       stp-srt-inp-max-100.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione delle richieste          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su data minima                         *
      *                  *---------------------------------------------*
           if        rr-dat-min           =    zero
                     go to stp-srt-inp-max-300.
       stp-srt-inp-max-200.
      *              *-------------------------------------------------*
      *              * Se ordinamento per data documento               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su data documento                      *
      *                  *---------------------------------------------*
           if        rf-oct-dat-doc       >    rr-dat-max
                     go to stp-srt-inp-max-900.
      *                  *---------------------------------------------*
      *                  * Test su codice dipendenza                   *
      *                  *---------------------------------------------*
______*    if        rf-oct-cod-dpz       not  = rr-dpz-inu
______*              go to stp-srt-inp-max-900.
      *                  *---------------------------------------------*
      *                  * Ad uscita per test superato                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-max-800.
       stp-srt-inp-max-300.
      *              *-------------------------------------------------*
      *              * Se ordinamento per flag di chiusura             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice dipendenza                   *
      *                  *---------------------------------------------*
           if        rf-oct-cod-dpz       not  = rr-dpz-inu
                     go to stp-srt-inp-max-900.
      *                  *---------------------------------------------*
      *                  * Test su flag di ordine chiuso               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione dello stato de-  *
      *                      * gli ordini richiesto                    *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-max-321
                     stp-srt-inp-max-322
                     stp-srt-inp-max-323
                     stp-srt-inp-max-324
                     depending            on   rr-sts-orc             .
       stp-srt-inp-max-321.
      *                      *-----------------------------------------*
      *                      * Se solo ordini da evadere               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test su flag di ordine chiuso       *
      *                          *-------------------------------------*
           if        rf-oct-flg-och       not  = spaces
                     go to stp-srt-inp-max-900.
      *                          *-------------------------------------*
      *                          * Ad uscita per test superato         *
      *                          *-------------------------------------*
           go to     stp-srt-inp-max-800.
       stp-srt-inp-max-322.
      *                      *-----------------------------------------*
      *                      * Se solo ordini in spedizione            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test su flag di ordine chiuso       *
      *                          *-------------------------------------*
           if        rf-oct-flg-och       not  = spaces
                     go to stp-srt-inp-max-900.
      *                          *-------------------------------------*
      *                          * Ad uscita per test superato         *
      *                          *-------------------------------------*
           go to     stp-srt-inp-max-800.
       stp-srt-inp-max-323.
      *                      *-----------------------------------------*
      *                      * Se solo ordini gia' evasi               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Ad uscita per test superato         *
      *                          *-------------------------------------*
           go to     stp-srt-inp-max-800.
       stp-srt-inp-max-324.
      *                      *-----------------------------------------*
      *                      * Se tutti gli ordini                     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Ad uscita per test superato         *
      *                          *-------------------------------------*
           go to     stp-srt-inp-max-800.
       stp-srt-inp-max-800.
      *              *-------------------------------------------------*
      *              * Uscita per test superato                        *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-max-999.
       stp-srt-inp-max-900.
      *              *-------------------------------------------------*
      *              * Uscita per test non superato                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita                              *
      *                  *---------------------------------------------*
           move      "#"                  to   w-stp-srt-inp-max      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-max-999.
       stp-srt-inp-max-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Subroutine per le selezioni                               *
      *    *-----------------------------------------------------------*
       stp-srt-inp-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-stp-srt-inp-sel      .
       stp-srt-inp-sel-100.
      *              *-------------------------------------------------*
      *              * Selezione sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice dipendenza                   *
      *                  *---------------------------------------------*
           if        rf-oct-cod-dpz       not  = rr-dpz-inu
                     go to stp-srt-inp-sel-900.
      *                  *---------------------------------------------*
      *                  * Test su codice cliente                      *
      *                  *---------------------------------------------*
           if        rf-oct-cod-arc       <    rr-cli-min or
                     rf-oct-cod-arc       >    rr-cli-max
                     go to stp-srt-inp-sel-900.
      *                  *---------------------------------------------*
      *                  * Test su codice agente                       *
      *                  *---------------------------------------------*
           if        rr-cod-age           =    zero
                     go to stp-srt-inp-sel-130.
           if        rf-oct-cod-age       not  = rr-cod-age
                     go to stp-srt-inp-sel-900.
       stp-srt-inp-sel-130.
      *                  *---------------------------------------------*
      *                  * Test su flag di ordine chiuso               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione delle richieste  *
      *                      *-----------------------------------------*
           if        rr-dat-min           =    zero
                     go to stp-srt-inp-sel-135.
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione dello stato de-  *
      *                      * gli ordini richiesto                    *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-sel-131
                     stp-srt-inp-sel-132
                     stp-srt-inp-sel-133
                     stp-srt-inp-sel-134
                     depending            on   rr-sts-orc             .
       stp-srt-inp-sel-131.
      *                      *-----------------------------------------*
      *                      * Se solo ordini da evadere               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test su flag di ordine chiuso       *
      *                          *-------------------------------------*
           if        rf-oct-flg-och       not  = spaces
                     go to stp-srt-inp-sel-900.
      *                          *-------------------------------------*
      *                          * A selezione superata                *
      *                          *-------------------------------------*
           go to     stp-srt-inp-sel-135.
       stp-srt-inp-sel-132.
      *                      *-----------------------------------------*
      *                      * Se solo ordini in spedizione            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test su flag di ordine chiuso       *
      *                          *-------------------------------------*
           if        rf-oct-flg-och       not  = spaces
                     go to stp-srt-inp-sel-900.
      *                          *-------------------------------------*
      *                          * A selezione superata                *
      *                          *-------------------------------------*
           go to     stp-srt-inp-sel-135.
       stp-srt-inp-sel-133.
      *                      *-----------------------------------------*
      *                      * Se solo ordini gia' evasi               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test su flag di ordine chiuso       *
      *                          *-------------------------------------*
           if        rf-oct-flg-och       not  = spaces
                     go to stp-srt-inp-sel-900.
      *                          *-------------------------------------*
      *                          * A selezione superata                *
      *                          *-------------------------------------*
           go to     stp-srt-inp-sel-135.
       stp-srt-inp-sel-134.
      *                      *-----------------------------------------*
      *                      * Se tutti gli ordini                     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * A selezione superata                *
      *                          *-------------------------------------*
           go to     stp-srt-inp-sel-135.
       stp-srt-inp-sel-135.
      *                  *---------------------------------------------*
      *                  * Test su tipo movimento                      *
      *                  *---------------------------------------------*
           if        rr-tip-mov           =    spaces
                     go to stp-srt-inp-sel-140.
           if        rf-oct-tmo-orc       not  = rr-tip-mov
                     go to stp-srt-inp-sel-900.
       stp-srt-inp-sel-140.
      *                  *---------------------------------------------*
      *                  * Test su data ordine minima e massima        *
      *                  *---------------------------------------------*
           if        rf-oct-dat-doc       <    rr-dat-min
                     go to stp-srt-inp-sel-145.
           if        rf-oct-dat-doc       >    rr-dat-max
                     go to stp-srt-inp-sel-145.
           go to     stp-srt-inp-sel-160.
       stp-srt-inp-sel-145.
      *                  *---------------------------------------------*
      *                  * Se selezione per data non superata, test se *
      *                  * ordine movimentato nel periodo              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da effettuare                   *
      *                      *-----------------------------------------*
           if        rr-opz-stp-mov       =    spaces
                     go to stp-srt-inp-sel-155.
      *                      *-----------------------------------------*
      *                      * Start su file [bir]                     *
      *                      *-----------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "RIFORC    "         to   f-key                  .
           move      rf-oct-cod-dpz       to   rf-bir-cod-dpz         .
           move      rf-oct-num-prt       to   rf-bir-coc-prt         .
           move      zero                 to   rf-bir-coc-prg         .
           move      zero                 to   rf-bir-num-prt         .
           move      zero                 to   rf-bir-num-prg         .
           move      "pgm/bol/fls/ioc/obj/iofbir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bir                 .
      *                      *-----------------------------------------*
      *                      * Test su esito operazione                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-sel-155.
       stp-srt-inp-sel-150.
      *                      *-----------------------------------------*
      *                      * Lettura sequenziale record [bir]        *
      *                      *-----------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofbir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bir                 .
      *                      *-----------------------------------------*
      *                      * Test se 'At End'                        *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-sel-155.
      *                      *-----------------------------------------*
      *                      * Test sul massimo                        *
      *                      *-----------------------------------------*
           if        rf-bir-cod-dpz       not  = rf-oct-cod-dpz or
                     rf-bir-coc-prt       not  = rf-oct-num-prt
                     go to stp-srt-inp-sel-155.
      *                      *-----------------------------------------*
      *                      * Test se data bolla rientra nei limiti   *
      *                      * delle date richieste                    *
      *                      *-----------------------------------------*
           if        rf-bir-dat-doc       not  < rr-dat-min and
                     rf-bir-dat-doc       not  > rr-dat-max
                     go to stp-srt-inp-sel-160.
      *                      *-----------------------------------------*
      *                      * Riciclo su lettura sequenziale record   *
      *                      * [bir]                                   *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-sel-150.
       stp-srt-inp-sel-155.
      *                      *-----------------------------------------*
      *                      * Riciclo su prossimo ordine              *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-sel-900.
       stp-srt-inp-sel-160.
      *                  *---------------------------------------------*
      *                  * Test su numero ordine minimo                *
      *                  *---------------------------------------------*
           if        rr-noc-min           not  = zero and
                     rf-oct-num-doc       <    rr-noc-min
                     go to stp-srt-inp-sel-900.
      *                  *---------------------------------------------*
      *                  * Test su numero ordine massimo               *
      *                  *---------------------------------------------*
           if        rr-noc-max           not  = zero and
                     rf-oct-num-doc       >    rr-noc-max
                     go to stp-srt-inp-sel-900.
       stp-srt-inp-sel-800.
      *              *-------------------------------------------------*
      *              * Uscita per test superato                        *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-sel-999.
       stp-srt-inp-sel-900.
      *              *-------------------------------------------------*
      *              * Uscita per test non superato                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita                              *
      *                  *---------------------------------------------*
           move      "#"                  to   w-stp-srt-inp-sel      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-sel-999.
       stp-srt-inp-sel-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Subroutine di calcolo importo                             *
      *    *-----------------------------------------------------------*
       stp-srt-inp-irs-000.
      *              *-------------------------------------------------*
      *              * Se tipo riga 'A'                                *
      *              *-------------------------------------------------*
           if        w-stp-srt-inp-wtp    =    "A"
                     move  rf-ocr-imp-rig to   w-stp-srt-inp-ipr
                     go to stp-srt-inp-irs-900.
       stp-srt-inp-irs-100.
      *              *-------------------------------------------------*
      *              * Se altro tipo riga                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione dello stato degli    *
      *                  * gli ordini richiesto                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-irs-200
                     stp-srt-inp-irs-300
                     stp-srt-inp-irs-400
                     stp-srt-inp-irs-500
                     depending            on   rr-sts-orc             .
       stp-srt-inp-irs-200.
      *                      *-----------------------------------------*
      *                      * Se solo ordini da evadere               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se prezzo per quantita'        *
      *                          *-------------------------------------*
           if        rf-ocr-flg-puq       =    spaces
                     go to stp-srt-inp-irs-280.
      *                          *-------------------------------------*
      *                          * Divisione                           *
      *                          *-------------------------------------*
           if        rf-ocr-flg-puq       =    "D"
                     divide 10            into d-qev-roc-qta-dev
                                        giving w-stp-srt-qta-dev
           else if   rf-ocr-flg-puq       =    "C"
                     divide 100           into d-qev-roc-qta-dev
                                        giving w-stp-srt-qta-dev
           else if   rf-ocr-flg-puq       =    "K"
                     divide 1000          into d-qev-roc-qta-dev
                                        giving w-stp-srt-qta-dev      .
      *                          *-------------------------------------*
      *                          * Aggiornamento importo               *
      *                          *-------------------------------------*
           multiply  w-stp-srt-qta-dev    by   w-stp-srt-inp-prz
                                        giving w-stp-srt-inp-ipr      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     stp-srt-inp-irs-600.
       stp-srt-inp-irs-280.
      *                          *-------------------------------------*
      *                          * (q.ta' da evadere x prezzo netto)   *
      *                          *-------------------------------------*
           multiply  d-qev-roc-qta-dev    by   w-stp-srt-inp-prz
                                        giving w-stp-srt-inp-ipr      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     stp-srt-inp-irs-600.
       stp-srt-inp-irs-300.
      *                      *-----------------------------------------*
      *                      * Se solo ordini in spedizione            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se prezzo per quantita'        *
      *                          *-------------------------------------*
           if        rf-ocr-flg-puq       =    spaces
                     go to stp-srt-inp-irs-380.
      *                          *-------------------------------------*
      *                          * Divisione                           *
      *                          *-------------------------------------*
           if        rf-ocr-flg-puq       =    "D"
                     divide 10            into d-qev-roc-qta-ics
                                        giving w-stp-srt-qta-dev
           else if   rf-ocr-flg-puq       =    "C"
                     divide 100           into d-qev-roc-qta-ics
                                        giving w-stp-srt-qta-dev
           else if   rf-ocr-flg-puq       =    "K"
                     divide 1000          into d-qev-roc-qta-ics
                                        giving w-stp-srt-qta-dev      .
      *                          *-------------------------------------*
      *                          * Aggiornamento importo               *
      *                          *-------------------------------------*
           multiply  w-stp-srt-qta-dev    by   w-stp-srt-inp-prz
                                        giving w-stp-srt-inp-ipr      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     stp-srt-inp-irs-600.
       stp-srt-inp-irs-380.
      *                          *-------------------------------------*
      *                          * (q.ta' in spediz. x prezzo netto)   *
      *                          *-------------------------------------*
           multiply  d-qev-roc-qta-ics    by   w-stp-srt-inp-prz
                                        giving w-stp-srt-inp-ipr      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     stp-srt-inp-irs-600.
       stp-srt-inp-irs-400.
      *                      *-----------------------------------------*
      *                      * Se solo ordini gia' evasi               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se prezzo per quantita'        *
      *                          *-------------------------------------*
           if        rf-ocr-flg-puq       =    spaces
                     go to stp-srt-inp-irs-480.
      *                          *-------------------------------------*
      *                          * Divisione                           *
      *                          *-------------------------------------*
           if        rf-ocr-flg-puq       =    "D"
                     divide 10            into d-qev-roc-qta-gsp
                                        giving w-stp-srt-qta-dev
           else if   rf-ocr-flg-puq       =    "C"
                     divide 100           into d-qev-roc-qta-gsp
                                        giving w-stp-srt-qta-dev
           else if   rf-ocr-flg-puq       =    "K"
                     divide 1000          into d-qev-roc-qta-gsp
                                        giving w-stp-srt-qta-dev      .
      *                          *-------------------------------------*
      *                          * Aggiornamento importo               *
      *                          *-------------------------------------*
           multiply  w-stp-srt-qta-dev    by   w-stp-srt-inp-prz
                                        giving w-stp-srt-inp-ipr      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     stp-srt-inp-irs-600.
       stp-srt-inp-irs-480.
      *                          *-------------------------------------*
      *                          * (q.ta' spedita x prezzo netto)      *
      *                          *-------------------------------------*
           multiply  d-qev-roc-qta-gsp    by   w-stp-srt-inp-prz
                                        giving w-stp-srt-inp-ipr      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     stp-srt-inp-irs-600.
       stp-srt-inp-irs-500.
      *                      *-----------------------------------------*
      *                      * Se tutti gli ordini                     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se prezzo per quantita'        *
      *                          *-------------------------------------*
           if        rf-ocr-flg-puq       =    spaces
                     go to stp-srt-inp-irs-580.
      *                          *-------------------------------------*
      *                          * Divisione                           *
      *                          *-------------------------------------*
           if        rf-ocr-flg-puq       =    "D"
                     divide 10            into d-qev-roc-qta-ord
                                        giving w-stp-srt-qta-dev
           else if   rf-ocr-flg-puq       =    "C"
                     divide 100           into d-qev-roc-qta-ord
                                        giving w-stp-srt-qta-dev
           else if   rf-ocr-flg-puq       =    "K"
                     divide 1000          into d-qev-roc-qta-ord
                                        giving w-stp-srt-qta-dev      .
      *                          *-------------------------------------*
      *                          * Aggiornamento importo               *
      *                          *-------------------------------------*
           multiply  w-stp-srt-qta-dev    by   w-stp-srt-inp-prz
                                        giving w-stp-srt-inp-ipr      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     stp-srt-inp-irs-600.
       stp-srt-inp-irs-580.
      *                          *-------------------------------------*
      *                          * (q.ta' ordinata x prezzo netto)     *
      *                          *-------------------------------------*
           multiply  d-qev-roc-qta-ord    by   w-stp-srt-inp-prz
                                        giving w-stp-srt-inp-ipr      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     stp-srt-inp-irs-600.
       stp-srt-inp-irs-600.
      *              *-------------------------------------------------*
      *              * Altre operazioni                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valuta e decimali prezzo                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Eventuale aggiustamento con decimali    *
      *                      * prezzo                                  *
      *                      *-----------------------------------------*
           if        rf-ocr-dec-prz       =    1
                     divide 10            into w-stp-srt-inp-ipr
           else if   rf-ocr-dec-prz       =    2
                     divide 100           into w-stp-srt-inp-ipr      .
      *                      *-----------------------------------------*
      *                      * Eventuale conversione nella valuta di   *
      *                      * fatturazione                            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se necessario                  *
      *                          *-------------------------------------*
           if        rf-ocr-sgl-vpp       =    rf-ocr-sgl-vpf
                     go to stp-srt-inp-irs-900.
      *                          *-------------------------------------*
      *                          * Determinazione coefficiente di cam- *
      *                          * bio alla data attuale per la valu-  *
      *                          * ta per il prezzo                    *
      *                          *-------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      rf-ocr-sgl-vpp       to   w-coe-cmb-vlt-sdv      .
           move      rf-ocr-tdc-vpp       to   w-coe-cmb-vlt-tdc      .
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                          *-------------------------------------*
      *                          * Se esito determinazione negativo si *
      *                          * considera il coefficiente rilevato  *
      *                          * alla data ordine                    *
      *                          *-------------------------------------*
           if        w-coe-cmb-vlt-ope    not  = "CC"
                     move  rf-ocr-cdc-vpp to   w-coe-cmb-vlt-cdc      .
      *                          *-------------------------------------*
      *                          * Conversione importo da valuta per   *
      *                          * il prezzo a valuta base             *
      *                          *-------------------------------------*
           move      rf-ocr-sgl-vpp       to   w-cvs-vlt-sgl          .
           move      rf-ocr-dec-vpp       to   w-cvs-vlt-dec          .
           move      rf-ocr-tdc-vpp       to   w-cvs-vlt-tdc          .
           move      w-coe-cmb-vlt-cdc    to   w-cvs-vlt-cdc          .
           move      w-stp-srt-inp-ipr    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
      *                          *-------------------------------------*
      *                          * Determinazione coefficiente di cam- *
      *                          * bio alla data attuale per la valu-  *
      *                          * ta per fatturazione                 *
      *                          *-------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      rf-ocr-sgl-vpf       to   w-coe-cmb-vlt-sdv      .
           move      rf-ocr-tdc-vpf       to   w-coe-cmb-vlt-tdc      .
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                          *-------------------------------------*
      *                          * Se esito determinazione negativo si *
      *                          * considera il coefficiente rilevato  *
      *                          * alla data ordine                    *
      *                          *-------------------------------------*
           if        w-coe-cmb-vlt-ope    not  = "CC"
                     move  rf-ocr-cdc-vpf to   w-coe-cmb-vlt-cdc      .
      *                          *-------------------------------------*
      *                          * Conversione importo da valuta base  *
      *                          * a valuta per fatturazione           *
      *                          *-------------------------------------*
           move      rf-ocr-sgl-vpf       to   w-cvs-vlt-sgl          .
           move      rf-ocr-dec-vpf       to   w-cvs-vlt-dec          .
           move      rf-ocr-tdc-vpf       to   w-cvs-vlt-tdc          .
           move      w-coe-cmb-vlt-cdc    to   w-cvs-vlt-cdc          .
           perform   cvs-vlb-alt-000      thru cvs-vlb-alt-999        .
      *                          *-------------------------------------*
      *                          * Bufferizzazione del risultato       *
      *                          *-------------------------------------*
           move      w-cvs-vlt-aav        to   w-stp-srt-inp-ipr      .
       stp-srt-inp-irs-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-irs-999.
       stp-srt-inp-irs-999.
           exit.

