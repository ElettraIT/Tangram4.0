      *              * Box per piede documento                         *
      *              *-------------------------------------------------*
       fin-cor-doc-620.
      *                  *---------------------------------------------*
      *                  * Primo box per visti                         *
      *                  *---------------------------------------------*
           move      w-fin-cor-doc-nlb    to   w-rou-stp-box-lin      .
           add       1                    to   w-rou-stp-box-lin      .
           move      001                  to   w-rou-stp-box-pin      .
           move      p-sel-efc-sel        to   w-rou-stp-box-lfi      .
           move      045                  to   w-rou-stp-box-pfi      .
           perform   rou-stp-box-000      thru rou-stp-box-999        .
      *                  *---------------------------------------------*
      *                  * Eventuale intestazione per primo box        *
      *                  *---------------------------------------------*
           if        w-ref-int-frm-des (1)
                                          =    spaces
                     go to fin-cor-doc-640.
      *                  *---------------------------------------------*
      *                  * Stampa intestazione per primo box           *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      40                   to   p-car                  .
           move      w-fin-cor-doc-nlb    to   p-lin                  .
           add       2                    to   p-lin                  .
           move      03                   to   p-pos                  .
           move      w-ref-int-frm-des (1)
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       fin-cor-doc-640.
      *                  *---------------------------------------------*
      *                  * Secondo box per visti                       *
      *                  *---------------------------------------------*
           move      w-fin-cor-doc-nlb    to   w-rou-stp-box-lin      .
           add       1                    to   w-rou-stp-box-lin      .
           move      045                  to   w-rou-stp-box-pin      .
           move      p-sel-efc-sel        to   w-rou-stp-box-lfi      .
           move      088                  to   w-rou-stp-box-pfi      .
           perform   rou-stp-box-000      thru rou-stp-box-999        .
      *                  *---------------------------------------------*
      *                  * Eventuale intestazione per secondo box      *
      *                  *---------------------------------------------*
           if        w-ref-int-frm-des (2)
                                          =    spaces
                     go to fin-cor-doc-660.
      *                  *---------------------------------------------*
      *                  * Stampa intestazione per secondo box         *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      40                   to   p-car                  .
           move      w-fin-cor-doc-nlb    to   p-lin                  .
           add       2                    to   p-lin                  .
           move      47                   to   p-pos                  .
           move      w-ref-int-frm-des (2)
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       fin-cor-doc-660.
      *                  *---------------------------------------------*
      *                  * Terzo box per visti                         *
      *                  *---------------------------------------------*
           move      w-fin-cor-doc-nlb    to   w-rou-stp-box-lin      .
           add       1                    to   w-rou-stp-box-lin      .
           move      088                  to   w-rou-stp-box-pin      .
           move      p-sel-efc-sel        to   w-rou-stp-box-lfi      .
           move      132                  to   w-rou-stp-box-pfi      .
           perform   rou-stp-box-000      thru rou-stp-box-999        .
      *                  *---------------------------------------------*
      *                  * Eventuale intestazione per terzo box        *
      *                  *---------------------------------------------*
           if        w-ref-int-frm-des (3)
                                          =    spaces
                     go to fin-cor-doc-800.
      *                  *---------------------------------------------*
      *                  * Stampa intestazione per terzo box           *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      40                   to   p-car                  .
           move      w-fin-cor-doc-nlb    to   p-lin                  .
           add       2                    to   p-lin                  .
           move      90                   to   p-pos                  .
           move      w-ref-int-frm-des (3)
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       fin-cor-doc-800.
      *              *-------------------------------------------------*
      *              * Vertical position                               *
      *              *-------------------------------------------------*
           move      "VP"                 to   p-ope                  .
           add       1
                     p-lnr              giving p-lin                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       fin-cor-doc-999.
           exit.

      *    *===========================================================*
      *    * Intestazione foglio                                       *
      *    *-----------------------------------------------------------*
       int-pag-sta-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo stampa          *
      *              *-------------------------------------------------*
           if        rr-opz-stp-tip       not  = spaces
                     go to int-pag-sta-200.
       int-pag-sta-100.
      *              *-------------------------------------------------*
      *              * Tipo stampa : Riepilogata                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Composizione titolo                         *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-tit-des-tit      .
           move      1                    to   w-int-pag-sta-pnt      .
      *
           string    "PORTAFOGLIO ORDINI"
                                delimited by   size
                                          into w-cnt-tit-des-tit
                                  with pointer w-int-pag-sta-pnt      .
      *
           if        rr-sts-orc           =   01
                     move  " DA EVADERE"  to  w-int-pag-sta-x30
           else if   rr-sts-orc           =   02
                     move  " IN CORSO DI SPEDIZIONE"
                                          to  w-int-pag-sta-x30
           else if   rr-sts-orc           =   03
                     move  " EVASI"
                                          to  w-int-pag-sta-x30
           else if   rr-sts-orc           =   04
                     move  spaces         to  w-int-pag-sta-x30       .
      *
           string    w-int-pag-sta-x30
                                delimited by   size
                                          into w-cnt-tit-des-tit
                                  with pointer w-int-pag-sta-pnt      .
      *                  *---------------------------------------------*
      *                  * Data di stampa                              *
      *                  *---------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-cnt-tit-dat-stp      .
      *                  *---------------------------------------------*
      *                  * Numero pagina                               *
      *                  *---------------------------------------------*
           move      p-pag                to   w-cnt-tit-num-pag      .
           add       1                    to   w-cnt-tit-num-pag      .
      *                  *---------------------------------------------*
      *                  * Intestazione standard                       *
      *                  *---------------------------------------------*
           perform   int-pag-std-000      thru int-pag-std-999        .
      *                      *-----------------------------------------*
      *                      * Se uscita per interruzione forzata      *
      *                      *-----------------------------------------*
           if        w-cnt-prn-flg-int    not  = spaces
                     go to  int-pag-sta-999.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     int-pag-sta-999.
       int-pag-sta-200.
      *              *-------------------------------------------------*
      *              * Tipo stampa : Completa                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Composizione titolo                         *
      *                  *---------------------------------------------*
           move      spaces               to   w-cnt-tit-des-tit      .
           move      1                    to   w-int-pag-sta-pnt      .
      *                  *---------------------------------------------*
      *                  * Descrizione documento                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura record [zoc]                    *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODTOC    "         to   f-key                  .
           move      rf-oct-tmo-orc       to   rf-zoc-cod-toc         .
           move      "pgm/orc/fls/ioc/obj/iofzoc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zoc                 .
           if        f-sts                not  = e-not-err
                     move  all "."        to   rf-zoc-des-toc         .
      *                      *-----------------------------------------*
      *                      * String                                  *
      *                      *-----------------------------------------*
           string    rf-zoc-des-toc
                                delimited by   size
                                          into w-cnt-tit-des-tit
                                  with pointer w-int-pag-sta-pnt      .
      *                      *-----------------------------------------*
      *                      * Riposizionamento puntatore all'ultimo   *
      *                      * carattere non-blank                     *
      *                      *-----------------------------------------*
           move      zero                 to   w-int-pag-sta-pnt      .
           inspect   w-cnt-tit-des-tit    
                                      tallying w-int-pag-sta-pnt
                                  for trailing spaces                 .
           subtract  w-int-pag-sta-pnt    from 80
                                        giving w-int-pag-sta-pnt      .
           add       1                    to   w-int-pag-sta-pnt      .
      *                  *---------------------------------------------*
      *                  * Numero documento                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Numero documento in work ridefinito     *
      *                      *-----------------------------------------*
           move      srt-num-doc          to   w-wrk-num-011          .
      *                      *-----------------------------------------*
      *                      * Editing numero progressivo              *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      06                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      w-wrk-num-011-prg    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * String                                  *
      *                      *-----------------------------------------*
           string    " nr. "
                                delimited by   size
                     p-edt
                                delimited by   spaces
                                          into w-cnt-tit-des-tit
                                  with pointer w-int-pag-sta-pnt      .
      *                  *---------------------------------------------*
      *                  * Data documento                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing data documento                  *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "D"                  to   p-tip                  .
           move      srt-dat-doc          to   p-dat                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * String                                  *
      *                      *-----------------------------------------*
           string    " del "
                                delimited by   size
                     p-edt
                                delimited by   spaces
                                          into w-cnt-tit-des-tit
                                  with pointer w-int-pag-sta-pnt      .
      *                  *---------------------------------------------*
      *                  * Data di stampa                              *
      *                  *---------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-cnt-tit-dat-stp      .
      *                  *---------------------------------------------*
      *                  * Numero pagina                               *
      *                  *---------------------------------------------*
           add       1                    to   w-cnt-tit-num-pag      .
      *                  *---------------------------------------------*
      *                  * Intestazione standard                       *
      *                  *---------------------------------------------*
           perform   int-pag-std-000      thru int-pag-std-999        .
      *                      *-----------------------------------------*
      *                      * Se uscita per interruzione forzata      *
      *                      *-----------------------------------------*
           if        w-cnt-prn-flg-int    not  = spaces
                     go to  int-pag-sta-999.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     int-pag-sta-999.
       int-pag-sta-999.
           exit.

      *    *===========================================================*
      *    * Determinazione descrizione riga ordine                    *
      *    *                                                           *
      *    * Input  :                                                  *
      *    *                                                           *
      *    *    - Record di [ocr] relativo alla riga ordine cliente a  *
      *    *      disposizione in rf-ocr                               *
      *    *                                                           *
      *    *    - Record di [dcc] relativo alla riga ordine cliente    *
      *    *                                                           *
      *    * Output :                                                  *
      *    *                                                           *
      *    *    - w-det-des-rig-des : Descrizione riga ordine          *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       det-des-rig-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore in uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-des-rig-des      .
       det-des-rig-010.
      *              *-------------------------------------------------*
      *              * Lettura preliminare estensione in file [ocx]    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [ocx]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofocx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocx                 .
      *                  *---------------------------------------------*
      *                  * Lettura file [ocx]                          *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-ocr-num-prt       to   rf-ocx-num-prt         .
           move      rf-ocr-num-prg       to   rf-ocx-num-prg         .
           move      11                   to   rf-ocx-tip-rec         .
           move      "pgm/orc/fls/ioc/obj/iofocx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocx                 .
      *
           if        f-sts                not  = e-not-err
                     go to det-des-rig-050.
      *
           move      rf-ocx-des-400       to   w-det-des-rig-des      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-des-rig-999.
       det-des-rig-050.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del flag di estensione   *
      *              * alla descrizione                                *
      *              *-------------------------------------------------*
           if        rf-ocr-des-ext       =    0
                     go to det-des-rig-100
           else if   rf-ocr-des-ext       =    1
                     go to det-des-rig-200
           else if   rf-ocr-des-ext       =    2
                     go to det-des-rig-300.
       det-des-rig-100.
      *              *-------------------------------------------------*
      *              * Se nessuna estensione : bufferizzazione descri- *
      *              * zione contenuta nel record [ocr]                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Descrizione                                 *
      *                  *---------------------------------------------*
           move      rf-ocr-des-rig       to   w-det-des-rig-des      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-des-rig-999.
       det-des-rig-200.
      *              *-------------------------------------------------*
      *              * Se estensione nel file [ocx]                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-des-rig-999.
       det-des-rig-300.
      *              *-------------------------------------------------*
      *              * Se estensione nel file [pdx]                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tentativo di lettura di una descrizione     *
      *                  * legata al cliente                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura archivio [pdx]                  *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "TRCLNG"             to   f-key                  .
           move      03                   to   rf-pdx-tip-rec         .
           move      rf-ocr-cod-arc       to   rf-pdx-cod-arc         .
           move      spaces               to   rf-pdx-cod-lng         .
           move      rf-ocr-num-pro       to   rf-pdx-cod-num         .
           move      spaces               to   rf-pdx-for-mat         .
           move      zero                 to   rf-pdx-num-prg         .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
      *                      *-----------------------------------------*
      *                      * Test su esito operazione                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-des-rig-305.
      *                      *-----------------------------------------*
      *                      * Se record trovato : bufferizzazione de- *
      *                      * scrizione e uscita                      *
      *                      *-----------------------------------------*
           move      rf-pdx-des-pro       to   w-det-des-rig-des      .
           go to     det-des-rig-999.
       det-des-rig-305.
      *                  *---------------------------------------------*
      *                  * Se codice lingua 'I  '                      *
      *                  *---------------------------------------------*
           if        rf-ocr-cod-lng       not  = "I  "
                     go to det-des-rig-350.
       det-des-rig-310.
      *                      *-----------------------------------------*
      *                      * Lettura archivio [pdx]                  *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "TRCLNG"             to   f-key                  .
           move      01                   to   rf-pdx-tip-rec         .
           move      zero                 to   rf-pdx-cod-arc         .
           move      "I  "                to   rf-pdx-cod-lng         .
           move      rf-ocr-num-pro       to   rf-pdx-cod-num         .
           move      spaces               to   rf-pdx-for-mat         .
           move      01                   to   rf-pdx-num-prg         .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
           if        f-sts                not  = e-not-err
                     move  all "."        to   rf-pdx-des-pro         .
           move      rf-pdx-des-pro       to   w-det-des-rig-des      .
           go to     det-des-rig-999.
       det-des-rig-350.
      *                  *---------------------------------------------*
      *                  * Se codice lingua diverso da 'I  '           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tentativo di lettura file [pdx] per de- *
      *                      * scrizione in lingua estera              *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "TRCLNG"             to   f-key                  .
           move      02                   to   rf-pdx-tip-rec         .
           move      zero                 to   rf-pdx-cod-arc         .
           move      rf-ocr-cod-lng       to   rf-pdx-cod-lng         .
           move      rf-ocr-num-pro       to   rf-pdx-cod-num         .
           move      spaces               to   rf-pdx-for-mat         .
           move      01                   to   rf-pdx-num-prg         .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
           if        f-sts                not  = e-not-err
                     go to det-des-rig-310.
           move      rf-pdx-des-pro       to   w-det-des-rig-des      .
           go to     det-des-rig-999.
       det-des-rig-999.
           exit.

      *    *===========================================================*
      *    * Routine di determinazione del literal di 40 caratteri     *
      *    * per la stampa o la visualizzazione del legame valutario   *
      *    *-----------------------------------------------------------*
       det-lit-lgv-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-lit-lgv-lit      .
       det-lit-lgv-100.
      *              *-------------------------------------------------*
      *              * Test preliminare                                *
      *              *-------------------------------------------------*
           if        w-det-lit-lgv-sgl    =    spaces
                     go to det-lit-lgv-900.
       det-lit-lgv-200.
      *              *-------------------------------------------------*
      *              * Composizione stringa                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Sigla valuta                                *
      *                  *---------------------------------------------*
           move      40                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      "Legame:"            to   w-all-str-cat (1)      .
           move      w-det-lit-lgv-sgl    to   w-all-str-cat (2)      .
           move      "a"                  to   w-all-str-cat (3)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                  *---------------------------------------------*
      *                  * Coefficiente di cambio di riferimento       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing                                 *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      06                   to   p-car                  .
           move      05                   to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<D"                 to   p-edm                  .
           move      w-det-lit-lgv-ccr    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Concatenamento                          *
      *                      *-----------------------------------------*
           move      40                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
           move      w-all-str-alf        to   w-all-str-cat (1)      .
           move      p-edt                to   w-all-str-cat (2)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                  *---------------------------------------------*
      *                  * Percentuale di limitazione                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing                                 *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      01                   to   p-car                  .
           move      02                   to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<D"                 to   p-edm                  .
           move      w-det-lit-lgv-plm    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Concatenamento                          *
      *                      *-----------------------------------------*
           move      40                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      w-all-str-alf        to   w-all-str-cat (1)      .
           if        w-det-lit-lgv-plm    =    zero
                     move  spaces         to   w-all-str-cat (2)
           else      move  "+/-"          to   w-all-str-cat (2)      .
           if        w-det-lit-lgv-plm    =    zero
                     move  spaces         to   w-all-str-cat (3)
           else      move  p-edt          to   w-all-str-cat (3)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                      *-----------------------------------------*
      *                      * Se la % di limitazione e' a zero : a    *
      *                      * preparazione literal in uscita          *
      *                      *-----------------------------------------*
           if        w-det-lit-lgv-plm    =    zero
                     go to det-lit-lgv-800.
       det-lit-lgv-400.
      *                  *---------------------------------------------*
      *                  * Tipo di limitazione                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del valore       *
      *                      *-----------------------------------------*
           if        w-det-lit-lgv-tlm    =    "T"
                     go to det-lit-lgv-410
           else if   w-det-lit-lgv-tlm    =    "F"
                     go to det-lit-lgv-420
           else if   w-det-lit-lgv-tlm    =    "M"
                     go to det-lit-lgv-430
           else      go to det-lit-lgv-800.
       det-lit-lgv-410.
      *                          *-------------------------------------*
      *                          * Tipo di limitazione : Tolleranza    *
      *                          *-------------------------------------*
           go to     det-lit-lgv-800.
       det-lit-lgv-420.
      *                          *-------------------------------------*
      *                          * Tipo di limitazione : Franchigia    *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Concatenamento                  *
      *                              *---------------------------------*
           move      40                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
           move      w-all-str-alf        to   w-all-str-cat (1)      .
           move      "Fr."                to   w-all-str-cat (2)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                              *---------------------------------*
      *                              * Ad uscita con literal           *
      *                              *---------------------------------*
           go to     det-lit-lgv-800.
       det-lit-lgv-430.
      *                          *-------------------------------------*
      *                          * Tipo di limitazione : Tetto massimo *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Concatenamento                  *
      *                              *---------------------------------*
           move      40                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
           move      w-all-str-alf        to   w-all-str-cat (1)      .
           move      "Max"                to   w-all-str-cat (2)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                              *---------------------------------*
      *                              * Ad uscita con literal           *
      *                              *---------------------------------*
           go to     det-lit-lgv-800.
       det-lit-lgv-800.
      *              *-------------------------------------------------*
      *              * Valore preparato in literal di uscita           *
      *              *-------------------------------------------------*
           move      w-all-str-alf        to   w-det-lit-lgv-lit      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     det-lit-lgv-999.
       det-lit-lgv-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-lit-lgv-999.
       det-lit-lgv-999.
           exit.

      *    *===========================================================*
      *    * Routine di stampa di un box                               *
      *    *-----------------------------------------------------------*
       rou-stp-box-000.
      *              *-------------------------------------------------*
      *              * Preparazione line - position - size             *
      *              *-------------------------------------------------*
           move      w-rou-stp-box-lin    to   w-rou-stp-box-wln      .
           move      w-rou-stp-box-pin    to   w-rou-stp-box-wps      .
           subtract  w-rou-stp-box-pin    from w-rou-stp-box-pfi
                                        giving w-rou-stp-box-wsz      .
           add       1                    to   w-rou-stp-box-wsz      .
      *              *-------------------------------------------------*
      *              * Linea superiore                                 *
      *              *-------------------------------------------------*
           move      w-rou-stp-box-wtr    to   w-rou-stp-box-wst      .
           move      "+"                  to   w-rou-stp-box-wch (1)  .
           move      "+"                  to   w-rou-stp-box-wch
                                              (w-rou-stp-box-wsz)     .
           perform   rou-stp-box-900      thru rou-stp-box-919        .
      *              *-------------------------------------------------*
      *              * Linee intermedie                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione                                *
      *                  *---------------------------------------------*
           move      spaces               to   w-rou-stp-box-wst      .
           move      "|"                  to   w-rou-stp-box-wch (1)  .
           move      "|"                  to   w-rou-stp-box-wch
                                              (w-rou-stp-box-wsz)     .
           subtract  w-rou-stp-box-lin    from w-rou-stp-box-lfi
                                        giving w-rou-stp-box-ctr      .
           subtract  1                    from w-rou-stp-box-ctr      .
       rou-stp-box-500.
           add       1                    to   w-rou-stp-box-wln      .
           if        w-rou-stp-box-ctr    >    zero
                     subtract 1           from w-rou-stp-box-ctr
                     perform  rou-stp-box-900
                                          thru rou-stp-box-919
                     go to    rou-stp-box-500.
      *              *-------------------------------------------------*
      *              * Linea inferiore                                 *
      *              *-------------------------------------------------*
           move      w-rou-stp-box-wtr    to   w-rou-stp-box-wst      .
           move      "+"                  to   w-rou-stp-box-wch (1)  .
           move      "+"                  to   w-rou-stp-box-wch
                                              (w-rou-stp-box-wsz)     .
           perform   rou-stp-box-900      thru rou-stp-box-919        .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     rou-stp-box-999.
       rou-stp-box-900.
      *              *=================================================*
      *              * Sub-routine interna di stampa riga              *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      w-rou-stp-box-wsz    to   p-car                  .
           move      w-rou-stp-box-wln    to   p-lin                  .
           move      w-rou-stp-box-wps    to   p-pos                  .
           move      w-rou-stp-box-wst    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       rou-stp-box-919.
           exit.
       rou-stp-box-999.
           exit.

