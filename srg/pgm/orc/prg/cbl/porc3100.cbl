      *    *===========================================================*
      *    * Ciclo Report Program : Selezione su record letto          *
      *    *-----------------------------------------------------------*
       prn-sel-rec-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
       prn-sel-rec-100.
      *              *-------------------------------------------------*
      *              * Test su tipo stampa                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo stampa      *
      *                  *---------------------------------------------*
           go to     prn-sel-rec-110
                     prn-sel-rec-120
                     prn-sel-rec-130
                     depending            on   rr-tip-stp             .
           go to     prn-sel-rec-110.
       prn-sel-rec-110.
      *                  *---------------------------------------------*
      *                  * Tipo stampa : definitiva                    *
      *                  *---------------------------------------------*
           if        rf-oct-ctr-stp       not  = zero
                     go to prn-sel-rec-900.
           go to     prn-sel-rec-200.
       prn-sel-rec-120.
      *                  *---------------------------------------------*
      *                  * Tipo stampa : di prova                      *
      *                  *---------------------------------------------*
           if        rf-oct-ctr-stp       not  = zero
                     go to prn-sel-rec-900.
           go to     prn-sel-rec-200.
       prn-sel-rec-130.
      *                  *---------------------------------------------*
      *                  * Tipo stampa : ristampa                      *
      *                  *---------------------------------------------*
           if        rf-oct-ctr-stp       not  > zero
                     go to prn-sel-rec-900.
           go to     prn-sel-rec-200.
       prn-sel-rec-200.
      *              *-------------------------------------------------*
      *              * Test su codice dipendenza                       *
      *              *-------------------------------------------------*
           if        rf-oct-cod-dpz       not  = rr-cod-dpz
                     go to prn-sel-rec-900.
      *              *-------------------------------------------------*
      *              * Test su numero ordine                           *
      *              *-------------------------------------------------*
           if        rf-oct-num-doc       <    rr-noc-min or
                     rf-oct-num-doc       >    rr-noc-max
                     go to prn-sel-rec-900.
      *              *-------------------------------------------------*
      *              * Test su tipo movimento                          *
      *              *-------------------------------------------------*
           if        rf-oct-tmo-orc       not  = rr-tip-mov
                     go to prn-sel-rec-900.
      *              *-------------------------------------------------*
      *              * Test su codice cliente                          *
      *              *-------------------------------------------------*
           if        rf-oct-cod-arc       <    rr-cli-min or
                     rf-oct-cod-arc       >    rr-cli-max
                     go to prn-sel-rec-900.
      *              *-------------------------------------------------*
      *              * Test su dipendenza del cliente                  *
      *              *-------------------------------------------------*
           if        rf-oct-dpz-arc       <    rr-dpz-min or
                     rf-oct-dpz-arc       >    rr-dpz-max
                     go to prn-sel-rec-900.
       prn-sel-rec-300.
      *              *-------------------------------------------------*
      *              * Selezione su status ordine                      *
      *              *-------------------------------------------------*
           if        rr-sts-orc           =    01
                     go to prn-sel-rec-800.
           if        rr-sts-orc           not  = 04 and
                     rf-oct-flg-och       not  = spaces
                     go to prn-sel-rec-900.
       prn-sel-rec-320.
      *              *-------------------------------------------------*
      *              * Determinazione status dell'ordine               *
      *              *-------------------------------------------------*
           move      "DT"                 to   d-sts-orc-tip-ope      .
           perform   det-sts-orc-cll-000  thru det-sts-orc-cll-999    .
       prn-sel-rec-400.
      *              *-------------------------------------------------*
      *              * Test su status dell'ordine                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione delle richieste      *
      *                  *---------------------------------------------*
           if        rr-sts-orc           =    02
                     go to prn-sel-rec-420
           else if   rr-sts-orc           =    03
                     go to prn-sel-rec-430
           else if   rr-sts-orc           =    04
                     go to prn-sel-rec-440.
       prn-sel-rec-420.
      *                      *-----------------------------------------*
      *                      * Se solo ordini inevasi                  *
      *                      *-----------------------------------------*
           if        d-sts-orc-sts-ord    =    02  or
                     d-sts-orc-sts-ord    =    04
                     go to prn-sel-rec-800
           else      go to prn-sel-rec-900.
       prn-sel-rec-430.
      *                      *-----------------------------------------*
      *                      * Se solo ordini evasi                    *
      *                      *-----------------------------------------*
           if        d-sts-orc-sts-ord    =    02  or
                     d-sts-orc-sts-ord    =    03
                     go to prn-sel-rec-800
           else      go to prn-sel-rec-900.
       prn-sel-rec-440.
      *                      *-----------------------------------------*
      *                      * Se solo ordini chiusi                   *
      *                      *-----------------------------------------*
           if        d-sts-orc-sts-ord    =    01
                     go to prn-sel-rec-800
           else      go to prn-sel-rec-900.
       prn-sel-rec-800.
      *              *-------------------------------------------------*
      *              * Uscita per selezione superata                   *
      *              *-------------------------------------------------*
           go to     prn-sel-rec-999.
       prn-sel-rec-900.
      *              *-------------------------------------------------*
      *              * Se selezione non superata                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita                              *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-prn-flg-sub      .
       prn-sel-rec-999.
           exit.

