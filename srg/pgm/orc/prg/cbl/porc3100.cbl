           perform   let-arc-zoc-000      thru let-arc-zoc-999        .
           move      w-let-arc-zoc-des    to   rr-tip-mov-des         .
           move      w-let-arc-zoc-vld    to   rr-tip-mov-vld         .
           move      w-let-arc-zoc-dpz    to   rr-tip-mov-dpz         .
