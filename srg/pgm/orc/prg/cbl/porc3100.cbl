                     go to acc-tmo-orc-100.
      *                  *---------------------------------------------*
      *                  * Se a spaces : reimpostazione                *
      *                  *---------------------------------------------*
           if        rr-tip-mov           =    spaces
                     go to acc-tmo-orc-100.
      *                  *---------------------------------------------*
      *                  * Test su codice dipendenza                   *
      *                  *---------------------------------------------*
           if        rr-tip-mov-vld       not  = 02
                     go to acc-tmo-orc-600.
           if        rr-cod-dpz           =    rr-tip-mov-dpz
                     go to acc-tmo-orc-600.
