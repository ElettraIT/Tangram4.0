           move      "GK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-rip-str-oct-prt    to   rf-oct-num-prt         .
           move      "pgm/orc/fls/ioc/obj/iofoct"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oct                 .
      *                      *-----------------------------------------*
      *                      * Se record non trovato : non si esegue   *
      *                      * l'aggiornamento del contatore           *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to prn-liv-det-600.
       prn-liv-det-540.
      *                      *-----------------------------------------*
      *                      * Aggiornamento contatore                 *
      *                      *-----------------------------------------*
           add       1                    to   rf-oct-ctr-stp         .
       prn-liv-det-560.
      *                      *-----------------------------------------*
      *                      * Riscrittura record                      *
