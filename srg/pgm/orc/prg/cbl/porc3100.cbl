           move      "UP"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofoct"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oct                 .
      *                      *-----------------------------------------*
      *                      * Se errore in riscrittura : non si ese-  *
      *                      * gue l'aggiornamento del contatore       *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to prn-liv-det-580.
       prn-liv-det-580.
      *                      *-----------------------------------------*
      *                      * Rilascio record                         *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofoct"
                                          to   s-pat                  .
