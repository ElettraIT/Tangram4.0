           move      "WR"                 to   m-ope                  .
           move      "Attenzione : durante il programma e' intervenuto u
      -              "n errore di tipo grave."
                                          to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
           move      "WR"                 to   m-ope                  .
           move      "             La stampa richiesta pertanto e' stata
      -              " interrotta."
                                          to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                  *---------------------------------------------*
      *                  * Ad uscita per errore                        *
