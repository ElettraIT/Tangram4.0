           move      rr-dat-min           to   rf-oct-dat-doc         .
           move      rr-cod-dpz           to   rf-oct-cod-dpz         .
           move      rr-noc-min           to   rf-oct-num-doc         .
           move      rr-tip-mov           to   rf-oct-tmo-orc         .
