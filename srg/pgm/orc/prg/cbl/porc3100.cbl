      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "GT"                 to   f-cfr                  .
           move      "IDEDOC    "         to   f-key                  .
           move      w-rip-str-oct-ddo    to   rf-oct-dat-doc         .
           move      w-rip-str-oct-dpz    to   rf-oct-cod-dpz         .
           move      w-rip-str-oct-ndo    to   rf-oct-num-doc         .
