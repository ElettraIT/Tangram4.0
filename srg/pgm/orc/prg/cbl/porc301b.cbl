      *                  *---------------------------------------------*
           if        w-all-str-flg        =    spaces
                     go to int-srt-inp-ser-800.
       int-srt-inp-ser-600.
      *              *-------------------------------------------------*
      *              * Lettura estensione riga ordine                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [ocx]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofocx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocx                 .
      *                  *---------------------------------------------*
      *                  * Lettura file [ocx]                          *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-ocr-num-prt       to   rf-ocx-num-prt         .
           move      rf-ocr-num-prg       to   rf-ocx-num-prg         .
           move      11                   to   rf-ocx-tip-rec         .
           move      "pgm/orc/fls/ioc/obj/iofocx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocx                 .
      *                  *---------------------------------------------*
      *                  * Se record non trovato, a riciclo            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to int-srt-inp-ser-700.
      *                  *---------------------------------------------*
      *                  * Trattamento 10 righe di descrizione         *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-num-rig-cde      .
       int-srt-inp-ser-620.
           add       01                   to   w-det-num-rig-cde      .
           if        w-det-num-rig-cde    >    10
                     go to int-srt-inp-ser-700.
      *                  *---------------------------------------------*
      *                  * Test su contenuto riga di descrizione       *
      *                  *---------------------------------------------*
           if        rf-ocx-rig-400
                    (w-det-num-rig-cde)   =    spaces
                     go to int-srt-inp-ser-620.
      *                  *---------------------------------------------*
      *                  * Preparazione decrizione per il confronto    *
      *                  *---------------------------------------------*
           move      rf-ocx-rig-400
                    (w-det-num-rig-cde)   to   w-all-str-alf          .
           move      40                   to   w-all-str-lun          .
           perform   all-nor-atz-000      thru all-nor-atz-999        .
           move      w-all-str-alf        to   w-all-str-cat (2)      .
      *                  *---------------------------------------------*
      *                  * Preparazione stringa per il confronto       *
      *                  *---------------------------------------------*
           move      rr-str-sel           to   w-all-str-cat (1)      .
      *                  *---------------------------------------------*
      *                  * Match tra i due valori                      *
      *                  *---------------------------------------------*
           perform   all-mch-atz-000      thru all-mch-atz-999        .
      *                  *---------------------------------------------*
      *                  * Se c'e' stato un match : selezione superata *
      *                  *---------------------------------------------*
           if        w-all-str-flg        =    spaces
                     go to int-srt-inp-ser-800.
       int-srt-inp-ser-680.
      *              *-------------------------------------------------*
      *              * Riciclo s riga descrizione successiva           *
      *              *-------------------------------------------------*
           go to     int-srt-inp-ser-620.
       int-srt-inp-ser-700.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     int-srt-inp-ser-200.
       int-srt-inp-ser-800.
      *              *-------------------------------------------------*
      *              * Flag di uscita                                  *
      *              *-------------------------------------------------*
           move      "#"                  to   w-det-sel-str-flr      .
      *              *-------------------------------------------------*
      *              * Uscita per selezione superata                   *
      *              *-------------------------------------------------*
           go to     int-srt-inp-ser-999.
       int-srt-inp-ser-900.
      *              *-------------------------------------------------*
      *              * Se selezione non superata                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita                              *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-qry-flg-sub      .
       int-srt-inp-ser-999.
           exit.

