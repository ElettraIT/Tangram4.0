      *              *-------------------------------------------------*
           if        w-cnt-exe-rou-srt    =    "<"
                     go to exe-rou-srt-140
           else      go to exe-rou-srt-120.
       exe-rou-srt-120.
      *              *-------------------------------------------------*
      *              * Se ordine ascendente                            *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   int-srt-inp-000
                                          thru int-srt-inp-999
                     output procedure     is   qry-rou-pri-000
                                          thru qry-rou-pri-999        .
      *
           go to     exe-rou-srt-900.
       exe-rou-srt-140.
      *              *-------------------------------------------------*
      *              * Se ordine discendente                           *
      *              *-------------------------------------------------*
           sort      srt                  on   descending srt-key
                     input  procedure     is   int-srt-inp-000
                                          thru int-srt-inp-999
                     output procedure     is   qry-rou-pri-000
                                          thru qry-rou-pri-999        .
      *
           go to     exe-rou-srt-900.
       exe-rou-srt-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-rou-srt-999.
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       int-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni                                 *
      *              *-------------------------------------------------*
       int-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Start su [oct] per data registrazione           *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "IDEDOC    "         to   f-key                  .
           move      rr-dem-min           to   rf-oct-dat-doc         .
           move      rr-dpz-inu           to   rf-oct-cod-dpz         .
           move      zero                 to   rf-oct-num-doc         .
           move      spaces               to   rf-oct-tmo-orc         .
           move      zero                 to   rf-oct-num-prt         .
           move      "pgm/orc/fls/ioc/obj/iofoct"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oct                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to int-srt-inp-900.
       int-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Eventuale interruzione                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Accettazione                                *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
           move      "AA"                 to   v-ope                  .
           move      21                   to   v-lin                  .
           move      80                   to   v-pos                  .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Se attesa disattivata : oltre               *
      *                  *---------------------------------------------*
           if        v-key                =    spaces
                     go to int-srt-inp-250.
      *                  *---------------------------------------------*
      *                  * Se 'EXIT'                                   *
      *                  *---------------------------------------------*
           if        v-key                not  = "EXIT"
                     go to int-srt-inp-250.
      *                  *---------------------------------------------*
      *                  * Flags                                       *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-qry-flg-sub      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     int-srt-inp-900.
       int-srt-inp-250.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [oct]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofoct"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oct                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to int-srt-inp-900.
       int-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su data emissione min e max            *
      *                  *---------------------------------------------*
           if        rr-dem-max           =    zero
                     go to int-srt-inp-320
           else      go to int-srt-inp-340.
       int-srt-inp-320.
      *                  *---------------------------------------------*
      *                  * Se data emissione max a zero                *
      *                  *---------------------------------------------*
           if        rr-dem-min           =    zero
                     go to int-srt-inp-400.
           if        rf-oct-dat-doc       >    rr-dem-min
                     go to int-srt-inp-900.
           go to     int-srt-inp-400.
       int-srt-inp-340.
      *                  *---------------------------------------------*
      *                  * Se data emissione massima non zero          *
      *                  *---------------------------------------------*
           if        rf-oct-dat-doc       >    rr-dem-max
                     go to int-srt-inp-900.
           go to     int-srt-inp-400.
       int-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Selezione su dipendenza in uso              *
      *                  *---------------------------------------------*
           if        rf-oct-cod-dpz       not  = rr-dpz-inu
                     go to int-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Selezione su ordini aperti                  *
      *                  *---------------------------------------------*
           if        rr-sts-orc           =    01
                     go to int-srt-inp-420.
           if        rr-sts-orc           not  = 04 and
                     rf-oct-flg-och       not  = spaces
                     go to int-srt-inp-200.
       int-srt-inp-420.
      *                  *---------------------------------------------*
      *                  * Determinazione status dell'ordine           *
      *                  *---------------------------------------------*
           move      "DT"                 to   d-sts-orc-tip-ope      .
           perform   det-sts-orc-cll-000  thru det-sts-orc-cll-999    .
       int-srt-inp-430.
      *                  *---------------------------------------------*
      *                  * Selezione su status dell'ordine             *
      *                  *---------------------------------------------*
           if        rr-sts-orc           =    01
                     go to int-srt-inp-440.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione delle richieste      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        rr-sts-orc           =    02
                     go to int-srt-inp-432
           else if   rr-sts-orc           =    03
                     go to int-srt-inp-434
           else if   rr-sts-orc           =    04
                     go to int-srt-inp-436.
       int-srt-inp-432.
      *                      *-----------------------------------------*
      *                      * Se solo ordini inevasi                  *
      *                      *-----------------------------------------*
           if        d-sts-orc-sts-ord    =    02  or
                     d-sts-orc-sts-ord    =    04
                     go to int-srt-inp-440
           else      go to int-srt-inp-200.
       int-srt-inp-434.
      *                      *-----------------------------------------*
      *                      * Se solo ordini evasi                    *
      *                      *-----------------------------------------*
           if        d-sts-orc-sts-ord    =    02  or
                     d-sts-orc-sts-ord    =    03
                     go to int-srt-inp-440
           else      go to int-srt-inp-200.
       int-srt-inp-436.
      *                      *-----------------------------------------*
      *                      * Se solo ordini chiusi                   *
      *                      *-----------------------------------------*
           if        d-sts-orc-sts-ord    =    01
                     go to int-srt-inp-440
           else      go to int-srt-inp-200.
       int-srt-inp-440.
      *                  *---------------------------------------------*
      *                  * Selezione su tipo movimento                 *
      *                  *---------------------------------------------*
           if        rr-cod-toc           =    spaces
                     go to int-srt-inp-450.
           if        rf-oct-tmo-orc       not  = rr-cod-toc
                     go to int-srt-inp-200.
       int-srt-inp-450.
      *                  *---------------------------------------------*
      *                  * Selezioni su stringa opzionale              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da eseguire                     *
      *                      *-----------------------------------------*
           if        rr-str-sel           =    spaces
                     go to int-srt-inp-500.
      *                      *-----------------------------------------*
      *                      * Ricerca su testata e righe              *
      *                      *-----------------------------------------*
           perform   int-srt-inp-sel-000  thru int-srt-inp-sel-999    .
      *                      *-----------------------------------------*
      *                      * Test su esito ricerca                   *
      *                      *-----------------------------------------*
           if        w-det-sel-str-flg    =    spaces
                     go to int-srt-inp-200.
       int-srt-inp-500.
      *              *-------------------------------------------------*
      *              * Determinazione totale ordine                    *
      *              *-------------------------------------------------*
           perform   det-tot-doc-000      thru det-tot-doc-999        .
      *              *-------------------------------------------------*
      *              * Determinazione numero righe documento           *
      *              *-------------------------------------------------*
           perform   int-srt-inp-rig-000  thru int-srt-inp-rig-999    .
       int-srt-inp-600.
      *              *-------------------------------------------------*
      *              * Preparazione record di Sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione iniziale                    *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Chiave di sort                              *
      *                  *---------------------------------------------*
           perform   int-srt-inp-key-000  thru int-srt-inp-key-999    .
       int-srt-inp-650.
      *                  *---------------------------------------------*
      *                  * Dati di sort                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Numero protocollo                       *
      *                      *-----------------------------------------*
           move      rf-oct-num-prt       to   srt-num-prt            .
      *                      *-----------------------------------------*
      *                      * Righe documento                         *
      *                      *-----------------------------------------*
           move      w-det-num-rig-ctr    to   srt-rig-doc            .
      *                      *-----------------------------------------*
      *                      * Imponibile documento                    *
      *                      *-----------------------------------------*
           move      w-det-tot-doc-tot    to   srt-tot-doc            .
      *                      *-----------------------------------------*
      *                      * Status ordine                           *
      *                      *-----------------------------------------*
           move      d-sts-orc-sts-ord    to   srt-sts-ord            .
      *                      *-----------------------------------------*
      *                      * Annotazioni                             *
      *                      *-----------------------------------------*
           move      d-sts-orc-sts-lit    to   srt-sts-lit            .
       int-srt-inp-700.
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       int-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     int-srt-inp-200.
       int-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     int-srt-inp-999.
       int-srt-inp-999.
           exit.

