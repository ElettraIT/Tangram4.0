      *    *===========================================================*
      *    * Determinazione totale sconto in chiusura                  *
      *    *-----------------------------------------------------------*
       det-tot-scc-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-tot-scc-flg      .
      *              *-------------------------------------------------*
      *              * Se sia la % che l'importo sono a zero : uscita  *
      *              *-------------------------------------------------*
           if        w-pie-tot-scc (1)    =    zero and
                     w-pie-per-scc (1)    =    zero
                     go to det-tot-scc-999.
      *              *-------------------------------------------------*
      *              * Se % a zero vuol dire che l'importo dello scon- *
      *              * to in chiusura e' stato impostato manualmente   *
      *              * nel piede                                       *
      *              *-------------------------------------------------*
           if        w-pie-per-scc (1)    =    zero
                     go to det-tot-scc-100.
      *              *-------------------------------------------------*
      *              * Calcolo                                         *
      *              *-------------------------------------------------*
           multiply  w-pie-per-scc (1)    by   w-pie-tot-lor (1)
                                        giving w-pie-tot-scc (1)      .
           divide    100                  into w-pie-tot-scc (1)
                                       rounded                        .
       det-tot-scc-100.
       det-tot-scc-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale al netto dello sonto in chiusura    *
      *    *-----------------------------------------------------------*
       det-tot-nsc-000.
           subtract  w-pie-tot-scc (1)    from w-pie-tot-lor (1)
                                        giving w-pie-tot-nsc (1)      .
       det-tot-nsc-999.
           exit.

      *    *===========================================================*
      *    * Determinazione importo spese in fattura                   *
      *    *-----------------------------------------------------------*
       det-imp-spe-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-imp-spe-flg      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione su tabella spese             *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-imp-spe-c01      .
       det-imp-spe-050.
           add       1                    to   w-det-imp-spe-c01      .
           if        w-det-imp-spe-c01    >    w-prs-spe-fat-nst
                     go to det-imp-spe-999.
      *              *-------------------------------------------------*
      *              * Determinazione indice per la spesa              *
      *              *-------------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-det-imp-spe-c01)   to   w-det-imp-spe-inx      .
      *              *-------------------------------------------------*
      *              * Se spesa da addebitare : oltre                  *
      *              *-------------------------------------------------*
           if        w-pie-spe-snx
                    (1, w-det-imp-spe-inx)
                                          =    1
                     go to det-imp-spe-075.
      *              *-------------------------------------------------*
      *              * Test su personalizzazione per tipo accettazione *
      *              *-------------------------------------------------*
           if        w-prs-spe-fat-tac    =    00
                     go to det-imp-spe-050.
       det-imp-spe-075.
      *              *-------------------------------------------------*
      *              * Se percentuale a zero : ad aggiornamenti        *
      *              *-------------------------------------------------*
           if        w-pie-spe-per
                    (1, w-det-imp-spe-inx)
                                          =    zero
                     go to det-imp-spe-500.
       det-imp-spe-100.
      *              *-------------------------------------------------*
      *              * Se percentuale esistente                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione imponibile per la spesa     *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-imp-spe-ibl      .
      *                  *---------------------------------------------*
      *                  * Determinazione imponibile per la spesa      *
      *                  *---------------------------------------------*
           if        w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    01
                     move w-pie-tot-lor (1)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    02
                     move w-pie-tot-nsc (1)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    03
                     go to det-imp-spe-220
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    11
                     move w-pie-tot-rig (1, 1)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    12
                     move w-pie-tot-rig (1, 2)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    13
                     move w-pie-tot-rig (1, 3)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    14
                     move w-pie-tot-rig (1, 4)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    15
                     move w-pie-tot-rig (1, 5)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    16
                     move w-pie-tot-rig (1, 6)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    17
                     move w-pie-tot-rig (1, 7)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    18
                     move w-pie-tot-rig (1, 8)
                                          to   w-det-imp-spe-ibl
           else if   w-pie-spe-ibl
                    (1, w-det-imp-spe-inx)
                                          =    19
                     move w-pie-tot-rig (1, 9)
                                          to   w-det-imp-spe-ibl      .
           go to     det-imp-spe-250.
       det-imp-spe-220.
      *                      *-----------------------------------------*
      *                      * Se risulta da una combinazione di tota- *
      *                      * li                                      *
      *                      *-----------------------------------------*
           move      w-pie-spe-ibt
                    (1, w-det-imp-spe-inx)
                                          to   w-det-imp-spe-ibt      .
           move      zero                 to   w-det-imp-spe-c02      .
       det-imp-spe-225.
           add       1                    to   w-det-imp-spe-c02      .
           if        w-det-imp-spe-c02    >    9
                     go to det-imp-spe-250.
           if        w-det-imp-spe-ibx
                    (w-det-imp-spe-c02)   not  = "S"
                     go to det-imp-spe-225.
           add       w-pie-tot-rig
                    (1, w-det-imp-spe-c02)
                                          to   w-det-imp-spe-ibl      .
           go to     det-imp-spe-225.
       det-imp-spe-250.
      *                  *---------------------------------------------*
      *                  * Calcolo                                     *
      *                  *---------------------------------------------*
           multiply  w-pie-spe-per
                    (1, w-det-imp-spe-inx)
                                          by   w-det-imp-spe-ibl
                                        giving w-pie-spe-imp
                                              (1, w-det-imp-spe-inx)  .
           divide    100                  into w-pie-spe-imp
                                              (1, w-det-imp-spe-inx)
                                                            rounded   .
       det-imp-spe-500.
      *              *-------------------------------------------------*
      *              * Riciclo su scansione tabella                    *
      *              *-------------------------------------------------*
           go to     det-imp-spe-050.
       det-imp-spe-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale al netto delle spese in fattura     *
      *    *-----------------------------------------------------------*
       det-tot-nsf-000.
      *              *-------------------------------------------------*
      *              * Azzeramento work per accumulo spese             *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-nsf-was      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione tabella spese                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-nsf-ctr      .
       det-tot-nsf-100.
           add       1                    to   w-det-tot-nsf-ctr      .
           if        w-det-tot-nsf-ctr    >    w-prs-spe-fat-nst
                     go to det-tot-nsf-200.
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-det-tot-nsf-ctr)   to   w-det-tot-nsf-inx      .
      *                  *---------------------------------------------*
      *                  * Se spesa da non addebitare : riciclo        *
      *                  *---------------------------------------------*
           if        w-pie-spe-snx
                    (1, w-det-tot-nsf-inx)
                                          =    0
                     go to det-tot-nsf-100.
      *                  *---------------------------------------------*
      *                  * Aggiornamento totalizzatore                 *
      *                  *---------------------------------------------*
           add       w-pie-spe-imp
                    (1, w-det-tot-nsf-inx)
                                          to   w-det-tot-nsf-was      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-tot-nsf-100.
       det-tot-nsf-200.
      *              *-------------------------------------------------*
      *              * Determinazione valore                           *
      *              *-------------------------------------------------*
           move      w-pie-tot-nsc (1)    to    w-pie-tot-nsf (1)     .
           add       w-det-tot-nsf-was    to    w-pie-tot-nsf (1)     .
       det-tot-nsf-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale sconto pagamento                    *
      *    *-----------------------------------------------------------*
       det-tot-scp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-tot-scp-flg      .
      *              *-------------------------------------------------*
      *              * Se sia la % che l'importo sono a zero : uscita  *
      *              *-------------------------------------------------*
           if        w-pie-tot-scp (1)    =    zero and
                     w-pie-per-scp (1)    =    zero
                     go to det-tot-scp-999.
      *              *-------------------------------------------------*
      *              * Se % a zero vuol dire che l'importo dello scon- *
      *              * to pagamento e' stato impostato manualmente nel *
      *              * piede                                           *
      *              *-------------------------------------------------*
           if        w-pie-per-scp (1)    =    zero
                     go to det-tot-scp-100.
      *              *-------------------------------------------------*
      *              * Calcolo, a seconda della personalizzazione sul  *
      *              * tipo di imponibile, che indica se prendere o    *
      *              * no in considerazione le spese                   *
      *              *-------------------------------------------------*
           if        w-prs-tim-scp-tip    =    "N"
                     multiply  w-pie-per-scp (1)
                                          by   w-pie-tot-nsc (1)
                                        giving w-pie-tot-scp (1)
           else      multiply  w-pie-per-scp (1)
                                          by   w-pie-tot-nsf (1)
                                        giving w-pie-tot-scp (1)      .
           divide    100                  into w-pie-tot-scp (1)
                                       rounded                        .
       det-tot-scp-100.
       det-tot-scp-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale netto                               *
      *    *-----------------------------------------------------------*
       det-tot-net-000.
           subtract  w-pie-tot-scc (1)    from w-pie-tot-lor (1)
                                        giving w-pie-tot-net (1)      .
           subtract  w-pie-tot-scp (1)    from w-pie-tot-net (1)      .
       det-tot-net-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale spese                               *
      *    *-----------------------------------------------------------*
       det-tot-spe-000.
      *              *-------------------------------------------------*
      *              * Azzeramento totalizzatore                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-pie-tot-spe (1)      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione tabella spese                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-spe-ctr      .
       det-tot-spe-100.
           add       1                    to   w-det-tot-spe-ctr      .
           if        w-det-tot-spe-ctr    >    w-prs-spe-fat-nst
                     go to det-tot-spe-200.
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-det-tot-spe-ctr)   to   w-det-tot-spe-inx      .
      *                  *---------------------------------------------*
      *                  * Se spesa da non addebitare : riciclo        *
      *                  *---------------------------------------------*
           if        w-pie-spe-snx
                    (1, w-det-tot-spe-inx)
                                          =    0
                     go to det-tot-spe-100.
      *                  *---------------------------------------------*
      *                  * Aggiornamento totalizzatore                 *
      *                  *---------------------------------------------*
           add       w-pie-spe-imp
                    (1, w-det-tot-spe-inx)
                                          to   w-pie-tot-spe (1)      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-tot-spe-100.
       det-tot-spe-200.
       det-tot-spe-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale documento                           *
      *    *-----------------------------------------------------------*
       det-tot-doc-000.
           add       w-pie-tot-net (1)
                     w-pie-tot-spe (1)  giving w-pie-tot-doc (1)      .
           add       w-pie-tot-rta (1)    to   w-pie-tot-doc (1)      .
       det-tot-doc-999.
           exit.

      *    *===========================================================*
      *    * Determinazione se ordine in distinta di invio tramite     *
      *    * mail                                                      *
      *    *-----------------------------------------------------------*
       det-prt-eml-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-prt-eml-ele      .
           move      zero                 to   w-det-prt-eml-dst      .
       det-prt-eml-100.
      *              *-------------------------------------------------*
      *              * Start su [oce]                                  *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DOCDST    "         to   f-key                  .
           move      w-det-prt-eml-prt    to   rf-oce-prt-doc         .
           move      zero                 to   rf-oce-num-dst         .
           move      zero                 to   rf-oce-num-prg         .
           move      "pgm/orc/fls/ioc/obj/iofoce"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oce                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : ad uscita                 *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-prt-eml-900.
       det-prt-eml-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale [oce]                       *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofoce"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oce                 .
      *                  *---------------------------------------------*
      *                  * Se fine file : ad uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-prt-eml-900.
       det-prt-eml-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-oce-prt-doc       not  = w-det-prt-eml-prt
                     go to det-prt-eml-900.
       det-prt-eml-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se inviato                             *
      *                  *---------------------------------------------*
           if        rf-oce-dat-inv       =    zero
                     go to det-prt-eml-200.
       det-prt-eml-600.
      *              *-------------------------------------------------*
      *              * Incremento contatore                            *
      *              *-------------------------------------------------*
           if        rf-oce-num-dst       =    w-det-prt-eml-dst
                     go to det-prt-eml-200.
           add       1                    to   w-det-prt-eml-ele      .
      *              *-------------------------------------------------*
      *              * Aggiornamento comodo di rottura protocollo      *
      *              * distinta                                        *
      *              *-------------------------------------------------*
           move      rf-oce-num-dst       to   w-det-prt-eml-dst      .
       det-prt-eml-800.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     det-prt-eml-200.
       det-prt-eml-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-prt-eml-999.
       det-prt-eml-999.
           exit.

      *    *===========================================================*
      *    * Determinazione quantita' secondaria per la vendita        *
      *    *-----------------------------------------------------------*
           copy      "pgm/fat/prg/cpy/wdetqts0.wks"                   .

      *    *===========================================================*
      *    * Routine di controllo riferimenti ordine cliente           *
      *    *-----------------------------------------------------------*
       ctl-rif-arc-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di esito                   *
      *              *-------------------------------------------------*
           move      spaces               to   w-ctl-rif-arc-flg      .
      *              *-------------------------------------------------*
      *              * Normalizzazione contatore                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-ctl-rif-arc-ctr      .
      *              *-------------------------------------------------*
      *              * Determinazione date                             *
      *              *-------------------------------------------------*
           move      w-ctl-rif-arc-dat    to   w-ctl-rif-arc-dmi      .
           move      w-ctl-rif-arc-dmi    to   s-dat                  .
           move      01                   to   s-mes                  .
           move      01                   to   s-gio                  .
           move      s-dat                to   w-ctl-rif-arc-dmi      .
      *
           move      w-ctl-rif-arc-dat    to   w-ctl-rif-arc-dma      .
       ctl-rif-arc-050.
      *              *-------------------------------------------------*
      *              * Test preliminari                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice cliente                      *
      *                  *---------------------------------------------*
           if        w-ctl-rif-arc-cli    =    zero
                     go to ctl-rif-arc-999.
      *                  *---------------------------------------------*
      *                  * Test su numero ordine cliente               *
      *                  *---------------------------------------------*
           if        w-ctl-rif-arc-num    =    spaces
                     go to ctl-rif-arc-999.
       ctl-rif-arc-100.
      *              *-------------------------------------------------*
      *              * Start su file [oct]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DPZARCDAT "         to   f-key                  .
           move      w-ctl-rif-arc-dpz    to   rf-oct-cod-dpz         .
           move      "C"                  to   rf-oct-tip-arc         .
           move      w-ctl-rif-arc-cli    to   rf-oct-cod-arc         .
           move      w-ctl-rif-arc-dmi    to   rf-oct-dat-doc         .
           move      zero                 to   rf-oct-num-doc         .
           move      zero                 to   rf-oct-num-prt         .
           move      "pgm/orc/fls/ioc/obj/iofoct"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oct                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : a test finale             *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to ctl-rif-arc-800.
       ctl-rif-arc-200.
      *              *-------------------------------------------------*
      *              * Next su [oct]                                   *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofoct"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oct                 .
      *                  *---------------------------------------------*
      *                  * Se 'at end' : a test finale                 *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to ctl-rif-arc-800.
       ctl-rif-arc-300.
      *              *-------------------------------------------------*
      *              * Max su [oct], se non superato : a test finale   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice dipendenza                   *
      *                  *---------------------------------------------*
           if        rf-oct-cod-dpz       not  = w-ctl-rif-arc-dpz
                     go to ctl-rif-arc-800.
      *                  *---------------------------------------------*
      *                  * Test su tipo archivio                       *
      *                  *---------------------------------------------*
           if        rf-oct-tip-arc       not  = "C"
                     go to ctl-rif-arc-800.
      *                  *---------------------------------------------*
      *                  * Test su tipo archivio                       *
      *                  *---------------------------------------------*
           if        rf-oct-cod-arc       not  = w-ctl-rif-arc-cli
                     go to ctl-rif-arc-800.
      *                  *---------------------------------------------*
      *                  * Test su date                                *
      *                  *---------------------------------------------*
           if        rf-oct-dat-doc       >    w-ctl-rif-arc-dma
                     go to ctl-rif-arc-800.
       ctl-rif-arc-400.
      *              *-------------------------------------------------*
      *              * Selezione su riferimenti ordine cliente         *
      *              *-------------------------------------------------*
           if        rf-oct-ocl-num       not  = w-ctl-rif-arc-num
                     go to ctl-rif-arc-200.
       ctl-rif-arc-500.
      *              *-------------------------------------------------*
      *              * Incremento contatore                            *
      *              *-------------------------------------------------*
           add       1                    to   w-ctl-rif-arc-ctr      .
       ctl-rif-arc-700.
      *              *-------------------------------------------------*
      *              * Riciclo a record [oct] successivo               *
      *              *-------------------------------------------------*
           go to     ctl-rif-arc-200.
       ctl-rif-arc-800.
      *              *-------------------------------------------------*
      *              * Determinazione finale                           *
      *              *-------------------------------------------------*
           if        w-ctl-rif-arc-ctr    =    zero
                     go to ctl-rif-arc-999
           else      go to ctl-rif-arc-900.
       ctl-rif-arc-900.
      *              *-------------------------------------------------*
      *              * Uscita per incongruenza                         *
      *              *-------------------------------------------------*
           move      "#"                  to   w-ctl-rif-arc-flg      .
       ctl-rif-arc-999.
           exit.

      *    *===========================================================*
      *    * Controllo tipo riga                                       *
      *    *-----------------------------------------------------------*
       ctl-tip-rig-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-ctl-tip-rig-flg      .
      *              *-------------------------------------------------*
      *              * Test che non ci siano blanks embedded           *
      *              *-------------------------------------------------*
           move      w-ctl-tip-rig-tri    to   w-all-str-alf          .
           move      05                   to   w-all-str-lun          .
           perform   all-str-ble-000      thru all-str-ble-999        .
           if        w-all-str-flg        not  = spaces
                     go to ctl-tip-rig-900.
      *              *-------------------------------------------------*
      *              * Controllo se ci sono asterischi                 *
      *              *-------------------------------------------------*
           move      zero                 to   w-ctl-tip-rig-inx      .
           inspect   w-ctl-tip-rig-tri
                                      tallying w-ctl-tip-rig-inx
                                          for  all "*"                .
      *               *------------------------------------------------*
      *               * Deviazione in funzione del numero asterischi   *
      *               * trovati                                        *
      *               *------------------------------------------------*
           if        w-ctl-tip-rig-inx    =    zero
                     go to ctl-tip-rig-200
           else if   w-ctl-tip-rig-inx    =    1
                     go to ctl-tip-rig-100
           else      go to ctl-tip-rig-900.
       ctl-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Se c'e' un asterisco                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Sostituzione con carattere spazio           *
      *                  *---------------------------------------------*
           inspect   w-ctl-tip-rig-tri
                                     replacing all "*" by   spaces    .
      *                  *---------------------------------------------*
      *                  * Test che non ci siano blanks embedded       *
      *                  *---------------------------------------------*
           move      w-ctl-tip-rig-tri    to   w-all-str-alf          .
           move      05                   to   w-all-str-lun          .
           perform   all-str-ble-000      thru all-str-ble-999        .
           if        w-all-str-flg        not  = spaces
                     go to ctl-tip-rig-900.
      *                  *---------------------------------------------*
      *                  * Segnale di presenza di asterisco            *
      *                  *---------------------------------------------*
           move      "#"                  to   w-rig-tip-rig-ast (1)  .
      *                  ***********************************************
      *                  * Non essendo ancora attivata la gestione a   *
      *                  * blocchi, la presenza dell'asterisco viene   *
      *                  * considerata errore                          *
      *                  ***********************************************
           go to     ctl-tip-rig-900.
       ctl-tip-rig-200.
      *              *-------------------------------------------------*
      *              * Test se valore ammesso                          *
      *              *-------------------------------------------------*
           if        w-ctl-tip-rig-tri    not  = "P    " and
                     w-ctl-tip-rig-tri    not  = "PN   " and
                     w-ctl-tip-rig-tri    not  = "C    " and
                     w-ctl-tip-rig-tri    not  = "A    "
                     go to ctl-tip-rig-900.
      *              *-------------------------------------------------*
      *              * Memorizzazione tipo riga                        *
      *              *-------------------------------------------------*
           move      w-ctl-tip-rig-chr (1)
                                          to   w-rig-tip-rig-tpr (1)  .
      *              *-------------------------------------------------*
      *              * Memorizzazione tipo funzionamento               *
      *              *-------------------------------------------------*
           move      w-ctl-tip-rig-chr (2)
                                          to   w-rig-tip-rig-tfu (1)  .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     ctl-tip-rig-999.
       ctl-tip-rig-900.
      *              *-------------------------------------------------*
      *              * Uscita con errore                               *
      *              *-------------------------------------------------*
           move      "#"                  to   w-ctl-tip-rig-flg      .
       ctl-tip-rig-999.
           exit.

      *    *===========================================================*
      *    * Controllo codice iva                                      *
      *    *-----------------------------------------------------------*
       ctl-cod-iva-000.
      *              *-------------------------------------------------*
      *              * Controllo                                       *
      *              *-------------------------------------------------*
           move      "CT"                 to   d-imp-iva-tip-ope      .
           perform   det-imp-iva-cll-000  thru det-imp-iva-cll-999    .
       ctl-cod-iva-999.
           exit.

      *    *===========================================================*
      *    * Controllo congruenza prezzo                               *
      *    *-----------------------------------------------------------*
       ctl-cng-prz-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione tipo errore in uscita           *
      *              *-------------------------------------------------*
           move      spaces               to   w-ctl-cng-prz-ter      .
      *              *-------------------------------------------------*
      *              * Se controllo da non eseguire : a uscita         *
      *              *-------------------------------------------------*
           if        w-prs-cnt-cng-prz    =    "N"
                     go to ctl-cng-prz-900.
      *              *-------------------------------------------------*
      *              * Determinazione primo prezzo per il confronto    *
      *              *-------------------------------------------------*
           if        w-prs-cnt-prz-001    =    "N"
                     move  w-rig-prz-nts (1)
                                          to   w-ctl-cng-prz-001
           else if   w-prs-cnt-prz-001    =    "L"
                     move  w-rig-prz-lrs (1)
                                          to   w-ctl-cng-prz-001
           else      move  zero           to   w-ctl-cng-prz-001      .
      *              *-------------------------------------------------*
      *              * Se primo prezzo per il confronto a zero : a u-  *
      *              * scita                                           *
      *              *-------------------------------------------------*
           if        w-ctl-cng-prz-001    =    zero
                     go to ctl-cng-prz-900.
      *              *-------------------------------------------------*
      *              * Determinazione secondo prezzo per il confronto  *
      *              *-------------------------------------------------*
           if        w-prs-cnt-prz-002    =    "N"
                     move  w-rig-prz-net (1)
                                          to   w-ctl-cng-prz-002
           else if   w-prs-cnt-prz-002    =    "L"
                     move  w-rig-prz-ven (1)
                                          to   w-ctl-cng-prz-002
           else      move  zero           to   w-ctl-cng-prz-002      .
      *              *-------------------------------------------------*
      *              * Se secondo prezzo per il confronto a zero : a   *
      *              * uscita                                          *
      *              *-------------------------------------------------*
           if        w-ctl-cng-prz-002    =    zero
                     go to ctl-cng-prz-900.
       ctl-cng-prz-100.
      *              *-------------------------------------------------*
      *              * Eventuale conversione primo prezzo per il con-  *
      *              * fronto nella valuta per il prezzo               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se necessario                          *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vps (1)    =    w-rig-sgl-vpp (1)
                     go to ctl-cng-prz-200.
      *                  *---------------------------------------------*
      *                  * Conversione valore da valuta per i prezzi   *
      *                  * standard a valuta base                      *
      *                  *---------------------------------------------*
           move      w-rig-sgl-vps (1)    to   w-cvs-vlt-sgl          .
           move      w-rig-dec-vps (1)    to   w-cvs-vlt-dec          .
           move      w-rig-tdc-vps (1)    to   w-cvs-vlt-tdc          .
           move      w-rig-cdc-vps (1)    to   w-cvs-vlt-cdc          .
           move      w-ctl-cng-prz-001    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
      *                  *---------------------------------------------*
      *                  * Conversione valore da valuta base a valuta  *
      *                  * per il prezzo                               *
      *                  *---------------------------------------------*
           move      w-rig-sgl-vpp (1)    to   w-cvs-vlt-sgl          .
           move      w-rig-dec-vpp (1)    to   w-cvs-vlt-dec          .
           move      w-rig-tdc-vpp (1)    to   w-cvs-vlt-tdc          .
           move      w-rig-cdc-vpp (1)    to   w-cvs-vlt-cdc          .
           perform   cvs-vlb-alt-000      thru cvs-vlb-alt-999        .
           move      w-cvs-vlt-aav        to   w-ctl-cng-prz-001      .
       ctl-cng-prz-200.
      *              *-------------------------------------------------*
      *              * Se primo prezzo per il confronto a zero : a u-  *
      *              * scita                                           *
      *              *-------------------------------------------------*
           if        w-ctl-cng-prz-001    =    zero
                     go to ctl-cng-prz-900.
      *              *-------------------------------------------------*
      *              * Se i due prezzi di confronto risultano uguali,  *
      *              * a uscita                                        *
      *              *-------------------------------------------------*
           if        w-ctl-cng-prz-001    =    w-ctl-cng-prz-002
                     go to ctl-cng-prz-900.
       ctl-cng-prz-300.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda che si tratti di uno sco-  *
      *              * stamento in diminuzione o in aumento            *
      *              *-------------------------------------------------*
           if        w-ctl-cng-prz-002    <    w-ctl-cng-prz-001
                     go to ctl-cng-prz-400
           else      go to ctl-cng-prz-600.
       ctl-cng-prz-400.
      *              *-------------------------------------------------*
      *              * Se scostamento in diminuzione                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se controllo da eseguire               *
      *                  *---------------------------------------------*
           if        w-prs-cnt-tdt-dim    not  = 01 or
                     w-prs-cnt-per-dim    =    zero
                     go to ctl-cng-prz-900.
      *                  *---------------------------------------------*
      *                  * Determinazione valore dello scostamento     *
      *                  *---------------------------------------------*
           subtract  w-ctl-cng-prz-002    from w-ctl-cng-prz-001
                                        giving w-ctl-cng-prz-wvs      .
      *                  *---------------------------------------------*
      *                  * Determinazione percentuale di scostamento   *
      *                  *---------------------------------------------*
           multiply  100                  by   w-ctl-cng-prz-wvs      .
           divide    w-ctl-cng-prz-001    into w-ctl-cng-prz-wvs
                                        giving w-ctl-cng-prz-wps
                                               rounded                .
      *                  *---------------------------------------------*
      *                  * Confronto con percentuale da personalizza-  *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           if        w-ctl-cng-prz-wps    not  > w-prs-cnt-per-dim
                     go to ctl-cng-prz-900.
      *                  *---------------------------------------------*
      *                  * Composizione messaggio di errore            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing percentuale di scostamento mas- *
      *                      * sima                                    *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-prs-cnt-per-dim    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Composizione stringa                    *
      *                      *-----------------------------------------*
           move      spaces               to   w-ctl-cng-prz-msg      .
           string    "Prezzo praticato abbattuto di piu' del "
      -                         delimited by   size
                     v-edt      delimited by   spaces
                     "%"        delimited by   size
                                          into w-ctl-cng-prz-msg      .
      *                  *---------------------------------------------*
      *                  * Determinazione tipo di errore a seconda     *
      *                  * della personalizzazione                     *
      *                  *---------------------------------------------*
           if        w-prs-cnt-cng-prz    =    "S"
                     move  "B"            to   w-ctl-cng-prz-ter
           else if   w-prs-cnt-cng-prz    =    "M"
                     move  "N"            to   w-ctl-cng-prz-ter      .
      *                  *---------------------------------------------*
      *                  * A uscita                                    *
      *                  *---------------------------------------------*
           go to     ctl-cng-prz-900.
       ctl-cng-prz-600.
      *              *-------------------------------------------------*
      *              * Se scostamento in aumento                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se controllo da eseguire               *
      *                  *---------------------------------------------*
           if        w-prs-cnt-tdt-aum    not  = 01 or
                     w-prs-cnt-per-aum    =    zero
                     go to ctl-cng-prz-900.
      *                  *---------------------------------------------*
      *                  * Determinazione valore dello scostamento     *
      *                  *---------------------------------------------*
           subtract  w-ctl-cng-prz-001    from w-ctl-cng-prz-002
                                        giving w-ctl-cng-prz-wvs      .
      *                  *---------------------------------------------*
      *                  * Determinazione percentuale di scostamento   *
      *                  *---------------------------------------------*
           multiply  100                  by   w-ctl-cng-prz-wvs      .
           divide    w-ctl-cng-prz-001    into w-ctl-cng-prz-wvs
                                        giving w-ctl-cng-prz-wps
                                               rounded                .
      *                  *---------------------------------------------*
      *                  * Confronto con percentuale da personalizza-  *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           if        w-ctl-cng-prz-wps    not  > w-prs-cnt-per-aum
                     go to ctl-cng-prz-900.
      *                  *---------------------------------------------*
      *                  * Composizione messaggio di errore            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing percentuale di scostamento mas- *
      *                      * sima                                    *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-prs-cnt-per-aum    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Composizione stringa                    *
      *                      *-----------------------------------------*
           move      spaces               to   w-ctl-cng-prz-msg      .
           string    "Prezzo praticato maggiorato di piu' del "
      -                         delimited by   size
                     v-edt      delimited by   spaces
                     "%"        delimited by   size
                                          into w-ctl-cng-prz-msg      .
      *                  *---------------------------------------------*
      *                  * Determinazione tipo di errore a seconda     *
      *                  * della personalizzazione                     *
      *                  *---------------------------------------------*
           if        w-prs-cnt-cng-prz    =    "S"
                     move  "B"            to   w-ctl-cng-prz-ter
           else if   w-prs-cnt-cng-prz    =    "M"
                     move  "N"            to   w-ctl-cng-prz-ter      .
      *                  *---------------------------------------------*
      *                  * A uscita                                    *
      *                  *---------------------------------------------*
           go to     ctl-cng-prz-900.
       ctl-cng-prz-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     ctl-cng-prz-999.
       ctl-cng-prz-999.
           exit.

      *    *===========================================================*
      *    * Calcolo prezzo netto                                      *
      *    *-----------------------------------------------------------*
           copy      "swd/std/prg/cpy/wcalprz0.cps"                   .

      *    *===========================================================*
      *    * Determinazione prezzo sottoposto a legame valutario       *
      *    *                                                           *
      *    * Input  : w-lvl-prz-prz = Prezzo da sottoporre a legame    *
      *    *                                                           *
      *    *          w-lvl-prz-vlt = Valuta per il legame             *
      *    *                                                           *
      *    *          w-lvl-prz-tdc = Tipo di cambio valuta            *
      *    *                                                           *
      *    *          w-lvl-prz-cdc = Coefficiente di cambio attuale   *
      *    *                                                           *
      *    *          w-lvl-prz-ccr = Coefficiente di cambio di rife-  *
      *    *                          rimento                          *
      *    *                                                           *
      *    *          w-lvl-prz-plm = Percentuale di limitazione       *
      *    *                                                           *
      *    *          w-lvl-prz-tlm = Tipo di limitazione              *
      *    *                                                           *
      *    *                                                           *
      *    * Output : w-lvl-prz-prz = Prezzo determinato               *
      *    *                                                           *
      *    *-----------------------------------------------------------*
           copy      "swd/std/prg/cpy/wlvlprz0.cps"                   .

      *    *===========================================================*
      *    * Routine di conversione da altra valuta a valuta base      *
      *    *                                                           *
      *    * Input  : w-cvs-vlt-sgl = Sigla dell'altra valuta          *
      *    *                                                           *
      *    *          w-cvs-vlt-dec = Numero decimali dell'altra valu- *
      *    *                          ta                               *
      *    *                                                           *
      *    *          w-cvs-vlt-tdc = Tipo di coefficiente dell'altra  *
      *    *                          valuta                           *
      *    *                                                           *
      *    *          w-cvs-vlt-cdc = Coefficiente di cambio dell'al-  *
      *    *                          tra valuta                       *
      *    *                                                           *
      *    *          w-cvs-vlt-aav = Ammontare da convertire, espres- *
      *    *                          so nell'altra valuta             *
      *    *                                                           *
      *    * Output : w-cvs-vlt-avb = Ammontare convertito, espresso   *
      *    *                          nella valuta base                *
      *    *                                                           *
      *    *-----------------------------------------------------------*
      *    * Routine di conversione da valuta base ad altra valuta     *
      *    *                                                           *
      *    * Input  : w-cvs-vlt-sgl = Sigla dell'altra valuta          *
      *    *                                                           *
      *    *          w-cvs-vlt-dec = Numero decimali dell'altra valu- *
      *    *                          ta                               *
      *    *                                                           *
      *    *          w-cvs-vlt-tdc = Tipo di coefficiente dell'altra  *
      *    *                          valuta                           *
      *    *                                                           *
      *    *          w-cvs-vlt-cdc = Coefficiente di cambio dell'al-  *
      *    *                          tra valuta                       *
      *    *                                                           *
      *    *          w-cvs-vlt-avb = Ammontare da convertire, espres- *
      *    *                          so nella valuta base             *
      *    *                                                           *
      *    * Output : w-cvs-vlt-aav = Ammontare convertito, espresso   *
      *    *                          nell'altra valuta                *
      *    *                                                           *
      *    *-----------------------------------------------------------*
           copy      "swd/std/prg/cpy/wcvsvlt0.cps"                   .

      *    *===========================================================*
      *    * Routine di composizione tipo riga                         *
      *    *                                                           *
      *    * Input  : w-rig-tip-rig (1) e relativi valori di w-rig con-*
      *    *          nessi                                            *
      *    *                                                           *
      *    * Output : rf-ocr-tip-rig                                   *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       cmp-tip-rig-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione puntatore per string           *
      *              *-------------------------------------------------*
           move      01                   to   w-cmp-tip-rig-pnt      .
      *              *-------------------------------------------------*
      *              * Tipo riga                                       *
      *              *-------------------------------------------------*
           move      w-rig-tip-rig-tpr (1)
                                          to   rf-ocr-tip-rig         .
      *              *-------------------------------------------------*
      *              * Tipo funzionamento                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se a spazi : oltre                          *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    spaces
                     go to cmp-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * String del tipo funzionamento               *
      *                  *---------------------------------------------*
           add       1                    to   w-cmp-tip-rig-pnt      .
           string    w-rig-tip-rig-tfu (1)
                                delimited by   spaces
                                          into rf-ocr-tip-rig
                                  with pointer w-cmp-tip-rig-pnt      .
       cmp-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Codice addebito o commento                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Solo se tipo riga 'A' o 'C'                 *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "A" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "C"
                     go to cmp-tip-rig-200.
      *                  *---------------------------------------------*
      *                  * Se codice addebito o commento a zero : oltre*
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-cac (1)
                                          =    zero
                     go to cmp-tip-rig-200.
      *                  *---------------------------------------------*
      *                  * Editing codice addebito o commento          *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-rig-tip-rig-cac (1)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * String codice addebito o commento           *
      *                  *---------------------------------------------*
           add       1                    to   w-cmp-tip-rig-pnt      .
           string    v-edt      delimited by   spaces
                                          into rf-ocr-tip-rig
                                  with pointer w-cmp-tip-rig-pnt      .
       cmp-tip-rig-200.
      *              *-------------------------------------------------*
      *              * Asterisco                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se non presente : oltre                     *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-ast (1)
                                          =    spaces
                     go to cmp-tip-rig-300.
      *                  *---------------------------------------------*
      *                  * String asterisco                            *
      *                  *---------------------------------------------*
           add       1                    to   w-cmp-tip-rig-pnt      .
           string    "*"        delimited by   size
                                          into rf-ocr-tip-rig
                                  with pointer w-cmp-tip-rig-pnt      .
       cmp-tip-rig-300.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     cmp-tip-rig-999.
       cmp-tip-rig-999.
           exit.

      *    *===========================================================*
      *    * Routine di decomposizione tipo riga                       *
      *    *                                                           *
      *    * Input  : rf-ocr-tip-rig                                   *
      *    *                                                           *
      *    * Output : w-rig-tip-rig (1) e relativi valori di w-rig con-*
      *    *          nessi                                            *
      *    *-----------------------------------------------------------*
       dec-tip-rig-000.
      *              *-------------------------------------------------*
      *              * Tipo riga in comodo di lavoro ridefinito        *
      *              *-------------------------------------------------*
           move      rf-ocr-tip-rig       to    w-dec-tip-rig-str     .
      *              *-------------------------------------------------*
      *              * Normalizzazione area di w-rig relativa al tipo  *
      *              * riga                                            *
      *              *-------------------------------------------------*
           move      spaces               to    w-rig-tip-rig (1)     .
           move      spaces               to    w-rig-tip-rig-tpr (1) .
           move      spaces               to    w-rig-tip-rig-tfu (1) .
           move      zero                 to    w-rig-tip-rig-cac (1) .
           move      spaces               to    w-rig-tip-rig-ast (1) .
      *              *-------------------------------------------------*
      *              * Presenza o assenza dell'asterisco               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ispezione stringa                           *
      *                  *---------------------------------------------*
           move      zero                 to   w-dec-tip-rig-inx      .
           inspect   w-dec-tip-rig-str
                                      tallying w-dec-tip-rig-inx
                                          for  all "*"                .
      *                  *---------------------------------------------*
      *                  * Se nessun asterisco trovato : oltre         *
      *                  *---------------------------------------------*
           if        w-dec-tip-rig-inx    =    zero
                     go to dec-tip-rig-100.
      *                  *---------------------------------------------*
      *                  * Segnale di presenza asterisco               *
      *                  *---------------------------------------------*
           move      "#"                  to   w-rig-tip-rig-ast (1)  .
      *                  *---------------------------------------------*
      *                  * Pulizia stringa da asterisco                *
      *                  *---------------------------------------------*
           inspect   w-dec-tip-rig-str
                                     replacing all "*" by   spaces    .
       dec-tip-rig-100.
      *              *-------------------------------------------------*
      *              * Memorizzazione tipo riga                        *
      *              *-------------------------------------------------*
           move      w-dec-tip-rig-chr (1)
                                          to   w-rig-tip-rig-tpr (1)  .
      *              *-------------------------------------------------*
      *              * Test se esiste un tipo funzionamento            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Solo per tipi riga P o L                    *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "L"
                     go to dec-tip-rig-200.
      *                  *---------------------------------------------*
      *                  * Se secondo carattere della stringa a spazi :*
      *                  * oltre                                       *
      *                  *---------------------------------------------*
           if        w-dec-tip-rig-chr (2)
                                          =    spaces
                     go to dec-tip-rig-200.
      *                  *---------------------------------------------*
      *                  * Memorizzazione tipo funzionamento           *
      *                  *---------------------------------------------*
           move      w-dec-tip-rig-chr (2)
                                          to   w-rig-tip-rig-tfu (1)  .
       dec-tip-rig-200.
      *              *-------------------------------------------------*
      *              * Ricerca di un codice addebito o commento        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Solo se tipo riga A o C                     *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "A" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "C"
                     go to dec-tip-rig-300.
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione stringa a ritroso        *
      *                  *---------------------------------------------*
           move      zero                 to   w-dec-tip-rig-cod      .
           move      6                    to   w-dec-tip-rig-c01      .
           move      3                    to   w-dec-tip-rig-c02      .
       dec-tip-rig-210.
           subtract  1                    from w-dec-tip-rig-c01      .
           if        w-dec-tip-rig-chr
                    (w-dec-tip-rig-c01)   =    w-rig-tip-rig-tpr (1)
                     go to dec-tip-rig-220.
           if        w-dec-tip-rig-chr
                    (w-dec-tip-rig-c01)   =    spaces or
                     w-dec-tip-rig-chr
                    (w-dec-tip-rig-c01)   <    "0"    or
                     w-dec-tip-rig-chr
                    (w-dec-tip-rig-c01)   >    "9"
                     go to dec-tip-rig-210.
