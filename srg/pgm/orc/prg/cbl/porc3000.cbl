      *                              *---------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Video in Off                    *
      *                              *---------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Box per messaggio all'operatore *
      *                              *---------------------------------*
           move      "BX"                 to   v-ope                  .
           move      09                   to   v-lin                  .
           move      18                   to   v-lto                  .
           move      09                   to   v-pos                  .
           move      72                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Messaggi entro il box           *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Titolo centrale             *
      *                                  *-----------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      11                   to   v-pos                  .
           move      "                      A T T E N Z I O N E         
      -              "          "         to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                  *-----------------------------*
      *                                  * Numeri saltati              *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Preparazione differenza *
      *                                      *-------------------------*
           move      w-att-orc-ndo-prg    to   w-att-orc-ndo-wdf      .
           subtract  w-att-orc-ndo-wpr    from w-att-orc-ndo-wdf      .
           add       1                    to   w-att-orc-ndo-wdf      .
      *                                      *-------------------------*
      *                                      * Preparazione numero     *
      *                                      *-------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-att-orc-ndo-wdf    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                                      *-------------------------*
      *                                      * Stringa per 1 numero    *
      *                                      *-------------------------*
           if        v-num                >    1
                     go to att-orc-ndo-410.
           move      spaces               to   v-alf                  .
           string    "La numerazione e' stata aumentata di "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " numero."
                                delimited by   size
                                          into v-alf                  .
           go to     att-orc-ndo-420.
       att-orc-ndo-410.
      *                                      *-------------------------*
      *                                      * Stringa per piu' numeri *
      *                                      *-------------------------*
           move      spaces               to   v-alf                  .
           string    "La numerazione e' stata aumentata di "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " numeri."
                                delimited by   size
                                          into v-alf                  .
       att-orc-ndo-420.
      *                                      *-------------------------*
      *                                      * Visualizzazione stringa *
      *                                      *-------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      11                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                      *-------------------------*
      *                                      * Prompt per richiesta    *
      *                                      *-------------------------*
      *                                          *---------------------*
      *                                          * Preparazione pros-  *
      *                                          * simo numero         *
      *                                          *---------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-att-orc-ndo-prg    to   v-num                  .
           add       1                    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                                          *---------------------*
      *                                          * Visualizzazione     *
      *                                          *---------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      11                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           string    "Si vuole che prosegua dal numero "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " ?"
                                delimited by   size
                                          into v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Video in On                     *
      *                              *---------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       att-orc-ndo-430.
      *                              *---------------------------------*
      *                              * Scelta dell'operatore           *
      *                              *---------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-rat-ndo-lun    to   v-car                  .
           move      w-exp-rat-ndo-num    to   v-ldt                  .
           move      "UNS#"               to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      15                   to   v-lin                  .
           move      54                   to   v-pos                  .
           move      w-exp-rat-ndo-tbl    to   v-txt                  .
           move      "EXIT"               to   v-pfk (20)             .
           move      zero                 to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-num                to   w-exp-rat-ndo-sce      .
      *                              *---------------------------------*
      *                              * Controllo risposta              *
      *                              *---------------------------------*
           if        w-exp-rat-ndo-sce    =    01 or
                     w-exp-rat-ndo-sce    =    02 or
                     w-exp-rat-ndo-sce    =    03
                     go to att-orc-ndo-440.
           if        v-key                =    "EXIT"
                     go to att-orc-ndo-440.
           go to     att-orc-ndo-430.
       att-orc-ndo-440.
      *                              *---------------------------------*
      *                              * Ripristino immagine video       *
      *                              *---------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Esame risposta                  *
      *                              *---------------------------------*
           if        v-key                =    "EXIT"
                     move  "#"            to   w-att-orc-ndo-flg
                     go to att-orc-ndo-600.
           if        w-exp-rat-ndo-sce    =    01
                     move  "#"            to   w-att-orc-ndo-flg
                     go to att-orc-ndo-600
           else if   w-exp-rat-ndo-sce    =    03
                     go to att-orc-ndo-500
           else if   w-exp-rat-ndo-sce    =    02
                     go to att-orc-ndo-600.
       att-orc-ndo-500.
      *                              *---------------------------------*
      *                              * Se risposta positiva            *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Aggiornamento numerazione   *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Numero                  *
      *                                      *-------------------------*
           move      w-att-orc-ndo-num    to   w-att-orc-ndo-wnu      .
           move      w-att-orc-ndo-saa    to   w-att-orc-ndo-wsa      .
           move      w-att-orc-ndo-dpz    to   w-att-orc-ndo-wdz      .
           move      w-att-orc-ndo-wnu    to   rn-orc-ndo-num-doc     .
      *                                      *-------------------------*
      *                                      * Data                    *
      *                                      *-------------------------*
           move      w-att-orc-ndo-dat    to   rn-orc-ndo-dat-doc     .
      *                                  *-----------------------------*
      *                                  * Update record               *
      *                                  *-----------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/orc/num/ioc/obj/inorcndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orc-ndo             .
      *                                  *-----------------------------*
      *                                  * Se errori ripete l'intera   *
      *                                  * operazione                  *
      *                                  *-----------------------------*
           if        f-sts                not  = e-not-err
                     go to att-orc-ndo-000.
      *                                  *-----------------------------*
      *                                  * Unlock della numerazione    *
      *                                  *-----------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/orc/num/ioc/obj/inorcndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orc-ndo             .
      *                                  *-----------------------------*
      *                                  * Salvataggio nuovo valore    *
      *                                  *-----------------------------*
           move      rn-orc-ndo-num-doc   to   w-att-orc-ndo-new      .
      *                                  *-----------------------------*
      *                                  * Uscita                      *
      *                                  *-----------------------------*
           go to     att-orc-ndo-999.
       att-orc-ndo-600.
      *                              *---------------------------------*
      *                              * Se risposta negativa            *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Unlock della numerazione    *
      *                                  *-----------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/orc/num/ioc/obj/inorcndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orc-ndo             .
      *                                  *-----------------------------*
      *                                  * Nessun nuovo valore         *
      *                                  *-----------------------------*
           move      zero                 to   w-att-orc-ndo-new      .
      *                                  *-----------------------------*
      *                                  * Uscita                      *
      *                                  *-----------------------------*
           go to     att-orc-ndo-999.
       att-orc-ndo-999.
           exit.

      *    *===========================================================*
      *    * Routine di ripristino numero documento ordini clienti     *
      *    *-----------------------------------------------------------*
       rip-orc-ndo-000.
      *              *-------------------------------------------------*
      *              * Se nessun nuovo numero documento : uscita       *
      *              *-------------------------------------------------*
           if        w-att-orc-ndo-new    =    zero
                     go to rip-orc-ndo-999.
      *              *-------------------------------------------------*
      *              * Composizione chiave per lettura                 *
      *              *-------------------------------------------------*
           move      w-att-orc-ndo-dat    to   s-dat                  .
           move      s-saa                to   w-att-orc-ndo-saa      .
           move      w-att-orc-ndo-saa    to   rn-orc-ndo-scl-ann     .
           move      w-att-orc-ndo-dpz    to   rn-orc-ndo-cod-dpz     .
           move      w-att-orc-ndo-sgl    to   rn-orc-ndo-sgl-num     .
      *              *-------------------------------------------------*
      *              * Lettura numerazione                             *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/orc/num/ioc/obj/inorcndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orc-ndo             .
           if        f-sts                =    e-not-err
                     go to rip-orc-ndo-100.
      *              *-------------------------------------------------*
      *              * Se numerazione non esistente la si crea norma-  *
      *              * lizzata a zero                                  *
      *              *-------------------------------------------------*
           move      zero                 to   rn-orc-ndo-num-doc     .
           move      zero                 to   rn-orc-ndo-dat-doc     .
           move      "PT"                 to   f-ope                  .
           move      "pgm/orc/num/ioc/obj/inorcndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orc-ndo             .
           go to     rip-orc-ndo-000.
       rip-orc-ndo-100.
      *              *-------------------------------------------------*
      *              * Se numerazione esistente                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Controllo se il valore attuale della nume-  *
      *                  * razione e' tuttora inalterato rispetto al-  *
      *                  * l'aggiornamento eseguito in fase di attri-  *
      *                  * buzione del numero                          *
      *                  *---------------------------------------------*
           if        rn-orc-ndo-num-doc   =    w-att-orc-ndo-new
                     go to rip-orc-ndo-200
           else      go to rip-orc-ndo-400.
       rip-orc-ndo-200.
      *                  *---------------------------------------------*
      *                  * Se il valore risulta inalterato             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controaggiornamento record              *
      *                      *-----------------------------------------*
           move      w-att-orc-ndo-nsv    to   rn-orc-ndo-num-doc     .
           move      w-att-orc-ndo-dsv    to   rn-orc-ndo-dat-doc     .
           move      "UP"                 to   f-ope                  .
           move      "pgm/orc/num/ioc/obj/inorcndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orc-ndo             .
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/orc/num/ioc/obj/inorcndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orc-ndo             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rip-orc-ndo-000.
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rip-orc-ndo-999.
       rip-orc-ndo-400.
      *                  *---------------------------------------------*
      *                  * Se il valore risulta cambiato               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se il cambiamento corrisponde alla for- *
      *                      * zatura eseguita dall'operatore stesso   *
      *                      * in caso di impostazione di un numero    *
      *                      * superiore al progressivo : si controag- *
      *                      * giorna senza alcun messaggio            *
      *                      *-----------------------------------------*
           if        rn-orc-ndo-num-doc   =    w-att-orc-ndo-num
                     go to rip-orc-ndo-200.
      *                      *-----------------------------------------*
      *                      * Se il cambiamento invece e' dovuto al   *
      *                      * fatto che un altro utente ha nel frat-  *
      *                      * tempo prelevato un numero progressivo   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Unlock                              *
      *                          *-------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/orc/num/ioc/obj/inorcndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orc-ndo             .
      *                          *-------------------------------------*
      *                          * Messaggio all'operatore che il nu-  *
      *                          * mero deve essere recuperato manual- *
      *                          * mente                               *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Salvataggio del video attuale   *
      *                              *---------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Video in Off                    *
      *                              *---------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Box                             *
      *                              *---------------------------------*
           move      "BX"                 to   v-ope                  .
           move      09                   to   v-lin                  .
           move      18                   to   v-lto                  .
           move      08                   to   v-pos                  .
           move      73                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Messaggi entro il box           *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Titolo centrale             *
      *                                  *-----------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "                     A T T E N Z I O N E          
      -              "            "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                  *-----------------------------*
      *                                  * Riga messaggio 1            *
      *                                  *-----------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "Un altro utente ha nel frattempo prelevato un nume
      -              "ro !        "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                  *-----------------------------*
      *                                  * Riga messaggio 2            *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Preparazione numero do- *
      *                                      * cumento editato         *
      *                                      *-------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-att-orc-ndo-new    to   w-att-orc-ndo-wnu      .
           move      w-att-orc-ndo-wpr    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                                      *-------------------------*
      *                                      * Visualizzazione         *
      *                                      *-------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           string    "Pertanto il numero  "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " dovra' essere recuperato manualmente."
                                delimited by   size
                                          into v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                  *-----------------------------*
      *                                  * Riga messaggio 3            *
      *                                  *-----------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "                                                  
      -              "         [ ]"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                      *-------------------------*
      *                                      * Video in On             *
      *                                      *-------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                      *-------------------------*
      *                                      * Accettazione carattere  *
      *                                      * di presa visione        *
      *                                      *-------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      17                   to   v-lin                  .
           move      70                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                      *-------------------------*
      *                                      * Ripristino immagine     *
      *                                      * video                   *
      *                                      *-------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       rip-orc-ndo-999.
           exit.

      *    *===========================================================*
      *    * Scrittura movimento su file                               *
      *    *-----------------------------------------------------------*
       scr-mov-fil-000.
      *              *-------------------------------------------------*
      *              * Se inserimento non si esaminano le righe dele-  *
      *              * tate                                            *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "I"
                     go to scr-mov-fil-200.
       scr-mov-fil-100.
      *              *-------------------------------------------------*
      *              * Lettura riga "last removed"                     *
      *              *-------------------------------------------------*
           move      "LR"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Se fine : a trattamento righe "in vita"         *
      *              *-------------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-200.
      *              *-------------------------------------------------*
      *              * Se riga precedente non esistente : riciclo      *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
           if        w-rig-num-prg (2)    =    zero
                     go to scr-mov-fil-100.
      *              *-------------------------------------------------*
      *              * Delete [ocr]                                    *
      *              *-------------------------------------------------*
           perform   del-rec-ocr-000      thru del-rec-ocr-999        .
      *              *-------------------------------------------------*
      *              * Delete [ocx]                                    *
      *              *-------------------------------------------------*
           perform   del-rec-ocx-000      thru del-rec-ocx-999        .
      *              *-------------------------------------------------*
      *              * Delete [ocf]                                    *
      *              *-------------------------------------------------*
           perform   del-rec-ocf-000      thru del-rec-ocf-999        .
      *              *-------------------------------------------------*
      *              * Riciclo a prossima "last removed"               *
      *              *-------------------------------------------------*
           go to     scr-mov-fil-100.
       scr-mov-fil-200.
      *              *-------------------------------------------------*
      *              * Determinazione del flag di variazioni in testa- *
      *              * ta che si ripercuotono anche sulle righe        *
      *              *-------------------------------------------------*
           if        w-tes-tip-arc (1)    not  = w-tes-tip-arc (2) or
                     w-tes-cod-arc (1)    not  = w-tes-cod-arc (2) or
                     w-tes-dpz-arc (1)    not  = w-tes-dpz-arc (2) or
                     w-tes-cod-lng (1)    not  = w-tes-cod-lng (2) or
                     w-tes-ocl-dat (1)    not  = w-tes-ocl-dat (2) or
                     w-tes-ocl-num (1)    not  = w-tes-ocl-num (2) or
                     w-tes-pri-eva (1)    not  = w-tes-pri-eva (2) or
                     w-tes-sgl-vpf (1)    not  = w-tes-sgl-vpf (2) or
                     w-tes-dec-vpf (1)    not  = w-tes-dec-vpf (2) or
                     w-tes-tdc-vpf (1)    not  = w-tes-tdc-vpf (2) or
                     w-tes-cdc-vpf (1)    not  = w-tes-cdc-vpf (2) or
                     w-tes-flg-nbx (1, 1) not  = w-tes-flg-nbx (2, 1)
                     move  "#"            to   w-cnt-var-tes-cor      .
      *              *-------------------------------------------------*
      *              * Start su righe corpo                            *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Se start non valida : uscita                    *
      *              *-------------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-700.
       scr-mov-fil-300.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale righe corpo                 *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
