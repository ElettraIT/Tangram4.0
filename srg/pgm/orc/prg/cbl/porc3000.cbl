           if        w-rig-flg-puq (1)    =    w-prs-arg-mag-ecu
                     go to det-cos-rif-999.
      *
           if        w-rig-flg-puq (1)    =    spaces
                     go to det-cos-rif-999
           else if   w-rig-flg-puq (1)    =    "D"
                     multiply  10         by   w-rig-cos-rif (1)
           else if   w-rig-flg-puq (1)    =    "C"
                     multiply  100        by   w-rig-cos-rif (1)
           else if   w-rig-flg-puq (1)    =    "K"
                     multiply  1000       by   w-rig-cos-rif (1)
           else      go to det-cos-rif-999.
