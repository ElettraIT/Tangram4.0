           if        w-det-vlt-dcd-dpz    =    spaces
                     go to det-vlt-dcd-999.
       det-vlt-dcd-160.
      *              *-------------------------------------------------*
      *              * Codice e descrizione voci descrittive           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se in modifica, questa tabella non viene    *
      *                  * riletta perche' altererebbe i valori gia'   *
      *                  * impostati in quanto, a differenza degli     *
      *                  * altri campi, non ha una copia relativa alla *
      *                  * dipendenza                                  *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to det-vlt-dcd-170.
      *                  *---------------------------------------------*
      *                  * Valori dell'anagrafica cliente principale   *
      *                  *---------------------------------------------*
           move      rf-dcc-vde-cod (1)   to   w-tes-voc-des (1, 1)   .
           move      rf-dcc-vde-cod (2)   to   w-tes-voc-des (1, 2)   .
           move      rf-dcc-vde-cod (3)   to   w-tes-voc-des (1, 3)   .
           move      rf-dcc-vde-cod (4)   to   w-tes-voc-des (1, 4)   .
           move      rf-dcc-vde-cod (5)   to   w-tes-voc-des (1, 5)   .
           move      rf-dcc-vde-cod (6)   to   w-tes-voc-des (1, 6)   .
           move      zero                 to   w-det-vlt-dcc-ctr      .
       det-vlt-dcd-162.
           add       1                    to   w-det-vlt-dcc-ctr      .
           if        w-det-vlt-dcc-ctr    >    w-prs-vde-fat-nvt
                     go to det-vlt-dcd-170.
           move      w-prs-vde-fat-npt
                    (w-det-vlt-dcc-ctr)   to   w-det-vlt-dcc-inx      .
           move      w-det-vlt-dcc-inx    to   w-let-arc-zvf-num      .
           move      w-tes-voc-des
                    (1, w-det-vlt-dcc-inx)
                                          to   w-let-arc-zvf-cod      .
           perform   let-arc-zvf-000      thru let-arc-zvf-999        .
           move      w-let-arc-zvf-des    to   w-tes-voc-des-des
                                              (1, w-det-vlt-dcc-inx)  .
           go to     det-vlt-dcd-162.
       det-vlt-dcd-170.
      *              *-------------------------------------------------*
      *              * Codice e descrizione ABI dipendenza             *
      *              *-------------------------------------------------*
           move      rf-dcc-cod-abi       to   w-tes-abi-dpz (1)      .
           move      w-tes-abi-dpz (1)    to   w-let-arc-axi-cod      .
           perform   let-arc-axi-000      thru let-arc-axi-999        .
           move      w-let-arc-axi-den    to   w-tes-abi-dpz-den (1)  .
      *              *-------------------------------------------------*
      *              * Codice e descrizione CAB dipendenza             *
      *              *-------------------------------------------------*
           move      rf-dcc-cod-cab       to   w-tes-cab-dpz (1)      .
           move      w-tes-abi-dpz (1)    to   w-let-arc-axs-abi      .
           move      w-tes-cab-dpz (1)    to   w-let-arc-axs-cab      .
           perform   let-arc-axs-000      thru let-arc-axs-999        .
           move      w-let-arc-axs-den    to   w-tes-cab-dpz-den (1)  .
      *              *-------------------------------------------------*
      *              * C/c appoggio della dipendenza                   *
      *              *-------------------------------------------------*
           move      rf-dcc-ccc-app       to   w-tes-cca-dpz (1)      .
       det-vlt-dcd-200.
      *              *-------------------------------------------------*
      *              * Codice e descrizione agente associato alla      *
      *              * dipendenza                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se tipo determinazione per cliente per fat- *
      *                  * turazione e tipo fornitura tramite Gruppo   *
      *                  * d'Acquisto e codice agente esistente : ri-  *
      *                  * mane quanto e' stato determinato per il     *
      *                  * Cliente Commerciale                         *
      *                  *---------------------------------------------*
           if        w-det-vlt-dcd-tdt    =    "F"    and
                     w-tes-tip-frn (1)    =    21     and
                     w-tes-age-aad (1)    not  = zero
                     go to det-vlt-dcd-400.
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           move      rf-dcc-cod-age       to   w-tes-age-aad (1)      .
       det-vlt-dcd-300.
      *              *-------------------------------------------------*
      *              * Categoria provvigionale e percentuali di prov-  *
      *              * vigione associate alla dipendenza               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           move      rf-dcc-cat-pvg       to   w-tes-cpv-aac (1)      .
           move      rf-dcc-per-pvg (1)   to   w-tes-ppv-aac (1, 1)   .
           move      rf-dcc-per-pvg (2)   to   w-tes-ppv-aac (1, 2)   .
           move      rf-dcc-per-pvg (3)   to   w-tes-ppv-aac (1, 3)   .
       det-vlt-dcd-400.
       det-vlt-dcd-999.
           exit.

      *    *===========================================================*
      *    * Determinazione valori testata indotti da inoltro pagamento*
      *    *-----------------------------------------------------------*
       det-vlt-ipg-000.
      *              *-------------------------------------------------*
      *              * Se dipendenza non esistente                     *
      *              *-------------------------------------------------*
           if        w-det-vlt-ipg-dpz    not  = spaces
                     go to det-vlt-ipg-500.
       det-vlt-ipg-100.
      *                  *---------------------------------------------*
      *                  * Codice ABI                                  *
      *                  *---------------------------------------------*
           move      w-tes-abi-cli (1)    to   w-tes-cod-abi (1)      .
           move      w-tes-abi-cli-den (1)
                                          to   w-tes-cod-abi-den (1)  .
      *                  *---------------------------------------------*
      *                  * Codice CAB                                  *
      *                  *---------------------------------------------*
           move      w-tes-cab-cli (1)    to   w-tes-cod-cab (1)      .
           move      w-tes-cab-cli-den (1)
                                          to   w-tes-cod-cab-den (1)  .
      *                  *---------------------------------------------*
      *                  * C/c appoggio                                *
      *                  *---------------------------------------------*
           move      w-tes-cca-cli (1)    to   w-tes-ccc-app (1)      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-vlt-ipg-999.
       det-vlt-ipg-500.
      *              *-------------------------------------------------*
      *              * Se dipendenza esistente                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se inoltro pagamento alla sede o alla sede  *
      *                  * legale : valori derivati da [dcc] principale*
      *                  *---------------------------------------------*
           if        w-tes-inl-pgt (1)    =    01 or
                     w-tes-inl-pgt (1)    =    02
                     go to det-vlt-ipg-100.
      *                  *---------------------------------------------*
      *                  * Codice ABI                                  *
      *                  *---------------------------------------------*
           move      w-tes-abi-dpz (1)    to   w-tes-cod-abi (1)      .
           move      w-tes-abi-dpz-den (1)
                                          to   w-tes-cod-abi-den (1)  .
      *                  *---------------------------------------------*
      *                  * Codice CAB                                  *
      *                  *---------------------------------------------*
           move      w-tes-cab-dpz (1)    to   w-tes-cod-cab (1)      .
           move      w-tes-cab-dpz-den (1)
                                          to   w-tes-cod-cab-den (1)  .
      *                  *---------------------------------------------*
      *                  * C/c appoggio                                *
      *                  *---------------------------------------------*
           move      w-tes-cca-dpz (1)    to   w-tes-ccc-app (1)      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-vlt-ipg-999.
       det-vlt-ipg-999.
           exit.

      *    *===========================================================*
      *    * Determinazione valori testata relativi all'agente         *
      *    *-----------------------------------------------------------*
       det-vlt-age-000.
      *              *-------------------------------------------------*
      *              * Se dipendenza esistente : si assumono quelli    *
      *              * della dipendenza, in ogni caso                  *
      *              *-------------------------------------------------*
           if        w-det-vlt-age-dpz    =    spaces
                     go to det-vlt-age-500.
      *                  *---------------------------------------------*
      *                  * Istruzioni inibite                          *
      *                  *---------------------------------------------*
______*    if        w-tes-age-aad (1)    =    zero
______*              go to det-vlt-age-500.
      *                  *---------------------------------------------*
      *                  * Codice agente                               *
      *                  *---------------------------------------------*
           move      w-tes-age-aad (1)    to   w-tes-cod-age (1)      .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     det-vlt-age-900.
       det-vlt-age-500.
      *              *-------------------------------------------------*
      *              * Se dipendenza non esistente si assumono i valo- *
      *              * ri relativi al [dcc] principale                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Codice agente                               *
      *                  *---------------------------------------------*
           move      w-tes-age-aac (1)    to   w-tes-cod-age (1)      .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     det-vlt-age-900.
       det-vlt-age-900.
      *              *-------------------------------------------------*
      *              * Lettura archivio [age]                          *
      *              *-------------------------------------------------*
           move      w-tes-cod-age (1)    to   w-let-arc-age-cod      .
           perform   let-arc-age-000      thru let-arc-age-999        .
      *              *-------------------------------------------------*
      *              * Bufferizzazione nominativo agente               *
      *              *-------------------------------------------------*
           move      w-let-arc-age-rag    to   w-tes-cod-age-des (1)  .
      *              *-------------------------------------------------*
      *              * Bufferizzazione categoria provvigioni agente    *
      *              *-------------------------------------------------*
           move      w-let-arc-age-cpv    to   w-tes-cpv-aaa (1)      .
      *              *-------------------------------------------------*
      *              * Bufferizzazione % provvigioni agente            *
      *              *-------------------------------------------------*
           move      w-let-arc-age-ppv (1)
                                          to   w-tes-ppv-aaa (1, 1)   .
           move      w-let-arc-age-ppv (2)
                                          to   w-tes-ppv-aaa (1, 2)   .
           move      w-let-arc-age-ppv (3)
                                          to   w-tes-ppv-aaa (1, 3)   .
       det-vlt-age-910.
      *              *-------------------------------------------------*
      *              * Determinazione flag di significativita' provvi- *
      *              * gioni in testata                                *
      *              *-------------------------------------------------*
           if        w-tes-cod-age (1)    =    zero
                     move  02             to   w-tes-fsp-doc (1)
                     go to det-vlt-age-920.
           if        w-tes-fsp-doc (1)    =    zero or
                     w-tes-fsp-doc (1)    =    02
                     move  01             to   w-tes-fsp-doc (1)      .
       det-vlt-age-920.
      *              *-------------------------------------------------*
      *              * Determinazione tipo vendita per l'agente        *
      *              *-------------------------------------------------*
           if        w-tes-cod-age (1)    =    zero
                     move  zero           to   w-tes-tip-vpa (1)
                     go to det-vlt-age-950.
           if        w-tes-fsp-doc (1)    =    02
                     move  zero           to   w-tes-tip-vpa (1)
                     go to det-vlt-age-950.
           if        w-tes-tip-vpa (1)    =    zero
                     move  01             to   w-tes-tip-vpa (1)      .
       det-vlt-age-950.
      *              *-------------------------------------------------*
      *              * Determinazione eventuale contropartita vendite  *
      *              * dipendente dall'agente                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se contropartita vendite associata all'a-   *
      *                  * gente a zero : oltre                        *
      *                  *---------------------------------------------*
           if        w-let-arc-age-ctv    =    zero
                     go to det-vlt-age-960.
      *                  *---------------------------------------------*
      *                  * Salvataggio contropartita vendite attuale   *
      *                  *---------------------------------------------*
           move      w-tes-ctp-ven (1)    to   w-sav-ctp-ven          .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione contropartita vendite asso- *
      *                  * ciata all'agente                            *
      *                  *---------------------------------------------*
           move      w-let-arc-age-ctv    to   w-tes-ctp-ven (1)      .
           move      w-tes-ctp-ven (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-tes-ctp-ven-des (1)  .
      *                  *---------------------------------------------*
      *                  * Ricalcolo contropartite vendite del docu-   *
      *                  * mento                                       *
      *                  *---------------------------------------------*
           perform   rcl-ctv-doc-000      thru rcl-ctv-doc-999        .
       det-vlt-age-960.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-vlt-age-999.
       det-vlt-age-999.
           exit.

      *    *===========================================================*
      *    * Determinazione valori testata dipendenti dalla forma di   *
      *    * pagamento                                                 *
      *    *-----------------------------------------------------------*
       det-vlt-zfp-000.
      *              *-------------------------------------------------*
      *              * Valori da estrarre con qualsiasi tipo funziona- *
      *              * mento                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione sconto pagamento associato  *
      *                  * alla forma di pagamento                     *
      *                  *---------------------------------------------*
           move      zero                 to   w-tes-scp-aap (1)      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione valori testata di appoggio  *
      *                  * alle impostazioni dei campi relativi ai pa- *
      *                  * pagamenti                                   *
      *                  *---------------------------------------------*
           move      spaces               to   w-tes-snx-nsb (1)      .
           move      spaces               to   w-tes-snx-ncp (1)      .
           move      spaces               to   w-tes-snx-abi (1)      .
           move      spaces               to   w-tes-snx-rid (1)      .
           move      spaces               to   w-tes-snx-spm (1)      .
           move      spaces               to   w-tes-snx-qaf (1)      .
           move      spaces               to   w-tes-snx-act (1)      .
      *                  *---------------------------------------------*
      *                  * Se forma di pagamento a zero : uscita       *
      *                  *---------------------------------------------*
           if        w-tes-cod-fop (1)    =    zero
                     go to det-vlt-zfp-999.
      *                  *---------------------------------------------*
      *                  * Sconto pagamento associato alla forma di    *
      *                  * pagamento                                   *
      *                  *---------------------------------------------*
           move      rf-zfp-sco-fat       to   w-tes-scp-aap (1)      .
      *                  *---------------------------------------------*
      *                  * Ciclo per tre codici pagamento possibili    *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-vlt-zfp-ctr      .
       det-vlt-zfp-100.
           add       1                    to   w-det-vlt-zfp-ctr      .
           if        w-det-vlt-zfp-ctr    >    3
                     go to det-vlt-zfp-999.
           if        rf-zfp-cod-pag
                    (w-det-vlt-zfp-ctr)   =    zero
                     go to det-vlt-zfp-100.
      *                      *-----------------------------------------*
      *                      * Campi testata derivati da record [zpg]  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione record [zpg]        *
      *                          *-------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofzpg"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zpg                 .
      *                          *-------------------------------------*
      *                          * Lettura record [zpg]                *
      *                          *-------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODPAG"             to   f-key                  .
           move      rf-zfp-cod-pag
                    (w-det-vlt-zfp-ctr)   to   rf-zpg-cod-pag         .
           move      "pgm/gep/fls/ioc/obj/iofzpg"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zpg                 .
       det-vlt-zfp-200.
      *                  *---------------------------------------------*
      *                  * Valori testata di appoggio alle successive  *
      *                  * impostazioni                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Si/no richiesta codice nostra banca per *
      *                      * bonifico                                *
      *                      *-----------------------------------------*
           if        rf-zpg-tip-pag       =    07
                     move  "S"            to   w-tes-snx-nsb (1)      .
      *                      *-----------------------------------------*
      *                      * Si/no richiesta codice nostro c/c pos-  *
      *                      * tale per pagamento                      *
      *                      *-----------------------------------------*
           if        rf-zpg-tip-pag       =    08
                     move  "S"            to   w-tes-snx-ncp (1)      .
      *                      *-----------------------------------------*
      *                      * Si/no richiesta codice ABI              *
      *                      *-----------------------------------------*
           if        rf-zpg-tip-pag       =    02 or
                     rf-zpg-tip-pag       =    03 or
                     rf-zpg-tip-pag       =    04 or
                     rf-zpg-tip-pag       =    05 or
                     rf-zpg-tip-pag       =    06 or
                     rf-zpg-tip-pag       =    09 or
                     rf-zpg-tip-pag       =    10 or
                     rf-zpg-tip-pag       =    11
                     move  "S"            to   w-tes-snx-abi (1)      .
      *                      *-----------------------------------------*
      *                      * Si/no tipo pagamento RID                *
      *                      *-----------------------------------------*
           if        rf-zpg-tip-pag       =    06
                     move  "S"            to   w-tes-snx-rid (1)      .
      *                      *-----------------------------------------*
      *                      * Si/no data scadenza pagamento manuale   *
      *                      *-----------------------------------------*
           if        rf-zpg-dec-prs       =    01
                     move  "S"            to   w-tes-snx-spm (1)      .
      *                      *-----------------------------------------*
      *                      * Si/no impostazione quota a forfait      *
      *                      *-----------------------------------------*
           if        rf-zfp-tip-amm
                    (w-det-vlt-zfp-ctr)   =    06 or
                     rf-zfp-tip-amm
                    (w-det-vlt-zfp-ctr)   =    07 or
                     rf-zfp-tip-amm
                    (w-det-vlt-zfp-ctr)   =    08 or
                     rf-zfp-tip-amm
                    (w-det-vlt-zfp-ctr)   =    09
                     move  "S"            to   w-tes-snx-qaf (1)      .
      *                      *-----------------------------------------*
      *                      * Si/no impostazione acconto              *
      *                      *-----------------------------------------*
           if        rf-zfp-dim-act
                    (w-det-vlt-zfp-ctr)   =    02
                     move  "S"            to   w-tes-snx-act (1)      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-vlt-zfp-100.
       det-vlt-zfp-999.
           exit.

      *    *===========================================================*
      *    * Determinazione flag di estensione alla descrizione        *
      *    *-----------------------------------------------------------*
       det-des-ext-000.
      *              *-------------------------------------------------*
      *              * Determinazione numero righe occupate            *
      *              *-------------------------------------------------*
           move      11                   to   w-det-des-ext-ctr      .
       det-des-ext-100.
           subtract  1                    from w-det-des-ext-ctr      .
           if        w-det-des-ext-ctr    =    zero
                     go to det-des-ext-200.
           if        w-rig-der-rig
                    (1, w-det-des-ext-ctr)
                                          =    spaces
                     go to det-des-ext-100.
       det-des-ext-200.
      *              *-------------------------------------------------*
      *              * Se numero righe non superiore a 1               *
      *              *-------------------------------------------------*
           if        w-det-des-ext-ctr    not  > 1
                     move  0              to   w-rig-des-ext (1)
                     go to det-des-ext-900.
       det-des-ext-300.
      *              *-------------------------------------------------*
      *              * Se numero righe maggiore di 1                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo riga                           *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"     or
                     w-rig-tip-rig-tpr (1)
                                          =    "C"     or
                    (w-rig-tip-rig-tpr (1)
                                          =    "P" and
                     w-rig-tip-rig-tfu (1)
                                          =    "N"   )
                     go to det-des-ext-400
           else      go to det-des-ext-500.
       det-des-ext-400.
      *                  *---------------------------------------------*
      *                  * Se riga tipo 'A', 'C' o 'PN'                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Forzatura                               *
      *                      *-----------------------------------------*
           move      1                    to   w-rig-des-ext (1)      .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     det-des-ext-900.
       det-des-ext-500.
      *                  *---------------------------------------------*
      *                  * Se riga tipo 'P', 'M' o 'S'                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se descrizione impostata uguale a  *
      *                      * descrizione originale                   *
      *                      *-----------------------------------------*
           if        w-rig-des-rig (1)    =    w-rig-des-por (1)
                     move  2              to   w-rig-des-ext (1)
           else      move  1              to   w-rig-des-ext (1)      .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     det-des-ext-900.
       det-des-ext-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-des-ext-999.
       det-des-ext-999.
           exit.

      *    *===========================================================*
      *    * Determinazione descrizione riga per record [ocr]          *
      *    *-----------------------------------------------------------*
       det-des-rig-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo riga            *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "P" and
                     w-rig-tip-rig-tfu (1)
                                          =    spaces
                     go to det-des-rig-100
           else if   w-rig-tip-rig-tpr (1)
                                          =    "P" and
                     w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to det-des-rig-200
           else if   w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to det-des-rig-200
           else if   w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to det-des-rig-200.
       det-des-rig-100.
      *              *-------------------------------------------------*
      *              * Tipo riga : 'P'                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del flag di esten-   *
      *                  * sione descrizione riga                      *
      *                  *---------------------------------------------*
           if        w-rig-des-ext (1)    =    0
                     go to det-des-rig-120
           else if   w-rig-des-ext (1)    =    1
                     go to det-des-rig-140
           else if   w-rig-des-ext (1)    =    2
                     go to det-des-rig-160.
       det-des-rig-120.
      *                  *---------------------------------------------*
      *                  * Flag di estensione descrizione riga : 0     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione originale o *
      *                      * modificata inferiore a 40 caratteri     *
      *                      *-----------------------------------------*
           move      w-rig-des-rig (1)    to   rf-ocr-des-rig         .
      *
           if        rf-ocr-des-rig       =    spaces
                     move  w-rig-des-int (1)
                                          to   rf-ocr-des-rig         .
      *                      *-----------------------------------------*
      *                      * A uscita                                *
      *                      *-----------------------------------------*
           go to     det-des-rig-900.
       det-des-rig-140.
      *                  *---------------------------------------------*
      *                  * Flag di estensione descrizione riga : 1     *
