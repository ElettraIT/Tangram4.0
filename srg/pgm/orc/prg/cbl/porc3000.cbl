      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da trattare                   *
      *                  *---------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to cnt-tdo-nok-050.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-cod-age (1)    =    zero
                     go to cnt-tdo-nok-050.
      *                  *---------------------------------------------*
      *                  * Controllo                                   *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    not  = zero
                     go to cnt-tdo-nok-050.
           move      "Si/No provvigioni per il documento indeterminato !
      -              "               "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-050.
      *              *-------------------------------------------------*
      *              * Controllo : Tipo vendita per l'agente           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da trattare                   *
      *                  *---------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to cnt-tdo-nok-080.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    =    02
                     go to cnt-tdo-nok-080.
           if        w-tes-cod-age (1)    =    zero
                     go to cnt-tdo-nok-080.
      *                  *---------------------------------------------*
      *                  * Controllo                                   *
      *                  *---------------------------------------------*
           if        w-tes-tip-vpa (1)    not  = zero
                     go to cnt-tdo-nok-080.
           move      "Manca la definizione del tipo vendita per l'agente
      -              " !             "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-080.
      *              *-------------------------------------------------*
      *              * Controllo : Provvigione a forfait per il docu-  *
      *              * mento                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da trattare                   *
      *                  *---------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to cnt-tdo-nok-090.
      *                  *---------------------------------------------*
      *                  * Test se controllo da effettuare             *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    not  = 03
                     go to cnt-tdo-nok-085.
      *                  *---------------------------------------------*
      *                  * Controllo                                   *
      *                  *---------------------------------------------*
           if        w-tes-pvf-age (1)    not  = zero
                     go to cnt-tdo-nok-090.
           move      "Manca l'importo provvigione a forfait per il docum
      -              "ento !         "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-085.
      *                  *---------------------------------------------*
      *                  * Test se controllo da effettuare             *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    not  = 04
                     go to cnt-tdo-nok-090.
      *                  *---------------------------------------------*
      *                  * Controllo                                   *
      *                  *---------------------------------------------*
           if        w-tes-pvf-age (1)    not  = zero
                     go to cnt-tdo-nok-090.
           move      "Manca la % di provvigione a forfait per il documen
      -              "to !           "    to   w-err-box-err-msg      .
           go to     cnt-tdo-nok-900.
       cnt-tdo-nok-090.
      *              *-------------------------------------------------*
      *              * Fine controlli testata                          *
      *              *-------------------------------------------------*
       cnt-tdo-nok-095.
      *              *-------------------------------------------------*
      *              * Normalizzazioni                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Archivio per fatturazione                   *
      *                  *---------------------------------------------*
           if        w-tes-tip-frn (1)    not  = 01
                     go to cnt-tdo-nok-100.
           move      w-tes-cod-arc (1)    to   w-tes-arc-plf (1)      .
           move      w-tes-dpz-arc (1)    to   w-tes-dpz-plf (1)      .
       cnt-tdo-nok-100.
      *              *-------------------------------------------------*
      *              * Controllo righe del documento                   *
      *              *-------------------------------------------------*
           perform   ctl-rig-doc-000      thru ctl-rig-doc-999        .
           if        w-ctl-rig-doc-flg    not  = spaces
                     go to cnt-tdo-nok-950.
       cnt-tdo-nok-800.
      *              *-------------------------------------------------*
      *              * Determinazione totali documento                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione totale righe                 *
      *                  *---------------------------------------------*
           perform   det-tot-rig-000      thru det-tot-rig-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione totali riepilogo documento   *
      *                  *---------------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazioni                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione Inoltro documenti           *
      *                  *---------------------------------------------*
           if        w-tes-inl-dcm (1)    =    zero
                     move  01             to   w-tes-inl-dcm (1)      .
           if        w-tes-tip-arc (1)    =    "D"
                     move  02             to   w-tes-inl-dcm (1)      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione Inoltro pagamenti           *
      *                  *---------------------------------------------*
           if        w-tes-inl-pgt (1)    =    zero
                     move  01             to   w-tes-inl-pgt (1)      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione Formato di stampa data con- *
      *                  * segna                                       *
      *                  *---------------------------------------------*
           if        w-tes-fds-dtc (1)    =    zero
                     move  01             to   w-tes-fds-dtc (1)      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione Tipo evasione ordine        *
      *                  *---------------------------------------------*
           if        w-tes-tip-eva (1)    =    zero
                     move  01             to   w-tes-tip-eva (1)      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione Flag di significativita'    *
      *                  * provvigioni per l'intero documento          *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    =    zero
                     move  01             to   w-tes-fsp-doc (1)      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     cnt-tdo-nok-999.
       cnt-tdo-nok-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore                              *
      *              *-------------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
       cnt-tdo-nok-950.
      *              *-------------------------------------------------*
      *              * Flag di uscita ad errore                        *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-tdo-nok-flg      .
       cnt-tdo-nok-999.
           exit.
           
      *    *===========================================================*
      *    * Controllo righe del documento                             *
      *    *-----------------------------------------------------------*
       ctl-rig-doc-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-ctl-rig-doc-flg      .
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Normalizzazione risposta da operatore           *
      *              *-------------------------------------------------*
           move      spaces               to    w-ctl-rig-doc-tro     .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       ctl-rig-doc-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to ctl-rig-doc-900.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to ctl-rig-doc-100.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to ctl-rig-doc-100.
       ctl-rig-doc-200.
      *              *-------------------------------------------------*
      *              * Richiamo routine di controllo impostazioni su   *
      *              * riga corpo                                      *
      *              *-------------------------------------------------*
           perform   ctl-imp-rig-000      thru ctl-imp-rig-999        .
      *              *-------------------------------------------------*
      *              * Se zero errori riscontrati : riciclo su lettura *
      *              * catena                                          *
      *              *-------------------------------------------------*
           if        w-ctl-imp-rig-ele    =    zero
                     go to ctl-rig-doc-100.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione buffer errori                *
      *              *-------------------------------------------------*
           move      zero                 to    w-ctl-imp-rig-ctr     .
       ctl-rig-doc-220.
           add       1                    to    w-ctl-imp-rig-ctr     .
      *                  *---------------------------------------------*
      *                  * Se fine scansione : riciclo su lettura ca-  *
      *                  * tena                                        *
      *                  *---------------------------------------------*
           if        w-ctl-imp-rig-ctr    >     w-ctl-imp-rig-ele
                     go to ctl-rig-doc-100.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda che si tratti o meno di un *
      *              * errore bloccante                                *
      *              *-------------------------------------------------*
           if        w-ctl-imp-rig-bte
                    (w-ctl-imp-rig-ctr)   =    "B"
                     go to ctl-rig-doc-300
           else if   w-ctl-imp-rig-bte
                    (w-ctl-imp-rig-ctr)   =    "N"
                     go to ctl-rig-doc-400.
       ctl-rig-doc-300.
      *              *-------------------------------------------------*
      *              * Se errore bloccante                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Composizione messaggio completo             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing numero riga                     *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-cat-rig-cur        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Composizione stringa                    *
      *                      *-----------------------------------------*
           move      spaces               to   w-err-box-err-msg      .
           string    "Errore a riga "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " : "      delimited by   size
                     w-ctl-imp-rig-bmg
                    (w-ctl-imp-rig-ctr)
                                delimited by   size
                                          into w-err-box-err-msg      .
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di uscita ad errore                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-ctl-rig-doc-flg      .
      *                  *---------------------------------------------*
      *                  * A uscita                                    *
      *                  *---------------------------------------------*
           go to     ctl-rig-doc-900.
       ctl-rig-doc-400.
      *              *-------------------------------------------------*
      *              * Se errore non bloccante                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se flag di risposta operatore a X : riciclo *
      *                  * su scansione buffer errori                  *
      *                  *---------------------------------------------*
           if        w-ctl-rig-doc-tro    =    "X"
                     go to ctl-rig-doc-220.
       ctl-rig-doc-420.
      *                  *---------------------------------------------*
      *                  * Box di avviso con conferma impostazioni     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Salvataggio immagine video              *
      *                      *-----------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Video in Off                            *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Box                                     *
      *                      *-----------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      11                   to   v-lin                  .
           move      04                   to   v-pos                  .
           move      15                   to   v-lto                  .
           move      77                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Messaggio nel box                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Linea 01                            *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Editing numero riga             *
      *                              *---------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-cat-rig-cur        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Composizione stringa            *
      *                              *---------------------------------*
           move      spaces               to   v-alf                  .
           string    "Avviso per riga "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " : "      delimited by   size
                     w-ctl-imp-rig-bmg
                    (w-ctl-imp-rig-ctr)
                                delimited by   size
                                          into v-alf                  .
      *                              *---------------------------------*
      *                              * Visualizzazione stringa         *
      *                              *---------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      70                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      06                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Linea 02                            *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      70                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      "Si confermano ugualmente le impostazioni (S/N) ? [
      -              " ]"                 to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Video in On                             *
      *                      *-----------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Accettazione della risposta             *
      *                      *-----------------------------------------*
           move      "S"                  to   v-alf                  .
       ctl-rig-doc-422.
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      56                   to   v-pos                  .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Set del tipo risposta da operatore      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test su function-key impostata      *
      *                          *-------------------------------------*
           if        v-key                =    "EXIT"
                     move  "N"            to   w-ctl-rig-doc-tro
                     go to ctl-rig-doc-426
           else if   v-key                =    "DO  "
                     move  "X"            to   w-ctl-rig-doc-tro
                     go to ctl-rig-doc-426
           else if   v-key                =    spaces
                     go to ctl-rig-doc-424
           else      go to ctl-rig-doc-422.
       ctl-rig-doc-424.
      *                          *-------------------------------------*
      *                          * Test su valore impostato se Return  *
      *                          *-------------------------------------*
           if        v-alf                =    "N"
                     move  "N"            to   w-ctl-rig-doc-tro
                     go to ctl-rig-doc-426
           else if   v-alf                =    "S"
                     move  "S"            to   w-ctl-rig-doc-tro
                     go to ctl-rig-doc-426
           else      go to ctl-rig-doc-422.
       ctl-rig-doc-426.
      *                      *-----------------------------------------*
      *                      * Ripristino immagine video               *
      *                      *-----------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       ctl-rig-doc-440.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo di risposta *
      *                  * da operatore                                *
      *                  *---------------------------------------------*
           if        w-ctl-rig-doc-tro    =    "N"
                     go to ctl-rig-doc-442
           else if   w-ctl-rig-doc-tro    =    "S"
                     go to ctl-rig-doc-444
           else if   w-ctl-rig-doc-tro    =    "X"
                     go to ctl-rig-doc-446.
       ctl-rig-doc-442.
      *                  *---------------------------------------------*
      *                  * Tipo di risposta : No                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di uscita ad errore                *
      *                      *-----------------------------------------*
           move      "#"                  to   w-ctl-rig-doc-flg      .
      *                      *-----------------------------------------*
      *                      * A uscita                                *
      *                      *-----------------------------------------*
           go to     ctl-rig-doc-900.
       ctl-rig-doc-444.
      *                  *---------------------------------------------*
      *                  * Tipo di risposta : Si                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Riciclo su scansione buffer errori      *
      *                      *-----------------------------------------*
           go to     ctl-rig-doc-220.
       ctl-rig-doc-446.
      *                  *---------------------------------------------*
      *                  * Tipo di risposta : Si, e con omissione di   *
      *                  * altri messaggi                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Riciclo su scansione buffer errori      *
      *                      *-----------------------------------------*
           go to     ctl-rig-doc-220.
       ctl-rig-doc-900.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       ctl-rig-doc-999.
           exit.

      *    *===========================================================*
      *    * Controllo su impostazione tasto Do riga corpo             *
      *    *-----------------------------------------------------------*
       cnt-tdo-rig-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-rig-flg      .
       cnt-tdo-rig-030.
      *              *-------------------------------------------------*
      *              * Test su tipo archivio                           *
      *              *-------------------------------------------------*
           if        w-tes-tip-arc (1)    =    "D"
                     go to cnt-tdo-rig-300.
       cnt-tdo-rig-050.
      *              *-------------------------------------------------*
      *              * Richiamo routine di eventuale controllo margine *
      *              * su prezzo netto                                 *
      *              *-------------------------------------------------*
           perform   ctl-prz-mrg-000      thru ctl-prz-mrg-999        .
       cnt-tdo-rig-100.
      *              *-------------------------------------------------*
      *              * Richiamo routine di controllo impostazioni su   *
      *              * riga corpo                                      *
      *              *-------------------------------------------------*
           perform   ctl-imp-rig-000      thru ctl-imp-rig-999        .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del numero di errori ri-   *
      *              * scontrati                                       *
      *              *-------------------------------------------------*
           if        w-ctl-imp-rig-ele    =    zero
                     go to cnt-tdo-rig-120
           else      go to cnt-tdo-rig-140.
       cnt-tdo-rig-120.
      *              *-------------------------------------------------*
      *              * Se zero errori riscontrati                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * A normalizzazioni                           *
      *                  *---------------------------------------------*
           go to     cnt-tdo-rig-200.
       cnt-tdo-rig-140.
      *              *-------------------------------------------------*
      *              * Se riscontrati errori                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione buffer                   *
      *                  *---------------------------------------------*
           move      zero                 to    w-ctl-imp-rig-ctr     .
       cnt-tdo-rig-142.
           add       1                    to    w-ctl-imp-rig-ctr     .
      *                      *-----------------------------------------*
      *                      * Se fine scansione e non sono stati tro- *
      *                      * vati errori Bloccanti : a normalizza-   *
      *                      * zioni                                   *
      *                      *-----------------------------------------*
           if        w-ctl-imp-rig-ctr    >     w-ctl-imp-rig-ele
                     go to cnt-tdo-rig-200.
      *                      *-----------------------------------------*
      *                      * Emissione messaggio                     *
      *                      *-----------------------------------------*
           move      w-ctl-imp-rig-bmg
                    (w-ctl-imp-rig-ctr)   to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda del tipo errore    *
      *                      *-----------------------------------------*
           if        w-ctl-imp-rig-bte
                    (w-ctl-imp-rig-ctr)   =    "B"
                     go to cnt-tdo-rig-144
           else if   w-ctl-imp-rig-bte
                    (w-ctl-imp-rig-ctr)   =    "N"
                     go to cnt-tdo-rig-146.
       cnt-tdo-rig-144.
      *                      *-----------------------------------------*
      *                      * Se tipo errore : Bloccante              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * A uscita con errore                 *
      *                          *-------------------------------------*
           go to     cnt-tdo-rig-900.
       cnt-tdo-rig-146.
      *                      *-----------------------------------------*
      *                      * Se tipo errore : Non bloccante          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Riciclo su scansione buffer         *
      *                          *-------------------------------------*
           go to     cnt-tdo-rig-142.
       cnt-tdo-rig-200.
      *              *-------------------------------------------------*
      *              * Normalizzazioni                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione flag di estensione alla de-  *
      *                  * scrizione prodotto                          *
      *                  *---------------------------------------------*
           if        w-rig-des-rig (1)    =    w-rig-des-rig (2)
                     go to cnt-tdo-rig-210.
           perform   det-des-ext-000      thru det-des-ext-999        .
       cnt-tdo-rig-210.
      *                  *---------------------------------------------*
      *                  * Attivazione flag di accettazione valuta per *
      *                  * fatturazione                                *
      *                  *---------------------------------------------*
           move      "#"                  to   w-tes-fda-vpf (1)      .
      *                  *---------------------------------------------*
      *                  * Forzatura prezzo per legame valutario       *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpl (1)    not  = spaces
                     move  w-rig-prz-ven (1)
                                          to   w-rig-prz-vpl (1)      .
      *                  *---------------------------------------------*
      *                  * Eventuale normalizzazione data consegna     *
      *                  * confermata                                  *
      *                  *---------------------------------------------*
           if        w-rig-dcn-cnf (1)    =    zero
                     move  w-rig-dcn-prv (1)
                                          to   w-rig-dcn-cnf (1)      .
      *                  *---------------------------------------------*
      *                  * Aggiornamento comodi di visualizzazione     *
      *                  *---------------------------------------------*
           move      "AG"                 to   w-edt-qta-inc-ope      .
           move      w-rig-qta-ord (1)    to   w-edt-qta-inc-qta      .
           move      w-rig-dec-qta (1)    to   w-edt-qta-inc-dec      .
           perform   edt-qta-inc-000      thru edt-qta-inc-999        .
           move      w-edt-qta-inc-din    to   w-tes-dec-qta          .
      *                  *---------------------------------------------*
      *                  * Eventuale attivazione segnale di riga       *
      *                  * successiva da pre-cablare                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione preliminare flag        *
      *                      *-----------------------------------------*
           move      spaces               to   w-cnt-pcr-rec-flg      .
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione               *
      *                      *-----------------------------------------*
           if        w-prs-snx-rae        not  = "S"
                     go to cnt-tdo-rig-300.
      *                      *-----------------------------------------*
      *                      * Test se riga nuova                      *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        =    spaces
                     go to cnt-tdo-rig-300.
      *                      *-----------------------------------------*
      *                      * Test se addebito presente               *
      *                      *-----------------------------------------*
           if        w-rig-add-pro (1)    =    zero
                     go to cnt-tdo-rig-300.
      *                      *-----------------------------------------*
      *                      * Attivazione del flag                    *
      *                      *-----------------------------------------*
           move      "#"                  to   w-cnt-pcr-rec-flg      .
      *                      *-----------------------------------------*
      *                      * Salvataggio valori per il pre-cablaggio *
      *                      *-----------------------------------------*
           move      w-rig-add-pro (1)    to   w-sav-rig-prc-add      .
           move      w-rig-qta-ord (1)    to   w-sav-rig-prc-qta      .
           move      w-rig-num-pro (1)    to   w-sav-rig-prc-pro      .
           move      w-rig-flg-frc (1)    to   w-sav-rig-prc-flf      .
           move      w-rig-prt-frc (1)    to   w-sav-rig-prc-ptf      .
           move      w-rig-prg-frc (1)    to   w-sav-rig-prc-prf      .
       cnt-tdo-rig-300.
      *                  *---------------------------------------------*
      *                  * Eventuale messaggio di prodotto con addebi- *
      *                  * to al seguito                               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione               *
      *                      *-----------------------------------------*
           if        w-prs-snx-rae        not  = "S"
                     go to cnt-tdo-rig-800.
      *                      *-----------------------------------------*
      *                      * Test se riga di addebito                *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to cnt-tdo-rig-800.
      *                      *-----------------------------------------*
      *                      * Test se riga nuova                      *
      *                      *-----------------------------------------*
           if        w-cat-rig-new        not  = spaces
                     go to cnt-tdo-rig-800.
      *                      *-----------------------------------------*
      *                      * Test se addebito presente               *
      *                      *-----------------------------------------*
           if        w-rig-add-pro (1)    =    zero
                     go to cnt-tdo-rig-800.
      *                      *-----------------------------------------*
      *                      * Test se quantita' modificata            *
      *                      *-----------------------------------------*
           if        w-rig-qta-ord (1)    =    w-sav-qta-ord
                     go to cnt-tdo-rig-800.
      *                      *-----------------------------------------*
      *                      * Messaggio di avviso                     *
      *                      *-----------------------------------------*
           move      "Verificare la quantita' della riga successiva !"
                                          to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
       cnt-tdo-rig-800.
      *              *-------------------------------------------------*
      *              * Uscita con esito positivo                       *
      *              *-------------------------------------------------*
           go to     cnt-tdo-rig-999.
       cnt-tdo-rig-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita ad errore                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-rig-flg      .
       cnt-tdo-rig-999.
           exit.

      *    *===========================================================*
      *    * Subroutine di eventuale controllo su margine di vendita   *
      *    *-----------------------------------------------------------*
       ctl-prz-mrg-000.
      *              *-------------------------------------------------*
      *              * Test se controllo da effettuare                 *
      *              *-------------------------------------------------*
           if        w-prs-cpv-tcn        not  = 11
                     go to ctl-prz-mrg-900.
           if        w-prs-cpv-pmg        =    zero
                     go to ctl-prz-mrg-900.
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P"
                     go to ctl-prz-mrg-900.
       ctl-prz-mrg-100.
      *              *-------------------------------------------------*
      *              * Determinazione del margine                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Costo di riferimento in work di lavoro      *
      *                  *---------------------------------------------*
           move      w-rig-cos-rif (1)    to   w-vis-not-rgd-pvp      .
      *                  *---------------------------------------------*
      *                  * Conversione costo di riferimento nella      *
      *                  * valuta per il prezzo                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se necessario                      *
      *                      *-----------------------------------------*
           if        w-rig-sgl-vpc (1)    =    w-rig-sgl-vpp (1)
                     go to ctl-prz-mrg-200.
      *                      *-----------------------------------------*
      *                      * Conversione valore da valuta per i      *
      *                      * prezzi standard a valuta base           *
      *                      *-----------------------------------------*
           move      w-rig-sgl-vpc (1)    to   w-cvs-vlt-sgl          .
           move      w-rig-dec-vpc (1)    to   w-cvs-vlt-dec          .
           move      w-rig-tdc-vpc (1)    to   w-cvs-vlt-tdc          .
           move      w-rig-cdc-vpc (1)    to   w-cvs-vlt-cdc          .
           move      w-vis-not-rgd-pvp    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
      *                      *-----------------------------------------*
      *                      * Conversione valore da valuta base a     *
      *                      * valuta base per il prezzo               *
      *                      *-----------------------------------------*
           move      w-rig-sgl-vpp (1)    to   w-cvs-vlt-sgl          .
           move      w-rig-dec-vpp (1)    to   w-cvs-vlt-dec          .
           move      w-rig-tdc-vpp (1)    to   w-cvs-vlt-tdc          .
           move      w-rig-cdc-vpp (1)    to   w-cvs-vlt-cdc          .
           perform   cvs-vlb-alt-000      thru cvs-vlb-alt-999        .
           move      w-cvs-vlt-aav        to   w-vis-not-rgd-pvp      .
       ctl-prz-mrg-200.
      *                  *---------------------------------------------*
      *                  * Test se determinabile                       *
      *                  *---------------------------------------------*
           if        w-vis-not-rgd-pvp    =    zero or
                     w-rig-prz-net (1)    =    zero
                     go to ctl-prz-mrg-300
           else      go to ctl-prz-mrg-400.
       ctl-prz-mrg-300.
      *                      *-----------------------------------------*
      *                      * Se non determinabile                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Azzeramento                         *
      *                          *-------------------------------------*
           move      zero                 to   w-vis-not-rgd-psc      .
      *                          *-------------------------------------*
      *                          * Ad errore                           *
      *                          *-------------------------------------*
           go to     ctl-prz-mrg-500.
       ctl-prz-mrg-400.
      *                      *-----------------------------------------*
      *                      * Se determinabile                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Costo di riferimento per determina- *
      *                          * zione scostamento                   *
      *                          *-------------------------------------*
           move      w-vis-not-rgd-pvp    to   w-vis-not-rgd-ws1      .
           if        w-rig-dec-cos (1)    =    1
                     divide 10            into w-vis-not-rgd-ws1
           else if   w-rig-dec-cos (1)    =    2
                     divide 100           into w-vis-not-rgd-ws1      .
      *                          *-------------------------------------*
      *                          * Prezzo netto per determinazione     *
      *                          * scostamento                         *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Eventuale determinazione prezzo *
      *                              * con legame valutario            *
      *                              *---------------------------------*
           move      w-rig-prz-net (1)    to   w-lvl-prz-prz          .
           move      w-rig-sgl-vpl (1)    to   w-lvl-prz-vlt          .
           move      w-rig-tdc-vpl (1)    to   w-lvl-prz-tdc          .
           move      w-rig-ccr-vpl (1)    to   w-lvl-prz-ccr          .
           move      w-rig-cdc-vpl (1)    to   w-lvl-prz-cdc          .
           move      w-rig-plm-vpl (1)    to   w-lvl-prz-plm          .
           move      w-rig-tlm-vpl (1)    to   w-lvl-prz-tlm          .
           perform   lvl-prz-det-000      thru lvl-prz-det-999        .
      *                              *---------------------------------*
      *                              * Spostamento in area di comodo   *
      *                              *---------------------------------*
           move      w-lvl-prz-prz        to   w-vis-not-rgd-ws2      .
      *                              *---------------------------------*
      *                              * Eventuale trattamento decimali  *
      *                              * prezzo per la vendita           *
      *                              *---------------------------------*
           if        w-rig-dec-prz (1)    =    1
                     divide 10            into w-vis-not-rgd-ws2
           else if   w-rig-dec-prz (1)    =    2
                     divide 100           into w-vis-not-rgd-ws2      .
      *                              *---------------------------------*
      *                              * Determinazione                  *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Determinazione valore scos- *
      *                                  * tamento                     *
      *                                  *-----------------------------*
           subtract  w-vis-not-rgd-ws1    from w-vis-not-rgd-ws2
                                        giving w-vis-not-rgd-vsc      .
      *                                  *-----------------------------*
      *                                  * Determinazione percentuale  *
      *                                  * scostamento                 *
      *                                  *-----------------------------*
           multiply  100                  by   w-vis-not-rgd-vsc      .
           divide    w-vis-not-rgd-ws2    into w-vis-not-rgd-vsc
                                        giving w-vis-not-rgd-psc
                                               rounded                .
       ctl-prz-mrg-500.
      *              *-------------------------------------------------*
      *              * Controllo vero e proprio                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Confronto con % espressa in personalizza-   *
      *                  * zioni                                       *
      *                  *---------------------------------------------*
           if        w-vis-not-rgd-psc    not  < w-prs-cpv-pmg
                     go to ctl-prz-mrg-900.
       ctl-prz-mrg-600.
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      12                   to   v-lin                  .
           move      04                   to   v-pos                  .
           move      14                   to   v-lto                  .
           move      77                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Preparazione messaggio nel box              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing percentuale di scostamento mas- *
      *                      * sima                                    *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-prs-cpv-pmg        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Composizione                            *
      *                      *-----------------------------------------*
           move      65                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      "Margine inferiore al "
                                          to   w-all-str-cat (1)      .
           move      v-edt                to   w-all-str-cat (2)      .
           move      "% ! ('S' per conferma)"
                                          to   w-all-str-cat (3)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *                  *---------------------------------------------*
      *                  * Messaggio nel box                           *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      65                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      w-all-str-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       ctl-prz-mrg-800.
      *                  *---------------------------------------------*
      *                  * Normalizzazione function key                *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Accettazione per presa visione              *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      74                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Test su carattere accettato             *
      *                      *-----------------------------------------*
           if        v-alf                not  = "S" and
                     v-alf                not  = "s"
                     go to ctl-prz-mrg-800.
      *                  *---------------------------------------------*
      *                  * Ripristino immagine video                   *
      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       ctl-prz-mrg-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     ctl-prz-mrg-999.
       ctl-prz-mrg-999.
           exit.

      *    *===========================================================*
      *    * Controllo impostazioni su riga corpo                      *
      *    *-----------------------------------------------------------*
       ctl-imp-rig-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione numero elementi nel buffer er- *
      *              * rori                                            *
      *              *-------------------------------------------------*
           move      zero                 to   w-ctl-imp-rig-ele      .
       ctl-imp-rig-010.
      *              *-------------------------------------------------*
      *              * Test su codice prodotto                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to ctl-imp-rig-020.
      *                  *---------------------------------------------*
      *                  * Se valore non a zero : oltre                *
      *                  *---------------------------------------------*
           if        w-rig-num-pro (1)    not  = zero
                     go to ctl-imp-rig-020.
      *                  *---------------------------------------------*
      *                  * Preparazione messaggio                      *
      *                  *---------------------------------------------*
           move      "Manca il codice prodotto                       "
                                          to   w-ctl-imp-rig-msg      .
      *                  *---------------------------------------------*
      *                  * Tipo errore : Bloccante                     *
      *                  *---------------------------------------------*
           move      "B"                  to   w-ctl-imp-rig-ter      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione errore                      *
      *                  *---------------------------------------------*
           perform   ctl-imp-rig-900      thru ctl-imp-rig-909        .
       ctl-imp-rig-020.
      *              *-------------------------------------------------*
      *              * Test su descrizione in riga                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a spazi ammesso solo per tipi riga   *
      *                  * 'C'                                         *
      *                  *---------------------------------------------*
           if        w-rig-des-rig (1)    not  = spaces
                     go to ctl-imp-rig-030.
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to ctl-imp-rig-030.
      *                  *---------------------------------------------*
      *                  * Preparazione messaggio                      *
      *                  *---------------------------------------------*
           move      "Manca la descrizione                           "
                                          to   w-ctl-imp-rig-msg      .
      *                  *---------------------------------------------*
      *                  * Tipo errore : Bloccante                     *
      *                  *---------------------------------------------*
           move      "B"                  to   w-ctl-imp-rig-ter      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione errore                      *
      *                  *---------------------------------------------*
           perform   ctl-imp-rig-900      thru ctl-imp-rig-909        .
       ctl-imp-rig-030.
      *              *-------------------------------------------------*
      *              * Test su tipo archivio                           *
      *              *-------------------------------------------------*
           if        w-tes-tip-arc (1)    =    "D"
                     go to ctl-imp-rig-220.
       ctl-imp-rig-040.
      *              *-------------------------------------------------*
      *              * Test su quantita' ordinata                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to ctl-imp-rig-060.
      *                  *---------------------------------------------*
      *                  * Test se valore a zero                       *
      *                  *---------------------------------------------*
           if        w-rig-qta-ord (1)    not  = zero
                     go to ctl-imp-rig-060.
      *                  *---------------------------------------------*
      *                  * Preparazione messaggio                      *
      *                  *---------------------------------------------*
           move      "Manca la quantita'                             "
                                          to   w-ctl-imp-rig-msg      .
      *                  *---------------------------------------------*
      *                  * Tipo errore : Non bloccante                 *
      *                  *---------------------------------------------*
           move      "N"                  to   w-ctl-imp-rig-ter      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione errore                      *
      *                  *---------------------------------------------*
           perform   ctl-imp-rig-900      thru ctl-imp-rig-909        .
       ctl-imp-rig-060.
      *              *-------------------------------------------------*
      *              * Test su sigla valuta per il prezzo              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to ctl-imp-rig-070.
      *                  *---------------------------------------------*
      *                  * Test se valore a spaces                     *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpp (1)    not  = spaces
                     go to ctl-imp-rig-070.
      *                  *---------------------------------------------*
      *                  * Preparazione messaggio                      *
      *                  *---------------------------------------------*
           move      "Manca la sigla valuta per il prezzo            "
                                          to   w-ctl-imp-rig-msg      .
      *                  *---------------------------------------------*
      *                  * Tipo errore : Bloccante                     *
      *                  *---------------------------------------------*
           move      "B"                  to   w-ctl-imp-rig-ter      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione errore                      *
      *                  *---------------------------------------------*
           perform   ctl-imp-rig-900      thru ctl-imp-rig-909        .
       ctl-imp-rig-070.
      *              *-------------------------------------------------*
      *              * Test su prezzo di vendita                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C" or
                     w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to ctl-imp-rig-080.
      *                  *---------------------------------------------*
      *                  * Test se valore a zero                       *
      *                  *---------------------------------------------*
           if        w-rig-prz-ven (1)    not  = zero
                     go to ctl-imp-rig-080.
      *                  *---------------------------------------------*
      *                  * Preparazione messaggio                      *
      *                  *---------------------------------------------*
           move      "Manca il prezzo di vendita                     "
                                          to   w-ctl-imp-rig-msg      .
      *                  *---------------------------------------------*
      *                  * Se prodotto similare : Tipo errore non      *
      *                  * bloccante                                   *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     move  "N"            to   w-ctl-imp-rig-ter
                     go to ctl-imp-rig-074.
      *                  *---------------------------------------------*
      *                  * Tipo errore bloccante o no a seconda della  *
      *                  * personalizzazione                           *
      *                  *---------------------------------------------*
           if        w-prs-cnt-prz-ven    =    "S"
                     move  "B"            to   w-ctl-imp-rig-ter
           else if   w-prs-cnt-prz-ven    =    "N"
                     move  "N"            to   w-ctl-imp-rig-ter
           else if   w-prs-cnt-prz-ven    =    "M"
                     move  "N"            to   w-ctl-imp-rig-ter      .
       ctl-imp-rig-074.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione errore                      *
      *                  *---------------------------------------------*
           perform   ctl-imp-rig-900      thru ctl-imp-rig-909        .
       ctl-imp-rig-080.
