           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      w-buf-doc-mvm-c05    to   v-lin                  .
           move      11                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           add       1                    to   w-buf-doc-mvm-c02      .
           add       1                    to   w-buf-doc-mvm-c05      .
           go to     buf-doc-mvm-952.
       buf-doc-mvm-955.
      *                  *---------------------------------------------*
