      *                      *-----------------------------------------*
           move      rn-orc-ndo-num-doc   to   w-att-orc-ndo-new      .
      *                      *-----------------------------------------*
      *                      * Valore in uscita                        *
      *                      *-----------------------------------------*
           move      rn-orc-ndo-num-doc   to   w-att-orc-ndo-num      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     att-orc-ndo-999.
       att-orc-ndo-300.
      *                  *---------------------------------------------*
      *                  * Se numero documento passato non a zero      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se numero documento passato minore o u- *
      *                      * guale a quello letto : uscita           *
      *                      *-----------------------------------------*
           if        w-att-orc-ndo-num    >    w-att-orc-ndo-nsv
                     go to att-orc-ndo-320.
      *                          *-------------------------------------*
      *                          * Unlock                              *
      *                          *-------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/orc/num/ioc/obj/inorcndo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-orc-ndo             .
      *                          *-------------------------------------*
      *                          * Azzeramento nuovo numero documento  *
      *                          *-------------------------------------*
           move      zero                 to   w-att-orc-ndo-new      .
           go to     att-orc-ndo-999.
       att-orc-ndo-320.
      *                      *-----------------------------------------*
      *                      * Se numero documento passato maggiore di *
      *                      * quello letto                            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se e' maggiore di un'unita' : come  *
      *                          * se fosse stato passato a zero       *
      *                          *-------------------------------------*
           move      w-att-orc-ndo-nsv    to   w-att-orc-ndo-wnu      .
           add       1                    to   w-att-orc-ndo-wpr      .
           if        w-att-orc-ndo-wpr    =    zero
                     move  1              to   w-att-orc-ndo-wpr      .
           if        w-att-orc-ndo-prg    =    w-att-orc-ndo-wpr
                     go to att-orc-ndo-200.
       att-orc-ndo-400.
