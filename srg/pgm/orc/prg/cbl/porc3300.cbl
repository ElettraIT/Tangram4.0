      *    *===========================================================*
      *    * Accettazione campo : Si/no esportazione                   *
      *    *-----------------------------------------------------------*
       acc-snx-exp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-snx-exp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-snx-exp-lun    to   v-car                  .
           move      w-exp-snx-exp-num    to   v-ldt                  .
           move      "NS#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      w-exp-snx-exp-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      21                   to   v-lin                  .
           move      30                   to   v-pos                  .
      *
           if        rr-snx-exp           =    "N"
                     move  01             to   v-num
           else if   rr-snx-exp           =    "S"
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
      *
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-acc-ric-sel
                     go to acc-snx-exp-999.
       acc-snx-exp-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    01
                     move  "N"            to   rr-snx-exp
           else if   v-num                =    02
                     move  "S"            to   rr-snx-exp
           else      move  zero           to   rr-snx-exp             .
       acc-snx-exp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a spaces non ammesso, a meno che non *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        rr-snx-exp           not  = spaces
                     go to acc-snx-exp-600.
           if        v-key                =    "UP  "
                     go to acc-snx-exp-600.
           go to     acc-snx-exp-100.
       acc-snx-exp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-snx-exp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform tdo-ric-sel-000
                                          thru tdo-ric-sel-999
                     if      w-cnt-tdo-ric-flg
                                          =    spaces
                             move  "S"    to   w-cnt-acc-ric-sel
                             go to acc-snx-exp-999
                     else    move  spaces to   w-cnt-tdo-ric-flg
                             go to acc-snx-exp-100.
       acc-snx-exp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione : Si/no esportazione                      *
      *    *-----------------------------------------------------------*
       vis-snx-exp-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-snx-exp-lun    to   v-car                  .
           move      w-exp-snx-exp-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-snx-exp-tbl    to   v-txt                  .
           move      21                   to   v-lin                  .
           move      30                   to   v-pos                  .
      *
           if        rr-snx-exp           =    "N"
                     move  01             to   v-num
           else if   rr-snx-exp           =    "S"
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       vis-snx-exp-999.
           exit.

      *    *===========================================================*
      *    * Controllo su tasto Do in parametri di selezione           *
      *    *-----------------------------------------------------------*
       tdo-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Controllo su data emissione minima e massima    *
      *              *-------------------------------------------------*
           if        rr-dem-min           =    zero or
                     rr-dem-max           =    zero
                     go to tdo-ric-sel-300.
           if        rr-dem-max           not  < rr-dem-min
                     go to tdo-ric-sel-300.
           move      "Data emissione massima inferiore a quella minima !
      -              "               "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-300.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione messaggio                   *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Uscita con errore                           *
      *                  *---------------------------------------------*
           move      "#"                  to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Regolarizzazione dei parametri di selezione               *
      *    *-----------------------------------------------------------*
       reg-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Data emissione massima                          *
      *              *-------------------------------------------------*
           if        rr-dem-max           not  = zero
                     go to reg-ric-sel-100.
           if        rr-dem-min           =    zero
                     move 9999999         to   rr-dem-max
           else      move rr-dem-min      to   rr-dem-max             .
       reg-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Normalizzazione data consegna richiesta massima *
      *              *-------------------------------------------------*
           if        rr-dcn-prv           =    zero
                     move  9999999        to   rr-dcn-prv             .
      *              *-------------------------------------------------*
      *              * Normalizzazione status ordini clienti           *
      *              *-------------------------------------------------*
           if        rr-sts-orc           =    zero
                     move  01             to   rr-sts-orc             .
      *              *-------------------------------------------------*
      *              * Normalizzazione si/no esportazione              *
      *              *-------------------------------------------------*
           if        rr-snx-exp           not  = "S"
                     move  "N"            to   rr-snx-exp             .
       reg-ric-sel-999.
           exit.

      *    *===========================================================*
      *    * Normalizzazione richieste di selezione                    *
      *    *-----------------------------------------------------------*
       nor-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Codice cliente                              *
      *                  *---------------------------------------------*
           move      zero                 to   rr-cod-cli             .
      *                  *---------------------------------------------*
      *                  * Codice cliente, ragione sociale             *
      *                  *---------------------------------------------*
           move      spaces               to   rr-cod-cli-rag         .
      *                  *---------------------------------------------*
      *                  * Codice cliente, indirizzo                   *
      *                  *---------------------------------------------*
           move      spaces               to   rr-cod-cli-via         .
      *                  *---------------------------------------------*
      *                  * Codice cliente, localita'                   *
      *                  *---------------------------------------------*
           move      spaces               to   rr-cod-cli-loc         .
      *                  *---------------------------------------------*
      *                  * Codice dipendenza del cliente               *
      *                  *---------------------------------------------*
           move      spaces               to   rr-dpz-cli             .
      *                  *---------------------------------------------*
      *                  * Codice dipendenza del cliente, ragione so-  *
      *                  * ciale                                       *
      *                  *---------------------------------------------*
           move      spaces               to   rr-dpz-cli-rag         .
      *                  *---------------------------------------------*
      *                  * Codice dipendenza del cliente, indirizzo    *
      *                  *---------------------------------------------*
           move      spaces               to   rr-dpz-cli-via         .
      *                  *---------------------------------------------*
      *                  * Codice dipendenza del cliente, localita'    *
      *                  *---------------------------------------------*
           move      spaces               to   rr-dpz-cli-loc         .
      *                  *---------------------------------------------*
      *                  * Data emissione minima da ricercare          *
      *                  *---------------------------------------------*
           move      zero                 to   rr-dem-min             .
      *                  *---------------------------------------------*
      *                  * Data emissione massima da ricercare         *
      *                  *---------------------------------------------*
           move      zero                 to   rr-dem-max             .
      *                  *---------------------------------------------*
      *                  * Data consegna prevista massima da ricercare *
      *                  *---------------------------------------------*
           move      zero                 to   rr-dcn-prv             .
      *                  *---------------------------------------------*
      *                  * Status ordini clienti                       *
      *                  *---------------------------------------------*
           move      zero                 to   rr-sts-orc             .
      *                  *---------------------------------------------*
      *                  * Tipi documento                              *
      *                  *---------------------------------------------*
           move      spaces               to   rr-tip-mov             .
           move      spaces               to   rr-tip-mov-des         .
           move      zero                 to   rr-tip-mov-vld         .
           move      zero                 to   rr-tip-mov-dpz         .
           move      spaces               to   rr-tip-mov-tar         .
      *                  *---------------------------------------------*
      *                  * Filtro di selezione                         *
      *                  *---------------------------------------------*
           move      zero                 to   rr-fso-dcp             .
           move      spaces               to   rr-fso-dcp-des         .
           move      zero                 to   rr-fso-dcp-ord         .
      *                  *---------------------------------------------*
      *                  * Si/no esportazione                          *
      *                  *---------------------------------------------*
           move      spaces               to   rr-snx-exp             .
       nor-ric-sel-999.
           exit.

