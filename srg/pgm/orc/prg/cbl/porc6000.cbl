      *                      *-----------------------------------------*
           move      "SL"                 to   d-sld-mag-tip-ope      .
           move      0000                 to   d-sld-mag-tip-sld      .
           move      w-det-buf-dsp-dtb    to   d-sld-mag-dat-sld      .
           move      "U"                  to   d-sld-mag-uot-dpz      .
           move      w-det-buf-dsp-dpz    to   d-sld-mag-cod-dpz      .
           move      w-det-buf-dsp-tpm    to   d-sld-mag-tip-mag      .
           move      w-det-buf-dsp-cnm    to   d-sld-mag-num-mag      .
           move      "T"                  to   d-sld-mag-uot-var      .
           move      spaces               to   d-sld-mag-var-mag      .
           move      "T"                  to   d-sld-mag-uot-dsl      .
           move      spaces               to   d-sld-mag-cod-dsl      .
      *                      *-----------------------------------------*
      *                      * Richiamo del sottoprogramma             *
      *                      *-----------------------------------------*
           perform   det-sld-mag-cll-000  thru det-sld-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Normalizzazione valore se negativo          *
      *                  *---------------------------------------------*
           if        d-sld-mag-sld-mag    <    zero
                     move  zero           to   d-sld-mag-sld-mag      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valore                      *
      *                  *---------------------------------------------*
           move      d-sld-mag-sld-mag    to   w-det-buf-dsp-wqg      .
       det-buf-dsp-150.
      *                  *---------------------------------------------*
