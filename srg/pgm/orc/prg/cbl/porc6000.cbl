      *              * Creazione elementi da righe ordini da fornitori *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su file [ofr]                         *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "RCHMAG    "         to   f-key                  .
           move      w-det-buf-dsp-dpz    to   rf-ofr-cod-dpz         .
           move      spaces               to   rf-ofr-flg-rch         .
           move      w-det-buf-dsp-tpm    to   rf-ofr-tip-mag         .
           move      w-det-buf-dsp-cnm    to   rf-ofr-num-mag         .
           move      zero                 to   rf-ofr-num-prt         .
           move      zero                 to   rf-ofr-num-prg         .
           move      "pgm/orf/fls/ioc/obj/iofofr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ofr                 .
      *                      *-----------------------------------------*
      *                      * Test su esito operazione                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-buf-dsp-300.
       det-buf-dsp-220.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale record [ofr]            *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/orf/fls/ioc/obj/iofofr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ofr                 .
      *                      *-----------------------------------------*
      *                      * Test se 'At end'                        *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-buf-dsp-300.
      *                  *---------------------------------------------*
      *                  * Test sul massimo                            *
      *                  *---------------------------------------------*
           if        rf-ofr-cod-dpz       not  = w-det-buf-dsp-dpz  or
                     rf-ofr-flg-rch       not  = spaces             or
                     rf-ofr-tip-mag       not  = w-det-buf-dsp-tpm  or
                     rf-ofr-num-mag       not  = w-det-buf-dsp-cnm
                     go to det-buf-dsp-300.
      *                  *---------------------------------------------*
      *                  * Selezione sul record                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su data documento                  *
      *                      *-----------------------------------------*
           if        rf-ofr-dat-doc       >    w-det-buf-dsp-dtb
                     go to det-buf-dsp-220.
      *                      *-----------------------------------------*
      *                      * Selezione su tipo riga                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Tipo riga in comodo ridefinito      *
      *                          *-------------------------------------*
           move      rf-ofr-tip-rig       to   w-det-buf-dsp-wtr      .
      *                          *-------------------------------------*
      *                          * Test su tipo funzionamento          *
      *                          *-------------------------------------*
           if        w-det-buf-dsp-wtf    not  = spaces
                     go to det-buf-dsp-220.
      *                      *-----------------------------------------*
      *                      * Determinazione, relativamente alla riga *
      *                      * ordine letta, di :                      *
      *                      *                                         *
      *                      *  - Quantita' in ordine                  *
      *                      *  - Quantita' ricevuta                   *
      *                      *  - Quantita' in corso di ricevimento    *
      *                      *                                         *
      *                      *  - Quantita' ancora da ricevere         *
      *                      *                                         *
      *                      *-----------------------------------------*
           move      "DT"                 to   d-qev-rof-tip-ope      .
