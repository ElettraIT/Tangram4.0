      *                  * zione                                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione work di accumulo        *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-buf-dsp-wqs      .
      *                      *-----------------------------------------*
      *                      * Start su file [osr]                     *
      *                      *-----------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "RCHMAG    "         to   f-key                  .
           move      w-det-buf-dsp-dpz    to   rf-osr-cod-dpz         .
           move      spaces               to   rf-osr-flg-rch         .
           move      w-det-buf-dsp-tpm    to   rf-osr-tip-mag         .
           move      w-det-buf-dsp-cnm    to   rf-osr-num-pro         .
           move      zero                 to   rf-osr-num-prt         .
           move      zero                 to   rf-osr-num-prg         .
           move      "pgm/ods/fls/ioc/obj/iofosr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osr                 .
      *                          *-------------------------------------*
      *                          * Test su esito operazione            *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-buf-dsp-180.
       det-buf-dsp-160.
      *                      *-----------------------------------------*
      *                      * Lettura sequenziale record [osr]        *
      *                      *-----------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/ods/fls/ioc/obj/iofosr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-osr                 .
      *                          *-------------------------------------*
      *                          * Test se 'At end'                    *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-buf-dsp-180.
      *                      *-----------------------------------------*
      *                      * Test sul massimo                        *
      *                      *-----------------------------------------*
           if        rf-osr-cod-dpz       not  = w-det-buf-dsp-dpz  or
                     rf-osr-flg-rch       not  = spaces             or
                     rf-osr-tip-mag       not  = w-det-buf-dsp-tpm  or
                     rf-osr-num-pro       not  = w-det-buf-dsp-cnm
                     go to det-buf-dsp-180.
      *                      *-----------------------------------------*
      *                      * Selezione sul record                    *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test su data registrazione          *
      *                          *-------------------------------------*
           if        rf-osr-dat-doc       >    w-det-buf-dsp-dtb
                     go to det-buf-dsp-160.
      *                          *-------------------------------------*
      *                          * Selezione su tipo riga              *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Tipo riga in comodo ridefinito  *
      *                              *---------------------------------*
           move      rf-osr-tip-rig       to   w-det-buf-dsp-wtr      .
      *                              *---------------------------------*
      *                              * Test su tipo funzionamento      *
      *                              *---------------------------------*
           if        w-det-buf-dsp-wtf    not  = spaces
                     go to det-buf-dsp-160.
      *                          *-------------------------------------*
      *                          * Determinazione, relativamente alla  *
      *                          * riga ordine di spedizione letta :   *
      *                          *                                     *
      *                          *  - Quantita' in ordine              *
      *                          *  - Quantita' spedita                *
      *                          *                                     *
      *                          *  - Quantita' ancora da spedire      *
      *                          *                                     *
      *                          *-------------------------------------*
           move      "DT"                 to   d-qds-ros-tip-ope      .
           perform   det-qds-ros-cll-000  thru det-qds-ros-cll-999    .
      *                          *-------------------------------------*
      *                          * Se quantita' da spedire a zero: ri- *
      *                          * ciclo                               *
