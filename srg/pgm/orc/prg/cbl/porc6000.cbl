      *
      *              *-------------------------------------------------*
           move      w-bds-num-ele        to   w-bds-ctr-002          .
           move      1                    to   w-bds-ctr-001          .
       det-buf-dsp-420.
           add       1                    to   w-bds-ctr-001          .
           if        w-bds-ctr-001        >    w-bds-ctr-002
                     go to det-buf-dsp-440.
      *                  *---------------------------------------------*
      *                  * Se data consegna prevista dell'elemento in- *
      *                  * feriore alla data orizzonte temporale : ri- *
      *                  * ciclo                                       *
      *                  *---------------------------------------------*
           if        w-bds-dat-dsp
                    (w-bds-ctr-001)       >    w-det-buf-dsp-dot
                     go to det-buf-dsp-440.
           go to     det-buf-dsp-420.
       det-buf-dsp-440.
      *                  *---------------------------------------------*
      *                  * Determinazione numero elementi effettivo    *
      *                  *---------------------------------------------*
           subtract  1                    from w-bds-ctr-001
                                        giving w-bds-num-ele          .
       det-buf-dsp-500.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-buf-dsp-999.
       det-buf-dsp-999.
           exit.

      *    *===========================================================*
      *    * Ordinamento buffer delle disponibilita'                   *
      *    *-----------------------------------------------------------*
       ord-buf-dsp-000.
      *              *-------------------------------------------------*
      *              * Test se almeno due codici da ordinare           *
      *              *-------------------------------------------------*
           if        w-bds-num-ele        <    2
                     go to ord-buf-dsp-999.
      *              *-------------------------------------------------*
      *              * Ciclo di ordinamento                            *
      *              *-------------------------------------------------*
           move      zero                 to   w-bds-ctr-001          .
       ord-buf-dsp-100.
           add       1                    to   w-bds-ctr-001          .
           if        w-bds-ctr-001        =    w-bds-num-ele
                     go to ord-buf-dsp-999.
           move      w-bds-ctr-001        to   w-bds-ctr-002
                                               w-bds-ctr-003          .
           move      w-bds-dat-dsp
                    (w-bds-ctr-001)       to   w-bds-sav-dds          .
       ord-buf-dsp-200.
           add       1                    to   w-bds-ctr-002          .
           if        w-bds-ctr-002        >    w-bds-num-ele
                     go to ord-buf-dsp-300.
           if        w-bds-dat-dsp
                    (w-bds-ctr-002)       >    w-bds-sav-dds
                     go to ord-buf-dsp-200.
           move      w-bds-ctr-002        to   w-bds-ctr-003          .
           move      w-bds-dat-dsp
                    (w-bds-ctr-002)       to   w-bds-sav-dds          .
           go to     ord-buf-dsp-200.
       ord-buf-dsp-300.
           move      w-bds-ctr-001        to   w-bds-ctr-004          .          
           if        w-bds-sav-dds        >    w-bds-dat-dsp
                                              (w-bds-ctr-004)
                     go to ord-buf-dsp-100.
           move      w-bds-sng-ele
                    (w-bds-ctr-003)       to   w-bds-sng-ele (1000)   .
           move      w-bds-sng-ele
                    (w-bds-ctr-004)       to   w-bds-sng-ele
                                              (w-bds-ctr-003)         .
           move      w-bds-sng-ele (1000) to   w-bds-sng-ele
                                              (w-bds-ctr-004)         .
           go to     ord-buf-dsp-100.
       ord-buf-dsp-999.
           exit.

      *    *===========================================================*
      *    * Determinazione buffer delle assegnazioni                  *
      *    *-----------------------------------------------------------*
       det-buf-ass-000.
      *              *-------------------------------------------------*
      *              * Data consegna prevista pari a data consegna ri- *
      *              * chiesta                                         *
      *              *-------------------------------------------------*
           move      w-det-buf-ass-dcr    to   w-det-buf-ass-dcp      .
      *              *-------------------------------------------------*
      *              * Inizializzazione numero elementi in buffer del- *
      *              * le assegnazioni                                 *
      *              *-------------------------------------------------*
           move      zero                 to   w-bas-num-ele          .
      *              *-------------------------------------------------*
      *              * Se data consegna richiesta superiore alla data  *
      *              * orizzonte temporale : uscita                    *
      *              *-------------------------------------------------*
           if        w-det-buf-ass-dcr    >    w-det-buf-ass-dot
                     go to det-buf-ass-999.
      *              *-------------------------------------------------*
      *              * Inizializzazione quantita' da assegnare         *
      *              *-------------------------------------------------*
           move      w-det-buf-ass-qev    to   w-det-buf-ass-wqa      .
       det-buf-ass-100.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione a ritroso sul buffer quanti- *
      *              * ta' disponibili                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione indice dell'elemento da cui  *
      *                  * partire                                     *
      *                  *---------------------------------------------*
           move      zero                 to   w-bds-ctr-001          .
       det-buf-ass-120.
           add       1                    to   w-bds-ctr-001          .
           if        w-bds-ctr-001        >    w-bds-num-ele
                     go to det-buf-ass-140.
           if        w-bds-dat-dsp
                    (w-bds-ctr-001)       >    w-det-buf-ass-dcr
                     go to det-buf-ass-140.
           go to     det-buf-ass-120.
       det-buf-ass-140.
      *                  *---------------------------------------------*
      *                  * Posizionamento sull'elemento trovato        *
      *                  *---------------------------------------------*
           move      w-bds-ctr-001        to   w-bds-ctr-002          .
       det-buf-ass-160.
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione buffer delle disponibi-  *
      *                  * lita'                                       *
      *                  *---------------------------------------------*
           subtract  1                    from w-bds-ctr-002          .
      *                      *-----------------------------------------*
      *                      * Se oltre il primo elemento : oltre      *
      *                      *-----------------------------------------*
           if        w-bds-ctr-002        =    zero
                     go to det-buf-ass-200.
      *                      *-----------------------------------------*
      *                      * Se quantita' residua dell'elemento a    *
      *                      * zero, si passa al precedente            *
      *                      *-----------------------------------------*
           if        w-bds-qta-res
                    (w-bds-ctr-002)       =    zero
                     go to det-buf-ass-160.
      *                      *-----------------------------------------*
      *                      * Determinazione quantita' utilizzabile   *
      *                      * dell'elemento                           *
      *                      *-----------------------------------------*
           if        w-det-buf-ass-wqa    >    w-bds-qta-res
                                              (w-bds-ctr-002)
                     move  w-bds-qta-res
                          (w-bds-ctr-002) to   w-det-buf-ass-wqu
           else      move  w-det-buf-ass-wqa
                                          to   w-det-buf-ass-wqu      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento elemento del buffer delle *
      *                      * disponibilita'                          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Quantita' assegnata                 *
      *                          *-------------------------------------*
           add       w-det-buf-ass-wqu    to   w-bds-qta-ass
                                              (w-bds-ctr-002)         .
      *                          *-------------------------------------*
      *                          * Quantita' residua                   *
      *                          *-------------------------------------*
           subtract  w-det-buf-ass-wqu    from w-bds-qta-res
                                              (w-bds-ctr-002)         .
      *                      *-----------------------------------------*
      *                      * Creazione elemento del buffer delle as- *
      *                      * segnazioni                              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Incremento numero elementi          *
      *                          *-------------------------------------*
           if        w-bas-num-ele        <    w-bas-max-ele
                     add   1              to   w-bas-num-ele          .
      *                          *-------------------------------------*
      *                          * Quantita' assegnata                 *
      *                          *-------------------------------------*
           move      w-det-buf-ass-wqu    to   w-bas-qta-ass
                                              (w-bas-num-ele)         .
      *                          *-------------------------------------*
      *                          * Data assegnata                      *
      *                          *-------------------------------------*
           move      w-bds-dat-dsp
                    (w-bds-ctr-002)       to   w-bas-dat-ass
                                              (w-bas-num-ele)         .
      *                          *-------------------------------------*
      *                          * Protocollo ordine fornitore         *
      *                          *-------------------------------------*
           move      w-bds-prt-orf
                    (w-bds-ctr-002)       to   w-bas-prt-orf
                                              (w-bas-num-ele)         .
      *                          *-------------------------------------*
      *                          * Progressivo riga ordine fornitore   *
      *                          *-------------------------------------*
           move      w-bds-prg-orf
                    (w-bds-ctr-002)       to   w-bas-prg-orf
                                              (w-bas-num-ele)         .
      *                      *-----------------------------------------*
      *                      * Aggiornamento quantita' da assegnare    *
      *                      *-----------------------------------------*
           subtract  w-det-buf-ass-wqu    from w-det-buf-ass-wqa      .
           if        w-det-buf-ass-wqa    <    zero
                     move  zero           to   w-det-buf-ass-wqa      .
      *                      *-----------------------------------------*
      *                      * Se quantita' da assegnare non a zero :  *
      *                      * si passa all'elemento precedente        *
      *                      *-----------------------------------------*
           if        w-det-buf-ass-wqa    >    zero
                     go to det-buf-ass-160.
      *                      *-----------------------------------------*
      *                      * Preparazione valore in uscita           *
      *                      *-----------------------------------------*
           move      w-bds-dat-dsp
                    (w-bds-ctr-002)       to   w-det-buf-ass-dcp      .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     det-buf-ass-400.
       det-buf-ass-200.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione in avanti sul buffer quanti- *
      *              * ta' disponibili                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Posizionamento sull'elemento precedente a   *
      *                  * quello trovato inizialmente                 *
      *                  *---------------------------------------------*
           move      w-bds-ctr-001        to   w-bds-ctr-002          .
           subtract  1                    from w-bds-ctr-002          .
       det-buf-ass-220.
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione                          *
      *                  *---------------------------------------------*
           add       1                    to   w-bds-ctr-002          .
      *                      *-----------------------------------------*
      *                      * Se oltre l'ultimo elemento : oltre      *
      *                      *-----------------------------------------*
           if        w-bds-ctr-002        >    w-bds-num-ele
                     go to det-buf-ass-300.
      *                      *-----------------------------------------*
      *                      * Se quantita' residua dell'elemento a    *
      *                      * zero, si passa al successivo            *
      *                      *-----------------------------------------*
           if        w-bds-qta-res
                    (w-bds-ctr-002)       =    zero
                     go to det-buf-ass-220.
      *                      *-----------------------------------------*
      *                      * Determinazione quantita' utilizzabile   *
      *                      * dell'elemento                           *
      *                      *-----------------------------------------*
           if        w-det-buf-ass-wqa    >    w-bds-qta-res
                                              (w-bds-ctr-002)
                     move  w-bds-qta-res
                          (w-bds-ctr-002) to   w-det-buf-ass-wqu
           else      move  w-det-buf-ass-wqa
                                          to   w-det-buf-ass-wqu      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento elemento del buffer delle *
      *                      * disponibilita'                          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Quantita' assegnata                 *
      *                          *-------------------------------------*
           add       w-det-buf-ass-wqu    to   w-bds-qta-ass
                                              (w-bds-ctr-002)         .
      *                          *-------------------------------------*
      *                          * Quantita' residua                   *
      *                          *-------------------------------------*
           subtract  w-det-buf-ass-wqu    from w-bds-qta-res
                                              (w-bds-ctr-002)         .
      *                      *-----------------------------------------*
      *                      * Creazione elemento del buffer delle as- *
      *                      * segnazioni                              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Incremento numero elementi          *
      *                          *-------------------------------------*
           if        w-bas-num-ele        <    w-bas-max-ele
                     add   1              to   w-bas-num-ele          .
      *                          *-------------------------------------*
      *                          * Quantita' assegnata                 *
      *                          *-------------------------------------*
           move      w-det-buf-ass-wqu    to   w-bas-qta-ass
                                              (w-bas-num-ele)         .
      *                          *-------------------------------------*
      *                          * Data assegnata                      *
      *                          *-------------------------------------*
           move      w-bds-dat-dsp
                    (w-bds-ctr-002)       to   w-bas-dat-ass
                                              (w-bas-num-ele)         .
      *                          *-------------------------------------*
      *                          * Protocollo ordine fornitore         *
      *                          *-------------------------------------*
           move      w-bds-prt-orf
                    (w-bds-ctr-002)       to   w-bas-prt-orf
                                              (w-bas-num-ele)         .
      *                          *-------------------------------------*
      *                          * Progressivo riga ordine fornitore   *
      *                          *-------------------------------------*
           move      w-bds-prg-orf
                    (w-bds-ctr-002)       to   w-bas-prg-orf
                                              (w-bas-num-ele)         .
      *                      *-----------------------------------------*
      *                      * Aggiornamento quantita' da assegnare    *
      *                      *-----------------------------------------*
           subtract  w-det-buf-ass-wqu    from w-det-buf-ass-wqa      .
           if        w-det-buf-ass-wqa    <    zero
                     move  zero           to   w-det-buf-ass-wqa      .
      *                      *-----------------------------------------*
      *                      * Se quantita' da assegnare non a zero :  *
      *                      * si passa all'elemento successivo        *
      *                      *-----------------------------------------*
           if        w-det-buf-ass-wqa    >    zero
                     go to det-buf-ass-220.
      *                      *-----------------------------------------*
      *                      * Preparazione valore in uscita           *
      *                      *-----------------------------------------*
           move      w-bds-dat-dsp
                    (w-bds-ctr-002)       to   w-det-buf-ass-dcp      .
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     det-buf-ass-400.
       det-buf-ass-300.
      *              *-------------------------------------------------*
      *              * Se quantita' da assegnare non ancora esaurita,  *
      *              * si pone come data consegna prevista la data     *
      *              * dell'orizzonte temporale                        *
      *              *-------------------------------------------------*
           move      w-det-buf-ass-dot    to   w-det-buf-ass-dcp      .
      *              *-------------------------------------------------*
      *              * Creazione ultimo elemento del buffer delle as-  *
      *              * segnazioni                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Incremento numero elementi                  *
      *                  *---------------------------------------------*
           if        w-bas-num-ele        <    w-bas-max-ele
                     add   1              to   w-bas-num-ele          .
      *                  *---------------------------------------------*
      *                  * Quantita' assegnata                         *
      *                  *---------------------------------------------*
           move      w-det-buf-ass-wqa    to   w-bas-qta-ass
                                              (w-bas-num-ele)         .
      *                  *---------------------------------------------*
      *                  * Data assegnata                              *
      *                  *---------------------------------------------*
           move      w-det-buf-ass-dot    to   w-bas-dat-ass
                                              (w-bas-num-ele)         .
      *                  *---------------------------------------------*
      *                  * Protocollo ordine fornitore                 *
      *                  *---------------------------------------------*
           move      zero                 to   w-bas-prt-orf
                                              (w-bas-num-ele)         .
      *                  *---------------------------------------------*
      *                  * Progressivo riga ordine fornitore           *
      *                  *---------------------------------------------*
           move      zero                 to   w-bas-prg-orf
                                              (w-bas-num-ele)         .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     det-buf-ass-400.
       det-buf-ass-400.
      *              *-------------------------------------------------*
      *              * Aggiustamento date assegnate nel buffer delle   *
      *              * assegnazioni                                    *
      *              *-------------------------------------------------*
           move      zero                 to   w-bas-ctr-001          .
       det-buf-ass-420.
           add       1                    to   w-bas-ctr-001          .
           if        w-bas-ctr-001        >    w-bas-num-ele
                     go to det-buf-ass-500.
      *                  *---------------------------------------------*
      *                  * Se a zero, cioe' assegnazione alla giacen-  *
      *                  * za : riciclo                                *
      *                  *---------------------------------------------*
           if        w-bas-dat-ass
                    (w-bas-ctr-001)       =    zero
                     go to det-buf-ass-420.
      *                  *---------------------------------------------*
      *                  * Se inferiore alla data consegna richiesta : *
      *                  * forzatura della data consegna richiesta     *
      *                  *---------------------------------------------*
           if        w-bas-dat-ass
                    (w-bas-ctr-001)       <    w-det-buf-ass-dcr
                     move  w-det-buf-ass-dcr
                                          to   w-bas-dat-ass
                                              (w-bas-ctr-001)         .
      *                  *---------------------------------------------*
      *                  * Se inferiore alla data elaborazione : for-  *
      *                  * zatura della data elaborazione              *
      *                  *---------------------------------------------*
           if        w-bas-dat-ass
                    (w-bas-ctr-001)       <    w-det-buf-ass-dtb
                     move  w-det-buf-ass-dtb
                                          to   w-bas-dat-ass
                                              (w-bas-ctr-001)         .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-buf-ass-420.
       det-buf-ass-500.
      *              *-------------------------------------------------*
      *              * Compattamento buffer delle assegnazioni         *
      *              *-------------------------------------------------*
           move      zero                 to   w-bas-ctr-001          .
           move      zero                 to   w-bas-ctr-002          .
       det-buf-ass-520.
           add       1                    to   w-bas-ctr-001          .
           if        w-bas-ctr-001        >    w-bas-num-ele
                     go to det-buf-ass-580.
           if        w-bas-ctr-002        =    zero
                     go to det-buf-ass-540.
           if        w-bas-dat-ass
                    (w-bas-ctr-001)       =    w-bas-dat-ass
                                              (w-bas-ctr-002)
                     add   w-bas-qta-ass
                          (w-bas-ctr-001) to   w-bas-qta-ass
                                              (w-bas-ctr-002)
                     go to det-buf-ass-520.
       det-buf-ass-540.
           add       1                    to   w-bas-ctr-002          .
           move      w-bas-sng-ele
                    (w-bas-ctr-001)       to   w-bas-sng-ele
                                              (w-bas-ctr-002)         .
           go to     det-buf-ass-520.
       det-buf-ass-580.
           move      w-bas-ctr-002        to   w-bas-num-ele          .
       det-buf-ass-600.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-buf-ass-999.
       det-buf-ass-999.
           exit.

