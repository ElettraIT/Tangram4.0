      *    *===========================================================*
      *    * Controllo su tasto Do in parametri di selezione           *
      *    *-----------------------------------------------------------*
       tdo-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione status di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tdo-ric-flg      .
       tdo-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Controlli                                       *
      *              *-------------------------------------------------*
       tdo-ric-sel-110.
      *                  *---------------------------------------------*
      *                  * Test su tipo movimento                      *
      *                  *---------------------------------------------*
           if        rr-tip-mov           not  = spaces
                     go to tdo-ric-sel-120.
           move      "Manca il tipo movimento !"
                                          to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-120.
      *                  *---------------------------------------------*
      *                  * Test su data registrazione minima e massima *
      *                  *---------------------------------------------*
           if        rr-dat-min           =    zero or
                     rr-dat-max           =    zero
                     go to tdo-ric-sel-130.
           if        rr-dat-min           not  > rr-dat-max
                     go to tdo-ric-sel-130.
           move      "Data registrazione iniziale maggiore di quella fin
      -              "ale !"              to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-130.
      *                  *---------------------------------------------*
      *                  * Test su numero protocollo minimo e massimo  *
      *                  *---------------------------------------------*
           if        rr-num-min           =    zero or
                     rr-num-max           =    zero
                     go to tdo-ric-sel-140.
           if        rr-num-min           not  > rr-num-max
                     go to tdo-ric-sel-140.
           move      "Protocollo iniziale maggiore di quello finale !"
                                          to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-140.
      *                  *---------------------------------------------*
      *                  * Test su codice fornitore minimo e massimo   *
      *                  *---------------------------------------------*
           if        rr-fnt-min           =    zero or
                     rr-fnt-max           =    zero
                     go to tdo-ric-sel-150.
           if        rr-fnt-min           not  > rr-fnt-max
                     go to tdo-ric-sel-150.
           move      "Codice fornitore iniziale maggiore di quella final
      -              "e !"                to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-150.
      *                  *---------------------------------------------*
      *                  * Test su dipendenza minima e massima         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se campo da accettare              *
      *                      *-----------------------------------------*
           if        rr-fnt-min           =    zero
                     go to tdo-ric-sel-160.
           if        rr-fnt-max           =    rr-fnt-min or
                     rr-fnt-max           =    zero
                     go to tdo-ric-sel-155
           else      go to tdo-ric-sel-160.
       tdo-ric-sel-155.
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        rr-dpz-min           =    spaces or
                     rr-dpz-max           =    spaces
                     go to tdo-ric-sel-160.
           if        rr-dpz-min           not  > rr-dpz-max
                     go to tdo-ric-sel-160.
           move      "Dipendenza fornitore iniziale maggiore di quella f
      -              "inale !"            to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-160.
       tdo-ric-sel-200.
      *                  *---------------------------------------------*
      *                  * Controllo su data consegna minima e massima *
      *                  *---------------------------------------------*
           if        rr-dcn-min           =    zero or
                     rr-dcn-max           =    zero
                     go to tdo-ric-sel-300.
           if        rr-dcn-max           not  < rr-dcn-min
                     go to tdo-ric-sel-300.
           move      "Data consegna massima inferiore alla data consegna
      -              " minima        "    to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-300.
