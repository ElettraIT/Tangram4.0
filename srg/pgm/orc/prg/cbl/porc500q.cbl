      *    *===========================================================*
      *    * Determinazione quantita' di fabbisogno/disponibilita' da  *
      *    * visualizzare nell'interrogazione                          *
      *    *-----------------------------------------------------------*
       det-qfd-dav-000.
      *              *-------------------------------------------------*
      *              * Determinazione giacenza                         *
      *              *-------------------------------------------------*
           move      d-buf-fod-qta-gia    to   w-det-qfd-dav-gia      .
       det-qfd-dav-100.
      *              *-------------------------------------------------*
      *              * Determinazione fabbisogno/disponibilita' alla   *
      *              * data nr. 1                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se data nr. 1 superiore alla data consegna  *
      *                  * prevista dell'ultimo elemento : bufferizza- *
      *                  * zione quantita' dell'ultimo elemento        *
      *                  *---------------------------------------------*
           if        w-det-qfd-dav-dt1    >    d-buf-fod-dcn-prv
                                              (d-buf-fod-num-ele)
                     move  d-buf-fod-qta-fod
                          (d-buf-fod-num-ele)
                                          to   w-det-qfd-dav-fd1
                     go to det-qfd-dav-200.
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione buffer delle quantita'   *
      *                  * di fabbisogno/disponibilita'                *
      *                  *---------------------------------------------*
           move      1                    to   d-buf-fod-ctr-001      .
       det-qfd-dav-120.
           add       1                    to   d-buf-fod-ctr-001      .
      *                      *-----------------------------------------*
      *                      * Se raggiunto l'ultimo elemento : buffe- *
      *                      * rizzazione quantita' dell'ultimo ele-   *
      *                      * mento                                   *
      *                      *-----------------------------------------*
           if        d-buf-fod-ctr-001    >    d-buf-fod-num-ele
                     move  d-buf-fod-qta-fod
                          (d-buf-fod-num-ele)
                                          to   w-det-qfd-dav-fd1
                     go to det-qfd-dav-200.
      *                      *-----------------------------------------*
      *                      * Finche' la data nr. 1 e' superiore alla *
      *                      * data consegna prevista dell'elemento :  *
      *                      * riciclo                                 *
      *                      *-----------------------------------------*
           if        w-det-qfd-dav-dt1    >    d-buf-fod-dcn-prv
                                              (d-buf-fod-ctr-001)
                     go to det-qfd-dav-120.
      *                      *-----------------------------------------*
      *                      * Determinazione indice elemento su cui   *
      *                      * posizionarsi                            *
      *                      *-----------------------------------------*
           if        w-det-qfd-dav-dt1    <    d-buf-fod-dcn-prv
                                              (d-buf-fod-ctr-001)
                     subtract  1          from d-buf-fod-ctr-001      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione quantita' di fabbiso-   *
      *                      * gno/disponibilita' dell'elemento su cui *
      *                      * si e' posizionati                       *
      *                      *-----------------------------------------*
           move      d-buf-fod-qta-fod
                    (d-buf-fod-ctr-001)   to   w-det-qfd-dav-fd1      .
       det-qfd-dav-200.
      *              *-------------------------------------------------*
      *              * Determinazione fabbisogno/disponibilita' alla   *
      *              * data nr. 2                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se data nr. 2 superiore alla data consegna  *
      *                  * prevista dell'ultimo elemento : bufferizza- *
      *                  * zione quantita' dell'ultimo elemento        *
      *                  *---------------------------------------------*
           if        w-det-qfd-dav-dt2    >    d-buf-fod-dcn-prv
                                              (d-buf-fod-num-ele)
                     move  d-buf-fod-qta-fod
                          (d-buf-fod-num-ele)
                                          to   w-det-qfd-dav-fd2
                     go to det-qfd-dav-300.
      *                  *---------------------------------------------*
      *                  * Continuazione scansione buffer delle quan-  *
      *                  * tita' di fabbisogno/disponibilita'          *
      *                  *---------------------------------------------*
       det-qfd-dav-220.
           add       1                    to   d-buf-fod-ctr-001      .
      *                      *-----------------------------------------*
      *                      * Se raggiunto l'ultimo elemento : buffe- *
      *                      * rizzazione quantita' dell'ultimo ele-   *
      *                      * mento                                   *
      *                      *-----------------------------------------*
           if        d-buf-fod-ctr-001    >    d-buf-fod-num-ele
                     move  d-buf-fod-qta-fod
                          (d-buf-fod-num-ele)
                                          to   w-det-qfd-dav-fd2
                     go to det-qfd-dav-300.
      *                      *-----------------------------------------*
      *                      * Finche' la data nr. 2 e' superiore alla *
      *                      * data consegna prevista dell'elemento :  *
      *                      * riciclo                                 *
      *                      *-----------------------------------------*
           if        w-det-qfd-dav-dt2    >    d-buf-fod-dcn-prv
                                              (d-buf-fod-ctr-001)
                     go to det-qfd-dav-220.
      *                      *-----------------------------------------*
      *                      * Determinazione indice elemento su cui   *
      *                      * posizionarsi                            *
      *                      *-----------------------------------------*
           if        w-det-qfd-dav-dt2    <    d-buf-fod-dcn-prv
                                              (d-buf-fod-ctr-001)
                     subtract  1          from d-buf-fod-ctr-001      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione quantita' di fabbiso-   *
      *                      * gno/disponibilita' dell'elemento su cui *
      *                      * si e' posizionati                       *
      *                      *-----------------------------------------*
           move      d-buf-fod-qta-fod
                    (d-buf-fod-ctr-001)   to   w-det-qfd-dav-fd2      .
       det-qfd-dav-300.
      *              *-------------------------------------------------*
      *              * Determinazione fabbisogno/disponibilita' alla   *
      *              * data nr. 3                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se data nr. 3 superiore alla data consegna  *
      *                  * prevista dell'ultimo elemento : bufferizza- *
      *                  * zione quantita' dell'ultimo elemento        *
      *                  *---------------------------------------------*
           if        w-det-qfd-dav-dt3    >    d-buf-fod-dcn-prv
                                              (d-buf-fod-num-ele)
                     move  d-buf-fod-qta-fod
                          (d-buf-fod-num-ele)
                                          to   w-det-qfd-dav-fd3
                     go to det-qfd-dav-400.
      *                  *---------------------------------------------*
      *                  * Continuazione scansione buffer delle quan-  *
      *                  * tita' di fabbisogno/disponibilita'          *
      *                  *---------------------------------------------*
       det-qfd-dav-320.
           add       1                    to   d-buf-fod-ctr-001      .
      *                      *-----------------------------------------*
      *                      * Se raggiunto l'ultimo elemento : buffe- *
      *                      * rizzazione quantita' dell'ultimo ele-   *
      *                      * mento                                   *
      *                      *-----------------------------------------*
           if        d-buf-fod-ctr-001        >    d-buf-fod-num-ele
                     move  d-buf-fod-qta-fod
                          (d-buf-fod-num-ele)
                                          to   w-det-qfd-dav-fd3
                     go to det-qfd-dav-400.
      *                      *-----------------------------------------*
      *                      * Finche' la data nr. 3 e' superiore alla *
      *                      * data consegna prevista dell'elemento :  *
      *                      * riciclo                                 *
      *                      *-----------------------------------------*
           if        w-det-qfd-dav-dt3    >    d-buf-fod-dcn-prv
                                              (d-buf-fod-ctr-001)
                     go to det-qfd-dav-320.
      *                      *-----------------------------------------*
      *                      * Determinazione indice elemento su cui   *
      *                      * posizionarsi                            *
      *                      *-----------------------------------------*
           if        w-det-qfd-dav-dt3    <    d-buf-fod-dcn-prv
                                              (d-buf-fod-ctr-001)
                     subtract  1          from d-buf-fod-ctr-001      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione quantita' di fabbiso-   *
      *                      * gno/disponibilita' dell'elemento su cui *
      *                      * si e' posizionati                       *
      *                      *-----------------------------------------*
           move      d-buf-fod-qta-fod
                    (d-buf-fod-ctr-001)   to   w-det-qfd-dav-fd3      .
       det-qfd-dav-400.
      *              *-------------------------------------------------*
      *              * Determinazione fabbisogno/disponibilita' oltre  *
      *              * la data nr. 3                                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Bufferizzazione quantita' di fabbisogno/di- *
      *                  * sponibilita' dell'ultimo elemento           *
      *                  *---------------------------------------------*
           move      d-buf-fod-qta-fod
                    (d-buf-fod-num-ele)   to   w-det-qfd-dav-fd4      .
       det-qfd-dav-500.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-qfd-dav-999.
       det-qfd-dav-999.
           exit.

      *    *===========================================================*
      *    * Interrogazione : Start iniziale                           *
      *    *-----------------------------------------------------------*
       qry-str-ini-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-qry-flg-sub      .
      *              *-------------------------------------------------*
      *              * Determinazione date per fabbisogni/disponibili- *
      *              * ta' da visualizzare                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Data nr. 1                                  *
      *                  *---------------------------------------------*
           move      rr-dat-ela           to   w-det-dat-nrg-dtb      .
           move      w-ref-nrg-fd1        to   w-det-dat-nrg-ngi      .
           perform   det-dat-nrg-000      thru det-dat-nrg-999        .
           move      w-det-dat-nrg-dti    to   w-qry-dat-fd1          .
      *                  *---------------------------------------------*
      *                  * Data nr. 2                                  *
      *                  *---------------------------------------------*
           move      rr-dat-ela           to   w-det-dat-nrg-dtb      .
           move      w-ref-nrg-fd2        to   w-det-dat-nrg-ngi      .
           perform   det-dat-nrg-000      thru det-dat-nrg-999        .
           move      w-det-dat-nrg-dti    to   w-qry-dat-fd2          .
      *                  *---------------------------------------------*
      *                  * Data nr. 3                                  *
      *                  *---------------------------------------------*
           move      rr-dat-ela           to   w-det-dat-nrg-dtb      .
           move      w-ref-nrg-fd3        to   w-det-dat-nrg-ngi      .
           perform   det-dat-nrg-000      thru det-dat-nrg-999        .
           move      w-det-dat-nrg-dti    to   w-qry-dat-fd3          .
       qry-str-ini-050.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo ordinamento     *
      *              *-------------------------------------------------*
           if        rr-tip-ord           =    01
                     go to qry-str-ini-100
           else if   rr-tip-ord           =    02
                     go to qry-str-ini-200
           else if   rr-tip-ord           =    03
                     go to qry-str-ini-300.
       qry-str-ini-100.
      *              *-------------------------------------------------*
      *              * Tipo ordinamento : Codice prodotto              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su file [dcp]                         *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "ALFPRO    "         to   f-key                  .
           move      rr-cod-min           to   rf-dcp-alf-pro         .
           move      zero                 to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
