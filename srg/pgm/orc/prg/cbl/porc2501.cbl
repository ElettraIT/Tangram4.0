                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Incremento progressivo di rilascio              *
      *              *-------------------------------------------------*
           add       1                    to   w-stp-srt-inp-prg      .
      *              *-------------------------------------------------*
      *              * Max su filtro                                   *
      *              *-------------------------------------------------*
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Sel su filtro                                   *
      *              *-------------------------------------------------*
       stp-srt-inp-500.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione righe ordine                 *
      *              *-------------------------------------------------*
           perform   stp-srt-inp-ocr-000  thru stp-srt-inp-ocr-999    .
       stp-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Riciclo su filtro                               *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Ciclo per righe ordine                                    *
      *    *-----------------------------------------------------------*
       stp-srt-inp-ocr-000.
      *              *-------------------------------------------------*
      *              * Start su file [ocr]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "MAGDAT    "         to   f-key                  .
           move      rr-dpz-inu           to   rf-ocr-cod-dpz         .
           move      01                   to   rf-ocr-tip-mag         .
           move      rf-dcp-num-pro       to   rf-ocr-num-pro         .
           move      rr-dem-min           to   rf-ocr-dat-doc         .
           move      spaces               to   rf-ocr-num-doc         .
           move      zero                 to   rf-ocr-num-prt         .
           move      zero                 to   rf-ocr-num-prg         .
           move      "pgm/orc/fls/ioc/obj/iofocr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-ocr-900.
       stp-srt-inp-ocr-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [ocr]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofocr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocr                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-ocr-900.
       stp-srt-inp-ocr-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice dipendenza                   *
      *                  *---------------------------------------------*
           if        rf-ocr-cod-dpz       not  = rr-dpz-inu
                     go to stp-srt-inp-ocr-900.
      *                  *---------------------------------------------*
      *                  * Test su tipo prodotto                       *
      *                  *---------------------------------------------*
           if        rf-ocr-tip-mag       not  = 01
                     go to stp-srt-inp-ocr-900.
      *                  *---------------------------------------------*
      *                  * Test su codice prodotto                     *
      *                  *---------------------------------------------*
           if        rf-ocr-num-pro       not  = rf-dcp-num-pro
                     go to stp-srt-inp-ocr-900.
      *                  *---------------------------------------------*
      *                  * Selezione su data emissione massima         *
      *                  *---------------------------------------------*
           if        rf-ocr-dat-doc       >    rr-dem-max
                     go to stp-srt-inp-ocr-900.
       stp-srt-inp-ocr-400.
      *              *-------------------------------------------------*
      *              * Selezioni sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Selezione su tipi ordine                    *
      *                  *---------------------------------------------*
           if        rr-tip-doc-nor       =    spaces and
                     rf-ocr-tip-ord       =    spaces
                     go to stp-srt-inp-ocr-200.
           if        rr-tip-doc-opf       =    spaces and
                     rf-ocr-tip-ord       =    "P"
                     go to stp-srt-inp-ocr-200.
           if        rr-tip-doc-ofc       =    spaces and
                     rf-ocr-tip-ord       =    "F"
                     go to stp-srt-inp-ocr-200.
       stp-srt-inp-ocr-410.
      *                  *---------------------------------------------*
      *                  * Selezione su codice del cliente             *
      *                  *---------------------------------------------*
           if        rr-cod-cli           not  = zero   and
                     rf-ocr-cod-arc       not  = rr-cod-cli
                     go to stp-srt-inp-ocr-200.
      *                  *---------------------------------------------*
      *                  * Selezione su codice dipendenza del cliente  *
      *                  *---------------------------------------------*
           if        rr-cod-cli           =    zero
                     go to stp-srt-inp-ocr-420.
           if        rr-dpz-cli           =    "*    "
                     go to stp-srt-inp-ocr-420.
           if        rf-ocr-dpz-arc       not  = rr-dpz-cli
                     go to stp-srt-inp-ocr-200.
       stp-srt-inp-ocr-420.
      *                  *---------------------------------------------*
      *                  * Selezione su data consegna prevista massima *
      *                  *---------------------------------------------*
           if        rf-ocr-dcn-prv       >    rr-dcn-prv
                     go to stp-srt-inp-ocr-200.
       stp-srt-inp-ocr-460.
      *                  *---------------------------------------------*
      *                  * Selezione su tipo riga                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo riga in comodo ridefinito          *
      *                      *-----------------------------------------*
           move      rf-ocr-tip-rig       to   w-stp-srt-inp-wtr      .
      *                      *-----------------------------------------*
      *                      * Se tipo riga non 'P' : riciclo          *
      *                      *-----------------------------------------*
           if        w-stp-srt-inp-wtp    not  = "P"
                     go to stp-srt-inp-ocr-200.
       stp-srt-inp-ocr-470.
      *                  *---------------------------------------------*
      *                  * Selezione su segnale di riga comunque con-  *
      *                  * siderata saldata                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione dello stato de-  *
      *                      * gli ordini richiesto                    *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-ocr-471
                     stp-srt-inp-ocr-472
                     stp-srt-inp-ocr-473
                     stp-srt-inp-ocr-474
                     stp-srt-inp-ocr-475
                     depending            on   rr-sts-orc             .
       stp-srt-inp-ocr-471.
      *                      *-----------------------------------------*
      *                      * Se solo ordini da evadere               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test su flag di riga comunque sal-  *
      *                          * data                                *
      *                          *-------------------------------------*
           if        rf-ocr-sdr-ccs       not  = spaces
                     go to stp-srt-inp-ocr-200.
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     stp-srt-inp-ocr-480.
       stp-srt-inp-ocr-472.
      *                      *-----------------------------------------*
      *                      * Se solo ordini in spedizione            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     stp-srt-inp-ocr-480.
       stp-srt-inp-ocr-473.
      *                      *-----------------------------------------*
      *                      * Se solo ordini gia' evasi               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     stp-srt-inp-ocr-480.
       stp-srt-inp-ocr-474.
      *                      *-----------------------------------------*
      *                      * Se tutti gli ordini                     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     stp-srt-inp-ocr-480.
       stp-srt-inp-ocr-475.
      *                      *-----------------------------------------*
      *                      * Se ultimo ordine                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     stp-srt-inp-ocr-480.
       stp-srt-inp-ocr-480.
      *                  *---------------------------------------------*
      *                  * Selezione sulla quantita' ancora da evadere *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione quantita' evasa riga or- *
      *                      * dine cliente                            *
      *                      *-----------------------------------------*
           move      "DT"                 to   d-qev-roc-tip-ope      .
           perform   det-qev-roc-cll-000  thru det-qev-roc-cll-999    .
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione dello stato de-  *
      *                      * gli ordini richiesto                    *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-ocr-482
                     stp-srt-inp-ocr-484
                     stp-srt-inp-ocr-486
                     stp-srt-inp-ocr-488
                     stp-srt-inp-ocr-490
                     depending            on   rr-sts-orc             .
       stp-srt-inp-ocr-482.
      *                      *-----------------------------------------*
      *                      * Se solo ordini da evadere               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se quantita' ancora da evadere a    *
      *                          * zero : riciclo                      *
      *                          *-------------------------------------*
           if        d-qev-roc-qta-dev    =    zero
                     go to stp-srt-inp-ocr-200.
           go to     stp-srt-inp-ocr-500.
       stp-srt-inp-ocr-484.
      *                      *-----------------------------------------*
      *                      * Se solo ordini in spedizione            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se quantita' in corso di spedizione *
      *                          * a zero : riciclo                    *
      *                          *-------------------------------------*
           if        d-qev-roc-qta-ics    =    zero
                     go to stp-srt-inp-ocr-200.
           go to     stp-srt-inp-ocr-500.
       stp-srt-inp-ocr-486.
      *                      *-----------------------------------------*
      *                      * Se solo ordini gia' evasi               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se quantita' ancora da evadere non  *
      *                          * a zero : riciclo                    *
      *                          *-------------------------------------*
           if        d-qev-roc-qta-dev    not  = zero
                     go to stp-srt-inp-ocr-200.
           go to     stp-srt-inp-ocr-500.
       stp-srt-inp-ocr-488.
      *                      *-----------------------------------------*
      *                      * Se tutti gli ordini                     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Nessun test                         *
      *                          *-------------------------------------*
           go to     stp-srt-inp-ocr-500.
       stp-srt-inp-ocr-490.
      *                      *-----------------------------------------*
      *                      * Se ultimo ordine                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Nessun test                         *
      *                          *-------------------------------------*
           go to     stp-srt-inp-ocr-500.
       stp-srt-inp-ocr-500.
      *              *-------------------------------------------------*
      *              * Letture complementari                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione [dcc]                       *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
      *                  *---------------------------------------------*
      *                  * Lettura record [dcc]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLI    "         to   f-key                  .
           move      rf-ocr-cod-arc       to   rf-dcc-cod-cli         .
           move      rf-ocr-dpz-arc       to   rf-dcc-dpz-cli         .
           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
           if        f-sts                not  = e-not-err
                     move  all "."        to   rf-dcc-rag-soc         .
       stp-srt-inp-ocr-520.
      *              *-------------------------------------------------*
      *              * Determinazione descrizione riga ordine          *
      *              *-------------------------------------------------*
       stp-srt-inp-ocr-600.
      *              *-------------------------------------------------*
      *              * Determinazione importo residuo nella valuta di  *
      *              * fatturazione                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Bufferizzazione prezzo netto contenuto nel  *
      *                  * record                                      *
      *                  *---------------------------------------------*
           move      rf-ocr-prz-net       to   w-stp-srt-inp-prz      .
      *                  *---------------------------------------------*
      *                  * Per righe prodotto                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione dello stato de-  *
      *                      * gli ordini richiesto                    *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-ocr-610
                     stp-srt-inp-ocr-620
                     stp-srt-inp-ocr-630
                     stp-srt-inp-ocr-640
                     stp-srt-inp-ocr-640
                     depending            on   rr-sts-orc             .
       stp-srt-inp-ocr-610.
      *                      *-----------------------------------------*
      *                      * Se solo ordini da evadere               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se prezzo per quantita'        *
      *                          *-------------------------------------*
           if        rf-ocr-flg-puq       =    spaces
                     go to stp-srt-inp-ocr-615.
      *                          *-------------------------------------*
      *                          * Divisione                           *
      *                          *-------------------------------------*
           if        rf-ocr-flg-puq       =    "D"
                     divide 10            into d-qev-roc-qta-dev
                                        giving w-stp-srt-qta-dev
           else if   rf-ocr-flg-puq       =    "C"
                     divide 100           into d-qev-roc-qta-dev
                                        giving w-stp-srt-qta-dev
           else if   rf-ocr-flg-puq       =    "K"
                     divide 1000          into d-qev-roc-qta-dev
                                        giving w-stp-srt-qta-dev      .
      *                          *-------------------------------------*
      *                          * Aggiornamento importo               *
      *                          *-------------------------------------*
           multiply  w-stp-srt-qta-dev    by   w-stp-srt-inp-prz
                                        giving w-stp-srt-inp-ipr      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     stp-srt-inp-ocr-650.
       stp-srt-inp-ocr-615.
      *                          *-------------------------------------*
      *                          * q.ta' da evadere x prezzo netto     *
      *                          *-------------------------------------*
           multiply  d-qev-roc-qta-dev    by   w-stp-srt-inp-prz
                                        giving w-stp-srt-inp-ipr      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     stp-srt-inp-ocr-650.
       stp-srt-inp-ocr-620.
      *                      *-----------------------------------------*
      *                      * Se solo ordini in spedizione            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se prezzo per quantita'        *
      *                          *-------------------------------------*
           if        rf-ocr-flg-puq       =    spaces
                     go to stp-srt-inp-ocr-625.
      *                          *-------------------------------------*
      *                          * Divisione                           *
      *                          *-------------------------------------*
           if        rf-ocr-flg-puq       =    "D"
                     divide 10            into d-qev-roc-qta-ics
                                        giving w-stp-srt-qta-dev
           else if   rf-ocr-flg-puq       =    "C"
                     divide 100           into d-qev-roc-qta-ics
                                        giving w-stp-srt-qta-dev
           else if   rf-ocr-flg-puq       =    "K"
                     divide 1000          into d-qev-roc-qta-ics
                                        giving w-stp-srt-qta-dev      .
      *                          *-------------------------------------*
      *                          * Aggiornamento importo               *
      *                          *-------------------------------------*
           multiply  w-stp-srt-qta-dev    by   w-stp-srt-inp-prz
                                        giving w-stp-srt-inp-ipr      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     stp-srt-inp-ocr-650.
       stp-srt-inp-ocr-625.
      *                          *-------------------------------------*
      *                          * q.ta' in spediz. x prezzo netto     *
      *                          *-------------------------------------*
           multiply  d-qev-roc-qta-ics    by   w-stp-srt-inp-prz
                                        giving w-stp-srt-inp-ipr      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     stp-srt-inp-ocr-650.
       stp-srt-inp-ocr-630.
      *                      *-----------------------------------------*
      *                      * Se solo ordini gia' evasi               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se prezzo per quantita'        *
      *                          *-------------------------------------*
           if        rf-ocr-flg-puq       =    spaces
                     go to stp-srt-inp-ocr-635.
      *                          *-------------------------------------*
      *                          * Divisione                           *
      *                          *-------------------------------------*
           if        rf-ocr-flg-puq       =    "D"
                     divide 10            into d-qev-roc-qta-gsp
                                        giving w-stp-srt-qta-dev
           else if   rf-ocr-flg-puq       =    "C"
                     divide 100           into d-qev-roc-qta-gsp
                                        giving w-stp-srt-qta-dev
           else if   rf-ocr-flg-puq       =    "K"
                     divide 1000          into d-qev-roc-qta-gsp
                                        giving w-stp-srt-qta-dev      .
      *                          *-------------------------------------*
      *                          * Aggiornamento importo               *
      *                          *-------------------------------------*
           multiply  w-stp-srt-qta-dev    by   w-stp-srt-inp-prz
                                        giving w-stp-srt-inp-ipr      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     stp-srt-inp-ocr-650.
       stp-srt-inp-ocr-635.
      *                          *-------------------------------------*
      *                          * q.ta' spedita x prezzo netto        *
      *                          *-------------------------------------*
           multiply  d-qev-roc-qta-gsp    by   w-stp-srt-inp-prz
                                        giving w-stp-srt-inp-ipr      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     stp-srt-inp-ocr-650.
       stp-srt-inp-ocr-640.
      *                      *-----------------------------------------*
      *                      * Se tutti gli ordini o se ultimo ordine  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se prezzo per quantita'        *
      *                          *-------------------------------------*
           if        rf-ocr-flg-puq       =    spaces
                     go to stp-srt-inp-ocr-645.
      *                          *-------------------------------------*
      *                          * Divisione                           *
      *                          *-------------------------------------*
           if        rf-ocr-flg-puq       =    "D"
                     divide 10            into d-qev-roc-qta-ord
                                        giving w-stp-srt-qta-dev
           else if   rf-ocr-flg-puq       =    "C"
                     divide 100           into d-qev-roc-qta-ord
                                        giving w-stp-srt-qta-dev
           else if   rf-ocr-flg-puq       =    "K"
                     divide 1000          into d-qev-roc-qta-ord
                                        giving w-stp-srt-qta-dev      .
      *                          *-------------------------------------*
      *                          * Aggiornamento importo               *
      *                          *-------------------------------------*
           multiply  w-stp-srt-qta-dev    by   w-stp-srt-inp-prz
                                        giving w-stp-srt-inp-ipr      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     stp-srt-inp-ocr-650.
       stp-srt-inp-ocr-645.
      *                          *-------------------------------------*
      *                          * q.ta' ordinata x prezzo netto       *
      *                          *-------------------------------------*
           multiply  d-qev-roc-qta-ord    by   w-stp-srt-inp-prz
                                        giving w-stp-srt-inp-ipr      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     stp-srt-inp-ocr-650.
       stp-srt-inp-ocr-650.
      *                  *---------------------------------------------*
      *                  * Altre operazioni                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Eventuale aggiustamento con decimali    *
      *                      * prezzo                                  *
      *                      *-----------------------------------------*
           if        rf-ocr-dec-prz       =    1
                     divide 10            into w-stp-srt-inp-ipr
           else if   rf-ocr-dec-prz       =    2
                     divide 100           into w-stp-srt-inp-ipr      .
      *                      *-----------------------------------------*
      *                      * Eventuale conversione nella valuta di   *
      *                      * fatturazione                            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se necessario                  *
      *                          *-------------------------------------*
           if        rf-ocr-sgl-vpp       =    rf-ocr-sgl-vpf
                     go to stp-srt-inp-ocr-700.
      *                          *-------------------------------------*
      *                          * Determinazione coefficiente di cam- *
      *                          * bio alla data attuale per la valu-  *
      *                          * ta per il prezzo                    *
      *                          *-------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      rf-ocr-sgl-vpp       to   w-coe-cmb-vlt-sdv      .
           move      rf-ocr-tdc-vpp       to   w-coe-cmb-vlt-tdc      .
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                          *-------------------------------------*
      *                          * Se esito determinazione negativo si *
      *                          * considera il coefficiente rilevato  *
      *                          * alla data ordine                    *
      *                          *-------------------------------------*
           if        w-coe-cmb-vlt-ope    not  = "CC"
                     move  rf-ocr-cdc-vpp to   w-coe-cmb-vlt-cdc      .
      *                          *-------------------------------------*
      *                          * Conversione importo da valuta per   *
      *                          * il prezzo a valuta base             *
      *                          *-------------------------------------*
           move      rf-ocr-sgl-vpp       to   w-cvs-vlt-sgl          .
           move      rf-ocr-dec-vpp       to   w-cvs-vlt-dec          .
           move      rf-ocr-tdc-vpp       to   w-cvs-vlt-tdc          .
           move      w-coe-cmb-vlt-cdc    to   w-cvs-vlt-cdc          .
           move      w-stp-srt-inp-ipr    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
      *                          *-------------------------------------*
      *                          * Determinazione coefficiente di cam- *
      *                          * bio alla data attuale per la valu-  *
      *                          * ta per fatturazione                 *
      *                          *-------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      rf-ocr-sgl-vpf       to   w-coe-cmb-vlt-sdv      .
           move      rf-ocr-tdc-vpf       to   w-coe-cmb-vlt-tdc      .
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                          *-------------------------------------*
      *                          * Se esito determinazione negativo si *
      *                          * considera il coefficiente rilevato  *
      *                          * alla data ordine                    *
      *                          *-------------------------------------*
           if        w-coe-cmb-vlt-ope    not  = "CC"
                     move  rf-ocr-cdc-vpf to   w-coe-cmb-vlt-cdc      .
      *                          *-------------------------------------*
      *                          * Conversione importo da valuta base  *
      *                          * a valuta per fatturazione           *
      *                          *-------------------------------------*
           move      rf-ocr-sgl-vpf       to   w-cvs-vlt-sgl          .
           move      rf-ocr-dec-vpf       to   w-cvs-vlt-dec          .
           move      rf-ocr-tdc-vpf       to   w-cvs-vlt-tdc          .
           move      w-coe-cmb-vlt-cdc    to   w-cvs-vlt-cdc          .
           perform   cvs-vlb-alt-000      thru cvs-vlb-alt-999        .
      *                          *-------------------------------------*
      *                          * Bufferizzazione del risultato       *
      *                          *-------------------------------------*
           move      w-cvs-vlt-aav        to   w-stp-srt-inp-ipr      .
       stp-srt-inp-ocr-700.
      *              *-------------------------------------------------*
      *              * Preparazione record di Sort                     *
      *              *-------------------------------------------------*
           perform   stp-srt-inp-cmp-000  thru stp-srt-inp-cmp-999    .
       stp-srt-inp-ocr-800.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale record [ocr]     *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-ocr-200.
       stp-srt-inp-ocr-900.
      *              *-------------------------------------------------*
