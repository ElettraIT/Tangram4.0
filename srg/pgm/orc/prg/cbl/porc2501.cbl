           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      12                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      112                  to   p-pos                  .
           move      "============"       to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       prn-fin-lr3-120.
      *                  *---------------------------------------------*
      *                  * Totale cliente                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Interlinea                              *
      *                      *-----------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Richiamo routine per stampa valori      *
      *                      *-----------------------------------------*
           move      "Totale cliente    " to   w-stp-val-tot-pmt      .
           if        w-tot-cli-vpf        =    spaces
                     move  c-sgl          to   w-stp-val-tot-vlt
           else      move  w-tot-cli-vpf  to   w-stp-val-tot-vlt
                     move  w-tot-cli-dpf  to   w-stp-val-tot-dcv      .
           move      w-tot-cli-tot        to   w-stp-val-tot-tot      .
           move      w-tot-cli-tiv        to   w-stp-val-tot-tiv      .
           perform   stp-val-tot-000      thru stp-val-tot-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione % di variazione valore   *
