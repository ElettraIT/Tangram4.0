       prn-fin-lr3-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
       prn-fin-lr3-010.
      *              *-------------------------------------------------*
      *              * Stampa totale cliente                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se differenza tra totali cliente in    *
      *                  * termini di valore inevaso                   *
      *                  *---------------------------------------------*
           if        w-tot-cli-tvi        not  = w-tot-cli-tvo
                     go to prn-fin-lr3-050.
      *                  *---------------------------------------------*
      *                  * Test se da stampare                         *
      *                  *---------------------------------------------*
           if        rr-sts-orc           =    05
                     go to prn-fin-lr3-999.
           if        w-tot-cli-tot        =    zero
                     go to prn-fin-lr3-999.
           if        w-tot-cli-vpf        not  = c-sgl
                     go to prn-fin-lr3-050.
           if        w-tot-cli-ord        not  > 1
                     go to prn-fin-lr3-999.
       prn-fin-lr3-050.
      *                  *---------------------------------------------*
