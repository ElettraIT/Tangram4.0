      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "RIFORC    "         to   f-key                  .
           move      rr-dpz-inu           to   rf-bir-cod-dpz         .
           move      srt-num-prt          to   rf-bir-coc-prt         .
           move      srt-num-prg          to   rf-bir-coc-prg         .
           move      zero                 to   rf-bir-num-prt         .
           move      zero                 to   rf-bir-num-prg         .
           move      "pgm/bol/fls/ioc/obj/iofbir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bir                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to prn-liv-det-bir-900.
       prn-liv-det-bir-200.
      *              *-------------------------------------------------*
      *              * Read Next su [bir]                              *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofbir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bir                 .
      *                  *---------------------------------------------*
      *                  * Se At end : uscita                          *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to prn-liv-det-bir-900.
       prn-liv-det-bir-300.
      *              *-------------------------------------------------*
      *              * Test Max su [bir]                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su :                                   *
      *                  *    - Codice dipendenza                      *
      *                  *    - Numero protocollo ordine cliente       *
      *                  *    - Numero riga ordine cliente             *
      *                  *---------------------------------------------*
           if        rf-bir-cod-dpz       =    rr-dpz-inu  and
                     rf-bir-coc-prt       =    srt-num-prt and
                     rf-bir-coc-prg       =    srt-num-prg
                     go to prn-liv-det-bir-400.
      *                  *---------------------------------------------*
      *                  * Se oltre il Max : uscita                    *
      *                  *---------------------------------------------*
           go to     prn-liv-det-bir-900.
