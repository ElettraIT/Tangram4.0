           copy      "pgm/dcp/prg/cpy/ldcppdx0.lts"                   .

      *    *===========================================================*
      *    * Stampa modulo in PostScript                               *
      *    *-----------------------------------------------------------*
       exe-000.
      *              *-------------------------------------------------*
      *              * Determinazione numero posizioni presenti        *
      *              *-------------------------------------------------*
           move      501                  to   w-fdl-dps-pos-tot      .
       exe-050.
           subtract  1                    from w-fdl-dps-pos-tot      .
           if        w-fdl-dps-pos-tot    =    zero
                     go to exe-100.
           if        w-fdl-pos-xxx
                    (w-fdl-dps-pos-tot)   =    spaces
                     go to exe-050.
       exe-075.
           if        w-fdl-pos-des-pos
                    (w-fdl-dps-pos-tot)   =    spaces
                     go to exe-100.
           if        w-fdl-dps-pos-tot    <    500
                     add   1              to   w-fdl-dps-pos-tot      .
       exe-100.
      *              *-------------------------------------------------*
      *              * Se zero posizioni : uscita immediata            *
      *              *-------------------------------------------------*
           if        w-fdl-dps-pos-tot    =    zero
                     go to exe-900.
       exe-150.
      *              *-------------------------------------------------*
      *              * Inizializzazione numero pagina attuale          *
      *              *-------------------------------------------------*
           move      zero                 to   w-fdl-dps-num-pag      .
      *              *-------------------------------------------------*
      *              * Calcolo numero pagine totali                    *
      *              *-------------------------------------------------*
           move      w-fdl-dps-pos-tot    to   w-fdl-dps-quo-div      .
           divide    16                   into w-fdl-dps-quo-div
                                     remainder w-fdl-dps-pag-tot      .
           if        w-fdl-dps-pag-tot    >    zero
                     move  1              to   w-fdl-dps-pag-tot      .
           add       w-fdl-dps-quo-div    to   w-fdl-dps-pag-tot      .
       exe-200.
      *              *-------------------------------------------------*
      *              * Inizializzazione job di stampa                  *
      *              *-------------------------------------------------*
           perform   exe-ini-000          thru exe-ini-999            .
      *              *-------------------------------------------------*
      *              * Inizializzazione indice su numero posizione at- *
      *              * tuale                                           *
      *              *-------------------------------------------------*
           move      zero                 to   w-fdl-dps-num-pos      .
       exe-300.
      *              *-------------------------------------------------*
      *              * Incremento indice su numero posizione attuale   *
      *              *-------------------------------------------------*
           add       1                    to   w-fdl-dps-num-pos      .
      *              *-------------------------------------------------*
      *              * Se oltre il numero totale di posizioni presen-  *
      *              * ti : a fine pagina e terminazione job di stampa *
      *              *-------------------------------------------------*
           if        w-fdl-dps-num-pos    >    w-fdl-dps-pos-tot
                     go to exe-600.
      *              *-------------------------------------------------*
      *              * Calcolo del numero posizione relativo al fo-    *
      *              * glio                                            *
      *              *-------------------------------------------------*
           move      w-fdl-dps-num-pos    to   w-fdl-dps-quo-div      .
           divide    16                   into w-fdl-dps-quo-div
                                     remainder w-fdl-dps-num-rel      .
           if        w-fdl-dps-num-rel    =    zero
                     move  16             to   w-fdl-dps-num-rel      .
      *              *-------------------------------------------------*
      *              * Se numero posizione relativo diverso da 1 si    *
      *              * tralasciano le azioni di inizio pagina          *
      *              *-------------------------------------------------*
           if        w-fdl-dps-num-rel    >    1
                     go to exe-400.
      *              *-------------------------------------------------*
      *              * Incremento numero pagina                        *
      *              *-------------------------------------------------*
           add       1                    to   w-fdl-dps-num-pag      .
      *              *-------------------------------------------------*
      *              * Se numero pagina pari a 1 non si esegue il      *
      *              * fine pagina precedente                          *
      *              *-------------------------------------------------*
           if        w-fdl-dps-num-pag    =    1
                     go to exe-350.
      *              *-------------------------------------------------*
      *              * PageEnd                                         *
      *              *-------------------------------------------------*
           move      "PageEnd"
                                          to   ps-tip-ope             .
           call      "swd/mod/prg/obj/mposts"
                                         using ps                     .
       exe-350.
      *              *-------------------------------------------------*
      *              * PageStart                                       *
      *              *-------------------------------------------------*
           move      "PageStart"
                                          to   ps-tip-ope             .
           call      "swd/mod/prg/obj/mposts"
                                         using ps                     .
      *              *-------------------------------------------------*
      *              * Disegna modulo                                  *
      *              *-------------------------------------------------*
           perform   exe-dis-mod-000      thru exe-dis-mod-999        .
      *              *-------------------------------------------------*
      *              * Intestazione modulo                             *
      *              *-------------------------------------------------*
           perform   exe-int-mod-000      thru exe-int-mod-999        .
       exe-400.
      *              *-------------------------------------------------*
      *              * Stampa posizione                                *
      *              *-------------------------------------------------*
           perform   exe-stp-pos-000      thru exe-stp-pos-999        .
       exe-450.
      *              *-------------------------------------------------*
      *              * Riciclo per posizione successiva                *
      *              *-------------------------------------------------*
           go to     exe-300.
       exe-600.
      *              *-------------------------------------------------*
      *              * PageEnd                                         *
      *              *-------------------------------------------------*
           move      "PageEnd"
                                          to   ps-tip-ope             .
           call      "swd/mod/prg/obj/mposts"
                                         using ps                     .
      *              *-------------------------------------------------*
      *              * Terminazione job                                *
      *              *-------------------------------------------------*
           perform   exe-ter-000          thru exe-ter-999            .
      *              *-------------------------------------------------*
      *              * Cancellazione modulo 'mposts'                   *
      *              *-------------------------------------------------*
           cancel    "swd/mod/prg/obj/mposts"                         .
       exe-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-999.
       exe-999.
           exit.

