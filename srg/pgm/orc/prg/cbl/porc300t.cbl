                     go to det-des-rig-100
           else if   rf-ocr-des-ext       =    1
                     go to det-des-rig-300
           else if   rf-ocr-des-ext       =    2
                     go to det-des-rig-600.
       det-des-rig-100.
      *              *-------------------------------------------------*
      *              * Se nessuna estensione                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Descrizione contenuta in record [ocr]       *
      *                  *---------------------------------------------*
           move      rf-ocr-des-rig       to   w-pre-cor-doc-der      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-des-rig-900.
       det-des-rig-300.
      *              *-------------------------------------------------*
      *              * Se estensione in file [ocx]                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura file [ocx]                          *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-inp-sfl-prt        to   rf-ocx-num-prt         .
           move      rf-ocr-num-prg       to   rf-ocx-num-prg         .
           move      11                   to   rf-ocx-tip-rec         .
           move      "pgm/orc/fls/ioc/obj/iofocx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocx                 .
           if        f-sts                =    e-not-err
                     move  rf-ocx-des-400 to   w-pre-cor-doc-der
           else      move  spaces         to   w-pre-cor-doc-der      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-des-rig-900.
       det-des-rig-600.
      *              *-------------------------------------------------*
      *              * Se estensione in file [pdx]                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dcp]                      *
      *                  *---------------------------------------------*
           move      rf-ocr-num-pro       to   w-let-dcp-pdx-cod      .
           move      rf-oct-tip-arc       to   w-let-dcp-pdx-tar      .
           if        rf-oct-tip-frn       =    11
                     move  rf-oct-cod-arc to   w-let-dcp-pdx-arc
           else      move  rf-oct-arc-plf to   w-let-dcp-pdx-arc      .
           move      rf-ocr-cod-lng       to   w-let-dcp-pdx-lng      .
           perform   let-dcp-pdx-000      thru let-dcp-pdx-999        .
           move      w-let-dcp-pdx-des    to   w-pre-cor-doc-der      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-des-rig-900.
       det-des-rig-900.
      *              *-------------------------------------------------*
      *              * Eventuale integrazione con righe aggiuntive per *
      *              * il codice prodotto                              *
      *              *-------------------------------------------------*
           perform   det-des-rig-rac-000  thru det-des-rig-rac-999    .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-des-rig-999.
       det-des-rig-999.
           exit.

      *    *===========================================================*
      *    * Determinazione descrizione per la riga                    *
      *    *                                                           *
      *    * Subroutine per l'eventuale integrazione con righe ag-     *
      *    * giuntive per il codice prodotto                           *
      *    *-----------------------------------------------------------*
       det-des-rig-rac-000.
      *              *-------------------------------------------------*
      *              * Scansione delle righe di descrizione per otte-  *
      *              * nere il posizionamento della prima riga libera  *
      *              * da utilizzare per la stampa dei codici          *
      *              *-------------------------------------------------*
           move      11                   to   w-pre-cor-doc-c01      .
       det-des-rig-rac-010.
           subtract  1                    from w-pre-cor-doc-c01      .
           if        w-pre-cor-doc-c01    =    zero
                     go to det-des-rig-rac-011.
           if        w-pre-cor-doc-rgd
                    (w-pre-cor-doc-c01)   =    spaces
                     go to det-des-rig-rac-010.
       det-des-rig-rac-011.
           move      w-pre-cor-doc-c01    to   w-pre-cor-doc-c02      .
      *              *-------------------------------------------------*
      *              * Deviazione in funzione della relativa persona-  *
      *              * lizzazione                                      *
      *              *-------------------------------------------------*
           if        w-prs-soc-rac        =    "N"
                     go to det-des-rig-rac-100
           else if   w-prs-soc-rac        =    "C" or
                     w-prs-soc-rac        =    "E"
                     go to det-des-rig-rac-200
           else if   w-prs-soc-rac        =    "M"
                     go to det-des-rig-rac-300
           else      go to det-des-rig-rac-100.
       det-des-rig-rac-100.
      *              *-------------------------------------------------*
      *              * Nessuna riga aggiuntiva                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     det-des-rig-rac-900.
       det-des-rig-rac-200.
      *              *-------------------------------------------------*
      *              * Una riga aggiuntiva con il codice del cliente   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test preliminari                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se codice del cliente a spaces : a test *
      *                      * se altra riga contenente in ns. codice  *
      *                      *-----------------------------------------*
           if        rf-ocr-cop-scl       =    spaces
                     go to det-des-rig-rac-290.
      *                      *-----------------------------------------*
      *                      * Incremento del contatore                *
      *                      *-----------------------------------------*
           add       1                    to   w-pre-cor-doc-c02      .
      *                      *-----------------------------------------*
      *                      * Composizione riga aggiuntiva            *
      *                      *-----------------------------------------*
           move      spaces               to   w-pre-cor-doc-rgd
                                              (w-pre-cor-doc-c02)     .
           string    "  - Vs. codice : "
                                delimited by   size
                     rf-ocr-cop-scl
                                delimited by   size
                                          into w-pre-cor-doc-rgd
                                              (w-pre-cor-doc-c02)     .
       det-des-rig-rac-290.
      *                  *---------------------------------------------*
      *                  * Test se altra riga aggiuntiva con il nostro *
      *                  * codice                                      *
      *                  *---------------------------------------------*
           if        w-prs-soc-rac        =    "E"
                     go to det-des-rig-rac-300.
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     det-des-rig-rac-900.
       det-des-rig-rac-300.
      *              *-------------------------------------------------*
      *              * Una riga aggiuntiva con il codice nostro        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test preliminari                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se nostro codice a spaces : ad uscita   *
      *                      *-----------------------------------------*
           if        rf-ocr-alf-pro       =    spaces
                     go to det-des-rig-rac-900.
      *                      *-----------------------------------------*
      *                      * Incremento del contatore                *
      *                      *-----------------------------------------*
           add       1                    to   w-pre-cor-doc-c02      .
      *                      *-----------------------------------------*
      *                      * Composizione riga aggiuntiva            *
      *                      *-----------------------------------------*
           move      spaces               to   w-pre-cor-doc-rgd
                                              (w-pre-cor-doc-c02)     .
           string    "  - Ns. codice : "
                                delimited by   size
                     rf-ocr-alf-pro
                                delimited by   size
                                          into w-pre-cor-doc-rgd
                                              (w-pre-cor-doc-c02)     .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     det-des-rig-rac-900.
       det-des-rig-rac-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-des-rig-rac-999.
       det-des-rig-rac-999.
           exit.

