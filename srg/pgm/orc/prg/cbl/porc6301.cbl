           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *              *-------------------------------------------------*
      *              * [pdx]                                           *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
      *              *-------------------------------------------------*
      *              * Close modulo accettazione coefficiente di cam-  *
      *              * bio valuta                                      *
      *              *-------------------------------------------------*
           perform   coe-cmb-vlt-cls-000  thru coe-cmb-vlt-cls-999    .
       prn-cls-fls-800.
      *              *-------------------------------------------------*
      *              * Close modulo di determinazione quantita' da e-  *
      *              * vadere riga ordine                              *
      *              *-------------------------------------------------*
           perform   det-qev-roc-cls-000  thru det-qev-roc-cls-999    .
       prn-cls-fls-820.
      *              *-------------------------------------------------*
      *              * Close modulo di determinazione saldo di magazz. *
      *              *-------------------------------------------------*
           perform   det-sld-mag-cls-000  thru det-sld-mag-cls-999    .
       prn-cls-fls-999.
           exit.

      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Start su file [ocr]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "RCHARC    "         to   f-key                  .
           move      rr-dpz-inu           to   rf-ocr-cod-dpz         .
           move      spaces               to   rf-ocr-flg-rch         .
           move      "C"                  to   rf-ocr-tip-arc         .
           move      rr-cod-cli           to   rf-ocr-cod-arc         .
           move      zero                 to   rf-ocr-num-prt         .
           move      zero                 to   rf-ocr-num-prg         .
           move      "pgm/orc/fls/ioc/obj/iofocr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [ocr]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofocr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocr                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-110.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
       stp-srt-inp-120.
      *                  *---------------------------------------------*
      *                  * Test su codice dipendenza                   *
      *                  *---------------------------------------------*
           if        rf-ocr-cod-dpz       not  = rr-dpz-inu
                     go to stp-srt-inp-999.
       stp-srt-inp-125.
      *                  *---------------------------------------------*
      *                  * Test su flag di riga ordine chiusa          *
      *                  *---------------------------------------------*
           if        rf-ocr-flg-rch       not  = spaces
                     go to stp-srt-inp-999.
       stp-srt-inp-130.
      *                  *---------------------------------------------*
      *                  * Test su tipo e codice archivio              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo archivio                   *
      *                      *-----------------------------------------*
           if        rf-ocr-tip-arc       not  = "C"
                     go to stp-srt-inp-999.
      *                      *-----------------------------------------*
      *                      * Test su codice archivio                 *
      *                      *-----------------------------------------*
           if        rr-cod-cli           not  = zero   and
                     rf-ocr-cod-arc       not  = rr-cod-cli
                     go to stp-srt-inp-999.
       stp-srt-inp-140.
      *              *-------------------------------------------------*
      *              * Selezione sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Selezione su tipi ordine                    *
      *                  *                                             *
      *                  * Solo ordini normali                         *
      *                  *---------------------------------------------*
           if        rf-ocr-tip-ord       not  = spaces
                     go to stp-srt-inp-100.
      *                  *---------------------------------------------*
      *                  * Selezione su codice dipendenza del cliente  *
      *                  *---------------------------------------------*
           if        rr-cod-cli           =    zero
                     go to stp-srt-inp-142.
           if        rr-dpz-cli           =    "*    "
                     go to stp-srt-inp-142.
           if        rf-ocr-dpz-arc       not  = rr-dpz-cli
                     go to stp-srt-inp-100.
       stp-srt-inp-142.
      *                  *---------------------------------------------*
      *                  * Selezione su data emissione minima          *
      *                  *---------------------------------------------*
           if        rf-ocr-dat-doc       <    rr-dem-min
                     go to stp-srt-inp-100.
      *                  *---------------------------------------------*
      *                  * Selezione su data emissione massima         *
      *                  *---------------------------------------------*
           if        rf-ocr-dat-doc       >    rr-dem-max
                     go to stp-srt-inp-100.
      *                  *---------------------------------------------*
      *                  * Selezione su data consegna richiesta max    *
      *                  *---------------------------------------------*
           if        rr-dcn-ric           =    zero
                     go to stp-srt-inp-150.
           if        rf-ocr-dcn-ric       >    rr-dcn-ric
                     go to stp-srt-inp-100.
       stp-srt-inp-150.
      *                  *---------------------------------------------*
      *                  * Selezione su tipo riga                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Tipo riga in comodo ridefinito          *
      *                      *-----------------------------------------*
           move      rf-ocr-tip-rig       to   w-stp-srt-inp-wtr      .
      *                      *-----------------------------------------*
      *                      * Se tipo riga 'C' o 'A' : riciclo        *
      *                      *-----------------------------------------*
           if        w-stp-srt-inp-wtp    =    "C" or
                     w-stp-srt-inp-wtp    =    "A"
                     go to stp-srt-inp-100.
       stp-srt-inp-220.
      *                  *---------------------------------------------*
      *                  * Selezione sulla quantita' ancora da evadere *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione quantita' evasa riga or- *
      *                      * dine cliente                            *
      *                      *-----------------------------------------*
           move      "DT"                 to   d-qev-roc-tip-ope      .
           perform   det-qev-roc-cll-000  thru det-qev-roc-cll-999    .
      *                          *-------------------------------------*
      *                          * Se quantita' ancora da evadere a    *
      *                          * zero : riciclo                      *
      *                          *-------------------------------------*
           if        d-qev-roc-qta-dev    =    zero
                     go to stp-srt-inp-100.
       stp-srt-inp-230.
      *                  *---------------------------------------------*
      *                  * Selezione sulla quantita' assegnata         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione quantita' assegnata     *
      *                      *-----------------------------------------*
           move      zero                 to   w-stp-srt-inp-qta      .
      *                      *-----------------------------------------*
      *                      * Normalizzazione data assegnazione       *
      *                      *-----------------------------------------*
           move      zero                 to   w-stp-srt-inp-dat      .
      *                      *-----------------------------------------*
      *                      * Lettura record [ocp]                    *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-ocr-num-prt       to   rf-ocp-num-prt         .
           move      rf-ocr-num-prg       to   rf-ocp-num-prg         .
           move      001                  to   rf-ocp-prg-frm         .
           move      "pgm/orc/fls/ioc/obj/iofocp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ocp                 .
      *                      *-----------------------------------------*
      *                      * Test su esito operazione                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-240.
      *                      *-----------------------------------------*
      *                      * Test se assegnazione alla giacenza      *
      *                      *-----------------------------------------*
           if        rf-ocp-dat-ass       not  = zero
                     go to stp-srt-inp-240.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione quantita' assegnata     *
      *                      *-----------------------------------------*
           move      rf-ocp-qta-ass       to   w-stp-srt-inp-qta      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione data assegnazione       *
      *                      *-----------------------------------------*
           move      rf-ocp-dat-ass       to   w-stp-srt-inp-dat      .
       stp-srt-inp-240.
      *                      *-----------------------------------------*
      *                      * Test sulla quantita' assegnata          *
      *                      *-----------------------------------------*
           if        rr-sts-ass           not  = 01
                     go to stp-srt-inp-260.
           if        w-stp-srt-inp-qta    =    zero
                     go to stp-srt-inp-100.
       stp-srt-inp-260.
      *              *-------------------------------------------------*
      *              * Fine selezioni sul record                       *
      *              *-------------------------------------------------*
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Raccolta dati cliente                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [dcc]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
      *                  *---------------------------------------------*
      *                  * Lettura record [dcc]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLI    "         to   f-key                  .
           move      rf-ocr-cod-arc       to   rf-dcc-cod-cli         .
           move      rf-ocr-dpz-arc       to   rf-dcc-dpz-cli         .
           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
           if        f-sts                not  = e-not-err
                     move  all "."        to   rf-dcc-rag-soc         .
       stp-srt-inp-310.
      *              *-------------------------------------------------*
      *              * Determinazione descrizione riga ordine          *
      *              *-------------------------------------------------*
           perform   det-des-rig-000      thru det-des-rig-999        .
       stp-srt-inp-315.
      *              *-------------------------------------------------*
      *              * Determinazione prezzo unitario                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se tipo riga 'A' : oltre                    *
      *                  *---------------------------------------------*
           if        w-stp-srt-inp-wtp    =    "A"
                     move  zero           to   w-stp-srt-inp-prz
                     go to stp-srt-inp-320.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione prezzo netto contenuto nel  *
      *                  * record                                      *
      *                  *---------------------------------------------*
           move      rf-ocr-prz-net       to   w-stp-srt-inp-prz      .
       stp-srt-inp-320.
      *              *-------------------------------------------------*
      *              * Determinazione importo residuo nella valuta di  *
      *              * fatturazione                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se tipo riga 'A'                            *
      *                  *---------------------------------------------*
           if        w-stp-srt-inp-wtp    =    "A"
                     move  rf-ocr-imp-rig to   w-stp-srt-inp-ipr
                     go to stp-srt-inp-340.
      *                  *---------------------------------------------*
      *                  * Se altro tipo riga                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione dello stato de-  *
      *                      * gli ordini richiesto                    *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-321
                     stp-srt-inp-322
                     stp-srt-inp-323
                     stp-srt-inp-324
                     depending            on   rr-sts-ass             .
       stp-srt-inp-321.
      *                      *-----------------------------------------*
      *                      * Se solo ordini da evadere               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * (q.ta' da evadere x prezzo netto)   *
      *                          *-------------------------------------*
           multiply  d-qev-roc-qta-dev    by   w-stp-srt-inp-prz
                                        giving w-stp-srt-inp-ipr      .
           go to     stp-srt-inp-330.
       stp-srt-inp-322.
      *                      *-----------------------------------------*
      *                      * Se solo ordini in spedizione            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * (q.ta' in spediz. x prezzo netto)   *
      *                          *-------------------------------------*
           multiply  d-qev-roc-qta-ics    by   w-stp-srt-inp-prz
                                        giving w-stp-srt-inp-ipr      .
           go to     stp-srt-inp-330.
       stp-srt-inp-323.
      *                      *-----------------------------------------*
      *                      * Se solo ordini gia' evasi               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * (q.ta' spedita x prezzo netto)      *
      *                          *-------------------------------------*
           multiply  d-qev-roc-qta-gsp    by   w-stp-srt-inp-prz
                                        giving w-stp-srt-inp-ipr      .
           go to     stp-srt-inp-330.
       stp-srt-inp-324.
      *                      *-----------------------------------------*
      *                      * Se tutti gli ordini                     *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * (q.ta' ordinata x prezzo netto)     *
      *                          *-------------------------------------*
           multiply  d-qev-roc-qta-ord    by   w-stp-srt-inp-prz
                                        giving w-stp-srt-inp-ipr      .
           go to     stp-srt-inp-330.
       stp-srt-inp-330.
      *                      *-----------------------------------------*
      *                      * Eventuale aggiustamento con decimali    *
      *                      * prezzo                                  *
      *                      *-----------------------------------------*
           if        rf-ocr-dec-prz       =    1
                     divide 10            into w-stp-srt-inp-ipr
           else if   rf-ocr-dec-prz       =    2
                     divide 100           into w-stp-srt-inp-ipr      .
      *                      *-----------------------------------------*
      *                      * Eventuale conversione nella valuta di   *
      *                      * fatturazione                            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se necessario                  *
      *                          *-------------------------------------*
           if        rf-ocr-sgl-vpp       =    rf-ocr-sgl-vpf
                     go to stp-srt-inp-340.
      *                          *-------------------------------------*
      *                          * Determinazione coefficiente di cam- *
      *                          * bio alla data attuale per la valu-  *
      *                          * ta per il prezzo                    *
      *                          *-------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      rf-ocr-sgl-vpp       to   w-coe-cmb-vlt-sdv      .
           move      rf-ocr-tdc-vpp       to   w-coe-cmb-vlt-tdc      .
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                          *-------------------------------------*
      *                          * Se esito determinazione negativo si *
      *                          * considera il coefficiente rilevato  *
      *                          * alla data ordine                    *
      *                          *-------------------------------------*
           if        w-coe-cmb-vlt-ope    not  = "CC"
                     move  rf-ocr-cdc-vpp to   w-coe-cmb-vlt-cdc      .
      *                          *-------------------------------------*
      *                          * Conversione importo da valuta per   *
      *                          * il prezzo a valuta base             *
      *                          *-------------------------------------*
           move      rf-ocr-sgl-vpp       to   w-cvs-vlt-sgl          .
           move      rf-ocr-dec-vpp       to   w-cvs-vlt-dec          .
           move      rf-ocr-tdc-vpp       to   w-cvs-vlt-tdc          .
           move      w-coe-cmb-vlt-cdc    to   w-cvs-vlt-cdc          .
           move      w-stp-srt-inp-ipr    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
      *                          *-------------------------------------*
      *                          * Determinazione coefficiente di cam- *
      *                          * bio alla data attuale per la valu-  *
      *                          * ta per fatturazione                 *
      *                          *-------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      rf-ocr-sgl-vpf       to   w-coe-cmb-vlt-sdv      .
           move      rf-ocr-tdc-vpf       to   w-coe-cmb-vlt-tdc      .
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                          *-------------------------------------*
      *                          * Se esito determinazione negativo si *
      *                          * considera il coefficiente rilevato  *
      *                          * alla data ordine                    *
      *                          *-------------------------------------*
           if        w-coe-cmb-vlt-ope    not  = "CC"
                     move  rf-ocr-cdc-vpf to   w-coe-cmb-vlt-cdc      .
      *                          *-------------------------------------*
      *                          * Conversione importo da valuta base  *
      *                          * a valuta per fatturazione           *
      *                          *-------------------------------------*
           move      rf-ocr-sgl-vpf       to   w-cvs-vlt-sgl          .
           move      rf-ocr-dec-vpf       to   w-cvs-vlt-dec          .
           move      rf-ocr-tdc-vpf       to   w-cvs-vlt-tdc          .
           move      w-coe-cmb-vlt-cdc    to   w-cvs-vlt-cdc          .
           perform   cvs-vlb-alt-000      thru cvs-vlb-alt-999        .
      *                          *-------------------------------------*
      *                          * Bufferizzazione del risultato       *
      *                          *-------------------------------------*
           move      w-cvs-vlt-aav        to   w-stp-srt-inp-ipr      .
       stp-srt-inp-340.
      *              *-------------------------------------------------*
      *              * Preparazione record di Sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione iniziale                    *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Chiave di sort                              *
      *                  *---------------------------------------------*
           move      rf-dcc-rag-key       to   srt-rag-key            .
           move      rf-ocr-cod-arc       to   srt-cod-cli            .
           move      rf-ocr-dpz-arc       to   srt-dpz-cli            .
           move      rf-ocr-dat-doc       to   srt-dat-doc            .
           move      rf-ocr-num-doc       to   srt-num-doc            .
           move      rf-ocr-num-prt       to   srt-num-prt            .
           move      rf-ocr-num-prg       to   srt-num-prg            .
      *                  *---------------------------------------------*
      *                  * Dati di sort                                *
      *                  *---------------------------------------------*
           move      rf-ocr-sgl-vpf       to   srt-sgl-vpf            .
           move      rf-ocr-dec-vpf       to   srt-dec-vpf            .
           move      rf-ocr-tdc-vpf       to   srt-tdc-vpf            .
           move      rf-ocr-cdc-vpf       to   srt-cdc-vpf            .
           move      rf-dcc-rag-soc       to   srt-rag-soc            .
           move      rf-ocr-ocl-dat       to   srt-ocl-dat            .
           move      rf-ocr-ocl-num       to   srt-ocl-num            .
           move      rf-ocr-dcn-ric       to   srt-dcn-ric            .
           move      rf-ocr-dcn-prv       to   srt-dcn-prv            .
           move      rf-ocr-flg-cnf       to   srt-flg-cnf            .
           move      rf-ocr-num-pro       to   srt-num-pro            .
           move      rf-ocr-alf-pro       to   srt-alf-pro            .
           if        w-stp-srt-inp-wtf    =    "N"
                     move  zero           to   srt-num-pro
                     move  spaces         to   srt-alf-pro            .
           move      w-det-des-rig-des    to   srt-des-rig            .
           move      rf-ocr-tmo-orc       to   srt-tip-mov            .
           move      rf-ocr-sgl-vpp       to   srt-sgl-vpp            .
           move      rf-ocr-dec-vpp       to   srt-dec-vpp            .
           move      rf-ocr-dec-prz       to   srt-dec-prz            .
           move      w-stp-srt-inp-prz    to   srt-prz-net            .
           move      w-stp-srt-inp-ipr    to   srt-imp-res            .
           move      d-qev-roc-qta-ord    to   srt-qta-ord            .
           move      d-qev-roc-qta-gsp    to   srt-qta-gsp            .
           move      d-qev-roc-qta-ics    to   srt-qta-ics            .
           move      d-qev-roc-qta-dev    to   srt-qta-dev            .
           move      w-stp-srt-inp-qta    to   srt-qta-ass            .
           move      w-stp-srt-inp-dat    to   srt-dat-ass            .
      *                      *-----------------------------------------*
      *                      * Se riga di addebito : normalizzazione   *
      *                      *-----------------------------------------*
           if        w-stp-srt-inp-wtp    =    "A"
                     move  zero           to   srt-qta-ord
                     move  zero           to   srt-qta-gsp
                     move  zero           to   srt-qta-ics
                     move  zero           to   srt-qta-dev
                     move  zero           to   srt-qta-ass
                     move  spaces         to   srt-sgl-vpl
                     move  zero           to   srt-dec-vpl
                     move  spaces         to   srt-tdc-vpl
                     move  zero           to   srt-prz-vpl
                     move  zero           to   srt-cdc-vpl
                     move  zero           to   srt-ccr-vpl
                     move  zero           to   srt-plm-vpl
                     move  spaces         to   srt-tlm-vpl
                     move  spaces         to   srt-map-vpl
                     go to stp-srt-inp-380.
      *                      *-----------------------------------------*
      *                      * Legame valutario                        *
      *                      *-----------------------------------------*
           move      rf-ocr-sgl-vpl       to   srt-sgl-vpl            .
           move      rf-ocr-dec-vpl       to   srt-dec-vpl            .
           move      rf-ocr-tdc-vpl       to   srt-tdc-vpl            .
           move      rf-ocr-prz-vpl       to   srt-prz-vpl            .
