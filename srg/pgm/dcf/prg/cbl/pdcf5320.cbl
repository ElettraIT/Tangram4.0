      *              *-------------------------------------------------*
       acc-prz-pes-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-prz-pes-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-prz-pes-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-prz-pes-100.
       acc-prz-pes-999.
           exit.

