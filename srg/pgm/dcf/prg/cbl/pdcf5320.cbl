      *    *===========================================================*
      *    * Accettazione : Percentuali di sconto                      *
      *    *-----------------------------------------------------------*
       acc-per-sco-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-per-sco-025.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se numero decimali valuta incongruente  *
      *                      * : uscita                                *
      *                      *-----------------------------------------*
           if        w-rig-dec-vlt        not  = w-tes-sgl-vlt-dec
                     go to acc-per-sco-999.
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore 01..05           *
      *                  *---------------------------------------------*
           move      01                   to   w-cix-ctr-001          .
       acc-per-sco-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      w-lin-pri-lin-vid    to   v-lin                  .
           add       w-lin-num-lin-vis    to   v-lin                  .
           add       4                    to   v-lin                  .
           move      w-cix-ctr-001        to   v-pos                  .
           if        w-cix-ctr-001        >    5
                     subtract  5          from v-pos                  .
           multiply  05                   by   v-pos                  .
           add       16                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "TAB "               to   v-pfk (10)             .
           move      w-rig-per-sco
                    (w-cix-ctr-001)       to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-per-sco-999.
       acc-per-sco-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-rig-per-sco
                                              (w-cix-ctr-001)         .
       acc-per-sco-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-per-sco-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-per-sco-650
           else if   v-key                =    "DOWN"
                     go to acc-per-sco-670
           else if   v-key                =    "TAB "
                     go to acc-per-sco-700
           else if   v-key                =    "DO  "
                     go to acc-per-sco-800
           else      go to acc-per-sco-670.
       acc-per-sco-650.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        w-cix-ctr-001        =    1
                     go to acc-per-sco-999.
           subtract  1                    from w-cix-ctr-001          .
           go to     acc-per-sco-100.
       acc-per-sco-670.
      *              *-------------------------------------------------*
      *              * Se Down o Return                                *
      *              *-------------------------------------------------*
           go to     acc-per-sco-999.
       acc-per-sco-700.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        w-cix-ctr-001        =    05
                     go to acc-per-sco-999.
      *                  *---------------------------------------------*
      *                  * Incremento contatore                        *
      *                  *---------------------------------------------*
           add       1                    to   w-cix-ctr-001          .
      *                  *---------------------------------------------*
      *                  * Ad accettazione                             *
      *                  *---------------------------------------------*
           go to     acc-per-sco-100.
       acc-per-sco-710.
      *              *-------------------------------------------------*
      *              * Se Return                                       *
      *              *-------------------------------------------------*
           if        w-cix-ctr-001        =    05
                     go to acc-per-sco-999.
      *                  *---------------------------------------------*
      *                  * Incremento contatore                        *
      *                  *---------------------------------------------*
           add       1                    to   w-cix-ctr-001          .
           go to     acc-per-sco-100.
       acc-per-sco-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-rig-000
                                          thru cnt-tdo-rig-999
                     if      w-cnt-tdo-rig-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-per-sco-999
                     else    move  spaces to   w-cnt-tdo-rig-flg
                             go to acc-per-sco-100.
       acc-per-sco-999.
           exit.

