      *                  * alcuna azione                               *
      *                  *---------------------------------------------*
           move      zero                 to   w-srt-buf-tst-inx      .
       ril-rec-tst-321.
           add       1                    to   w-srt-buf-tst-inx      .
           if        w-srt-buf-tst-inx    >    8192
                     go to ril-rec-tst-999.
           if        w-srt-buf-tst-inx    >    w-srt-buf-tst-num
                     go to ril-rec-tst-330.
           if        w-srt-buf-tst-cod
                    (w-srt-buf-tst-inx)   =    rf-dcf-cod-zon
                     go to ril-rec-tst-999.
           go to     ril-rec-tst-321.
       ril-rec-tst-330.
