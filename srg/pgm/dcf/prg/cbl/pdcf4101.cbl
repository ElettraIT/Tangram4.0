      *                      * Se uscita per interruzione forzata      *
      *                      *-----------------------------------------*
           if        w-cnt-prn-flg-int    not  = spaces
                     go to  int-pag-002-999.
      *                  *---------------------------------------------*
      *                  * Normalizzazione numero etichette stampate   *
      *                  * pagina                                      *
      *                  *---------------------------------------------*
           move      zero                 to   w-cnt-eti-num-epc      .
      *                  *---------------------------------------------*
      *                  * Salvataggio di questa linea di stampa       *
      *                  *---------------------------------------------*
           move      "LS"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     int-pag-002-999.
       int-pag-002-200.
      *              *-------------------------------------------------*
      *              * Se colonne oltre la prima                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino linea salvata                    *
      *                  *---------------------------------------------*
           move      "LR"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione numero etichette stampate   *
      *                  * pagina                                      *
      *                  *---------------------------------------------*
           move      zero                 to   w-cnt-eti-num-epc      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     int-pag-002-999.
       int-pag-002-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [yst]                         *
      *    *-----------------------------------------------------------*
       let-arc-yst-000.
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLS    "         to   f-key                  .
           move      w-let-arc-yst-tip    to   rf-yst-tip-cls         .
           move      w-let-arc-yst-cod    to   rf-yst-cod-cls         .
           move      "pgm/dcf/fls/ioc/obj/iofyst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-yst                 .
      *              *-------------------------------------------------*
      *              * Deviazione secondo l'esito della lettura        *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to let-arc-yst-400.
       let-arc-yst-200.
      *              *-------------------------------------------------*
      *              * Se record esistente                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      rf-yst-des-cls       to   w-let-arc-yst-des      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     let-arc-yst-999.
       let-arc-yst-400.
      *              *-------------------------------------------------*
      *              * Se record non esistente                         *
      *              *-------------------------------------------------*
       let-arc-yst-410.
      *                  *---------------------------------------------*
      *                  * Editing codice                              *
      *                  *---------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      05                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      w-let-arc-yst-cod    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       let-arc-yst-420.
      *                  *---------------------------------------------*
      *                  * Composizione stringa per ,non esistente     *
      *                  *---------------------------------------------*
           move      spaces               to   w-let-arc-yst-des      .
           if        w-let-arc-yst-tip    =    01
                     go to let-arc-yst-421
           else if   w-let-arc-yst-tip    =    02
                     go to let-arc-yst-422
           else if   w-let-arc-yst-tip    =    03
                     go to let-arc-yst-423.
       let-arc-yst-421.
           string    "ZONA "    delimited by   size
                     p-edt      delimited by   spaces
                                          into w-let-arc-yst-des      .
           go to     let-arc-yst-430.
       let-arc-yst-422.
           string    "CATEGORIA "
                                delimited by   size
                     p-edt      delimited by   spaces
                                          into w-let-arc-yst-des      .
           go to     let-arc-yst-430.
       let-arc-yst-423.
           string    "CODICE STAT. "
                                delimited by   size
                     p-edt      delimited by   spaces
                                          into w-let-arc-yst-des      .
           go to     let-arc-yst-430.
       let-arc-yst-430.
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     let-arc-yst-999.
       let-arc-yst-999.
           exit.

