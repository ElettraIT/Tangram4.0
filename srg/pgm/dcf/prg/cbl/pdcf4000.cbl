      *    * Accettazione campo testata : Codice fornitore di riferi-  *
      *    *                              mento                        *
      *    *-----------------------------------------------------------*
       acc-sta-tuc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se dipendenza : uscita                      *
      *                  *---------------------------------------------*
           if        w-tes-dpz-fnt        not  = spaces
                     go to acc-sta-tuc-999.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *                                             *
      *                  * Solo se status a 21,52,62,72                *
      *                  *---------------------------------------------*
           if        w-tes-sta-tus (1)    not  = 21  and
                     w-tes-sta-tus (1)    not  = 52  and
                     w-tes-sta-tus (1)    not  = 62  and
                     w-tes-sta-tus (1)    not  = 72
                     go to acc-sta-tuc-999.
       acc-sta-tuc-100.
      *              *-------------------------------------------------*
      *              * Salvataggio valore precedente                   *
      *              *-------------------------------------------------*
           move      w-tes-sta-tuc (1)    to   w-sav-sta-tuc          .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-dcf-ope      .
           move      w-tes-sta-tuc (1)    to   w-cod-mne-dcf-cod      .
           move      16                   to   w-cod-mne-dcf-lin      .
           move      30                   to   w-cod-mne-dcf-pos      .
           move      16                   to   w-cod-mne-dcf-rln      .
           move      41                   to   w-cod-mne-dcf-rps      .
           move      17                   to   w-cod-mne-dcf-vln      .
           move      41                   to   w-cod-mne-dcf-vps      .
           move      18                   to   w-cod-mne-dcf-lln      .
           move      41                   to   w-cod-mne-dcf-lps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "PRSC"               to   v-pfk (07)             .
           move      "NXSC"               to   v-pfk (08)             .
           perform   cod-mne-dcf-cll-000  thru cod-mne-dcf-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-dcf-foi-000  thru cod-mne-dcf-foi-999    .
       acc-sta-tuc-110.
           perform   cod-mne-dcf-cll-000  thru cod-mne-dcf-cll-999    .
           if        w-cod-mne-dcf-ope    =    "F+"
                     go to acc-sta-tuc-115.
           if        w-cod-mne-dcf-ope    =    "AC"
                     go to acc-sta-tuc-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-sta-tuc-115.
           perform   cod-mne-dcf-foi-000  thru cod-mne-dcf-foi-999    .
           go to     acc-sta-tuc-110.
       acc-sta-tuc-120.
           move      w-cod-mne-dcf-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-sta-tuc-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-sta-tuc-999.
       acc-sta-tuc-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-sta-tuc (1)      .
       acc-sta-tuc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-sta-tuc-410.
      *                  *---------------------------------------------*
      *                  * Lettura file [fnt]                          *
      *                  *---------------------------------------------*
           move      w-tes-sta-tuc (1)    to   w-let-arc-fnt-cod      .
           perform   let-arc-fnt-000      thru let-arc-fnt-999        .
      *                  *---------------------------------------------*
