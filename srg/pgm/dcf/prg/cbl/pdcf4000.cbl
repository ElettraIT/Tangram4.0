      *    * sibilita' della sola funzione di visualizzazione          *
      *    *-----------------------------------------------------------*
       ipc-sol-vis-000.
      *              *-------------------------------------------------*
      *              * Estrazione della variabile 'sol-vis' dallo      *
      *              * stesso livello                                  *
      *              *-------------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "sol-vis"            to   s-var                  .
           move      "="                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda dell'esito dell'operazione *
      *              *-------------------------------------------------*
           if        s-ves                =    spaces
                     go to ipc-sol-vis-200
           else      go to ipc-sol-vis-400.
       ipc-sol-vis-200.
      *              *-------------------------------------------------*
      *              * Se variabile esistente                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore della variabile                      *
      *                  *---------------------------------------------*
           move      s-alf                to   w-ipc-sol-vis-snx      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione della variabile             *
      *                  *---------------------------------------------*
           if        w-ipc-sol-vis-snx    not  = "S"
                     go to ipc-sol-vis-400.
      *                  *---------------------------------------------*
      *                  * Estrazione della variabile 'ide-fas' per la *
      *                  * fase del chiamante                          *
      *                  *---------------------------------------------*
           move      "CV"                 to   s-ope                  .
           move      "ide-fas"            to   s-var                  .
           move      "="                  to   s-dop                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda dell'esito del-    *
      *                      * l'operazione                            *
      *                      *-----------------------------------------*
           if        s-ves                =    spaces
                     go to ipc-sol-vis-220
           else      go to ipc-sol-vis-240.
       ipc-sol-vis-220.
      *                          *-------------------------------------*
      *                          * Se variabile esistente              *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Valore letto                    *
      *                              *---------------------------------*
           move      s-alf                to   w-ipc-sol-vis-fas      .
      *                              *---------------------------------*
      *                              * Uscita                          *
      *                              *---------------------------------*
           go to     ipc-sol-vis-999.
       ipc-sol-vis-240.
      *                          *-------------------------------------*
      *                          * Se variabile non esistente          *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Forzatura del valore            *
      *                              *---------------------------------*
           move      i-ide-fas            to   w-ipc-sol-vis-fas      .
      *                              *---------------------------------*
      *                              * Uscita                          *
      *                              *---------------------------------*
           go to     ipc-sol-vis-999.
       ipc-sol-vis-400.
      *              *-------------------------------------------------*
      *              * Se variabile non esistente                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Forzatura dei valori                        *
      *                  *---------------------------------------------*
           move      "N"                  to   w-ipc-sol-vis-snx      .
           move      spaces               to   w-ipc-sol-vis-fas      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     ipc-sol-vis-999.
       ipc-sol-vis-999.
           exit.

