      *                  *---------------------------------------------*
           move      w-let-arc-fnt-rag    to   w-tes-sta-tuc-rag (1)  .
           move      w-let-arc-fnt-via    to   w-tes-sta-tuc-via (1)  .
           move      w-let-arc-fnt-loc    to   w-tes-sta-tuc-loc (1)  .
       acc-sta-tuc-420.
      *                  *---------------------------------------------*
      *                  * Visualizzazione ragione sociale da anagra-  *
      *                  * fica contabile                              *
      *                  *---------------------------------------------*
           perform   vis-sta-tuc-rag-000  thru vis-sta-tuc-rag-999    .
       acc-sta-tuc-430.
      *                  *---------------------------------------------*
      *                  * Se fornitore non esistente                  *
      *                  *---------------------------------------------*
           if        w-let-arc-fnt-flg    =    spaces
                     go to acc-sta-tuc-440.
       acc-sta-tuc-434.
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-sta-tuc-100.
       acc-sta-tuc-440.
      *                  *---------------------------------------------*
      *                  * Se codice a zero                            *
      *                  *---------------------------------------------*
           if        w-tes-sta-tuc (1)    not  = zero
                     go to acc-sta-tuc-450.
       acc-sta-tuc-444.
      *                      *-----------------------------------------*
      *                      * A dipendenze dall'impostazione          *
      *                      *-----------------------------------------*
           go to     acc-sta-tuc-600.
       acc-sta-tuc-450.
      *                  *---------------------------------------------*
      *                  * Se codice diverso da zero                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda del confronto con  *
      *                      * il valore precedente                    *
      *                      *-----------------------------------------*
           if        w-tes-sta-tuc (1)    =    w-sav-sta-tuc
                     go to acc-sta-tuc-455
           else      go to acc-sta-tuc-480.
       acc-sta-tuc-455.
      *                      *-----------------------------------------*
      *                      * Se valore impostato pari al valore pre- *
      *                      * cedente                                 *
      *                      *-----------------------------------------*
       acc-sta-tuc-457.
      *                          *-------------------------------------*
      *                          * Lettura anagrafica commerciale del  *
      *                          * fornitore principale                *
      *                          *-------------------------------------*
           move      "C"                  to   w-let-arc-dcf-tle      .
           move      w-tes-sta-tuc (1)    to   w-let-arc-dcf-cod      .
           move      spaces               to   w-let-arc-dcf-dpz      .
           perform   let-arc-dcf-000      thru let-arc-dcf-999        .
      *                          *-------------------------------------*
      *                          * Deviazione a seconda dell'esito     *
      *                          * della lettura                       *
      *                          *-------------------------------------*
           if        w-let-arc-dcf-flg    =    spaces
                     go to acc-sta-tuc-467.
       acc-sta-tuc-459.
      *                          *-------------------------------------*
      *                          * Se anagrafica commerciale del for-  *
      *                          * nitore principale non esistente     *
      *                          *-------------------------------------*
       acc-sta-tuc-463.
      *                              *---------------------------------*
      *                              * Messaggio di errore             *
      *                              *---------------------------------*
           move      "Manca l'anagrafica commerciale per il fornitore   
      -              "          "         to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
       acc-sta-tuc-465.
      *                              *---------------------------------*
      *                              * A reimpostazione                *
      *                              *---------------------------------*
           go to     acc-sta-tuc-100.
       acc-sta-tuc-467.
      *                          *-------------------------------------*
      *                          * Se anagrafica commerciale del for-  *
      *                          * nitore principale esistente         *
      *                          *-------------------------------------*
      *                                  *-----------------------------*
      *                                  * A ulteriori controlli su    *
      *                                  * impostazione                *
      *                                  *-----------------------------*
           go to     acc-sta-tuc-500.
       acc-sta-tuc-480.
      *                      *-----------------------------------------*
      *                      * Se valore impostato diverso dal valore  *
      *                      * precedente                              *
      *                      *-----------------------------------------*
       acc-sta-tuc-484.
      *                              *---------------------------------*
      *                              * Riaggancio                      *
      *                              *---------------------------------*
           go to     acc-sta-tuc-457.
       acc-sta-tuc-500.
      *                      *-----------------------------------------*
      *                      * Controllo che il codice fornitore impo- *
      *                      * stato non sia pari a quello di testata  *
      *                      *-----------------------------------------*
           if        w-tes-sta-tuc (1)    =    w-tes-cod-fnt
                     go to acc-sta-tuc-100.
       acc-sta-tuc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale normalizzazione modalita' di      *
      *                  * trattamento per le statistiche              *
      *                  *---------------------------------------------*
           if        w-tes-sta-tuc (1)    not  = zero
                     go to acc-sta-tuc-800.
           if        w-tes-sta-tuc (1)    =    w-sav-sta-tuc
                     go to acc-sta-tuc-800.
           if        w-tes-sta-tux (1)    =    zero
                     go to acc-sta-tuc-800.
      *                  *---------------------------------------------*
      *                  * Normalizzazione modalita' di trattamento    *
      *                  * per le statistiche                          *
      *                  *---------------------------------------------*
           move      zero                 to   w-tes-sta-tux (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione modalita' di trattamento    *
      *                  * per le statistiche                          *
      *                  *---------------------------------------------*
           perform   vis-sta-tux-000      thru vis-sta-tux-999        .
       acc-sta-tuc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-sta-tuc-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-sta-tuc-100.
       acc-sta-tuc-999.
           exit.

