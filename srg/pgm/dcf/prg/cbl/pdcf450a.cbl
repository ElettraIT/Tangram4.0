      *    *===========================================================*
      *    * Accettazione campo : Indirizzo                            *
      *    *-----------------------------------------------------------*
       acc-via-dcf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-via-dcf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-ind-cec-geo-ope      .
           move      w-rig-naz-dcf        to   w-ind-cec-geo-naz      .
           move      w-rig-via-dcf        to   w-ind-cec-geo-ind      .
           move      16                   to   w-ind-cec-geo-lin      .
           move      22                   to   w-ind-cec-geo-pos      .
           move      w-rig-loc-dcf        to   w-ind-cec-geo-cec      .
           move      w-rig-cmn-dcf        to   w-ind-cec-geo-cmn      .
           move      w-rig-cmn-dcf-des    to   w-ind-cec-geo-dco      .
           move      w-rig-cmn-dcf-prv    to   w-ind-cec-geo-prv      .
           move      w-rig-fzn-dcf        to   w-ind-cec-geo-fzn      .
           move      w-rig-fzn-dcf-des    to   w-ind-cec-geo-dfr      .
           move      w-rig-lct-dcf        to   w-ind-cec-geo-lct      .
           move      w-rig-lct-dcf-des    to   w-ind-cec-geo-dlo      .
           move      spaces               to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   ind-cec-geo-cll-000  thru ind-cec-geo-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   ind-cec-geo-foi-000  thru ind-cec-geo-foi-999    .
       acc-via-dcf-110.
           perform   ind-cec-geo-cll-000  thru ind-cec-geo-cll-999    .
           if        w-ind-cec-geo-ope    =    "F+"
                     go to acc-via-dcf-115.
           if        w-ind-cec-geo-ope    =    "AC"
                     go to acc-via-dcf-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-via-dcf-115.
           perform   ind-cec-geo-foi-000  thru ind-cec-geo-foi-999    .
           go to     acc-via-dcf-110.
       acc-via-dcf-120.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-via-dcf-999.
       acc-via-dcf-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      w-ind-cec-geo-ind    to   w-rig-via-dcf          .
      *              *-------------------------------------------------*
      *              * Altri valori se automatismo eseguito            *
      *              *-------------------------------------------------*
           if        w-ind-cec-geo-aut    =    spaces
                     go to acc-via-dcf-400.
      *                  *---------------------------------------------*
      *                  * C.a.p. e citta'                             *
      *                  *---------------------------------------------*
           move      w-ind-cec-geo-cec    to   w-rig-loc-dcf          .
           perform   vis-loc-dcf-000      thru vis-loc-dcf-999        .
      *                  *---------------------------------------------*
      *                  * Comune                                      *
      *                  *---------------------------------------------*
           move      w-ind-cec-geo-cmn    to   w-rig-cmn-dcf          .
           move      w-ind-cec-geo-dco    to   w-rig-cmn-dcf-des      .
           move      w-ind-cec-geo-prv    to   w-rig-cmn-dcf-prv      .
           perform   vis-rig-cmn-000      thru vis-rig-cmn-999        .
           perform   vis-rig-cmn-des-000  thru vis-rig-cmn-des-999    .
           perform   vis-rig-cmn-prv-000  thru vis-rig-cmn-prv-999    .
      *                  *---------------------------------------------*
      *                  * Frazione                                    *
      *                  *---------------------------------------------*
           move      w-ind-cec-geo-fzn    to   w-rig-fzn-dcf          .
           move      w-ind-cec-geo-dfr    to   w-rig-fzn-dcf-des      .
           perform   vis-rig-fzn-000      thru vis-rig-fzn-999        .
           perform   vis-rig-fzn-des-000  thru vis-rig-fzn-des-999    .
      *                  *---------------------------------------------*
      *                  * Localita'                                   *
      *                  *---------------------------------------------*
           move      w-ind-cec-geo-lct    to   w-rig-lct-dcf          .
           move      w-ind-cec-geo-dlo    to   w-rig-lct-dcf-des      .
           perform   vis-rig-lct-000      thru vis-rig-lct-999        .
           perform   vis-rig-lct-des-000  thru vis-rig-lct-des-999    .
       acc-via-dcf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore a non spaces il primo carattere   *
      *                  * non deve essere a spaces                    *
      *                  *---------------------------------------------*
           if        w-rig-via-dcf        =    spaces
                     go to acc-via-dcf-600.
      *
           if        w-rig-via-dcf
                    (01 : 01)             =    spaces
                     go to acc-via-dcf-100.
       acc-via-dcf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-via-dcf-800.
      *              *-------------------------------------------------*
