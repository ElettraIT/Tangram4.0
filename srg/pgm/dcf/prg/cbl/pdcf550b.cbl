      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-per-sco-650
           else if   v-key                =    "DOWN"
                     go to acc-per-sco-670
           else if   v-key                =    "TAB "
                     go to acc-per-sco-700
           else if   v-key                =    "DO  "
