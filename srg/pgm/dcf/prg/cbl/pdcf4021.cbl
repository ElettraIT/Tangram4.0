           move      "pgm/dcf/fls/ioc/obj/iofydf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ydf                 .
       prs-vde-fat-999.
           exit.

