           if        rf-gxp-des-prv       >    rr-sel-prv-def or
                     rf-gxp-des-prv       <    rr-sel-prv-dei
                     go to stp-srt-inp-sel-900.
           if        rf-gxp-cod-prv       >    rr-sel-prv-cof or
                     rf-gxp-cod-prv       <    rr-sel-prv-coi
                     go to stp-srt-inp-sel-900.
      *                      *-----------------------------------------*
      *                      * Preparazione chiavi per il sort         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Chiave numerica                     *
      *                          *-------------------------------------*
           move      zero                 to   w-srt-key-num          .
      *                          *-------------------------------------*
      *                          * Chiavi alfanumeriche 1 e 2          *
      *                          *-------------------------------------*
           if        rr-ord-ana-prv       =    01
                     move  rf-gxp-cod-prv to   w-srt-key-al2
                     move  spaces         to   w-srt-key-alf
           else if   rr-ord-ana-prv       =    02
                     move  rf-gxp-cod-prv to   w-srt-key-al2
                     move  rf-gxp-des-prv to   w-srt-key-alf          .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-sel-800.
       stp-srt-inp-sel-640.
      *                  *---------------------------------------------*
      *                  * Se ordinamento per codice comune            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se codice nazione non e' 'IT' : uscita  *
      *                      * per elemento non selezionato            *
      *                      *-----------------------------------------*
           if        rf-dcf-cod-naz       not  = "IT "
                     go to stp-srt-inp-sel-900.
      *                      *-----------------------------------------*
      *                      * Se codice comune a zero : uscita per    *
      *                      * elemento non selezionato                *
      *                      *-----------------------------------------*
           if        rf-dcf-cod-cmn       =    zero
                     go to stp-srt-inp-sel-900.
      *                      *-----------------------------------------*
      *                      * Lettura preliminare del codice comune   *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCFL    "         to   f-key                  .
           move      rf-dcf-cod-cmn       to   rf-gxc-cod-cmn         .
           move      zero                 to   rf-gxc-cod-fzn         .
           move      zero                 to   rf-gxc-cod-lct         .
           move      "pgm/geo/fls/ioc/obj/iofgxc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gxc                 .
      *                          *-------------------------------------*
      *                          * Se record non trovato : uscita per  *
      *                          * elemento non selezionato            *
      *                          *-------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-sel-900.
      *                      *-----------------------------------------*
      *                      * Selezioni su anagrafica comuni          *
      *                      *-----------------------------------------*
           if        rf-gxc-des-cfl       >    rr-sel-cmn-def or
                     rf-gxc-des-cfl       <    rr-sel-cmn-dei
                     go to stp-srt-inp-sel-900.
           if        rf-gxc-cap-avp       >    rr-sel-cmn-cpf or
                     rf-gxc-cap-avp       <    rr-sel-cmn-cpi
                     go to stp-srt-inp-sel-900.
      *                      *-----------------------------------------*
      *                      * Preparazione chiavi per il sort         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Chiave numerica                     *
      *                          *-------------------------------------*
           move      zero                 to   w-srt-key-num          .
      *                          *-------------------------------------*
      *                          * Chiavi alfanumeriche 1 e 2          *
      *                          *-------------------------------------*
           if        rr-ord-ana-cmn       =    01
                     move  rf-gxc-cap-avp to   w-srt-key-al2
                     move  rf-gxc-des-cfl to   w-srt-key-alf
           else if   rr-ord-ana-cmn       =    02
                     move  rf-gxc-cap-avp to   w-srt-key-al2
                     move  spaces         to   w-srt-key-alf          .
      *                      *-----------------------------------------*
      *                      * Preparazione CAP per le selezioni sup-  *
      *                      * plementari                              *
      *                      *-----------------------------------------*
           move      rf-gxc-cap-avp       to   w-srt-cap-avp          .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-sel-800.
       stp-srt-inp-sel-710.
      *                  *---------------------------------------------*
      *                  * Se ordinamento per codice avviamento posta- *
      *                  * le                                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se codice nazione non e' 'IT' : uscita  *
      *                      * per elemento non selezionato            *
      *                      *-----------------------------------------*
           if        rf-dcf-cod-naz       not  = "IT "
                     go to stp-srt-inp-sel-900.
      *                      *-----------------------------------------*
      *                      * Se il campo localita' e' a spaces :     *
      *                      * uscita per elemento non selezionato     *
      *                      *-----------------------------------------*
           if        rf-dcf-loc-dcf       =    spaces
                     go to stp-srt-inp-sel-900.
      *                      *-----------------------------------------*
      *                      * Rilevamento del codice avviamento pos-  *
      *                      * tale dal campo localita'                *
      *                      *-----------------------------------------*
           move      rf-dcf-loc-dcf       to   w-srt-cap-avp          .
      *                      *-----------------------------------------*
      *                      * Se il CAP non e' un valore numerico :   *
      *                      * uscita per elemento non selezionato     *
      *                      *-----------------------------------------*
           if        w-srt-cap-avp-num    not  numeric
                     go to stp-srt-inp-sel-900.
      *                      *-----------------------------------------*
      *                      * Determinazione del CAP del comune se    *
      *                      * CAP stradario                           *
      *                      *-----------------------------------------*
           if        rr-tip-ors           =    22
                     go to stp-srt-inp-sel-712.
      *                          *-------------------------------------*
      *                          * Subroutine di determinazione        *
      *                          *-------------------------------------*
           move      w-srt-cap-avp        to   w-det-std-gxs-cap      .
           perform   det-std-gxs-000      thru det-std-gxs-999        .
      *                          *-------------------------------------*
      *                          * Test su esito determinazione        *
      *                          *-------------------------------------*
           if        w-det-std-gxs-flg    not  = spaces
                     go to stp-srt-inp-sel-712.
           if        w-det-std-gxs-ccm    =    spaces
                     go to stp-srt-inp-sel-712.
           move      w-det-std-gxs-ccm    to   w-srt-cap-avp          .
       stp-srt-inp-sel-712.
      *                      *-----------------------------------------*
      *                      * Preparazione chiavi per il sort         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Chiave numerica                     *
      *                          *-------------------------------------*
           move      zero                 to   w-srt-key-num          .
      *                          *-------------------------------------*
      *                          * Chiavi alfanumeriche 1 e 2          *
      *                          *-------------------------------------*
           move      spaces               to   w-srt-key-alf          .
           move      w-srt-cap-avp        to   w-srt-key-al2          .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-sel-800.
       stp-srt-inp-sel-800.
      *              *-------------------------------------------------*
      *              * Uscita per selezioni superate                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-sel-999.
       stp-srt-inp-sel-900.
      *              *-------------------------------------------------*
      *              * Uscita per selezioni non superate               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita                              *
      *                  *---------------------------------------------*
           move      "#"                  to   w-srt-sel-rec          .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-sel-999.
       stp-srt-inp-sel-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Selezioni supplementari su anagrafica fornitori           *
      *    *-----------------------------------------------------------*
       stp-srt-inp-ssu-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-srt-sel-rec          .
       stp-srt-inp-ssu-050.
      *              *-------------------------------------------------*
      *              * Se si tratta di una dipendenza e la selezione   *
      *              * implica fornitori con status diverso da normale *
      *              * selezione non superata, a meno che non sia una  *
      *              * richiesta di stampa di singola scheda           *
      *              *-------------------------------------------------*
           if        rr-sel-fnt-dpz       not  = spaces
                     go to stp-srt-inp-ssu-800.
           if        rf-dcf-dpz-fnt       not  = spaces      and
                     rr-ssu-sta-tus       not  = "X        "
                     go to stp-srt-inp-ssu-900.
      *              *-------------------------------------------------*
      *              * Se si tratta di una dipendenza e la selezione   *
      *              * implica solo fornitori con status pari a nor-   *
      *              * male: non si seleziona sullo status commerciale *
      *              *-------------------------------------------------*
           if        rf-dcf-dpz-fnt       not  = spaces
                     go to stp-srt-inp-ssu-100.
      *              *-------------------------------------------------*
      *              * Selezione su status commerciale del cliente     *
      *              *-------------------------------------------------*
           if        rf-dcf-sta-tus       =    01 and
                     rr-ssu-sta-tus (01 : 01)
                                          =    spaces
                     go to stp-srt-inp-ssu-900.
           if        rf-dcf-sta-tus       =    11 and
                     rr-ssu-sta-tus (02 : 01)
                                          =    spaces
                     go to stp-srt-inp-ssu-900.
           if        rf-dcf-sta-tus       =    21 and
                     rr-ssu-sta-tus (03 : 01)
                                          =    spaces
                     go to stp-srt-inp-ssu-900.
           if        rf-dcf-sta-tus       =    51 and
                     rr-ssu-sta-tus (04 : 01)
                                          =    spaces
                     go to stp-srt-inp-ssu-900.
           if        rf-dcf-sta-tus       =    52 and
                     rr-ssu-sta-tus (05 : 01)
                                          =    spaces
                     go to stp-srt-inp-ssu-900.
           if        rf-dcf-sta-tus       =    61 and
                     rr-ssu-sta-tus (06 : 01)
                                          =    spaces
                     go to stp-srt-inp-ssu-900.
           if        rf-dcf-sta-tus       =    62 and
                     rr-ssu-sta-tus (07 : 01)
                                          =    spaces
                     go to stp-srt-inp-ssu-900.
           if        rf-dcf-sta-tus       =    71 and
                     rr-ssu-sta-tus (08 : 01)
                                          =    spaces
                     go to stp-srt-inp-ssu-900.
           if        rf-dcf-sta-tus       =    72 and
                     rr-ssu-sta-tus (09 : 01)
                                          =    spaces
                     go to stp-srt-inp-ssu-900.
       stp-srt-inp-ssu-100.
      *              *-------------------------------------------------*
      *              * Codice nostra banca                             *
      *              *-------------------------------------------------*
           if        rr-ssu-cod-cbp       =    spaces
                     go to stp-srt-inp-ssu-200.
           if        rf-dcf-nos-ban       not  = rr-ssu-cod-cbp
                     go to stp-srt-inp-ssu-900.
       stp-srt-inp-ssu-200.
      *              *-------------------------------------------------*
      *              * Codice zona                                     *
      *              *-------------------------------------------------*
           if        rr-ssu-cod-zon       =    zero
                     go to stp-srt-inp-ssu-300.
           if        rf-dcf-cod-zon       not  = rr-ssu-cod-zon
                     go to stp-srt-inp-ssu-900.
       stp-srt-inp-ssu-300.
      *              *-------------------------------------------------*
      *              * Codice categoria                                *
      *              *-------------------------------------------------*
           if        rr-ssu-cod-cat       =    zero
                     go to stp-srt-inp-ssu-400.
           if        rf-dcf-cod-cat       not  = rr-ssu-cod-cat
                     go to stp-srt-inp-ssu-900.
       stp-srt-inp-ssu-400.
      *              *-------------------------------------------------*
      *              * Codice statistico                               *
      *              *-------------------------------------------------*
           if        rr-ssu-cod-stt       =    zero
                     go to stp-srt-inp-ssu-500.
           if        rf-dcf-cod-stt       not  = rr-ssu-cod-stt
                     go to stp-srt-inp-ssu-900.
       stp-srt-inp-ssu-500.
      *              *-------------------------------------------------*
      *              * Codici di avviamento postale                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se tutti i CAP a spaces : a selezione  *
      *                  * superata                                    *
      *                  *---------------------------------------------*
           if        rr-ssu-cod-cap (1)   =    spaces and
                     rr-ssu-cod-cap (2)   =    spaces and
                     rr-ssu-cod-cap (3)   =    spaces and
                     rr-ssu-cod-cap (4)   =    spaces and
                     rr-ssu-cod-cap (5)   =    spaces and
                     rr-ssu-cod-cap (6)   =    spaces
                     go to stp-srt-inp-ssu-800.
      *                  *---------------------------------------------*
      *                  * Se codice nazione non e' 'IT' : uscita per  *
      *                  * elemento non selezionato                    *
      *                  *---------------------------------------------*
           if        rf-dcf-cod-naz       not  = "IT "
                     go to stp-srt-inp-ssu-900.
      *                  *---------------------------------------------*
      *                  * Se il tipo ordinamento stampa e' per comune *
      *                  * si utilizza il CAP gia' rilevato dal comune *
      *                  * stesso                                      *
      *                  *---------------------------------------------*
           if        rr-tip-ors           =    14
                     go to stp-srt-inp-ssu-540.
       stp-srt-inp-ssu-520.
      *                  *---------------------------------------------*
      *                  * Rilevamento del codice avviamento postale   *
      *                  * dal campo localita'                         *
      *                  *---------------------------------------------*
           move      rf-dcf-loc-dcf       to   w-srt-cap-avp          .
      *                  *---------------------------------------------*
      *                  * Se il CAP non e' un valore numerico : usci- *
      *                  * ta per elemento non selezionato             *
      *                  *---------------------------------------------*
           if        w-srt-cap-avp-num    not  numeric
                     go to stp-srt-inp-ssu-900.
       stp-srt-inp-ssu-540.
      *                  *---------------------------------------------*
      *                  * Regolarizzazione dei CAP richiesti          *
      *                  *---------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Regolarizzazione dei CAP richiesti          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * CAP richiesto '1'                       *
      *                      *-----------------------------------------*
           move      rr-ssu-cod-cap (1)   to   w-srt-cap-in1          .
           inspect   w-srt-cap-in1   replacing all " "
                                          by       "0"                .
           move      rr-ssu-cod-cap (1)   to   w-srt-cap-fi1          .
           inspect   w-srt-cap-fi1   replacing all " "
                                          by       "9"                .
      *                      *-----------------------------------------*
      *                      * CAP richiesto '2'                       *
      *                      *-----------------------------------------*
           move      rr-ssu-cod-cap (2)   to   w-srt-cap-in2          .
           inspect   w-srt-cap-in2   replacing all " "
                                          by       "0"                .
           move      rr-ssu-cod-cap (2)   to   w-srt-cap-fi2          .
           inspect   w-srt-cap-fi2   replacing all " "
                                          by       "9"                .
      *                      *-----------------------------------------*
      *                      * CAP richiesto '3'                       *
      *                      *-----------------------------------------*
           move      rr-ssu-cod-cap (3)   to   w-srt-cap-in3          .
           inspect   w-srt-cap-in3   replacing all " "
                                          by       "0"                .
           move      rr-ssu-cod-cap (3)   to   w-srt-cap-fi3          .
           inspect   w-srt-cap-fi3   replacing all " "
                                          by       "9"                .
      *                      *-----------------------------------------*
      *                      * CAP richiesto '4'                       *
      *                      *-----------------------------------------*
           move      rr-ssu-cod-cap (4)   to   w-srt-cap-in4          .
           inspect   w-srt-cap-in4   replacing all " "
                                          by       "0"                .
           move      rr-ssu-cod-cap (4)   to   w-srt-cap-fi4          .
           inspect   w-srt-cap-fi4   replacing all " "
                                          by       "9"                .
      *                      *-----------------------------------------*
      *                      * CAP richiesto '5'                       *
      *                      *-----------------------------------------*
           move      rr-ssu-cod-cap (5)   to   w-srt-cap-in5          .
           inspect   w-srt-cap-in5   replacing all " "
                                          by       "0"                .
           move      rr-ssu-cod-cap (5)   to   w-srt-cap-fi5          .
           inspect   w-srt-cap-fi5   replacing all " "
                                          by       "9"                .
      *                      *-----------------------------------------*
      *                      * CAP richiesto '6'                       *
      *                      *-----------------------------------------*
           move      rr-ssu-cod-cap (6)   to   w-srt-cap-in6          .
           inspect   w-srt-cap-in6   replacing all " "
                                          by       "0"                .
           move      rr-ssu-cod-cap (6)   to   w-srt-cap-fi6          .
           inspect   w-srt-cap-fi6   replacing all " "
                                          by       "9"                .
      *                  *---------------------------------------------*
      *                  * Test per la selezione                       *
      *                  *---------------------------------------------*
           if        w-srt-cap-avp        >    w-srt-cap-fi1  or
                     w-srt-cap-avp        <    w-srt-cap-in1
                     go to stp-srt-inp-ssu-900.
           if        w-srt-cap-avp        >    w-srt-cap-fi2  or
                     w-srt-cap-avp        <    w-srt-cap-in2
                     go to stp-srt-inp-ssu-900.
           if        w-srt-cap-avp        >    w-srt-cap-fi3  or
                     w-srt-cap-avp        <    w-srt-cap-in3
                     go to stp-srt-inp-ssu-900.
           if        w-srt-cap-avp        >    w-srt-cap-fi4  or
                     w-srt-cap-avp        <    w-srt-cap-in4
                     go to stp-srt-inp-ssu-900.
           if        w-srt-cap-avp        >    w-srt-cap-fi5  or
                     w-srt-cap-avp        <    w-srt-cap-in5
                     go to stp-srt-inp-ssu-900.
           if        w-srt-cap-avp        >    w-srt-cap-fi6  or
                     w-srt-cap-avp        <    w-srt-cap-in6
                     go to stp-srt-inp-ssu-900.
       stp-srt-inp-ssu-800.
      *              *-------------------------------------------------*
      *              * Uscita per selezioni supplementari superate     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-ssu-999.
       stp-srt-inp-ssu-900.
      *              *-------------------------------------------------*
      *              * Uscita per selezioni non superate               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di uscita                              *
      *                  *---------------------------------------------*
           move      "#"                  to   w-srt-sel-rec          .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-ssu-999.
       stp-srt-inp-ssu-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Composizione area di sort                                 *
      *    *-----------------------------------------------------------*
       stp-srt-inp-cms-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione preliminare                     *
      *              *-------------------------------------------------*
           move      spaces               to   srt-rec                .
       stp-srt-inp-cms-100.
      *              *-------------------------------------------------*
      *              * Composizione chiave di sort per i fornitori     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funazione del tipo ordinamen- *
      *                  * to per fornitore                            *
      *                  *---------------------------------------------*
           if        w-srt-ord-fnt        =    01
                     go to stp-srt-inp-cms-110
           else if   w-srt-ord-fnt        =    02
                     go to stp-srt-inp-cms-120
           else if   w-srt-ord-fnt        =    03
                     go to stp-srt-inp-cms-130.
       stp-srt-inp-cms-110.
      *                      *-----------------------------------------*
      *                      * Se ordinamento per ragione sociale      *
      *                      *-----------------------------------------*
           move      zero                 to   srt-key-num            .
           move      spaces               to   srt-key-alf            .
           move      spaces               to   srt-key-al2            .
           move      zero                 to   srt-key-ncl            .
           move      rf-dcf-rag-key       to   srt-key-acl            .
           move      spaces               to   srt-key-adp            .
      *                          *-------------------------------------*
      *                          * A composizione chiave di sort       *
      *                          *-------------------------------------*
           go to     stp-srt-inp-cms-200.
       stp-srt-inp-cms-120.
      *                      *-----------------------------------------*
      *                      * Se ordinamento per codice               *
      *                      *-----------------------------------------*
           move      zero                 to   srt-key-num            .
           move      spaces               to   srt-key-alf            .
           move      spaces               to   srt-key-al2            .
           move      rf-dcf-cod-fnt       to   srt-key-ncl            .
           move      spaces               to   srt-key-acl            .
           move      rf-dcf-dpz-fnt       to   srt-key-adp            .
      *                          *-------------------------------------*
      *                          * A composizione chiave di sort       *
      *                          *-------------------------------------*
           go to     stp-srt-inp-cms-200.
       stp-srt-inp-cms-130.
      *                      *-----------------------------------------*
      *                      * Se ordinamento per mnemonico            *
      *                      *-----------------------------------------*
           move      zero                 to   srt-key-num            .
           move      spaces               to   srt-key-alf            .
           move      spaces               to   srt-key-al2            .
           move      zero                 to   srt-key-ncl            .
           move      rf-fnt-cod-mne       to   srt-key-acl            .
           move      rf-dcf-dpz-fnt       to   srt-key-adp            .
      *                          *-------------------------------------*
      *                          * A composizione chiave di sort       *
      *                          *-------------------------------------*
           go to     stp-srt-inp-cms-200.
       stp-srt-inp-cms-200.
      *              *-------------------------------------------------*
      *              * Composizione chiave di sort generica            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Chiave di ordinamento numerica generica     *
      *                  *---------------------------------------------*
           move      w-srt-key-num        to   srt-key-num            .
      *                  *---------------------------------------------*
      *                  * Chiave di ordinamento alfanumerica generica *
      *                  *---------------------------------------------*
           move      w-srt-key-alf        to   srt-key-alf            .
      *                  *---------------------------------------------*
      *                  * Chiave di ordinamento alfanumerica generica *
      *                  * numero 2                                    *
      *                  *---------------------------------------------*
           move      w-srt-key-al2        to   srt-key-al2            .
       stp-srt-inp-cms-600.
      *              *-------------------------------------------------*
      *              * Composizione dati di sort                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Per ospitare un intero 'rf-dcf'             *
      *                  *---------------------------------------------*
           move      rf-dcf               to   srt-dat-rec-dcf        .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-cms-900.
       stp-srt-inp-cms-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-cms-999.
       stp-srt-inp-cms-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Composizione area di sort supplementare in caso di ordi-  *
      *    * namento fornitori per mnemonico                           *
      *    *-----------------------------------------------------------*
       stp-srt-inp-csu-000.
      *              *-------------------------------------------------*
      *              * Test preliminare                                *
      *              *-------------------------------------------------*
           if        w-srt-ord-fnt        not  = 03
                     go to stp-srt-inp-csu-900.
      *              *-------------------------------------------------*
      *              * Preparazione preliminare del codice fornitore   *
      *              * per la scansione                                *
      *              *-------------------------------------------------*
           move      rf-dcf-cod-fnt       to   w-srt-cod-fnt          .
      *              *-------------------------------------------------*
      *              * Preparazione preliminare delle chiavi di sort   *
      *              *-------------------------------------------------*
           move      srt-key-ncl          to   w-srt-key-ncl          .
           move      srt-key-acl          to   w-srt-key-acl          .
       stp-srt-inp-csu-100.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione eventuali dipendenze per il  *
      *              * fornitore in corso di trattamento               *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CODFNT    "         to   f-key                  .
           move      w-srt-cod-fnt        to   rf-dcf-cod-fnt         .
           move      spaces               to   rf-dcf-dpz-fnt         .
           move      "pgm/dcf/fls/ioc/obj/iofdcf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcf                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : ad uscita                 *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-csu-900.
       stp-srt-inp-csu-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale archivio [dcf]              *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcf/fls/ioc/obj/iofdcf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcf                 .
      *                  *---------------------------------------------*
      *                  * Se lettura errata : ad uscita               *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-csu-900.
       stp-srt-inp-csu-300.
      *              *-------------------------------------------------*
      *              * Test max                                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice                              *
      *                  *---------------------------------------------*
           if        rf-dcf-cod-fnt       >    w-srt-cod-fnt
                     go to stp-srt-inp-csu-900.
       stp-srt-inp-csu-400.
      *              *-------------------------------------------------*
      *              * Selezioni per le dipendenze                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se codice dipendenza a spaces : riciclo     *
      *                  *---------------------------------------------*
           if        rf-dcf-dpz-fnt       =    spaces
                     go to stp-srt-inp-csu-200.
      *                  *---------------------------------------------*
      *                  * Selettori supplementari                     *
      *                  *---------------------------------------------*
       stp-srt-inp-csu-420.
      *                      *-----------------------------------------*
      *                      * Codice zona                             *
      *                      *-----------------------------------------*
           if        rr-ssu-cod-zon       =    zero
                     go to stp-srt-inp-csu-600.
           if        rf-dcf-cod-zon       not  = rr-ssu-cod-zon
                     go to stp-srt-inp-csu-200.
       stp-srt-inp-csu-430.
      *                      *-----------------------------------------*
      *                      * Codici di avviamento postale            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Rilevamento del codice avviamento   *
      *                          * postale dal campo localita'         *
      *                          *-------------------------------------*
           move      rf-dcf-loc-dcf       to   w-srt-cap-avp          .
      *                          *-------------------------------------*
      *                          * Test sui CAP                        *
      *                          *-------------------------------------*
           if        w-srt-cap-avp        >    w-srt-cap-fi1  or
                     w-srt-cap-avp        <    w-srt-cap-in1
                     go to stp-srt-inp-csu-200.
           if        w-srt-cap-avp        >    w-srt-cap-fi2  or
                     w-srt-cap-avp        <    w-srt-cap-in2
                     go to stp-srt-inp-csu-200.
           if        w-srt-cap-avp        >    w-srt-cap-fi3  or
                     w-srt-cap-avp        <    w-srt-cap-in3
                     go to stp-srt-inp-csu-200.
           if        w-srt-cap-avp        >    w-srt-cap-fi4  or
                     w-srt-cap-avp        <    w-srt-cap-in4
                     go to stp-srt-inp-csu-200.
           if        w-srt-cap-avp        >    w-srt-cap-fi5  or
                     w-srt-cap-avp        <    w-srt-cap-in5
                     go to stp-srt-inp-csu-200.
           if        w-srt-cap-avp        >    w-srt-cap-fi6  or
                     w-srt-cap-avp        <    w-srt-cap-in6
                     go to stp-srt-inp-csu-200.
       stp-srt-inp-csu-600.
      *              *-------------------------------------------------*
      *              * Composizione area di sort                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Composizione chiavi di sort                 *
      *                  *---------------------------------------------*
           move      w-srt-key-num        to   srt-key-num            .
           move      w-srt-key-alf        to   srt-key-alf            .
           move      w-srt-key-al2        to   srt-key-al2            .
           move      w-srt-key-ncl        to   srt-key-ncl            .
           move      w-srt-key-acl        to   srt-key-acl            .
           move      rf-dcf-dpz-fnt       to   srt-key-adp            .
      *                  *---------------------------------------------*
      *                  * Composizione dati di sort                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Per ospitare un intero 'rf-dcf'         *
      *                      *-----------------------------------------*
           move      rf-dcf               to   srt-dat-rec-dcf        .
       stp-srt-inp-csu-800.
      *              *-------------------------------------------------*
      *              * Rilascio del record al sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-csu-850.
      *              *-------------------------------------------------*
      *              * Riciclo a record successivo                     *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-csu-200.
       stp-srt-inp-csu-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-csu-999.
       stp-srt-inp-csu-999.
           exit.

