      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Preparazione del tipo ordinamento anagrafica    *
      *              * fornitori e dei selettori per la scansione del- *
      *              * anagrafica fornitori                            *
      *              *-------------------------------------------------*
           move      zero                 to   w-srt-ord-fnt          .
           move      zero                 to   w-srt-cof-min          .
           move      zero                 to   w-srt-cof-max          .
           move      spaces               to   w-srt-rsf-min          .
           move      spaces               to   w-srt-rsf-max          .
           move      spaces               to   w-srt-mnf-min          .
           move      spaces               to   w-srt-mnf-max          .
      *              *-------------------------------------------------*
      *              * Test sul tipo ordinamento stampa                *
      *              *-------------------------------------------------*
           if        rr-tip-ors           =    01
                     go to stp-srt-inp-020.
       stp-srt-inp-010.
      *              *-------------------------------------------------*
      *              * Se ordinamento stampa per altra anagrafica      *
      *              *-------------------------------------------------*
           move      rr-tip-ocp           to   w-srt-ord-fnt          .
           move      zero                 to   w-srt-cof-min          .
           move      9999999              to   w-srt-cof-max          .
           move      spaces               to   w-srt-rsf-min          .
           move      all "z"              to   w-srt-rsf-max          .
           move      spaces               to   w-srt-mnf-min          .
           move      all "z"              to   w-srt-mnf-max          .
      *                  *---------------------------------------------*
      *                  * A inizio ciclo di scansione                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-100.
       stp-srt-inp-020.
      *              *-------------------------------------------------*
      *              * Se ordinamento stampa per fornitore             *
      *              *-------------------------------------------------*
           move      rr-ord-ana-fnt       to   w-srt-ord-fnt          .
           move      rr-sel-fnt-coi       to   w-srt-cof-min          .
           move      rr-sel-fnt-cof       to   w-srt-cof-max          .
           move      rr-sel-fnt-rsi       to   w-srt-rsf-min          .
           move      rr-sel-fnt-rsf       to   w-srt-rsf-max          .
           move      rr-sel-fnt-mni       to   w-srt-mnf-min          .
           move      rr-sel-fnt-mnf       to   w-srt-mnf-max          .
      *                  *---------------------------------------------*
      *                  * A inizio ciclo di scansione                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-100.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Inizio ciclo di scansione archivio fornitori    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo ordinamento *
      *                  * fornitori                                   *
      *                  *---------------------------------------------*
           if        w-srt-ord-fnt        =    01
                     go to stp-srt-inp-110
           else if   w-srt-ord-fnt        =    02
                     go to stp-srt-inp-120
           else if   w-srt-ord-fnt        =    03
                     go to stp-srt-inp-130.
       stp-srt-inp-110.
      *              *-------------------------------------------------*
      *              * Se ordinamento fornitori per ragione sociale    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start per ragione sociale in uppercase      *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "RAGKEY    "         to   f-key                  .
           move      w-srt-rsf-min        to   rf-dcf-rag-key         .
           move      zero                 to   rf-dcf-cod-fnt         .
           move      spaces               to   rf-dcf-dpz-fnt         .
           move      "pgm/dcf/fls/ioc/obj/iofdcf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcf                 .
      *                      *-----------------------------------------*
      *                      * Se Start errata : ad uscita             *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A read-next                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-120.
      *              *-------------------------------------------------*
      *              * Se ordinamento fornitori per codice             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start per codice                            *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CODFNT    "         to   f-key                  .
           move      w-srt-cof-min        to   rf-dcf-cod-fnt         .
           move      spaces               to   rf-dcf-dpz-fnt         .
           move      "pgm/dcf/fls/ioc/obj/iofdcf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcf                 .
      *                      *-----------------------------------------*
      *                      * Se Start errata : ad uscita             *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A read-next                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-130.
      *              *-------------------------------------------------*
      *              * Se ordinamento fornitori per mnemonico          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start per mnemonico su archivio [fnt]       *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CODMNE    "         to   f-key                  .
           move      w-srt-mnf-min        to   rf-fnt-cod-mne         .
           move      zero                 to   rf-fnt-cod-fnt         .
           move      "pgm/cge/fls/ioc/obj/ioffnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fnt                 .
      *                      *-----------------------------------------*
      *                      * Se Start errata : ad uscita             *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A read-next                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Read-next su anagrafica fornitori               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Indicatore di programma in esecuzione       *
      *                  *---------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo ordinamento *
      *                  * fornitori                                   *
      *                  *---------------------------------------------*
           if        w-srt-ord-fnt        =    01
                     go to stp-srt-inp-210
           else if   w-srt-ord-fnt        =    02
                     go to stp-srt-inp-210
           else if   w-srt-ord-fnt        =    03
                     go to stp-srt-inp-230.
       stp-srt-inp-210.
      *              *-------------------------------------------------*
      *              * Se ordinamento fornitori per ragione sociale o  *
      *              * codice                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale archivio [dcf]          *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcf/fls/ioc/obj/iofdcf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcf                 .
      *                      *-----------------------------------------*
      *                      * Se lettura errata : ad uscita           *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A test-max                                  *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-300.
       stp-srt-inp-230.
      *              *-------------------------------------------------*
      *              * Se ordinamento fornitori per mnemonico          *
      *              * codice                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale archivio [fnt]          *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/ioffnt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fnt                 .
      *                      *-----------------------------------------*
      *                      * Se lettura errata : ad uscita           *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A test-max                                  *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-300.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Test-max su anagrafica fornitori                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo ordinamento *
      *                  * fornitori                                   *
      *                  *---------------------------------------------*
           if        w-srt-ord-fnt        =    01
                     go to stp-srt-inp-310
           else if   w-srt-ord-fnt        =    02
                     go to stp-srt-inp-320
           else if   w-srt-ord-fnt        =    03
                     go to stp-srt-inp-330.
       stp-srt-inp-310.
      *              *-------------------------------------------------*
      *              * Se ordinamento fornitori per ragione sociale    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su ragione sociale in chiave           *
      *                  *---------------------------------------------*
           if        rf-dcf-rag-key       >    w-srt-rsf-max
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A selezioni                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-400.
       stp-srt-inp-320.
      *              *-------------------------------------------------*
      *              * Se ordinamento fornitori per codice             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice                              *
      *                  *---------------------------------------------*
           if        rf-dcf-cod-fnt       >    w-srt-cof-max
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A selezioni                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-400.
       stp-srt-inp-330.
      *              *-------------------------------------------------*
      *              * Se ordinamento fornitori per mnemonico          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su mnemonico                           *
      *                  *---------------------------------------------*
           if        rf-fnt-cod-mne       >    w-srt-mnf-max
                     go to stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * A selezioni                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-400.
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni su anagrafica fornitori               *
      *              *-------------------------------------------------*
           perform   stp-srt-inp-sel-000  thru stp-srt-inp-sel-999    .
      *                  *---------------------------------------------*
      *                  * Test sul flag di uscita dalla routine di    *
      *                  * selezione                                   *
      *                  *---------------------------------------------*
           if        w-srt-sel-rec        not  = spaces
                     go to stp-srt-inp-200.
       stp-srt-inp-500.
      *              *-------------------------------------------------*
      *              * Selezioni supplementari su anagrafica fornitori *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale normalizzazione status            *
      *                  *---------------------------------------------*
           if        rf-dcf-sta-tus       not  numeric
                     move  01             to   rf-dcf-sta-tus         .
      *                  *---------------------------------------------*
      *                  * Subroutine                                  *
      *                  *---------------------------------------------*
           perform   stp-srt-inp-ssu-000  thru stp-srt-inp-ssu-999    .
      *                  *---------------------------------------------*
      *                  * Test sul flag di uscita dalla routine di    *
      *                  * selezione                                   *
      *                  *---------------------------------------------*
           if        w-srt-sel-rec        not  = spaces
                     go to stp-srt-inp-200.
       stp-srt-inp-600.
      *              *-------------------------------------------------*
      *              * Composizione area di sort                       *
      *              *-------------------------------------------------*
           perform   stp-srt-inp-cms-000  thru stp-srt-inp-cms-999    .
       stp-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Rilascio del record al sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-820.
      *              *-------------------------------------------------*
      *              * Composizione area di sort supplementare per le  *
      *              * dipendenze, solo in caso di ordinamento per co- *
      *              * dice mnemonico fornitori                        *
      *              *-------------------------------------------------*
           perform   stp-srt-inp-csu-000  thru stp-srt-inp-csu-999    .
       stp-srt-inp-880.
      *              *-------------------------------------------------*
      *              * Riciclo ad anagrafica fornitore successiva      *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Selezioni su anagrafica fornitori                         *
      *    *-----------------------------------------------------------*
       stp-srt-inp-sel-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-srt-sel-rec          .
      *              *-------------------------------------------------*
      *              * Normalizzazione chiavi di sort per anagrafiche  *
      *              * generiche                                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-srt-key-num          .
           move      spaces               to   w-srt-key-alf          .
           move      spaces               to   w-srt-key-al2          .
       stp-srt-inp-sel-010.
      *              *-------------------------------------------------*
      *              * In caso di ordinamento fornitori per mnemonico  *
      *              * si legge la relativa anagrafica [dcf]           *
      *              *-------------------------------------------------*
           if        w-srt-ord-fnt        not  = 03
                     go to stp-srt-inp-sel-050.
      *                  *---------------------------------------------*
      *                  * Lettura per codice record [dcf]             *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODFNT"             to   f-key                  .
           move      rf-fnt-cod-fnt       to   rf-dcf-cod-fnt         .
           move      spaces               to   rf-dcf-dpz-fnt         .
           move      "pgm/dcf/fls/ioc/obj/iofdcf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcf                 .
      *                      *-----------------------------------------*
      *                      * Se record [dcf] non trovato : uscita    *
      *                      * per selezione non superata              *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-sel-900.
       stp-srt-inp-sel-050.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del Tipo ordinamento     *
      *              * stampa                                          *
      *              *-------------------------------------------------*
           if        rr-tip-ors           =    01
                     go to stp-srt-inp-sel-100
           else if   rr-tip-ors           =    03
                     go to stp-srt-inp-sel-300
           else if   rr-tip-ors           =    04
                     go to stp-srt-inp-sel-400
           else if   rr-tip-ors           =    05
                     go to stp-srt-inp-sel-500
           else if   rr-tip-ors           =    07
                     go to stp-srt-inp-sel-a00
           else if   rr-tip-ors           =    11
                     go to stp-srt-inp-sel-610
           else if   rr-tip-ors           =    12
                     go to stp-srt-inp-sel-620
           else if   rr-tip-ors           =    13
                     go to stp-srt-inp-sel-630
           else if   rr-tip-ors           =    14
                     go to stp-srt-inp-sel-640
           else if   rr-tip-ors           =    21   or
                     rr-tip-ors           =    22
                     go to stp-srt-inp-sel-710
           else      go to stp-srt-inp-sel-800.
       stp-srt-inp-sel-100.
      *                  *---------------------------------------------*
      *                  * Se ordinamento per fornitore                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-sel-800.
       stp-srt-inp-sel-300.
      *                  *---------------------------------------------*
      *                  * Se ordinamento per zona                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se codice zona a zero : uscita per      *
      *                      * elemento non selezionato                *
      *                      *-----------------------------------------*
           if        rf-dcf-cod-zon       =    zero
                     go to stp-srt-inp-sel-900.
      *                      *-----------------------------------------*
      *                      * Lettura preliminare anagrafica zona     *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLS    "         to   f-key                  .
           move      01                   to   rf-yst-tip-cls         .
           move      rf-dcf-cod-zon       to   rf-yst-cod-cls         .
           move      "pgm/dcf/fls/ioc/obj/iofyst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-yst                 .
      *                          *-------------------------------------*
      *                          * Se record trovato : a selezioni     *
      *                          *-------------------------------------*
           if        f-sts                =    e-not-err
                     go to stp-srt-inp-sel-310.
      *                          *-------------------------------------*
      *                          * Se record non trovato               *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Normalizzazione record          *
      *                              *---------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcf/fls/ioc/obj/iofyst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-yst                 .
      *                              *---------------------------------*
      *                              * Normalizzazione descrizione     *
      *                              *---------------------------------*
           move      all "."              to   rf-yst-des-cls         .
      *                              *---------------------------------*
      *                              * Se ordinamento per codice : a   *
      *                              * selezione su solo codice        *
      *                              *---------------------------------*
           if        rr-ord-ana-zon       =    01
                     go to stp-srt-inp-sel-312.
      *                              *---------------------------------*
      *                              * Altrimenti                      *
      *                              *  - Se selezione totale : Ok     *
      *                              *  - In caso contrario   : Ko     *
      *                              *---------------------------------*
           if        rr-ord-ana-zon       =    02
                     if    rr-sel-zon-dei =    all " " and
                           rr-sel-zon-def =    all "z"
                           go to stp-srt-inp-sel-314
                     else  go to stp-srt-inp-sel-900
           else if   rr-ord-ana-zon       =    03
                     if    rr-sel-zon-mni =    all " " and
                           rr-sel-zon-mnf =    all "z"
                           go to stp-srt-inp-sel-314
                     else  go to stp-srt-inp-sel-900.
       stp-srt-inp-sel-310.
      *                      *-----------------------------------------*
      *                      * Selezioni su anagrafica zona            *
      *                      *-----------------------------------------*
           if        rf-yst-des-cls       >    rr-sel-zon-def or
                     rf-yst-des-cls       <    rr-sel-zon-dei
                     go to stp-srt-inp-sel-900.
           if        rf-yst-mne-cls       >    rr-sel-zon-mnf or
                     rf-yst-mne-cls       <    rr-sel-zon-mni
                     go to stp-srt-inp-sel-900.
       stp-srt-inp-sel-312.
           if        rf-yst-cod-cls       >    rr-sel-zon-cof or
                     rf-yst-cod-cls       <    rr-sel-zon-coi
                     go to stp-srt-inp-sel-900.
       stp-srt-inp-sel-314.
      *                      *-----------------------------------------*
      *                      * Preparazione chiavi per il sort         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Chiave numerica                     *
      *                          *-------------------------------------*
           move      rf-yst-cod-cls       to   w-srt-key-num          .
      *                          *-------------------------------------*
      *                          * Chiave alfanumerica                 *
      *                          *-------------------------------------*
           if        rr-ord-ana-zon       =    01
                     move  spaces         to   w-srt-key-alf
           else if   rr-ord-ana-zon       =    02
                     move  rf-yst-des-cls to   w-srt-key-alf
           else if   rr-ord-ana-zon       =    03
                     move  rf-yst-mne-cls to   w-srt-key-alf          .
      *                          *-------------------------------------*
      *                          * Chiave alfanumerica 2               *
      *                          *-------------------------------------*
           move      spaces               to   w-srt-key-al2          .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-sel-800.
       stp-srt-inp-sel-400.
      *                  *---------------------------------------------*
      *                  * Se ordinamento per categoria                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se codice categoria a zero : uscita per *
      *                      * elemento non selezionato                *
      *                      *-----------------------------------------*
           if        rf-dcf-cod-cat       =    zero
                     go to stp-srt-inp-sel-900.
      *                      *-----------------------------------------*
      *                      * Lettura preliminare anagrafica catego-  *
      *                      * ria                                     *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLS    "         to   f-key                  .
           move      02                   to   rf-yst-tip-cls         .
           move      rf-dcf-cod-cat       to   rf-yst-cod-cls         .
           move      "pgm/dcf/fls/ioc/obj/iofyst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-yst                 .
      *                          *-------------------------------------*
      *                          * Se record trovato : a selezioni     *
      *                          *-------------------------------------*
           if        f-sts                =    e-not-err
                     go to stp-srt-inp-sel-410.
      *                          *-------------------------------------*
      *                          * Se record non trovato               *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Normalizzazione record          *
      *                              *---------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcf/fls/ioc/obj/iofyst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-yst                 .
      *                              *---------------------------------*
      *                              * Normalizzazione descrizione     *
      *                              *---------------------------------*
           move      all "."              to   rf-yst-des-cls         .
      *                              *---------------------------------*
      *                              * Se ordinamento per codice : a   *
      *                              * selezione su solo codice        *
      *                              *---------------------------------*
           if        rr-ord-ana-cat       =    01
                     go to stp-srt-inp-sel-412.
      *                              *---------------------------------*
      *                              * Altrimenti                      *
      *                              *  - Se selezione totale : Ok     *
      *                              *  - In caso contrario   : Ko     *
      *                              *---------------------------------*
           if        rr-ord-ana-cat       =    02
                     if    rr-sel-cat-dei =    all " " and
