      *                  *---------------------------------------------*
           go to     acc-dcf-pfz-300.
       acc-dcf-pfz-100.
      *              *-------------------------------------------------*
      *              * Note operative                                  *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           move      "[F1] per sostituzione"
                                          to   v-not                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-dcf-ope      .
           move      w-tes-dcf-pfz        to   w-cod-mne-dcf-cod      .
           move      w-lpt-dcf-pfz-lin    to   w-cod-mne-dcf-lin      .
           move      w-lpt-dcf-pfz-pos    to   w-cod-mne-dcf-pos      .
           move      w-lpt-dcf-pfz-lin    to   w-cod-mne-dcf-rln      .
           move      w-lpt-dcf-pfz-pos    to   w-cod-mne-dcf-rps      .
           add       11                   to   w-cod-mne-dcf-rps      .
           move      zero                 to   w-cod-mne-dcf-vln      .
           move      zero                 to   w-cod-mne-dcf-vps      .
           move      zero                 to   w-cod-mne-dcf-lln      .
           move      zero                 to   w-cod-mne-dcf-lps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "[1] "               to   v-pfk (14)             .
           perform   cod-mne-dcf-cll-000  thru cod-mne-dcf-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-dcf-foi-000  thru cod-mne-dcf-foi-999    .
       acc-dcf-pfz-110.
           perform   cod-mne-dcf-cll-000  thru cod-mne-dcf-cll-999    .
           if        w-cod-mne-dcf-ope    =    "F+"
                     go to acc-dcf-pfz-115.
           if        w-cod-mne-dcf-ope    =    "AC"
                     go to acc-dcf-pfz-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-dcf-pfz-115.
           perform   cod-mne-dcf-foi-000  thru cod-mne-dcf-foi-999    .
           go to     acc-dcf-pfz-110.
       acc-dcf-pfz-120.
           move      w-cod-mne-dcf-cod    to   v-num                  .
