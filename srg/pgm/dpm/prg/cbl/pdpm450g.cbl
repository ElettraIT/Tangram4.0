      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      w-lpt-tmp-apv-lin    to   v-lin                  .
           subtract  1                    from v-lin                  .
           move      w-lpt-tmp-apv-pos    to   v-pos                  .
           subtract  1                    from v-pos                  .
           move      w-lpt-tmp-apv-lin    to   v-lto                  .
           add       1                    to   v-lto                  .
           move      w-lpt-tmp-apv-pos    to   v-pto                  .
           add       50                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-tmp-apv-sos-010.
      *                  *---------------------------------------------*
      *                  * Prompts per il box                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Valore da sostituire                    *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      15                   to   v-car                  .
           move      w-lpt-tmp-apv-lin    to   v-lin                  .
           move      w-lpt-tmp-apv-pos    to   v-pos                  .
           move      "Da sostituire :"    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Con                                     *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      w-lpt-tmp-apv-lin    to   v-lin                  .
           move      w-lpt-tmp-apv-pos    to   v-pos                  .
           add       29                   to   v-pos                  .
           move      "Con :"              to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in 'ON'                               *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-tmp-apv-sos-100.
      *              *-------------------------------------------------*
      *              * Visualizzazioni                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione valore da sostituire        *
      *                  *---------------------------------------------*
           perform   vis-tmp-apv-so1-000  thru vis-tmp-apv-so1-999    .
      *                  *---------------------------------------------*
      *                  * Visualizzazione valore sostitutivo          *
      *                  *---------------------------------------------*
           perform   vis-tmp-apv-so2-000  thru vis-tmp-apv-so2-999    .
       acc-tmp-apv-sos-200.
      *              *-------------------------------------------------*
      *              * Accettazioni                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore da sostituire                        *
      *                  *---------------------------------------------*
           perform   acc-tmp-apv-so1-000  thru acc-tmp-apv-so1-999    .
           if        w-cnt-tus-acc-key    not  = spaces
                     go to acc-tmp-apv-sos-600.
           if        v-key                =    "DOWN"
                     go to acc-tmp-apv-sos-600.
       acc-tmp-apv-sos-300.
      *                  *---------------------------------------------*
      *                  * Valore sostitutivo                          *
      *                  *---------------------------------------------*
           perform   acc-tmp-apv-so2-000  thru acc-tmp-apv-so2-999    .
           if        w-cnt-tus-acc-key    not  = spaces
                     go to acc-tmp-apv-sos-600.
           if        v-key                =    "UP  "
                     go to acc-tmp-apv-sos-200.
       acc-tmp-apv-sos-600.
      *              *-------------------------------------------------*
      *              * Controlli su valori accettati                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se i valori sono a zero : a dipendenze dal- *
      *                  * le impostazioni                             *
      *                  *---------------------------------------------*
           if        w-tes-tmp-apv        =    zero  and
                     w-tes-apv-sos        =    zero
                     go to acc-tmp-apv-sos-800.
      *                  *---------------------------------------------*
      *                  * Che i valori non siano uguali               *
      *                  *---------------------------------------------*
           if        w-tes-tmp-apv        not  = w-tes-apv-sos
                     go to acc-tmp-apv-sos-800.
      *                      *-----------------------------------------*
      *                      * Normalizzazione valore sostitutivo      *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-apv-sos          .
      *                      *-----------------------------------------*
      *                      * Segnale di sostituzione non effettuata  *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-tmp-apv-sns      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     acc-tmp-apv-sos-900.
       acc-tmp-apv-sos-800.
      *              *-------------------------------------------------*
      *              * Dipendenza dalle impostazioni                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Segnale di sostituzione effettuata          *
      *                  *---------------------------------------------*
           if        w-tes-tmp-apv        not  = zero or
                     w-tes-apv-sos        not  = zero
                     move  1              to   w-tes-tmp-apv-sns      .
       acc-tmp-apv-sos-900.
      *              *-------------------------------------------------*
      *              * Normalizzazione stato di uscita                 *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-key      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-tmp-apv-sos-999.
       acc-tmp-apv-sos-999.
           exit.

      *    *===========================================================*
