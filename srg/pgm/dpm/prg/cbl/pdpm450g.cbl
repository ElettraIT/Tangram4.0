      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore attuale                  *
      *                  *---------------------------------------------*
           move      w-tes-lot-acq        to   w-sav-lot-acq          .
      *                  *---------------------------------------------*
      *                  * Test se richiesta sostituzione              *
      *                  *---------------------------------------------*
           if        w-tes-lot-acq-sns    =    zero
                     go to acc-lot-acq-100.
      *                  *---------------------------------------------*
      *                  * Forzatura del tasto Pf1                     *
      *                  *---------------------------------------------*
           move      "[1] "               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * A test su Pf1                               *
      *                  *---------------------------------------------*
           go to     acc-lot-acq-300.
       acc-lot-acq-100.
      *              *-------------------------------------------------*
      *              * Note operative                                  *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           move      "[F1] per sostituzione"
                                          to   v-not                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      03                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-lpt-lot-acq-lin    to   v-lin                  .
           move      w-lpt-lot-acq-pos    to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "[1] "               to   v-pfk (14)             .
           move      w-tes-lot-acq        to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Cancellazione eventuali note operative          *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-lot-acq-999.
       acc-lot-acq-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-lot-acq          .
       acc-lot-acq-300.
      *              *-------------------------------------------------*
      *              * Se Pf1                                          *
      *              *-------------------------------------------------*
           if        v-key                not  = "[1] "
                     go to acc-lot-acq-400.
      *                  *---------------------------------------------*
      *                  * Subroutine di accettazione valore sostitu-  *
      *                  * tivo                                        *
      *                  *---------------------------------------------*
           perform   acc-lot-acq-sos-000  thru acc-lot-acq-sos-999    .
           if        w-cnt-tus-acc-key    not  = spaces
                     go to acc-lot-acq-999.
      *                  *---------------------------------------------*
      *                  * Visualizzazione sostituzione effettuata     *
      *                  *---------------------------------------------*
           perform   vis-lot-acq-sos-000  thru vis-lot-acq-sos-999    .
