      *                  * tivo                                        *
      *                  *---------------------------------------------*
           perform   acc-cla-map-sos-000  thru acc-cla-map-sos-999    .
           if        w-cnt-tus-acc-key    not  = spaces
                     go to acc-cla-map-999.
      *                  *---------------------------------------------*
      *                  * Visualizzazione sostituzione effettuata     *
      *                  *---------------------------------------------*
           perform   vis-cla-map-sos-000  thru vis-cla-map-sos-999    .
      *                  *---------------------------------------------*
      *                  * Se sostituzione non effettuata ma impostati *
      *                  * valori : rivisualizzazione valori impostati *
      *                  *---------------------------------------------*
           if        w-tes-cla-map-sns    not  = zero
                     go to acc-cla-map-800.
      *                  *---------------------------------------------*
      *                  * Visualizzazione codice impostato            *
      *                  *---------------------------------------------*
           perform   vis-cla-map-000      thru vis-cla-map-999        .
       acc-cla-map-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [zm1]                      *
      *                  *---------------------------------------------*
           move      w-tes-cla-map        to   w-let-arc-zm1-cla      .
           perform   let-arc-zm1-000      thru let-arc-zm1-999        .
      *                   *--------------------------------------------*
      *                   * Bufferizzazione di :                       *
      *                   * - Descrizione                              *
      *                   * - Ulteriore suddivisione                   *
      *                   * - Unita' di misura da proporre             *
      *                   *--------------------------------------------*
           if        w-tes-cla-map        =    zero
                     move  "Tutte"        to   w-tes-cla-map-des
           else      move  w-let-arc-zm1-des
                                          to   w-tes-cla-map-des      .
           move      w-let-arc-zm1-sud    to   w-tes-cla-map-sud      .
      *                   *--------------------------------------------*
      *                   * Visualizzazione descrizione                *
      *                   *--------------------------------------------*
           perform   vis-cla-map-des-000  thru vis-cla-map-des-999    .
       acc-cla-map-450.
      *                  *---------------------------------------------*
      *                  * Controllo con valori letti da filtro        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se codice a zero : nessun controllo     *
      *                      *-----------------------------------------*
           if        w-tes-cla-map        =    zero
                     go to acc-cla-map-600.
      *                      *-----------------------------------------*
      *                      * Controllo con codice min                *
      *                      *-----------------------------------------*
           if        w-zos-dpm-cla-min    =    zero
                     go to acc-cla-map-500.
           if        w-tes-cla-map        <    w-zos-dpm-cla-min
                     go to acc-cla-map-550.
       acc-cla-map-500.
      *                      *-----------------------------------------*
      *                      * Controllo con codice max                *
      *                      *-----------------------------------------*
           if        w-zos-dpm-cla-max    =    zero
                     go to acc-cla-map-600.
           if        w-tes-cla-map        >    w-zos-dpm-cla-max
                     go to acc-cla-map-550.
           go to     acc-cla-map-600.
       acc-cla-map-550.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Incompatibilita' con il filtro di selezione !   "
                                          to   w-box-msg-err-msg      .
      *                      *-----------------------------------------*
      *                      * Box di errore                           *
      *                      *-----------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
       acc-cla-map-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore impostato uguale a precedente :   *
      *                  * oltre                                       *
      *                  *---------------------------------------------*
           if        w-tes-cla-map        =    w-sav-cla-map
                     go to acc-cla-map-800.
      *                      *-----------------------------------------*
      *                      * Normalizzazione e visualizzazione dati  *
      *                      * gruppo merceologico                     *
      *                      *-----------------------------------------*
           if        w-tes-gru-map        =    zero
                     go to acc-cla-map-620.
           move      zero                 to   w-tes-gru-map          .
           move      spaces               to   w-tes-gru-map-des      .
           move      zero                 to   w-tes-gru-map-sud      .
           perform   vis-gru-map-000      thru vis-gru-map-999        .
           perform   vis-gru-map-des-000  thru vis-gru-map-des-999    .
       acc-cla-map-620.
      *                      *-----------------------------------------*
      *                      * Normalizzazione e visualizzazione dati  *
      *                      * sottogruppo merceologico                *
      *                      *-----------------------------------------*
           if        w-tes-sgr-map        =    zero
                     go to acc-cla-map-640.
           move      zero                 to   w-tes-sgr-map          .
           move      spaces               to   w-tes-sgr-map-des      .
           perform   vis-sgr-map-000      thru vis-sgr-map-999        .
           perform   vis-sgr-map-des-000  thru vis-sgr-map-des-999    .
       acc-cla-map-640.
       acc-cla-map-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-cla-map-999.
           perform   cnt-key-vuo-000      thru cnt-key-vuo-999        .
           if        w-cnt-key-vuo-flg    not  = spaces
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-cla-map-999.
           perform   cnt-tdo-key-000      thru cnt-tdo-key-999        .
           if        w-cnt-tdo-key-flg    not  = spaces
                     go to acc-cla-map-100
           else      move  "S"            to   w-cnt-tus-acc-key
                     go to acc-cla-map-999.
       acc-cla-map-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Classe merceologica       *
      *    *-----------------------------------------------------------*
       vis-cla-map-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-lpt-cla-map-lin    to   v-lin                  .
           move      w-lpt-cla-map-pos    to   v-pos                  .
           move      w-tes-cla-map        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cla-map-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione classe        *
      *    *-----------------------------------------------------------*
       vis-cla-map-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      w-lpt-cla-map-lin    to   v-lin                  .
           move      w-lpt-cla-map-pos    to   v-pos                  .
           add       11                   to   v-pos                  .
           move      w-tes-cla-map-des    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cla-map-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice classe                        *
      *    *                                                           *
      *    * Subroutine di sostituzione                                *
      *    *-----------------------------------------------------------*
       acc-cla-map-sos-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione segnale di sostituzione     *
      *                  *---------------------------------------------*
           move      zero                 to   w-tes-cla-map-sns      .
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      w-lpt-cla-map-lin    to   v-lin                  .
           subtract  1                    from v-lin                  .
           move      w-lpt-cla-map-pos    to   v-pos                  .
           subtract  1                    from v-pos                  .
           move      w-lpt-cla-map-lin    to   v-lto                  .
           add       1                    to   v-lto                  .
           move      w-lpt-cla-map-pos    to   v-pto                  .
           add       50                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cla-map-sos-010.
      *                  *---------------------------------------------*
      *                  * Prompts per il box                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Valore da sostituire                    *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      15                   to   v-car                  .
           move      w-lpt-cla-map-lin    to   v-lin                  .
           move      w-lpt-cla-map-pos    to   v-pos                  .
           move      "Da sostituire :"    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Con                                     *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      w-lpt-cla-map-lin    to   v-lin                  .
           move      w-lpt-cla-map-pos    to   v-pos                  .
           add       29                   to   v-pos                  .
           move      "Con :"              to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in 'ON'                               *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cla-map-sos-100.
      *              *-------------------------------------------------*
      *              * Visualizzazioni                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione valore da sostituire        *
      *                  *---------------------------------------------*
           perform   vis-cla-map-so1-000  thru vis-cla-map-so1-999    .
      *                  *---------------------------------------------*
      *                  * Visualizzazione valore sostitutivo          *
      *                  *---------------------------------------------*
           perform   vis-cla-map-so2-000  thru vis-cla-map-so2-999    .
       acc-cla-map-sos-200.
      *              *-------------------------------------------------*
      *              * Accettazioni                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore da sostituire                        *
      *                  *---------------------------------------------*
           perform   acc-cla-map-so1-000  thru acc-cla-map-so1-999    .
           if        w-cnt-tus-acc-key    not  = spaces
                     go to acc-cla-map-sos-600.
           if        v-key                =    "UP  "
                     go to acc-cla-map-sos-600.
           if        v-key                =    "DOWN"
                     go to acc-cla-map-sos-600.
       acc-cla-map-sos-300.
      *                  *---------------------------------------------*
      *                  * Valore sostitutivo                          *
      *                  *---------------------------------------------*
           perform   acc-cla-map-so2-000  thru acc-cla-map-so2-999    .
           if        w-cnt-tus-acc-key    not  = spaces
                     go to acc-cla-map-sos-600.
           if        v-key                =    "UP  "
                     go to acc-cla-map-sos-200.
       acc-cla-map-sos-600.
      *              *-------------------------------------------------*
      *              * Controlli su valori accettati                   *
      *              *-------------------------------------------------*
       acc-cla-map-sos-800.
      *              *-------------------------------------------------*
      *              * Dipendenza dalle impostazioni                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Segnale di sostituzione effettuata          *
      *                  *---------------------------------------------*
           if        w-tes-cla-map        not  = zero or
                     w-tes-cla-sos        not  = zero
                     move  1              to   w-tes-cla-map-sns      .
       acc-cla-map-sos-900.
      *              *-------------------------------------------------*
      *              * Normalizzazione stato di uscita                 *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-key      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-cla-map-sos-999.
       acc-cla-map-sos-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice classe                        *
      *    *                                                           *
      *    * Subroutine di visualizzazione sostituzione                *
      *    *-----------------------------------------------------------*
       vis-cla-map-sos-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del segnale di sostitu-  *
      *              * zione effettuata                                *
      *              *-------------------------------------------------*
           if        w-tes-cla-map-sns    =    zero
                     go to vis-cla-map-sos-100
           else      go to vis-cla-map-sos-500.
       vis-cla-map-sos-100.
      *              *-------------------------------------------------*
      *              * Se sostituzione non effettuata                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      50                   to   v-car                  .
           move      w-lpt-cla-map-lin    to   v-lin                  .
           move      w-lpt-cla-map-pos    to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     vis-cla-map-sos-900.
       vis-cla-map-sos-500.
      *              *-------------------------------------------------*
      *              * Se sostituzione effettuata                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing codice da sostituire                *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-tes-cla-map        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Concatenamento prima parte                  *
      *                  *---------------------------------------------*
           move      spaces               to   w-vis-lit-sos          .
           move      50                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      "( Sostituzione di :"
                                          to   w-all-str-cat (1)      .
           move      v-edt                to   w-all-str-cat (2)      .
           move      "- con :"            to   w-all-str-cat (3)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
           move      w-all-str-alf        to   w-vis-lit-sos          .
      *                  *---------------------------------------------*
      *                  * Editing codice sostitutivo                  *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-tes-cla-sos        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Concatenamento seconda parte                *
      *                  *---------------------------------------------*
           move      50                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      w-vis-lit-sos        to   w-all-str-cat (1)      .
           move      v-edt                to   w-all-str-cat (2)      .
           move      ")"                  to   w-all-str-cat (3)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
           move      w-all-str-alf        to   w-vis-lit-sos          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      50                   to   v-car                  .
           move      w-lpt-cla-map-lin    to   v-lin                  .
           move      w-lpt-cla-map-pos    to   v-pos                  .
           move      w-vis-lit-sos        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     vis-cla-map-sos-900.
       vis-cla-map-sos-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     vis-cla-map-sos-999.
       vis-cla-map-sos-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice classe                        *
      *    *                                                           *
      *    * Subroutine di accettazione valore da sostituire           *
      *    *-----------------------------------------------------------*
       acc-cla-map-so1-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione ventuale default               *
      *                  *---------------------------------------------*
           if        w-zos-dpm-cla-min    =    zero
                     go to acc-cla-map-so1-100.
           if        w-tes-cla-map        not  = zero
                     go to acc-cla-map-so1-100.
           move      w-zos-dpm-cla-min    to   w-tes-cla-map          .
       acc-cla-map-so1-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zm1-ope      .
           move      w-tes-cla-map        to   w-cod-mne-zm1-cla      .
           move      w-lpt-cla-map-lin    to   w-cod-mne-zm1-lin      .
           move      w-lpt-cla-map-pos    to   w-cod-mne-zm1-pos      .
           add       16                   to   w-cod-mne-zm1-pos      .
           move      zero                 to   w-cod-mne-zm1-dln      .
           move      zero                 to   w-cod-mne-zm1-dps      .
           move      "<"                  to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   cod-mne-zm1-cll-000  thru cod-mne-zm1-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zm1-foi-000  thru cod-mne-zm1-foi-999    .
       acc-cla-map-so1-110.
           perform   cod-mne-zm1-cll-000  thru cod-mne-zm1-cll-999    .
           if        w-cod-mne-zm1-ope    =    "F+"
                     go to acc-cla-map-so1-115.
           if        w-cod-mne-zm1-ope    =    "AC"
                     go to acc-cla-map-so1-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cla-map-so1-115.
           perform   cod-mne-zm1-foi-000  thru cod-mne-zm1-foi-999    .
           go to     acc-cla-map-so1-110.
       acc-cla-map-so1-120.
           move      w-cod-mne-zm1-cla    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-cla-map-so1-999.
       acc-cla-map-so1-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cla-map          .
       acc-cla-map-so1-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Controllo con valori letti da filtro        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controllo con codice min                *
      *                      *-----------------------------------------*
           if        w-zos-dpm-cla-min    =    zero
                     go to acc-cla-map-so1-500.
           if        w-tes-cla-map        <    w-zos-dpm-cla-min
                     go to acc-cla-map-so1-550.
       acc-cla-map-so1-500.
      *                      *-----------------------------------------*
      *                      * Controllo con codice max                *
      *                      *-----------------------------------------*
           if        w-zos-dpm-cla-max    =    zero
                     go to acc-cla-map-so1-600.
           if        w-tes-cla-map        >    w-zos-dpm-cla-max
                     go to acc-cla-map-so1-550.
           go to     acc-cla-map-so1-600.
       acc-cla-map-so1-550.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Incompatibilita' con il filtro di selezione !   "
                                          to   w-box-msg-err-msg      .
      *                      *-----------------------------------------*
      *                      * Box di errore                           *
      *                      *-----------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
       acc-cla-map-so1-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cla-map-so1-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-cla-map-so1-999.
           perform   cnt-key-vuo-000      thru cnt-key-vuo-999        .
           if        w-cnt-key-vuo-flg    not  = spaces
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-cla-map-so1-999.
           perform   cnt-tdo-key-000      thru cnt-tdo-key-999        .
           if        w-cnt-tdo-key-flg    not  = spaces
                     go to acc-cla-map-so1-100
           else      move  "S"            to   w-cnt-tus-acc-key
                     go to acc-cla-map-so1-999.
       acc-cla-map-so1-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice classe                     *
      *    *                                                           *
      *    * Subroutine di visualizzazione valore da sostituire        *
      *    *-----------------------------------------------------------*
       vis-cla-map-so1-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-lpt-cla-map-lin    to   v-lin                  .
           move      w-lpt-cla-map-pos    to   v-pos                  .
           add       16                   to   v-pos                  .
           move      w-tes-cla-map        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cla-map-so1-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice classe                        *
      *    *                                                           *
      *    * Subroutine di accettazione valore sostitutivo             *
      *    *-----------------------------------------------------------*
       acc-cla-map-so2-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-cla-map-so2-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zm1-ope      .
           move      w-tes-cla-sos        to   w-cod-mne-zm1-cla      .
           move      w-lpt-cla-map-lin    to   w-cod-mne-zm1-lin      .
           move      w-lpt-cla-map-pos    to   w-cod-mne-zm1-pos      .
           add       35                   to   w-cod-mne-zm1-pos      .
           move      zero                 to   w-cod-mne-zm1-dln      .
           move      zero                 to   w-cod-mne-zm1-dps      .
           move      "<"                  to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   cod-mne-zm1-cll-000  thru cod-mne-zm1-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zm1-foi-000  thru cod-mne-zm1-foi-999    .
       acc-cla-map-so2-110.
           perform   cod-mne-zm1-cll-000  thru cod-mne-zm1-cll-999    .
           if        w-cod-mne-zm1-ope    =    "F+"
                     go to acc-cla-map-so2-115.
           if        w-cod-mne-zm1-ope    =    "AC"
                     go to acc-cla-map-so2-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cla-map-so2-115.
           perform   cod-mne-zm1-foi-000  thru cod-mne-zm1-foi-999    .
           go to     acc-cla-map-so2-110.
       acc-cla-map-so2-120.
           move      w-cod-mne-zm1-cla    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-cla-map-so2-999.
       acc-cla-map-so2-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cla-sos          .
       acc-cla-map-so2-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-cla-map-so2-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cla-map-so2-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-cla-map-so2-999.
           perform   cnt-key-vuo-000      thru cnt-key-vuo-999        .
           if        w-cnt-key-vuo-flg    not  = spaces
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-cla-map-so2-999.
           perform   cnt-tdo-key-000      thru cnt-tdo-key-999        .
           if        w-cnt-tdo-key-flg    not  = spaces
                     go to acc-cla-map-so2-100
           else      move  "S"            to   w-cnt-tus-acc-key
                     go to acc-cla-map-so2-999.
       acc-cla-map-so2-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice classe                     *
      *    *                                                           *
      *    * Subroutine di visualizzazione valore sostitutivo          *
      *    *-----------------------------------------------------------*
       vis-cla-map-so2-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-lpt-cla-map-lin    to   v-lin                  .
           move      w-lpt-cla-map-pos    to   v-pos                  .
           add       35                   to   v-pos                  .
           move      w-tes-cla-sos        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cla-map-so2-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Gruppo merceologico          *
      *    *-----------------------------------------------------------*
       acc-gru-map-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se valore da accettare                 *
      *                  *---------------------------------------------*
           if        w-tes-cla-map        =    zero
                     go to acc-gru-map-999.
           if        w-tes-cla-map-sud    =    01
                     go to acc-gru-map-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-gru-map        to   w-sav-gru-map          .
      *                  *---------------------------------------------*
      *                  * Test se richiesta sostituzione              *
      *                  *---------------------------------------------*
           if        w-tes-gru-map-sns    =    zero
                     go to acc-gru-map-100.
      *                  *---------------------------------------------*
      *                  * Forzatura del tasto Pf1                     *
      *                  *---------------------------------------------*
           move      "[1] "               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * A test su Pf1                               *
      *                  *---------------------------------------------*
           go to     acc-gru-map-300.
       acc-gru-map-100.
      *              *-------------------------------------------------*
      *              * Note operative                                  *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           move      "[F1] per sostituzione"
                                          to   v-not                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zm2-ope      .
           move      w-tes-cla-map        to   w-cod-mne-zm2-cla      .
           move      w-tes-cla-map-des    to   w-cod-mne-zm2-dcl      .
           move      w-tes-gru-map        to   w-cod-mne-zm2-gru      .
           move      zero                 to   w-cod-mne-zm2-sgr      .
           move      w-lpt-gru-map-lin    to   w-cod-mne-zm2-lin      .
           move      w-lpt-gru-map-pos    to   w-cod-mne-zm2-pos      .
           move      w-lpt-gru-map-lin    to   w-cod-mne-zm2-dln      .
           move      w-lpt-gru-map-pos    to   w-cod-mne-zm2-dps      .
           add       11                   to   w-cod-mne-zm2-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "[1] "               to   v-pfk (14)             .
           perform   cod-mne-zm2-cll-000  thru cod-mne-zm2-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zm2-foi-000  thru cod-mne-zm2-foi-999    .
       acc-gru-map-110.
           perform   cod-mne-zm2-cll-000  thru cod-mne-zm2-cll-999    .
           if        w-cod-mne-zm2-ope    =    "F+"
                     go to acc-gru-map-115.
           if        w-cod-mne-zm2-ope    =    "AC"
                     go to acc-gru-map-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-gru-map-115.
           perform   cod-mne-zm2-foi-000  thru cod-mne-zm2-foi-999    .
           go to     acc-gru-map-110.
       acc-gru-map-120.
           move      w-cod-mne-zm2-gru    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Cancellazione eventuali note operative          *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-gru-map-999.
       acc-gru-map-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-gru-map          .
       acc-gru-map-300.
      *              *-------------------------------------------------*
      *              * Se Pf1                                          *
      *              *-------------------------------------------------*
           if        v-key                not  = "[1] "
                     go to acc-gru-map-400.
      *                  *---------------------------------------------*
      *                  * Subroutine di accettazione valore sostitu-  *
      *                  * tivo                                        *
      *                  *---------------------------------------------*
           perform   acc-gru-map-sos-000  thru acc-gru-map-sos-999    .
           if        w-cnt-tus-acc-key    not  = spaces
                     go to acc-gru-map-999.
      *                  *---------------------------------------------*
      *                  * Visualizzazione sostituzione effettuata     *
      *                  *---------------------------------------------*
           perform   vis-gru-map-sos-000  thru vis-gru-map-sos-999    .
      *                  *---------------------------------------------*
      *                  * Se sostituzione non effettuata ma impostati *
      *                  * valori : rivisualizzazione valori impostati *
      *                  *---------------------------------------------*
           if        w-tes-gru-map-sns    not  = zero
                     go to acc-gru-map-800.
      *                  *---------------------------------------------*
      *                  * Visualizzazione codice impostato            *
      *                  *---------------------------------------------*
           perform   vis-gru-map-000      thru vis-gru-map-999        .
       acc-gru-map-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [zm2]                      *
      *                  *---------------------------------------------*
           move      w-tes-cla-map        to   w-let-arc-zm2-cla      .
           move      w-tes-gru-map        to   w-let-arc-zm2-gru      .
           perform   let-arc-zm2-000      thru let-arc-zm2-999        .
      *                   *--------------------------------------------*
      *                   * Bufferizzazione di :                       *
      *                   * - Descrizione                              *
      *                   * - Ulteriore suddivisione                   *
      *                   * - Unita' di misura da proporre             *
      *                   *--------------------------------------------*
           move      w-let-arc-zm2-des    to   w-tes-gru-map-des      .
           move      w-let-arc-zm2-sud    to   w-tes-gru-map-sud      .
      *                   *--------------------------------------------*
      *                   * Visualizzazione descrizione                *
      *                   *--------------------------------------------*
           perform   vis-gru-map-des-000  thru vis-gru-map-des-999    .
       acc-gru-map-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore impostato uguale a precedente :   *
      *                  * oltre                                       *
      *                  *---------------------------------------------*
           if        w-tes-gru-map        =    w-sav-gru-map
                     go to acc-gru-map-800.
      *                      *-----------------------------------------*
      *                      * Normalizzazione e visualizzazione dati  *
      *                      * sottogruppo merceologico                *
      *                      *-----------------------------------------*
           if        w-tes-sgr-map        =    zero
                     go to acc-gru-map-640.
           move      zero                 to   w-tes-sgr-map          .
           move      spaces               to   w-tes-sgr-map-des      .
           perform   vis-sgr-map-000      thru vis-sgr-map-999        .
           perform   vis-sgr-map-des-000  thru vis-sgr-map-des-999    .
       acc-gru-map-640.
       acc-gru-map-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                not  = "DO  "
                     go to acc-gru-map-999.
           perform   cnt-key-vuo-000      thru cnt-key-vuo-999        .
           if        w-cnt-key-vuo-flg    not  = spaces
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-gru-map-999.
           perform   cnt-tdo-key-000      thru cnt-tdo-key-999        .
           if        w-cnt-tdo-key-flg    not  = spaces
                     go to acc-gru-map-100
           else      move  "S"            to   w-cnt-tus-acc-key
                     go to acc-gru-map-999.
       acc-gru-map-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Gruppo merceologico       *
      *    *-----------------------------------------------------------*
       vis-gru-map-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-lpt-gru-map-lin    to   v-lin                  .
           move      w-lpt-gru-map-pos    to   v-pos                  .
           move      w-tes-gru-map        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-gru-map-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione gruppo        *
      *    *-----------------------------------------------------------*
       vis-gru-map-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      w-lpt-gru-map-lin    to   v-lin                  .
           move      w-lpt-gru-map-pos    to   v-pos                  .
           add       11                   to   v-pos                  .
           move      w-tes-gru-map-des    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-gru-map-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice gruppo                        *
      *    *                                                           *
      *    * Subroutine di sostituzione                                *
      *    *-----------------------------------------------------------*
       acc-gru-map-sos-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione segnale di sostituzione     *
      *                  *---------------------------------------------*
           move      zero                 to   w-tes-gru-map-sns      .
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      w-lpt-gru-map-lin    to   v-lin                  .
           subtract  1                    from v-lin                  .
           move      w-lpt-gru-map-pos    to   v-pos                  .
           subtract  1                    from v-pos                  .
           move      w-lpt-gru-map-lin    to   v-lto                  .
           add       1                    to   v-lto                  .
           move      w-lpt-gru-map-pos    to   v-pto                  .
           add       50                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-gru-map-sos-010.
      *                  *---------------------------------------------*
      *                  * Prompts per il box                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Valore da sostituire                    *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      15                   to   v-car                  .
           move      w-lpt-gru-map-lin    to   v-lin                  .
           move      w-lpt-gru-map-pos    to   v-pos                  .
           move      "Da sostituire :"    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Con                                     *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      w-lpt-gru-map-lin    to   v-lin                  .
           move      w-lpt-gru-map-pos    to   v-pos                  .
           add       29                   to   v-pos                  .
           move      "Con :"              to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in 'ON'                               *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-gru-map-sos-100.
      *              *-------------------------------------------------*
      *              * Visualizzazioni                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione valore da sostituire        *
      *                  *---------------------------------------------*
           perform   vis-gru-map-so1-000  thru vis-gru-map-so1-999    .
      *                  *---------------------------------------------*
      *                  * Visualizzazione valore sostitutivo          *
      *                  *---------------------------------------------*
           perform   vis-gru-map-so2-000  thru vis-gru-map-so2-999    .
       acc-gru-map-sos-200.
      *              *-------------------------------------------------*
      *              * Accettazioni                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore da sostituire                        *
      *                  *---------------------------------------------*
           perform   acc-gru-map-so1-000  thru acc-gru-map-so1-999    .
           if        w-cnt-tus-acc-key    not  = spaces
                     go to acc-gru-map-sos-600.
           if        v-key                =    "UP  "
                     go to acc-gru-map-sos-600.
           if        v-key                =    "DOWN"
                     go to acc-gru-map-sos-600.
       acc-gru-map-sos-300.
      *                  *---------------------------------------------*
      *                  * Valore sostitutivo                          *
      *                  *---------------------------------------------*
           perform   acc-gru-map-so2-000  thru acc-gru-map-so2-999    .
           if        w-cnt-tus-acc-key    not  = spaces
                     go to acc-gru-map-sos-600.
           if        v-key                =    "UP  "
                     go to acc-gru-map-sos-200.
       acc-gru-map-sos-600.
      *              *-------------------------------------------------*
      *              * Controlli su valori accettati                   *
      *              *-------------------------------------------------*
       acc-gru-map-sos-800.
      *              *-------------------------------------------------*
      *              * Dipendenza dalle impostazioni                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Segnale di sostituzione effettuata          *
      *                  *---------------------------------------------*
           if        w-tes-gru-map        not  = zero or
                     w-tes-gru-sos        not  = zero
                     move  1              to   w-tes-gru-map-sns      .
       acc-gru-map-sos-900.
      *              *-------------------------------------------------*
      *              * Normalizzazione stato di uscita                 *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-key      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-gru-map-sos-999.
       acc-gru-map-sos-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Codice gruppo                        *
      *    *                                                           *
      *    * Subroutine di visualizzazione sostituzione                *
      *    *-----------------------------------------------------------*
       vis-gru-map-sos-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del segnale di sostitu-  *
      *              * zione effettuata                                *
      *              *-------------------------------------------------*
           if        w-tes-gru-map-sns    =    zero
                     go to vis-gru-map-sos-100
           else      go to vis-gru-map-sos-500.
       vis-gru-map-sos-100.
      *              *-------------------------------------------------*
      *              * Se sostituzione non effettuata                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      50                   to   v-car                  .
           move      w-lpt-gru-map-lin    to   v-lin                  .
           move      w-lpt-gru-map-pos    to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     vis-gru-map-sos-900.
       vis-gru-map-sos-500.
      *              *-------------------------------------------------*
      *              * Se sostituzione effettuata                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Editing codice da sostituire                *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-tes-gru-map        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Concatenamento prima parte                  *
      *                  *---------------------------------------------*
           move      spaces               to   w-vis-lit-sos          .
           move      50                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      "( Sostituzione di :"
                                          to   w-all-str-cat (1)      .
           move      v-edt                to   w-all-str-cat (2)      .
           move      "- con :"            to   w-all-str-cat (3)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
           move      w-all-str-alf        to   w-vis-lit-sos          .
      *                  *---------------------------------------------*
      *                  * Editing codice sostitutivo                  *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-tes-gru-sos        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Concatenamento seconda parte                *
      *                  *---------------------------------------------*
           move      50                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      w-vis-lit-sos        to   w-all-str-cat (1)      .
           move      v-edt                to   w-all-str-cat (2)      .
           move      ")"                  to   w-all-str-cat (3)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
           move      w-all-str-alf        to   w-vis-lit-sos          .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      50                   to   v-car                  .
