      *    *===========================================================*
      *    * Subroutines per l'accettazione del codice statistico 3    *
      *    *-----------------------------------------------------------*
       cmn-zms-003-opn-000.
           move      "pgm/dpm/prg/obj/acmnzms3"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           move      s-pat                to   w-cmn-zms-003-pth      .
           move      "OP"                 to   w-cmn-zms-003-ope      .
           perform   cmn-zms-003-cll-000  thru cmn-zms-003-cll-999    .
       cmn-zms-003-opn-999.
           exit.
       cmn-zms-003-cls-000.
           move      "CL"                 to   w-cmn-zms-003-ope      .
           perform   cmn-zms-003-cll-000  thru cmn-zms-003-cll-999    .
           move      "C?"                 to   w-cmn-zms-003-ope      .
           perform   cmn-zms-003-cll-000  thru cmn-zms-003-cll-999    .
           if        w-cmn-zms-003-ope    not  = spaces
                     go to cmn-zms-003-cls-999.
           cancel    w-cmn-zms-003-pth                                .
       cmn-zms-003-cls-999.
           exit.
       cmn-zms-003-foi-000.
           if        v-key                not  = "INSR"
                     go to cmn-zms-003-foi-500.
           move      "P?"                 to   s-ope                  .
           move      "pdpm1900"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to cmn-zms-003-foi-999.
           move      "pgm/dpm/prg/obj/pdpm1900"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
           move      "I+"                 to   w-cmn-zms-003-ope      .
           go to     cmn-zms-003-foi-999.
       cmn-zms-003-foi-500.
           if        v-key                not  = "FIND"
                     go to cmn-zms-003-foi-999.
           move      "P?"                 to   s-ope                  .
           move      "pdpm1910"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to cmn-zms-003-foi-999.
           move      "PV"                 to   s-ope                  .
           move      "fkselect"           to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      04                   to   s-car                  .
           move      "SLCT"               to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      "pgm/dpm/prg/obj/pdpm1910"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
           move      "F+"                 to   w-cmn-zms-003-ope      .
           go to     cmn-zms-003-foi-999.
       cmn-zms-003-foi-999.
           exit.
       cmn-zms-003-cll-000.
           call      w-cmn-zms-003-pth   using w-cmn-zms-003
                                               v
                                               s                      .
       cmn-zms-003-cll-999.
           exit.

