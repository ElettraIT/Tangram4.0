           move      w-det-num-mcp-dtf    to   w-det-num-mcp-wdt      .
           move      w-det-num-mcp-wme    to   w-det-num-mcp-wmf      .
           move      w-det-num-mcp-wsa    to   w-det-num-mcp-waf      .
      *              *-------------------------------------------------*
