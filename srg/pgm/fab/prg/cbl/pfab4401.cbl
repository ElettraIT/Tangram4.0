                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [fir]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/fat/fls/ioc/obj/ioffir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fir                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-qta-fat-200.
       det-qta-fat-130.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-fir-tip-mag       not  = w-det-qta-fat-tpm or
                     rf-fir-num-pro       not  = w-det-qta-fat-cnm or
