      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-exe-rou-srt      .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Start iniziale                     *
      *    *-----------------------------------------------------------*
       prn-str-ini-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
      *              *-------------------------------------------------*
      *              * Start filtro di ordinamento e selezione per il  *
      *              * file [dcp]                                      *
      *              *-------------------------------------------------*
           move      "ST"                 to   f-ope                  .
           move      rr-fso-dcp           to   f-key                  .
           perform   det-zos-dcp-cll-000  thru det-zos-dcp-cll-999    .
      *              *-------------------------------------------------*
      *              * Se errore su Start : uscita con flag a Eof      *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     move  "#"            to   w-cnt-prn-flg-sub
                     go to prn-str-ini-999.
       prn-str-ini-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Messaggio per nessuna registraz.   *
      *    *-----------------------------------------------------------*
       prn-nes-ela-000.
           move      "WR"                 to   m-ope                  .
           move      "Nessuna registrazione entro i limiti assegnati !"
                                          to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       prn-nes-ela-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Lettura sequenziale                *
      *    *-----------------------------------------------------------*
       prn-let-seq-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
      *              *-------------------------------------------------*
      *              * Read Next filtro di ordinamento e selezione per *
      *              * file [dcp]                                      *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           perform   det-zos-dcp-cll-000  thru det-zos-dcp-cll-999    .
      *              *-------------------------------------------------*
      *              * Se At End : uscita con flag a Eof               *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     move  "#"            to   w-cnt-prn-flg-sub
                     go to prn-let-seq-999.
       prn-let-seq-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Test se superamento limiti massimi *
      *    *-----------------------------------------------------------*
       prn-tst-max-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
       prn-tst-max-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Selezione su record letto          *
      *    *-----------------------------------------------------------*
       prn-sel-rec-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
      *              *-------------------------------------------------*
      *              * Test su tipo prodotto                           *
      *              *-------------------------------------------------*
           if        rf-dcp-tip-pro       not  = 01
                     move  "#"            to   w-cnt-prn-flg-sub
                     go to prn-sel-rec-999.
      *              *-------------------------------------------------*
      *              * Determinazione buffer dei fabbisogni/disponibi- *
      *              * lita'                                           *
      *              *-------------------------------------------------*
           move      "DT"                 to   d-buf-fod-tip-ope      .
           move      w-gen-dat-att        to   d-buf-fod-dat-ela      .
           move      rr-dpz-inu           to   d-buf-fod-cod-dpz      .
           move      01                   to   d-buf-fod-tip-mag      .
           move      rf-dcp-num-pro       to   d-buf-fod-num-mag      .
           move      01                   to   d-buf-fod-tip-crg      .
           move      01                   to   d-buf-fod-snx-oav      .
           perform   det-buf-fod-cll-000  thru det-buf-fod-cll-999    .
      *              *-------------------------------------------------*
      *              * Se quantita' totale in ordine a fornitori a ze- *
      *              * ro : selezione non superata                     *
      *              *-------------------------------------------------*
           if        d-buf-fod-qta-oaf    =    zero
                     move  "#"            to   w-cnt-prn-flg-sub
                     go to prn-sel-rec-999.
      *              *-------------------------------------------------*
      *              * Determinazione quantita' vendute medie ultimi   *
      *              * n mesi per il prodotto                          *
      *              *-------------------------------------------------*
           move      w-gen-dat-att        to   w-det-vem-unm-dtb      .
           move      01                   to   w-det-vem-unm-tpm      .
           move      rf-dcp-num-pro       to   w-det-vem-unm-cnm      .
           move      w-ref-fab-420-nmc    to   w-det-vem-unm-nmc      .
           move      w-ref-fab-420-mde    to   w-det-vem-unm-mde      .
           move      w-ref-fab-420-ncm    to   w-det-vem-unm-ncc      .
           perform   det-vem-unm-000      thru det-vem-unm-999        .
      *              *-------------------------------------------------*
      *              * Determinazione buffer delle disponibilita' per  *
      *              * i prossimi 6 mesi                               *
      *              *-------------------------------------------------*
           move      w-gen-dat-att        to   w-det-qta-ecc-dtb      .
           move      w-det-vem-unm-qta    to   w-det-qta-ecc-qvm      .
           move      rr-pdm-imm           to   w-det-qta-ecc-ptm      .
           move      w-ref-fab-420-mde    to   w-det-qta-ecc-mde      .
           move      w-ref-fab-420-ncm    to   w-det-qta-ecc-nco      .
           perform   det-qta-ecc-000      thru det-qta-ecc-999        .
      *              *-------------------------------------------------*
      *              * Test se esistono quantita' in eccedenza mensili *
      *              *-------------------------------------------------*
           if        w-det-qta-ecc-qec (1)
                                          >    zero or
                     w-det-qta-ecc-qec (2)
                                          >    zero or
                     w-det-qta-ecc-qec (3)
                                          >    zero or
                     w-det-qta-ecc-qec (4)
                                          >    zero or
                     w-det-qta-ecc-qec (5)
                                          >    zero or
                     w-det-qta-ecc-qec (6)
                                          >    zero
                     go to prn-sel-rec-999
           else      move  "#"            to   w-cnt-prn-flg-sub      .
       prn-sel-rec-999.
           exit.

      *    *===========================================================*
      *    * Determinazione quantita' vendute medie ultimi n mesi per  *
      *    * il prodotto                                               *
      *    *-----------------------------------------------------------*
       det-vem-unm-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore in uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-vem-unm-qta      .
      *              *-------------------------------------------------*
      *              * Determinazione data iniziale per scansione      *
      *              *-------------------------------------------------*
           move      w-det-vem-unm-dtb    to   w-det-vem-unm-wdt      .
           move      01                   to   w-det-vem-unm-wgi      .
           move      zero                 to   w-det-vem-unm-c01      .
       det-vem-unm-020.
           add       1                    to   w-det-vem-unm-c01      .
           if        w-det-vem-unm-c01    >    w-det-vem-unm-nmc
                     go to det-vem-unm-040.
       det-vem-unm-030.
           subtract  1                    from w-det-vem-unm-wme      .
           if        w-det-vem-unm-mde    not  = zero        and
                     w-det-vem-unm-wme    =    w-det-vem-unm-mde
                     go to det-vem-unm-030.
           if        w-det-vem-unm-wme    =    zero
                     move  12             to   w-det-vem-unm-wme
                     subtract 1           from w-det-vem-unm-wsa      .
           go to     det-vem-unm-020.
       det-vem-unm-040.
           move      w-det-vem-unm-wdt    to   w-det-vem-unm-wdi      .
      *              *-------------------------------------------------*
      *              * Determinazione data finale per scansione        *
      *              *-------------------------------------------------*
           move      w-det-vem-unm-dtb    to   w-det-vem-unm-wdt      .
           move      31                   to   w-det-vem-unm-wgi      .
           subtract  1                    from w-det-vem-unm-wme      .
           if        w-det-vem-unm-mde    not  = zero        and
                     w-det-vem-unm-wme    =    w-det-vem-unm-mde
                     go to det-vem-unm-020.
           if        w-det-vem-unm-wme    =    zero
                     move  12             to   w-det-vem-unm-wme
                     subtract 1           from w-det-vem-unm-wsa      .
           move      w-det-vem-unm-wdt    to   w-det-vem-unm-wdf      .
       det-vem-unm-100.
      *              *-------------------------------------------------*
      *              * Inizializzazione area per rottura anno/mese     *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-vem-unm-wra      .
           move      zero                 to   w-det-vem-unm-wrm      .
      *              *-------------------------------------------------*
      *              * Inizializzazione numero elementi in tabella     *
      *              * quantita' vendute                               *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-vem-unm-ele      .
      *              *-------------------------------------------------*
      *              * Start su file [fir]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "PRODAT    "         to   f-key                  .
           move      w-det-vem-unm-tpm    to   rf-fir-tip-mag         .
           move      w-det-vem-unm-cnm    to   rf-fir-num-pro         .
           move      w-det-vem-unm-wdi    to   rf-fir-dat-doc         .
           move      zero                 to   rf-fir-num-prt         .
           move      zero                 to   rf-fir-num-prg         .
           move      "pgm/fat/fls/ioc/obj/ioffir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fir                 .
      *              *-------------------------------------------------*
      *              * Test su esito operazione                        *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-vem-unm-200.
       det-vem-unm-120.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [fir]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/fat/fls/ioc/obj/ioffir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fir                 .
      *              *-------------------------------------------------*
      *              * Test se 'At End'                                *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-vem-unm-200.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-fir-tip-mag       not  = w-det-vem-unm-tpm or
                     rf-fir-num-pro       not  = w-det-vem-unm-cnm or
                     rf-fir-dat-doc       >    w-det-vem-unm-wdf
                     go to det-vem-unm-200.
      *              *-------------------------------------------------*
      *              * Selezione sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo riga                           *
      *                  *---------------------------------------------*
           if        rf-fir-tip-rig (1:1) not  = "P" or
                     rf-fir-tip-rig (2:1) not  = " "
                     go to det-vem-unm-120.
      *                  *---------------------------------------------*
      *                  * Test su mese da escludere                   *
      *                  *---------------------------------------------*
           move      rf-fir-dat-doc       to   w-det-vem-unm-wdt      .
           if        w-det-vem-unm-mde    not  = zero and
                     w-det-vem-unm-wme    =    w-det-vem-unm-mde
                     go to det-vem-unm-120.
      *                  *---------------------------------------------*
      *                  * Lettura record [fit]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-fir-num-prt       to   rf-fit-num-prt         .
           move      "pgm/fat/fls/ioc/obj/ioffit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fit                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-vem-unm-120.
      *                  *---------------------------------------------*
      *                  * Test su tipo documento                      *
      *                  *---------------------------------------------*
           if        rf-fit-tip-doc       =    03 or
                     rf-fit-tip-doc       =    04
                     go to det-vem-unm-120.
      *              *-------------------------------------------------*
      *              * Se rottura mese                                 *
      *              *-------------------------------------------------*
           move      rf-fir-dat-doc       to   w-det-vem-unm-wdt      .
           if        w-det-vem-unm-wsa    =    w-det-vem-unm-wra and
                     w-det-vem-unm-wme    =    w-det-vem-unm-wrm
                     go to det-vem-unm-140.
      *                  *---------------------------------------------*
      *                  * Aggiornamento rottura anno/mese             *
      *                  *---------------------------------------------*
           move      w-det-vem-unm-wsa    to   w-det-vem-unm-wra      .
           move      w-det-vem-unm-wme    to   w-det-vem-unm-wrm      .
      *                  *---------------------------------------------*
      *                  * Incremento numero elementi in tabella       *
      *                  *---------------------------------------------*
           add       1                    to   w-det-vem-unm-ele      .
      *                  *---------------------------------------------*
      *                  * Inizializzazione nuovo elemento             *
      *                  *---------------------------------------------*
           move      w-det-vem-unm-wsa    to   w-det-vem-unm-saa
                                              (w-det-vem-unm-ele)     .
           move      w-det-vem-unm-wme    to   w-det-vem-unm-mes
                                              (w-det-vem-unm-ele)     .
           move      zero                 to   w-det-vem-unm-clf
                                              (w-det-vem-unm-ele, 1)  .
           move      zero                 to   w-det-vem-unm-clf
                                              (w-det-vem-unm-ele, 2)  .
           move      zero                 to   w-det-vem-unm-clf
                                              (w-det-vem-unm-ele, 3)  .
           move      zero                 to   w-det-vem-unm-clf
                                              (w-det-vem-unm-ele, 4)  .
           move      zero                 to   w-det-vem-unm-qtf
                                              (w-det-vem-unm-ele)     .
       det-vem-unm-140.
      *              *-------------------------------------------------*
      *              * Aggiornamento progressivi anno/mese             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Clienti fatturati                           *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-vem-unm-c01      .
       det-vem-unm-142.
           add       1                    to   w-det-vem-unm-c01      .
           if        w-det-vem-unm-c01    >    w-det-vem-unm-ncc
                     go to det-vem-unm-150.
           if        w-det-vem-unm-clf
                    (w-det-vem-unm-ele,
                     w-det-vem-unm-c01)   =    zero
                     go to det-vem-unm-144.
           if        rf-fir-cod-cli       =    w-det-vem-unm-clf
                                              (w-det-vem-unm-ele,
                                               w-det-vem-unm-c01)
                     go to det-vem-unm-150.
           go to     det-vem-unm-142.
       det-vem-unm-144.
           move      rf-fir-cod-cli       to   w-det-vem-unm-clf
                                              (w-det-vem-unm-ele,
                                               w-det-vem-unm-c01)     .
       det-vem-unm-150.
      *                  *---------------------------------------------*
      *                  * Progressivo quantita' fatturate             *
      *                  *---------------------------------------------*
           add       rf-fir-qta-ven       to   w-det-vem-unm-qtf
                                              (w-det-vem-unm-ele)     .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale record [fir]     *
      *              *-------------------------------------------------*
           go to     det-vem-unm-120.
       det-vem-unm-200.
      *              *-------------------------------------------------*
      *              * Determinazione quantita' totale fatturata e il  *
      *              * relativo numero mesi                            *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-vem-unm-wnm      .
           move      zero                 to   w-det-vem-unm-wqt      .
           move      zero                 to   w-det-vem-unm-c01      .
       det-vem-unm-220.
           add       1                    to   w-det-vem-unm-c01      .
           if        w-det-vem-unm-c01    >    w-det-vem-unm-ele
                     go to det-vem-unm-300.
      *                  *---------------------------------------------*
      *                  * Se cliente fatturato significativo minimo a *
      *                  * zero : il mese non e' da prendere in consi- *
      *                  * derazione                                   *
      *                  *---------------------------------------------*
           if        w-det-vem-unm-clf
                    (w-det-vem-unm-c01,
                     w-det-vem-unm-ncc)   =    zero
                     go to det-vem-unm-220.
      *                  *---------------------------------------------*
      *                  * Aggiornamento numero mesi da considerare    *
      *                  * nella media                                 *
      *                  *---------------------------------------------*
           add       1                    to   w-det-vem-unm-wnm      .
      *                  *---------------------------------------------*
      *                  * Aggiornamento quantita' totale da conside-  *
      *                  * rare nella media                            *
      *                  *---------------------------------------------*
           add       w-det-vem-unm-qtf
                    (w-det-vem-unm-c01)   to   w-det-vem-unm-wqt      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-vem-unm-220.
       det-vem-unm-300.
      *              *-------------------------------------------------*
      *              * Se numero mesi da considerare nella media a ze- *
      *              * ro : Uscita                                     *
      *              *-------------------------------------------------*
           if        w-det-vem-unm-wnm    =    zero
                     go to det-vem-unm-999.
      *              *-------------------------------------------------*
      *              * Se quantita' totale da considerare nella media  *
      *              * a zero : Uscita                                 *
      *              *-------------------------------------------------*
           if        w-det-vem-unm-wqt    =    zero
                     go to det-vem-unm-999.
      *              *-------------------------------------------------*
      *              * Determinazione quantita' fatturata media        *
      *              *-------------------------------------------------*
           divide    w-det-vem-unm-wnm    into w-det-vem-unm-wqt
                                        giving w-det-vem-unm-qta
                                               rounded                .
       det-vem-unm-999.
           exit.

      *    *===========================================================*
      *    * Determinazione quantita' in eccedenza                     *
      *    *-----------------------------------------------------------*
       det-qta-ecc-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione buffer                         *
      *              *-------------------------------------------------*
           move      w-det-qta-ecc-dtb    to   w-det-qta-ecc-wdt      .
           move      zero                 to   w-det-qta-ecc-c01      .
       det-qta-ecc-020.
           add       1                    to   w-det-qta-ecc-c01      .
           if        w-det-qta-ecc-c01    >    6
                     go to det-qta-ecc-040.
       det-qta-ecc-030.
           add       1                    to   w-det-qta-ecc-wme      .
           if        w-det-qta-ecc-mde    not  = zero and
                     w-det-qta-ecc-wme    =    w-det-qta-ecc-mde
                     go to det-qta-ecc-030.
           if        w-det-qta-ecc-wme    >    12
                     move  01             to   w-det-qta-ecc-wme
                     add   01             to   w-det-qta-ecc-wsa      .
      *                  *---------------------------------------------*
      *                  * Inizializzazione elemento del buffer        *
      *                  *---------------------------------------------*
           move      w-det-qta-ecc-wsa    to   w-det-qta-ecc-saa
                                              (w-det-qta-ecc-c01)     .
           move      w-det-qta-ecc-wme    to   w-det-qta-ecc-mes
                                              (w-det-qta-ecc-c01)     .
           move      zero                 to   w-det-qta-ecc-qof
                                              (w-det-qta-ecc-c01)     .
           move      zero                 to   w-det-qta-ecc-qic
                                              (w-det-qta-ecc-c01)     .
           move      zero                 to   w-det-qta-ecc-cio
                                              (w-det-qta-ecc-c01, 1)  .
           move      zero                 to   w-det-qta-ecc-cio
                                              (w-det-qta-ecc-c01, 2)  .
           move      zero                 to   w-det-qta-ecc-cio
                                              (w-det-qta-ecc-c01, 3)  .
           move      zero                 to   w-det-qta-ecc-cio
                                              (w-det-qta-ecc-c01, 4)  .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-qta-ecc-020.
       det-qta-ecc-040.
      *              *-------------------------------------------------*
      *              * Determinazione data saldo iniziale              *
      *              *-------------------------------------------------*
           move      01                   to   w-det-qta-ecc-wgi      .
           move      w-det-qta-ecc-mes (1)
                                          to   w-det-qta-ecc-wme      .
           move      w-det-qta-ecc-saa (1)
                                          to   w-det-qta-ecc-wsa      .
           move      w-det-qta-ecc-wdt    to   w-det-qta-ecc-wds      .
      *              *-------------------------------------------------*
      *              * Inizializzazione saldo iniziale                 *
      *              *-------------------------------------------------*
           move      zero                 to    w-det-qta-ecc-wqs     .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione buffer delle disponibilita'  *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-qta-ecc-c01      .
       det-qta-ecc-100.
           add       1                    to   w-det-qta-ecc-c01      .
           if        w-det-qta-ecc-c01    >    d-buf-fod-num-ele
                     go to det-qta-ecc-300.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo record          *
      *              *-------------------------------------------------*
           if        d-buf-fod-tip-rec
                    (w-det-qta-ecc-c01)   =    00
                     go to det-qta-ecc-120
           else if   d-buf-fod-tip-rec
                    (w-det-qta-ecc-c01)   =    10 or
                     d-buf-fod-tip-rec
                    (w-det-qta-ecc-c01)   =    40
                     go to det-qta-ecc-140
           else if   d-buf-fod-tip-rec
                    (w-det-qta-ecc-c01)   =    20 or
                     d-buf-fod-tip-rec
                    (w-det-qta-ecc-c01)   =    50
                     go to det-qta-ecc-160
           else if   d-buf-fod-tip-rec
                    (w-det-qta-ecc-c01)   =    30
                     go to det-qta-ecc-180.
       det-qta-ecc-120.
      *              *-------------------------------------------------*
      *              * Tipo record : 00 - Giacenza                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Aggiornamento saldo iniziale                *
      *                  *---------------------------------------------*
           add       d-buf-fod-qta-ioc
                    (w-det-qta-ecc-c01)   to   w-det-qta-ecc-wqs      .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     det-qta-ecc-200.
       det-qta-ecc-140.
      *              *-------------------------------------------------*
      *              * Tipo record : 10 o 40 - Fornitori               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se data consegna prevista inferiore alla    *
      *                  * data saldo iniziale : aggiornamento saldo   *
      *                  * iniziale                                    *
      *                  *---------------------------------------------*
           if        d-buf-fod-dcn-prv
                    (w-det-qta-ecc-c01)   <    w-det-qta-ecc-wds
                     add   d-buf-fod-qta-ioc
                          (w-det-qta-ecc-c01)
                                          to   w-det-qta-ecc-wqs
                     go to det-qta-ecc-200.
      *                  *---------------------------------------------*
      *                  * Test su mese escluso                        *
      *                  *---------------------------------------------*
           move      d-buf-fod-dcn-prv
                    (w-det-qta-ecc-c01)   to   w-det-qta-ecc-wdt      .
           if        w-det-qta-ecc-mde    not  = zero and
                     w-det-qta-ecc-wme    =    w-det-qta-ecc-mde
                     go to det-qta-ecc-200.
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione buffer                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-qta-ecc-c02      .
       det-qta-ecc-142.
           add       1                    to   w-det-qta-ecc-c02      .
           if        w-det-qta-ecc-c02    >    6
                     move  6              to   w-det-qta-ecc-c02
                     go to det-qta-ecc-144.
      *                  *---------------------------------------------*
      *                  * Ricerca dell'elemento corrispondente        *
      *                  *---------------------------------------------*
           move      d-buf-fod-dcn-prv
                    (w-det-qta-ecc-c01)   to   w-det-qta-ecc-wdt      .
           if        w-det-qta-ecc-wsa    =    w-det-qta-ecc-saa
                                              (w-det-qta-ecc-c02) and
                     w-det-qta-ecc-wme    =    w-det-qta-ecc-mes
                                              (w-det-qta-ecc-c02)
                     go to det-qta-ecc-144.
           go to     det-qta-ecc-142.
       det-qta-ecc-144.
      *                  *---------------------------------------------*
      *                  * Aggiornamento elemento                      *
      *                  *---------------------------------------------*
           add       d-buf-fod-qta-ioc
                    (w-det-qta-ecc-c01)   to   w-det-qta-ecc-qof
                                              (w-det-qta-ecc-c02)     .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     det-qta-ecc-200.
       det-qta-ecc-160.
      *              *-------------------------------------------------*
      *              * Tipo record : 20 o 50 - Clienti                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se data consegna richiesta inferiore alla   *
      *                  * data saldo iniziale : aggiornamento saldo   *
      *                  * iniziale                                    *
      *                  *---------------------------------------------*
           if        d-buf-fod-dcn-ric
                    (w-det-qta-ecc-c01)   <    w-det-qta-ecc-wds
                     subtract d-buf-fod-qta-ioc
                             (w-det-qta-ecc-c01)
                                          from w-det-qta-ecc-wqs
                     go to det-qta-ecc-200.
      *                  *---------------------------------------------*
      *                  * Test su mese escluso                        *
      *                  *---------------------------------------------*
           move      d-buf-fod-dcn-ric
                    (w-det-qta-ecc-c01)   to   w-det-qta-ecc-wdt      .
           if        w-det-qta-ecc-mde    not  = zero and
                     w-det-qta-ecc-wme    =    w-det-qta-ecc-mde
                     go to det-qta-ecc-200.
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione buffer                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-qta-ecc-c02      .
       det-qta-ecc-162.
           add       1                    to   w-det-qta-ecc-c02      .
           if        w-det-qta-ecc-c02    >    6
                     move  6              to   w-det-qta-ecc-c02
                     go to det-qta-ecc-164.
      *                  *---------------------------------------------*
      *                  * Ricerca dell'elemento corrispondente        *
      *                  *---------------------------------------------*
           move      d-buf-fod-dcn-ric
                    (w-det-qta-ecc-c01)   to   w-det-qta-ecc-wdt      .
           if        w-det-qta-ecc-wsa    =    w-det-qta-ecc-saa
                                              (w-det-qta-ecc-c02) and
                     w-det-qta-ecc-wme    =    w-det-qta-ecc-mes
                                              (w-det-qta-ecc-c02)
                     go to det-qta-ecc-164.
           go to     det-qta-ecc-162.
       det-qta-ecc-164.
      *                  *---------------------------------------------*
      *                  * Aggiornamento elemento                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Clienti in ordine                       *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-qta-ecc-c03      .
       det-qta-ecc-166.
           add       1                    to   w-det-qta-ecc-c03      .
           if        w-det-qta-ecc-c03    >    w-det-qta-ecc-nco
                     go to det-qta-ecc-170.
           if        w-det-qta-ecc-cio
                    (w-det-qta-ecc-c02,
                     w-det-qta-ecc-c03)   =    zero
                     go to det-qta-ecc-168.
           if        d-buf-fod-cod-arc
                    (w-det-qta-ecc-c01)   =    w-det-qta-ecc-cio
                                              (w-det-qta-ecc-c02,
                                               w-det-qta-ecc-c03)
                     go to det-qta-ecc-170.
           go to     det-qta-ecc-166.
       det-qta-ecc-168.
           move      d-buf-fod-cod-arc
                    (w-det-qta-ecc-c01)   to   w-det-qta-ecc-cio
                                              (w-det-qta-ecc-c02,
                                               w-det-qta-ecc-c03)     .
       det-qta-ecc-170.
      *                      *-----------------------------------------*
      *                      * Progressivo quantita' impegnate da cli- *
      *                      * enti nel mese                           *
      *                      *-----------------------------------------*
           add       d-buf-fod-qta-ioc
                    (w-det-qta-ecc-c01)   to   w-det-qta-ecc-qic
                                              (w-det-qta-ecc-c02)     .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     det-qta-ecc-200.
       det-qta-ecc-180.
      *              *-------------------------------------------------*
      *              * Tipo record : 30 - Elemento dell'orizzonte      *
      *              *                    temporale                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     det-qta-ecc-200.
       det-qta-ecc-200.
      *              *-------------------------------------------------*
      *              * Riciclo su scansione buffer dei fabbisogni/di-  *
      *              * sponibilita'                                    *
      *              *-------------------------------------------------*
           go to     det-qta-ecc-100.
       det-qta-ecc-300.
      *              *-------------------------------------------------*
      *              * Aggiustamento saldo iniziale con quantita' in   *
      *              * corso di spedizione                             *
      *              *-------------------------------------------------*
           subtract  d-buf-fod-qta-ics    from w-det-qta-ecc-wqs      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione buffer per aggiustamento     *
      *              * quantita' ordinate da clienti                   *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-qta-ecc-c01      .
       det-qta-ecc-320.
           add       1                    to   w-det-qta-ecc-c01      .
           if        w-det-qta-ecc-c01    >    6
                     go to det-qta-ecc-400.
      *                  *---------------------------------------------*
      *                  * Confronto quantita' impegnata da clienti    *
      *                  * nel mese e quantita' venduta media negli    *
      *                  * ultimi n mesi                               *
      *                  *---------------------------------------------*
           if        w-det-qta-ecc-qic
                    (w-det-qta-ecc-c01)   >    w-det-qta-ecc-qvm
                     go to det-qta-ecc-340
           else      go to det-qta-ecc-360.
       det-qta-ecc-340.
      *                  *---------------------------------------------*
      *                  * Se maggiore                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda del numero di cli- *
      *                      * enti con ordini nel mese                *
      *                      *-----------------------------------------*
           if        w-det-qta-ecc-cio
                    (w-det-qta-ecc-c01,
                     w-det-qta-ecc-nco)   =    zero
                     go to det-qta-ecc-342
           else      go to det-qta-ecc-344.
       det-qta-ecc-342.
      *                      *-----------------------------------------*
      *                      * Se inferiore al minimo                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Base per determinazione quantita'   *
      *                          * in tolleranza : quantita' media     *
      *                          * venduta negli ultimi n mesi         *
      *                          *-------------------------------------*
           move      w-det-qta-ecc-qvm    to   w-det-qta-ecc-wbt      .
      *                          *-------------------------------------*
      *                          * A determinazione quantita' impegna- *
      *                          * ta nel mese comprensiva di una per- *
      *                          * centuale di tolleranza              *
      *                          *-------------------------------------*
           go to     det-qta-ecc-380.
       det-qta-ecc-344.
      *                      *-----------------------------------------*
      *                      * Se superiore al minimo                  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Base per determinazione quantita'   *
      *                          * in tolleranza : quantita' impegnata *
      *                          * da clienti nel mese                 *
      *                          *-------------------------------------*
           move      w-det-qta-ecc-qic
                    (w-det-qta-ecc-c01)   to   w-det-qta-ecc-wbt      .
      *                          *-------------------------------------*
      *                          * A determinazione quantita' impegna- *
      *                          * ta nel mese comprensiva di una per- *
      *                          * centuale di tolleranza              *
      *                          *-------------------------------------*
           go to     det-qta-ecc-380.
       det-qta-ecc-360.
      *                  *---------------------------------------------*
      *                  * Se minore                                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Sostituzione della quantita' venduta    *
      *                      * media negli ultimi n mesi nella quanti- *
      *                      * ta' impegnata da clienti nel mese       *
      *                      *-----------------------------------------*
           move      w-det-qta-ecc-qvm    to   w-det-qta-ecc-qic
                                              (w-det-qta-ecc-c01)     .
      *                      *-----------------------------------------*
      *                      * Base per determinazione quantita' in    *
      *                      * tolleranza : quantita' media venduta    *
      *                      * negli ultimi n mesi                     *
      *                      *-----------------------------------------*
           move      w-det-qta-ecc-qvm    to   w-det-qta-ecc-wbt      .
      *                      *-----------------------------------------*
      *                      * A determinazione quantita' impegnata    *
      *                      * nel mese comprensiva di una percentuale *
      *                      * di tolleranza                           *
      *                      *-----------------------------------------*
           go to     det-qta-ecc-380.
       det-qta-ecc-380.
      *                  *---------------------------------------------*
      *                  * Determinazione quantita' impegnata nel mese *
      *                  * comprensiva di una percentuale di tolleran- *
      *                  * za                                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se percentuale o base per calcolo tol-  *
      *                      * leranza a zero : bufferizzazione e ol-  *
      *                      * tre                                     *
      *                      *-----------------------------------------*
           if        w-det-qta-ecc-ptm    =    zero or
                     w-det-qta-ecc-wbt    =    zero
                     move  w-det-qta-ecc-wbt
                                          to   w-det-qta-ecc-wqt
                     go to det-qta-ecc-390.
      *                      *-----------------------------------------*
      *                      * Calcolo                                 *
      *                      *-----------------------------------------*
           multiply  w-det-qta-ecc-wbt    by   w-det-qta-ecc-ptm
                                        giving w-det-qta-ecc-wqt      .
           divide    100                  into w-det-qta-ecc-wqt
                                               rounded                .
       det-qta-ecc-390.
      *                  *---------------------------------------------*
      *                  * Determinazione quantita' impegnata nel mese *
      *                  *---------------------------------------------*
           move      w-det-qta-ecc-qic
                    (w-det-qta-ecc-c01)   to   w-det-qta-ecc-qim
                                              (w-det-qta-ecc-c01)     .
           add       w-det-qta-ecc-wqt    to   w-det-qta-ecc-qim
                                              (w-det-qta-ecc-c01)     .
      *                  *---------------------------------------------*
      *                  * Riciclo su scansione buffer                 *
      *                  *---------------------------------------------*
           go to     det-qta-ecc-320.
       det-qta-ecc-400.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione buffer per determinazione    *
      *              * quantita' in eccedenza mensile                  *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-qta-ecc-c01      .
       det-qta-ecc-420.
           add       1                    to   w-det-qta-ecc-c01      .
           if        w-det-qta-ecc-c01    >    6
                     go to det-qta-ecc-500.
      *                  *---------------------------------------------*
      *                  * Determinazione saldo eccedenza mensile      *
      *                  *---------------------------------------------*
           move      w-det-qta-ecc-wqs    to   w-det-qta-ecc-qec
                                              (w-det-qta-ecc-c01)     .
           add       w-det-qta-ecc-qof
                    (w-det-qta-ecc-c01)   to   w-det-qta-ecc-qec
                                              (w-det-qta-ecc-c01)     .
           subtract  w-det-qta-ecc-qim
                    (w-det-qta-ecc-c01)   from w-det-qta-ecc-qec
                                              (w-det-qta-ecc-c01)     .
      *                  *---------------------------------------------*
      *                  * Aggiornamento saldo progressivo             *
      *                  *---------------------------------------------*
           add       w-det-qta-ecc-qof
                    (w-det-qta-ecc-c01)   to   w-det-qta-ecc-wqs      .
           subtract  w-det-qta-ecc-qic
                    (w-det-qta-ecc-c01)   from w-det-qta-ecc-wqs      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-qta-ecc-420.
       det-qta-ecc-500.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-qta-ecc-999.
       det-qta-ecc-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Composizione area per rotture      *
      *    *-----------------------------------------------------------*
       prn-cmp-rot-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo ordinamento     *
      *              *-------------------------------------------------*
           if        w-tip-ord-tip-ord    =    01 or
                     w-tip-ord-tip-ord    =    02
                     go to prn-cmp-rot-300
           else if   w-tip-ord-tip-ord    =    03 or
                     w-tip-ord-tip-ord    =    04
                     go to prn-cmp-rot-600.
       prn-cmp-rot-300.
      *              *-------------------------------------------------*
      *              * Se tipo ordinamento :                           *
      *              * - Per classe, gruppo, sottogruppo, codice ma-   *
      *              *   gazzino                                       *
      *              * - Per classe, gruppo, sottogruppo, descrizione  *
      *              *   magazzino                                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Composizione area per rottura classe        *
      *                  *---------------------------------------------*
           move      rf-dcp-cla-pro       to   w-rot-l03-cod-cla      .
      *                  *---------------------------------------------*
      *                  * Composizione area per rottura gruppo        *
      *                  *---------------------------------------------*
           move      rf-dcp-gru-pro       to   w-rot-l02-cod-gru      .
      *                  *---------------------------------------------*
      *                  * Composizione area per rottura sottogruppo   *
      *                  *---------------------------------------------*
           move      rf-dcp-sgr-pro       to   w-rot-l01-cod-sgr      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     prn-cmp-rot-999.
       prn-cmp-rot-600.
      *              *-------------------------------------------------*
      *              * Se tipo ordinamento :                           *
      *              * - Per codice magazzino                          *
      *              * - Per descrizione magazzino                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione area rottura classe         *
      *                  *---------------------------------------------*
           move      zero                 to   w-rot-l03-cod-cla      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione area rottura gruppo         *
      *                  *---------------------------------------------*
           move      zero                 to   w-rot-l02-cod-gru      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione area rottura sottogruppo    *
      *                  *---------------------------------------------*
           move      zero                 to   w-rot-l01-cod-sgr      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     prn-cmp-rot-999.
       prn-cmp-rot-999.
