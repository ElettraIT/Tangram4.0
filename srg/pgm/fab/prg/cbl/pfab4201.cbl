      *    *===========================================================*
      *    * Lettura delle referenze relative allo sconto in chiusura  *
      *    *-----------------------------------------------------------*
       ref-fab-420-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione work-area                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-ref-fab-420-nmc      .
           move      zero                 to   w-ref-fab-420-mde      .
           move      zero                 to   w-ref-fab-420-ncm      .
      *              *-------------------------------------------------*
      *              * Lettura referenza                               *
      *              *-------------------------------------------------*
           move      "R:"                 to   s-ope                  .
           move      "pgm/fab/pri/fab420" to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Test su esito operazione                        *
      *              *-------------------------------------------------*
           if        s-ves                not  = spaces
                     go to ref-fab-420-100.
      *              *-------------------------------------------------*
      *              * Valore referenza in comodo rifefinito           *
      *              *-------------------------------------------------*
           move      s-alf                to   w-ref-fab-420-str      .
       ref-fab-420-100.
      *              *-------------------------------------------------*
      *              * Normalizzazione valori                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Numero mesi da considerare                  *
      *                  *---------------------------------------------*
           if        w-ref-fab-420-nmc    not  numeric or
                     w-ref-fab-420-nmc    <    01 or
                     w-ref-fab-420-nmc    >    12
                     move  06             to   w-ref-fab-420-nmc      .
      *                  *---------------------------------------------*
      *                  * Mese da escludere                           *
      *                  *---------------------------------------------*
           if        w-ref-fab-420-mde    not  numeric or
                     w-ref-fab-420-mde    <    00 or
                     w-ref-fab-420-mde    >    12
                     move  08             to   w-ref-fab-420-mde      .
      *                  *---------------------------------------------*
      *                  * Numero clienti minimo                       *
      *                  *---------------------------------------------*
           if        w-ref-fab-420-ncm    not  numeric or
                     w-ref-fab-420-ncm    <    01 or
                     w-ref-fab-420-ncm    >    04
                     move  03             to   w-ref-fab-420-ncm      .
       ref-fab-420-999.
           exit.

