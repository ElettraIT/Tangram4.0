      *    *===========================================================*
      *    * Subroutines per determinazione importo in riga            *
      *    *-----------------------------------------------------------*
       det-imp-ven-opn-000.
      *              *=================================================*
      *              * Open modulo                                     *
      *              *-------------------------------------------------*
           move      "OP"                 to   d-imp-ven-tip-ope      .
           perform   det-imp-ven-cll-000  thru det-imp-ven-cll-999    .
       det-imp-ven-opn-999.
           exit.

       det-imp-ven-cls-000.
      *              *=================================================*
      *              * Close modulo                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Chiusura                                    *
      *                  *---------------------------------------------*
           move      "CL"                 to   d-imp-ven-tip-ope      .
           perform   det-imp-ven-cll-000  thru det-imp-ven-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test se cancellabile                        *
      *                  *---------------------------------------------*
           move      "C?"                 to   d-imp-ven-tip-ope      .
           perform   det-imp-ven-cll-000  thru det-imp-ven-cll-999    .
           if        d-imp-ven-exi-sts    not  = spaces
                     go to det-imp-ven-cls-999.
      *                  *---------------------------------------------*
      *                  * Cancellazione modulo                        *
      *                  *---------------------------------------------*
           move      "pgm/fat/prg/obj/dimpven0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           cancel    s-pat                                            .
       det-imp-ven-cls-999.
           exit.

       det-imp-ven-cll-000.
      *              *=================================================*
      *              * Chiamata generica modulo                        *
      *              *-------------------------------------------------*
           move      "pgm/fat/prg/obj/dimpven0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-imp-ven              .
       det-imp-ven-cll-999.
           exit.

