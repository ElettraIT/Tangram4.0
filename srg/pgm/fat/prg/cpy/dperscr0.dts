      *    *===========================================================*
      *    * Subroutines per determinazione sconti in riga             *
      *    *-----------------------------------------------------------*
       det-per-scr-opn-000.
      *              *=================================================*
      *              * Open modulo                                     *
      *              *-------------------------------------------------*
           move      "OP"                 to   d-per-scr-tip-ope      .
           perform   det-per-scr-cll-000  thru det-per-scr-cll-999    .
       det-per-scr-opn-999.
           exit.

       det-per-scr-cls-000.
      *              *=================================================*
      *              * Close modulo                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Chiusura                                    *
      *                  *---------------------------------------------*
           move      "CL"                 to   d-per-scr-tip-ope      .
           perform   det-per-scr-cll-000  thru det-per-scr-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test se cancellabile                        *
      *                  *---------------------------------------------*
           move      "C?"                 to   d-per-scr-tip-ope      .
           perform   det-per-scr-cll-000  thru det-per-scr-cll-999    .
           if        d-per-scr-exi-sts    not  = spaces
                     go to det-per-scr-cls-999.
      *                  *---------------------------------------------*
      *                  * Cancellazione modulo                        *
      *                  *---------------------------------------------*
           move      "pgm/fat/prg/obj/dperscr0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           cancel    s-pat                                            .
       det-per-scr-cls-999.
           exit.

       det-per-scr-cll-000.
      *              *=================================================*
      *              * Chiamata generica modulo                        *
      *              *-------------------------------------------------*
           move      "pgm/fat/prg/obj/dperscr0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-per-scr              .
       det-per-scr-cll-999.
           exit.

