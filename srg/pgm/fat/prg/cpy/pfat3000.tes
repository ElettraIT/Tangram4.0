       acc-cpv-aac-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cpv-aac (1)      .
       acc-cpv-aac-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      03                   to   w-let-arc-zpv-tip      .
           move      w-tes-cpv-aac (1)    to   w-let-arc-zpv-cod      .
           perform   let-arc-zpv-000      thru let-arc-zpv-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-zpv-des    to   w-tes-cpv-aac-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-cpv-aac-des-000  thru vis-cpv-aac-des-999    .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-zpv-flg    not  = spaces
                     go to acc-cpv-aac-100.
       acc-cpv-aac-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-cpv-aac (1)    =    w-sav-cpv-aac
                     go to acc-cpv-aac-800.
      *                  *---------------------------------------------*
      *                  * Ricalcolo dati provvigionali in riga        *
      *                  *---------------------------------------------*
           perform   rcl-dpv-rig-000      thru rcl-dpv-rig-999        .
       acc-cpv-aac-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cpv-aac-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cpv-aac-100.
       acc-cpv-aac-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Categoria provvigioni     *
      *    *-----------------------------------------------------------*
       vis-cpv-aac-000.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda se si tratta di modifiche  *
      *              * ai dati provvigionali                           *
      *              *-------------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to vis-cpv-aac-200
           else      go to vis-cpv-aac-400.
       vis-cpv-aac-200.
      *              *-------------------------------------------------*
      *              * Se in modifica dati provvigionali               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      10                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cpv-aac (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     vis-cpv-aac-999.
       vis-cpv-aac-400.
      *              *-------------------------------------------------*
      *              * In tutti gli altri casi                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     vis-cpv-aac-999.
       vis-cpv-aac-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione categoria     *
      *    *-----------------------------------------------------------*
       vis-cpv-aac-des-000.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda se si tratta di modifiche  *
      *              * ai dati provvigionali                           *
      *              *-------------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to vis-cpv-aac-des-200
           else      go to vis-cpv-aac-des-400.
       vis-cpv-aac-des-200.
      *              *-------------------------------------------------*
      *              * Se in modifica dati provvigionali               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cpv-aac-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     vis-cpv-aac-des-999.
       vis-cpv-aac-des-400.
      *              *-------------------------------------------------*
      *              * In tutti gli altri casi                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     vis-cpv-aac-des-999.
       vis-cpv-aac-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Percentuale di provvigione   *
      *    *                              legata al cliente            *
      *    *-----------------------------------------------------------*
       acc-ppv-aac-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-ppv-aac-050
           else      go to acc-ppv-aac-999.
       acc-ppv-aac-050.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-ppv-aac (1, 1) to   w-sav-ppv-aac          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-ppv-aac-400.
       acc-ppv-aac-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      11                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "PRSC"               to   v-pfk (07)             .
           move      "NXSC"               to   v-pfk (08)             .
           move      w-tes-ppv-aac (1, 1) to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-ppv-aac-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-ppv-aac-999.
       acc-ppv-aac-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-ppv-aac (1, 1)   .
       acc-ppv-aac-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-ppv-aac-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-ppv-aac (1, 1) =    w-sav-ppv-aac
                     go to acc-ppv-aac-800.
      *                  *---------------------------------------------*
      *                  * Ricalcolo dati provvigionali in riga        *
      *                  *---------------------------------------------*
           perform   rcl-dpv-rig-000      thru rcl-dpv-rig-999        .
       acc-ppv-aac-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-ppv-aac-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-ppv-aac-100.
       acc-ppv-aac-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : % provvigioni             *
      *    *-----------------------------------------------------------*
       vis-ppv-aac-000.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda se si tratta di modifiche  *
      *              * ai dati provvigionali                           *
      *              *-------------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to vis-ppv-aac-200
           else      go to vis-ppv-aac-400.
       vis-ppv-aac-200.
      *              *-------------------------------------------------*
      *              * Se in modifica dati provvigionali               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      11                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-ppv-aac (1, 1) to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     vis-ppv-aac-999.
       vis-ppv-aac-400.
      *              *-------------------------------------------------*
      *              * In tutti gli altri casi                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     vis-ppv-aac-999.
       vis-ppv-aac-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice agente                *
      *    *-----------------------------------------------------------*
       acc-cod-age-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cod-age (1)    to   w-sav-cod-age          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-age-400.
       acc-cod-age-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-age-ope      .
           move      w-tes-cod-age (1)    to   w-cod-mne-age-cod      .
           move      12                   to   w-cod-mne-age-lin      .
           move      30                   to   w-cod-mne-age-pos      .
           move      12                   to   w-cod-mne-age-nln      .
           move      41                   to   w-cod-mne-age-nps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-age-cll-000  thru cod-mne-age-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-age-foi-000  thru cod-mne-age-foi-999    .
       acc-cod-age-110.
           perform   cod-mne-age-cll-000  thru cod-mne-age-cll-999    .
           if        w-cod-mne-age-ope    =    "F+"
                     go to acc-cod-age-115.
           if        w-cod-mne-age-ope    =    "AC"
                     go to acc-cod-age-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-age-115.
           perform   cod-mne-age-foi-000  thru cod-mne-age-foi-999    .
           go to     acc-cod-age-110.
       acc-cod-age-120.
           move      w-cod-mne-age-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-age-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-age-999.
       acc-cod-age-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-age (1)      .
       acc-cod-age-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [age]                      *
      *                  *---------------------------------------------*
           move      w-tes-cod-age (1)    to   w-let-arc-age-cod      .
           perform   let-arc-age-000      thru let-arc-age-999        .
           move      w-let-arc-age-rag    to   w-tes-cod-age-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-age-000      thru vis-des-age-999        .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-age-flg    not  = spaces
                     go to acc-cod-age-100.
       acc-cod-age-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale non esistente             *
      *                  *---------------------------------------------*
           if        w-tes-cod-age (1)    not  = zero
                     go to acc-cod-age-700.
      *                      *-----------------------------------------*
      *                      * Trattamento flag di significativita'    *
      *                      * provvigioni per il documento            *
      *                      *-----------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     move  02             to   w-tes-fsp-doc (1)
                     go to acc-cod-age-610.
           if        w-tes-fsp-doc (1)    =    02
                     go to acc-cod-age-610.
           move      02                   to   w-tes-fsp-doc (1)      .
           perform   vis-fsp-doc-000      thru vis-fsp-doc-999        .
      *                      *-----------------------------------------*
      *                      * Normalizzazione dati provvigionali ri-  *
      *                      * ghe corpo                               *
      *                      *-----------------------------------------*
           perform   nor-dpv-rig-000      thru nor-dpv-rig-999        .
       acc-cod-age-610.
      *                      *-----------------------------------------*
      *                      * Trattamento tipo vendita per l'agente   *
      *                      *-----------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     move  zero           to   w-tes-tip-vpa (1)
                     go to acc-cod-age-620.
           if        w-tes-tip-vpa (1)    =    zero
                     go to acc-cod-age-620.
           move      zero                 to   w-tes-tip-vpa (1)      .
           perform   vis-tip-vpa-000      thru vis-tip-vpa-999        .
       acc-cod-age-620.
      *                      *-----------------------------------------*
      *                      * Trattamento importo provvigioni a for-  *
      *                      * fait per il documento                   *
      *                      *-----------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-cod-age-630.
           if        w-tes-pvf-age (1)    =    zero
                     go to acc-cod-age-630.
           move      zero                 to   w-tes-pvf-age (1)      .
           perform   vis-pvf-age-000      thru vis-pvf-age-999        .
       acc-cod-age-630.
      *                      *-----------------------------------------*
      *                      * Oltre                                   *
      *                      *-----------------------------------------*
           go to     acc-cod-age-800.
       acc-cod-age-700.
      *                  *---------------------------------------------*
      *                  * Se valore attuale esistente                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore attuale come precedente : ol- *
      *                      * tre                                     *
      *                      *-----------------------------------------*
           if        w-tes-cod-age (1)    =    w-sav-cod-age
                     go to acc-cod-age-800.
       acc-cod-age-710.
      *                      *-----------------------------------------*
      *                      * Trattamento categoria provvigioni asso- *
      *                      * ciata all'agente                        *
      *                      *-----------------------------------------*
           move      w-let-arc-age-cpv    to   w-tes-cpv-aaa (1)      .
       acc-cod-age-720.
      *                      *-----------------------------------------*
      *                      * Trattamento percentuali di provvigione  *
      *                      * associate all'agente                    *
      *                      *-----------------------------------------*
           move      w-let-arc-age-ppv (1)
                                          to   w-tes-ppv-aaa (1, 1)   .
           move      w-let-arc-age-ppv (2)
                                          to   w-tes-ppv-aaa (1, 2)   .
           move      w-let-arc-age-ppv (3)
                                          to   w-tes-ppv-aaa (1, 3)   .
       acc-cod-age-730.
      *                      *-----------------------------------------*
      *                      * Eventuale ricalcolo dati provvigionali  *
      *                      * in riga                                 *
      *                      *-----------------------------------------*
           perform   rcl-dpv-rig-000      thru rcl-dpv-rig-999        .
       acc-cod-age-740.
      *                      *-----------------------------------------*
      *                      * Trattamento contropartita vendite       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se contropartita derivata da tipo   *
      *                          * movimento : oltre                   *
      *                          *-------------------------------------*
           if        w-tes-tip-mov-sve    not  = zero
                     go to acc-cod-age-750.
      *                          *-------------------------------------*
      *                          * Deviazione a seconda del tipo docu- *
      *                          * mento                               *
      *                          *-------------------------------------*
           if        w-tes-tip-mov-tdo    =    03
                     go to acc-cod-age-742
           else      go to acc-cod-age-744.
       acc-cod-age-742.
      *                          *-------------------------------------*
      *                          * Se Nota di Accredito                *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se contropartita resi su vendi- *
      *                              * te associata all'agente a zero: *
      *                              * oltre                           *
      *                              *---------------------------------*
           if        w-let-arc-age-crv    =    zero
                     go to acc-cod-age-750.
      *                              *---------------------------------*
      *                              * Salvataggio contropartita ven-  *
      *                              * dite attuale                    *
      *                              *---------------------------------*
           move      w-tes-ctp-ven (1)    to   w-sav-ctp-ven          .
      *                              *---------------------------------*
      *                              * Bufferizzazione contropartita   *
      *                              * resi su vendite associata al-   *
      *                              * l'agente                        *
      *                              *---------------------------------*
           move      w-let-arc-age-crv    to   w-tes-ctp-ven (1)      .
           move      w-tes-ctp-ven (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-tes-ctp-ven-des (1)  .
      *                              *---------------------------------*
      *                              * Ricalcolo contropartite vendite *
      *                              * del documento                   *
      *                              *---------------------------------*
           perform   rcl-ctv-doc-000      thru rcl-ctv-doc-999        .
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     acc-cod-age-750.
       acc-cod-age-744.
      *                          *-------------------------------------*
      *                          * Se Fattura o Nota di Addebito       *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Se contropartita vendite asso-  *
      *                              * ciata all'agente a zero : oltre *
      *                              *---------------------------------*
           if        w-let-arc-age-ctv    =    zero
                     go to acc-cod-age-750.
      *                              *---------------------------------*
      *                              * Salvataggio contropartita ven-  *
      *                              * dite attuale                    *
      *                              *---------------------------------*
           move      w-tes-ctp-ven (1)    to   w-sav-ctp-ven          .
      *                              *---------------------------------*
      *                              * Bufferizzazione contropartita   *
      *                              * vendite associata all'agente    *
      *                              *---------------------------------*
           move      w-let-arc-age-ctv    to   w-tes-ctp-ven (1)      .
           move      w-tes-ctp-ven (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-tes-ctp-ven-des (1)  .
      *                              *---------------------------------*
      *                              * Ricalcolo contropartite vendite *
      *                              * del documento                   *
      *                              *---------------------------------*
           perform   rcl-ctv-doc-000      thru rcl-ctv-doc-999        .
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     acc-cod-age-750.
       acc-cod-age-750.
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     acc-cod-age-800.
       acc-cod-age-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-age-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-age-100.
       acc-cod-age-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice agente             *
      *    *-----------------------------------------------------------*
       vis-cod-age-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      12                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<B"                 to   v-edm                  .
           move      w-tes-cod-age (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-age-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione agente        *
      *    *-----------------------------------------------------------*
       vis-des-age-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-age-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-age-999.
           exit.

      *    *===========================================================*
      *    * Routine di normalizzazione dati provvigionali nelle righe *
      *    *-----------------------------------------------------------*
       nor-dpv-rig-000.
      *              *-------------------------------------------------*
      *              * Se corpo ancora da accettare : uscita           *
      *              *-------------------------------------------------*
           if        w-cnt-sts-imp-cor    =    spaces
                     go to nor-dpv-rig-999.
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       nor-dpv-rig-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to nor-dpv-rig-900.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to nor-dpv-rig-100.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to nor-dpv-rig-100.
      *              *-------------------------------------------------*
      *              * Selezione su tipo riga                          *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to nor-dpv-rig-100.
       nor-dpv-rig-150.
      *              *-------------------------------------------------*
      *              * Normalizzazione valori di accettazione provvi-  *
      *              * gioni in riga                                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del flag di testata  *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    =    04
                     go to nor-dpv-rig-400.
       nor-dpv-rig-200.
      *                  *---------------------------------------------*
      *                  * Se flag a 02 o 03                           *
      *                  *---------------------------------------------*
           move      02                   to   w-rig-fsp-rig (1)      .
           move      zero                 to   w-rig-ppv-rig (1, 1)   .
           move      zero                 to   w-rig-ppv-rig (1, 2)   .
           move      zero                 to   w-rig-ppv-rig (1, 3)   .
           move      zero                 to   w-rig-pvf-rig (1)      .
           go to     nor-dpv-rig-800.
       nor-dpv-rig-400.
      *                  *---------------------------------------------*
      *                  * Se flag a 04                                *
      *                  *---------------------------------------------*
           move      03                   to   w-rig-fsp-rig (1)      .
           move      zero                 to   w-rig-ppv-rig (1, 1)   .
           move      zero                 to   w-rig-ppv-rig (1, 2)   .
           move      zero                 to   w-rig-ppv-rig (1, 3)   .
           move      zero                 to   w-rig-pvf-rig (1)      .
           go to     nor-dpv-rig-800.
       nor-dpv-rig-800.
      *              *-------------------------------------------------*
      *              * Aggiornamento catena movimenti                  *
      *              *-------------------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-cur        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura catena                       *
      *              *-------------------------------------------------*
           go to     nor-dpv-rig-100.
       nor-dpv-rig-900.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       nor-dpv-rig-999.
           exit.

      *    *===========================================================*
      *    * Routine di ricalcolo dati provvigionali in riga           *
      *    *-----------------------------------------------------------*
       rcl-dpv-rig-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se corpo ancora da accettare : no           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-cor    =    spaces
                     go to rcl-dpv-rig-999.
      *                  *---------------------------------------------*
      *                  * Test se gestione agenti attiva              *
      *                  *---------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to rcl-dpv-rig-999.
      *                  *---------------------------------------------*
      *                  * Test se flag significativita' provvigioni   *
      *                  * per il documento indica 'No' o 'A forfait'  *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    =    02 or
                     w-tes-fsp-doc (1)    =    03
                     go to rcl-dpv-rig-999.
       rcl-dpv-rig-100.
      *              *-------------------------------------------------*
      *              * Box di avviso con conferma                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      07                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      74                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Messaggi nel box                            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "                       A T T E N Z I O N E        
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "La modifica appena apportata potrebbe avere delle 
      -              "ripercussioni "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "sulle provvigioni in riga gia' determinate.       
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "Si desidera che esse vengano ricalcolate (S/N) ? [
      -              " ]            "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Preparazione default per risposta           *
      *                  *---------------------------------------------*
           move      spaces               to   v-alf                  .
       rcl-dpv-rig-120.
      *                  *---------------------------------------------*
      *                  * Accettazione risposta                       *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      59                   to   v-pos                  .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Controllo risposta operatore                *
      *                  *---------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "N"            to   v-alf
           else if   v-key                =    "DO  "
                     move  "S"            to   v-alf                  .
           if        v-alf                not  = "S" and
                     v-alf                not  = "N"
                     go to rcl-dpv-rig-120.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione risposta operatore          *
      *                  *---------------------------------------------*
           move      v-alf                to   w-rcl-dpv-rig-tro      .
      *                  *---------------------------------------------*
      *                  * Ripristino immagine video                   *
      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       rcl-dpv-rig-200.
      *              *-------------------------------------------------*
      *              * Se risposta operatore negativa : uscita         *
      *              *-------------------------------------------------*
           if        w-rcl-dpv-rig-tro    =    "N"
                     go to rcl-dpv-rig-999.
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       rcl-dpv-rig-300.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to rcl-dpv-rig-900.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to rcl-dpv-rig-300.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to rcl-dpv-rig-300.
       rcl-dpv-rig-400.
      *              *-------------------------------------------------*
      *              * Selezione su tipo riga                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se riga di commento : riciclo               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to rcl-dpv-rig-300.
      *                  *---------------------------------------------*
      *                  * Se riga di addebito : riciclo               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to rcl-dpv-rig-300.
      *                  *---------------------------------------------*
      *                  * Se prodotto similare : riciclo              *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to rcl-dpv-rig-300.
       rcl-dpv-rig-500.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del flag di testata      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se a forfait in testata                *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    =    04
                     go to rcl-dpv-rig-700.
       rcl-dpv-rig-620.
      *              *-------------------------------------------------*
      *              * Flag di significativita' provvigioni forzato a  *
      *              * 01, cioe' Si provvigioni                        *
      *              *-------------------------------------------------*
           move      01                   to   w-rig-fsp-rig (1)      .
      *              *-------------------------------------------------*
      *              * Richiamo routine di determinazione provvigioni  *
      *              *-------------------------------------------------*
           perform   det-ppv-rig-000      thru det-ppv-rig-999        .
           go to     rcl-dpv-rig-800.
       rcl-dpv-rig-700.
      *              *-------------------------------------------------*
      *              * Flag di significativita' provvigioni forzato a  *
      *              * 03, cioe' Speciali                              *
      *              *-------------------------------------------------*
           move      03                   to   w-rig-fsp-rig (1)      .
      *              *-------------------------------------------------*
      *              * % in riga uguale a % a forfait                  *
      *              *-------------------------------------------------*
           divide    100                  into w-tes-pvf-age (1)
                                        giving w-rig-ppv-rig (1, 1)   .
           move      zero                 to   w-rig-ppv-rig (1, 2)   .
           move      zero                 to   w-rig-ppv-rig (1, 3)   .
           move      zero                 to   w-rig-pvf-rig (1)      .
           go to     rcl-dpv-rig-800.
       rcl-dpv-rig-800.
      *              *-------------------------------------------------*
      *              * Aggiornamento catena movimenti                  *
      *              *-------------------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-cur        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Riciclo su lettura catena                       *
      *              *-------------------------------------------------*
           go to     rcl-dpv-rig-300.
       rcl-dpv-rig-900.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       rcl-dpv-rig-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Flag di significativita' da- *
      *    * ti provvigionali per il documento                         *
      *    *-----------------------------------------------------------*
       acc-fsp-doc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da trattare                   *
      *                  *---------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     move  02             to   w-tes-fsp-doc (1)
                     go to acc-fsp-doc-999.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-cod-age (1)    =    zero
                     go to acc-fsp-doc-999.
      *                  *---------------------------------------------*
      *                  * Test se fattura Pro-Forma                   *
      *                  *---------------------------------------------*
           if        w-tes-tip-mov-tdo    =    04
                     go to acc-fsp-doc-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-fsp-doc (1)    to    w-sav-fsp-doc         .
      *                  *---------------------------------------------*
      *                  * Preparazione eventuale default              *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    not  = zero
                     go to acc-fsp-doc-050.
           move      01                   to   w-tes-fsp-doc (1)      .
           perform   vis-fsp-doc-000      thru vis-fsp-doc-999        .
       acc-fsp-doc-050.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-fsp-doc-400.
       acc-fsp-doc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-fsp-doc-lun    to   v-car                  .
           move      w-exp-fsp-doc-num    to   v-ldt                  .
           move      "SNIF#"              to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      14                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-fsp-doc-tbl    to   v-txt                  .
           move      w-tes-fsp-doc (1)    to   v-num                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-fsp-doc-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-fsp-doc-999.
       acc-fsp-doc-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-fsp-doc (1)      .
       acc-fsp-doc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    not  = zero
                     go to acc-fsp-doc-500.
           if        v-key                =    "UP  "
                     go to acc-fsp-doc-600
           else      go to acc-fsp-doc-100.
       acc-fsp-doc-500.
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    >    w-exp-fsp-doc-num
                     go to acc-fsp-doc-100.
       acc-fsp-doc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    =    w-sav-fsp-doc
                     go to acc-fsp-doc-800.
      *                  *---------------------------------------------*
      *                  * Trattamento tipo vendita per l'agente       *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    not  = 02
                     go to acc-fsp-doc-620.
           if        w-tes-tip-vpa (1)    =    zero
                     go to acc-fsp-doc-620.
           move      zero                 to   w-tes-tip-vpa (1)      .
           perform   vis-tip-vpa-000      thru vis-tip-vpa-999        .
       acc-fsp-doc-620.
      *                  *---------------------------------------------*
      *                  * Trattamento importo provvigioni a forfait   *
      *                  * per il documento                            *
      *                  *---------------------------------------------*
           if        w-tes-pvf-age (1)    =    zero
                     go to acc-fsp-doc-700.
           move      zero                 to   w-tes-pvf-age (1)      .
           perform   vis-pvf-age-000      thru vis-pvf-age-999        .
       acc-fsp-doc-700.
      *                  *---------------------------------------------*
      *                  * Trattamento dati provvigionali in riga      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del valore       *
      *                      *-----------------------------------------*
           if        w-tes-fsp-doc (1)    =    01
                     go to acc-fsp-doc-710
           else if   w-tes-fsp-doc (1)    =    02
                     go to acc-fsp-doc-720
           else if   w-tes-fsp-doc (1)    =    03
                     go to acc-fsp-doc-730
           else if   w-tes-fsp-doc (1)    =    04
                     go to acc-fsp-doc-740.
       acc-fsp-doc-710.
      *                      *-----------------------------------------*
      *                      * Se valore a 01, Si da righe documento   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Ricalcolo dati provvigionali in ri- *
      *                          * ga                                  *
      *                          *-------------------------------------*
           perform   rcl-dpv-rig-000      thru rcl-dpv-rig-999        .
           go to     acc-fsp-doc-800.
       acc-fsp-doc-720.
      *                      *-----------------------------------------*
      *                      * Se valore a 02, No provvigioni          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione dati provvigionali  *
      *                          * in righe corpo                      *
      *                          *-------------------------------------*
           perform   nor-dpv-rig-000      thru nor-dpv-rig-999        .
           go to     acc-fsp-doc-800.
       acc-fsp-doc-730.
      *                      *-----------------------------------------*
      *                      * Se valore a 03, A forfait               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione dati provvigionali  *
      *                          * in righe corpo                      *
      *                          *-------------------------------------*
           perform   nor-dpv-rig-000      thru nor-dpv-rig-999        .
           go to     acc-fsp-doc-800.
       acc-fsp-doc-740.
      *                      *-----------------------------------------*
      *                      * Se valore a 04, A forfait in %          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Normalizzazione dati provvigionali  *
      *                          * in righe corpo                      *
      *                          *-------------------------------------*
           perform   nor-dpv-rig-000      thru nor-dpv-rig-999        .
           go to     acc-fsp-doc-800.
       acc-fsp-doc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-fsp-doc-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-fsp-doc-100.
       acc-fsp-doc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Flag di significativita'  *
      *    * dati provvigionali per il documento                       *
      *    *-----------------------------------------------------------*
       vis-fsp-doc-000.
      *              *-------------------------------------------------*
      *              * Test se campo da trattare                       *
      *              *-------------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to vis-fsp-doc-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione campo                           *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-fsp-doc-lun    to   v-car                  .
           move      w-exp-fsp-doc-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      14                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-fsp-doc-tbl    to   v-txt                  .
           move      w-tes-fsp-doc (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-fsp-doc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Tipo vendita per l'agente    *
      *    *-----------------------------------------------------------*
       acc-tip-vpa-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da trattare                   *
      *                  *---------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-tip-vpa-999.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    =    02
                     go to acc-tip-vpa-999.
           if        w-tes-cod-age (1)    =    zero
                     go to acc-tip-vpa-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-tip-vpa (1)    to   w-sav-tip-vpa          .
      *                  *---------------------------------------------*
      *                  * Preparazione eventuale default              *
      *                  *---------------------------------------------*
           if        w-tes-tip-vpa (1)    not  = zero
                     go to acc-tip-vpa-050.
           move      01                   to   w-tes-tip-vpa (1)      .
           perform   vis-tip-vpa-000      thru vis-tip-vpa-999        .
       acc-tip-vpa-050.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-tip-vpa-400.
       acc-tip-vpa-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-vpa-lun    to   v-car                  .
           move      w-exp-tip-vpa-num    to   v-ldt                  .
           move      "DI#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      16                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-tip-vpa-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-tip-vpa (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-tip-vpa-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-tip-vpa-999.
       acc-tip-vpa-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-tip-vpa (1)      .
       acc-tip-vpa-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-tes-tip-vpa (1)    not  = zero
                     go to acc-tip-vpa-500.
           if        v-key                =    "UP  "
                     go to acc-tip-vpa-600
           else      go to acc-tip-vpa-100.
       acc-tip-vpa-500.
      *                  *---------------------------------------------*
      *                  * Test se valore ammesso                      *
      *                  *---------------------------------------------*
           if        w-tes-tip-vpa (1)    >    w-exp-tip-vpa-num
                     go to acc-tip-vpa-100.
       acc-tip-vpa-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-tip-vpa (1)    =    w-sav-tip-vpa
                     go to acc-tip-vpa-800.
      *                  *---------------------------------------------*
      *                  * Se valore attuale a zero : oltre            *
      *                  *---------------------------------------------*
           if        w-tes-tip-vpa (1)    =    zero
                     go to acc-tip-vpa-800.
      *                  *---------------------------------------------*
      *                  * Ricalcolo dati provvigionali in riga        *
      *                  *---------------------------------------------*
           perform   rcl-dpv-rig-000      thru rcl-dpv-rig-999        .
       acc-tip-vpa-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-tip-vpa-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-tip-vpa-100.
       acc-tip-vpa-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Tipo vendita per l'agente *
      *    *-----------------------------------------------------------*
       vis-tip-vpa-000.
      *              *-------------------------------------------------*
      *              * Test se campo da trattare                       *
      *              *-------------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to vis-tip-vpa-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione campo                           *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-vpa-lun    to   v-car                  .
           move      w-exp-tip-vpa-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      16                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-tip-vpa-tbl    to   v-txt                  .
           move      w-tes-tip-vpa (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tip-vpa-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Importo o % provvigioni a    *
      *    *                              forfait per l'agente         *
      *    *-----------------------------------------------------------*
       acc-pvf-age-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-pvf-age-999.
           if        w-tes-fsp-doc (1)    not  = 03 and
                     w-tes-fsp-doc (1)    not  = 04
                     go to acc-pvf-age-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-pvf-age (1)    to   w-sav-pvf-age          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-pvf-age-400.
       acc-pvf-age-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
      *
           if        w-tes-fsp-doc (1)    =    03
                     move  11             to   v-car
                     move  c-dec          to   v-dec
           else      move  04             to   v-car
                     move  2              to   v-dec                  .
      *
           move      spaces               to   v-sgn                  .
           move      18                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<BG"                to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-pvf-age (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pvf-age-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pvf-age-999.
       acc-pvf-age-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-pvf-age (1)      .
       acc-pvf-age-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a zero non ammesso, a meno che non   *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-tes-pvf-age (1)    not  = zero
                     go to acc-pvf-age-600.
           if        v-key                =    "UP  "
                     go to acc-pvf-age-600
           else      go to acc-pvf-age-100.
       acc-pvf-age-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-pvf-age (1)    =    w-sav-pvf-age
                     go to acc-pvf-age-800.
      *                  *---------------------------------------------*
      *                  * Ricalcolo dati provvigionali in riga se     *
      *                  * forfait in testata in %                     *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    not  = 04
                     go to acc-pvf-age-800.
           perform   rcl-dpv-rig-000      thru rcl-dpv-rig-999        .
       acc-pvf-age-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pvf-age-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pvf-age-100.
       acc-pvf-age-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Importo o % provvigioni a forfait *
      *    *                         per l'agente                      *
      *    *-----------------------------------------------------------*
       vis-pvf-age-000.
      *              *-------------------------------------------------*
      *              * Test se campo da trattare                       *
      *              *-------------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to vis-pvf-age-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione campo                           *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
      *
           if        w-tes-fsp-doc (1)    =    03
                     move  11             to   v-car
                     move  c-dec          to   v-dec
           else      move  04             to   v-car
                     move  2              to   v-dec                  .
      *
           move      spaces               to   v-sgn                  .
           move      18                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<BG"                to   v-edm                  .
           move      w-tes-pvf-age (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-pvf-age-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Categoria clienti                    *
      *    *-----------------------------------------------------------*
       acc-cod-cat-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to acc-cod-cat-999.
           if        w-prs-snx-cat        not  = "S"
                     go to acc-cod-cat-999.
           if        w-ipc-sub-pgm-ind    not  = "MP"
                     go to acc-cod-cat-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-cat-400.
       acc-cod-cat-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *                                                 *
      *              * N.B. : la linea a video varia a seconda se      *
      *              *        - cliente principale                     *
      *              *        - dipendenza                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cmn-zst-002-ope      .
           move      w-tes-cod-ime (1)    to   w-cmn-zst-002-cod      .
           move      20                   to   w-cmn-zst-002-lin      .
           move      30                   to   w-cmn-zst-002-pos      .
           move      20                   to   w-cmn-zst-002-dln      .
           move      41                   to   w-cmn-zst-002-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cmn-zst-002-cll-000  thru cmn-zst-002-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cmn-zst-002-foi-000  thru cmn-zst-002-foi-999    .
       acc-cod-cat-110.
           perform   cmn-zst-002-cll-000  thru cmn-zst-002-cll-999    .
           if        w-cmn-zst-002-ope    =    "F+"
                     go to acc-cod-cat-115.
           if        w-cmn-zst-002-ope    =    "AC"
                     go to acc-cod-cat-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-cat-115.
           perform   cmn-zst-002-foi-000  thru cmn-zst-002-foi-999    .
           go to     acc-cod-cat-110.
       acc-cod-cat-120.
           move      w-cmn-zst-002-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cat-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cat-999.
       acc-cod-cat-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-ime (1)      .
       acc-cod-cat-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      02                   to   w-let-arc-zst-tip      .
           move      w-tes-cod-ime (1)    to   w-let-arc-zst-cod      .
           perform   let-arc-zst-000      thru let-arc-zst-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-zst-des    to   w-tes-cod-ime-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-cod-cat-des-000  thru vis-cod-cat-des-999    .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-zst-flg    not  = spaces
                     go to acc-cod-cat-100.
       acc-cod-cat-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-cat-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-cat-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-cat-100.
       acc-cod-cat-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice categoria                  *
      *    *-----------------------------------------------------------*
       vis-cod-cat-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzaare                  *
      *              *-------------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to vis-cod-cat-999.
           if        w-prs-snx-cat        not  = "S"
                     go to vis-cod-cat-999.
           if        w-ipc-sub-pgm-ind    not  = "MP"
                     go to vis-cod-cat-999.
       vis-cod-cat-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      20                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-ime (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-cat-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione categoria     *
      *    *-----------------------------------------------------------*
       vis-cod-cat-des-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzaare                  *
      *              *-------------------------------------------------*
           if        w-prs-age-snx        not  = "S"
                     go to vis-cod-cat-des-999.
           if        w-prs-snx-cat        not  = "S"
                     go to vis-cod-cat-des-999.
           if        w-ipc-sub-pgm-ind    not  = "MP"
                     go to vis-cod-cat-des-999.
       vis-cod-cat-des-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-ime-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-cat-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice pagamento             *
      *    *-----------------------------------------------------------*
       acc-cod-fop-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-cod-fop-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cod-fop (1)    to   w-sav-cod-fop          .
      *                  *---------------------------------------------*
      *                  * Salvataggio percentuale di sconto pagamento *
      *                  * associata alla forma di pagamento           *
      *                  *---------------------------------------------*
           move      w-tes-scp-aap (1)    to   w-sav-scp-aap          .
      *                  *---------------------------------------------*
      *                  * Se Tab in corso : a controllo valore impo-  *
      *                  * stato                                       *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-fop-400.
       acc-cod-fop-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zfp-ope      .
           move      w-tes-cod-fop (1)    to   w-cod-mne-zfp-cod      .
           move      05                   to   w-cod-mne-zfp-lin      .
           move      30                   to   w-cod-mne-zfp-pos      .
           move      05                   to   w-cod-mne-zfp-dln      .
           move      41                   to   w-cod-mne-zfp-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-zfp-cll-000  thru cod-mne-zfp-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zfp-foi-000  thru cod-mne-zfp-foi-999    .
       acc-cod-fop-110.
           perform   cod-mne-zfp-cll-000  thru cod-mne-zfp-cll-999    .
           if        w-cod-mne-zfp-ope    =    "F+"
                     go to acc-cod-fop-115.
           if        w-cod-mne-zfp-ope    =    "AC"
                     go to acc-cod-fop-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-fop-115.
           perform   cod-mne-zfp-foi-000  thru cod-mne-zfp-foi-999    .
           go to     acc-cod-fop-110.
       acc-cod-fop-120.
           move      w-cod-mne-zfp-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-fop-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-fop-999.
       acc-cod-fop-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-fop (1)      .
       acc-cod-fop-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [zfp]                      *
      *                  *---------------------------------------------*
           move      w-tes-cod-fop (1)    to   w-let-arc-zfp-cod      .
           perform   let-arc-zfp-000      thru let-arc-zfp-999        .
           move      w-let-arc-zfp-des    to   w-tes-cod-fop-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-fop-000      thru vis-des-fop-999        .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-zfp-flg    not  = spaces
                     go to acc-cod-fop-100.
      *                  *---------------------------------------------*
      *                  * Determinazione valori testata indotti da    *
      *                  * record [zfp]                                *
      *                  *---------------------------------------------*
           perform   det-vlt-zfp-000      thru det-vlt-zfp-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione segnale di scadenze modifi- *
      *                  * cabili                                      *
      *                  *---------------------------------------------*
           perform   vis-snx-ims-000      thru vis-snx-ims-999        .
      *                      *-----------------------------------------*
      *                      * Test su esito determinazione            *
      *                      *-----------------------------------------*
           if        w-det-vlt-zfp-flg    =    spaces
                     go to acc-cod-fop-420.
      *                      *-----------------------------------------*
      *                      * Se Tab in corso : a reimpostazione      *
      *                      *-----------------------------------------*
           if        w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-fop-100.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Errore in fase di lettura di un codice di pagament
      -              "o !            "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-fop-100.
       acc-cod-fop-420.
      *                  *---------------------------------------------*
      *                  * Se tipo documento : Nota di Accredito si    *
      *                  * controlla che i codici di pagamento asso-   *
      *                  * ciati alla forma di pagamento siano tutti   *
      *                  * di tipo Rimessa Diretta                     *
      *                  *---------------------------------------------*
           if        w-tes-cod-fop (1)    =    zero
                     go to acc-cod-fop-500.
           if        w-tes-tip-mov-tdo    not  = 03
                     go to acc-cod-fop-500.
      *                  *---------------------------------------------*
      *                  * Controllo che i codici pagamento associati  *
      *                  * alla forma di pagamento se non sono a zero, *
      *                  * siano di tipo Rimessa Diretta               *
      *                  *---------------------------------------------*
           if        w-tes-cod-pag (1, 1) not  = zero and
                     w-tes-tip-pag (1, 1) not  =  01
                     go to acc-cod-fop-450.
           if        w-tes-cod-pag (1, 2) not  = zero and
                     w-tes-tip-pag (1, 2) not  =  01
                     go to acc-cod-fop-450.
           if        w-tes-cod-pag (1, 3) not  = zero and
                     w-tes-tip-pag (1, 3) not  =  01
                     go to acc-cod-fop-450.
           go to     acc-cod-fop-500.
       acc-cod-fop-450.
      *                      *-----------------------------------------*
      *                      * Messaggio di avviso                     *
      *                      *-----------------------------------------*
           move      "Forma di pagamento sconsigliata per Note di Accred
      -              "ito            "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
______*    go to     acc-cod-fop-100.
       acc-cod-fop-500.
      *                  *---------------------------------------------*
      *                  * Controllo causali contabili associate ai    *
      *                  * codici pagamento                            *
      *                  *---------------------------------------------*
           if        w-tes-cod-fop (1)    =    zero
                     go to acc-cod-fop-600.
      *                      *-----------------------------------------*
      *                      * Ciclo per tre codici pagamento          *
      *                      *-----------------------------------------*
           move      zero                 to   w-acc-cod-fop-ctr      .
       acc-cod-fop-502.
           add       1                    to   w-acc-cod-fop-ctr      .
           if        w-acc-cod-fop-ctr    >    3
                     go to acc-cod-fop-600.
      *                          *-------------------------------------*
      *                          * Se codice pagamento a zero : riciclo*
      *                          *-------------------------------------*
           if        w-tes-cod-pag
                    (1, w-acc-cod-fop-ctr)
                                          =    zero
                     go to acc-cod-fop-502.
      *                          *-------------------------------------*
      *                          * Se causale contabile a zero: riciclo*
      *                          *-------------------------------------*
           if        w-tes-cau-cge
                    (1, w-acc-cod-fop-ctr)
                                          =    zero
                     go to acc-cod-fop-502.
      *                          *-------------------------------------*
      *                          * Controllo                           *
      *                          *-------------------------------------*
           move      w-tes-cau-cge
                    (1, w-acc-cod-fop-ctr)
                                          to   w-ctl-cau-pag-cod      .
           perform   ctl-cau-pag-000      thru ctl-cau-pag-999        .
           if        w-ctl-cau-pag-flg    =    spaces
                     go to acc-cod-fop-504.
      *                              *---------------------------------*
      *                              * Messaggio di errore             *
      *                              *---------------------------------*
           move      "Causali contabili associate alla forma pagamento e
      -              "rrate          "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                              *---------------------------------*
      *                              * A reimpostazione                *
      *                              *---------------------------------*
           go to     acc-cod-fop-100.
       acc-cod-fop-504.
      *                          *-------------------------------------*
      *                          * Riciclo                             *
      *                          *-------------------------------------*
           go to     acc-cod-fop-502.
       acc-cod-fop-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-sav-cod-fop        =    zero
                     go to acc-cod-fop-605.
           if        w-tes-cod-fop (1)    =    w-sav-cod-fop
                     go to acc-cod-fop-605.
      *                  *---------------------------------------------*
      *                  * Test su segnale di scadenze modificabili    *
      *                  *---------------------------------------------*
           if        w-tes-snx-ims (1)    not  = "S"
                     go to acc-cod-fop-605.
      *                  *---------------------------------------------*
      *                  * Messaggio                                   *
      *                  *---------------------------------------------*
           move      "Attenzione : la forma di pagamento scelta implica 
      -              "la gestione manu- " to   w-err-box-err-msg      .
           move      "             ale delle scadenze. Quelle presenti n
      -              "on sono variate   " to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       acc-cod-fop-605.
      *                  *---------------------------------------------*
      *                  * Determinazione valori testata indotti da    *
      *                  * record [zin]                                *
      *                  *---------------------------------------------*
           perform   det-vlt-zin-000      thru det-vlt-zin-999        .
      *                  *---------------------------------------------*
      *                  * Determinazione valori testata indotti da    *
      *                  * record [zbo]                                *
      *                  *---------------------------------------------*
           perform   det-vlt-zbo-000      thru det-vlt-zbo-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione sconto pagamento            *
      *                  *---------------------------------------------*
           perform   vis-scp-aap-000      thru vis-scp-aap-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento % sconto pagamento per piede    *
      *                  *---------------------------------------------*
           if        w-sav-scp-aap        =    w-tes-scp-aap (1)
                     go to acc-cod-fop-610.
           move      w-tes-scp-aap (1)    to   w-pie-per-scp (1)      .
           move      zero                 to   w-pie-tot-scp (1)      .
       acc-cod-fop-610.
      *                  *---------------------------------------------*
      *                  * Trattamento codice nostra banca per bonifi- *
      *                  * co                                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se da trattare                          *
      *                      *-----------------------------------------*
           if        w-tes-snx-nsb (1)    not  = "S"
                     go to acc-cod-fop-615.
           if        w-tes-nos-ban (1)    not  = spaces
                     go to acc-cod-fop-620.
           move      w-tes-nsb-aac (1)    to   w-tes-nos-ban (1)      .
           perform   vis-nos-ban-000      thru vis-nos-ban-999        .
           move      02                   to   w-let-arc-cbp-tip      .
           move      w-tes-nos-ban (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
           move      w-let-arc-cbp-des    to   w-tes-nos-ban-des (1)  .
           perform   vis-nos-ban-des-000  thru vis-nos-ban-des-999    .
           go to     acc-cod-fop-620.
       acc-cod-fop-615.
      *                      *-----------------------------------------*
      *                      * Se non da trattare                      *
      *                      *-----------------------------------------*
           if        w-tes-nos-ban (1)    =    spaces
                     go to acc-cod-fop-620.
           move      spaces               to   w-tes-nos-ban (1)      .
           move      spaces               to   w-tes-nos-ban-des (1)  .
           perform   vis-nos-ban-000      thru vis-nos-ban-999        .
           perform   vis-nos-ban-des-000  thru vis-nos-ban-des-999    .
           go to     acc-cod-fop-620.
       acc-cod-fop-620.
      *                  *---------------------------------------------*
      *                  * Trattamento codice nostro c/c postale per   *
      *                  * pagamento                                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se da trattare                          *
      *                      *-----------------------------------------*
           if        w-tes-snx-ncp (1)    not  = "S"
                     go to acc-cod-fop-625.
           if        w-tes-nos-ccp (1)    not  = spaces
                     go to acc-cod-fop-630.
           move      w-tes-ncp-aac (1)    to   w-tes-nos-ccp (1)      .
           perform   vis-nos-ccp-000      thru vis-nos-ccp-999        .
           move      03                   to   w-let-arc-cbp-tip      .
           move      w-tes-nos-ccp (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
           move      w-let-arc-cbp-des    to   w-tes-nos-ccp-des (1)  .
           perform   vis-nos-ccp-des-000  thru vis-nos-ccp-des-999    .
           go to     acc-cod-fop-630.
       acc-cod-fop-625.
      *                      *-----------------------------------------*
      *                      * Se non da trattare                      *
      *                      *-----------------------------------------*
           if        w-tes-nos-ccp (1)    =    spaces
                     go to acc-cod-fop-630.
           move      spaces               to   w-tes-nos-ccp (1)      .
           move      spaces               to   w-tes-nos-ccp-des (1)  .
           perform   vis-nos-ccp-000      thru vis-nos-ccp-999        .
           perform   vis-nos-ccp-des-000  thru vis-nos-ccp-des-999    .
           go to     acc-cod-fop-630.
       acc-cod-fop-630.
      *                  *---------------------------------------------*
      *                  * Trattamento codici Abi e Cab                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se da trattare                          *
      *                      *-----------------------------------------*
           if        w-tes-snx-abi (1)    not  = "S"
                     go to acc-cod-fop-635.
           if        w-tes-cod-abi (1)    not  = zero
                     go to acc-cod-fop-640.
           move      w-tes-dpc-plf (1)    to   w-det-vlt-ipg-dpz      .
           perform   det-vlt-ipg-000      thru det-vlt-ipg-999        .
           move      w-tes-cod-abi (1)    to   w-let-arc-axi-cod      .
           perform   let-arc-axi-000      thru let-arc-axi-999        .
           move      w-let-arc-axi-den    to   w-tes-cod-abi-den (1)  .
           perform   vis-cod-abi-000      thru vis-cod-abi-999        .
           perform   vis-den-abi-000      thru vis-den-abi-999        .
           move      w-tes-cod-abi (1)    to   w-let-arc-axs-abi      .
           move      w-tes-cod-cab (1)    to   w-let-arc-axs-cab      .
           perform   let-arc-axs-000      thru let-arc-axs-999        .
           move      w-let-arc-axs-den    to   w-tes-cod-cab-den (1)  .
           perform   vis-cod-cab-000      thru vis-cod-cab-999        .
           perform   vis-den-cab-000      thru vis-den-cab-999        .
           go to     acc-cod-fop-640.
       acc-cod-fop-635.
      *                      *-----------------------------------------*
      *                      * Se non da trattare                      *
      *                      *-----------------------------------------*
           if        w-tes-cod-abi (1)    =    zero
                     go to acc-cod-fop-640.
           move      zero                 to   w-tes-cod-abi (1)      .
           move      spaces               to   w-tes-cod-abi-den (1)  .
           perform   vis-cod-abi-000      thru vis-cod-abi-999        .
           perform   vis-den-abi-000      thru vis-den-abi-999        .
           move      zero                 to   w-tes-cod-cab (1)      .
           move      spaces               to   w-tes-cod-cab-den (1)  .
           perform   vis-cod-cab-000      thru vis-cod-cab-999        .
           perform   vis-den-cab-000      thru vis-den-cab-999        .
           go to     acc-cod-fop-640.
       acc-cod-fop-640.
      *                  *---------------------------------------------*
      *                  * Trattamento c/c di appoggio cliente         *
      *                  *---------------------------------------------*
           if        w-tes-snx-rid (1)    =    spaces   and
                     w-tes-ccc-app (1)    not  = spaces
                     move  spaces         to   w-tes-ccc-app (1)
                     perform vis-ccc-app-000
                                          thru vis-ccc-app-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento data scadenza pagamento manuale *
      *                  *---------------------------------------------*
           if        w-tes-snx-spm (1)    =    spaces and
                     w-tes-pag-dsm (1)    not  = zero
                     move  zero           to   w-tes-pag-dsm (1)
                     perform vis-pag-dsm-000
                                          thru vis-pag-dsm-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento quota a forfait                 *
      *                  *---------------------------------------------*
           if        w-tes-snx-qaf (1)    =    spaces and
                     w-tes-pag-qaf (1)    not  = zero
                     move  zero           to   w-tes-pag-qaf (1)
                     perform vis-pag-qaf-000
                                          thru vis-pag-qaf-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento acconto                         *
      *                  *---------------------------------------------*
           if        w-tes-snx-act (1)    =    spaces and
                     w-tes-pag-act (1)    not  = zero
                     move  zero           to   w-tes-pag-act (1)
                     perform vis-pag-act-000
                                          thru vis-pag-act-999        .
       acc-cod-fop-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-fop-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-fop-100.
       acc-cod-fop-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice forma di pagamento *
      *    *-----------------------------------------------------------*
       vis-cod-fop-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-fop (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-fop-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione forma di paga-*
      *    * mento                                                     *
      *    *-----------------------------------------------------------*
       vis-des-fop-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-fop-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-fop-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Indicazione scadenze modificabili *
      *    *-----------------------------------------------------------*
       vis-snx-ims-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      18                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      63                   to   v-pos                  .
      *
           if        w-tes-snx-ims (1)    =    "S"
                     move  "(Scadenze manuali)"
                                          to   v-alf
           else      move  spaces         to   v-alf                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-snx-ims-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : % sconto pagamento        *
      *    *-----------------------------------------------------------*
       vis-scp-aap-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      06                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<BD"                to   v-edm                  .
           move      w-tes-scp-aap (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-scp-aap-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice nostra banca per bo-  *
      *    * nifico                                                    *
      *    *-----------------------------------------------------------*
       acc-nos-ban-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-nos-ban-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-nos-ban-400.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
            if       w-tes-snx-nsb (1)    =    spaces
                     go to acc-nos-ban-999.
       acc-nos-ban-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-des-cbp-ope      .
           move      02                   to   w-cod-des-cbp-tip      .
           move      w-tes-nos-ban (1)    to   w-cod-des-cbp-cod      .
           move      12                   to   w-cod-des-cbp-lin      .
           move      30                   to   w-cod-des-cbp-pos      .
           move      12                   to   w-cod-des-cbp-dln      .
           move      41                   to   w-cod-des-cbp-dps      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-des-cbp-cll-000  thru cod-des-cbp-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-des-cbp-foi-000  thru cod-des-cbp-foi-999    .
       acc-nos-ban-110.
           perform   cod-des-cbp-cll-000  thru cod-des-cbp-cll-999    .
           if        w-cod-des-cbp-ope    =    "F+"
                     go to acc-nos-ban-115.
           if        w-cod-des-cbp-ope    =    "AC"
                     go to acc-nos-ban-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-nos-ban-115.
           perform   cod-des-cbp-foi-000  thru cod-des-cbp-foi-999    .
           go to     acc-nos-ban-110.
       acc-nos-ban-120.
           move      w-cod-des-cbp-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-nos-ban-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-nos-ban-999.
       acc-nos-ban-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-nos-ban (1)      .
       acc-nos-ban-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [cbp]                      *
      *                  *---------------------------------------------*
           move      02                   to   w-let-arc-cbp-tip      .
           move      w-tes-nos-ban (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-cbp-des    to   w-tes-nos-ban-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-nos-ban-des-000  thru vis-nos-ban-des-999    .
      *                  *---------------------------------------------*
      *                  * Se record non esistente : reimpostazione    *
      *                  *---------------------------------------------*
           if        w-let-arc-cbp-flg    not  = spaces
                     go to acc-nos-ban-100.
       acc-nos-ban-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-nos-ban-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-nos-ban-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-nos-ban-100.
       acc-nos-ban-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice nostra banca per   *
      *    * bonifico                                                  *
      *    *-----------------------------------------------------------*
       vis-nos-ban-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-nos-ban (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-nos-ban-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice nostra banca per   *
      *    * bonifico, descrizione                                     *
      *    *-----------------------------------------------------------*
       vis-nos-ban-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-nos-ban-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-nos-ban-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice nostro c/c postale    *
      *    * per pagamento                                             *
      *    *-----------------------------------------------------------*
       acc-nos-ccp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-nos-ccp-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-nos-ccp-400.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
            if       w-tes-snx-ncp (1)    =    spaces
                     go to acc-nos-ccp-999.
       acc-nos-ccp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-des-cbp-ope      .
           move      03                   to   w-cod-des-cbp-tip      .
           move      w-tes-nos-ccp (1)    to   w-cod-des-cbp-cod      .
           move      13                   to   w-cod-des-cbp-lin      .
           move      30                   to   w-cod-des-cbp-pos      .
           move      13                   to   w-cod-des-cbp-dln      .
           move      41                   to   w-cod-des-cbp-dps      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-des-cbp-cll-000  thru cod-des-cbp-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-des-cbp-foi-000  thru cod-des-cbp-foi-999    .
       acc-nos-ccp-110.
           perform   cod-des-cbp-cll-000  thru cod-des-cbp-cll-999    .
           if        w-cod-des-cbp-ope    =    "F+"
                     go to acc-nos-ccp-115.
           if        w-cod-des-cbp-ope    =    "AC"
                     go to acc-nos-ccp-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-nos-ccp-115.
           perform   cod-des-cbp-foi-000  thru cod-des-cbp-foi-999    .
           go to     acc-nos-ccp-110.
       acc-nos-ccp-120.
           move      w-cod-des-cbp-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-nos-ccp-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-nos-ccp-999.
       acc-nos-ccp-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-nos-ccp (1)      .
       acc-nos-ccp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [cbp]                      *
      *                  *---------------------------------------------*
           move      03                   to   w-let-arc-cbp-tip      .
           move      w-tes-nos-ccp (1)    to   w-let-arc-cbp-cod      .
           perform   let-arc-cbp-000      thru let-arc-cbp-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-cbp-des    to   w-tes-nos-ccp-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-nos-ccp-des-000  thru vis-nos-ccp-des-999    .
      *                  *---------------------------------------------*
      *                  * Se record non esistente : reimpostazione    *
      *                  *---------------------------------------------*
           if        w-let-arc-cbp-flg    not  = spaces
                     go to acc-nos-ccp-100.
       acc-nos-ccp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-nos-ccp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-nos-ccp-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-nos-ccp-100.
       acc-nos-ccp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice nostro c/c postale *
      *    * per pagamento                                             *
      *    *-----------------------------------------------------------*
       vis-nos-ccp-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-nos-ccp (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-nos-ccp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice nostro c/c postale *
      *    * per pagamento, descrizione                                *
      *    *-----------------------------------------------------------*
       vis-nos-ccp-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-nos-ccp-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-nos-ccp-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice ABI banca d'appoggio  *
      *    *-----------------------------------------------------------*
       acc-cod-abi-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-cod-abi-999.
            if       w-tes-snx-abi (1)    =    spaces
                     go to acc-cod-abi-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cod-abi (1)    to   w-sav-cod-abi          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-abi-400.
       acc-cod-abi-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-abi-ope      .
           move      w-tes-cod-abi (1)    to   w-cod-mne-abi-cod      .
           move      08                   to   w-cod-mne-abi-lin      .
           move      30                   to   w-cod-mne-abi-pos      .
           move      08                   to   w-cod-mne-abi-dln      .
           move      41                   to   w-cod-mne-abi-dps      .
           move      "9B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-abi-cll-000  thru cod-mne-abi-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-abi-foi-000  thru cod-mne-abi-foi-999    .
       acc-cod-abi-110.
           perform   cod-mne-abi-cll-000  thru cod-mne-abi-cll-999    .
           if        w-cod-mne-abi-ope    =    "F+"
                     go to acc-cod-abi-115.
           if        w-cod-mne-abi-ope    =    "AC"
                     go to acc-cod-abi-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-abi-115.
           perform   cod-mne-abi-foi-000  thru cod-mne-abi-foi-999    .
           go to     acc-cod-abi-110.
       acc-cod-abi-120.
           move      w-cod-mne-abi-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-abi-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-abi-999.
       acc-cod-abi-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-abi (1)      .
       acc-cod-abi-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura anagrafica istituti                 *
      *                  *---------------------------------------------*
           move      w-tes-cod-abi (1)    to   w-let-arc-axi-cod      .
           perform   let-arc-axi-000      thru let-arc-axi-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione denominazione                *
      *                  *---------------------------------------------*
           move      w-let-arc-axi-den    to   w-tes-cod-abi-den (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione denominazione               *
      *                  *---------------------------------------------*
           perform   vis-den-abi-000      thru vis-den-abi-999        .
      *                  *---------------------------------------------*
      *                  * Test su flag di uscita da lettura           *
      *                  *---------------------------------------------*
           if        w-let-arc-axi-flg    not  = spaces
                     go to acc-cod-abi-100.
       acc-cod-abi-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se variato codice ABI                       *
      *                  *---------------------------------------------*
           if        w-tes-cod-abi (1)    =    w-sav-cod-abi
                     go to acc-cod-abi-800.
           if        w-tes-cod-cab (1)    =    zero
                     go to acc-cod-abi-800.
      *                      *-----------------------------------------*
      *                      * Normalizzazione dati sportello CAB      *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-cod-cab (1)      .
           move      spaces               to   w-tes-cod-cab-den (1)  .
      *                      *-----------------------------------------*
      *                      * Visualizzazione dati sportello CAB      *
      *                      *-----------------------------------------*
           perform   vis-cod-cab-000      thru vis-cod-cab-999        .
           perform   vis-den-cab-000      thru vis-den-cab-999        .
       acc-cod-abi-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-abi-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-abi-100.
       acc-cod-abi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice ABI banca          *
      *    *-----------------------------------------------------------*
       vis-cod-abi-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9B"                 to   v-edm                  .
           move      08                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-abi (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-abi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Denominazione banca       *
      *    *-----------------------------------------------------------*
       vis-den-abi-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-abi-den (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-den-abi-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice CAB                   *
      *    *-----------------------------------------------------------*
       acc-cod-cab-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-cod-cab-999.
           if        w-tes-cod-abi (1)    =    zero
                     go to acc-cod-cab-999.
            if       w-tes-snx-abi (1)    =    spaces
                     go to acc-cod-cab-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-cab-400.
       acc-cod-cab-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-cab-ope      .
           move      w-tes-cod-abi (1)    to   w-cod-mne-cab-abi      .
           move      w-tes-cod-cab (1)    to   w-cod-mne-cab-cab      .
           move      09                   to   w-cod-mne-cab-lin      .
           move      30                   to   w-cod-mne-cab-pos      .
           move      09                   to   w-cod-mne-cab-dln      .
           move      41                   to   w-cod-mne-cab-dps      .
           move      "9B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-cab-cll-000  thru cod-mne-cab-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-cab-foi-000  thru cod-mne-cab-foi-999    .
       acc-cod-cab-110.
           perform   cod-mne-cab-cll-000  thru cod-mne-cab-cll-999    .
           if        w-cod-mne-cab-ope    =    "F+"
                     go to acc-cod-cab-115.
           if        w-cod-mne-cab-ope    =    "AC"
                     go to acc-cod-cab-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-cab-115.
           perform   cod-mne-cab-foi-000  thru cod-mne-cab-foi-999    .
           go to     acc-cod-cab-110.
       acc-cod-cab-120.
           move      w-cod-mne-cab-cab    to   v-num                  .
       acc-cod-cab-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cab-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cab-999.
       acc-cod-cab-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-cab (1)      .
       acc-cod-cab-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      w-tes-cod-abi (1)    to   w-let-arc-axs-abi      .
           move      w-tes-cod-cab (1)    to   w-let-arc-axs-cab      .
           perform   let-arc-axs-000      thru let-arc-axs-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-axs-den    to   w-tes-cod-cab-den (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-den-cab-000      thru vis-den-cab-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-axs-flg    not  = spaces
                     go to acc-cod-cab-100.
       acc-cod-cab-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-cab-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-cab-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-cab-100.
       acc-cod-cab-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice CAB                *
      *    *-----------------------------------------------------------*
       vis-cod-cab-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9B"                 to   v-edm                  .
           move      09                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-cab (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-cab-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Denominazione sportello   *
      *    *-----------------------------------------------------------*
       vis-den-cab-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      30                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-cab-den (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-den-cab-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Conto corrente del cliente   *
      *    *-----------------------------------------------------------*
       acc-ccc-app-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-ccc-app-999.
           if        w-tes-snx-rid (1)    =    spaces
                     go to acc-ccc-app-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-ccc-app-400.
       acc-ccc-app-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-ccc-app (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-ccc-app-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-ccc-app-999.
       acc-ccc-app-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-ccc-app (1)      .
       acc-ccc-app-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-ccc-app-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ccc-app-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-ccc-app-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-ccc-app-100.
       acc-ccc-app-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Conto corrente cliente    *
      *    *-----------------------------------------------------------*
       vis-ccc-app-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-ccc-app (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ccc-app-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Addebito spese incasso       *
      *    *-----------------------------------------------------------*
       acc-add-spi-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-add-spi-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-add-spi-400.
       acc-add-spi-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-zin-ope      .
           move      w-tes-add-spi (1)    to   w-cod-cod-zin-cod      .
           move      15                   to   w-cod-cod-zin-lin      .
           move      30                   to   w-cod-cod-zin-pos      .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "PRSC"               to   v-pfk (07)             .
           move      "NXSC"               to   v-pfk (08)             .
           perform   cod-cod-spi-cll-000  thru cod-cod-spi-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-spi-foi-000  thru cod-cod-spi-foi-999    .
       acc-add-spi-110.
           perform   cod-cod-spi-cll-000  thru cod-cod-spi-cll-999    .
           if        w-cod-cod-zin-ope    =    "F+"
                     go to acc-add-spi-115.
           if        w-cod-cod-zin-ope    =    "AC"
                     go to acc-add-spi-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-add-spi-115.
           perform   cod-cod-spi-foi-000  thru cod-cod-spi-foi-999    .
           go to     acc-add-spi-110.
       acc-add-spi-120.
           move      w-cod-cod-zin-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-add-spi-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-add-spi-999.
       acc-add-spi-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-add-spi (1)      .
       acc-add-spi-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      w-tes-add-spi (1)    to   w-let-arc-zin-cod      .
           move      00                   to   w-let-arc-zin-tpg      .
           perform   let-arc-zin-000      thru let-arc-zin-999        .
           move      w-let-arc-zin-des    to   w-tes-add-spi-des (1)  .
           move      w-let-arc-zin-coi    to   w-tes-civ-spi (1)      .
           move      w-let-arc-zin-ccp    to   w-tes-ccp-spi (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-spi-000      thru vis-des-spi-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-zin-flg    not  = spaces
                     go to acc-add-spi-100.
       acc-add-spi-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione valori testata indotti da    *
      *                  * record [zin]                                *
      *                  *---------------------------------------------*
           perform   det-vlt-zin-000      thru det-vlt-zin-999        .
      *                  *---------------------------------------------*
      *                  * Eventuale avviso per scadenze manuali       *
      *                  *---------------------------------------------*
           if        w-tes-add-spi (1)    =    spaces
                     go to acc-add-spi-800.
           if        w-tes-snx-ims (1)    not  = "S"
                     go to acc-add-spi-800.
      *                  *---------------------------------------------*
      *                  * Messaggio                                   *
      *                  *---------------------------------------------*
           move      "Attenzione : le scadenze manuali non prevedono il 
      -              "calcolo automati- " to   w-err-box-err-msg      .
           move      "             co delle spese incasso. Utilizzare qu
      -              "elle aggiuntive   " to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       acc-add-spi-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-add-spi-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-add-spi-100.
       acc-add-spi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Addebito spese incasso    *
      *    *-----------------------------------------------------------*
       vis-add-spi-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-add-spi (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-add-spi-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descriz. spese incasso    *
      *    *-----------------------------------------------------------*
       vis-des-spi-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-add-spi-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-spi-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Addebito spese bollo         *
      *    *-----------------------------------------------------------*
       acc-add-spb-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-add-spb-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-add-spb-400.
       acc-add-spb-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-zbo-ope      .
           move      w-tes-add-spb (1)    to   w-cod-cod-zbo-cod      .
           move      16                   to   w-cod-cod-zbo-lin      .
           move      30                   to   w-cod-cod-zbo-pos      .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "PRSC"               to   v-pfk (07)             .
           move      "NXSC"               to   v-pfk (08)             .
           perform   cod-cod-spb-cll-000  thru cod-cod-spb-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-spb-foi-000  thru cod-cod-spb-foi-999    .
       acc-add-spb-110.
           perform   cod-cod-spb-cll-000  thru cod-cod-spb-cll-999    .
           if        w-cod-cod-zbo-ope    =    "F+"
                     go to acc-add-spb-115.
           if        w-cod-cod-zbo-ope    =    "AC"
                     go to acc-add-spb-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-add-spb-115.
           perform   cod-cod-spb-foi-000  thru cod-cod-spb-foi-999    .
           go to     acc-add-spb-110.
       acc-add-spb-120.
           move      w-cod-cod-zbo-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-add-spb-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-add-spb-999.
       acc-add-spb-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-add-spb (1)      .
       acc-add-spb-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      w-tes-add-spb (1)    to   w-let-arc-zbo-cod      .
           move      00                   to   w-let-arc-zbo-tpg      .
           perform   let-arc-zbo-000      thru let-arc-zbo-999        .
           move      w-let-arc-zbo-des    to   w-tes-add-spb-des (1)  .
           move      w-let-arc-zbo-coi    to   w-tes-civ-spb (1)      .
           move      w-let-arc-zbo-ccp    to   w-tes-ccp-spb (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-spb-000      thru vis-des-spb-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-zbo-flg    not  = spaces
                     go to acc-add-spb-100.
       acc-add-spb-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione valori testata indotti da    *
      *                  * record [zbo]                                *
      *                  *---------------------------------------------*
           perform   det-vlt-zbo-000      thru det-vlt-zbo-999        .
       acc-add-spb-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-add-spb-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-add-spb-100.
       acc-add-spb-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Addebito spese bollo      *
      *    *-----------------------------------------------------------*
       vis-add-spb-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-add-spb (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-add-spb-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descriz. spese bollo      *
      *    *-----------------------------------------------------------*
       vis-des-spb-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-add-spb-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-spb-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Data scadenza pagamento      *
      *    *-----------------------------------------------------------*
       acc-pag-dsm-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-pag-dsm-999.
           if        w-tes-snx-spm (1)    =    spaces
                     go to acc-pag-dsm-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-pag-dsm-400.
       acc-pag-dsm-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      18                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      ">"                  to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-pag-dsm (1)    to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pag-dsm-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pag-dsm-999.
       acc-pag-dsm-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-dat                to   w-tes-pag-dsm (1)      .
       acc-pag-dsm-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se inferiore a data documento          *
      *                  *---------------------------------------------*
           if        w-tes-pag-dsm (1)    <    w-tes-dat-doc
                     go to acc-pag-dsm-100.
      *                  *---------------------------------------------*
      *                  * Test se cade entro i mesi esclusi           *
      *                  *---------------------------------------------*
           if        w-tes-tip-esm (1)    =    zero
                     go to acc-pag-dsm-600.
           move      w-tes-pag-dsm (1)    to   s-dat                  .
           if        s-mes                not  = w-tes-mmm-e01 (1) and
                     s-mes                not  = w-tes-mmm-e02 (1)
                     go to acc-pag-dsm-600.
      *                      *-----------------------------------------*
      *                      * Salvataggio immagine video              *
      *                      *-----------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Video in Off                            *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Box                                     *
      *                      *-----------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      07                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      74                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Literals nel box                        *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "Attenzione :  la data di scadenza impostata cade i
      -              "n uno dei mesi"     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "              esclusi dal cliente"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "Scelta     :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Video in On                             *
      *                      *-----------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-pag-dsm-425.
      *                      *-----------------------------------------*
      *                      * Accettazione risposta                   *
      *                      *-----------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-err-dsm-lun    to   v-car                  .
           move      w-exp-err-dsm-num    to   v-ldt                  .
           move      "RF#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      14                   to   v-lin                  .
           move      23                   to   v-pos                  .
           move      w-exp-err-dsm-tbl    to   v-txt                  .
           move      zero                 to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-num                to   w-exp-err-dsm-sce      .
      *                      *-----------------------------------------*
      *                      * Controllo risposta                      *
      *                      *-----------------------------------------*
           if        w-exp-err-dsm-sce    not  = 01 and
                     w-exp-err-dsm-sce    not  = 02
                     go to acc-pag-dsm-425.
      *                      *-----------------------------------------*
      *                      * Ripristino immagine video               *
      *                      *-----------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda della risposta     *
      *                      *-----------------------------------------*
           if        w-exp-err-dsm-sce    =    01
                     go to acc-pag-dsm-100.
       acc-pag-dsm-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-pag-dsm-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pag-dsm-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pag-dsm-100.
       acc-pag-dsm-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Data scadenza pagamento   *
      *    *-----------------------------------------------------------*
       vis-pag-dsm-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      18                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-pag-dsm (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-pag-dsm-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Importo quota a forfait      *
      *    *-----------------------------------------------------------*
       acc-pag-qaf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-pag-qaf-999.
            if       w-tes-snx-qaf (1)    =    spaces
                     go to acc-pag-qaf-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-pag-qaf-400.
       acc-pag-qaf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      19                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<BG"                to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-pag-qaf (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pag-qaf-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pag-qaf-999.
       acc-pag-qaf-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-pag-qaf (1)      .
       acc-pag-qaf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-pag-qaf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore diverso da zero : attivazione     *
      *                  * flag di accettazione valuta per fatturazio- *
      *                  * ne                                          *
      *                  *---------------------------------------------*
           if        w-tes-pag-qaf (1)    not  = zero
                     move  "#"            to   w-tes-fda-vpf (1)      .
       acc-pag-qaf-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pag-qaf-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pag-qaf-100.
       acc-pag-qaf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Importo quota a forfait   *
      *    *-----------------------------------------------------------*
       vis-pag-qaf-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      19                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<BG"                to   v-edm                  .
           move      w-tes-pag-qaf (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-pag-qaf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Importo acconto              *
      *    *-----------------------------------------------------------*
       acc-pag-act-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-pag-act-999.
            if       w-tes-snx-act (1)    =    spaces
                     go to acc-pag-act-999.
           if        w-ctl-cau-doc-tdo    =    03
                     go to acc-pag-act-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-pag-act (1)    to   w-sav-pag-act          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-pag-act-400.
       acc-pag-act-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      20                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<BG"                to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-pag-act (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pag-act-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pag-act-999.
       acc-pag-act-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-pag-act (1)      .
       acc-pag-act-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-pag-act-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-pag-act (1)    =    zero
                     go to acc-pag-act-800.
           if        w-tes-pag-act (1)    =    w-sav-pag-act
                     go to acc-pag-act-800.
      *                  *---------------------------------------------*
      *                  * Se valore diverso da zero : attivazione     *
      *                  * flag di accettazione valuta per fatturazio- *
      *                  * ne                                          *
      *                  *---------------------------------------------*
           if        w-tes-pag-act (1)    not  = zero
                     move  "#"            to   w-tes-fda-vpf (1)      .
      *                  *---------------------------------------------*
      *                  * Se valore diverso da zero : accettazione    *
      *                  * di eventuali riferimenti alla fattura di    *
      *                  * acconto                                     *
      *                  *---------------------------------------------*
           perform   pmt-dri-act-000      thru pmt-dri-act-999        .
           perform   pmt-nri-act-000      thru pmt-nri-act-999        .
       acc-pag-act-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pag-act-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pag-act-100.
       acc-pag-act-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Importo acconto           *
      *    *-----------------------------------------------------------*
       vis-pag-act-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      20                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<BG"                to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-pag-act (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-pag-act-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Data riferimento per acconto         *
      *    *-----------------------------------------------------------*
       acc-dri-act-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-dri-act-999.
           if        w-tes-pag-act (1)    =    zero
                     go to acc-dri-act-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-dri-act-400.
       acc-dri-act-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      20                   to   v-lin                  .
           move      71                   to   v-pos                  .
           move      w-tes-dri-mgd (1)    to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-dri-act-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-dri-act-999.
       acc-dri-act-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-dat                to   w-tes-dri-mgd (1)      .
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-dri-act-400.
      *                  *---------------------------------------------*
      *                  * Find su riferimenti cliente                 *
      *                  *---------------------------------------------*
           move      w-tes-cli-plf (1)    to   w-fnd-rif-cli-cod      .
           perform   fnd-rif-cli-000      thru fnd-rif-cli-999        .
      *                  *---------------------------------------------*
      *                  * Se nessuna selezione : reimpostazione       *
      *                  *---------------------------------------------*
           if        w-fnd-rif-cli-sel    not  = spaces
                     go to acc-dri-act-100.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione riferimenti selezionati     *
      *                  *---------------------------------------------*
           move      w-fnd-rif-cli-dat    to   w-tes-dri-mgd (1)      .
           move      w-fnd-rif-cli-num    to   w-tes-nri-mgd (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione riferimenti selezionati     *
      *                  *---------------------------------------------*
           perform   vis-dri-act-000      thru vis-dri-act-999        .
           perform   vis-nri-act-000      thru vis-nri-act-999        .
      *                  *---------------------------------------------*
      *                  * Continuazione                               *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
           go to     acc-dri-act-400.
       acc-dri-act-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-dri-act-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se data riferimento a zero si forza spaces  *
      *                  * il numero riferimento                       *
      *                  *---------------------------------------------*
           if        w-tes-dri-mgd (1)    not  = zero
                     go to acc-dri-act-800.
           if        w-tes-nri-mgd (1)    =    spaces
                     go to acc-dri-act-800.
           move      spaces               to   w-tes-nri-mgd (1)      .
           perform   vis-nri-act-000      thru vis-nri-act-999        .
       acc-dri-act-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-dri-act-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-dri-act-100.
       acc-dri-act-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Data riferimento per acconto      *
      *    *-----------------------------------------------------------*
       vis-dri-act-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-pag-act (1)    =    zero
                     go to vis-dri-act-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      spaces               to   v-edm                  .
           move      20                   to   v-lin                  .
           move      71                   to   v-pos                  .
           move      w-tes-dri-mgd (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dri-act-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Numero riferimento per acconto       *
      *    *-----------------------------------------------------------*
       acc-nri-act-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-nri-act-999.
           if        w-tes-pag-act (1)    =    zero
                     go to acc-nri-act-999.
           if        w-tes-dri-mgd (1)    =    zero
                     go to acc-nri-act-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-nri-act-400.
       acc-nri-act-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      21                   to   v-lin                  .
           move      71                   to   v-pos                  .
           move      w-tes-nri-mgd (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-nri-act-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-nri-act-999.
       acc-nri-act-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-nri-mgd (1)      .
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-nri-act-400.
      *                  *---------------------------------------------*
      *                  * Find su riferimenti cliente                 *
      *                  *---------------------------------------------*
           move      w-tes-cli-plf (1)    to   w-fnd-rif-cli-cod      .
           perform   fnd-rif-cli-000      thru fnd-rif-cli-999        .
      *                  *---------------------------------------------*
      *                  * Se nessuna selezione : reimpostazione       *
      *                  *---------------------------------------------*
           if        w-fnd-rif-cli-sel    not  = spaces
                     go to acc-nri-act-100.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione riferimenti selezionati     *
      *                  *---------------------------------------------*
           move      w-fnd-rif-cli-dat    to   w-tes-dri-mgd (1)      .
           move      w-fnd-rif-cli-num    to   w-tes-nri-mgd (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione riferimenti selezionati     *
      *                  *---------------------------------------------*
           perform   vis-nri-act-000      thru vis-nri-act-999        .
           perform   vis-nri-act-000      thru vis-nri-act-999        .
      *                  *---------------------------------------------*
      *                  * Continuazione                               *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
           go to     acc-nri-act-400.
       acc-nri-act-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a spaces non ammesso, a meno che non *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-tes-nri-mgd (1)    not  = spaces
                     go to acc-nri-act-600.
           if        v-key                =    "UP  "
                     go to acc-nri-act-600
           else      go to acc-nri-act-100.
       acc-nri-act-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-nri-act-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-nri-act-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-nri-act-100.
       acc-nri-act-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Data riferimento per acconto      *
      *    *-----------------------------------------------------------*
       vis-nri-act-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-pag-act (1)    =    zero
                     go to vis-nri-act-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      71                   to   v-pos                  .
           move      w-tes-nri-mgd (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-nri-act-999.
           exit.

