      *    *===========================================================*
      *    * Accettazione campo testata : Presa visione per pagina     *
      *    *-----------------------------------------------------------*
       acc-pre-vpg-000.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      spaces               to   v-msk                  .
           move      spaces               to   v-alf                  .
           move      spaces               to   v-not                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vpg-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pre-vpg-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pre-vpg-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pre-vpg-000.
       acc-pre-vpg-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice cliente               *
      *    *-----------------------------------------------------------*
       acc-cod-cli-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-cod-cli-999.
      *                  *---------------------------------------------*
      *                  * Se flag di modificabilita' parziale regi-   *
      *                  * strazione attivo : non accettabile          *
      *                  *---------------------------------------------*
           if        w-tes-flg-mdp        not  = spaces
                     go to acc-cod-cli-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cod-cli (1)    to   w-sav-cod-cli          .
           move      spaces               to   w-sav-cod-cli-flg      .
      *                  *---------------------------------------------*
      *                  * Eventuale default per Autofattura           *
      *                  *---------------------------------------------*
           if        w-tes-tip-mov-tdo    not  = 05
                     go to acc-cod-cli-100.
           if        w-tes-tip-mov-caf    =    zero
                     go to acc-cod-cli-100.
           move      w-tes-tip-mov-caf    to   w-tes-cod-cli (1)      .
       acc-cod-cli-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-dcc-ope      .
           move      w-tes-cod-cli (1)    to   w-cod-mne-dcc-cod      .
           move      08                   to   w-cod-mne-dcc-lin      .
           move      30                   to   w-cod-mne-dcc-pos      .
           move      08                   to   w-cod-mne-dcc-rln      .
           move      41                   to   w-cod-mne-dcc-rps      .
           move      09                   to   w-cod-mne-dcc-vln      .
           move      41                   to   w-cod-mne-dcc-vps      .
           move      10                   to   w-cod-mne-dcc-lln      .
           move      41                   to   w-cod-mne-dcc-lps      .
           move      "<B"                 to   v-edm                  .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-dcc-cll-000  thru cod-mne-dcc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-dcc-foi-000  thru cod-mne-dcc-foi-999    .
       acc-cod-cli-110.
           perform   cod-mne-dcc-cll-000  thru cod-mne-dcc-cll-999    .
           if        w-cod-mne-dcc-ope    =    "F+"
                     go to acc-cod-cli-115.
           if        w-cod-mne-dcc-ope    =    "AC"
                     go to acc-cod-cli-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-cli-115.
           perform   cod-mne-dcc-foi-000  thru cod-mne-dcc-foi-999    .
           go to     acc-cod-cli-110.
       acc-cod-cli-120.
           move      w-cod-mne-dcc-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cli-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cli-999.
       acc-cod-cli-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-cli (1)      .
       acc-cod-cli-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Subroutine per controlli su cliente         *
      *                  *---------------------------------------------*
           move      w-tes-cod-cli (1)    to   w-ctl-cod-cli-cod      .
           perform   acc-cod-cli-ctl-000  thru acc-cod-cli-ctl-999    .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione cliente         *
      *                  *---------------------------------------------*
           perform   vis-cod-cli-des-000  thru vis-cod-cli-des-999    .
      *                  *---------------------------------------------*
      *                  * Controllo su flag di 'exit'                 *
      *                  *---------------------------------------------*
           if        w-ctl-cod-cli-ext    not  = spaces
                     go to acc-cod-cli-999.
      *                  *---------------------------------------------*
      *                  * Controllo su flag di errore                 *
      *                  *---------------------------------------------*
           if        w-ctl-cod-cli-flg    not  = spaces
                     go to acc-cod-cli-100.
      *                  *---------------------------------------------*
      *                  * Subroutine per note su cliente              *
      *                  *---------------------------------------------*
           perform   cod-mne-dcc-not-000  thru cod-mne-dcc-not-999    .
       acc-cod-cli-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se variato                         *
      *                      *-----------------------------------------*
           if        w-tes-cod-cli (1)    =    w-sav-cod-cli
                     go to acc-cod-cli-800.
      *                      *-----------------------------------------*
      *                      * Flag di modifica avvenuta               *
      *                      *-----------------------------------------*
           move      "#"                  to   w-sav-cod-cli-flg      .
      *                      *-----------------------------------------*
      *                      * Test se modificabile                    *
      *                      *-----------------------------------------*
           if        w-tes-fda-pt1 (1)    =    spaces
                     go to acc-cod-cli-602.
      *                      *-----------------------------------------*
      *                      * Box di avvertimento                     *
      *                      *-----------------------------------------*
           perform   acc-cod-cli-mod-000  thru acc-cod-cli-mod-999    .
      *                      *-----------------------------------------*
      *                      * Test su scelta                          *
      *                      *-----------------------------------------*
           if        w-exp-arc-mod-sce    =    01
                     go to acc-cod-cli-100.
       acc-cod-cli-602.
      *                  *---------------------------------------------*
      *                  * Trattamento tipo fornitura abituale         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da trattare                     *
      *                      *-----------------------------------------*
           if        w-prs-ges-apf        not  = 11 and
                     w-prs-ges-apf        not  = 21 and
                     w-prs-ges-apf        not  = 99
                     go to acc-cod-cli-605.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione e visualizzazione       *
      *                      *-----------------------------------------*
           move      w-let-arc-dcc-tpf    to   w-tes-tip-frn (1)      .
           perform   vis-tip-frn-000      thru vis-tip-frn-999        .
       acc-cod-cli-605.
      *                      *-----------------------------------------*
      *                      * Normalizzazione e rivisualizzazione di- *
      *                      * pendenza                                *
      *                      *-----------------------------------------*
           move      spaces               to   w-tes-dpz-cli (1)      .
           move      spaces               to   w-tes-dpz-cli-rag (1)  .
           move      spaces               to   w-tes-dpz-cli-via (1)  .
           move      spaces               to   w-tes-dpz-cli-loc (1)  .
           perform   vis-dpz-cli-000      thru vis-dpz-cli-999        .
           perform   vis-des-dpz-000      thru vis-des-dpz-999        .
      *                      *-----------------------------------------*
      *                      * Normalizzazione dati testata associati  *
      *                      * alla dipendenza                         *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-abi-dpz (1)      .
           move      spaces               to   w-tes-abi-dpz-den (1)  .
           move      zero                 to   w-tes-cab-dpz (1)      .
           move      spaces               to   w-tes-cab-dpz-den (1)  .
           move      spaces               to   w-tes-cca-dpz (1)      .
           move      zero                 to   w-tes-age-aad (1)      .
      *                      *-----------------------------------------*
      *                      * Determinazione valori testata indotti   *
      *                      * da record [dcc] principale              *
      *                      *-----------------------------------------*
           move      "C"                  to   w-det-vlt-dcc-tdt      .
           perform   det-vlt-dcc-000      thru det-vlt-dcc-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione funzionamento spese      *
      *                      *-----------------------------------------*
           move      "C"                  to   w-det-fun-spe-tdt      .
           perform   det-fun-spe-000      thru det-fun-spe-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione valori testata dipendenti*
      *                      * dall'inoltro pagamenti                  *
      *                      *-----------------------------------------*
           move      w-tes-dpz-cli (1)    to   w-det-vlt-ipg-dpz      .
           perform   det-vlt-ipg-000      thru det-vlt-ipg-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione valori testata associati *
      *                      * all'agente                              *
      *                      *-----------------------------------------*
           move      w-tes-dpz-cli (1)    to   w-det-vlt-age-dpz      .
           perform   det-vlt-age-000      thru det-vlt-age-999        .
      *                          *-------------------------------------*
      *                          * Flag di significativita' provvigio- *
      *                          * ni                                  *
      *                          *-------------------------------------*
           if        w-tes-fsp-doc (1)    =    02  and
                     w-tes-cod-age (1)    not  =   zero
                     move  01             to   w-tes-fsp-doc (1)      .
       acc-cod-cli-620.
      *                  *---------------------------------------------*
      *                  * Determinazione se presenti dipendenze per   *
      *                  * il cliente commerciale                      *
      *                  *---------------------------------------------*
           move      w-tes-cod-cli (1)    to   w-det-snd-dcc-cli      .
           perform   det-snd-dcc-000      thru det-snd-dcc-999        .
           move      w-det-snd-dcc-snx    to   w-tes-cod-cli-snd (1)  .
       acc-cod-cli-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-cli-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-cli-100.
       acc-cod-cli-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice cliente               *
      *    *                                                           *
      *    * Controlli                                                 *
      *    *-----------------------------------------------------------*
       acc-cod-cli-ctl-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flags di uscita                 *
      *              *-------------------------------------------------*
           move      spaces               to   w-ctl-cod-cli-flg      .
           move      spaces               to   w-ctl-cod-cli-ext      .
       acc-cod-cli-ctl-100.
      *              *-------------------------------------------------*
      *              * Lettura file [cli]                              *
      *              *-------------------------------------------------*
           move      w-ctl-cod-cli-cod    to   w-let-arc-cli-cod      .
           perform   let-arc-cli-000      thru let-arc-cli-999        .
           move      w-let-arc-cli-rag    to   w-tes-cod-cli-rag (1)  .
           move      w-let-arc-cli-via    to   w-tes-cod-cli-via (1)  .
           move      w-let-arc-cli-loc    to   w-tes-cod-cli-loc (1)  .
           move      w-let-arc-cli-piv    to   w-tes-cod-cli-piv (1)  .
           move      w-let-arc-cli-cfi    to   w-tes-cod-cli-cfi (1)  .
           move      w-let-arc-cli-stc    to   w-tes-cod-cli-stc (1)  .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : ad uscita per con-  *
      *                  * trollo non superato senza messaggio di er-  *
      *                  * rore                                        *
      *                  *---------------------------------------------*
           if        w-let-arc-cli-flg    not  = spaces or
                     w-ctl-cod-cli-cod    =    zero
                     go to acc-cod-cli-ctl-930.
      *                  *---------------------------------------------*
      *                  * Test su codice sottoconto associato al      *
      *                  * cliente                                     *
      *                  *---------------------------------------------*
           if        w-tes-cod-cli-stc (1)
                                          not  = zero
                     go to acc-cod-cli-ctl-200.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Manca il sottoconto contabile per il cliente !    
      -              "               "    to   w-err-box-err-msg      .
      *                      *-----------------------------------------*
      *                      * Ad uscita per controllo non superato    *
      *                      * con emissione messaggio di errore       *
      *                      *-----------------------------------------*
           go to     acc-cod-cli-ctl-920.
       acc-cod-cli-ctl-200.
      *                  *---------------------------------------------*
      *                  * Lettura record [dcc] principale             *
      *                  *---------------------------------------------*
           move      w-ctl-cod-cli-cod    to   w-let-arc-dcc-cli      .
           move      spaces               to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                  *---------------------------------------------*
      *                  * Se lettura OK : oltre                       *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-flg    =    spaces
                     go to acc-cod-cli-ctl-300.
      *                      *-----------------------------------------*
      *                      * Altrimenti : messaggio di errore        *
      *                      *-----------------------------------------*
           move      "Manca l'anagrafica commerciale per il cliente     
      -              "               "    to   w-err-box-err-msg      .
      *                      *-----------------------------------------*
      *                      * Ad uscita per controllo non superato    *
      *                      * con emissione messaggio di errore       *
      *                      *-----------------------------------------*
           go to     acc-cod-cli-ctl-920.
       acc-cod-cli-ctl-300.
      *              *-------------------------------------------------*
      *              * Trattamento assoggettamento iva                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale forzatura                         *
      *                  *---------------------------------------------*
           if        w-ctl-cau-doc-tdo    =    03  and
                     w-tes-tip-mov-dst    =    "*"
                     move  301            to   w-tes-ass-iva (1)
                     go to acc-cod-cli-ctl-400.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo assoggetta- *
      *                  * mento iva del cliente                       *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-tai    =    01
                     go to acc-cod-cli-ctl-320
           else if   w-let-arc-dcc-tai    =    02
                     go to acc-cod-cli-ctl-340
           else if   w-let-arc-dcc-tai    =    03
                     go to acc-cod-cli-ctl-360
           else if   w-let-arc-dcc-tai    =    04
                     go to acc-cod-cli-ctl-380.
       acc-cod-cli-ctl-320.
      *                  *---------------------------------------------*
      *                  * Tipo assoggettamento iva cliente : sempre   *
      *                  * soggetto ad iva                             *
      *                  *---------------------------------------------*
           move      zero                 to   w-tes-ass-iva (1)      .
           move      "Soggetto ad iva"    to   w-tes-ass-iva-des (1)  .
           go to     acc-cod-cli-ctl-400.
       acc-cod-cli-ctl-340.
      *                  *---------------------------------------------*
      *                  * Tipo assoggettamento iva cliente : sempre   *
      *                  * esente da iva                               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controllo che il codice iva in anagra-  *
      *                      * fica cliente sia un titolo di esenzione *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    >    2 and
                     w-edt-iva-cod-003    <    7
                     go to acc-cod-cli-ctl-345.
      *                          *-------------------------------------*
      *                          * Preparazione messaggio di errore    *
      *                          *-------------------------------------*
           move      "Assoggettamento iva errato in anagrafica cliente c
      -              "ontabile       "    to   w-err-box-err-msg      .
      *                          *-------------------------------------*
      *                          * Ad uscita per controllo non supera- *
      *                          * to con emissione messaggio di erro- *
      *                          * re                                  *
      *                          *-------------------------------------*
           go to     acc-cod-cli-ctl-920.
       acc-cod-cli-ctl-345.
      *                      *-----------------------------------------*
      *                      * Lettura tabella [codiva]                *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata                       *
      *                      *-----------------------------------------*
           if        w-let-arc-zci-flg    =    spaces
                     go to acc-cod-cli-ctl-350.
      *                          *-------------------------------------*
      *                          * Preparazione messaggio di errore    *
      *                          *-------------------------------------*
           move      "Assoggettamento iva non esistente in anagrafica cl
      -              "iente contabile"    to   w-err-box-err-msg      .
      *                          *-------------------------------------*
      *                          * Ad uscita per controllo non supera- *
      *                          * to con emissione messaggio di erro- *
      *                          * re                                  *
      *                          *-------------------------------------*
           go to     acc-cod-cli-ctl-920.
       acc-cod-cli-ctl-350.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione assoggettamento iva     *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-tes-ass-iva (1)      .
           move      w-let-arc-zci-des    to   w-tes-ass-iva-des (1)  .
           go to     acc-cod-cli-ctl-400.
       acc-cod-cli-ctl-360.
      *                  *---------------------------------------------*
      *                  * Tipo assoggettamento iva cliente : Cliente  *
      *                  * con plafond                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione relativa alla *
      *                      * gestione lettera d'intenti              *
      *                      *-----------------------------------------*
           if        w-prs-snx-lic        not  = "S"
                     go to acc-cod-cli-ctl-365.
      *                      *-----------------------------------------*
      *                      * Lettura record [lic]                    *
      *                      *-----------------------------------------*
           move      w-ctl-cod-cli-cod    to   w-let-arc-lic-cod      .
           perform   let-arc-lic-000      thru let-arc-lic-999        .
      *                      *-----------------------------------------*
      *                      * Se data documento non compresa tra data *
      *                      * riferimento iniziale e finale : si pro- *
      *                      * cede come per cliente sempre soggetto   *
      *                      *-----------------------------------------*
           if        w-tes-dat-doc        not  < w-let-arc-lic-dri and
                     w-tes-dat-doc        not  > w-let-arc-lic-drf
                     go to acc-cod-cli-ctl-365.
      *                          *-------------------------------------*
      *                          * Messaggio                           *
      *                          *-------------------------------------*
           move      "Il documento non ricade entro gli estremi della le
      -              "ttera d'intenti"    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                          *-------------------------------------*
      *                          * Si procede come per cliente sempre  *
      *                          * soggetto                            *
      *                          *-------------------------------------*
           go to     acc-cod-cli-ctl-320.
       acc-cod-cli-ctl-365.
      *                      *-----------------------------------------*
      *                      * Controllo che il codice iva in anagra-  *
      *                      * fica cliente sia un titolo di esenzione *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    >    2 and
                     w-edt-iva-cod-003    <    7
                     go to acc-cod-cli-ctl-370.
      *                          *-------------------------------------*
      *                          * Preparazione messaggio di errore    *
      *                          *-------------------------------------*
           move      "Assoggettamento iva errato in anagrafica cliente c
      -              "ontabile       "    to   w-err-box-err-msg      .
      *                          *-------------------------------------*
      *                          * Ad uscita per controllo non supera- *
      *                          * to con emissione messaggio di erro- *
      *                          * re                                  *
      *                          *-------------------------------------*
           go to     acc-cod-cli-ctl-920.
       acc-cod-cli-ctl-370.
      *                      *-----------------------------------------*
      *                      * Lettura tabella [codiva]                *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata                       *
      *                      *-----------------------------------------*
           if        w-let-arc-zci-flg    =    spaces
                     go to acc-cod-cli-ctl-375.
      *                          *-------------------------------------*
      *                          * Preparazione messaggio di errore    *
      *                          *-------------------------------------*
           move      "Assoggettamento iva non esistente in anagrafica cl
      -              "iente contabile"    to   w-err-box-err-msg      .
      *                          *-------------------------------------*
      *                          * Ad uscita per controllo non supera- *
      *                          * to con emissione messaggio di erro- *
      *                          * re                                  *
      *                          *-------------------------------------*
           go to     acc-cod-cli-ctl-920.
       acc-cod-cli-ctl-375.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione assoggettamento iva     *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-tes-ass-iva (1)      .
           move      w-let-arc-zci-des    to   w-tes-ass-iva-des (1)  .
           go to     acc-cod-cli-ctl-400.
       acc-cod-cli-ctl-380.
      *                  *---------------------------------------------*
      *                  * Tipo assoggettamento iva cliente : Cliente  *
      *                  * in regime di Scissione Pagamenti            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Assoggettamento Iva                     *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-ass-iva (1)      .
      *                      *-----------------------------------------*
      *                      * Segnale di Scissione Pagamenti          *
      *                      *-----------------------------------------*
           move      "S"                  to   w-tes-ass-iva-spl (1)  .
      *                      *-----------------------------------------*
      *                      * Dicitura per aliquota Iva               *
      *                      *-----------------------------------------*
           move      "Scissione Pagamenti"
                                          to   w-tes-ass-iva-des (1)  .
      *                      *-----------------------------------------*
      *                      * Nessun controllo in questa fase         *
      *                      *-----------------------------------------*
           go to     acc-cod-cli-ctl-400.
       acc-cod-cli-ctl-400.
      *                  *---------------------------------------------*
      *                  * Test su segnale di consegne bloccate        *
      *                  *---------------------------------------------*
       acc-cod-cli-ctl-500.
      *                  *---------------------------------------------*
      *                  * Test su tipo documento preferenziale        *
      *                  *---------------------------------------------*
       acc-cod-cli-ctl-600.
      *                  *---------------------------------------------*
      *                  * Test su status commerciale del cliente      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se la personalizzazione lo prevede *
      *                      *-----------------------------------------*
           if        w-prs-ttd-sts-dcc    =    "N"
                     go to acc-cod-cli-ctl-800.
      *                      *-----------------------------------------*
      *                      * Se status normale : ad uscita           *
      *                      *-----------------------------------------*
           if        w-let-arc-dcc-tus    =    01 or
                     w-let-arc-dcc-tus    =    09
                     go to acc-cod-cli-ctl-800.
      *                      *-----------------------------------------*
      *                      * Se status non normale : box specifico   *
      *                      * per lo status commerciale               *
      *                      *-----------------------------------------*
           perform   acc-cod-cli-bsc-000  thru acc-cod-cli-bsc-999    .
      *                      *-----------------------------------------*
      *                      * Tipo di uscita a seconda della persona- *
      *                      * lizzazione                              *
      *                      *-----------------------------------------*
           if        w-prs-ttd-sts-dcc    =    "B"
                     go to acc-cod-cli-ctl-930
           else      go to acc-cod-cli-ctl-800.
       acc-cod-cli-ctl-800.
      *              *-------------------------------------------------*
      *              * Uscita per controlli superati                   *
      *              *-------------------------------------------------*
           go to     acc-cod-cli-ctl-999.
       acc-cod-cli-ctl-900.
      *              *-------------------------------------------------*
      *              * Uscita per controlli non superati o per emis-   *
      *              * sione messaggio di errore                       *
      *              *-------------------------------------------------*
       acc-cod-cli-ctl-910.
      *                  *---------------------------------------------*
      *                  * Uscita con solo messaggio di errore         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Box di errore                           *
      *                      *-----------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     acc-cod-cli-ctl-999.
       acc-cod-cli-ctl-920.
      *                  *---------------------------------------------*
      *                  * Uscita con messaggio di errore e flag di    *
      *                  * errore                                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Box di errore                           *
      *                      *-----------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
       acc-cod-cli-ctl-930.
      *                  *---------------------------------------------*
      *                  * Uscita con flag di errore                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di uscita                          *
      *                      *-----------------------------------------*
           move      "#"                  to   w-ctl-cod-cli-flg      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     acc-cod-cli-ctl-999.
       acc-cod-cli-ctl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice archivio              *
      *    *                                                           *
      *    * Routine di avviso per cambio codice archivio              *
      *    *-----------------------------------------------------------*
       acc-cod-cli-mod-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
       acc-cod-cli-mod-100.
      *              *-------------------------------------------------*
      *              * Box di avviso con conferma                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      07                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      74                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Messaggi nel box                            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "                       A T T E N Z I O N E        
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "La modifica del codice cliente non comporta alcuna
      -              " variazione   "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "nelle condizioni gia' presenti nel documento !    
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "Si desidera :"      to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Preparazione default per risposta           *
      *                  *---------------------------------------------*
           move      spaces               to   v-alf                  .
           move      zero                 to   w-exp-arc-mod-sce      .
       acc-cod-cli-mod-120.
      *                  *---------------------------------------------*
      *                  * Accettazione risposta                       *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-arc-mod-lun    to   v-car                  .
           move      w-exp-arc-mod-num    to   v-ldt                  .
           move      "AP#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      15                   to   v-lin                  .
           move      23                   to   v-pos                  .
           move      w-exp-arc-mod-tbl    to   v-txt                  .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-exp-arc-mod-sce    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Controllo risposta operatore                *
      *                  *---------------------------------------------*
           if        v-key                =    "EXIT"
                     move  01             to   v-num
                     go to acc-cod-cli-mod-800.
           if        v-num                not  = 01 and
                     v-num                not  = 02
                     go to acc-cod-cli-mod-120.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione risposta operatore          *
      *                  *---------------------------------------------*
           move      v-num                to   w-exp-arc-mod-sce      .
       acc-cod-cli-mod-800.
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-cli-mod-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-cod-cli-mod-999.
       acc-cod-cli-mod-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice cliente               *
      *    *                                                           *
      *    * Box di errore emesso in funzione dello status commerciale *
      *    * del cliente, se diverso da 'normale'                      *
      *    *-----------------------------------------------------------*
       acc-cod-cli-bsc-000.
      *              *-------------------------------------------------*
      *              * Messaggio di errore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio del video attuale               *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      20                   to   v-lto                  .
           move      08                   to   v-pos                  .
           move      73                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-cli-bsc-200.
      *                  *---------------------------------------------*
      *                  * Messaggi entro il box                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Titolo centrale                         *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "                     A T T E N Z I O N E          
      -              "            "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 1                        *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "Per il cliente impostato si rileva la seguente con
      -              "dizione :   "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Preparazione riga messaggio 2           *
      *                      *-----------------------------------------*
           if        w-let-arc-dcc-tus    =    11
                     move  "[Esauriti i rapporti commerciali]           
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    21
                     move  "[Sostituito da ns. nuovo cliente]           
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    51
                     move  "[Cessata attivita']                         
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    52
                     move  "[Cessata attivita', ma sostituito da ns. nuo
      -                    "vo cliente]       "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    61
                     move  "[In contenzioso]                            
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    62
                     move  "[In contenzioso, ma sostituito da ns. nuovo 
      -                    "cliente]          "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    71
                     move  "[Fallito]                                   
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    72
                     move  "[Fallito, ma sostituito da ns. nuovo cliente
      -                    "]                 "
                                          to   v-alf
           else      move  "(status non determinato)                    
      -                    "                  "
                                          to   v-alf                  .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 2                        *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      10                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 3                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da emettere                 *
      *                          *-------------------------------------*
           if        w-let-arc-dcc-tud    =    zero
                     go to acc-cod-cli-bsc-300.
      *                          *-------------------------------------*
      *                          * Emissione                           *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "La determinazione di tale condizione risale al :  
      -              "            "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Data di rilevamento status          *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      15                   to   v-lin                  .
           move      59                   to   v-pos                  .
           move      w-let-arc-dcc-tud    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-cli-bsc-300.
      *                      *-----------------------------------------*
      *                      * Righe messaggio 4 e 5                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da emettere                 *
      *                          *-------------------------------------*
           if        w-let-arc-dcc-tuc    =    zero
                     go to acc-cod-cli-bsc-600.
      *                          *-------------------------------------*
      *                          * Emissione                           *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "Il cliente utilizzabile in alternativa e' il segue
      -              "nte :       "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Codice cliente alternativo          *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      19                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      w-let-arc-dcc-tuc    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Lettura descrizione per il cliente  *
      *                          * alternativo                         *
      *                          *-------------------------------------*
           move      w-let-arc-dcc-tuc    to   w-let-arc-cli-cod      .
           perform   let-arc-cli-000      thru let-arc-cli-999        .
           if        w-let-arc-cli-flg    not  = spaces
                     move  all "."        to   v-alf
           else      move  w-let-arc-cli-rag
                                          to   v-alf                  .
      *                          *-------------------------------------*
      *                          * Emissione                           *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      20                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-cli-bsc-600.
      *                      *-----------------------------------------*
      *                      * Prompt per presa visione                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      69                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-cli-bsc-800.
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      19                   to   v-lin                  .
           move      70                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cod-cli-bsc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice cliente            *
      *    *-----------------------------------------------------------*
       vis-cod-cli-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      08                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<B"                 to   v-edm                  .
           move      w-tes-cod-cli (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-cli-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione cliente       *
      *    *-----------------------------------------------------------*
       vis-cod-cli-des-000.
      *              *-------------------------------------------------*
      *              * Ragione sociale                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-cli-rag (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Indirizzo                                       *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-cli-via (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Localita'                                       *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cod-cli-loc (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Partita IVA e Codice Fiscale                    *
      *              *-------------------------------------------------*
           perform   vis-cod-cli-pcf-000  thru vis-cod-cli-pcf-999    .
       vis-cod-cli-des-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Partita IVA e Codice Fiscale      *
      *    *-----------------------------------------------------------*
       vis-cod-cli-pcf-000.
      *              *-------------------------------------------------*
      *              * Preparazione valori                             *
      *              *-------------------------------------------------*
           move      "Pi:"                to   w-all-str-cat (1)      .
           move      "Cf:"                to   w-all-str-cat (3)      .
           move      w-tes-cod-cli-cfi (1)
                                          to   w-all-str-cat (4)      .
      *              *-------------------------------------------------*
      *              * Editing Partita Iva                             *
      *              *-------------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9B"                 to   v-edm                  .
           move      w-tes-cod-cli-piv (1)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-all-str-cat (2)      .
       vis-cod-cli-pcf-300.
      *              *-------------------------------------------------*
      *              * Eventuali correttivi                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Partita Iva e Codice Fiscale vuoti          *
      *                  *---------------------------------------------*
           if        w-tes-cod-cli-cfi (1)
                                          =    spaces and
                     w-tes-cod-cli-piv (1)
                                          =    zero
                     move  spaces         to   w-all-str-alf
                     go to vis-cod-cli-pcf-800.
      *                  *---------------------------------------------*
      *                  * Partita Iva e Codice Fiscale uguali         *
      *                  *---------------------------------------------*
           if        w-all-str-cat (2)    =    w-all-str-cat (4)
                     move  "Pi "          to   w-all-str-cat (1)
                     move  "e"            to   w-all-str-cat (2)
                     go to vis-cod-cli-pcf-600.
      *                  *---------------------------------------------*
      *                  * Partita Iva mancante                        *
      *                  *---------------------------------------------*
           if        w-tes-cod-cli-piv (1)
                                          =    zero
                     move  "..."          to   w-all-str-cat (2)      .
      *                  *---------------------------------------------*
      *                  * Codice Fiscale mancante                     *
      *                  *---------------------------------------------*
           if        w-tes-cod-cli-cfi (1)
                                          =    spaces
                     move  "..."          to   w-all-str-cat (4)      .
       vis-cod-cli-pcf-600.
      *              *-------------------------------------------------*
      *              * Assemblaggio                                    *
      *              *-------------------------------------------------*
           move      40                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *
           perform   all-str-adx-000      thru all-str-adx-999        .
       vis-cod-cli-pcf-800.
      *              *-------------------------------------------------*
      *              * Visualizzazione stringa preparata               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-all-str-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-cli-pcf-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     vis-cod-cli-pcf-999.
       vis-cod-cli-pcf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice dipendenza            *
      *    *-----------------------------------------------------------*
       acc-dpz-cli-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test  se campo da accettare                 *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-dpz-cli-999.
           if        w-tes-cod-cli-snd (1)
                                          =    "N"
                     go to acc-dpz-cli-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-dpz-cli (1)    to   w-sav-dpz-cli          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-dpz-cli-400.
       acc-dpz-cli-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-dcc-ope      .
           move      w-tes-cod-cli (1)    to   w-cod-cod-dcc-cli      .
           move      w-tes-dpz-cli (1)    to   w-cod-cod-dcc-cod      .
           move      14                   to   w-cod-cod-dcc-lin      .
           move      30                   to   w-cod-cod-dcc-pos      .
           move      14                   to   w-cod-cod-dcc-rln      .
           move      41                   to   w-cod-cod-dcc-rps      .
           move      15                   to   w-cod-cod-dcc-vln      .
           move      41                   to   w-cod-cod-dcc-vps      .
           move      16                   to   w-cod-cod-dcc-lln      .
           move      41                   to   w-cod-cod-dcc-lps      .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-dcc-cll-000  thru cod-cod-dcc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-dcc-foi-000  thru cod-cod-dcc-foi-999    .
       acc-dpz-cli-110.
           perform   cod-cod-dcc-cll-000  thru cod-cod-dcc-cll-999    .
           if        w-cod-cod-dcc-ope    =    "F+"
                     go to acc-dpz-cli-115.
           if        w-cod-cod-dcc-ope    =    "AC"
                     go to acc-dpz-cli-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-dpz-cli-115.
           perform   cod-cod-dcc-foi-000  thru cod-cod-dcc-foi-999    .
           go to     acc-dpz-cli-110.
       acc-dpz-cli-120.
           move      w-cod-cod-dcc-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-dpz-cli-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-dpz-cli-999.
       acc-dpz-cli-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-dpz-cli (1)      .
       acc-dpz-cli-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura file [dcc]                          *
      *                  *---------------------------------------------*
           move      w-tes-cod-cli (1)    to   w-let-arc-dcc-cli      .
           move      w-tes-dpz-cli (1)    to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           move      w-let-arc-dcc-rag    to   w-tes-dpz-cli-rag (1)  .
           move      w-let-arc-dcc-via    to   w-tes-dpz-cli-via (1)  .
           move      w-let-arc-dcc-loc    to   w-tes-dpz-cli-loc (1)  .
           perform   vis-des-dpz-000      thru vis-des-dpz-999        .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-flg    not  = spaces
                     go to acc-dpz-cli-100.
       acc-dpz-cli-580.
      *                  *---------------------------------------------*
      *                  * Subroutine per note su dipendenza cliente   *
      *                  *---------------------------------------------*
           perform   cod-cod-dcc-not-000  thru cod-cod-dcc-not-999    .
       acc-dpz-cli-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale messaggio di avviso per inoltro   *
      *                  * documenti o inoltro pagamenti incongruenti  *
      *                  * con il codice dipendenza                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se codice dipendenza : oltre            *
      *                      *-----------------------------------------*
           if        w-tes-dpz-cli (1)    not  = spaces
                     go to acc-dpz-cli-620.
      *                      *-----------------------------------------*
      *                      * Se inoltro documenti e/o pagamenti non  *
      *                      * alla dipendenza : oltre                 *
      *                      *-----------------------------------------*
           if        w-tes-inl-dcm (1)    not  = 03 or
                     w-tes-inl-pgt (1)    not  = 03
                     go to acc-dpz-cli-620.
      *                      *-----------------------------------------*
      *                      * Se Tab in corso : a reimpostazione      *
      *                      *-----------------------------------------*
           if        w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-dpz-cli-100.
      *                      *-----------------------------------------*
      *                      * Box di avviso                           *
      *                      *-----------------------------------------*
           move      "Attenzione : c'e' una incongruenza con gli indicat
      -              "ori di         "    to   w-err-box-err-msg      .
           move      "Inoltro Documenti o Inoltro Pagamenti !           
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       acc-dpz-cli-620.
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-tes-dpz-cli (1)    =    w-sav-dpz-cli
                     go to acc-dpz-cli-800.
      *                      *-----------------------------------------*
      *                      * Eventuale normalizzazione valore per i- *
      *                      * noltro documenti                        *
      *                      *-----------------------------------------*
           if        w-tes-dpz-cli (1)    =    spaces and
                     w-tes-inl-dcm (1)    =    03
                     move  02             to   w-tes-inl-dcm (1)      .
      *                      *-----------------------------------------*
      *                      * Eventuale normalizzazione valore per i- *
      *                      * noltro pagamenti                        *
      *                      *-----------------------------------------*
           if        w-tes-dpz-cli (1)    =    spaces and
                     w-tes-inl-pgt (1)    =    03
                     move  02             to   w-tes-inl-pgt (1)      .
      *                      *-----------------------------------------*
      *                      * Valori testata indotti da record [dcc]  *
      *                      * relativo alla dipendenza                *
      *                      *-----------------------------------------*
           move      "C"                  to   w-det-vlt-dcd-tdt      .
           move      w-tes-dpz-cli (1)    to   w-det-vlt-dcd-dpz      .
           perform   det-vlt-dcd-000      thru det-vlt-dcd-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione valori testata dipendenti*
      *                      * dall'inoltro pagamenti                  *
      *                      *-----------------------------------------*
           move      w-tes-dpz-cli (1)    to   w-det-vlt-ipg-dpz      .
           perform   det-vlt-ipg-000      thru det-vlt-ipg-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione valori testata associati *
      *                      * all'agente                              *
      *                      *-----------------------------------------*
           move      w-tes-dpz-cli (1)    to   w-det-vlt-age-dpz      .
           perform   det-vlt-age-000      thru det-vlt-age-999        .
       acc-dpz-cli-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-dpz-cli-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-dpz-cli-100.
       acc-dpz-cli-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Dipendenza del cliente    *
      *    *-----------------------------------------------------------*
       vis-dpz-cli-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-dpz-cli (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dpz-cli-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione dipendenza    *
      *    *-----------------------------------------------------------*
       vis-des-dpz-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-dpz-cli-rag (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-dpz-cli-via (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-dpz-cli-loc (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-dpz-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Tipo fattura elettronica             *
      *    *-----------------------------------------------------------*
       acc-tdo-fel-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione eventuale default              *
      *                  *---------------------------------------------*
           if        w-tes-tdo-fel (1)    not  = spaces
                     go to acc-tdo-fel-100.
           move      w-tes-tip-mov-sdi    to   w-tes-tdo-fel (1)      .
       acc-tdo-fel-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-tdo-fel (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-tdo-fel-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-tdo-fel-999.
       acc-tdo-fel-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-tdo-fel (1)      .
       acc-tdo-fel-300.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-tdo-fel-400.
      *                  *---------------------------------------------*
      *                  * Find su tipi fattura elettronica            *
      *                  *---------------------------------------------*
           perform   fnd-tdo-fel-000      thru fnd-tdo-fel-999        .
           if        w-fnd-tdo-fel-sel    not  = spaces
                     go to acc-tdo-fel-100.
           move      w-fnd-tdo-fel-tdo    to   w-tes-tdo-fel (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione tipo fattura elettronica    *
      *                  *---------------------------------------------*
           perform   vis-tdo-fel-000      thru vis-tdo-fel-999        .
           move      spaces               to   v-key                  .
       acc-tdo-fel-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Controlli su tipo documento impostato       *
      *                  *---------------------------------------------*
           move      w-tes-tdo-fel (1)    to   w-ctl-tdo-fel-tdo      .
           perform   ctl-tdo-fel-000      thru ctl-tdo-fel-999        .
           if        w-ctl-tdo-fel-flg    = spaces
                     go to acc-tdo-fel-600.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "Tipo documento per 'sdi' non accettabile !       "
                                          to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-tdo-fel-100.
       acc-tdo-fel-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Tipo documento 'sdi'                        *
      *                  *---------------------------------------------*
           perform   vis-tdo-fel-000      thru vis-tdo-fel-999        .
       acc-tdo-fel-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-tdo-fel-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-tdo-fel-100.
       acc-tdo-fel-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Tipo fattura elettronica          *
      *    *-----------------------------------------------------------*
       vis-tdo-fel-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tdo-fel-lun    to   v-car                  .
           move      w-exp-tdo-fel-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      18                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-tdo-fel-tbl    to   v-txt                  .
      *
           if        w-tes-tdo-fel (1)    =    "TD01"
                     move  1              to   v-num
           else if   w-tes-tdo-fel (1)    =    "TD02"
                     move  2              to   v-num
           else if   w-tes-tdo-fel (1)    =    "TD03"
                     move  3              to   v-num
           else if   w-tes-tdo-fel (1)    =    "TD04"
                     move  4              to   v-num
           else if   w-tes-tdo-fel (1)    =    "TD05"
                     move  5              to   v-num
           else if   w-tes-tdo-fel (1)    =    "TD06"
                     move  6              to   v-num
           else if   w-tes-tdo-fel (1)    =    "TD16"
                     move  7              to   v-num
           else if   w-tes-tdo-fel (1)    =    "TD17"
                     move  8              to   v-num
           else if   w-tes-tdo-fel (1)    =    "TD18"
                     move  9              to   v-num
           else if   w-tes-tdo-fel (1)    =    "TD19"
                     move  10             to   v-num
           else if   w-tes-tdo-fel (1)    =    "TD20"
                     move  11             to   v-num
           else if   w-tes-tdo-fel (1)    =    "TD21"
                     move  12             to   v-num
           else if   w-tes-tdo-fel (1)    =    "TD22"
                     move  13             to   v-num
           else if   w-tes-tdo-fel (1)    =    "TD23"
                     move  14             to   v-num
           else if   w-tes-tdo-fel (1)    =    "TD24"
                     move  15             to   v-num
           else if   w-tes-tdo-fel (1)    =    "TD25"
                     move  16             to   v-num
           else if   w-tes-tdo-fel (1)    =    "TD26"
                     move  17             to   v-num
           else if   w-tes-tdo-fel (1)    =    "TD27"
                     move  18             to   v-num
           else      move  zero           to   v-num                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tdo-fel-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Tipo fornitura               *
      *    *-----------------------------------------------------------*
       acc-tip-frn-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se pagina testata gia' impostata   *
      *                      *-----------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-tip-frn-999.
           if        w-tes-fda-pt1 (1)    not  = spaces
                     go to acc-tip-frn-999.
      *                      *-----------------------------------------*
      *                      * Test se personalizzazione lo prevede    *
      *                      *-----------------------------------------*
           if        w-prs-ges-apf        not  = 11 and
                     w-prs-ges-apf        not  = 21 and
                     w-prs-ges-apf        not  = 99
                     go to acc-tip-frn-999.
      *                  *---------------------------------------------*
      *                  * Preparazione eventuale default              *
      *                  *---------------------------------------------*
           if        w-tes-tip-frn (1)    =    zero
                     move  01             to   w-tes-tip-frn (1)      .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-tip-frn-400.
       acc-tip-frn-050.
      *                  *---------------------------------------------*
      *                  * Preparazione Pop-Up di accettazione in fun- *
      *                  * zione della personalizzazione               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del valore della *
      *                      * personalizzazione                       *
      *                      *-----------------------------------------*
           if        w-prs-ges-apf        =    11
                     go to acc-tip-frn-052
           else if   w-prs-ges-apf        =    21
                     go to acc-tip-frn-054
           else if   w-prs-ges-apf        =    99
                     go to acc-tip-frn-056.
       acc-tip-frn-052.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per : Leasing          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Aggiustamento numero elementi del   *
      *                          * Pop-Up                              *
      *                          *-------------------------------------*
           move      02                   to   w-exp-tip-frn-num      .
      *                          *-------------------------------------*
      *                          * Ad accettazione                     *
      *                          *-------------------------------------*
           go to     acc-tip-frn-100.
       acc-tip-frn-054.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per: Gruppo d'Acquisto *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Aggiustamento numero elementi del   *
      *                          * Pop-Up                              *
      *                          *-------------------------------------*
           move      02                   to   w-exp-tip-frn-num      .
      *                          *-------------------------------------*
      *                          * Shift del terzo elemento sul secon- *
      *                          * do                                  *
      *                          *-------------------------------------*
           move      w-exp-tip-frn-ele (03)
                                          to   w-exp-tip-frn-ele (02) .
      *                          *-------------------------------------*
      *                          * Ad accettazione                     *
      *                          *-------------------------------------*
           go to     acc-tip-frn-100.
       acc-tip-frn-056.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per : Completa         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Ad accettazione                     *
      *                          *-------------------------------------*
           go to     acc-tip-frn-100.
       acc-tip-frn-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Parametri di accettazione                   *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-frn-lun    to   v-car                  .
           move      w-exp-tip-frn-num    to   v-ldt                  .
           move      "DLG#"               to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      19                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-tip-frn-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
       acc-tip-frn-150.
      *                  *---------------------------------------------*
      *                  * Valore di accettazione                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del valore della *
      *                      * personalizzazione                       *
      *                      *-----------------------------------------*
           if        w-prs-ges-apf        =    11
                     go to acc-tip-frn-152
           else if   w-prs-ges-apf        =    21
                     go to acc-tip-frn-154
           else if   w-prs-ges-apf        =    99
                     go to acc-tip-frn-156.
       acc-tip-frn-152.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per : Leasing          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Preparazione v-num                  *
      *                          *-------------------------------------*
           if        w-tes-tip-frn (1)    =    01
                     move  01             to   v-num
           else if   w-tes-tip-frn (1)    =    11
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
      *                          *-------------------------------------*
      *                          * A richiamo accettazione             *
      *                          *-------------------------------------*
           go to     acc-tip-frn-160.
       acc-tip-frn-154.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per: Gruppo d'Acquisto *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Preparazione v-num                  *
      *                          *-------------------------------------*
           if        w-tes-tip-frn (1)    =    01
                     move  01             to   v-num
           else if   w-tes-tip-frn (1)    =    21
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
      *                          *-------------------------------------*
      *                          * A richiamo accettazione             *
      *                          *-------------------------------------*
           go to     acc-tip-frn-160.
       acc-tip-frn-156.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per : Completa         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Preparazione v-num                  *
      *                          *-------------------------------------*
           if        w-tes-tip-frn (1)    =    01
                     move  01             to   v-num
           else if   w-tes-tip-frn (1)    =    11
                     move  02             to   v-num
           else if   w-tes-tip-frn (1)    =    21
                     move  03             to   v-num
           else      move  zero           to   v-num                  .
      *                          *-------------------------------------*
      *                          * A richiamo accettazione             *
      *                          *-------------------------------------*
           go to     acc-tip-frn-160.
       acc-tip-frn-160.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-tip-frn-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-tip-frn-999.
       acc-tip-frn-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del valore della     *
      *                  * personalizzazione                           *
      *                  *---------------------------------------------*
           if        w-prs-ges-apf        =    11
                     go to acc-tip-frn-202
           else if   w-prs-ges-apf        =    21
                     go to acc-tip-frn-204
           else if   w-prs-ges-apf        =    99
                     go to acc-tip-frn-206.
       acc-tip-frn-202.
      *                  *---------------------------------------------*
      *                  * Se gestione solo per : Leasing              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Spostamento da v-num                    *
      *                      *-----------------------------------------*
           if        v-num                =    01
                     move  01             to   w-tes-tip-frn (1)
           else if   v-num                =    02
                     move  11             to   w-tes-tip-frn (1)
           else      move  zero           to   w-tes-tip-frn (1)      .
      *                      *-----------------------------------------*
      *                      * A controllo valore impostato            *
      *                      *-----------------------------------------*
           go to     acc-tip-frn-400.
       acc-tip-frn-204.
      *                  *---------------------------------------------*
      *                  * Se gestione solo per : Gruppo d'Acquisto    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Spostamento da v-num                    *
      *                      *-----------------------------------------*
           if        v-num                =    01
                     move  01             to   w-tes-tip-frn (1)
           else if   v-num                =    02
                     move  21             to   w-tes-tip-frn (1)
           else      move  zero           to   w-tes-tip-frn (1)      .
      *                      *-----------------------------------------*
      *                      * A controllo valore impostato            *
      *                      *-----------------------------------------*
           go to     acc-tip-frn-400.
       acc-tip-frn-206.
      *                  *---------------------------------------------*
      *                  * Se gestione solo per : Completa             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Spostamento da v-num                    *
      *                      *-----------------------------------------*
           if        v-num                =    01
                     move  01             to   w-tes-tip-frn (1)
           else if   v-num                =    02
                     move  11             to   w-tes-tip-frn (1)
           else if   v-num                =    03
                     move  21             to   w-tes-tip-frn (1)
           else      move  zero           to   w-tes-tip-frn (1)      .
      *                      *-----------------------------------------*
      *                      * A controllo valore impostato            *
      *                      *-----------------------------------------*
           go to     acc-tip-frn-400.
       acc-tip-frn-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se zero : reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-tes-tip-frn (1)    not  = zero
                     go to acc-tip-frn-600.
           if        v-key                =    "UP  "
                     go to acc-tip-frn-600
           else      go to acc-tip-frn-100.
       acc-tip-frn-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-tip-frn-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-tip-frn-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-tip-frn-100.
       acc-tip-frn-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Tipo fornitura            *
      *    *-----------------------------------------------------------*
       vis-tip-frn-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da visualizzare               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se personalizzazione lo prevede    *
      *                      *-----------------------------------------*
           if        w-prs-ges-apf        not  = 11 and
                     w-prs-ges-apf        not  = 21 and
                     w-prs-ges-apf        not  = 99
                     go to vis-tip-frn-999.
       vis-tip-frn-050.
      *                  *---------------------------------------------*
      *                  * Preparazione Pop-Up di accettazione in fun- *
      *                  * zione della personalizzazione               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del valore della *
      *                      * personalizzazione                       *
      *                      *-----------------------------------------*
           if        w-prs-ges-apf        =    11
                     go to vis-tip-frn-052
           else if   w-prs-ges-apf        =    21
                     go to vis-tip-frn-054
           else if   w-prs-ges-apf        =    99
                     go to vis-tip-frn-056.
       vis-tip-frn-052.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per : Leasing          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Aggiustamento numero elementi del   *
      *                          * Pop-Up                              *
      *                          *-------------------------------------*
           move      02                   to   w-exp-tip-frn-num      .
      *                          *-------------------------------------*
      *                          * A visualizzazione                   *
      *                          *-------------------------------------*
           go to     vis-tip-frn-100.
       vis-tip-frn-054.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per: Gruppo d'Acquisto *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Aggiustamento numero elementi del   *
      *                          * Pop-Up                              *
      *                          *-------------------------------------*
           move      02                   to   w-exp-tip-frn-num      .
      *                          *-------------------------------------*
      *                          * Shift del terzo elemento sul secon- *
      *                          * do                                  *
      *                          *-------------------------------------*
           move      w-exp-tip-frn-ele (03)
                                          to   w-exp-tip-frn-ele (02) .
      *                          *-------------------------------------*
      *                          * A visualizzazione                   *
      *                          *-------------------------------------*
           go to     vis-tip-frn-100.
       vis-tip-frn-056.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per : Completa         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * A visualizzazione                   *
      *                          *-------------------------------------*
           go to     vis-tip-frn-100.
       vis-tip-frn-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Parametri di visualizzazione                *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tip-frn-lun    to   v-car                  .
           move      w-exp-tip-frn-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      19                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-tip-frn-tbl    to   v-txt                  .
       vis-tip-frn-150.
      *                  *---------------------------------------------*
      *                  * Valore di visualizzazione                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del valore della *
      *                      * personalizzazione                       *
      *                      *-----------------------------------------*
           if        w-prs-ges-apf        =    11
                     go to vis-tip-frn-152
           else if   w-prs-ges-apf        =    21
                     go to vis-tip-frn-154
           else if   w-prs-ges-apf        =    99
                     go to vis-tip-frn-156.
       vis-tip-frn-152.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per : Leasing          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Preparazione v-num                  *
      *                          *-------------------------------------*
           if        w-tes-tip-frn (1)    =    01
                     move  01             to   v-num
           else if   w-tes-tip-frn (1)    =    11
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
      *                          *-------------------------------------*
      *                          * A richiamo visualizzazione          *
      *                          *-------------------------------------*
           go to     vis-tip-frn-160.
       vis-tip-frn-154.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per: Gruppo d'Acquisto *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Preparazione v-num                  *
      *                          *-------------------------------------*
           if        w-tes-tip-frn (1)    =    01
                     move  01             to   v-num
           else if   w-tes-tip-frn (1)    =    21
                     move  02             to   v-num
           else      move  zero           to   v-num                  .
      *                          *-------------------------------------*
      *                          * A richiamo visualizzazione          *
      *                          *-------------------------------------*
           go to     vis-tip-frn-160.
       vis-tip-frn-156.
      *                      *-----------------------------------------*
      *                      * Se gestione solo per : Completa         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Preparazione v-num                  *
      *                          *-------------------------------------*
           if        w-tes-tip-frn (1)    =    01
                     move  01             to   v-num
           else if   w-tes-tip-frn (1)    =    11
                     move  02             to   v-num
           else if   w-tes-tip-frn (1)    =    21
                     move  03             to   v-num
           else      move  zero           to   v-num                  .
      *                          *-------------------------------------*
      *                          * A richiamo visualizzazione          *
      *                          *-------------------------------------*
           go to     vis-tip-frn-160.
       vis-tip-frn-160.
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tip-frn-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Si/no fattura da verificare          *
      *    *-----------------------------------------------------------*
       acc-snx-fav-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se personalizzazione lo prevede    *
      *                      *-----------------------------------------*
           if        w-prs-snx-fav        not  = "S"
                     go to acc-snx-fav-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-snx-fav-400.
       acc-snx-fav-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-snx-fav-lun    to   v-car                  .
           move      w-exp-snx-fav-num    to   v-ldt                  .
           move      "DE#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      21                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-snx-fav-tbl    to   v-txt                  .
      *
           if        w-tes-flg-nbx (1, 2) =    "#"
                     move  1              to   v-num
           else if   w-tes-flg-nbx (1, 2) =    spaces
                     move  2              to   v-num
           else      move  zero           to   v-num                  .
      *
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-snx-fav-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-snx-fav-999.
       acc-snx-fav-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    1
                     move  "#"            to   w-tes-flg-nbx (1, 2)
           else if   v-num                =    2
                     move  spaces         to   w-tes-flg-nbx (1, 2)
           else      move  spaces         to   w-tes-flg-nbx (1, 2)   .
       acc-snx-fav-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-snx-fav-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-snx-fav-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-snx-fav-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-snx-fav-100.
       acc-snx-fav-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Si/no fattura da verificare       *
      *    *-----------------------------------------------------------*
       vis-snx-fav-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da visualizzare               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se personalizzazione lo prevede    *
      *                      *-----------------------------------------*
           if        w-prs-snx-fav        not  = "S"
                     go to vis-snx-fav-999.
       vis-snx-fav-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione valore                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-snx-fav-lun    to   v-car                  .
           move      w-exp-snx-fav-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      21                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-snx-fav-tbl    to   v-txt                  .
      *
           if        w-tes-flg-nbx (1, 2) =    "#"
                     move  1              to   v-num
           else if   w-tes-flg-nbx (1, 2) =    spaces
                     move  2              to   v-num
           else      move  zero           to   v-num                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-snx-fav-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Distinta invio XML                *
      *    *-----------------------------------------------------------*
       vis-dst-xml-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da visualizzare               *
      *                  *---------------------------------------------*
           if        w-det-dst-num-prt    =    zero
                     go to vis-dst-xml-999.
           if        w-cnt-mfu-tip-fun    not  = "V"
                     go to vis-dst-xml-999.
       vis-dst-xml-100.
      *              *-------------------------------------------------*
      *              * Editing distinta                                *
      *              *-------------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "P"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-det-dst-num-dst    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Assemblaggio                                    *
      *              *-------------------------------------------------*
           move      80                   to   w-all-str-lun          .
           move      07                   to   w-all-str-num          .
           move      "[Dist."             to   w-all-str-cat (1)      .
           move      v-edt                to   w-all-str-cat (2)      .
      *
           if        w-det-dst-sts-dst    =    spaces
                     move  spaces         to   w-all-str-cat (3)
                     move  spaces         to   w-all-str-cat (4)
           else      move  "-"            to   w-all-str-cat (3)
                     move  w-det-dst-sts-dst
                                          to   w-all-str-cat (4)      .
      *
           if        w-det-dst-ide-sdi    =    spaces
                     move  spaces         to   w-all-str-cat (5)
                     move  spaces         to   w-all-str-cat (6)
           else      move  "-"            to   w-all-str-cat (5)
                     move  w-det-dst-ide-sdi
                                          to   w-all-str-cat (6)      .
      *
           move      "]"                  to   w-all-str-cat (7)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      23                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      w-all-str-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dst-xml-999.
           exit.

      *    *===========================================================*
      *    * Trattamento archivio per fatturazione                     *
      *    *-----------------------------------------------------------*
       trt-arc-plf-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to trt-arc-plf-999.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del tipo fornitura         *
      *              *-------------------------------------------------*
           if        w-tes-tip-frn (1)    =    01
                     go to trt-arc-plf-200
           else if   w-tes-tip-frn (1)    =    11
                     go to trt-arc-plf-400
           else if   w-tes-tip-frn (1)    =    21
                     go to trt-arc-plf-600
           else      go to trt-arc-plf-200.
       trt-arc-plf-200.
      *              *-------------------------------------------------*
      *              * Tipo fornitura : Diretta                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Forzatura dei valori relativi al cliente    *
      *                  *---------------------------------------------*
           move      w-tes-cod-cli (1)    to   w-tes-cli-plf (1)      .
           move      w-tes-dpz-cli (1)    to   w-tes-dpc-plf (1)      .
           go to     trt-arc-plf-999.
       trt-arc-plf-400.
      *              *-------------------------------------------------*
      *              * Tipo fornitura : Tramite Leasing                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Nessuna azione                              *
      *                  *---------------------------------------------*
           go to     trt-arc-plf-999.
       trt-arc-plf-600.
      *              *-------------------------------------------------*
      *              * Tipo fornitura : Tramite Gruppo d'Acquisto      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore gia' presente : nessuna azione    *
      *                  *---------------------------------------------*
           if        w-tes-cli-plf (1)    not  = zero
                     go to trt-arc-plf-999.
      *                  *---------------------------------------------*
      *                  * Preparazione default da anagrafica commer-  *
      *                  * ciale                                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura record [dcc] principale del     *
      *                      * cliente commerciale                     *
      *                      *-----------------------------------------*
           move      w-tes-cod-cli (1)    to   w-let-arc-dcc-cli      .
           move      spaces               to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione codice e dipendenza ar- *
      *                      * chivio per fatturazione                 *
      *                      *-----------------------------------------*
           move      w-let-arc-dcc-apf    to   w-tes-cli-plf (1)      .
           move      w-let-arc-dcc-dpf    to   w-tes-dpc-plf (1)      .
      *                      *-----------------------------------------*
      *                      * Lettura record [cli] del cliente per    *
      *                      * fatturazione associato al cliente com-  *
      *                      * merciale                                *
      *                      *-----------------------------------------*
           move      w-tes-cli-plf (1)    to   w-let-arc-cli-cod      .
           perform   let-arc-cli-000      thru let-arc-cli-999        .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione archivio    *
      *                      * per fatturazione                        *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-rag    to   w-tes-cli-plf-rag (1)  .
           move      w-let-arc-cli-via    to   w-tes-cli-plf-via (1)  .
           move      w-let-arc-cli-loc    to   w-tes-cli-plf-loc (1)  .
      *                      *-----------------------------------------*
      *                      * Lettura record [dcc] relativo alla di-  *
      *                      * pendenza dell'archivio per fatturazione *
      *                      * associato al cliente commerciale        *
      *                      *-----------------------------------------*
           move      w-tes-cli-plf (1)    to   w-let-arc-dcc-cli      .
           move      w-tes-dpc-plf (1)    to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione dipendenza  *
      *                      * dell'archivio per fatturazione associa- *
      *                      * to al cliente commerciale               *
      *                      *-----------------------------------------*
           move      w-let-arc-dcc-rag    to   w-tes-dpc-plf-rag (1)  .
           move      w-let-arc-dcc-via    to   w-tes-dpc-plf-via (1)  .
           move      w-let-arc-dcc-loc    to   w-tes-dpc-plf-loc (1)  .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     trt-arc-plf-999.
       trt-arc-plf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice cliente per fattura-  *
      *    * zione                                                     *
      *    *-----------------------------------------------------------*
       acc-cli-plf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-cli-plf-999.
           if        w-tes-fda-pt2 (1)    not  = spaces
                     go to acc-cli-plf-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cli-plf (1)    to   w-sav-cli-plf          .
      *                  *---------------------------------------------*
      *                  * Se Tab in corso : a controllo valore impo-  *
      *                  * stato                                       *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cli-plf-999.
       acc-cli-plf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-dcc-ope      .
           move      w-tes-cli-plf (1)    to   w-cod-mne-dcc-cod      .
           move      05                   to   w-cod-mne-dcc-lin      .
           move      30                   to   w-cod-mne-dcc-pos      .
           move      05                   to   w-cod-mne-dcc-rln      .
           move      41                   to   w-cod-mne-dcc-rps      .
           move      06                   to   w-cod-mne-dcc-vln      .
           move      41                   to   w-cod-mne-dcc-vps      .
           move      07                   to   w-cod-mne-dcc-lln      .
           move      41                   to   w-cod-mne-dcc-lps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-dcc-cll-000  thru cod-mne-dcc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-dcc-foi-000  thru cod-mne-dcc-foi-999    .
       acc-cli-plf-110.
           perform   cod-mne-dcc-cll-000  thru cod-mne-dcc-cll-999    .
           if        w-cod-mne-dcc-ope    =    "F+"
                     go to acc-cli-plf-115.
           if        w-cod-mne-dcc-ope    =    "AC"
                     go to acc-cli-plf-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cli-plf-115.
           perform   cod-mne-dcc-foi-000  thru cod-mne-dcc-foi-999    .
           go to     acc-cli-plf-110.
       acc-cli-plf-120.
           move      w-cod-mne-dcc-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cli-plf-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cli-plf-999.
       acc-cli-plf-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cli-plf (1)      .
       acc-cli-plf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Subroutine per controlli su cliente per la  *
      *                  * fatturazione                                *
      *                  *---------------------------------------------*
           move      w-tes-cli-plf (1)    to   w-ctl-cod-cli-cod      .
           perform   acc-cli-plf-ctl-000  thru acc-cli-plf-ctl-999    .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione cliente         *
      *                  *---------------------------------------------*
           perform   vis-cli-plf-des-000  thru vis-cli-plf-des-999    .
      *                  *---------------------------------------------*
      *                  * Controllo su flag di 'exit'                 *
      *                  *---------------------------------------------*
           if        w-ctl-cod-cli-ext    not  = spaces
                     go to acc-cli-plf-999.
      *                  *---------------------------------------------*
      *                  * Controllo su flag di errore                 *
      *                  *---------------------------------------------*
           if        w-ctl-cod-cli-flg    not  = spaces
                     go to acc-cli-plf-100.
       acc-cli-plf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazioni anche se valore attuale come *
      *                  * precedente                                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione valori testata indotti   *
      *                      * da record [dcc] principale              *
      *                      *-----------------------------------------*
           move      "F"                  to   w-det-vlt-dcc-tdt      .
           perform   det-vlt-dcc-000      thru det-vlt-dcc-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione funzionamento spese      *
      *                      *-----------------------------------------*
           move      "F"                  to   w-det-fun-spe-tdt      .
           perform   det-fun-spe-000      thru det-fun-spe-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione valori testata dipendenti*
      *                      * dall'inoltro pagamenti                  *
      *                      *-----------------------------------------*
           move      w-tes-dpc-plf (1)    to   w-det-vlt-ipg-dpz      .
           perform   det-vlt-ipg-000      thru det-vlt-ipg-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione valori testata associati *
      *                      * all'agente                              *
      *                      *-----------------------------------------*
           move      w-tes-dpc-plf (1)    to   w-det-vlt-age-dpz      .
           perform   det-vlt-age-000      thru det-vlt-age-999        .
       acc-cli-plf-620.
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-cli-plf (1)    =    w-sav-cli-plf
                     go to acc-cli-plf-800.
      *                      *-----------------------------------------*
      *                      * Trattamento dipendenza                  *
      *                      *-----------------------------------------*
           if        w-tes-dpc-plf (1)    =    spaces
                     go to acc-cli-plf-610.
      *                          *-------------------------------------*
      *                          * Normalizzazione e rivisualizzazione *
      *                          *-------------------------------------*
           move      spaces               to   w-tes-dpc-plf (1)      .
           move      spaces               to   w-tes-dpc-plf-rag (1)  .
           move      spaces               to   w-tes-dpc-plf-via (1)  .
           move      spaces               to   w-tes-dpc-plf-loc (1)  .
           perform   vis-dpc-plf-000      thru vis-dpc-plf-999        .
           perform   vis-dpc-plf-des-000  thru vis-dpc-plf-des-999    .
      *                          *-------------------------------------*
      *                          * Normalizzazione dati testata asso-  *
      *                          * ciati alla dipendenza               *
      *                          *-------------------------------------*
           move      zero                 to   w-tes-abi-dpz (1)      .
           move      spaces               to   w-tes-abi-dpz-den (1)  .
           move      zero                 to   w-tes-cab-dpz (1)      .
           move      spaces               to   w-tes-cab-dpz-den (1)  .
           move      spaces               to   w-tes-cca-dpz (1)      .
           move      zero                 to   w-tes-age-aad (1)      .
       acc-cli-plf-610.
      *                  *---------------------------------------------*
      *                  * Determinazione se presenti dipendenze per   *
      *                  * il cliente per fatturazione                 *
      *                  *---------------------------------------------*
           move      w-tes-cli-plf (1)    to   w-det-snd-dcc-cli      .
           perform   det-snd-dcc-000      thru det-snd-dcc-999        .
           move      w-det-snd-dcc-snx    to   w-tes-cli-plf-snd (1)  .
       acc-cli-plf-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cli-plf-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cli-plf-100.
       acc-cli-plf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice cliente per fattura-  *
      *    * zione                                                     *
      *    *                                                           *
      *    * Controlli                                                 *
      *    *-----------------------------------------------------------*
       acc-cli-plf-ctl-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flags di uscita                 *
      *              *-------------------------------------------------*
           move      spaces               to   w-ctl-cod-cli-flg      .
           move      spaces               to   w-ctl-cod-cli-ext      .
       acc-cli-plf-ctl-100.
      *              *-------------------------------------------------*
      *              * Lettura file [cli]                              *
      *              *-------------------------------------------------*
           move      w-ctl-cod-cli-cod    to   w-let-arc-cli-cod      .
           perform   let-arc-cli-000      thru let-arc-cli-999        .
           move      w-let-arc-cli-rag    to   w-tes-cli-plf-rag (1)  .
           move      w-let-arc-cli-via    to   w-tes-cli-plf-via (1)  .
           move      w-let-arc-cli-loc    to   w-tes-cli-plf-loc (1)  .
           move      w-let-arc-cli-stc    to   w-tes-cod-cli-stc (1)  .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : ad uscita per con-  *
      *                  * trollo non superato senza messaggio di er-  *
      *                  * rore                                        *
      *                  *---------------------------------------------*
           if        w-let-arc-cli-flg    not  = spaces
                     go to acc-cli-plf-ctl-930.
       acc-cli-plf-ctl-120.
      *                  *---------------------------------------------*
      *                  * Controllo che cliente impostato sia diverso *
      *                  * da zero                                     *
      *                  *---------------------------------------------*
           if        w-ctl-cod-cli-cod    not  = zero
                     go to acc-cli-plf-ctl-130.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Cliente per fatturazione a zero non accettabile ! 
      -              "               "    to   w-err-box-err-msg      .
      *                      *-----------------------------------------*
      *                      * Ad uscita per controllo non superato    *
      *                      * con emissione messaggio di errore       *
      *                      *-----------------------------------------*
           go to     acc-cli-plf-ctl-920.
       acc-cli-plf-ctl-130.
      *                  *---------------------------------------------*
      *                  * Controllo che cliente impostato sia diverso *
      *                  * da quello principale                        *
      *                  *---------------------------------------------*
           if        w-ctl-cod-cli-cod    not  = w-tes-cod-cli (1)
                     go to acc-cli-plf-ctl-140.
      *                      *-----------------------------------------*
      *                      * Se fornitura tramite gruppo d'acquisto, *
      *                      * si ammette, solo in modifica, che il    *
      *                      * cliente per fatturazione sia pari a     *
      *                      * quello commerciale                      *
      *                      *-----------------------------------------*
           if        w-tes-tip-frn (1)    =    21  and
                     w-cnt-mfu-tip-fun    =    "M"
                     go to acc-cli-plf-ctl-140.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Cliente per fatturazione uguale a quello principal
      -              "e !            "    to   w-err-box-err-msg      .
      *                      *-----------------------------------------*
      *                      * Ad uscita per controllo non superato    *
      *                      * con emissione messaggio di errore       *
      *                      *-----------------------------------------*
           go to     acc-cli-plf-ctl-920.
       acc-cli-plf-ctl-140.
      *                  *---------------------------------------------*
      *                  * Test su codice sottoconto associato al      *
      *                  * cliente                                     *
      *                  *---------------------------------------------*
           if        w-tes-cod-cli-stc (1)
                                          not  = zero
                     go to acc-cli-plf-ctl-200.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Manca il sottoconto contabile per il cliente !    
      -              "               "    to   w-err-box-err-msg      .
      *                      *-----------------------------------------*
      *                      * Ad uscita per controllo non superato    *
      *                      * con emissione messaggio di errore       *
      *                      *-----------------------------------------*
           go to     acc-cli-plf-ctl-920.
       acc-cli-plf-ctl-200.
      *                  *---------------------------------------------*
      *                  * Lettura record [dcc] principale             *
      *                  *---------------------------------------------*
           move      w-ctl-cod-cli-cod    to   w-let-arc-dcc-cli      .
           move      spaces               to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                  *---------------------------------------------*
      *                  * Se lettura OK : oltre                       *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-flg    =    spaces
                     go to acc-cli-plf-ctl-300.
      *                      *-----------------------------------------*
      *                      * Altrimenti : messaggio di errore        *
      *                      *-----------------------------------------*
           move      "Manca l'anagrafica commerciale per il cliente     
      -              "               "    to   w-err-box-err-msg      .
      *                      *-----------------------------------------*
      *                      * Ad uscita per controllo non superato    *
      *                      * con emissione messaggio di errore       *
      *                      *-----------------------------------------*
           go to     acc-cli-plf-ctl-920.
       acc-cli-plf-ctl-300.
      *              *-------------------------------------------------*
      *              * Trattamento assoggettamento iva                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale forzatura                         *
      *                  *---------------------------------------------*
           if        w-ctl-cau-doc-tdo    =    03  and
                     w-tes-tip-mov-dst    =    "*"
                     move  301            to   w-tes-ass-iva (1)
                     go to acc-cli-plf-ctl-400.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo assoggetta- *
      *                  * mento iva del cliente                       *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-tai    =    01
                     go to acc-cli-plf-ctl-320
           else if   w-let-arc-dcc-tai    =    02
                     go to acc-cli-plf-ctl-340
           else if   w-let-arc-dcc-tai    =    03
                     go to acc-cli-plf-ctl-360
           else if   w-let-arc-dcc-tai    =    04
                     go to acc-cli-plf-ctl-380.
       acc-cli-plf-ctl-320.
      *                  *---------------------------------------------*
      *                  * Tipo assoggettamento iva cliente : sempre   *
      *                  * soggetto ad iva                             *
      *                  *---------------------------------------------*
           move      zero                 to   w-tes-ass-iva (1)      .
           move      "Soggetto ad iva"    to   w-tes-ass-iva-des (1)  .
           go to     acc-cli-plf-ctl-400.
       acc-cli-plf-ctl-340.
      *                  *---------------------------------------------*
      *                  * Tipo assoggettamento iva cliente : sempre   *
      *                  * esente da iva                               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controllo che il codice iva in anagra-  *
      *                      * fica cliente sia un titolo di esenzione *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    >    2 and
                     w-edt-iva-cod-003    <    7
                     go to acc-cli-plf-ctl-345.
      *                          *-------------------------------------*
      *                          * Preparazione messaggio di errore    *
      *                          *-------------------------------------*
           move      "Assoggettamento iva errato in anagrafica cliente c
      -              "ontabile       "    to   w-err-box-err-msg      .
      *                          *-------------------------------------*
      *                          * Ad uscita per controllo non supera- *
      *                          * to con emissione messaggio di erro- *
      *                          * re                                  *
      *                          *-------------------------------------*
           go to     acc-cli-plf-ctl-920.
       acc-cli-plf-ctl-345.
      *                      *-----------------------------------------*
      *                      * Lettura tabella [codiva]                *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata                       *
      *                      *-----------------------------------------*
           if        w-let-arc-zci-flg    =    spaces
                     go to acc-cli-plf-ctl-350.
      *                          *-------------------------------------*
      *                          * Preparazione messaggio di errore    *
      *                          *-------------------------------------*
           move      "Assoggettamento iva non esistente in anagrafica cl
      -              "iente contabile"    to   w-err-box-err-msg      .
      *                          *-------------------------------------*
      *                          * Ad uscita per controllo non supera- *
      *                          * to con emissione messaggio di erro- *
      *                          * re                                  *
      *                          *-------------------------------------*
           go to     acc-cli-plf-ctl-920.
       acc-cli-plf-ctl-350.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione assoggettamento iva     *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-tes-ass-iva (1)      .
           move      w-let-arc-zci-des    to   w-tes-ass-iva-des (1)  .
           go to     acc-cli-plf-ctl-400.
       acc-cli-plf-ctl-360.
      *                  *---------------------------------------------*
      *                  * Tipo assoggettamento iva cliente : Cliente  *
      *                  * con plafond                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione relativa alla *
      *                      * gestione lettera d'intenti              *
      *                      *-----------------------------------------*
           if        w-prs-snx-lic        not  = "S"
                     go to acc-cli-plf-ctl-365.
      *                      *-----------------------------------------*
      *                      * Lettura record [lic]                    *
      *                      *-----------------------------------------*
           move      w-ctl-cod-cli-cod    to   w-let-arc-lic-cod      .
           perform   let-arc-lic-000      thru let-arc-lic-999        .
      *                      *-----------------------------------------*
      *                      * Se data documento non compresa tra data *
      *                      * riferimento iniziale e finale : si pro- *
      *                      * cede come per cliente sempre soggetto   *
      *                      *-----------------------------------------*
           if        w-tes-dat-doc        not  < w-let-arc-lic-dri and
                     w-tes-dat-doc        not  > w-let-arc-lic-drf
                     go to acc-cli-plf-ctl-365.
      *                          *-------------------------------------*
      *                          * Messaggio                           *
      *                          *-------------------------------------*
           move      "Il documento non ricade entro gli estremi della le
      -              "ttera d'intenti"    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                          *-------------------------------------*
      *                          * Si procede come per cliente sempre  *
      *                          * soggetto                            *
      *                          *-------------------------------------*
           go to     acc-cli-plf-ctl-320.
       acc-cli-plf-ctl-365.
      *                      *-----------------------------------------*
      *                      * Controllo che il codice iva in anagra-  *
      *                      * fica cliente sia un titolo di esenzione *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    >    2 and
                     w-edt-iva-cod-003    <    7
                     go to acc-cli-plf-ctl-370.
      *                          *-------------------------------------*
      *                          * Preparazione messaggio di errore    *
      *                          *-------------------------------------*
           move      "Assoggettamento iva errato in anagrafica cliente c
      -              "ontabile       "    to   w-err-box-err-msg      .
      *                          *-------------------------------------*
      *                          * Ad uscita per controllo non supera- *
      *                          * to con emissione messaggio di erro- *
      *                          * re                                  *
      *                          *-------------------------------------*
           go to     acc-cli-plf-ctl-920.
       acc-cli-plf-ctl-370.
      *                      *-----------------------------------------*
      *                      * Lettura tabella [codiva]                *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata                       *
      *                      *-----------------------------------------*
           if        w-let-arc-zci-flg    =    spaces
                     go to acc-cli-plf-ctl-375.
      *                          *-------------------------------------*
      *                          * Preparazione messaggio di errore    *
      *                          *-------------------------------------*
           move      "Assoggettamento iva non esistente in anagrafica cl
      -              "iente contabile"    to   w-err-box-err-msg      .
      *                          *-------------------------------------*
      *                          * Ad uscita per controllo non supera- *
      *                          * to con emissione messaggio di erro- *
      *                          * re                                  *
      *                          *-------------------------------------*
           go to     acc-cli-plf-ctl-920.
       acc-cli-plf-ctl-375.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione assoggettamento iva     *
      *                      *-----------------------------------------*
           move      w-let-arc-cli-ass    to   w-tes-ass-iva (1)      .
           move      w-let-arc-zci-des    to   w-tes-ass-iva-des (1)  .
           go to     acc-cli-plf-ctl-400.
       acc-cli-plf-ctl-380.
      *                  *---------------------------------------------*
      *                  * Tipo assoggettamento iva cliente : Cliente  *
      *                  * in regime di Scissione Pagamenti            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Assoggettamento Iva                     *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-ass-iva (1)      .
      *                      *-----------------------------------------*
      *                      * Segnale di Scissione Pagamenti          *
      *                      *-----------------------------------------*
           move      "S"                  to   w-tes-ass-iva-spl (1)  .
      *                      *-----------------------------------------*
      *                      * Dicitura per aliquota Iva               *
      *                      *-----------------------------------------*
           move      "Scissione Pagamenti"
                                          to   w-tes-ass-iva-des (1)  .
      *                      *-----------------------------------------*
      *                      * Nessun controllo in questa fase         *
      *                      *-----------------------------------------*
           go to     acc-cli-plf-ctl-400.
       acc-cli-plf-ctl-400.
      *                  *---------------------------------------------*
      *                  * Test su segnale di consegne bloccate        *
      *                  *---------------------------------------------*
       acc-cli-plf-ctl-500.
      *                  *---------------------------------------------*
      *                  * Test su tipo documento preferenziale        *
      *                  *---------------------------------------------*
       acc-cli-plf-ctl-600.
      *                  *---------------------------------------------*
      *                  * Test su status commerciale del cliente      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se status normale : ad uscita           *
      *                      *-----------------------------------------*
           if        w-let-arc-dcc-tus    =    01 or
                     w-let-arc-dcc-tus    =    09
                     go to acc-cli-plf-ctl-800.
      *                      *-----------------------------------------*
      *                      * Se status non normale : box specifico   *
      *                      * per lo status commerciale               *
      *                      *-----------------------------------------*
           perform   acc-cli-plf-bsc-000  thru acc-cli-plf-bsc-999    .
      *                      *-----------------------------------------*
      *                      * Ad uscita per controllo non superato    *
      *                      * ma senza emissione messaggio di errore  *
      *                      *-----------------------------------------*
           go to     acc-cli-plf-ctl-930.
       acc-cli-plf-ctl-800.
      *              *-------------------------------------------------*
      *              * Uscita per controlli superati                   *
      *              *-------------------------------------------------*
           go to     acc-cli-plf-ctl-999.
       acc-cli-plf-ctl-900.
      *              *-------------------------------------------------*
      *              * Uscita per controlli non superati o per emis-   *
      *              * sione messaggio di errore                       *
      *              *-------------------------------------------------*
       acc-cli-plf-ctl-910.
      *                  *---------------------------------------------*
      *                  * Uscita con solo messaggio di errore         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Box di errore                           *
      *                      *-----------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     acc-cli-plf-ctl-999.
       acc-cli-plf-ctl-920.
      *                  *---------------------------------------------*
      *                  * Uscita con messaggio di errore e flag di    *
      *                  * errore                                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Box di errore                           *
      *                      *-----------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
       acc-cli-plf-ctl-930.
      *                  *---------------------------------------------*
      *                  * Uscita con flag di errore                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di uscita                          *
      *                      *-----------------------------------------*
           move      "#"                  to   w-ctl-cod-cli-flg      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     acc-cli-plf-ctl-999.
       acc-cli-plf-ctl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice cliente per fattura-  *
      *    * zione                                                     *
      *    *                                                           *
      *    * Box di errore emesso in funzione dello status commerciale *
      *    * del cliente, se diverso da 'normale'                      *
      *    *-----------------------------------------------------------*
       acc-cli-plf-bsc-000.
      *              *-------------------------------------------------*
      *              * Messaggio di errore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio del video attuale               *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      20                   to   v-lto                  .
           move      08                   to   v-pos                  .
           move      73                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cli-plf-bsc-200.
      *                  *---------------------------------------------*
      *                  * Messaggi entro il box                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Titolo centrale                         *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "                     A T T E N Z I O N E          
      -              "            "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 1                        *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "Per il cliente impostato si rileva la seguente con
      -              "dizione :   "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Preparazione riga messaggio 2           *
      *                      *-----------------------------------------*
           if        w-let-arc-dcc-tus    =    11
                     move  "[Esauriti i rapporti commerciali]           
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    21
                     move  "[Sostituito da ns. nuovo cliente]           
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    51
                     move  "[Cessata attivita']                         
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    52
                     move  "[Cessata attivita', ma sostituito da ns. nuo
      -                    "vo cliente]       "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    61
                     move  "[In contenzioso]                            
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    62
                     move  "[In contenzioso, ma sostituito da ns. nuovo 
      -                    "cliente]          "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    71
                     move  "[Fallito]                                   
      -                    "                  "
                                          to   v-alf
           else if   w-let-arc-dcc-tus    =    72
                     move  "[Fallito, ma sostituito da ns. nuovo cliente
      -                    "]                 "
                                          to   v-alf
           else      move  "(status non determinato)                    
      -                    "                  "
                                          to   v-alf                  .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 2                        *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      10                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Riga messaggio 3                        *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da emettere                 *
      *                          *-------------------------------------*
           if        w-let-arc-dcc-tud    =    zero
                     go to acc-cli-plf-bsc-300.
      *                          *-------------------------------------*
      *                          * Emissione                           *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "La determinazione di tale condizione risale al :  
      -              "            "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Data di rilevamento status          *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      15                   to   v-lin                  .
           move      59                   to   v-pos                  .
           move      w-let-arc-dcc-tud    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cli-plf-bsc-300.
      *                      *-----------------------------------------*
      *                      * Righe messaggio 4 e 5                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da emettere                 *
      *                          *-------------------------------------*
           if        w-let-arc-dcc-tuc    =    zero
                     go to acc-cli-plf-bsc-600.
      *                          *-------------------------------------*
      *                          * Emissione                           *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "Il cliente utilizzabile in alternativa e' il segue
      -              "nte :       "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Codice cliente alternativo          *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      19                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      w-let-arc-dcc-tuc    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Lettura descrizione per il cliente  *
      *                          * alternativo                         *
      *                          *-------------------------------------*
           move      w-let-arc-dcc-tuc    to   w-let-arc-cli-cod      .
           perform   let-arc-cli-000      thru let-arc-cli-999        .
           if        w-let-arc-cli-flg    not  = spaces
                     move  all "."        to   v-alf
           else      move  w-let-arc-cli-rag
                                          to   v-alf                  .
      *                          *-------------------------------------*
      *                          * Emissione                           *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      20                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cli-plf-bsc-600.
      *                      *-----------------------------------------*
      *                      * Prompt per presa visione                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      69                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cli-plf-bsc-800.
      *              *-------------------------------------------------*
      *              * Video in On                                     *
      *              *-------------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Accettazione carattere di presa visione         *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      19                   to   v-lin                  .
           move      70                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Ripristino immagine video                       *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-cli-plf-bsc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice cliente per fattu- *
      *    * razione                                                   *
      *    *-----------------------------------------------------------*
       vis-cli-plf-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<B"                 to   v-edm                  .
           move      w-tes-cli-plf (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cli-plf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione cliente per   *
      *    * fatturazione                                              *
      *    *-----------------------------------------------------------*
       vis-cli-plf-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cli-plf-rag (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cli-plf-via (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-cli-plf-loc (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cli-plf-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Dipendenza cliente per fat-  *
      *    * turazione                                                 *
      *    *-----------------------------------------------------------*
       acc-dpc-plf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test  se campo da accettare                 *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-dpc-plf-999.
           if        w-tes-cli-plf-snd (1)
                                          =    "N"
                     go to acc-dpc-plf-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-dpc-plf (1)    to   w-sav-dpc-plf          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-dpc-plf-400.
       acc-dpc-plf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-dcc-ope      .
           move      w-tes-cli-plf (1)    to   w-cod-cod-dcc-cli      .
           move      w-tes-dpc-plf (1)    to   w-cod-cod-dcc-cod      .
           move      09                   to   w-cod-cod-dcc-lin      .
           move      30                   to   w-cod-cod-dcc-pos      .
           move      09                   to   w-cod-cod-dcc-rln      .
           move      41                   to   w-cod-cod-dcc-rps      .
           move      10                   to   w-cod-cod-dcc-vln      .
           move      41                   to   w-cod-cod-dcc-vps      .
           move      11                   to   w-cod-cod-dcc-lln      .
           move      41                   to   w-cod-cod-dcc-lps      .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-dcc-cll-000  thru cod-cod-dcc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-dcc-foi-000  thru cod-cod-dcc-foi-999    .
       acc-dpc-plf-110.
           perform   cod-cod-dcc-cll-000  thru cod-cod-dcc-cll-999    .
           if        w-cod-cod-dcc-ope    =    "F+"
                     go to acc-dpc-plf-115.
           if        w-cod-cod-dcc-ope    =    "AC"
                     go to acc-dpc-plf-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-dpc-plf-115.
           perform   cod-cod-dcc-foi-000  thru cod-cod-dcc-foi-999    .
           go to     acc-dpc-plf-110.
       acc-dpc-plf-120.
           move      w-cod-cod-dcc-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-dpc-plf-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-dpc-plf-999.
       acc-dpc-plf-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-dpc-plf (1)      .
       acc-dpc-plf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura file [dcc]                          *
      *                  *---------------------------------------------*
           move      w-tes-cli-plf (1)    to   w-let-arc-dcc-cli      .
           move      w-tes-dpc-plf (1)    to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           move      w-let-arc-dcc-rag    to   w-tes-dpc-plf-rag (1)  .
           move      w-let-arc-dcc-via    to   w-tes-dpc-plf-via (1)  .
           move      w-let-arc-dcc-loc    to   w-tes-dpc-plf-loc (1)  .
           perform   vis-dpc-plf-des-000  thru vis-dpc-plf-des-999    .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : reimpostazione      *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-flg    not  = spaces
                     go to acc-dpc-plf-100.
       acc-dpc-plf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-dpc-plf (1)    =    w-sav-dpc-plf
                     go to acc-dpc-plf-800.
      *                      *-----------------------------------------*
      *                      * Eventuale normalizzazione valore per i- *
      *                      * noltro pagamenti                        *
      *                      *-----------------------------------------*
           if        w-tes-dpc-plf (1)    =    spaces and
                     w-tes-inl-pgt (1)    =    03
                     move  02             to   w-tes-inl-pgt (1)      .
      *                      *-----------------------------------------*
      *                      * Valori testata indotti da record [dcc]  *
      *                      * relativo alla dipendenza                *
      *                      *-----------------------------------------*
           move      "F"                  to   w-det-vlt-dcd-tdt      .
           move      w-tes-dpc-plf (1)    to   w-det-vlt-dcd-dpz      .
           perform   det-vlt-dcd-000      thru det-vlt-dcd-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione valori testata dipendenti*
      *                      * dall'inoltro pagamenti                  *
      *                      *-----------------------------------------*
           move      w-tes-dpc-plf (1)    to   w-det-vlt-ipg-dpz      .
           perform   det-vlt-ipg-000      thru det-vlt-ipg-999        .
      *                      *-----------------------------------------*
      *                      * Determinazione valori testata associati *
      *                      * all'agente                              *
      *                      *-----------------------------------------*
           move      w-tes-dpc-plf (1)    to   w-det-vlt-age-dpz      .
           perform   det-vlt-age-000      thru det-vlt-age-999        .
       acc-dpc-plf-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-dpc-plf-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-dpc-plf-100.
       acc-dpc-plf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Dipendenza cliente per la *
      *    * fatturazione                                              *
      *    *-----------------------------------------------------------*
       vis-dpc-plf-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-dpc-plf (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dpc-plf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione dipendenza    *
      *    * cliente per la fatturazione                               *
      *    *-----------------------------------------------------------*
       vis-dpc-plf-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-dpc-plf-rag (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-dpc-plf-via (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-dpc-plf-loc (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dpc-plf-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Inoltro documenti            *
      *    *-----------------------------------------------------------*
       acc-inl-dcm-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-inl-dcm-999.
           if        w-tes-tip-mov-ord    =    02
                     go to acc-inl-dcm-999.
      *                  *---------------------------------------------*
      *                  * Se dipendenza cliente per fatturazione non  *
      *                  * esistente, modifica nr. elementi del pop-up *
      *                  * di accettazione                             *
      *                  *---------------------------------------------*
           if        w-tes-dpc-plf (1)    =    spaces
                     move 02              to   w-exp-inl-dcm-num
           else      move 03              to   w-exp-inl-dcm-num      .
           if        w-tes-dpc-plf (1)    =    spaces and
                     w-tes-inl-dcm (1)    =    03
                     move  02             to   w-tes-inl-dcm (1)      .
      *                  *---------------------------------------------*
      *                  * Preparazione eventuale default              *
      *                  *---------------------------------------------*
           if        w-tes-inl-dcm (1)    =    zero
                     move  02             to   w-tes-inl-dcm (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           perform   vis-inl-dcm-000      thru vis-inl-dcm-999        .
       acc-inl-dcm-050.
      *                  *---------------------------------------------*
      *                  * Se Tab in corso : a controllo valore impo-  *
      *                  * stato                                       *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-inl-dcm-999.
       acc-inl-dcm-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-inl-dcm-lun    to   v-car                  .
           move      w-exp-inl-dcm-num    to   v-ldt                  .
           move      "SLD#"               to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-inl-dcm-tbl    to   v-txt                  .
           move      w-tes-inl-dcm (1)    to   v-num                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-inl-dcm-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-inl-dcm-999.
       acc-inl-dcm-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-inl-dcm (1)      .
       acc-inl-dcm-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se zero : reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-tes-inl-dcm (1)    not  = zero
                     go to acc-inl-dcm-600.
           if        v-key                =    "UP  "
                     go to acc-inl-dcm-600
           else      go to acc-inl-dcm-100.
       acc-inl-dcm-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-inl-dcm-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-inl-dcm-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-inl-dcm-100.
       acc-inl-dcm-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Inoltro documenti         *
      *    *-----------------------------------------------------------*
       vis-inl-dcm-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-inl-dcm-lun    to   v-car                  .
           move      w-exp-inl-dcm-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-inl-dcm-tbl    to   v-txt                  .
           move      w-tes-inl-dcm (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-inl-dcm-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Inoltro pagamenti            *
      *    *-----------------------------------------------------------*
       acc-inl-pgt-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-inl-pgt-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-inl-pgt (1)    to    w-sav-inl-pgt         .
      *                  *---------------------------------------------*
      *                  * Se dipendenza cliente per fatturazione non  *
      *                  * esistente, modifica nr. elementi del pop-up *
      *                  * di accettazione                             *
      *                  *---------------------------------------------*
           if        w-tes-dpc-plf (1)    =    spaces
                     move 02              to   w-exp-inl-pgt-num
           else      move 03              to   w-exp-inl-pgt-num      .
           if        w-tes-dpc-plf (1)    =    spaces and
                     w-tes-inl-pgt (1)    =    03
                     move  02             to   w-tes-inl-pgt (1)      .
      *                  *---------------------------------------------*
      *                  * Preparazione eventuale default              *
      *                  *---------------------------------------------*
           if        w-tes-inl-pgt (1)    =    zero
                     move  02             to   w-tes-inl-pgt (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           perform   vis-inl-pgt-000      thru vis-inl-pgt-999        .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-inl-pgt-400.
       acc-inl-pgt-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-inl-pgt-lun    to   v-car                  .
           move      w-exp-inl-pgt-num    to   v-ldt                  .
           move      "SLD#"               to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      06                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-inl-pgt-tbl    to   v-txt                  .
           move      w-tes-inl-pgt (1)    to   v-num                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-inl-pgt-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-inl-pgt-999.
       acc-inl-pgt-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-inl-pgt (1)      .
       acc-inl-pgt-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se zero : reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-tes-inl-pgt (1)    not  = zero
                     go to acc-inl-pgt-600.
           if        v-key                =    "UP  "
                     go to acc-inl-pgt-600
           else      go to acc-inl-pgt-100.
       acc-inl-pgt-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-inl-pgt (1)    =     w-sav-inl-pgt
                     go to acc-inl-pgt-800.
      *                  *---------------------------------------------*
      *                  * Determinazione valori testata dipendenti    *
      *                  * dall'inoltro pagamenti                      *
      *                  *---------------------------------------------*
           move      w-tes-dpc-plf (1)    to   w-det-vlt-ipg-dpz      .
           perform   det-vlt-ipg-000      thru det-vlt-ipg-999        .
       acc-inl-pgt-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-inl-pgt-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-inl-pgt-100.
       acc-inl-pgt-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Inoltro pagamenti         *
      *    *-----------------------------------------------------------*
       vis-inl-pgt-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-inl-pgt-lun    to   v-car                  .
           move      w-exp-inl-pgt-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      06                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-inl-pgt-tbl    to   v-txt                  .
           move      w-tes-inl-pgt (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-inl-pgt-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Sigla valuta per fatturazio- *
      *    * ne                                                        *
      *    *-----------------------------------------------------------*
       acc-sgl-vpf-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-sgl-vpf-999.
           if        w-tes-fda-vpf (1)    not  = spaces
                     go to acc-sgl-vpf-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-sav-sgl-vpf          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-sgl-vpf-400.
       acc-sgl-vpf-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-zvl-ope      .
           move      w-tes-sgl-vpf (1)    to   w-cod-cod-zvl-cod      .
           move      08                   to   w-cod-cod-zvl-lin      .
           move      30                   to   w-cod-cod-zvl-pos      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
       acc-sgl-vpf-110.
           perform   cod-cod-zvl-cll-000  thru cod-cod-zvl-cll-999    .
           if        w-cod-cod-zvl-ope    =    "F+"
                     go to acc-sgl-vpf-115.
           if        w-cod-cod-zvl-ope    =    "AC"
                     go to acc-sgl-vpf-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-sgl-vpf-115.
           perform   cod-cod-zvl-foi-000  thru cod-cod-zvl-foi-999    .
           go to     acc-sgl-vpf-110.
       acc-sgl-vpf-120.
           move      w-cod-cod-zvl-cod    to   v-alf                  .
       acc-sgl-vpf-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-sgl-vpf-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-sgl-vpf-999.
       acc-sgl-vpf-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-sgl-vpf (1)      .
       acc-sgl-vpf-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura record [zvl]                        *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-let-arc-zvl-cod      .
           perform   let-arc-zvl-000      thru let-arc-zvl-999        .
           move      w-let-arc-zvl-des    to   w-tes-sgl-vpf-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione valuta          *
      *                  *---------------------------------------------*
           perform   vis-sgl-vpf-des-000  thru vis-sgl-vpf-des-999    .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        w-let-arc-zvl-flg    not  = spaces
                     go to acc-sgl-vpf-100.
      *                  *---------------------------------------------*
      *                  * Valore a spaces non ammesso                 *
      *                  *---------------------------------------------*
           if        w-tes-sgl-vpf (1)    =    spaces
                     go to acc-sgl-vpf-100.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione numero decimali             *
      *                  *---------------------------------------------*
           move      w-let-arc-zvl-dec    to   w-tes-dec-vpf (1)      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione tipo di cambio              *
      *                  *---------------------------------------------*
           move      w-let-arc-zvl-tdc    to   w-tes-tdc-vpf (1)      .
      *                  *---------------------------------------------*
      *                  * Determinazione coefficiente di cambio       *
      *                  *---------------------------------------------*
           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      w-tes-sgl-vpf (1)    to   w-coe-cmb-vlt-sdv      .
           move      w-tes-tdc-vpf (1)    to   w-coe-cmb-vlt-tdc      .
           move      w-tes-dat-doc        to   w-coe-cmb-vlt-drc      .
           move      00                   to   w-coe-cmb-vlt-quc      .
           perform   coe-cmb-vlt-cll-000  thru coe-cmb-vlt-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test su esito determinazione                *
      *                  *---------------------------------------------*
           if        w-coe-cmb-vlt-ope    =    "CC"
                     go to acc-sgl-vpf-420.
           move      "Coefficiente di cambio indeterminato !            
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-sgl-vpf-100.
       acc-sgl-vpf-420.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione coefficiente di cambio      *
      *                  *---------------------------------------------*
           move      w-coe-cmb-vlt-cdc    to   w-tes-cdc-vpf (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione coefficiente di cambio      *
      *                  *---------------------------------------------*
           perform   pmt-cdc-vpf-000      thru pmt-cdc-vpf-999        .
           perform   vis-cdc-vpf-000      thru vis-cdc-vpf-999        .
       acc-sgl-vpf-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-sgl-vpf-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-sgl-vpf-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-sgl-vpf-100.
       acc-sgl-vpf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Sigla valuta per fattura- *
      *    * zione                                                     *
      *    *-----------------------------------------------------------*
       vis-sgl-vpf-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-sgl-vpf (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sgl-vpf-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione sigla valuta  *
      *    * per fatturazione                                          *
      *    *-----------------------------------------------------------*
       vis-sgl-vpf-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-tes-sgl-vpf-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-sgl-vpf-des-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Coefficiente di cambio            *
      *    *-----------------------------------------------------------*
       vis-cdc-vpf-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-sgl-vpf (1)    =    c-sgl
                     go to vis-cdc-vpf-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      05                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<GBD"               to   v-edm                  .
           move      08                   to   v-lin                  .
           move      68                   to   v-pos                  .
           if        w-tes-sgl-vpf (1)    =    c-sgl
                     move  zero           to   v-num
           else      move  w-tes-cdc-vpf (1)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cdc-vpf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Assoggettamento iva          *
      *    *-----------------------------------------------------------*
       acc-ass-iva-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-ass-iva-999.
           if        w-ctl-cau-doc-tdo    =    03  and
                     w-tes-tip-mov-dst    =    "*"
                     go to acc-ass-iva-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-sav-ass-iva          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-ass-iva-400.
       acc-ass-iva-100.
      *              *-------------------------------------------------*
      *              * Editing preliminare per l'accettazione          *
      *              *-------------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zci-ope      .
           move      w-edt-iva-cie        to   w-cod-mne-zci-cod      .
           move      10                   to   w-cod-mne-zci-lin      .
           move      30                   to   w-cod-mne-zci-pos      .
           move      10                   to   w-cod-mne-zci-dln      .
           move      37                   to   w-cod-mne-zci-dps      .
           move      "<BD"                to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
       acc-ass-iva-110.
           perform   cod-mne-zci-cll-000  thru cod-mne-zci-cll-999    .
           if        w-cod-mne-zci-ope    =    "F+"
                     go to acc-ass-iva-115.
           if        w-cod-mne-zci-ope    =    "AC"
                     go to acc-ass-iva-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-ass-iva-115.
           perform   cod-mne-zci-foi-000  thru cod-mne-zci-foi-999    .
           go to     acc-ass-iva-110.
       acc-ass-iva-120.
      *              *-------------------------------------------------*
      *              * Editing valore impostato                        *
      *              *-------------------------------------------------*
           move      w-cod-mne-zci-cod    to   w-edt-iva-cie          .
           perform   edt-iva-cod-000      thru edt-iva-cod-999        .
           move      w-edt-iva-cod        to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-ass-iva-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-ass-iva-999.
       acc-ass-iva-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-ass-iva (1)      .
       acc-ass-iva-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-zci-des    to   w-tes-ass-iva-des (1)  .
           if        w-tes-ass-iva (1)    =    zero
                     move  "Soggetto ad iva"
                                          to   w-tes-ass-iva-des (1)  .
      *
           if        w-tes-ass-iva (1)    =    zero and
                     w-tes-ass-iva-spl (1)
                                          =    "S"
                     move  "Scissione Pagamenti"
                                          to   w-tes-ass-iva-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-ass-iva-des-000  thru vis-ass-iva-des-999    .
      *                  *---------------------------------------------*
      *                  * Se lettura errata : reimpostazione          *
      *                  *---------------------------------------------*
           if        w-let-arc-zci-flg    not  = spaces
                     go to acc-ass-iva-100.
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso : test che non sia un *
      *                  * codice Iva imponibile per la sostituzione   *
      *                  * in tutte le righe                           *
      *                  *---------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-edt-iva-cod          .
      *
           if       (w-tes-ass-iva (1)    not  = zero   ) and
                    (w-edt-iva-cod-003    not  > zero)
                     go to acc-ass-iva-500
           else      go to acc-ass-iva-600.
       acc-ass-iva-500.
      *                  *---------------------------------------------*
      *                  * Eventuale ricalcolo codici iva in riga      *
      *                  *---------------------------------------------*
           perform   rcl-civ-doc-000      thru rcl-civ-doc-999        .
      *                  *---------------------------------------------*
      *                  * Ripristino del codice Iva memorizzato       *
      *                  *---------------------------------------------*
           if       (w-tes-ass-iva (1)    not  = zero   ) and
                    (w-edt-iva-cod-003    not  > zero)
                     move  zero           to   w-tes-ass-iva (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione codice Iva impostato        *
      *                  *---------------------------------------------*
           perform   vis-ass-iva-000      thru vis-ass-iva-999        .
      *                  *---------------------------------------------*
      *                  * A rilettura tabella e visualizzazione       *
      *                  *---------------------------------------------*
           go to     acc-ass-iva-400.
       acc-ass-iva-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag per scissione pagamenti                *
      *                  *---------------------------------------------*
           if        w-tes-ass-iva-spl (1)
                                          =    "S"
                     move  "S"            to   w-tes-flg-rfp (1)      .
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-ass-iva (1)    =    w-sav-ass-iva
                     go to acc-ass-iva-800.
      *                  *---------------------------------------------*
      *                  * Eventuale ricalcolo codici iva in riga      *
      *                  *---------------------------------------------*
           perform   rcl-civ-doc-000      thru rcl-civ-doc-999        .
      *                  *---------------------------------------------*
      *                  * Eventuale rivisualizzazione Plafond         *
      *                  *---------------------------------------------*
           perform   vis-imp-plf-000      thru vis-imp-plf-999        .
       acc-ass-iva-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-ass-iva-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-ass-iva-100.
       acc-ass-iva-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice di esenzione IVA   *
      *    *-----------------------------------------------------------*
       vis-ass-iva-000.
      *              *-------------------------------------------------*
      *              * Test se documento di accredito                  *
      *              *-------------------------------------------------*
           if        w-ctl-cau-doc-tdo    =    03  and
                     w-tes-tip-mov-dst    =    "*"
                     go to vis-ass-iva-999.
      *              *-------------------------------------------------*
      *              * Test se documento in scissione pagamenti        *
      *              *-------------------------------------------------*
           if        w-tes-ass-iva-spl (1)
                                          =    "S"
                     go to vis-ass-iva-999.
       vis-ass-iva-100.
      *              *-------------------------------------------------*
      *              * Editing preliminare                             *
      *              *-------------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-edt-iva-cod          .
           perform   edt-cod-iva-000      thru edt-cod-iva-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BD"                to   v-edm                  .
           move      10                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-edt-iva-cie        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ass-iva-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione assoggetta-   *
      *    * mento IVA                                                 *
      *    *-----------------------------------------------------------*
       vis-ass-iva-des-000.
           if        w-ctl-cau-doc-tdo    =    03  and
                     w-tes-tip-mov-dst    =    "*"
                     go to vis-ass-iva-des-999.
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-tes-ass-iva-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ass-iva-des-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Plafond (lettera d'intenti)       *
      *    *-----------------------------------------------------------*
       vis-imp-plf-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione preliminare prompt              *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      21                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      59                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-imp-plf-100.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *                                                 *
      *              * ___ MIGLIORABILE ___                            *
      *              * Se codice assoggettamento diverso da codice di  *
      *              * esenzione del cliente                           *
      *              * ___ MIGLIORABILE ___                            *
      *              *-------------------------------------------------*
           if        w-prs-snx-lic        not  = "S"
                     go to vis-imp-plf-999.
           if        w-let-arc-lic-plf    =    zero
                     go to vis-imp-plf-999.
           if        w-tes-dat-doc        < w-let-arc-lic-dri or
                     w-tes-dat-doc        > w-let-arc-lic-drf
                     go to vis-imp-plf-999.
           if       (w-tes-ass-iva (1)    not  = zero   ) and
                    (w-edt-iva-cod-003    not  > zero)
                     go to vis-imp-plf-999.
           if        w-tes-ass-iva (1)    =    zero
                     go to vis-imp-plf-999.
       vis-imp-plf-200.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompt                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      59                   to   v-pos                  .
           move      "Plafond:"           to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione importo                         *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      10                   to   v-lin                  .
           move      68                   to   v-pos                  .
           move      w-let-arc-lic-plf    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-imp-plf-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Si/no imposta di bollo virtuale      *
      *    *-----------------------------------------------------------*
       acc-flg-ibv-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-let-arc-zci-nop    not  = "N2.2 "
                     go to acc-flg-ibv-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-flg-ibv-400.
       acc-flg-ibv-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-flg-ibv-lun    to   v-car                  .
           move      w-exp-flg-ibv-num    to   v-ldt                  .
           move      "SN#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      11                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-flg-ibv-tbl    to   v-txt                  .
      *
           if        w-tes-flg-nbx (1, 3)
                                          =    spaces
                     move  2              to   v-num
           else if   w-tes-flg-nbx (1, 3)
                                          =    "#"
                     move  1              to   v-num
           else      move  2              to   v-num                  .
      *
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-flg-ibv-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-flg-ibv-999.
       acc-flg-ibv-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    1
                     move  "#"            to   w-tes-flg-nbx (1, 3)
           else      move  spaces         to   w-tes-flg-nbx (1, 3)   .
       acc-flg-ibv-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-flg-ibv-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
           perform   vis-flg-ibv-000      thru vis-flg-ibv-999        .
       acc-flg-ibv-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-flg-ibv-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-flg-ibv-100.
       acc-flg-ibv-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Imposta di bollo virtuale         *
      *    *-----------------------------------------------------------*
       vis-flg-ibv-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-let-arc-zci-nop    =    spaces
                     go to vis-flg-ibv-999.
       vis-flg-ibv-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione prompt                          *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Bollo virtuale             :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione flag                            *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-flg-ibv-lun    to   v-car                  .
           move      w-exp-flg-ibv-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      11                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-flg-ibv-tbl    to   v-txt                  .
      *
           if        w-tes-flg-nbx (1, 3)
                                          =    spaces
                     move  2              to   v-num
           else if   w-tes-flg-nbx (1, 3)
                                          =    "#"
                     move  1              to   v-num
           else      move  2              to   v-num                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-flg-ibv-999.
           exit.

      *    *===========================================================*
      *    * Routine di ricalcolo codici iva del documento             *
      *    *-----------------------------------------------------------*
       rcl-civ-doc-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di impossibilita' di va-   *
      *              * riazione di un codice iva                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-rcl-civ-doc-fiv      .
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se corpo ancora da accettare : no           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-cor    =    spaces
                     go to rcl-civ-doc-999.
       rcl-civ-doc-100.
      *              *-------------------------------------------------*
      *              * Box di avviso con conferma                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      07                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      74                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Messaggi nel box                            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "                       A T T E N Z I O N E        
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "La modifica appena apportata potrebbe avere delle 
      -              "ripercussioni "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "sui codici iva del documento gia' determinati.    
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "Si desidera che essi vengano ricalcolati (S/N) ? [
      -              " ]            "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Preparazione default per risposta           *
      *                  *---------------------------------------------*
           move      spaces               to   v-alf                  .
       rcl-civ-doc-120.
      *                  *---------------------------------------------*
      *                  * Accettazione risposta                       *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      59                   to   v-pos                  .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Controllo risposta operatore                *
      *                  *---------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "N"            to   v-alf
           else if   v-key                =    "DO  "
                     move  "S"            to   v-alf                  .
           if        v-alf                not  = "S" and
                     v-alf                not  = "N"
                     go to rcl-civ-doc-120.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione risposta operatore          *
      *                  *---------------------------------------------*
           move      v-alf                to   w-rcl-civ-doc-tro      .
      *                  *---------------------------------------------*
      *                  * Ripristino immagine video                   *
      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       rcl-civ-doc-200.
      *              *-------------------------------------------------*
      *              * Se risposta operatore negativa : a uscita       *
      *              *-------------------------------------------------*
           if        w-rcl-civ-doc-tro    =    "N"
                     go to rcl-civ-doc-900.
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       rcl-civ-doc-300.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to rcl-civ-doc-600.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to rcl-civ-doc-300.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to rcl-civ-doc-300.
      *              *-------------------------------------------------*
      *              * Selezione su tipo riga                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se riga di commento : riciclo               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to rcl-civ-doc-300.
       rcl-civ-doc-400.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo di modifica     *
      *              *-------------------------------------------------*
           move      w-sav-ass-iva        to   w-edt-iva-cod          .
           move      w-edt-iva-cod-003    to   w-edt-iva-wk1          .
      *
           move      w-tes-ass-iva (1)    to   w-edt-iva-cod          .
           move      w-edt-iva-cod-003    to   w-edt-iva-wk2          .
      *
           if       (w-sav-ass-iva        =    zero) and
                    (w-edt-iva-wk2        >    2 and
                     w-edt-iva-wk2        <    8   )
                     go to rcl-civ-doc-420
           else if  (w-edt-iva-wk1        >    2 and
                     w-edt-iva-wk1        <    8   ) and
                    (w-tes-ass-iva (1)    =    zero)
                     go to rcl-civ-doc-440
           else if  (w-edt-iva-wk1        >    2 and
                     w-edt-iva-wk1        <    8   ) and
                    (w-edt-iva-wk2        >    2 and
                     w-edt-iva-wk2        <    8   )
                     go to rcl-civ-doc-460.
       rcl-civ-doc-420.
      *              *-------------------------------------------------*
      *              * Se assoggettamento : da soggetto a esente       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se codice iva gia' esente : a riciclo       *
      *                  *---------------------------------------------*
           move      w-rig-coi-rig (1)    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    >    2 and
                     w-edt-iva-cod-003    <    7
                     go to rcl-civ-doc-580.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione codice iva                  *
      *                  *---------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-rig-coi-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Ad aggiornamento catena e riciclo           *
      *                  *---------------------------------------------*
           go to     rcl-civ-doc-500.
       rcl-civ-doc-440.
      *              *-------------------------------------------------*
      *              * Se assoggettamento : da esente a soggetto       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo riga        *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "P"
                     go to rcl-civ-doc-442
           else if   w-rig-tip-rig-tpr (1)
                                          =    "M"
                     go to rcl-civ-doc-444
           else if   w-rig-tip-rig-tpr (1)
                                          =    "S"
                     go to rcl-civ-doc-446
           else if   w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to rcl-civ-doc-450.
       rcl-civ-doc-442.
      *                  *---------------------------------------------*
      *                  * Tipo riga : Prodotto di vendita             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura archivio [dcp]                  *
      *                      *-----------------------------------------*
           move      w-rig-num-pro (1)    to   w-let-dcp-pdx-cod      .
           move      "C"                  to   w-let-dcp-pdx-tar      .
           if        w-tes-tip-frn (1)    =    11
                     move  w-tes-cod-cli (1)
                                          to   w-let-dcp-pdx-arc
           else      move  w-tes-cli-plf (1)
                                          to   w-let-dcp-pdx-arc      .
           move      w-tes-cod-lng (1)    to   w-let-dcp-pdx-lng      .
           perform   let-dcp-pdx-000      thru let-dcp-pdx-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata o codice iva letto a  *
      *                      * zero : a riciclo con set del flag di    *
      *                      * impossibilita' di determinazione di un  *
      *                      * codice iva                              *
      *                      *-----------------------------------------*
           if        w-let-dcp-pdx-flg    not  = spaces or
                     w-let-dcp-pdx-coi    =    zero
                     move  "#"            to   w-rcl-civ-doc-fiv
                     go to rcl-civ-doc-580.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione codice iva              *
      *                      *-----------------------------------------*
           move      w-let-dcp-pdx-coi    to   w-rig-coi-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Ad aggiornamento catena e riciclo       *
      *                      *-----------------------------------------*
           go to     rcl-civ-doc-500.
       rcl-civ-doc-444.
      *                  *---------------------------------------------*
      *                  * Tipo riga : Materia prima                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Non e' attualmente possibile calcolare  *
      *                      * automaticamente il codice iva per cui   *
      *                      * esso rimane inalterato e si attiva il   *
      *                      * flag                                    *
      *                      *-----------------------------------------*
           move      "#"                  to   w-rcl-civ-doc-fiv      .
      *                      *-----------------------------------------*
      *                      * A riciclo                               *
      *                      *-----------------------------------------*
           go to     rcl-civ-doc-580.
       rcl-civ-doc-446.
      *                  *---------------------------------------------*
      *                  * Tipo riga : Semilavorato                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Non e' attualmente possibile calcolare  *
      *                      * automaticamente il codice iva per cui   *
      *                      * esso rimane inalterato e si attiva il   *
      *                      * flag                                    *
      *                      *-----------------------------------------*
           move      "#"                  to   w-rcl-civ-doc-fiv      .
      *                      *-----------------------------------------*
      *                      * A riciclo                               *
      *                      *-----------------------------------------*
           go to     rcl-civ-doc-580.
       rcl-civ-doc-450.
      *                  *---------------------------------------------*
      *                  * Tipo riga : Addebito                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura archivio [zac]                  *
      *                      *-----------------------------------------*
           move      01                   to   w-let-arc-zac-tip      .
           move      w-rig-tip-rig-cac (1)
                                          to   w-let-arc-zac-cod      .
           perform   let-arc-zac-000      thru let-arc-zac-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata o codice iva letto a  *
      *                      * zero : a riciclo con set del flag di    *
      *                      * impossibilita' di determinazione di un  *
      *                      * codice iva                              *
      *                      *-----------------------------------------*
           if        w-let-arc-zac-flg    not  = spaces or
                     w-let-arc-zac-civ    =    zero
                     move  "#"            to   w-rcl-civ-doc-fiv
                     go to rcl-civ-doc-580.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione codice iva              *
      *                      *-----------------------------------------*
           move      w-let-arc-zac-civ    to   w-rig-coi-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Ad aggiornamento catena e riciclo       *
      *                      *-----------------------------------------*
           go to     rcl-civ-doc-500.
       rcl-civ-doc-460.
      *              *-------------------------------------------------*
      *              * Se assoggettamento : da esente a esente         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se codice iva soggetto : a riciclo          *
      *                  *---------------------------------------------*
           move      w-rig-coi-rig (1)    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    =    zero
                     go to rcl-civ-doc-580.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione codice iva                  *
      *                  *---------------------------------------------*
           move      w-tes-ass-iva (1)    to   w-rig-coi-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Ad aggiornamento catena e riciclo           *
      *                  *---------------------------------------------*
           go to     rcl-civ-doc-500.
       rcl-civ-doc-500.
      *              *-------------------------------------------------*
      *              * Lettura tabella [codiva]                        *
      *              *-------------------------------------------------*
           move      w-rig-coi-rig (1)    to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
           move      w-let-arc-zci-des    to   w-rig-coi-rig-des (1)  .
      *              *-------------------------------------------------*
      *              * Aggiornamento catena movimenti                  *
      *              *-------------------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-cur        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       rcl-civ-doc-580.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura catena                       *
      *              *-------------------------------------------------*
           go to     rcl-civ-doc-300.
       rcl-civ-doc-600.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       rcl-civ-doc-700.
      *              *-------------------------------------------------*
      *              * Codici iva per piede documento                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo di modifica *
      *                  *---------------------------------------------*
           move      w-sav-ass-iva        to   w-edt-iva-cod          .
           move      w-edt-iva-cod-003    to   w-edt-iva-wk1          .
      *
           move      w-tes-ass-iva (1)    to   w-edt-iva-cod          .
           move      w-edt-iva-cod-003    to   w-edt-iva-wk2          .
      *
           if       (w-sav-ass-iva        =    zero) and
                    (w-edt-iva-wk2        >    2 and
                     w-edt-iva-wk2        <    8   )
                     go to rcl-civ-doc-720
           else if  (w-edt-iva-wk1        >    2 and
                     w-edt-iva-wk1        <    8   ) and
                    (w-tes-ass-iva (1)    =    zero)
                     go to rcl-civ-doc-740
           else if  (w-edt-iva-wk1        >    2 and
                     w-edt-iva-wk1        <    8   ) and
                    (w-edt-iva-wk2        >    2 and
                     w-edt-iva-wk2        <    8   )
                     go to rcl-civ-doc-760.
       rcl-civ-doc-720.
      *              *-------------------------------------------------*
      *              * Se assoggettamento : da soggetto a esente       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Nessuna azione : i codici iva verranno ri-  *
      *                  * calcolati dalla routine det-civ-pie-000/999 *
      *                  *---------------------------------------------*
           go to     rcl-civ-doc-800.
       rcl-civ-doc-740.
      *              *-------------------------------------------------*
      *              * Se assoggettamento : da esente a soggetto       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Codice iva sconto in chiusura               *
      *                  *---------------------------------------------*
           move      w-pie-civ-scc (1)    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    >    2 and
                     w-edt-iva-cod-003    <    7
                     move  w-ref-sco-chi-civ
                                          to   w-pie-civ-scc (1)      .
      *                  *---------------------------------------------*
      *                  * Codice iva sconto pagamento                 *
      *                  *---------------------------------------------*
           move      w-pie-civ-scp (1)    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    >    2 and
                     w-edt-iva-cod-003    <    7
                     move  w-ref-sco-pag-civ
                                          to   w-pie-civ-scp (1)      .
      *                  *---------------------------------------------*
      *                  * Codice iva spese in fattura                 *
      *                  *---------------------------------------------*
           move      zero                 to   w-rcl-civ-doc-ctr      .
       rcl-civ-doc-742.
           add       1                    to   w-rcl-civ-doc-ctr      .
           if        w-rcl-civ-doc-ctr    >    w-prs-spe-fat-nst
                     go to rcl-civ-doc-744.
           move      w-prs-spe-fat-npt
                    (w-rcl-civ-doc-ctr)   to   w-rcl-civ-doc-inx      .
      *
           move      w-pie-spe-civ
                    (1, w-rcl-civ-doc-inx)
                                          to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    >    2 and
                     w-edt-iva-cod-003    <    7
                     move  w-prs-spe-fat-civ
                          (w-rcl-civ-doc-ctr)
                                          to   w-pie-spe-civ
                                              (1, w-rcl-civ-doc-inx)  .
           go to     rcl-civ-doc-742.
       rcl-civ-doc-744.
      *                  *---------------------------------------------*
      *                  * Codice iva spese incasso                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da ricalcolare                  *
      *                      *-----------------------------------------*
           if        w-tes-add-spi (1)    =    spaces
                     go to rcl-civ-doc-746.
           move      w-tes-civ-spi (1)    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    =    zero
                     go to rcl-civ-doc-746.
      *                      *-----------------------------------------*
      *                      * Lettura archivio [zin]                  *
      *                      *-----------------------------------------*
           move      w-tes-add-spi (1)    to   w-let-arc-zin-cod      .
           move      00                   to   w-let-arc-zin-tpg      .
           perform   let-arc-zin-000      thru let-arc-zin-999        .
           move      w-let-arc-zin-coi    to   w-tes-civ-spi (1)      .
       rcl-civ-doc-746.
      *                  *---------------------------------------------*
      *                  * Codice iva spese bollo                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da ricalcolare                  *
      *                      *-----------------------------------------*
           if        w-tes-add-spb (1)    =    spaces
                     go to rcl-civ-doc-748.
           move      w-tes-civ-spb (1)    to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    =    zero
                     go to rcl-civ-doc-748.
      *                      *-----------------------------------------*
      *                      * Lettura archivio [zbo]                  *
      *                      *-----------------------------------------*
           move      w-tes-add-spb (1)    to   w-let-arc-zbo-cod      .
           move      00                   to   w-let-arc-zbo-tpg      .
           perform   let-arc-zbo-000      thru let-arc-zbo-999        .
           move      w-let-arc-zbo-coi    to   w-tes-civ-spb (1)      .
       rcl-civ-doc-748.
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     rcl-civ-doc-800.
       rcl-civ-doc-760.
      *              *-------------------------------------------------*
      *              * Se assoggettamento : da esente a esente         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Nessuna azione : i codici iva verranno ri-  *
      *                  * calcolati dalla routine det-civ-pie-000/999 *
      *                  *---------------------------------------------*
           go to     rcl-civ-doc-800.
       rcl-civ-doc-800.
      *              *-------------------------------------------------*
      *              * Test se flag di impossibilita' di variazione di *
      *              * un codice iva attivo                            *
      *              *-------------------------------------------------*
           if        w-rcl-civ-doc-fiv    =    spaces
                     go to rcl-civ-doc-900.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "Attenzione : non e' stato possibile applicare il r
      -              "icalcolo a uno "    to   w-err-box-err-msg      .
           move      "              o piu' codici iva del documento.    
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       rcl-civ-doc-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     rcl-civ-doc-999.
       rcl-civ-doc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Contropartita vendite        *
      *    *-----------------------------------------------------------*
       acc-ctp-ven-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-ctp-ven-999.
      *                  *---------------------------------------------*
      *                  * Se contropartita derivata da tipo movimento *
      *                  * il campo non e' da accettare                *
      *                  *---------------------------------------------*
           if        w-tes-tip-mov-sve    not  = zero
                     go to acc-ctp-ven-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-ctp-ven (1)    to   w-sav-ctp-ven          .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-ctp-ven-400.
       acc-ctp-ven-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-pdc-ope      .
           move      w-prs-liv-pdc        to   w-cod-mne-pdc-liv      .
           move      w-tes-ctp-ven (1)    to   w-cod-mne-pdc-cod      .
           move      12                   to   w-cod-mne-pdc-lin      .
           move      30                   to   w-cod-mne-pdc-pos      .
           move      12                   to   w-cod-mne-pdc-dln      .
           move      41                   to   w-cod-mne-pdc-dps      .
           move      "B"                  to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
       acc-ctp-ven-110.
           perform   cod-mne-pdc-cll-000  thru cod-mne-pdc-cll-999    .
           if        w-cod-mne-pdc-ope    =    "F+"
                     go to acc-ctp-ven-115.
           if        w-cod-mne-pdc-ope    =    "AC"
                     go to acc-ctp-ven-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-ctp-ven-115.
           perform   cod-mne-pdc-foi-000  thru cod-mne-pdc-foi-999    .
           go to     acc-ctp-ven-110.
       acc-ctp-ven-120.
           move      w-cod-mne-pdc-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-ctp-ven-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-ctp-ven-999.
       acc-ctp-ven-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-ctp-ven (1)      .
       acc-ctp-ven-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio piano dei conti            *
      *                  *---------------------------------------------*
           move      w-tes-ctp-ven (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-tes-ctp-ven-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione sottoconto      *
      *                  *---------------------------------------------*
           perform   vis-des-cvt-000      thru vis-des-cvt-999        .
      *                  *---------------------------------------------*
      *                  * Se codice sottoconto non esistente : reim-  *
      *                  * postazione                                  *
      *                  *---------------------------------------------*
           if        w-let-arc-pdc-flg    not  = spaces
                     go to acc-ctp-ven-100.
       acc-ctp-ven-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-tes-ctp-ven (1)    =    w-sav-ctp-ven
                     go to acc-ctp-ven-800.
      *                      *-----------------------------------------*
      *                      * Eventuale ricalcolo contropartite ven-  *
      *                      * dite del documento                      *
      *                      *-----------------------------------------*
           perform   rcl-ctv-doc-000      thru rcl-ctv-doc-999        .
       acc-ctp-ven-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-ctp-ven-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-ctp-ven-100.
       acc-ctp-ven-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Sottoconto contabile      *
      *    *-----------------------------------------------------------*
       vis-ctp-ven-000.
      *              *-------------------------------------------------*
      *              * Editing con appoggio a sinistra                 *
      *              *-------------------------------------------------*
           move      w-prs-liv-pdc        to   w-edt-cod-pdc-liv      .
           move      w-tes-ctp-ven (1)    to   w-edt-cod-pdc-cod      .
           move      "B"                  to   w-edt-cod-pdc-edm      .
           perform   edt-pdc-asx-000      thru edt-pdc-asx-999        .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-edt-cod-pdc-edt    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ctp-ven-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Contropartita vendite in  *
      *    * testata                                                   *
      *    *-----------------------------------------------------------*
       vis-des-cvt-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-tes-ctp-ven-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-cvt-999.
           exit.

      *    *===========================================================*
      *    * Editing del codice sottoconto con appoggio a sx o dx      *
      *    *-----------------------------------------------------------*
           copy      "pgm/cge/prg/cpy/wedtpdc0.wks"                   .

      *    *===========================================================*
      *    * Subroutines per editing del codice iva                    *
      *    *-----------------------------------------------------------*
           copy      "pgm/cge/prg/cpy/wedtzci0.wks"                   .

      *    *===========================================================*
      *    * Routine di ricalcolo contropartite vendite del documento  *
      *    *-----------------------------------------------------------*
       rcl-ctv-doc-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di impossibilita' di va-   *
      *              * riazione di un codice iva                       *
      *              *-------------------------------------------------*
           move      spaces               to   w-rcl-ctv-doc-fic      .
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se corpo ancora da accettare : no           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-cor    =    spaces
                     go to rcl-ctv-doc-999.
       rcl-ctv-doc-100.
      *              *-------------------------------------------------*
      *              * Box di avviso con conferma                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      07                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      74                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Messaggi nel box                            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "                       A T T E N Z I O N E        
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "La modifica appena apportata potrebbe avere delle 
      -              "ripercussioni "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "sulle contropartite alle vendite del documento gia
      -              "' determinate."     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "Si desidera che esse vengano ricalcolate (S/N) ? [
      -              " ]            "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Preparazione default per risposta           *
      *                  *---------------------------------------------*
           move      spaces               to   v-alf                  .
       rcl-ctv-doc-120.
      *                  *---------------------------------------------*
      *                  * Accettazione risposta                       *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      59                   to   v-pos                  .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Controllo risposta operatore                *
      *                  *---------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "N"            to   v-alf
           else if   v-key                =    "DO  "
                     move  "S"            to   v-alf                  .
           if        v-alf                not  = "S" and
                     v-alf                not  = "N"
                     go to rcl-ctv-doc-120.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione risposta operatore          *
      *                  *---------------------------------------------*
           move      v-alf                to   w-rcl-ctv-doc-tro      .
      *                  *---------------------------------------------*
      *                  * Ripristino immagine video                   *
      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       rcl-ctv-doc-200.
      *              *-------------------------------------------------*
      *              * Se risposta operatore negativa : a uscita       *
      *              *-------------------------------------------------*
           if        w-rcl-ctv-doc-tro    =    "N"
                     go to rcl-ctv-doc-900.
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       rcl-ctv-doc-300.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to rcl-ctv-doc-600.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to rcl-ctv-doc-300.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to rcl-ctv-doc-300.
      *              *-------------------------------------------------*
      *              * Selezione su tipo riga                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se riga di commento : riciclo               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to rcl-ctv-doc-300.
       rcl-ctv-doc-400.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo di modifica     *
      *              *-------------------------------------------------*
           if        w-sav-ctp-ven        =    zero   and
                     w-tes-ctp-ven (1)    not  = zero
                     go to rcl-ctv-doc-420
           else if   w-sav-ctp-ven        not  = zero and
                     w-tes-ctp-ven (1)    =    zero
                     go to rcl-ctv-doc-440
           else if   w-sav-ctp-ven        not  = zero and
                     w-tes-ctp-ven (1)    not  = zero
                     go to rcl-ctv-doc-460.
       rcl-ctv-doc-420.
      *              *-------------------------------------------------*
      *              * Se contropartita vendite : da non esistente a   *
      *              * esistente                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Bufferizzazione contropartita vendite       *
      *                  *---------------------------------------------*
           move      w-tes-ctp-ven (1)    to   w-rig-ctv-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Ad aggiornamento catena e riciclo           *
      *                  *---------------------------------------------*
           go to     rcl-ctv-doc-500.
       rcl-ctv-doc-440.
      *              *-------------------------------------------------*
      *              * Se contropartita vendite : da esistente a non   *
      *              * esistente                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo riga        *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "P"
                     go to rcl-ctv-doc-442
           else if   w-rig-tip-rig-tpr (1)
                                          =    "M"
                     go to rcl-ctv-doc-444
           else if   w-rig-tip-rig-tpr (1)
                                          =    "S"
                     go to rcl-ctv-doc-446
           else if   w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to rcl-ctv-doc-450.
       rcl-ctv-doc-442.
      *                  *---------------------------------------------*
      *                  * Tipo riga : Prodotto di vendita             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura archivio [dcp]                  *
      *                      *-----------------------------------------*
           move      w-rig-num-pro (1)    to   w-let-dcp-pdx-cod      .
           move      "C"                  to   w-let-dcp-pdx-tar      .
           if        w-tes-tip-frn (1)    =    11
                     move  w-tes-cod-cli (1)
                                          to   w-let-dcp-pdx-arc
           else      move  w-tes-cli-plf (1)
                                          to   w-let-dcp-pdx-arc      .
           move      w-tes-cod-lng (1)    to   w-let-dcp-pdx-lng      .
           perform   let-dcp-pdx-000      thru let-dcp-pdx-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata o codice controparti- *
      *                      * ta vendite a zero : a riciclo con set   *
      *                      * del flag di impossibilita' di determi-  *
      *                      * nazione di una contropartita            *
      *                      *-----------------------------------------*
           if        w-let-dcp-pdx-flg    not  = spaces or
                     w-let-dcp-pdx-ctp    =    zero
                     move  "#"            to   w-rcl-ctv-doc-fic
                     go to rcl-ctv-doc-580.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione contropartita vendite   *
      *                      *-----------------------------------------*
           move      w-let-dcp-pdx-ctp    to   w-rig-ctv-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Ad aggiornamento catena e riciclo       *
      *                      *-----------------------------------------*
           go to     rcl-ctv-doc-500.
       rcl-ctv-doc-444.
      *                  *---------------------------------------------*
      *                  * Tipo riga : Materia prima                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Non e' attualmente possibile calcolare  *
      *                      * automaticamente il codice contropartita *
      *                      * per cui esso rimane inalterato e si at- *
      *                      * tiva il flag                            *
      *                      *-----------------------------------------*
           move      "#"                  to   w-rcl-ctv-doc-fic      .
      *                      *-----------------------------------------*
      *                      * A riciclo                               *
      *                      *-----------------------------------------*
           go to     rcl-ctv-doc-580.
       rcl-ctv-doc-446.
      *                  *---------------------------------------------*
      *                  * Tipo riga : Semilavorato                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Non e' attualmente possibile calcolare  *
      *                      * automaticamente il codice contropartita *
      *                      * per cui esso rimane inalterato e si at- *
      *                      * tiva il flag                            *
      *                      *-----------------------------------------*
           move      "#"                  to   w-rcl-ctv-doc-fic      .
      *                      *-----------------------------------------*
      *                      * A riciclo                               *
      *                      *-----------------------------------------*
           go to     rcl-ctv-doc-580.
       rcl-ctv-doc-450.
      *                  *---------------------------------------------*
      *                  * Tipo riga : Addebito                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura archivio [zac]                  *
      *                      *-----------------------------------------*
           move      01                   to   w-let-arc-zac-tip      .
           move      w-rig-tip-rig-cac (1)
                                          to   w-let-arc-zac-cod      .
           perform   let-arc-zac-000      thru let-arc-zac-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata o codice iva letto a  *
      *                      * zero : a riciclo con set del flag di    *
      *                      * impossibilita' di determinazione di un  *
      *                      * codice iva                              *
      *                      *-----------------------------------------*
           if        w-let-arc-zac-flg    not  = spaces or
                     w-let-arc-zac-ccp    =    zero
                     move  "#"            to   w-rcl-ctv-doc-fic
                     go to rcl-ctv-doc-580.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione contropartita vendite   *
      *                      *-----------------------------------------*
           move      w-let-arc-zac-ccp    to   w-rig-ctv-rig (1)      .
      *                      *-----------------------------------------*
      *                      * Ad aggiornamento catena e riciclo       *
      *                      *-----------------------------------------*
           go to     rcl-ctv-doc-500.
       rcl-ctv-doc-460.
      *              *-------------------------------------------------*
      *              * Se contropartita vendite : da una ad un'altra   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Bufferizzazione codice iva                  *
      *                  *---------------------------------------------*
           move      w-tes-ctp-ven (1)    to   w-rig-ctv-rig (1)      .
      *                  *---------------------------------------------*
      *                  * Ad aggiornamento catena e riciclo           *
      *                  *---------------------------------------------*
           go to     rcl-ctv-doc-500.
       rcl-ctv-doc-500.
      *              *-------------------------------------------------*
      *              * Lettura archivio [pdc]                          *
      *              *-------------------------------------------------*
           move      w-rig-ctv-rig (1)    to   w-let-arc-pdc-cod      .
           perform   let-arc-pdc-000      thru let-arc-pdc-999        .
           move      w-let-arc-pdc-des    to   w-rig-ctv-rig-des (1)  .
      *              *-------------------------------------------------*
      *              * Aggiornamento catena movimenti                  *
      *              *-------------------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-cur        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       rcl-ctv-doc-580.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura catena                       *
      *              *-------------------------------------------------*
           go to     rcl-ctv-doc-300.
       rcl-ctv-doc-600.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       rcl-ctv-doc-800.
      *              *-------------------------------------------------*
      *              * Test se flag di impossibilita' di variazione di *
      *              * un codice contropartita attivo                  *
      *              *-------------------------------------------------*
           if        w-rcl-ctv-doc-fic    =    spaces
                     go to rcl-ctv-doc-900.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "Attenzione : non e' stato possibile applicare il r
      -              "icalcolo a uno "    to   w-err-box-err-msg      .
           move      "              o piu' codici contropartita vendite 
      -              "del documento. "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       rcl-ctv-doc-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     rcl-ctv-doc-999.
       rcl-ctv-doc-999.
           exit.

      *    *===========================================================*
      *    * Routine di ricalcolo descrizioni prodotti del documento   *
      *    *-----------------------------------------------------------*
       rcl-des-doc-000.
      *              *-------------------------------------------------*
      *              * Test se da eseguire                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se corpo ancora da accettare : no           *
      *                  *---------------------------------------------*
           if        w-cnt-sts-imp-cor    =    spaces
                     go to rcl-des-doc-999.
       rcl-des-doc-100.
      *              *-------------------------------------------------*
      *              * Box di avviso con conferma                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio immagine video                  *
      *                  *---------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      08                   to   v-lin                  .
           move      07                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      74                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Messaggi nel box                            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "                       A T T E N Z I O N E        
      -              "              "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "La modifica appena apportata potrebbe avere delle 
      -              "ripercussioni "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "sulle descrizioni dei prodotti del documento gia' 
      -              "imputate.     "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      64                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      09                   to   v-pos                  .
           move      "Si desidera che esse vengano rideterminate (S/N) ?
      -              " [ ]          "     to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Preparazione default per risposta           *
      *                  *---------------------------------------------*
           move      spaces               to   v-alf                  .
       rcl-des-doc-120.
      *                  *---------------------------------------------*
      *                  * Accettazione risposta                       *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      61                   to   v-pos                  .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Controllo risposta operatore                *
      *                  *---------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "N"            to   v-alf
           else if   v-key                =    "DO  "
                     move  "S"            to   v-alf                  .
           if        v-alf                not  = "S" and
                     v-alf                not  = "N"
                     go to rcl-des-doc-120.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione risposta operatore          *
      *                  *---------------------------------------------*
           move      v-alf                to   w-rcl-des-doc-tro      .
      *                  *---------------------------------------------*
      *                  * Ripristino immagine video                   *
      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       rcl-des-doc-200.
      *              *-------------------------------------------------*
      *              * Se risposta operatore negativa : a uscita       *
      *              *-------------------------------------------------*
           if        w-rcl-des-doc-tro    =    "N"
                     go to rcl-des-doc-900.
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       rcl-des-doc-300.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to rcl-des-doc-600.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to rcl-des-doc-300.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to rcl-des-doc-300.
      *              *-------------------------------------------------*
      *              * Selezione su tipo riga                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se riga di commento : riciclo               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to rcl-des-doc-300.
      *                  *---------------------------------------------*
      *                  * Se riga di addebito : riciclo               *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"
                     go to rcl-des-doc-300.
      *                  *---------------------------------------------*
      *                  * Se prodotto similare : oltre                *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tfu (1)
                                          =    "N"
                     go to rcl-des-doc-300.
       rcl-des-doc-400.
      *              *-------------------------------------------------*
      *              * Aggiornamento descrizione prodotti              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [dcp]                      *
      *                  *---------------------------------------------*
           move      w-rig-num-pro (1)    to   w-let-dcp-pdx-cod      .
           move      "C"                  to   w-let-dcp-pdx-tar      .
           move      w-tes-cod-cli (1)    to   w-let-dcp-pdx-arc      .
           move      w-tes-cod-lng (1)    to   w-let-dcp-pdx-lng      .
           perform   let-dcp-pdx-000      thru let-dcp-pdx-999        .
      *                      *-----------------------------------------*
      *                      * Se lettura errata o descrizione a spa-  *
      *                      * zi : a riciclo con set del flag di      *
      *                      * impossibilita' di determinazione della  *
      *                      * descrizione                             *
      *                      *-----------------------------------------*
           if        w-let-dcp-pdx-flg    not  = spaces or
                     w-let-dcp-pdx-des    =    spaces
                     move  "#"            to   w-rcl-des-doc-fiv
                     go to rcl-des-doc-580.
      *                      *-----------------------------------------*
      *                      * Bufferizzazione descrizione             *
      *                      *-----------------------------------------*
           move      w-let-dcp-pdx-des    to   w-rig-des-por (1)
                                               w-rig-des-rig (1)      .
       rcl-des-doc-500.
      *              *-------------------------------------------------*
      *              * Aggiornamento catena movimenti                  *
      *              *-------------------------------------------------*
           move      "UP"                 to   w-cat-rig-ope          .
           move      w-cat-rig-cur        to   w-cat-rig-num          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       rcl-des-doc-580.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura catena                       *
      *              *-------------------------------------------------*
           go to     rcl-des-doc-300.
       rcl-des-doc-600.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       rcl-des-doc-800.
      *              *-------------------------------------------------*
      *              * Test se flag di impossibilita' di variazione di *
      *              * un codice contropartita attivo                  *
      *              *-------------------------------------------------*
           if        w-rcl-des-doc-fiv    =    spaces
                     go to rcl-des-doc-900.
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           move      "Attenzione : non e' stato possibile applicare la v
      -              "ariazione a una"    to   w-err-box-err-msg      .
           move      "             o piu' descrizioni prodotti.         
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
       rcl-des-doc-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     rcl-des-doc-999.
       rcl-des-doc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Esclusione da statistiche            *
      *    *-----------------------------------------------------------*
       acc-svf-snx-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-svf-snx-400.
       acc-svf-snx-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-svf-snx-lun    to   v-car                  .
           move      w-exp-svf-snx-num    to   v-ldt                  .
           move      "NS#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      13                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-svf-snx-tbl    to   v-txt                  .
      *
           if        w-tes-flg-nbx (1, 1) =    spaces
                     move  1              to   v-num
           else if   w-tes-flg-nbx (1, 1) =    "#"
                     move  2              to   v-num
           else      move  zero           to   v-num                  .
      *
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-svf-snx-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-svf-snx-999.
       acc-svf-snx-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    1
                     move  spaces         to   w-tes-flg-nbx (1, 1)
           else if   v-num                =    2
                     move  "#"            to   w-tes-flg-nbx (1, 1)
           else      move  spaces         to   w-tes-flg-nbx (1, 1)   .
       acc-svf-snx-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-svf-snx-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-svf-snx-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-svf-snx-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-svf-snx-100.
       acc-svf-snx-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Esclusione da statistiche         *
      *    *-----------------------------------------------------------*
       vis-svf-snx-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-svf-snx-lun    to   v-car                  .
           move      w-exp-svf-snx-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      13                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-exp-svf-snx-tbl    to   v-txt                  .
      *
           if        w-tes-flg-nbx (1, 1) =    spaces
                     move  1              to   v-num
           else if   w-tes-flg-nbx (1, 1) =    "#"
                     move  2              to   v-num
           else      move  zero           to   v-num                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-svf-snx-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Si/no ritenuta d'acconto             *
      *    *-----------------------------------------------------------*
       acc-snx-rda-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-snx-rda        not  = "S"
                     go to acc-snx-rda-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-flg-rda (1)    to    w-sav-flg-rda         .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-snx-rda-400.
       acc-snx-rda-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-snx-rda-lun    to   v-car                  .
           move      w-exp-snx-rda-num    to   v-ldt                  .
           move      "NS#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      13                   to   v-lin                  .
           move      76                   to   v-pos                  .
           move      w-exp-snx-rda-tbl    to   v-txt                  .
      *
           if        w-tes-flg-rda (1)    =    spaces
                     move  1              to   v-num
           else if   w-tes-flg-rda (1)    =    "N"
                     move  1              to   v-num
           else if   w-tes-flg-rda (1)    =    "S"
                     move  2              to   v-num
           else      move  zero           to   v-num                  .
      *
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-snx-rda-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-snx-rda-999.
       acc-snx-rda-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           if        v-num                =    1
                     move  "N"            to   w-tes-flg-rda (1)
           else if   v-num                =    2
                     move  "S"            to   w-tes-flg-rda (1)
           else      move  "N"            to   w-tes-flg-rda (1)      .
       acc-snx-rda-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-snx-rda-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se valore variato                      *
      *                  *---------------------------------------------*
           if        w-tes-flg-rda (1)    =    w-sav-flg-rda
                     go to acc-snx-rda-800.
      *                  *---------------------------------------------*
      *                  * Valori e prompt relativi alla ritenuta      *
      *                  *---------------------------------------------*
           if        w-tes-flg-rda (1)    =    "S"
                     go to acc-snx-rda-620.
      *                  *---------------------------------------------*
      *                  * Se No ritenuta                              *
      *                  *---------------------------------------------*
           move      zero                 to   w-tes-per-rda (1)      .
           move      zero                 to   w-tes-pib-rda (1)      .
           perform   pmt-per-rda-000      thru pmt-per-rda-999        .
           perform   pmt-pib-rda-000      thru pmt-pib-rda-999        .
           perform   vis-per-rda-000      thru vis-per-rda-999        .
           perform   vis-pib-rda-000      thru vis-pib-rda-999        .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     acc-snx-rda-800.
       acc-snx-rda-620.
      *                  *---------------------------------------------*
      *                  * Se Si ritenuta                              *
      *                  *---------------------------------------------*
           perform   pmt-per-rda-000      thru pmt-per-rda-999        .
           perform   pmt-pib-rda-000      thru pmt-pib-rda-999        .
           perform   vis-per-rda-000      thru vis-per-rda-999        .
           perform   vis-pib-rda-000      thru vis-pib-rda-999        .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     acc-snx-rda-800.
       acc-snx-rda-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-snx-rda-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-snx-rda-100.
       acc-snx-rda-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Si/no ritenuta d'acconto          *
      *    *-----------------------------------------------------------*
       vis-snx-rda-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-prs-snx-rda        not  = "S"
                     go to vis-snx-rda-999.
       vis-snx-rda-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-snx-rda-lun    to   v-car                  .
           move      w-exp-snx-rda-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      13                   to   v-lin                  .
           move      76                   to   v-pos                  .
           move      w-exp-snx-rda-tbl    to   v-txt                  .
      *
           if        w-tes-flg-rda (1)    =    spaces
                     move  1              to   v-num
           else if   w-tes-flg-rda (1)    =    "N"
                     move  1              to   v-num
           else if   w-tes-flg-rda (1)    =    "S"
                     move  2              to   v-num
           else      move  zero           to   v-num                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-snx-rda-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : % ritenuta d'acconto                 *
      *    *-----------------------------------------------------------*
       acc-per-rda-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-flg-rda (1)    not  = "S"
                     go to acc-per-rda-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-per-rda-400.
       acc-per-rda-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "B"                  to   v-edm                  .
           move      14                   to   v-lin                  .
           move      76                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-per-rda (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-per-rda-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-per-rda-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-per-rda (1)      .
       acc-per-rda-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-per-rda-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-per-rda-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-per-rda-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-per-rda-100.
       acc-per-rda-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : % ritenuta d'acconto              *
      *    *-----------------------------------------------------------*
       vis-per-rda-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "B"                  to   v-edm                  .
           move      14                   to   v-lin                  .
           move      76                   to   v-pos                  .
           move      w-tes-per-rda (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-per-rda-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : % imponibile ritenuta d'acconto      *
      *    *-----------------------------------------------------------*
       acc-pib-rda-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-flg-rda (1)    not  = "S"
                     go to acc-pib-rda-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-pib-rda-400.
       acc-pib-rda-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "B"                  to   v-edm                  .
           move      15                   to   v-lin                  .
           move      76                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-tes-pib-rda (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-pib-rda-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-pib-rda-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-pib-rda (1)      .
       acc-pib-rda-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-pib-rda-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-pib-rda-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-pib-rda-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pib-rda-100.
       acc-pib-rda-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : % imponibile ritenuta d'acconto   *
      *    *-----------------------------------------------------------*
       vis-pib-rda-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "B"                  to   v-edm                  .
           move      15                   to   v-lin                  .
           move      76                   to   v-pos                  .
           move      w-tes-pib-rda (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-pib-rda-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Data riferimento di CGE      *
      *    *-----------------------------------------------------------*
       acc-dri-mgd-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-dri-mgd-999.
           if        w-tes-tip-mov-tdo    not  = 03
                     go to acc-dri-mgd-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-dri-mgd-400.
       acc-dri-mgd-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      15                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-dri-mgd (1)    to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-dri-mgd-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-dri-mgd-999.
       acc-dri-mgd-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-dat                to   w-tes-dri-mgd (1)      .
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-dri-mgd-400.
      *                  *---------------------------------------------*
      *                  * Find su riferimenti cliente                 *
      *                  *---------------------------------------------*
           move      w-tes-cli-plf (1)    to   w-fnd-rif-cli-cod      .
           perform   fnd-rif-cli-000      thru fnd-rif-cli-999        .
      *                  *---------------------------------------------*
      *                  * Se nessuna selezione : reimpostazione       *
      *                  *---------------------------------------------*
           if        w-fnd-rif-cli-sel    not  = spaces
                     go to acc-dri-mgd-100.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione riferimenti selezionati     *
      *                  *---------------------------------------------*
           move      w-fnd-rif-cli-dat    to   w-tes-dri-mgd (1)      .
           move      w-fnd-rif-cli-num    to   w-tes-nri-mgd (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione riferimenti selezionati     *
      *                  *---------------------------------------------*
           perform   vis-dri-mgd-000      thru vis-dri-mgd-999        .
           perform   vis-nri-mgd-000      thru vis-nri-mgd-999        .
      *                  *---------------------------------------------*
      *                  * Continuazione                               *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
           go to     acc-dri-mgd-400.
       acc-dri-mgd-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-dri-mgd-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se data riferimento a zero si forza spaces  *
      *                  * il numero riferimento                       *
      *                  *---------------------------------------------*
           if        w-tes-dri-mgd (1)    not  = zero
                     go to acc-dri-mgd-800.
           if        w-tes-nri-mgd (1)    =    spaces
                     go to acc-dri-mgd-800.
           move      spaces               to   w-tes-nri-mgd (1)      .
           perform   vis-nri-mgd-000      thru vis-nri-mgd-999        .
       acc-dri-mgd-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-dri-mgd-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-dri-mgd-100.
       acc-dri-mgd-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Data riferimento di CGE   *
      *    *-----------------------------------------------------------*
       vis-dri-mgd-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-tip-mov-tdo    not  = 03
                     go to vis-dri-mgd-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      spaces               to   v-edm                  .
           move      15                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-dri-mgd (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dri-mgd-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Numero riferimento di CGE    *
      *    *-----------------------------------------------------------*
       acc-nri-mgd-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-nri-mgd-999.
           if        w-tes-tip-mov-tdo    not  = 03
                     go to acc-nri-mgd-999.
           if        w-tes-dri-mgd (1)    =    zero
                     go to acc-nri-mgd-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-nri-mgd-400.
       acc-nri-mgd-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      16                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-nri-mgd (1)    to   v-alf                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-nri-mgd-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-nri-mgd-999.
       acc-nri-mgd-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-nri-mgd (1)      .
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-nri-mgd-400.
      *                  *---------------------------------------------*
      *                  * Find su riferimenti cliente                 *
      *                  *---------------------------------------------*
           move      w-tes-cli-plf (1)    to   w-fnd-rif-cli-cod      .
           perform   fnd-rif-cli-000      thru fnd-rif-cli-999        .
      *                  *---------------------------------------------*
      *                  * Se nessuna selezione : reimpostazione       *
      *                  *---------------------------------------------*
           if        w-fnd-rif-cli-sel    not  = spaces
                     go to acc-nri-mgd-100.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione riferimenti selezionati     *
      *                  *---------------------------------------------*
           move      w-fnd-rif-cli-dat    to   w-tes-dri-mgd (1)      .
           move      w-fnd-rif-cli-num    to   w-tes-nri-mgd (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione riferimenti selezionati     *
      *                  *---------------------------------------------*
           perform   vis-nri-mgd-000      thru vis-nri-mgd-999        .
           perform   vis-nri-mgd-000      thru vis-nri-mgd-999        .
      *                  *---------------------------------------------*
      *                  * Continuazione                               *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
           go to     acc-nri-mgd-400.
       acc-nri-mgd-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore a spaces non ammesso, a meno che non *
      *                  * si sia in Up                                *
      *                  *---------------------------------------------*
           if        w-tes-nri-mgd (1)    not  = spaces
                     go to acc-nri-mgd-600.
           if        v-key                =    "UP  "
                     go to acc-nri-mgd-600
           else      go to acc-nri-mgd-100.
       acc-nri-mgd-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-nri-mgd-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-nri-mgd-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-nri-mgd-100.
       acc-nri-mgd-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Data riferimento di CGE   *
      *    *-----------------------------------------------------------*
       vis-nri-mgd-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-tes-tip-mov-tdo    not  = 03
                     go to vis-nri-mgd-999.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      10                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-nri-mgd (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-nri-mgd-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Voce descrittiva ennesima in *
      *    *                              funzione di w-acc-voc-des-ctr*
      *    *-----------------------------------------------------------*
       acc-voc-des-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-voc-des-999.
           if        w-prs-vde-fat-nvt    =    zero
                     go to acc-voc-des-999.
           if        w-tes-tip-mov-tdo    =    03
                     go to acc-voc-des-999.
      *                  *---------------------------------------------*
      *                  * Preparazione indice per la voce             *
      *                  *---------------------------------------------*
           move      w-prs-vde-fat-npt
                    (w-acc-voc-des-ctr)   to   w-acc-voc-des-inx      .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-voc-des-400.
       acc-voc-des-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-zvf-ope      .
           move      w-acc-voc-des-inx    to   w-cod-cod-zvf-voc      .
           move      "I  "                to   w-cod-cod-zvf-lng      .
           move      w-tes-voc-des
                    (1, w-acc-voc-des-inx)
                                          to   w-cod-cod-zvf-cod      .
           add       14
                     w-acc-voc-des-ctr  giving w-cod-cod-zvf-lin      .
           move      30                   to   w-cod-cod-zvf-pos      .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-zvf-cll-000  thru cod-cod-zvf-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-zvf-foi-000  thru cod-cod-zvf-foi-999    .
       acc-voc-des-110.
           perform   cod-cod-zvf-cll-000  thru cod-cod-zvf-cll-999    .
           if        w-cod-cod-zvf-ope    =    "F+"
                     go to acc-voc-des-115.
           if        w-cod-cod-zvf-ope    =    "AC"
                     go to acc-voc-des-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-voc-des-115.
           perform   cod-cod-zvf-foi-000  thru cod-cod-zvf-foi-999    .
           go to     acc-voc-des-110.
       acc-voc-des-120.
           move      w-cod-cod-zvf-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-voc-des-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-voc-des-999.
       acc-voc-des-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-voc-des
                                              (1, w-acc-voc-des-inx)  .
       acc-voc-des-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [zvf]                      *
      *                  *---------------------------------------------*
           move      w-acc-voc-des-inx    to   w-let-arc-zvf-num      .
           move      w-tes-voc-des
                    (1, w-acc-voc-des-inx)
                                          to   w-let-arc-zvf-cod      .
           perform   let-arc-zvf-000      thru let-arc-zvf-999        .
           move      w-let-arc-zvf-des    to   w-tes-voc-des-des
                                              (1, w-acc-voc-des-inx)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           move      w-acc-voc-des-ctr    to   w-vis-voc-des-ctr      .
           perform   vis-des-vde-000      thru vis-des-vde-999        .
      *                  *---------------------------------------------*
      *                  * Se record non esistente : reimpostazione    *
      *                  *---------------------------------------------*
           if        w-let-arc-zvf-flg    not  = spaces
                     go to acc-voc-des-100.
       acc-voc-des-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-voc-des-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-voc-des-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-voc-des-100.
       acc-voc-des-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Voce descrittiva ennesima *
      *    * in funzione di w-vis-voc-des-ctr                          *
      *    *-----------------------------------------------------------*
       vis-voc-des-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-tes-tip-mov-tdo    =    03
                     go to vis-voc-des-999.
      *              *-------------------------------------------------*
      *              * Preparazione indice per la voce                 *
      *              *-------------------------------------------------*
           move      w-prs-vde-fat-npt
                    (w-vis-voc-des-ctr)   to   w-vis-voc-des-inx      .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           add       14
                     w-vis-voc-des-ctr  giving v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-voc-des
                    (1, w-vis-voc-des-inx)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-voc-des-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione voce descrit- *
      *    * tiva ennesima in funzione di w-vis-voc-des-ctr            *
      *    *-----------------------------------------------------------*
       vis-des-vde-000.
      *              *-------------------------------------------------*
      *              * Test se da visualizzare                         *
      *              *-------------------------------------------------*
           if        w-tes-tip-mov-tdo    =    03
                     go to vis-des-vde-999.
      *              *-------------------------------------------------*
      *              * Preparazione indice per la voce                 *
      *              *-------------------------------------------------*
           move      w-prs-vde-fat-npt
                    (w-vis-voc-des-ctr)   to   w-vis-voc-des-inx      .
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      24                   to   v-car                  .
           add       14
                     w-vis-voc-des-ctr  giving v-lin                  .
           move      35                   to   v-pos                  .
           move      w-tes-voc-des-des
                    (1, w-vis-voc-des-inx)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-vde-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Codice listino               *
      *    *-----------------------------------------------------------*
       acc-cod-lst-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-cod-lst-999.
           if        w-tes-fda-vpf (1)    not  = spaces
                     go to acc-cod-lst-999.
      *                  *---------------------------------------------*
      *                  * Se Tab in corso : a controllo valore impo-  *
      *                  * stato                                       *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-lst-400.
       acc-cod-lst-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-lst-ope      .
           move      w-tes-cod-lst (1)    to   w-cod-cod-lst-cod      .
           move      05                   to   w-cod-cod-lst-lin      .
           move      30                   to   w-cod-cod-lst-pos      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-zls-cll-000  thru cod-cod-zls-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-zls-foi-000  thru cod-cod-zls-foi-999    .
       acc-cod-lst-110.
           perform   cod-cod-zls-cll-000  thru cod-cod-zls-cll-999    .
           if        w-cod-cod-lst-ope    =    "F+"
                     go to acc-cod-lst-115.
           if        w-cod-cod-lst-ope    =    "AC"
                     go to acc-cod-lst-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-lst-115.
           perform   cod-cod-zls-foi-000  thru cod-cod-zls-foi-999    .
           go to     acc-cod-lst-110.
       acc-cod-lst-120.
           move      w-cod-cod-lst-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-lst-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-lst-999.
       acc-cod-lst-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-cod-lst (1)      .
       acc-cod-lst-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [zls]                      *
      *                  *---------------------------------------------*
           move      w-tes-cod-lst (1)    to   w-let-arc-zls-cod      .
           perform   let-arc-zls-000      thru let-arc-zls-999        .
           move      w-let-arc-zls-des    to   w-tes-cod-lst-des (1)  .
           move      w-let-arc-zls-drg    to   w-tes-cod-lst-drg (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-lst-000      thru vis-des-lst-999        .
           perform   vis-drg-lst-000      thru vis-drg-lst-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-zls-flg    not  = spaces
                     go to acc-cod-lst-100.
       acc-cod-lst-430.
      *                  *---------------------------------------------*
      *                  * Se listino di lavoro : messaggio e reimpo-  *
      *                  * stazione                                    *
      *                  *---------------------------------------------*
           if        w-let-arc-zls-wrk    =    spaces
                     go to acc-cod-lst-440.
           move      "Codice Listino corrispondente ad un Listino di lav
      -              "oro !          "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
           go to     acc-cod-lst-100.
       acc-cod-lst-440.
      *                  *---------------------------------------------*
      *                  * Controllo valuta del listino con quella del *
      *                  * documento                                   *
      *                  *---------------------------------------------*
           if        w-tes-cod-lst (1)    =    spaces
                     go to acc-cod-lst-600.
           if        w-let-arc-zls-vlt    =    w-tes-sgl-vpf (1)
                     go to acc-cod-lst-600.
      *                      *-----------------------------------------*
      *                      * Se incompatibile : messaggio di errore  *
      *                      *-----------------------------------------*
           move      "Listino incompatibile in termini di sigla valuta !
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Reimpostazione                          *
      *                      *-----------------------------------------*
           go to     acc-cod-lst-100.
       acc-cod-lst-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-lst-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-lst-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-lst-100.
       acc-cod-lst-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Codice listino            *
      *    *-----------------------------------------------------------*
       vis-cod-lst-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-lst (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-lst-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione listino       *
      *    *-----------------------------------------------------------*
       vis-des-lst-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-tes-cod-lst-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-lst-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Direttive generali listino        *
      *    *-----------------------------------------------------------*
       vis-drg-lst-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      61                   to   v-pos                  .
           if        w-tes-cod-lst-drg (1)
                                          =    "K"
                     move  "(Prezzi per 1000)   "
                                          to   v-alf
           else      move  spaces         to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-drg-lst-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo chiave : Codice lingua                 *
      *    *-----------------------------------------------------------*
       acc-cod-lng-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-tes-cod-lng (1)    to    w-sav-cod-lng         .
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-cod-lng-400.
       acc-cod-lng-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-cod-zln-ope      .
           move      w-tes-cod-lng (1)    to   w-cod-cod-zln-cod      .
           move      06                   to   w-cod-cod-zln-lin      .
           move      30                   to   w-cod-cod-zln-pos      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-cod-zln-cll-000  thru cod-cod-zln-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-cod-zln-foi-000  thru cod-cod-zln-foi-999    .
       acc-cod-lng-110.
           perform   cod-cod-zln-cll-000  thru cod-cod-zln-cll-999    .
           if        w-cod-cod-zln-ope    =    "F+"
                     go to acc-cod-lng-115.
           if        w-cod-cod-zln-ope    =    "AC"
                     go to acc-cod-lng-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-lng-115.
           perform   cod-cod-zln-foi-000  thru cod-cod-zln-foi-999    .
           go to     acc-cod-lng-110.
       acc-cod-lng-120.
           move      w-cod-cod-zln-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-lng-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-lng-999.
       acc-cod-lng-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-cod-lng (1)      .
       acc-cod-lng-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura file [zln]                          *
      *                  *---------------------------------------------*
           move      w-tes-cod-lng (1)    to   w-let-arc-zln-cod      .
           perform   let-arc-zln-000      thru let-arc-zln-999        .
           move      w-let-arc-zln-des    to   w-tes-cod-lng-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-lng-000      thru vis-des-lng-999        .
      *                  *---------------------------------------------*
      *                  * Test sul flag                               *
      *                  *---------------------------------------------*
           if        w-let-arc-zln-flg    not  = spaces
                     go to acc-cod-lng-100.
      *                  *---------------------------------------------*
      *                  * Se valore a spaces : reimpostazione         *
      *                  *---------------------------------------------*
           if        w-tes-cod-lng (1)    not  = spaces
                     go to acc-cod-lng-600.
           go to     acc-cod-lng-100.
       acc-cod-lng-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se valore variato                      *
      *                  *---------------------------------------------*
           if        w-tes-cod-lng (1)    =    w-sav-cod-lng
                     go to acc-cod-lng-800.
      *                  *---------------------------------------------*
      *                  * Ricalcolo descrizione prodotti del documen- *
      *                  * to                                          *
      *                  *---------------------------------------------*
           perform   rcl-des-doc-000      thru rcl-des-doc-999        .
       acc-cod-lng-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-cod-lng-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-lng-100.
       acc-cod-lng-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo chiave : Codice lingua              *
      *    *-----------------------------------------------------------*
       vis-cod-lng-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-cod-lng (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-lng-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Descrizione lingua        *
      *    *-----------------------------------------------------------*
       vis-des-lng-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-tes-cod-lng-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-lng-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo testata : Categoria sconto in riga     *
      *    *-----------------------------------------------------------*
       acc-csr-aac-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to acc-csr-aac-999.
      *                  *---------------------------------------------*
      *                  * Se Nxsc da campi della pagina precedenti o  *
      *                  * Tab in corso : a controllo valore impostato *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-csr-aac-400.
       acc-csr-aac-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cmn-zcs-002-ope      .
           move      w-tes-csr-aac (1)    to   w-cmn-zcs-002-cod      .
           move      08                   to   w-cmn-zcs-002-lin      .
           move      30                   to   w-cmn-zcs-002-pos      .
           move      08                   to   w-cmn-zcs-002-dln      .
           move      37                   to   w-cmn-zcs-002-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cmn-zcs-002-cll-000  thru cmn-zcs-002-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cmn-zcs-002-foi-000  thru cmn-zcs-002-foi-999    .
       acc-csr-aac-110.
           perform   cmn-zcs-002-cll-000  thru cmn-zcs-002-cll-999    .
           if        w-cmn-zcs-002-ope    =    "F+"
                     go to acc-csr-aac-115.
           if        w-cmn-zcs-002-ope    =    "AC"
                     go to acc-csr-aac-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-csr-aac-115.
           perform   cmn-zcs-002-foi-000  thru cmn-zcs-002-foi-999    .
           go to     acc-csr-aac-110.
       acc-csr-aac-120.
           move      w-cmn-zcs-002-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-csr-aac-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-csr-aac-999.
       acc-csr-aac-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-csr-aac (1)      .
       acc-csr-aac-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      02                   to   w-let-arc-zcs-tip      .
           move      w-tes-csr-aac (1)    to   w-let-arc-zcs-cod      .
           perform   let-arc-zcs-000      thru let-arc-zcs-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione descrizione                  *
      *                  *---------------------------------------------*
           move      w-let-arc-zcs-des    to   w-tes-csr-aac-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-csr-000      thru vis-des-csr-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-zcs-flg    not  = spaces
                     go to acc-csr-aac-100.
       acc-csr-aac-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Memorizzazione % di sconto associate        *
      *                  *---------------------------------------------*
           move      w-let-arc-zcs-per (1)
                                          to   w-tes-psr-acc (1, 1)   .
           move      w-let-arc-zcs-per (2)
                                          to   w-tes-psr-acc (1, 2)   .
           move      w-let-arc-zcs-per (3)
                                          to   w-tes-psr-acc (1, 3)   .
           move      w-let-arc-zcs-per (4)
                                          to   w-tes-psr-acc (1, 4)   .
           move      w-let-arc-zcs-per (5)
                                          to   w-tes-psr-acc (1, 5)   .
       acc-csr-aac-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-csr-aac-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-csr-aac-100.
       acc-csr-aac-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo testata : Categoria sconto in riga  *
      *    *-----------------------------------------------------------*
       vis-csr-aac-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      08                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-tes-csr-aac (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-csr-aac-999.
           exit.

