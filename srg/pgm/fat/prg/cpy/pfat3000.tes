      *              *-------------------------------------------------*
           move      "AC"                 to   w-cmn-zpv-003-ope      .
           move      w-tes-cpv-aac (1)    to   w-cmn-zpv-003-cod      .
           move      10                   to   w-cmn-zpv-003-lin      .
           move      10                   to   w-cmn-zpv-003-dln      .
           move      30                   to   w-cmn-zpv-003-pos      .
           move      41                   to   w-cmn-zpv-003-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           move      "PRSC"               to   v-pfk (07)             .
           move      "NXSC"               to   v-pfk (08)             .
           perform   cmn-zpv-003-cll-000  thru cmn-zpv-003-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cmn-zpv-003-foi-000  thru cmn-zpv-003-foi-999    .
       acc-cpv-aac-110.
           perform   cmn-zpv-003-cll-000  thru cmn-zpv-003-cll-999    .
