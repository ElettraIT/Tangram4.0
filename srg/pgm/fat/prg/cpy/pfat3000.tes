      *    *===========================================================*
      *    * Determinazione numero pagine che compongono la testata    *
      *    *-----------------------------------------------------------*
       dmp-tes-reg-000.
      *              *-------------------------------------------------*
      *              * La testata e' composta di nr. 5 pagine          *
      *              *-------------------------------------------------*
           move      5                    to   w-cnt-sts-imp-mpt      .
       dmp-tes-reg-999.
           exit.

      *    *===========================================================*
      *    * Determinazione si/no pagina w-cnt-sts-imp-npt da trattare *
      *    *-----------------------------------------------------------*
       snp-tes-reg-000.
      *              *-------------------------------------------------*
      *              * Flag di uscita a Si                             *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-sts-imp-snp      .
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del numero pagina        *
      *              *-------------------------------------------------*
           go to     snp-tes-reg-100
                     snp-tes-reg-200
                     snp-tes-reg-300
                     snp-tes-reg-400
                     snp-tes-reg-500
                     depending            on   w-cnt-sts-imp-npt      .
           go to     snp-tes-reg-999.
       snp-tes-reg-100.
      *              *-------------------------------------------------*
      *              * Pagina numero 1                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Sempre gestita                              *
      *                  *---------------------------------------------*
           go to     snp-tes-reg-999.
       snp-tes-reg-200.
      *              *-------------------------------------------------*
      *              * Pagina numero 2                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se personalizzazione lo prevede        *
      *                  *---------------------------------------------*
           if        w-prs-ges-apf        not  = 11 and
                     w-prs-ges-apf        not  = 21 and
                     w-prs-ges-apf        not  = 99
                     move  "#"            to   w-cnt-sts-imp-snp
                     go to snp-tes-reg-999.
      *                  *---------------------------------------------*
      *                  * Test su tipo fornitura                      *
      *                  *---------------------------------------------*
           if        w-tes-tip-frn (1)    =    01
                     move  "#"            to   w-cnt-sts-imp-snp
                     go to snp-tes-reg-999.
           go to     snp-tes-reg-999.
       snp-tes-reg-300.
      *              *-------------------------------------------------*
      *              * Pagina numero 3                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Sempre gestita                              *
      *                  *---------------------------------------------*
           go to     snp-tes-reg-999.
       snp-tes-reg-400.
      *              *-------------------------------------------------*
      *              * Pagina numero 4                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Sempre gestita                              *
      *                  *---------------------------------------------*
           go to     snp-tes-reg-999.
       snp-tes-reg-500.
      *              *-------------------------------------------------*
      *              * Pagina numero 5                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Sempre gestita                              *
      *                  *---------------------------------------------*
           go to     snp-tes-reg-999.
       snp-tes-reg-999.
           exit.

      *    *===========================================================*
      *    * Accettazione testata registrazione                        *
      *    *-----------------------------------------------------------*
       acc-tes-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione tipo uscita                     *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-tus-acc-tes      .
      *              *-------------------------------------------------*
      *              * Normalizzazione function-key                    *
      *              *-------------------------------------------------*
           move      spaces               to   v-key                  .
      *              *-------------------------------------------------*
      *              * Tipo impostazione : testata                     *
      *              *-------------------------------------------------*
           move      "T"                  to   w-cnt-mfu-tip-imp      .
      *              *-------------------------------------------------*
      *              * Accettazioni                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del numero pagina    *
      *                  *---------------------------------------------*
           go to     acc-tes-reg-100
                     acc-tes-reg-200
                     acc-tes-reg-300
                     acc-tes-reg-400
                     acc-tes-reg-500
                     depending            on   w-cnt-sts-imp-npt      .
           go to     acc-tes-reg-999.
       acc-tes-reg-100.
      *                  *---------------------------------------------*
      *                  * Test se modificabile                        *
      *                  *---------------------------------------------*
           if        w-tes-fda-pt1 (1)    not  = spaces
                     go to acc-tes-reg-110.
       acc-tes-reg-105.
      *                  *---------------------------------------------*
      *                  * Normalizzazione func-key di impostazione    *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Codice cliente                              *
      *                  *---------------------------------------------*
           perform   acc-cod-cli-000      thru acc-cod-cli-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
       acc-tes-reg-110.
      *                  *---------------------------------------------*
      *                  * Codice dipendenza cliente                   *
      *                  *---------------------------------------------*
           perform   acc-dpz-cli-000      thru acc-dpz-cli-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-105.
      *                  *---------------------------------------------*
      *                  * Ad accettazione Tipo fornitura              *
      *                  *---------------------------------------------*
           go to     acc-tes-reg-120.
       acc-tes-reg-115.
      *                  *---------------------------------------------*
      *                  * Tipo documento 'sdi'                        *
      *                  *---------------------------------------------*
           perform   acc-tdo-fel-000      thru acc-tdo-fel-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-110.
       acc-tes-reg-120.
      *                  *---------------------------------------------*
      *                  * Tipo fornitura                              *
      *                  *---------------------------------------------*
           perform   acc-tip-frn-000      thru acc-tip-frn-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-115.
       acc-tes-reg-130.
      *                  *---------------------------------------------*
      *                  * Si/no fattura da verificare                 *
      *                  *---------------------------------------------*
           perform   acc-snx-fav-000      thru acc-snx-fav-999        .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-120.
      *                  *---------------------------------------------*
      *                  * Se Next Screen o Tab in corso               *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-tes-reg-190.
      *                  *---------------------------------------------*
      *                  * Presa visione per pagina 1                  *
      *                  *---------------------------------------------*
           perform   acc-pre-vpg-000      thru acc-pre-vpg-999        .
           if        v-key                =    "NXSC"
                     go to acc-tes-reg-190
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-130.
       acc-tes-reg-190.
      *                  *---------------------------------------------*
      *                  * Flag di accettazione pagina testata 1       *
      *                  *---------------------------------------------*
           move      "#"                  to   w-tes-fda-pt1 (1)      .
      *                  *---------------------------------------------*
      *                  * Trattamento archivio per fatturazione       *
      *                  *---------------------------------------------*
           perform   trt-arc-plf-000      thru trt-arc-plf-999        .
      *                  *---------------------------------------------*
      *                  * Fine Pagina                                 *
      *                  *---------------------------------------------*
           move      "+"                  to   w-cnt-tus-acc-tes      .
           go to     acc-tes-reg-999.
       acc-tes-reg-200.
      *                  *---------------------------------------------*
      *                  * Codice cliente per fatturazione             *
      *                  *---------------------------------------------*
           perform   acc-cli-plf-000      thru acc-cli-plf-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     move  "-"            to   w-cnt-tus-acc-tes
                     go to acc-tes-reg-999.
       acc-tes-reg-210.
      *                  *---------------------------------------------*
      *                  * Dipendenza cliente per fatturazione         *
      *                  *---------------------------------------------*
           perform   acc-dpc-plf-000      thru acc-dpc-plf-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-200.
      *                  *---------------------------------------------*
      *                  * Se Next Screen o Tab in corso               *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     go to acc-tes-reg-290.
      *                  *---------------------------------------------*
      *                  * Presa visione per pagina 2                  *
      *                  *---------------------------------------------*
           perform   acc-pre-vpg-000      thru acc-pre-vpg-999        .
           if        v-key                =    "NXSC"
                     go to acc-tes-reg-290
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-210.
       acc-tes-reg-290.
      *                  *---------------------------------------------*
      *                  * Flag di accettazione pagina testata 2       *
      *                  *---------------------------------------------*
           move      "#"                  to   w-tes-fda-pt2 (1)      .
      *                  *---------------------------------------------*
      *                  * Fine Pagina                                 *
      *                  *---------------------------------------------*
           move      "+"                  to   w-cnt-tus-acc-tes      .
           go to     acc-tes-reg-999.
       acc-tes-reg-300.
      *                  *---------------------------------------------*
      *                  * Inoltro documenti                           *
      *                  *---------------------------------------------*
           perform   acc-inl-dcm-000      thru acc-inl-dcm-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     move  "-"            to   w-cnt-tus-acc-tes
                     go to acc-tes-reg-999.
       acc-tes-reg-310.
      *                  *---------------------------------------------*
      *                  * Inoltro pagamenti                           *
      *                  *---------------------------------------------*
           perform   acc-inl-pgt-000      thru acc-inl-pgt-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-300.
       acc-tes-reg-315.
      *                  *---------------------------------------------*
      *                  * Sigla valuta per fatturazione               *
      *                  *---------------------------------------------*
           perform   acc-sgl-vpf-000      thru acc-sgl-vpf-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-310.
       acc-tes-reg-320.
      *                  *---------------------------------------------*
      *                  * Assoggettamento iva                         *
      *                  *---------------------------------------------*
           perform   acc-ass-iva-000      thru acc-ass-iva-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-315.
       acc-tes-reg-325.
      *                  *---------------------------------------------*
      *                  * Imposta di bollo virtuale                   *
      *                  *---------------------------------------------*
           perform   acc-flg-ibv-000      thru acc-flg-ibv-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-320.
       acc-tes-reg-330.
      *                  *---------------------------------------------*
      *                  * Contropartita vendite                       *
      *                  *---------------------------------------------*
           perform   acc-ctp-ven-000      thru acc-ctp-ven-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-320.
       acc-tes-reg-335.
      *                  *---------------------------------------------*
      *                  * Esclusione da statistiche                   *
      *                  *---------------------------------------------*
           perform   acc-svf-snx-000      thru acc-svf-snx-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-330.
       acc-tes-reg-340.
      *                  *---------------------------------------------*
      *                  * Si/no ritenuta d'acconto                    *
      *                  *---------------------------------------------*
           perform   acc-snx-rda-000      thru acc-snx-rda-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-335.
       acc-tes-reg-342.
      *                  *---------------------------------------------*
      *                  * % ritenuta d'acconto                        *
      *                  *---------------------------------------------*
           perform   acc-per-rda-000      thru acc-per-rda-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-340.
       acc-tes-reg-343.
      *                  *---------------------------------------------*
      *                  * % imponibile ritenuta d'acconto             *
      *                  *---------------------------------------------*
           perform   acc-pib-rda-000      thru acc-pib-rda-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-342.
       acc-tes-reg-345.
      *                  *---------------------------------------------*
      *                  * Data riferimento per CGE                    *
      *                  *---------------------------------------------*
           perform   acc-dri-mgd-000      thru acc-dri-mgd-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-343.
       acc-tes-reg-350.
      *                  *---------------------------------------------*
      *                  * Numero riferimento per CGE                  *
      *                  *---------------------------------------------*
           perform   acc-nri-mgd-000      thru acc-nri-mgd-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-345.
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore per tabella vo-  *
      *                  * ci descrittive                              *
      *                  *---------------------------------------------*
           move      1                    to   w-acc-voc-des-ctr      .
           move      "D"                  to   w-acc-voc-des-dir      .
       acc-tes-reg-360.
      *                  *---------------------------------------------*
      *                  * Voci descrittive                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Accettazione                            *
      *                      *-----------------------------------------*
           perform   acc-voc-des-000      thru acc-voc-des-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
      *                      *-----------------------------------------*
      *                      * Test se Up                              *
      *                      *-----------------------------------------*
           if        v-key                not  = "UP  "
                     go to acc-tes-reg-364.
       acc-tes-reg-362.
      *                      *-----------------------------------------*
      *                      * Se Up                                   *
      *                      *-----------------------------------------*
           move      "U"                  to   w-acc-voc-des-dir      .
           subtract  1                    from w-acc-voc-des-ctr      .
           if        w-acc-voc-des-ctr    =    zero
                     go to acc-tes-reg-335
           else      go to acc-tes-reg-360.
       acc-tes-reg-364.
      *                      *-----------------------------------------*
      *                      * Se Down o Return                        *
      *                      *-----------------------------------------*
           move      "D"                  to   w-acc-voc-des-dir      .
           add       1                    to   w-acc-voc-des-ctr      .
           if        w-acc-voc-des-ctr    >    w-prs-vde-fat-nvt
                     go to acc-tes-reg-368
           else      go to acc-tes-reg-360.
       acc-tes-reg-368.
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore per tabella vo-  *
      *                  * ci descrittive                              *
      *                  *---------------------------------------------*
           move      w-prs-vde-fat-nvt    to   w-acc-voc-des-ctr      .
           move      "U"                  to   w-acc-voc-des-dir      .
       acc-tes-reg-370.
      *                  *---------------------------------------------*
      *                  * Se Next Screen o Tab in corso               *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     move  "+"            to   w-cnt-tus-acc-tes
                     go to acc-tes-reg-999.
      *                  *---------------------------------------------*
      *                  * Presa visione per pagina 3                  *
      *                  *---------------------------------------------*
           perform   acc-pre-vpg-000      thru acc-pre-vpg-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-tes      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-360.
      *                  *---------------------------------------------*
      *                  * Fine Pagina                                 *
      *                  *---------------------------------------------*
           move      "+"                  to   w-cnt-tus-acc-tes      .
           go to     acc-tes-reg-999.
       acc-tes-reg-400.
      *                  *---------------------------------------------*
      *                  * Codice listino                              *
      *                  *---------------------------------------------*
           perform   acc-cod-lst-000      thru acc-cod-lst-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     move  "-"            to   w-cnt-tus-acc-tes
                     go to acc-tes-reg-999.
       acc-tes-reg-405.
      *                  *---------------------------------------------*
      *                  * Codice lingua                               *
      *                  *---------------------------------------------*
           perform   acc-cod-lng-000      thru acc-cod-lng-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-400.
       acc-tes-reg-410.
      *                  *---------------------------------------------*
      *                  * Categoria sconto in riga                    *
      *                  *---------------------------------------------*
           perform   acc-csr-aac-000      thru acc-csr-aac-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-405.
       acc-tes-reg-420.
      *                  *---------------------------------------------*
      *                  * Categoria sconto in chiusura                *
      *                  *---------------------------------------------*
           perform   acc-csc-aac-000      thru acc-csc-aac-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-410.
       acc-tes-reg-422.
      *                  *---------------------------------------------*
      *                  * Categoria provvigioni                       *
      *                  *---------------------------------------------*
           perform   acc-cpv-aac-000      thru acc-cpv-aac-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-420.
       acc-tes-reg-424.
      *                  *---------------------------------------------*
      *                  * Percentuale di provvigioni                  *
      *                  *---------------------------------------------*
           perform   acc-ppv-aac-000      thru acc-ppv-aac-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-422.
       acc-tes-reg-430.
      *                  *---------------------------------------------*
      *                  * Codice agente                               *
      *                  *---------------------------------------------*
           perform   acc-cod-age-000      thru acc-cod-age-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-424.
       acc-tes-reg-440.
      *                  *---------------------------------------------*
      *                  * Flag di significativita' provvigioni per il *
      *                  * documento                                   *
      *                  *---------------------------------------------*
           perform   acc-fsp-doc-000      thru acc-fsp-doc-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-430.
       acc-tes-reg-450.
      *                  *---------------------------------------------*
      *                  * Tipo vendita per l'agente                   *
      *                  *---------------------------------------------*
           perform   acc-tip-vpa-000      thru acc-tip-vpa-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-440.
       acc-tes-reg-460.
      *                  *---------------------------------------------*
      *                  * Importo provvigione per l'agente            *
      *                  *---------------------------------------------*
           perform   acc-pvf-age-000      thru acc-pvf-age-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-450.
       acc-tes-reg-470.
      *                  *---------------------------------------------*
      *                  * Codice categoria commerciale                *
      *                  *---------------------------------------------*
           perform   acc-cod-cat-000      thru acc-cod-cat-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-460.
      *                  *---------------------------------------------*
      *                  * Se Next Screen o Tab in corso               *
      *                  *---------------------------------------------*
           if        v-key                =    "NXSC"   or
                     w-cnt-mfu-fky-tab    not  = spaces
                     move  "+"            to   w-cnt-tus-acc-tes
                     go to acc-tes-reg-999.
      *                  *---------------------------------------------*
      *                  * Presa visione per pagina 4                  *
      *                  *---------------------------------------------*
           perform   acc-pre-vpg-000      thru acc-pre-vpg-999        .
           if        v-key                =    "NXSC"
                     move  "+"            to   w-cnt-tus-acc-tes      .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-460.
      *                  *---------------------------------------------*
      *                  * Fine Pagina                                 *
      *                  *---------------------------------------------*
           move      "+"                  to   w-cnt-tus-acc-tes      .
           go to     acc-tes-reg-999.
       acc-tes-reg-500.
      *                  *---------------------------------------------*
      *                  * Codice forma di pagamento                   *
      *                  *---------------------------------------------*
           perform   acc-cod-fop-000      thru acc-cod-fop-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     move  "-"            to   w-cnt-tus-acc-tes
                     go to acc-tes-reg-999.
       acc-tes-reg-505.
      *                  *---------------------------------------------*
      *                  * Codice ABI banca di appoggio                *
      *                  *---------------------------------------------*
           perform   acc-cod-abi-000      thru acc-cod-abi-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-500.
       acc-tes-reg-510.
      *                  *---------------------------------------------*
      *                  * Codice CAB sportello banca di appoggio      *
      *                  *---------------------------------------------*
           perform   acc-cod-cab-000      thru acc-cod-cab-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-505.
       acc-tes-reg-515.
      *                  *---------------------------------------------*
      *                  * Conto corrente di appoggio                  *
      *                  *---------------------------------------------*
           perform   acc-ccc-app-000      thru acc-ccc-app-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-510.
       acc-tes-reg-520.
      *                  *---------------------------------------------*
      *                  * Codice nostra banca per bonifico            *
      *                  *---------------------------------------------*
           perform   acc-nos-ban-000      thru acc-nos-ban-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
