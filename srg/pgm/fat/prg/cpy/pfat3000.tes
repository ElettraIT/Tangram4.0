      *              *-------------------------------------------------*
           move      "AC"                 to   w-cmn-zcs-001-ope      .
           move      w-tes-csc-aac (1)    to   w-cmn-zcs-001-cod      .
           move      09                   to   w-cmn-zcs-001-lin      .
           move      30                   to   w-cmn-zcs-001-pos      .
           move      09                   to   w-cmn-zcs-001-dln      .
           move      37                   to   w-cmn-zcs-001-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cmn-zcs-001-cll-000  thru cmn-zcs-001-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cmn-zcs-001-foi-000  thru cmn-zcs-001-foi-999    .
       acc-csc-aac-110.
           perform   cmn-zcs-001-cll-000  thru cmn-zcs-001-cll-999    .
           if        w-cmn-zcs-001-ope    =    "F+"
                     go to acc-csc-aac-115.
           if        w-cmn-zcs-001-ope    =    "AC"
                     go to acc-csc-aac-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-csc-aac-115.
           perform   cmn-zcs-001-foi-000  thru cmn-zcs-001-foi-999    .
           go to     acc-csc-aac-110.
       acc-csc-aac-120.
           move      w-cmn-zcs-001-cod    to   v-num                  .
      *              *-------------------------------------------------*
