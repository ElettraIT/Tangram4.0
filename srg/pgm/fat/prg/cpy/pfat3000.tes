                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
                     go to acc-tes-reg-535.
       acc-tes-reg-545.
      *                  *---------------------------------------------*
      *                  * Ammontare quota a forfait pagamento         *
      *                  *---------------------------------------------*
           perform   acc-pag-qaf-000      thru acc-pag-qaf-999        .
           if        v-key                =    "PRSC"
                     move  "-"            to   w-cnt-tus-acc-tes      .
           if        w-cnt-tus-acc-tes    not  = spaces
                     go to acc-tes-reg-999.
           if        v-key                =    "UP  "
