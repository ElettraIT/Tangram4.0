      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   qry-rou-pri-000
                                          thru qry-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Preparazione eventuale messaggio di errore      *
      *              *-------------------------------------------------*
           move      "Nessun movimento da stampare entro limiti assegnat
      -              "i !    "            to   w-err-box-err-msg      .
       stp-srt-inp-030.
      *              *-------------------------------------------------*
      *              * Apertura modulo di stampa documento             *
      *              *-------------------------------------------------*
           perform   opn-mod-stp-000      thru opn-mod-stp-999        .
      *                  *---------------------------------------------*
      *                  * Se selezione non effettuata : uscita        *
      *                  *---------------------------------------------*
           if        w-cnt-mst-sel        =    "N"
                     move  "Stampa annullata !"
                                          to   w-err-box-err-msg
                     go to stp-srt-inp-999.
       stp-srt-inp-050.
      *              *-------------------------------------------------*
      *              * Messaggio di programma in esecuzione            *
      *              *-------------------------------------------------*
           move      "PE"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Start su [fit] per data registrazione           *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "IDEDOC    "         to   f-key                  .
           move      rr-dat-min           to   rf-fit-dat-doc         .
           move      rr-dpz-inu           to   rf-fit-cod-dpz         .
           if        rr-tip-mov           =    spaces
                     move  zero           to   rf-fit-num-doc
           else      move  rr-nfi-min     to   rf-fit-num-doc         .
           move      rr-tip-mov           to   rf-fit-cod-tmo         .
           move      zero                 to   rf-fit-num-prt         .
           move      "pgm/fat/fls/ioc/obj/ioffit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fit                 .
      *                  *---------------------------------------------*
      *                  * Se start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale archivio [fit]              *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/fat/fls/ioc/obj/ioffit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fit                 .
      *                  *---------------------------------------------*
      *                  * Se lettura errata : uscita                  *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se oltre data massima : superamento         *
      *                  *---------------------------------------------*
           if        rr-dat-max           =    zero
                     go to stp-srt-inp-320
           else      go to stp-srt-inp-340.
       stp-srt-inp-320.
      *                  *---------------------------------------------*
      *                  * Se data documenti massima a zero            *
      *                  *---------------------------------------------*
           if        rr-dat-min           =    zero
                     go to stp-srt-inp-400.
           if        rf-fit-dat-doc       >    rr-dat-min
                     go to stp-srt-inp-999.
           go to     stp-srt-inp-400.
       stp-srt-inp-340.
      *                  *---------------------------------------------*
      *                  * Se data documenti massima non zero          *
      *                  *---------------------------------------------*
           if        rf-fit-dat-doc       >    rr-dat-max
                     go to stp-srt-inp-999.
           go to     stp-srt-inp-400.
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se fine dipendenza in uso : riciclo         *
      *                  *---------------------------------------------*
           if        rf-fit-cod-dpz       not  = rr-dpz-inu
                     go to stp-srt-inp-200.
       stp-srt-inp-420.
      *                  *---------------------------------------------*
      *                  * Test se destinatario con posta elettronica  *
      *                  *---------------------------------------------*
           if        rr-snx-edp           =    2
                     go to stp-srt-inp-440.
      *                  *---------------------------------------------*
      *                  * Determinazione indirizzo elettronico        *
      *                  *---------------------------------------------*
           move      "IE"                 to   d-con-arc-tip-ope      .
           move      02                   to   d-con-arc-tip-arc      .
           move      rf-fit-cod-cli       to   d-con-arc-cod-arc      .
           move      rf-fit-dpz-cli       to   d-con-arc-dpz-arc      .
           move      "fat"                to   d-con-arc-tip-sel      .
           perform   con-arc-tip-cll-000  thru con-arc-tip-cll-999    .
      *                      *-----------------------------------------*
      *                      * Test su esito lettura                   *
      *                      *-----------------------------------------*
           if        rr-snx-edp           =    1 and
                     d-con-arc-num-con (1)
                                          not  = spaces
                     go to stp-srt-inp-200.
           if        rr-snx-edp           =    3 and
                     d-con-arc-num-con (1)
                                          =    spaces
                     go to stp-srt-inp-200.
       stp-srt-inp-440.
      *                  *---------------------------------------------*
      *                  * Test su numero fattura                      *
      *                  *---------------------------------------------*
           if        rr-tip-mov           =    spaces and
                     w-nmz-doc-num-num    =    "+"
                     go to stp-srt-inp-460.
           if        rf-fit-num-doc       <    rr-nfi-min or
                     rf-fit-num-doc       >    rr-nfi-max
                     go to stp-srt-inp-200.
       stp-srt-inp-460.
      *                  *---------------------------------------------*
      *                  * Test su tipo movimento                      *
      *                  *---------------------------------------------*
           if        rr-tip-mov           =    spaces
                     go to stp-srt-inp-480.
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        rf-fit-cod-tmo       not  = rr-tip-mov
                     go to stp-srt-inp-200.
      *                      *-----------------------------------------*
      *                      * A test su tipo stampa                   *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-500.
       stp-srt-inp-480.
      *                  *---------------------------------------------*
      *                  * Test su tipi documento                      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su tipo movimento                  *
      *                      *-----------------------------------------*
           if        rr-tip-mov           not  = spaces
                     go to stp-srt-inp-490.
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo docu-   *
      *                      * mento                                   *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-481
                     stp-srt-inp-482
                     stp-srt-inp-483
                     stp-srt-inp-484
                     depending            on   rf-fit-tip-doc         .
       stp-srt-inp-481.
      *                      *-----------------------------------------*
      *                      * Fattura                                 *
      *                      *-----------------------------------------*
           if        rr-tip-doc-fat       not  = spaces
                     go to stp-srt-inp-490
           else      go to stp-srt-inp-200.
       stp-srt-inp-482.
      *                      *-----------------------------------------*
      *                      * Nota di addebito                        *
      *                      *-----------------------------------------*
           if        rr-tip-doc-nad       not  = spaces
                     go to stp-srt-inp-490
           else      go to stp-srt-inp-200.
       stp-srt-inp-483.
      *                      *-----------------------------------------*
      *                      * Nota di accredito                       *
      *                      *-----------------------------------------*
           if        rr-tip-doc-nac       not  = spaces
                     go to stp-srt-inp-490
           else      go to stp-srt-inp-200.
       stp-srt-inp-484.
      *                      *-----------------------------------------*
      *                      * Fattura Pro-Forma                       *
      *                      *-----------------------------------------*
           if        rr-tip-doc-fpf       not  = spaces
                     go to stp-srt-inp-490
           else      go to stp-srt-inp-200.
       stp-srt-inp-490.
      *                  *---------------------------------------------*
      *                  * Test che il tipo movimento in corso di      *
      *                  * trattamento sia stampabile dal programma    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura tipo movimento                  *
      *                      *-----------------------------------------*
           move      rf-fit-cod-tmo       to   w-let-arc-zfi-cod      .
           perform   let-arc-zfi-000      thru let-arc-zfi-999        .
           if        w-let-arc-zfi-flg    not  = spaces
                     go to stp-srt-inp-200.
      *                      *-----------------------------------------*
      *                      * Test su descrizione per la stampa       *
      *                      *-----------------------------------------*
           if        w-let-arc-zfi-dst    =    "*"
                     go to stp-srt-inp-200.
      *                      *-----------------------------------------*
      *                      * Test su origine del documento           *
      *                      *-----------------------------------------*
           if        rf-fit-org-doc       not  = 02 and
                     w-let-arc-zfi-ord    not  = 03
                     go to stp-srt-inp-500
           else      go to stp-srt-inp-200.
       stp-srt-inp-500.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo stampa      *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-510
                     stp-srt-inp-520
                     stp-srt-inp-530
                     stp-srt-inp-540
                     depending            on   rr-tip-stp             .
           go to     stp-srt-inp-510.
       stp-srt-inp-510.
      *                  *---------------------------------------------*
      *                  * Tipo stampa : incondizionata                *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-600.
       stp-srt-inp-520.
      *                  *---------------------------------------------*
      *                  * Tipo stampa : definitiva                    *
      *                  *---------------------------------------------*
           if        rf-fit-ctr-stp       not  = zero
                     go to stp-srt-inp-200.
           go to     stp-srt-inp-600.
       stp-srt-inp-530.
      *                  *---------------------------------------------*
      *                  * Tipo stampa : di prova                      *
      *                  *---------------------------------------------*
           if        rf-fit-ctr-stp       not  = zero
                     go to stp-srt-inp-200.
           go to     stp-srt-inp-600.
       stp-srt-inp-540.
      *                  *---------------------------------------------*
      *                  * Tipo stampa : ristampa                      *
      *                  *---------------------------------------------*
           if        rf-fit-ctr-stp       not  > zero
                     go to stp-srt-inp-200.
           go to     stp-srt-inp-600.
       stp-srt-inp-600.
      *              *-------------------------------------------------*
      *              * Preparazione record di sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Chiave di sort                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Data documento                          *
      *                      *-----------------------------------------*
           move      rf-fit-dat-doc       to   srt-dat-doc            .
      *                      *-----------------------------------------*
      *                      * Codice dipendenza                       *
      *                      *-----------------------------------------*
           move      rf-fit-cod-dpz       to   srt-cod-dpz            .
      *                      *-----------------------------------------*
      *                      * Numero documento                        *
      *                      *-----------------------------------------*
           move      rf-fit-num-doc       to   srt-num-doc            .
      *                      *-----------------------------------------*
      *                      * Tipo documento                          *
      *                      *-----------------------------------------*
           move      rf-fit-cod-tmo       to   srt-cod-tmo            .
      *                  *---------------------------------------------*
      *                  * Dati di sort                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Protocollo documento                    *
      *                      *-----------------------------------------*
           move      rf-fit-num-prt       to   srt-num-prt            .
       stp-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Riciclo a record successivo                     *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-999.
           exit.

