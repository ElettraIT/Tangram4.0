      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Tipo movimento non stampabile con questo programma
      -              " !   "              to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-tip-mov-100.
       acc-tip-mov-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se codice non a spaces : normalizzazione e  *
      *                  * visualizzazione tipi documento              *
      *                  *---------------------------------------------*
           if        rr-tip-mov           =    spaces
                     go to acc-tip-mov-625.
           move      spaces               to   rr-tip-doc             .
           if        w-let-arc-zfi-tdo    =    1
                     move  "X"            to   rr-tip-doc-fat
           else if   w-let-arc-zfi-tdo    =    2
                     move  "X"            to   rr-tip-doc-nad
           else if   w-let-arc-zfi-tdo    =    3
                     move  "X"            to   rr-tip-doc-nac
           else      move  "X"            to   rr-tip-doc-fpf         .
           perform   vis-tip-doc-000      thru vis-tip-doc-999        .
       acc-tip-mov-625.
      *                  *---------------------------------------------*
      *                  * Se codice a spaces, e sono presenti piu'    *
      *                  * numerazioni, e attualmente i numeri docu-   *
      *                  * mento sono diversi da zero : si normalizza- *
      *                  * no i numeri documento                       *
      *                  *---------------------------------------------*
           if        rr-tip-mov           not  = spaces
                     go to acc-tip-mov-800.
           if        w-nmz-doc-num-num    not  = "+"
                     go to acc-tip-mov-800.
           if        rr-nfa-min           =    zero and
                     rr-nfa-max           =    zero
                     go to acc-tip-mov-800.
