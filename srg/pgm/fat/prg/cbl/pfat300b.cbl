                     move  w-tes-dpz-cli (1)
                                          to   w-tes-dpc-plf (1)
           else if   w-tes-tip-frn (1)    =    11
                     move  zero           to   w-tes-cli-plf (1)
                     move  spaces         to   w-tes-dpc-plf (1)
           else if   w-tes-tip-frn (1)    =    21
                     move  rf-dcc-arc-plf to   w-tes-cli-plf (1)
