                                          to   w-tes-ppv-aaa (1, 2)   .
           move      w-let-arc-age-ppv (3)
                                          to   w-tes-ppv-aaa (1, 3)   .
           move      w-let-arc-age-spa    to   w-tes-cod-ime (1)      .
           move      zero                 to   w-tes-pvf-ime (1)      .
      *
           if        w-ref-fpd-nac-cod    not  = zero
