      *    *===========================================================*
      *    * Generazione file 'xml'                                    *
      *    *                                                           *
      *    * Subroutine per lettura eventuale CUP e CIG da righe di    *
      *    * commento fattura se non gia' determinati in testata ordi- *
      *    * ne                                                        *
      *    *-----------------------------------------------------------*
       gfx-ccf-000.
      *              *-------------------------------------------------*
      *              * Test gia' determinati                           *
      *              *-------------------------------------------------*
           if        w-gen-cod-cup        not  = spaces and
                     w-gen-cod-cig        not  = spaces
                     go to gfx-ccf-900.
       gfx-ccf-100.
      *              *-------------------------------------------------*
      *              * Start su file [fir]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-fit-num-prt       to   rf-fir-num-prt         .
           move      zero                 to   rf-fir-num-prg         .
           move      "pgm/fat/fls/ioc/obj/ioffir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fir                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : A riciclo su [fit]        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to gfx-ccf-900.
       gfx-ccf-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [fir]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/fat/fls/ioc/obj/ioffir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fir                 .
      *                  *---------------------------------------------*
      *                  * Se fine file : A riciclo su [fit]           *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to gfx-ccf-900.
       gfx-ccf-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-fir-num-prt       not  = rf-fit-num-prt
                     go to gfx-ccf-900.
       gfx-ccf-400.
      *              *-------------------------------------------------*
      *              * Selezione sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo riga                           *
      *                  *---------------------------------------------*
           if        rf-fir-tip-rig (1:1) not  = "C"
                     go to gfx-ccf-200.
       gfx-ccf-500.
      *              *-------------------------------------------------*
      *              * Test se 'CUP' o 'CIG'                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su contenuto commento                  *
      *                  *---------------------------------------------*
           move      rf-fir-des-rig       to   w-all-str-alf          .
           move      ":"                  to   w-all-str-del          .
           perform   all-str-ext-000      thru all-str-ext-999        .
           if        w-all-str-num        not  > 1
                     go to gfx-ccf-200.
      *                  *---------------------------------------------*
      *                  * Scorporo componenti                         *
      *                  *---------------------------------------------*
           if        rf-fir-des-rig
                    (01 : 03)             =    "CUP"
                     move  w-all-str-cat (2)
                                          to   w-gen-cod-cup
           else if   rf-fir-des-rig
                    (01 : 03)             =    "CIG"
                     move  w-all-str-cat (2)
                                          to   w-gen-cod-cig          .
      *                  *---------------------------------------------*
      *                  * Allineamento a sinistra eventuale           *
      *                  *---------------------------------------------*
           move      20                   to   w-all-str-lun          .
           move      w-gen-cod-cup        to   w-all-str-alf          .
           perform   all-str-asx-000      thru all-str-asx-999        .
           move      w-all-str-alf        to   w-gen-cod-cup          .
      *
           move      20                   to   w-all-str-lun          .
           move      w-gen-cod-cig        to   w-all-str-alf          .
           perform   all-str-asx-000      thru all-str-asx-999        .
           move      w-all-str-alf        to   w-gen-cod-cig          .
       gfx-ccf-800.
      *              *-------------------------------------------------*
      *              * Riciclo su file [fir]                           *
      *              *-------------------------------------------------*
           go to     gfx-ccf-200.
       gfx-ccf-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     gfx-ccf-999.
       gfx-ccf-999.
           exit.

