                     go to gfx-cau-lic-900.
      *              *-------------------------------------------------*
      *              * Editing data lettera d'intenti                  *
      *              *-------------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      "<"                  to   v-edm                  .
           move      rf-lic-dat-lic       to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-gen-lic-dat          .
       gfx-cau-lic-500.
      *              *-------------------------------------------------*
      *              * Assemblaggio                                    *
      *              *                                                 *
      *              * La stringa risulterebbe cosi' formata:          *
      *              *                                                 *
      *              * [testo di premessa memorizzato in 'lic' ...] +  *
      *              * - Vs. lettera d'intenti nr. 999999 del 99/99/99 *
      *              * prot. nr. XXXXXXXXXXXXXXXXX/999999              *
      *              *                                                 *
      *              * N.B.: max 200 chr                               *
      *              *-------------------------------------------------*
           move      200                  to   w-all-str-lun          .
           move      07                   to   w-all-str-num          .
           move      rf-lic-alx-exp       to   w-all-str-cat (1)      .
           move      "- Vs. lettera d'intenti nr."
                                          to   w-all-str-cat (2)      .
           move      rf-lic-num-lic       to   w-all-str-cat (3)      .
           move      "del"                to   w-all-str-cat (4)      .
           move      w-gen-lic-dat        to   w-all-str-cat (5)      .
           move      "prot. nr."          to   w-all-str-cat (6)      .
           move      rf-cli-nom-int       to   w-all-str-cat (7)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *              *-------------------------------------------------*
      *              * Emissione tag <Causale>                         *
      *              *                                                 *
      *              * '2.1.1.11'                                      *
      *              *-------------------------------------------------*
           move      "Causale"            to   w-sta-emi-xml-pmt      .
           move      "E"                  to   w-sta-emi-xml-ope      .
           move      w-all-str-alf        to   w-sta-emi-xml-val      .
           move      "="                  to   w-sta-emi-xml-ind      .
           perform   emi-tag-xml-000      thru emi-tag-xml-999        .
       gfx-cau-lic-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     gfx-cau-lic-999.
       gfx-cau-lic-999.
           exit.

