      *                  * si espone il prezzo lordo                   *
      *                  *                                             *
      *                  * N.B.: attualmente inibito                   *
      *                  *---------------------------------------------*
______*    if        rf-fir-per-scr (1)   not  = zero and
______*              rf-fir-per-scr (2)   = zero
______*              move  rf-fir-prz-ven to   w-gen-prz-uni          .
      *                  *---------------------------------------------*
      *                  * Se la quantita' della riga e' negativa, si  *
      *                  * inverte il segno del prezzo unitario        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su quantita'                       *
      *                      *-----------------------------------------*
           if        rf-fir-qta-ven       not  < zero
                     go to gfx-rig-pro-680.
      *                      *-----------------------------------------*
      *                      * Inversione segno del prezzo unitario    *
      *                      *-----------------------------------------*
           multiply  -1                   by   w-gen-prz-uni          .
       gfx-rig-pro-680.
      *                  *=============================================*
      *                  *                                             *
      *                  *               ******************            *
      *                  *               * ATTENZIONE !!! *            *
      *                  *               ******************            *
      *                  *                                             *
      *                  * IN PRESENZA DI SCONTI, PER PROBLEMI SUL     *
      *                  * CONTROLLO DI 'AdE', SI RICALCOLA IL PREZZO  *
      *                  * UNITARIO CHE VIENE EDITATO IN MODO PARTICO- *
      *                  * LARE, DIVIDENDO L'IMPORTO PER LA QUANTITA'  *
      *                  *                                             *
      *                  * Importo / quantita' = 111111111.99999999    *
      *                  *                                             *
      *                  * dove 111111111  = interi                    *
      *                  *      99999999   = decimali (max 8)          *
      *                  *                                             *
      *                  * Bisogna pero' considerare che l'importo e'  *
      *                  * un virtuale con due decimali in piu' per    *
      *                  * cui il risultato del calcolo e' di 7 interi *
      *                  * e 10 decimali di cui si considerano solo 8  *
      *                  *                                             *
      *                  * Si deve poi applicare l'eventuale prezzo    *
      *                  * per quantita'                               *
      *                  *                                             *
      *                  * Prezzo unitario = 1111111.9999999900        *
      *                  *                                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su sconti                          *
      *                      *-----------------------------------------*
           if        rf-fir-per-scr (1)   =    zero
                     go to gfx-rig-pro-685.
      *                      *-----------------------------------------*
      *                      * Calcolo prezzo netto                    *
      *                      *-----------------------------------------*
           divide    rf-fir-qta-ven       into rf-fir-imp-rig
                                        giving w-sta-emi-xml-ims      .
      *                      *-----------------------------------------*
      *                      * Eventuale correttivo in caso di prezzo  *
      *                      * per quantita'                           *
      *                      *-----------------------------------------*
           if        rf-fir-flg-puq       =    "K"
                     multiply 1000        by   w-sta-emi-xml-ims
           else if   rf-fir-flg-puq       =    "C"
                     multiply 100         by   w-sta-emi-xml-ims
           else if   rf-fir-flg-puq       =    "D"
                     multiply 10          by   w-sta-emi-xml-ims      .
      *                      *-----------------------------------------*
      *                      * Trattamento del segno                   *
      *                      *-----------------------------------------*
           if        rf-fir-prz-net       <    zero
                     move  "-"            to   w-all-str-cat (1)
           else      move  spaces         to   w-all-str-cat (1)      .
      *                      *-----------------------------------------*
      *                      * Editing interi                          *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-sta-emi-xml-ims
                    (01 : 07)             to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-all-str-cat (2)      .
      *
           if        v-edt                =    spaces
                     move  "0"            to   w-all-str-cat (2)      .
      *                      *-----------------------------------------*
      *                      * Editing decimali                        *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "9"                  to   v-edm                  .
           move      w-sta-emi-xml-ims
                    (08 : 08)             to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-all-str-cat (4)      .
      *
           if        v-edt                =    spaces
                     move  "0"            to   w-all-str-cat (4)      .
      *                      *-----------------------------------------*
      *                      * Assemblaggio prezzo netto               *
      *                      *-----------------------------------------*
           move      20                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
      *
           move      "."                  to   w-all-str-cat (3)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
           move      w-all-str-alf        to   w-sta-emi-xml-val      .
      *                      *-----------------------------------------*
      *                      * A emissione tag                         *
      *                      *-----------------------------------------*
           go to     gfx-rig-pro-690.
