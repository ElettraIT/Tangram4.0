      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo di stampa       *
      *              *-------------------------------------------------*
           if        rr-tip-stp           =    01
                     go to stp-srt-inp-010
           else if   rr-tip-stp           =    02
                     go to stp-srt-inp-020
           else      go to stp-srt-inp-010.
       stp-srt-inp-010.
      *              *-------------------------------------------------*
      *              * Start su archivio [fit] per data registrazione  *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "IDEDOC    "         to   f-key                  .
           move      rr-dat-ini           to   rf-fit-dat-doc         .
           move      rr-dpz-inu           to   rf-fit-cod-dpz         .
           move      zero                 to   rf-fit-num-doc         .
           move      spaces               to   rf-fit-cod-tmo         .
           move      zero                 to   rf-fit-num-prt         .
           move      "pgm/fat/fls/ioc/obj/ioffit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fit                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
      *                  *---------------------------------------------*
      *                  * A read-next                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-100.
       stp-srt-inp-020.
      *              *-------------------------------------------------*
      *              * Start su archivio [fit] per data ultima modifi- *
      *              * ca                                              *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DATSYS    "         to   f-key                  .
           move      rr-dat-ini           to   rf-fit-ide-dat         .
           move      zero                 to   rf-fit-dat-doc         .
           move      zero                 to   rf-fit-num-prt         .
           move      "pgm/fat/fls/ioc/obj/ioffit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fit                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
      *                  *---------------------------------------------*
      *                  * A read-next                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-100.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Read-next su archivio [fit]                     *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/fat/fls/ioc/obj/ioffit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fit                 .
      *                  *---------------------------------------------*
      *                  * Se at end : uscita                          *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo di stampa   *
      *                  *---------------------------------------------*
           if        rr-tip-stp           =    01
                     go to stp-srt-inp-210
           else if   rr-tip-stp           =    02
                     go to stp-srt-inp-220
           else      go to stp-srt-inp-210.
       stp-srt-inp-210.
      *                  *---------------------------------------------*
      *                  * Test su data documento                      *
      *                  *---------------------------------------------*
           if        rf-fit-dat-doc       >    rr-dat-fin
                     go to stp-srt-inp-999.
      *                      *-----------------------------------------*
      *                      * A selezioni                             *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-300.
       stp-srt-inp-220.
      *                  *---------------------------------------------*
      *                  * Test su data ultima modifica                *
      *                  *---------------------------------------------*
           if        rf-fit-ide-dat       >    rr-dat-fin
                     go to stp-srt-inp-999.
      *                      *-----------------------------------------*
      *                      * A selezioni                             *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-300.
       stp-srt-inp-300.
      *                  *---------------------------------------------*
      *                  * Selezioni sul record [fit]                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su codice dipendenza : se diverso, *
      *                      * a riciclo                               *
      *                      *-----------------------------------------*
           if        rf-fit-cod-dpz       not  = rr-dpz-inu
                     go to stp-srt-inp-100.
       stp-srt-inp-320.
      *                      *-----------------------------------------*
      *                      * Test su codice utente                   *
      *                      *-----------------------------------------*
           if        rr-cod-ute           =    spaces
                     go to stp-srt-inp-330.
           if        rf-fit-ide-ute       not  = rr-cod-ute
                     go to stp-srt-inp-100.
       stp-srt-inp-330.
      *                      *-----------------------------------------*
      *                      * Test su codice fase                     *
      *                      *-----------------------------------------*
           if        rr-cod-fas           =    spaces
                     go to stp-srt-inp-340.
           if        rf-fit-ide-fas       not  = rr-cod-fas
                     go to stp-srt-inp-100.
       stp-srt-inp-340.
      *                      *-----------------------------------------*
      *                      * Test su codice tipo movimento           *
      *                      *-----------------------------------------*
           if        rr-cod-tmo           =    spaces
                     go to stp-srt-inp-360.
           if        rf-fit-cod-tmo       not  = rr-cod-tmo
                     go to stp-srt-inp-100.
       stp-srt-inp-360.
      *                      *-----------------------------------------*
      *                      * Test su tipo invio                      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Deviazione in funzione tipo invio   *
      *                          *-------------------------------------*
           go to     stp-srt-inp-362
                     stp-srt-inp-364
                     stp-srt-inp-366
                     stp-srt-inp-368
                     stp-srt-inp-370
                     stp-srt-inp-372
                     depending            on   rr-tip-inv             .
       stp-srt-inp-362.
      *                          *-------------------------------------*
      *                          * Se nessuna selezione                *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Oltre                           *
      *                              *---------------------------------*
           go to     stp-srt-inp-380.
       stp-srt-inp-364.
      *                          *-------------------------------------*
      *                          * Se invio cartaceo                   *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Test di presenza in distinta    *
      *                              *---------------------------------*
           move      rf-fit-num-prt       to   w-det-dst-num-prt      .
