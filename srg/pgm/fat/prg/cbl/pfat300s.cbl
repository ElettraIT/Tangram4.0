      *                              *---------------------------------*
           if        w-kk0-wrt-app-tr1    not  = "P" and
                     w-kk0-wrt-app-tr1    not  = "M" and
                     w-kk0-wrt-app-tr1    not  = "S"
                     go to fil-kk0-rco-570.
      *                              *---------------------------------*
      *                              * Solo se tipo esposizione riga   *
      *                              * lo consente                     *
      *                              *---------------------------------*
           if        kk0-dat-tip-erf      =    1
                     go to fil-kk0-rco-565
           else if   kk0-dat-tip-erf      =    2 or
                     kk0-dat-tip-erf      =    3
                     go to fil-kk0-rco-570
           else if   kk0-dat-tip-erf      =    4
                     if     kk0-dat-qta-cum
                                          =    1,000
                            go to fil-kk0-rco-570
                     else   go to fil-kk0-rco-565
           else if   kk0-dat-tip-erf      =    5
                     go to fil-kk0-rco-570.
       fil-kk0-rco-565.
