      *    *===========================================================*
      *    * Stampa importo in riga                                    *
      *    *-----------------------------------------------------------*
       stp-imp-rig-000.
      *              *-------------------------------------------------*
      *              * Determinazione numero caratteri e maschera di   *
      *              * editing                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del numero decimali  *
      *                  * valuta                                      *
      *                  *---------------------------------------------*
           go to     stp-imp-rig-100
                     stp-imp-rig-200
                     stp-imp-rig-300
                     depending            on   w-stp-imp-rig-dcv      .
      *                  *---------------------------------------------*
      *                  * Numero decimali : 0                         *
      *                  *---------------------------------------------*
           if        w-stp-imp-rig-imp    >    999999999 or
                     w-stp-imp-rig-imp    <   -999999999
                     move  11             to   w-stp-imp-rig-car
                     move  spaces         to   w-stp-imp-rig-edm
           else      move  09             to   w-stp-imp-rig-car
                     move  "G"            to   w-stp-imp-rig-edm      .
           go to     stp-imp-rig-500.
       stp-imp-rig-100.
      *                  *---------------------------------------------*
      *                  * Numero decimali : 1                         *
      *                  *---------------------------------------------*
           if        w-stp-imp-rig-imp    >    99999999 or
                     w-stp-imp-rig-imp    <   -99999999
                     move  09             to   w-stp-imp-rig-car
                     move  spaces         to   w-stp-imp-rig-edm
           else      move  07             to   w-stp-imp-rig-car
                     move  "G"            to   w-stp-imp-rig-edm      .
           go to     stp-imp-rig-500.
       stp-imp-rig-200.
      *                  *---------------------------------------------*
      *                  * Numero decimali : 2                         *
      *                  *---------------------------------------------*
           if        w-stp-imp-rig-imp    >    99999999 or
                     w-stp-imp-rig-imp    <   -99999999
                     move  09             to   w-stp-imp-rig-car
                     move  spaces         to   w-stp-imp-rig-edm
           else      move  07             to   w-stp-imp-rig-car
                     move  "G"            to   w-stp-imp-rig-edm
                     add   1              to   w-stp-imp-rig-pos      .
           go to     stp-imp-rig-500.
       stp-imp-rig-300.
      *                  *---------------------------------------------*
      *                  * Numero decimali : 3                         *
      *                  *---------------------------------------------*
           if        w-stp-imp-rig-imp    >    999999999 or
                     w-stp-imp-rig-imp    <   -999999999
                     move  07             to   w-stp-imp-rig-car
                     move  spaces         to   w-stp-imp-rig-edm
           else      move  06             to   w-stp-imp-rig-car
                     move  "G"            to   w-stp-imp-rig-edm      .
           go to     stp-imp-rig-500.
       stp-imp-rig-500.
      *              *-------------------------------------------------*
      *              * Stampa                                          *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           move      w-stp-imp-rig-car    to   p-car                  .
           move      w-stp-imp-rig-dcv    to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      w-stp-imp-rig-edm    to   p-edm                  .
           move      w-stp-imp-rig-lin    to   p-lin                  .
           move      w-stp-imp-rig-pos    to   p-pos                  .
           move      w-stp-imp-rig-imp    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-imp-rig-999.
           exit.

      *    *===========================================================*
      *    * Routine di stampa piede documento                         *
      *    *-----------------------------------------------------------*
       stp-pie-doc-000.
      *              *-------------------------------------------------*
      *              * Determinazione castelletto iva per la stampa    *
      *              *-------------------------------------------------*
           perform   det-cst-iva-000      thru det-cst-iva-999        .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione castelletto iva              *
      *              *-------------------------------------------------*
           move      zero                 to   w-stp-pie-ctr          .
       stp-pie-doc-100.
           add       1                    to   w-stp-pie-ctr          .
           if        w-stp-pie-ctr        >    6
                     go to stp-pie-doc-200.
           if        w-iva-cst-cod
                    (w-stp-pie-ctr)       =    zero
                     go to stp-pie-doc-100.
      *                  *---------------------------------------------*
      *                  * Imponibile                                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se posizionamento esistente        *
      *                      *-----------------------------------------*
           if        w-lpp-iva-ibl-lin
                    (w-stp-pie-ctr)       =   zero or
                     w-lpp-iva-ibl-pos
                    (w-stp-pie-ctr)       =   zero
                     go to stp-pie-doc-120.
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda che si tratti o no *
      *                      * di un'aliquota di sola iva              *
      *                      *-----------------------------------------*
           move      w-iva-cst-cod
                    (w-stp-pie-ctr)       to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    =    9
                     go to stp-pie-doc-102
           else      go to stp-pie-doc-104.
       stp-pie-doc-102.
      *                      *-----------------------------------------*
      *                      * Se aliquota di sola iva                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Stampa literal a seconda dei flag   *
      *                          * incontrati nelle singole righe      *
      *                          *-------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      12                   to   p-car                  .
           move      w-lpp-iva-ibl-lin
                    (w-stp-pie-ctr)       to   p-lin                  .
           move      w-lpp-iva-ibl-pos
                    (w-stp-pie-ctr)       to   p-pos                  .
           if        w-stp-pie-sir        =    spaces
                     move  "      Omaggi" to   p-alf
           else if   w-stp-pie-sir        =    "S"
                     move  "    Sola Iva" to   p-alf
           else if   w-stp-pie-sir        =    "N"
                     move  "     *      " to   p-alf
           else      move  spaces         to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           go to     stp-pie-doc-120.
       stp-pie-doc-104.
      *                      *-----------------------------------------*
      *                      * Se altra aliquota iva                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Stampa                              *
      *                          *-------------------------------------*
           move      w-iva-cst-ibl
                    (w-stp-pie-ctr)       to   w-stp-imp-rig-imp      .
           move      rf-fit-dec-vpf       to   w-stp-imp-rig-dcv      .
           move      w-lpp-iva-ibl-lin
                    (w-stp-pie-ctr)       to   w-stp-imp-rig-lin      .
           move      w-lpp-iva-ibl-pos
                    (w-stp-pie-ctr)       to   w-stp-imp-rig-pos      .
           perform   stp-imp-rig-000      thru stp-imp-rig-999        .
       stp-pie-doc-120.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del codice iva         *
      *                  *---------------------------------------------*
           move      w-iva-cst-cod
                    (w-stp-pie-ctr)       to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    =    3 or
                     w-edt-iva-cod-003    =    4 or
                     w-edt-iva-cod-003    =    5 or
                     w-edt-iva-cod-003    =    6
                     go to stp-pie-doc-150
           else      go to stp-pie-doc-140.
       stp-pie-doc-140.
      *                  *---------------------------------------------*
      *                  * Se codice iva imponibile                    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice iva                              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se posizionamento esistente    *
      *                          *-------------------------------------*
           if        w-lpp-iva-cod-lin
                    (w-stp-pie-ctr)       =   zero or
                     w-lpp-iva-cod-pos
                    (w-stp-pie-ctr)       =   zero
                     go to stp-pie-doc-142.
      *                          *-------------------------------------*
      *                          * Stampa                              *
      *                          *-------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      03                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      spaces               to   p-edm                  .
           move      w-lpp-iva-cod-lin
                    (w-stp-pie-ctr)       to   p-lin                  .
           move      w-lpp-iva-cod-pos
                    (w-stp-pie-ctr)       to   p-pos                  .
           move      w-iva-cst-cod
                    (w-stp-pie-ctr)       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-pie-doc-142.
      *                      *-----------------------------------------*
      *                      * Imposta                                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se posizionamento esistente    *
      *                          *-------------------------------------*
           if        w-lpp-iva-imp-lin
                    (w-stp-pie-ctr)       =   zero or
                     w-lpp-iva-imp-pos
                    (w-stp-pie-ctr)       =   zero
                     go to stp-pie-doc-144.
      *                          *-------------------------------------*
      *                          * Stampa                              *
      *                          *-------------------------------------*
           move      w-iva-cst-imp
                    (w-stp-pie-ctr)       to   w-stp-imp-rig-imp      .
           move      rf-fit-dec-vpf       to   w-stp-imp-rig-dcv      .
           move      w-lpp-iva-imp-lin
                    (w-stp-pie-ctr)       to   w-stp-imp-rig-lin      .
           move      w-lpp-iva-imp-pos
                    (w-stp-pie-ctr)       to   w-stp-imp-rig-pos      .
           perform   stp-imp-rig-000      thru stp-imp-rig-999        .
       stp-pie-doc-144.
      *                          *-------------------------------------*
      *                          * A riciclo su castelletto iva        *
      *                          *-------------------------------------*
           go to     stp-pie-doc-152.
       stp-pie-doc-150.
      *                  *---------------------------------------------*
      *                  * Se codice iva esente                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione record [zci]            *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofzci"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zci                 .
      *                      *-----------------------------------------*
      *                      * Lettura record [zci]                    *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODIVA    "         to   f-key                  .
           move      w-iva-cst-cod
                    (w-stp-pie-ctr)       to   rf-zci-cod-iva         .
