       nom-cmb-stp-rit-000.
      *              *-------------------------------------------------*
      *              * Somma dei valori degli elementi                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazioni preliminari                 *
      *                  *---------------------------------------------*
           move      zero                 to   w-nom-cmb-tot-val      .
           move      zero                 to   w-nom-cmb-ctr-001      .
       nom-cmb-stp-rit-100.
           add       001                  to   w-nom-cmb-ctr-001      .
      *                  *---------------------------------------------*
      *                  * Test sul massimo                            *
      *                  *---------------------------------------------*
           if        w-nom-cmb-ctr-001    >    w-nom-cmb-num-ele
                     go to nom-cmb-stp-rit-200.
           if        w-nom-cmb-ctr-001    >    w-nom-cmb-max-ele
                     go to nom-cmb-stp-rit-200.
      *                  *---------------------------------------------*
      *                  * Incremento totale                           *
      *                  *---------------------------------------------*
           add       w-nom-cmb-cst-val
                    (w-nom-cmb-ctr-001)   to   w-nom-cmb-tot-val      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     nom-cmb-stp-rit-100.
       nom-cmb-stp-rit-200.
      *              *-------------------------------------------------*
      *              * Determinazione castelletto iva per la stampa    *
      *              *-------------------------------------------------*
           perform   det-cst-iva-000      thru det-cst-iva-999        .
       nom-cmb-stp-rit-300.
      *              *-------------------------------------------------*
      *              * Confronto dei valori ottenuti                   *
      *              *-------------------------------------------------*
           if        w-nom-cmb-tot-val    =    w-iva-ibl-doc
                     go to nom-cmb-stp-rit-900.
      *              *-------------------------------------------------*
      *              * Differenza dei valori ottenuti                  *
      *              *-------------------------------------------------*
           move      w-nom-cmb-tot-val    to   w-nom-cmb-tot-dif      .
           subtract  w-iva-ibl-doc        from w-nom-cmb-tot-dif      .
           move      w-nom-cmb-tot-dif    to   w-nom-cmb-ass-dif      .
           if        w-nom-cmb-tot-dif    >    zero
                     move  "-"            to   w-nom-cmb-sgn-dif
           else      move  "+"            to   w-nom-cmb-sgn-dif      .
       nom-cmb-stp-rit-400.
      *              *-------------------------------------------------*
      *              * Determinazione del coefficiente di incidenza di *
      *              * ogni singolo elemento e ricalcolo del valore    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazioni preliminari                 *
      *                  *---------------------------------------------*
           move      zero                 to   w-nom-cmb-ctr-001      .
           move      zero                 to   w-nom-cmb-tot-rcl      .
       nom-cmb-stp-rit-420.
           add       001                  to   w-nom-cmb-ctr-001      .
      *                  *---------------------------------------------*
      *                  * Test sul massimo                            *
      *                  *---------------------------------------------*
           if        w-nom-cmb-ctr-001    >    w-nom-cmb-num-ele
                     go to nom-cmb-stp-rit-900.
           if        w-nom-cmb-ctr-001    >    w-nom-cmb-max-ele
                     go to nom-cmb-stp-rit-900.
      *                  *---------------------------------------------*
      *                  * Determinazione del coefficiente di inciden- *
      *                  * za che ha il valore dell'elemento in esame  *
      *                  * sul totale                                  *
      *                  *---------------------------------------------*
           move      w-nom-cmb-cst-val
                    (w-nom-cmb-ctr-001)   to   w-nom-cmb-iap-w02      .
           divide    w-nom-cmb-tot-val    into w-nom-cmb-iap-w02      .
           move      w-nom-cmb-iap-w02    to   w-nom-cmb-ivl-tot      .
      *                  *---------------------------------------------*
      *                  * Ricalcolo del valore                        *
      *                  *---------------------------------------------*
           move      w-nom-cmb-ass-dif    to   w-nom-cmb-iap-w01      .
           multiply  w-nom-cmb-ivl-tot    by   w-nom-cmb-iap-w01      .
           if        w-nom-cmb-sgn-dif    =    "+"
                     add      w-nom-cmb-iap-w01
                                          to   w-nom-cmb-cst-val
                                              (w-nom-cmb-ctr-001)
           else      subtract w-nom-cmb-iap-w01
                                          from w-nom-cmb-cst-val
                                              (w-nom-cmb-ctr-001)     .
      *                  *---------------------------------------------*
      *                  * Incremento totale di comodo                 *
      *                  *---------------------------------------------*
           add       w-nom-cmb-cst-val
                    (w-nom-cmb-ctr-001)   to   w-nom-cmb-tot-rcl      .
      *                  *---------------------------------------------*
      *                  * Test se ultimo elemento                     *
      *                  *---------------------------------------------*
           if        w-nom-cmb-ctr-001    not  = w-nom-cmb-num-ele
                     go to nom-cmb-stp-rit-480.
      *                  *---------------------------------------------*
      *                  * Se il totale fin qui cumulato e' ancora di- *
      *                  * verso da quello da ottenere, si assegna la  *
      *                  * differenza all'ultimo elemento              *
      *                  *---------------------------------------------*
           if        w-nom-cmb-tot-rcl    =    w-iva-ibl-doc
                     go to nom-cmb-stp-rit-480.
           move      w-nom-cmb-tot-rcl    to   w-nom-cmb-tot-dif      .
           subtract  w-iva-ibl-doc        from w-nom-cmb-tot-dif      .
           subtract  w-nom-cmb-tot-dif    from w-nom-cmb-cst-val
                                              (w-nom-cmb-ctr-001)     .
       nom-cmb-stp-rit-480.
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     nom-cmb-stp-rit-420.
       nom-cmb-stp-rit-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     nom-cmb-stp-rit-999.
       nom-cmb-stp-rit-999.
           exit.

