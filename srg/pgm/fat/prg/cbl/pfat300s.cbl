           move      w-lpc-per-scr-pos (4)
                                          to   p-pos                  .
           move      kk0-dat-05s-rix (4)  to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       fil-kk0-rco-560.
      *                          *-------------------------------------*
      *                          * Sconto in riga 5                    *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Solo se in riga 3               *
      *                              *---------------------------------*
           if        w-stp-cor-doc-c01    not  = 3
                     go to fil-kk0-rco-570.
      *                              *---------------------------------*
