           if        rf-dcx-ann-rig (03)  not  = spaces
                     move  03             to   w-stp-cor-doc-wrd      .
           if        rf-dcx-ann-rig (04)  not  = spaces
                     move  04             to   w-stp-cor-doc-wrd      .
           if        rf-dcx-ann-rig (05)  not  = spaces
                     move  05             to   w-stp-cor-doc-wrd      .
           if        rf-dcx-ann-rig (06)  not  = spaces
                     move  06             to   w-stp-cor-doc-wrd      .
           if        rf-dcx-ann-rig (07)  not  = spaces
                     move  07             to   w-stp-cor-doc-wrd      .
           if        rf-dcx-ann-rig (08)  not  = spaces
                     move  08             to   w-stp-cor-doc-wrd      .
           if        rf-dcx-ann-rig (09)  not  = spaces
                     move  09             to   w-stp-cor-doc-wrd      .
           if        rf-dcx-ann-rig (10)  not  = spaces
                     move  10             to   w-stp-cor-doc-wrd      .
      *
