      *                              *---------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      02                   to   p-car                  .
           move      01                   to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "BD"                 to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      w-lpc-per-scr-pos (5)
                                          to   p-pos                  .
           move      kk0-dat-05s-rix (5)  to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       fil-kk0-rco-570.
      *                          *-------------------------------------*
      *                          * Riciclo a linee di descrizione      *
      *                          *-------------------------------------*
           go to     fil-kk0-rco-520.
       fil-kk0-rco-590.
      *              *-------------------------------------------------*
      *              * Riciclo su lettura sequenziale file [kk0]       *
      *              *-------------------------------------------------*
           go to     fil-kk0-rco-040.
       fil-kk0-rco-700.
      *              *-------------------------------------------------*
