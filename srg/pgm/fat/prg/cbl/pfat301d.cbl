       stp-imp-rig-000.
      *              *-------------------------------------------------*
      *              * Determinazione numero caratteri e maschera di   *
      *              * editing                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del numero decimali  *
      *                  * valuta                                      *
      *                  *---------------------------------------------*
           go to     stp-imp-rig-100
                     stp-imp-rig-200
                     stp-imp-rig-300
                     depending            on   w-stp-imp-rig-dcv      .
       stp-imp-rig-050.
      *                  *---------------------------------------------*
      *                  * Numero decimali : 0                         *
      *                  *---------------------------------------------*
           if        w-stp-imp-rig-imp    >    999999999 or
                     w-stp-imp-rig-imp    <   -999999999
                     move  11             to   w-stp-imp-rig-car
                     move  spaces         to   w-stp-imp-rig-edm
           else      move  09             to   w-stp-imp-rig-car
                     move  "G"            to   w-stp-imp-rig-edm      .
           go to     stp-imp-rig-500.
       stp-imp-rig-100.
      *                  *---------------------------------------------*
      *                  * Numero decimali : 1                         *
      *                  *---------------------------------------------*
           if        w-stp-imp-rig-imp    >    99999999 or
                     w-stp-imp-rig-imp    <   -99999999
                     move  09             to   w-stp-imp-rig-car
                     move  spaces         to   w-stp-imp-rig-edm
           else      move  07             to   w-stp-imp-rig-car
                     move  "G"            to   w-stp-imp-rig-edm      .
           go to     stp-imp-rig-500.
       stp-imp-rig-200.
      *                  *---------------------------------------------*
      *                  * Numero decimali : 2                         *
      *                  *---------------------------------------------*
           if        w-stp-imp-rig-imp    >    99999999 or
                     w-stp-imp-rig-imp    <   -99999999
                     move  08             to   w-stp-imp-rig-car
                     move  spaces         to   w-stp-imp-rig-edm
           else      move  06             to   w-stp-imp-rig-car
                     move  "G"            to   w-stp-imp-rig-edm
                     add   1              to   w-stp-imp-rig-pos      .
           go to     stp-imp-rig-500.
       stp-imp-rig-300.
      *                  *---------------------------------------------*
      *                  * Numero decimali : 3                         *
      *                  *---------------------------------------------*
           if        w-stp-imp-rig-imp    >    999999999 or
                     w-stp-imp-rig-imp    <   -999999999
                     move  07             to   w-stp-imp-rig-car
                     move  spaces         to   w-stp-imp-rig-edm
           else      move  06             to   w-stp-imp-rig-car
                     move  "G"            to   w-stp-imp-rig-edm      .
           go to     stp-imp-rig-500.
       stp-imp-rig-500.
      *              *-------------------------------------------------*
      *              * Stampa                                          *
      *              *-------------------------------------------------*
           move      "PF"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      w-stp-imp-rig-car    to   v-car                  .
           move      w-stp-imp-rig-dcv    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      w-stp-imp-rig-edm    to   v-edm                  .
           move      w-stp-imp-rig-lin    to   v-lin                  .
           move      w-stp-imp-rig-pos    to   v-pos                  .
           move      w-stp-imp-rig-imp    to   v-num                  .
      *
           if        w-stp-imp-rig-dcv    =    1
                     divide 10            into v-num
           else if   w-stp-imp-rig-dcv    =    2
                     divide 100           into v-num
           else if   w-stp-imp-rig-dcv    =    3
                     divide 1000          into v-num                  .
      *
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       stp-imp-rig-999.
           exit.

