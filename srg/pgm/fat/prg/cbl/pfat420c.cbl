           move      rf-dcc-via-dcc       to   w-let-arc-dcc-via      .
           move      rf-dcc-loc-dcc       to   w-let-arc-dcc-loc      .
           move      rf-dcc-cod-naz       to   w-let-arc-dcc-naz      .
           move      rf-dcc-idn-em2       to   w-let-arc-dcc-cpf      .
