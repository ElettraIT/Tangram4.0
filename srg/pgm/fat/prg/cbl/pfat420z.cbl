           move      "NL"                 to   f-cfr                  .
           move      "NUMDST    "         to   f-key                  .
           move      rr-num-dst           to   rf-ddx-num-dst         .
           move      zero                 to   rf-ddx-num-prg         .
           move      "pgm/fat/fls/ioc/obj/iofddx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddx                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata                             *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale [ddx]                       *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/fat/fls/ioc/obj/iofddx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddx                 .
      *                  *---------------------------------------------*
      *                  * Test su flag                                *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Test max                                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Controllo su numero distinta                *
      *                  *---------------------------------------------*
           if        rf-ddx-num-dst       not  = rr-num-dst
                     go to stp-srt-inp-900.
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se annullato invio                     *
      *                  *---------------------------------------------*
           if        rf-ddx-flg-ain       not  = spaces
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Controllo se archivio attachement preparato *
      *                  *---------------------------------------------*
           if        rf-ddx-flg-apr       =    spaces
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Controllo su percorso archivio attachement  *
      *                  *---------------------------------------------*
           if        rf-ddx-eml-all       =    spaces
                     go to stp-srt-inp-200.
      *                  *---------------------------------------------*
      *                  * Controllo di integrita' del file XML        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Subroutine di controllo                 *
      *                      *-----------------------------------------*
           perform   stp-srt-inp-ifx-000  thru stp-srt-inp-ifx-999    .
           if        w-det-int-xml-flg    =    spaces
                     go to stp-srt-inp-410.
      *                      *-----------------------------------------*
      *                      * Se allegato non integro                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * String                              *
      *                          *-------------------------------------*
           move      spaces               to   m-msg                  .
           string    "Fattura : "
                                delimited by   size
                     rf-ddx-num-doc
                                delimited by   spaces
                     " - con file 'XML' non integro!"
                                delimited by   size
                                          into m-msg                  .
      *                          *-------------------------------------*
      *                          * Messaggio di errore                 *
      *                          *-------------------------------------*
           move      "WR"                 to   m-ope                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                          *-------------------------------------*
      *                          * A riciclo                           *
      *                          *-------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-410.
      *                  *---------------------------------------------*
      *                  * Controllo se archivio gia' inviato          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo opera-  *
      *                      * zione                                   *
      *                      *                                         *
      *                      *  - 06 : Invio distinta                  *
      *                      *  - 07 : Re-invio distinta               *
      *                      *  - 08 : Re-invio dist. - solo scartati  *
      *                      *-----------------------------------------*
