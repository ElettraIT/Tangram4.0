      *                  *---------------------------------------------*
      *                  * Subroutine di determinazione Codice SDI e   *
      *                  * PEC destinatario                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Subroutine                              *
      *                      *-----------------------------------------*
           perform   stp-srt-inp-sdi-000  thru stp-srt-inp-sdi-999    .
      *                      *-----------------------------------------*
      *                      * Test su valori determinati              *
      *                      *-----------------------------------------*
           if        w-wrk-cod-sdi        =    "XXXXXXX"
                     go to stp-srt-inp-590.
           if        w-wrk-cod-sdi        =    "0000000" and
                     w-wrk-pec-snx        not  = "N"     and
                     w-wrk-pec-sdi        =    spaces
                     go to stp-srt-inp-580.
           if        w-wrk-cod-sdi        not  = spaces 
                     go to stp-srt-inp-590.
           if        w-wrk-pec-snx        =    "N" 
                     go to stp-srt-inp-590.
           if        w-wrk-pec-sdi        not  = spaces 
                     go to stp-srt-inp-590.
       stp-srt-inp-580.
      *                      *-----------------------------------------*
      *                      * Trattamento messaggio di errore         *
      *                      *-----------------------------------------*
           move      "Manca codice SDI e/o PEC"
                                          to   w-all-str-cat (10)     .
           perform   stp-srt-inp-err-000  thru stp-srt-inp-err-999    .


      *                      *-----------------------------------------*
      *                      * ___ ELIMINARE ___                       *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-600.





      *                      *-----------------------------------------*
      *                      * A riciclo                               *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-590.
      *                      *-----------------------------------------*
      *                      * Test se SDI Pubblica Amministrazione    *
      *                      *-----------------------------------------*
           move      w-wrk-cod-sdi        to   w-all-str-alf          .
           perform   all-str-lun-000      thru all-str-lun-999        .
           if        w-all-str-lun        not  = 006
                     go to stp-srt-inp-600.
      *                      *-----------------------------------------*
      *                      * Trattamento messaggio di errore         *
      *                      *-----------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      all "*"              to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *
           move      "Pubblica Amm. - necessaria Firma !"
                                          to   w-all-str-cat (10)     .
           perform   stp-srt-inp-err-000  thru stp-srt-inp-err-999    .
      *
           move      "WR"                 to   m-ope                  .
           move      all "*"              to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *                      *-----------------------------------------*
      *                      * Proseguimento                           *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-600.
       stp-srt-inp-600.
      *              *-------------------------------------------------*
      *              * Preparazione record di sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Chiave di sort                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice cliente                          *
      *                      *-----------------------------------------*
           move      rf-fit-cod-cli       to   srt-cod-cli            .
      *                      *-----------------------------------------*
      *                      * Codice cliente                          *
      *                      *-----------------------------------------*
           move      rf-fit-dpz-cli       to   srt-dpz-cli            .
       stp-srt-inp-640.
      *                  *---------------------------------------------*
      *                  * Composizione dati                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice SDI                              *
      *                      *-----------------------------------------*
           move      w-wrk-cod-sdi        to   srt-cod-sdi            .
      *                      *-----------------------------------------*
      *                      * Indirizzo di posta destinatario         *
      *                      *-----------------------------------------*
           move      w-wrk-pec-sdi        to   srt-eml-ind            .
      *                      *-----------------------------------------*
      *                      * Tipo indirizzo di posta destinatario    *
      *                      *-----------------------------------------*
           move      w-wrk-tip-eml        to   srt-eml-tip            .
      *
           if        w-wrk-pec-snx        =    "N"
                     move   "SDI"         to   srt-eml-tip            .
      *                      *-----------------------------------------*
      *                      * Record [fit]                            *
      *                      *-----------------------------------------*
           move      rf-fit               to   srt-rec-fit            .
       stp-srt-inp-700.
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-200.
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Subroutine di determinazione codice SDI e PEC destinata-  *
      *    * rio                                                       *
      *    *-----------------------------------------------------------*
       stp-srt-inp-sdi-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valori determinati              *
      *              *-------------------------------------------------*
           move      spaces               to   w-wrk-cod-sdi          .
           move      spaces               to   w-wrk-pec-sdi          .
           move      spaces               to   w-wrk-pec-snx          .
           move      spaces               to   w-wrk-tip-eml          .
       stp-srt-inp-sdi-100.
      *              *-------------------------------------------------*
      *              * Determinazione Codice SDI e PEC in base all'in- *
      *              * dicatore 'inoltro documenti'                    *
      *              *                                                 *
      *              * - 01 : alla sede                                *
      *              * - 02 : alla sede legale                         *
      *              * - 03 : alla dipendenza                          *
      *              *-------------------------------------------------*
           if        rf-fit-inl-dcm       =    01
                     go to stp-srt-inp-sdi-200
           else if   rf-fit-inl-dcm       =    02
                     go to stp-srt-inp-sdi-400
           else      go to stp-srt-inp-sdi-600.
       stp-srt-inp-sdi-200.
      *              *-------------------------------------------------*
      *              * Se inoltro alla 'Sede'                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione del codice destinatario in   *
      *                  * anagrafica cliente                          *
      *                  *---------------------------------------------*
           move      "C"                  to   w-let-arc-dcc-tle      .
           move      rf-fit-cod-cli       to   w-let-arc-dcc-cod      .
           move      spaces               to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                  *---------------------------------------------*
      *                  * Test su codice nazione                      *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-naz    =    "IT "
                     go to stp-srt-inp-sdi-220.
      *                  *---------------------------------------------*
      *                  * Se estero                                   *
      *                  *---------------------------------------------*
           move      w-let-arc-dcc-cpf    to   w-wrk-cod-sdi          .
           go to     stp-srt-inp-sdi-900.
       stp-srt-inp-sdi-220.
      *                  *---------------------------------------------*
      *                  * Se codice SDI a spazi: forzatura '0000000'  *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-cpf    =    spaces
                     move "0000000"       to   w-wrk-cod-sdi
                     go to stp-srt-inp-sdi-300.
      *                  *---------------------------------------------*
      *                  * Se codice SDI con indicatore di PEC non ne- *
      *                  * cessaria: uscita senza PEC                  *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-cpf
                    (08 : 01)             =    "N"
                     move "0000000"       to   w-wrk-cod-sdi
                     move "N"             to   w-wrk-pec-snx
                     go to stp-srt-inp-sdi-900.
      *                  *---------------------------------------------*
      *                  * Se codice SDI                               *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-cpf    not  = spaces   and
                     w-let-arc-dcc-cpf    not  = "0000000"
                     move w-let-arc-dcc-cpf
                                          to   w-wrk-cod-sdi
                     go to stp-srt-inp-sdi-900.
       stp-srt-inp-sdi-300.
      *                  *---------------------------------------------*
      *                  * Determinazione indirizzo PEC destinatario   *
      *                  *---------------------------------------------*
           move      "IE"                 to   d-con-arc-tip-ope      .
           move      02                   to   d-con-arc-tip-arc      .
           move      rf-fit-cod-cli       to   d-con-arc-cod-arc      .
           move      spaces               to   d-con-arc-dpz-arc      .
           move      "xml"                to   d-con-arc-tip-sel      .
           move      01                   to   d-con-arc-num-edr      .
           perform   con-arc-tip-cll-000  thru con-arc-tip-cll-999    .
      *                  *---------------------------------------------*
      *                  * Pec destinatario                            *
      *                  *---------------------------------------------*
           move      d-con-arc-num-con (1)
                                          to   w-wrk-pec-sdi          .
      *                  *---------------------------------------------*
      *                  * Test che l'indirizzo mail sia di tipo 'PEC' *
      *                  *---------------------------------------------*
           if        d-con-arc-tip-con (1)
                                          not  = "PEC"
                     move  spaces         to   w-wrk-pec-sdi          .   
      *                  *---------------------------------------------*
      *                  * Tipo email                                  *
      *                  *---------------------------------------------*
           move      d-con-arc-tip-con (1)
                                          to   w-wrk-tip-eml          .   
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-sdi-900.
       stp-srt-inp-sdi-400.
      *              *-------------------------------------------------*
      *              * Se inoltro alla 'Sede legale'                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Come per la 'Sede'                          *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-sdi-200.
       stp-srt-inp-sdi-600.
      *              *-------------------------------------------------*
      *              * Se inoltro alla 'Dipendenza'                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione del codice destinatario in   *
      *                  * anagrafica dipendenza del cliente           *
      *                  *---------------------------------------------*
           if        rf-fit-dpz-cli       =    spaces
                     move  "C"            to   w-let-arc-dcc-tle
           else      move  "D"            to   w-let-arc-dcc-tle      .
      *
           move      rf-fit-cod-cli       to   w-let-arc-dcc-cod      .
           move      rf-fit-dpz-cli       to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
      *                  *---------------------------------------------*
      *                  * Test su codice nazione                      *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-naz    =    "IT "
                     go to stp-srt-inp-sdi-650.
      *                  *---------------------------------------------*
      *                  * Se estero                                   *
      *                  *---------------------------------------------*
           move      w-let-arc-dcc-cpf    to   w-wrk-cod-sdi          .
           go to     stp-srt-inp-sdi-900.
       stp-srt-inp-sdi-650.
      *                  *---------------------------------------------*
      *                  * Se codice SDI a spazi: forzatura '0000000'  *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-cpf    =    spaces
                     move "0000000"       to   w-wrk-cod-sdi
                     go to stp-srt-inp-sdi-700.
      *                  *---------------------------------------------*
      *                  * Se codice SDI con indicatore di PEC non ne- *
      *                  * cessaria: uscita senza PEC                  *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-cpf
                    (08 : 01)             =    "N"
                     move "0000000"       to   w-wrk-cod-sdi
                     move "N"             to   w-wrk-pec-snx
                     go to stp-srt-inp-sdi-900.
      *                  *---------------------------------------------*
      *                  * Se codice SDI                               *
      *                  *---------------------------------------------*
           if        w-let-arc-dcc-cpf    not  = spaces   and
                     w-let-arc-dcc-cpf    not  = "0000000"
                     move w-let-arc-dcc-cpf
                                          to   w-wrk-cod-sdi
                     go to stp-srt-inp-sdi-900.
       stp-srt-inp-sdi-700.
      *                  *---------------------------------------------*
      *                  * Determinazione indirizzo PEC destinatario   *
      *                  *---------------------------------------------*
           move      "IE"                 to   d-con-arc-tip-ope      .
           move      02                   to   d-con-arc-tip-arc      .
           move      rf-fit-cod-cli       to   d-con-arc-cod-arc      .
           move      rf-fit-dpz-cli       to   d-con-arc-dpz-arc      .
           move      "xml"                to   d-con-arc-tip-sel      .
           move      01                   to   d-con-arc-num-edr      .
           perform   con-arc-tip-cll-000  thru con-arc-tip-cll-999    .
      *                  *---------------------------------------------*
      *                  * Pec destinatario                            *
      *                  *---------------------------------------------*
           move      d-con-arc-num-con (1)
                                          to   w-wrk-pec-sdi          .
      *                  *---------------------------------------------*
      *                  * Test che l'indirizzo mail sia di tipo 'PEC' *
      *                  *---------------------------------------------*
           if        d-con-arc-tip-con (1)
                                          not  = "PEC"
                     move  spaces         to   w-wrk-pec-sdi          .   
      *                  *---------------------------------------------*
      *                  * Tipo email                                  *
      *                  *---------------------------------------------*
           move      d-con-arc-tip-con (1)
                                          to   w-wrk-tip-eml          .   
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-sdi-900.
       stp-srt-inp-sdi-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-sdi-999.
       stp-srt-inp-sdi-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Subroutine per errori da anagrafica clienti               *
      *    *-----------------------------------------------------------*
       stp-srt-inp-err-000.
      *              *-------------------------------------------------*
      *              * Editing codice cliente                          *
      *              *-------------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      07                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<B"                 to   p-edm                  .
           move      rf-fit-cod-cli       to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-all-str-cat (2)      .
      *              *-------------------------------------------------*
      *              * Editing numero documento                        *
      *              *-------------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      06                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      rf-fit-num-doc
                    (06 : 06)             to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-all-str-cat (6)      .
      *              *-------------------------------------------------*
      *              * Editing data documento                          *
      *              *-------------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "D"                  to   p-tip                  .
           move      rf-fit-dat-doc       to   p-dat                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-all-str-cat (8)      .
      *              *-------------------------------------------------*
      *              * Assemblaggio                                    *
      *              *-------------------------------------------------*
           move      80                   to   w-all-str-lun          .
           move      10                   to   w-all-str-num          .
           move      "Cliente"            to   w-all-str-cat (1)      .
           move      "-"                  to   w-all-str-cat (3)      .
           move      rf-fit-cod-tmo       to   w-all-str-cat (4)      .
           move      "Nr."                to   w-all-str-cat (5)      .
           move      "del"                to   w-all-str-cat (7)      .
           move      ":"                  to   w-all-str-cat (9)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *              *-------------------------------------------------*
      *              * Messaggio                                       *
      *              *-------------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      w-all-str-alf        to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       stp-srt-inp-err-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-err-999.
       stp-srt-inp-err-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Subroutine di determinazione se fattura gia' in distinta  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-ddx-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione preliminare                     *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-dst-ctr-ele      .
       stp-srt-inp-ddx-100.
      *              *-------------------------------------------------*
      *              * Start su [ddx]                                  *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DOCDST    "         to   f-key                  .
           move      w-det-dst-num-prt    to   rf-ddx-prt-doc         .
           move      zero                 to   rf-ddx-num-dst         .
           move      zero                 to   rf-ddx-num-prg         .
           move      "pgm/fat/fls/ioc/obj/iofddx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddx                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : ad uscita                 *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-ddx-900.
       stp-srt-inp-ddx-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale [ddx]                       *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/fat/fls/ioc/obj/iofddx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-ddx                 .
      *                  *---------------------------------------------*
      *                  * Se fine file : ad uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-ddx-900.
       stp-srt-inp-ddx-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-ddx-prt-doc       not  = w-det-dst-num-prt
                     go to stp-srt-inp-ddx-900.
       stp-srt-inp-ddx-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
       stp-srt-inp-ddx-600.
      *              *-------------------------------------------------*
      *              * Incremento contatore                            *
      *              *-------------------------------------------------*
           add       1                    to   w-det-dst-ctr-ele      .
       stp-srt-inp-ddx-800.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-ddx-200.
       stp-srt-inp-ddx-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-ddx-999.
       stp-srt-inp-ddx-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Subroutine di determinazione se documento gia' esportato  *
      *    * con ESTEROMETRO                                           *
      *    *                                                           *
      *    * ___ DA ELIMINARE A FINE USO ESTEROMETRO ___               *
      *    *-----------------------------------------------------------*
       stp-srt-inp-est-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-est-flg-exp      .
      *              *-------------------------------------------------*
      *              * Test se presenti numero e data per la lettura   *
      *              *-------------------------------------------------*
           if        rf-fit-dat-doc       =    zero or
                     rf-fit-prt-mgd       =    zero
                     go to stp-srt-inp-est-900.
       stp-srt-inp-est-100.
      *              *-------------------------------------------------*
      *              * Normalizzazione record [mgi]                    *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofmgi"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgi                 .
      *              *-------------------------------------------------*
      *              * Lettura movimento iva                           *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "DATPRT"             to   f-key                  .
           move      rf-fit-dat-doc       to   rf-mgi-dat-reg         .
           move      rf-fit-prt-mgd       to   rf-mgi-num-prt         .
           move      "pgm/cge/fls/ioc/obj/iofmgi"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mgi                 .
      *                  *---------------------------------------------*
      *                  * Test su esito lettura                       *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-est-900.
       stp-srt-inp-est-200.
      *              *-------------------------------------------------*
      *              * Test su 'alx-exp'                               *
      *              *-------------------------------------------------*
           if        rf-mgi-alx-exp
                    (01 : 01)             =    "#"
                     move  "#"            to   w-det-est-flg-exp      .   
       stp-srt-inp-est-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-est-999.
       stp-srt-inp-est-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Start iniziale                     *
      *    *-----------------------------------------------------------*
       prn-str-ini-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-sub      .
       prn-str-ini-300.
      *              *-------------------------------------------------*
      *              * Normalizzazione contatori elementi              *
      *              *-------------------------------------------------*
           move      zero                 to   w-cix-num-ele          .
           move      zero                 to   w-cix-gen-ele          .
       prn-str-ini-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Messaggio per nessuna registraz.   *
      *    *-----------------------------------------------------------*
       prn-nes-ela-000.
           move      "WR"                 to   m-ope                  .
           move      "Nessun elemento entro i limiti assegnati !"
                                          to   m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
       prn-nes-ela-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Lettura sequenziale                *
      *    *-----------------------------------------------------------*
       prn-let-seq-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
