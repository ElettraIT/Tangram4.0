                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Imposta                                 *
      *                      *-----------------------------------------*
           move      rf-fit-iva-imp
                    (w-stp-tot-doc-ctr)   to   w-stp-imp-rig-imp      .
           move      w-tot-doc-dpf        to   w-stp-imp-rig-dcv      .
           move      p-lin                to   w-stp-imp-rig-lin      .
           move      055                  to   w-stp-imp-rig-pos      .
           perform   stp-imp-rig-000      thru stp-imp-rig-999        .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     stp-tot-doc-560.
       stp-tot-doc-540.
      *                      *-----------------------------------------*
      *                      * Codice iva esente                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Lettura record [zci]                *
      *                          *-------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODIVA    "         to   f-key                  .
           move      rf-fit-iva-cod
                    (w-stp-tot-doc-ctr)   to   rf-zci-cod-iva         .
           move      "pgm/cge/fls/ioc/obj/iofzci"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zci                 .
           if        f-sts                not  = e-not-err
                     move  all "."        to   rf-zci-des-doc         .
      *                          *-------------------------------------*
      *                          * Stampa                              *
      *                          *-------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      15                   to   p-car                  .
           move      051                  to   p-pos                  .
           move      rf-zci-des-doc       to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-tot-doc-560.
      *                      *-----------------------------------------*
      *                      * Riciclo su castelletto iva              *
      *                      *-----------------------------------------*
           go to     stp-tot-doc-510.
       stp-tot-doc-600.
      *              *-------------------------------------------------*
      *              * Salvataggio numero linea dopo stampa castellet- *
      *              * to iva                                          *
      *              *-------------------------------------------------*
           move      p-lin                to   w-sav-lin-iva          .
      *              *-------------------------------------------------*
      *              * Determinazione del numero linea piu' alto tra   *
      *              * quelli salvati                                  *
      *              *-------------------------------------------------*
           move      w-sav-lin-tot        to   p-lin                  .
           if        w-sav-lin-scd        >    p-lin
                     move  w-sav-lin-scd  to   p-lin                  .
           if        w-sav-lin-iva        >    p-lin
                     move  w-sav-lin-iva  to   p-lin                  .
      *              *-------------------------------------------------*
      *              * Determinazione del numero di interlinee da ese- *
      *              * guire                                           *
      *              *-------------------------------------------------*
           subtract  w-sav-lin-ini        from p-lin                  .
      *              *-------------------------------------------------*
      *              * Esecuzione numero interlinee cosi' determinato  *
      *              *-------------------------------------------------*
           move      "L+"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-tot-doc-999.
           exit.

      *    *===========================================================*
      *    * Stampa importo in riga                                    *
      *    *-----------------------------------------------------------*
       stp-imp-rig-000.
      *              *-------------------------------------------------*
      *              * Stampa                                          *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           if        w-stp-imp-rig-imp    >    999999999 or
                     w-stp-imp-rig-imp    <   -999999999
                     move  11             to   p-car
           else      move  09             to   p-car                  .
           move      w-stp-imp-rig-dcv    to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           if        w-stp-imp-rig-imp    >    999999999 or
                     w-stp-imp-rig-imp    <   -999999999
                     move  spaces         to   p-edm
           else      move  "G"            to   p-edm                  .
           move      w-stp-imp-rig-lin    to   p-lin                  .
           move      w-stp-imp-rig-pos    to   p-pos                  .
           if        w-stp-imp-rig-dcv    =    zero
                     add   1              to   p-pos                  .
           move      w-stp-imp-rig-imp    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-imp-rig-999.
           exit.

      *    *===========================================================*
      *    * Stampa valori totali                                      *
      *    *-----------------------------------------------------------*
       stp-val-tot-000.
      *              *-------------------------------------------------*
      *              * Composizione stringa                            *
      *              *-------------------------------------------------*
           move      spaces               to   w-stp-val-tot-x60      .
           move      1                    to   w-stp-val-tot-pnt      .
      *              *-------------------------------------------------*
      *              * Prompt                                          *
      *              *-------------------------------------------------*
           string    w-stp-val-tot-pmt
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
      *              *-------------------------------------------------*
      *              * Allineamento all'ultimo non-blank               *
      *              *-------------------------------------------------*
           move      zero                 to   w-stp-val-tot-ctr      .
           inspect   w-stp-val-tot-x60    
                                      tallying w-stp-val-tot-ctr
                                          for  trailing spaces        .
           subtract  w-stp-val-tot-ctr    from 60
                                        giving w-stp-val-tot-pnt      .
           add       1                    to   w-stp-val-tot-pnt      .
      *              *-------------------------------------------------*
      *              * Totale documento in valuta base se documento in *
      *              * valuta                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da stampare                         *
      *                  *---------------------------------------------*
           if        w-stp-val-tot-vlt    =    c-sgl
                     go to stp-val-tot-100.
           if        w-stp-val-tot-tot    =    zero
                     go to stp-val-tot-100.
      *                  *---------------------------------------------*
      *                  * Editing                                     *
      *                  *---------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           move      11                   to   p-car                  .
           move      c-dec                to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      "G<"                 to   p-edm                  .
           move      w-stp-val-tot-tot    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * String                                      *
      *                  *---------------------------------------------*
           string    " ("
                                delimited by   size
                     c-sgl
                                delimited by   size
                     " "
                                delimited by   size
                     p-edt
                                delimited by   spaces
                     ")"
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
       stp-val-tot-100.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda che il documento sia in    *
      *              * valuta o no                                     *
      *              *-------------------------------------------------*
           if        w-stp-val-tot-vlt    not  = c-sgl
                     go to stp-val-tot-200
           else      go to stp-val-tot-300.
       stp-val-tot-200.
      *              *-------------------------------------------------*
      *              * Se documento in valuta                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Sigla valuta                                *
      *                  *---------------------------------------------*
           string    " "
                                delimited by   size
                     w-stp-val-tot-vlt
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
      *                  *---------------------------------------------*
      *                  * Due punti di separazione                    *
      *                  *---------------------------------------------*
           string    " : "
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
      *                  *---------------------------------------------*
      *                  * Totale in valuta                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing                                 *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           if        w-stp-val-tot-tiv    >    999999999 or
                     w-stp-val-tot-tiv    <   -999999999
                     move  11             to   p-car
           else      move  09             to   p-car                  .
           move      w-stp-val-tot-dcv    to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           if        w-stp-val-tot-tiv    >    999999999 or
                     w-stp-val-tot-tiv    <   -999999999
                     move  spaces         to   p-edm
           else      move  "G"            to   p-edm                  .
           move      w-stp-val-tot-tiv    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * String                                  *
      *                      *-----------------------------------------*
           string    p-edt
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
      *                  *---------------------------------------------*
      *                  * A stampa stringa composta                   *
      *                  *---------------------------------------------*
           go to     stp-val-tot-500.
       stp-val-tot-300.
      *              *-------------------------------------------------*
      *              * Se documento in valuta base                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Due punti di separazione                    *
      *                  *---------------------------------------------*
           string    " : "
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
      *                  *---------------------------------------------*
      *                  * Totale in valuta base                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing                                 *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           if        w-stp-val-tot-tot    >    999999999 or
                     w-stp-val-tot-tot    <   -999999999
                     move  11             to   p-car
           else      move  09             to   p-car                  .
           move      c-dec                to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           if        w-stp-val-tot-tot    >    999999999 or
                     w-stp-val-tot-tot    <   -999999999
                     move  spaces         to   p-edm
           else      move  "G"            to   p-edm                  .
           move      w-stp-val-tot-tot    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * String                                  *
      *                      *-----------------------------------------*
           string    p-edt
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
      *                  *---------------------------------------------*
      *                  * A stampa stringa composta                   *
      *                  *---------------------------------------------*
           go to     stp-val-tot-500.
       stp-val-tot-500.
      *              *-------------------------------------------------*
      *              * Riposizionamento puntatore                      *
      *              *-------------------------------------------------*
           move      zero                 to   w-stp-val-tot-ctr      .
           inspect   w-stp-val-tot-x60    
                                      tallying w-stp-val-tot-ctr
                                          for  trailing spaces        .
           subtract  w-stp-val-tot-ctr    from 60
                                        giving w-stp-val-tot-pnt      .
           add       1                    to   w-stp-val-tot-pnt      .
      *              *-------------------------------------------------*
      *              * Stampa stringa composta                         *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      w-stp-val-tot-pnt    to   p-car                  .
           move      w-stp-val-tot-lin    to   p-lin                  .
           subtract  w-stp-val-tot-pnt    from 127
                                        giving p-pos                  .
           add       2                    to   p-pos                  .
           move      w-stp-val-tot-x60    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-val-tot-999.
           exit.

      *    *===========================================================*
      *    * Aggiornamento numerazione [ftilfd]                        *
      *    *-----------------------------------------------------------*
       agg-fti-lfd-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record [ftilfd]                 *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftilfd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-lfd             .
      *              *-------------------------------------------------*
      *              * Determinazione secolo/anno attuali              *
      *              *-------------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Get record [ftilfd]                             *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      s-saa                to   rn-fti-lfd-scl-ann     .
           move      "pgm/fat/num/ioc/obj/inftilfd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-lfd             .
      *              *-------------------------------------------------*
      *              * Test su esito operazione                        *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to agg-fti-lfd-300.
       agg-fti-lfd-200.
      *              *-------------------------------------------------*
      *              * Se record non trovato                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     agg-fti-lfd-999.
       agg-fti-lfd-300.
      *              *-------------------------------------------------*
      *              * Se record trovato                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se il progressivo lotto di fatturazione     *
      *                  * differita ottenuto non e' uguale a quello   *
      *                  * letto in ipc : uscita                       *
      *                  *---------------------------------------------*
           if        rn-fti-lfd-num-lfd   not  = w-ipc-dsl-num-lfd
                     go to agg-fti-lfd-999.
      *                  *---------------------------------------------*
      *                  * Status di avanzamento : eseguito            *
      *                  *---------------------------------------------*
           move      spaces               to   rn-fti-lfd-sts-avz     .
      *                  *---------------------------------------------*
      *                  * Aggiornamento record [ftilfd]               *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftilfd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-lfd             .
      *                  *---------------------------------------------*
      *                  * Rilascio record [ftilfd]                    *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftilfd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-lfd             .
      *                  *---------------------------------------------*
      *                  * Se errori si ripete l'operazione            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-fti-lfd-000.
       agg-fti-lfd-999.
           exit.

      *    *===========================================================*
      *    * Routine di lettura archivio [lic]                         *
      *    *-----------------------------------------------------------*
       let-arc-lic-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione marker di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-let-arc-lic-flg      .
      *              *-------------------------------------------------*
      *              * Test se codice a zero                           *
      *              *-------------------------------------------------*
           if        w-let-arc-lic-cod    =    zero
                     go to let-arc-lic-500.
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLI"             to   f-key                  .
           move      w-let-arc-lic-cod    to   rf-lic-cod-cli         .
           move      "pgm/cge/fls/ioc/obj/ioflic"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lic                 .
           if        f-sts                not  = e-not-err
                     go to let-arc-lic-400.
       let-arc-lic-200.
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori                          *
      *              *-------------------------------------------------*
           move      rf-lic-drf-ini       to   w-let-arc-lic-dri      .
           move      rf-lic-drf-fin       to   w-let-arc-lic-drf      .
           move      rf-lic-imp-plf       to   w-let-arc-lic-plf      .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-arc-lic-999.
       let-arc-lic-400.
      *              *-------------------------------------------------*
      *              * Azioni per record non trovato                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-let-arc-lic-flg      .
           go to     let-arc-lic-520.
       let-arc-lic-500.
      *              *-------------------------------------------------*
      *              * Normalizzazione work area                       *
      *              *-------------------------------------------------*
       let-arc-lic-520.
           move      zero                 to   w-let-arc-lic-dri      .
           move      zero                 to   w-let-arc-lic-drf      .
           move      zero                 to   w-let-arc-lic-plf      .
       let-arc-lic-999.
           exit.

      *    *===========================================================*
      *    * Determinazione pathname completo per il file di appoggio  *
      *    * per Bolle da Fatturare                                    *
      *    *-----------------------------------------------------------*
       det-pat-fde-000.
      *              *-------------------------------------------------*
      *              * Determinazione nome del direttorio di base      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Estrazione pathname di base per spool-files *
      *                  * per richiesta al modulo di segreteria       *
      *                  *---------------------------------------------*
           move      ".S"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Memorizzazione del pathname ottenuto        *
      *                  *---------------------------------------------*
           move      s-pat                to   w-det-pat-fde-dir      .
       det-pat-fde-300.
      *              *-------------------------------------------------*
      *              * Determinazione nome del file                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione anno del lotto di fattura-   *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           move      w-det-pat-fde-lfd
                    (02 : 02)             to   w-det-pat-fde-lfa      .
      *                  *---------------------------------------------*
      *                  * Determinazione numero del lotto di fattura- *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           move      w-det-pat-fde-lfd
                    (04 : 04)             to   w-det-pat-fde-lfn      .
      *                  *---------------------------------------------*
      *                  * Composizione di una stringa composta come   *
      *                  * segue :                                     *
      *                  *                                             *
      *                  *        Fnnnnbb.FDE                          *
      *                  *                                             *
      *                  * dove : F          = prefisso fisso          *
      *                  *        nnnn       = progressivo lotto di    *
      *                  *                     fatturazione            *
      *                  *                     la presentazione        *
      *                  *        bb         = anno del lotto di fat-  *
      *                  *                     turazione               *
      *                  *        .FDE       = estensione fissa        *
      *                  *                                             *
      *                  *---------------------------------------------*
           move      spaces               to   w-det-pat-fde-nam      .
           string    "F"        delimited by   size
                     w-det-pat-fde-lfn
                                delimited by   size
                     w-det-pat-fde-lfa
                                delimited by   size
                     ".FDE"     delimited by   size
                                          into w-det-pat-fde-nam      .
       det-pat-fde-600.
      *              *-------------------------------------------------*
      *              * Determinazione pathname completo del file       *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-pat-fde-pat      .
           string    w-det-pat-fde-dir
                                delimited by   spaces
                     "/"
                                delimited by   size
                     w-det-pat-fde-nam
                                delimited by   spaces
                                          into w-det-pat-fde-pat      .
       det-pat-fde-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale documento                           *
      *    *-----------------------------------------------------------*
       det-tot-doc-000.
      *              *-------------------------------------------------*
      *              * Azzeramento totalizzatori                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-doc-ibl      .
           move      zero                 to   w-det-tot-doc-imp      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione castelletto iva              *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-doc-ctr      .
       det-tot-doc-100.
           add       1                    to   w-det-tot-doc-ctr      .
           if        w-det-tot-doc-ctr    >    6
                     go to det-tot-doc-900.
           if        rf-fit-iva-cod
                    (w-det-tot-doc-ctr)   =    zero
                     go to det-tot-doc-100.
      *                  *---------------------------------------------*
      *                  * Imponibile                                  *
      *                  *---------------------------------------------*
           add       rf-fit-iva-ibl
                    (w-det-tot-doc-ctr)   to   w-det-tot-doc-ibl      .
      *                  *---------------------------------------------*
      *                  * Imposta                                     *
      *                  *---------------------------------------------*
           add       rf-fit-iva-imp
                    (w-det-tot-doc-ctr)   to   w-det-tot-doc-imp      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-tot-doc-100.
       det-tot-doc-900.
      *              *-------------------------------------------------*
      *              * Totale documento                                *
      *              *-------------------------------------------------*
           add       w-det-tot-doc-ibl
                     w-det-tot-doc-imp  giving w-det-tot-doc-tot      .
       det-tot-doc-999.
           exit.

      *    *===========================================================*
      *    * Descrizione in lingua per la stampa di : spese per la     *
      *    * fatturazione e sconti in chiusura e pagamento             *
      *    *-----------------------------------------------------------*
       det-des-zsf-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore in uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-des-zsf-des      .
       det-des-zsf-100.
      *              *-------------------------------------------------*
      *              * Normalizzazione record [zsf]                    *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofzsf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zsf                 .
      *              *-------------------------------------------------*
      *              * Tentativo di lettura della descrizione con il   *
      *              * codice lingua del cliente                       *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODSPF    "         to   f-key                  .
           move      w-det-des-zsf-cod    to   rf-zsf-num-spf         .
           move      w-det-des-zsf-lng    to   rf-zsf-cod-lng         .
           move      "pgm/dcc/fls/ioc/obj/iofzsf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zsf                 .
      *                  *---------------------------------------------*
      *                  * Se valore trovato : uscita con il valore    *
      *                  * letto                                       *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-des-zsf-200.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valore letto                *
      *                  *---------------------------------------------*
           move      rf-zsf-des-stp       to   w-det-des-zsf-des      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-des-zsf-999.
       det-des-zsf-200.
      *              *-------------------------------------------------*
      *              * Tentativo di lettura della descrizione con il   *
      *              * codice lingua per l'Italia                      *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODSPF    "         to   f-key                  .
           move      w-det-des-zsf-cod    to   rf-zsf-num-spf         .
           move      "I  "                to   rf-zsf-cod-lng         .
           move      "pgm/dcc/fls/ioc/obj/iofzsf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zsf                 .
      *                  *---------------------------------------------*
      *                  * Se valore trovato : uscita con il valore    *
      *                  * letto                                       *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-des-zsf-400.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valore letto                *
      *                  *---------------------------------------------*
           move      rf-zsf-des-stp       to   w-det-des-zsf-des      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-des-zsf-999.
       det-des-zsf-400.
      *              *-------------------------------------------------*
      *              * Uscita con valore a spaces                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-des-zsf-999.
       det-des-zsf-999.
           exit.

      *    *===========================================================*
      *    * Routine di conversione da altra valuta a valuta base      *
      *    *-----------------------------------------------------------*
           copy      "swd/std/prg/cpy/wcvsvlt0.cps"                   .

      *    *===========================================================*
      *    * Determinazione protocollo ordine cliente                  *
      *    *-----------------------------------------------------------*
       det-prt-oct-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore di uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-prt-oct-prt      .
      *              *-------------------------------------------------*
      *              * Start su [oct]                                  *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "IDEDOC    "         to   f-key                  .
           move      w-det-prt-oct-dat    to   rf-oct-dat-doc         .
           move      w-det-prt-oct-dpz    to   rf-oct-cod-dpz         .
           move      w-det-prt-oct-num    to   rf-oct-num-doc         .
           move      w-det-prt-oct-tmo    to   rf-oct-tmo-orc         .
           move      zero                 to   rf-oct-num-prt         .
           move      "pgm/orc/fls/ioc/obj/iofoct"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oct                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : ad uscita                 *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-prt-oct-900.
       det-prt-oct-100.
      *              *-------------------------------------------------*
      *              * Read next su [oct]                              *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/orc/fls/ioc/obj/iofoct"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-oct                 .
      *                  *---------------------------------------------*
      *                  * Se fine file : ad uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-prt-oct-900.
       det-prt-oct-200.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-oct-dat-doc       not  = w-det-prt-oct-dat or
                     rf-oct-cod-dpz       not  = w-det-prt-oct-dpz or
                     rf-oct-num-doc       not  = w-det-prt-oct-num or
                     rf-oct-tmo-orc       not  = w-det-prt-oct-tmo
                     go to det-prt-oct-900.
       det-prt-oct-400.
      *              *-------------------------------------------------*
      *              * Bufferizzazione numero protocollo               *
      *              *-------------------------------------------------*
           move      rf-oct-num-prt       to   w-det-prt-oct-prt      .
       det-prt-oct-500.
      *              *-------------------------------------------------*
      *              * Riciclo a record successivo                     *
      *              *-------------------------------------------------*
           go to     det-prt-oct-100.
       det-prt-oct-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-prt-oct-999.
       det-prt-oct-999.
           exit.

