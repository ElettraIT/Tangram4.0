      *    *===========================================================*
      *    * Stampa riga corpo documento                               *
      *    *                                                           *
      *    * Subroutine per la stampa eventuale della % di margine al- *
      *    * l'estrema destra dell'area dedicata agli sconti che ven-  *
      *    * gono comunque compattati verso sinistra                   *
      *    *-----------------------------------------------------------*
       stp-rig-cor-pmg-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione della personalizzazione  *
      *              *-------------------------------------------------*
           if        w-prs-cpv-tcn        not  = 01 and
                     w-prs-cpv-tcn        not  = 02 and
                     w-prs-cpv-tcn        not  = 05
                     go to stp-rig-cor-pmg-900.
       stp-rig-cor-pmg-100.
      *              *-------------------------------------------------*
      *              * Stampa della % di margine ed eventuale scosta-  *
      *              * mento                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-mrg-lrd-pmr      .
       stp-rig-cor-pmg-120.
      *                  *---------------------------------------------*
      *                  * Determinazione costo medio in base a perso- *
      *                  * nalizzazione                                *
      *                  *---------------------------------------------*
           move      "VM"                 to   d-vun-mag-tip-ope      .
           move      w-prs-cpv-tcn        to   d-vun-mag-tip-val      .
           move      rf-fir-bcc-dat       to   d-vun-mag-dat-val      .
           move      01                   to   d-vun-mag-tip-mag      .
           move      rf-fir-num-pro       to   d-vun-mag-num-mag      .
           perform   det-vun-mag-cll-000  thru det-vun-mag-cll-999    .
      *                      *-----------------------------------------*
      *                      * Test su esito determinazione            *
      *                      *-----------------------------------------*
           if        d-vun-mag-val-uni    not  = zero
                     go to stp-rig-cor-pmg-200.
       stp-rig-cor-pmg-140.
      *                  *---------------------------------------------*
      *                  * Determinazione costo ultimo                 *
      *                  *---------------------------------------------*
           move      "VM"                 to   d-vun-mag-tip-ope      .
           move      0002                 to   d-vun-mag-tip-val      .
           move      rf-fir-bcc-dat       to   d-vun-mag-dat-val      .
           move      01                   to   d-vun-mag-tip-mag      .
           move      rf-fir-num-pro       to   d-vun-mag-num-mag      .
           perform   det-vun-mag-cll-000  thru det-vun-mag-cll-999    .
       stp-rig-cor-pmg-200.
      *                  *---------------------------------------------*
      *                  * Test se margine determinabile               *
      *                  *---------------------------------------------*
           if        d-vun-mag-val-uni    =    zero or
                     rf-fir-prz-net       =    zero
                     go to stp-rig-cor-pmg-500.
      *                  *---------------------------------------------*
      *                  * Aggiustamento prezzo di vendita             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Prezzo netto in work di comodo          *
      *                      *-----------------------------------------*
           move      rf-fir-prz-net       to   w-det-mrg-lrd-wpp      .
      *                      *-----------------------------------------*
      *                      * Conversione da valuta di espressione    *
      *                      * prezzo di vendita a valuta base         *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se da eseguire                 *
      *                          *-------------------------------------*
           if        rf-fir-sgl-vpp       =    c-sgl
                     go to stp-rig-cor-pmg-220.
      *                          *-------------------------------------*
      *                          * Conversione da valuta di espressio- *
      *                          * ne prezzo a valuta base             *
      *                          *-------------------------------------*
           move      rf-fir-sgl-vpp       to   w-cvs-vlt-sgl          .
           move      rf-fir-dec-vpp       to   w-cvs-vlt-dec          .
           move      rf-fir-tdc-vpp       to   w-cvs-vlt-tdc          .
           move      rf-fir-cdc-vpp       to   w-cvs-vlt-cdc          .
           move      w-det-mrg-lrd-wpp    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
      *                              *---------------------------------*
      *                              * Bufferizzazione valore determi- *
      *                              * nato                            *
      *                              *---------------------------------*
           move      w-cvs-vlt-avb        to   w-det-mrg-lrd-wpp      .
       stp-rig-cor-pmg-220.
      *                  *---------------------------------------------*
      *                  * Spostamento in area di comodo con 2 decima- *
      *                  * li                                          *
      *                  *---------------------------------------------*
           move      w-det-mrg-lrd-wpp    to   w-det-mrg-lrd-9v2      .
           if        rf-fir-dec-prz       =    1
                     divide 10            into w-det-mrg-lrd-9v2
           else if   rf-fir-dec-prz       =    2
                     divide 100           into w-det-mrg-lrd-9v2
           else if   rf-fir-dec-prz       =    3
                     divide 1000          into w-det-mrg-lrd-9v2      .
      *                  *---------------------------------------------*
      *                  * Determinazione valore scostamento           *
      *                  *---------------------------------------------*
           move      d-vun-mag-val-uni    to   w-det-mrg-lrd-wvu      .
      *                  *---------------------------------------------*
      *                  * Applicazione decimali gestione magazzino    *
      *                  *---------------------------------------------*
           divide    100                  into w-det-mrg-lrd-wvu      .
      *                  *---------------------------------------------*
      *                  * Se la riga in corso di trattamento prevede  *
      *                  * l'espressione del prezzo per 'n' unita', si *
      *                  * deve adeguare il costo di magazzino per il  *
      *                  * confronto                                   *
      *                  *---------------------------------------------*
           if        w-prs-arg-mag-ecu    =    rf-fir-flg-puq
                     go to stp-rig-cor-pmg-260.
       stp-rig-cor-pmg-240.
           if        rf-fir-flg-puq       =    "D"
                     multiply 10          by   w-det-mrg-lrd-wvu
           else if   rf-fir-flg-puq       =    "C"
                     multiply 100         by   w-det-mrg-lrd-wvu
           else if   rf-fir-flg-puq       =    "K"
                     multiply 1000        by   w-det-mrg-lrd-wvu      .
       stp-rig-cor-pmg-260.
      *                  *---------------------------------------------*
      *                  * Calcolo                                     *
      *                  *---------------------------------------------*
           subtract  w-det-mrg-lrd-wvu    from w-det-mrg-lrd-9v2
                                        giving w-det-mrg-lrd-vsc      .
      *                  *---------------------------------------------*
      *                  * Determinazione percentuale scostamento      *
      *                  *---------------------------------------------*
           multiply  100                  by   w-det-mrg-lrd-vsc      .
           divide    w-det-mrg-lrd-9v2    into w-det-mrg-lrd-vsc
                                        giving w-det-mrg-lrd-pmr
                                               rounded                .
       stp-rig-cor-pmg-300.
      *                  *---------------------------------------------*
      *                  * Stampa % margine                            *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      03                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      "<B"                 to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      108                  to   p-pos                  .
           move      w-det-mrg-lrd-pmr    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-rig-cor-pmg-320.
      *                  *---------------------------------------------*
      *                  * Stampa eventuale segnale di costo ultimo    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da stampare                     *
      *                      *-----------------------------------------*
           if        d-vun-mag-tip-val    not  = 0002
                     go to stp-rig-cor-pmg-400.
      *                      *-----------------------------------------*
      *                      * Stampa                                  *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      01                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      107                  to   p-pos                  .
           move      "u"                  to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-rig-cor-pmg-400.
      *                  *---------------------------------------------*
      *                  * Stampa eventuale segnale di scostamento     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da stampare                     *
      *                      *-----------------------------------------*
           if        w-det-mrg-lrd-pmr    not  < w-prs-cpv-pmg
                     go to stp-rig-cor-pmg-500.
      *                      *-----------------------------------------*
      *                      * Stampa                                  *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      01                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      111                  to   p-pos                  .
           move      "*"                  to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-rig-cor-pmg-500.
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     stp-rig-cor-pmg-900.
       stp-rig-cor-pmg-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-rig-cor-pmg-999.
       stp-rig-cor-pmg-999.
           exit.

