      *    *-----------------------------------------------------------*
       upd-rec-idv-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione del record                      *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/fat/fls/ioc/obj/iofidv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-idv                 .
       upd-rec-idv-100.
      *              *-------------------------------------------------*
      *              * Lettura, con lock, del record                   *
      *              *-------------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "SRGTRG "            to   f-key                  .
           move      srt-tip-dsr          to   rf-idv-tip-dsr         .
           move      srt-prt-dsr          to   rf-idv-prt-dsr         .
           move      srt-prg-dsr          to   rf-idv-prg-dsr         .
           move      srt-tip-dtr          to   rf-idv-tip-dtr         .
           move      srt-prt-dtr          to   rf-idv-prt-dtr         .
           move      srt-prg-dtr          to   rf-idv-prg-dtr         .
           move      "pgm/fat/fls/ioc/obj/iofidv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-idv                 .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'esito lettura     *
      *                  *---------------------------------------------*
           if        f-sts                =    e-not-err
                     go to upd-rec-idv-300.
       upd-rec-idv-200.
      *              *-------------------------------------------------*
