           move      "UP"                 to   f-ope                  .
           move      "pgm/fat/fls/ioc/obj/iofidv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-idv                 .
      *                  *---------------------------------------------*
