      *              *-------------------------------------------------*
           move      zero                 to   w-det-prt-bol-prt      .
       det-prt-bol-050.
      *              *-------------------------------------------------*
      *              * Normalizzazione [zbi]                           *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofzbi"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zbi                 .
      *              *-------------------------------------------------*
      *              * Lettura per codice                              *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODTMB"             to   f-key                  .
           move      w-det-prt-bol-tmb    to   rf-zbi-cod-tmb         .
           move      w-det-prt-bol-ndp    to   rf-zbi-cod-dpz         .
           move      "pgm/bol/fls/ioc/obj/iofzbi"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zbi                 .
       det-prt-bol-100.
      *              *-------------------------------------------------*
      *              * Start su file [bit]                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start                                       *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "CNTDEN    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      "N"                  to   rf-bit-snx-fac         .
           move      w-det-prt-bol-nsa    to   rf-bit-scl-ann         .
           move      w-det-prt-bol-ndp    to   rf-bit-cod-dpz         .
           move      rf-zbi-sgl-num       to   rf-bit-sgl-num         .
           move      w-det-prt-bol-num    to   rf-bit-num-doc         .
           move      zero                 to   rf-bit-num-prt         .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *                  *---------------------------------------------*
      *                  * Se errore di start : ad uscita              *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-prt-bol-900.
       det-prt-bol-200.
      *              *-------------------------------------------------*
      *              * Read-next su [bit]                              *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *                  *---------------------------------------------*
      *                  * Se at end : ad uscita                       *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-prt-bol-900.
       det-prt-bol-300.
      *              *-------------------------------------------------*
      *              * Se oltre il massimo : ad uscita                 *
      *              *-------------------------------------------------*
           if        rf-bit-snx-fac       not  = "N"               or
                     rf-bit-scl-ann       not  = w-det-prt-bol-nsa or
                     rf-bit-cod-dpz       not  = w-det-prt-bol-ndp or
                     rf-bit-sgl-num       not  = rf-zbi-sgl-num    or
                     rf-bit-num-doc       not  = w-det-prt-bol-num
                     go to det-prt-bol-900.
       det-prt-bol-400.
      *              *-------------------------------------------------*
      *              * Selezioni su [bit]                              *
      *              *-------------------------------------------------*
       det-prt-bol-500.
      *              *-------------------------------------------------*
      *              * Bufferizzazione                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Protocollo                                  *
      *                  *---------------------------------------------*
           move      rf-bit-num-prt       to   w-det-prt-bol-prt      .
       det-prt-bol-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-prt-bol-999.
       det-prt-bol-999.
           exit.

