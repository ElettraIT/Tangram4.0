           go to     rou-let-reg-999.
       rou-let-reg-055.
      *                      *-----------------------------------------*
      *                      * Controllo che la data documento sia su- *
      *                      * periore alla data di registrazione con- *
      *                      * tabile minima, a seconda se la causale  *
      *                      * tocca l'iva oppure no                   *
      *                      *-----------------------------------------*
       rou-let-reg-056.
      *                          *-------------------------------------*
      *                          * Se causale a zero : nessun ulterio- *
      *                          * re controllo                        *
      *                          *-------------------------------------*
           if        w-tes-tip-mov-cau    =    zero
                     go to rou-let-reg-060.
      *                          *-------------------------------------*
      *                          * Lettura archivio [zcc], e deviazio- *
      *                          * ne a seconda se causale iva o no    *
      *                          *-------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCAU    "         to   f-key                  .
           move      w-tes-tip-mov-cau    to   rf-zcc-cod-cau         .
           move      "pgm/cge/fls/ioc/obj/iofzcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zcc                 .
           if        f-sts                not  = e-not-err
                     go to rou-let-reg-058.
           if        rf-zcc-tip-moi       =    spaces or
                     rf-zcc-tip-moi       =    "0"
                     go to rou-let-reg-058.
       rou-let-reg-057.
      *                          *-------------------------------------*
