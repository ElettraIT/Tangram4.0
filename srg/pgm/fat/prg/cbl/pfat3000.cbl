      *    *===========================================================*
      *    * Accettazione campo chiave : Tipo movimento                *
      *    *-----------------------------------------------------------*
       acc-tip-mov-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione valore di default              *
      *                  *---------------------------------------------*
           if        w-tes-tip-mov        not  = spaces
                     go to acc-tip-mov-100.
           move      w-def-tip-mov        to   w-tes-tip-mov          .
       acc-tip-mov-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-des-zfi-ope      .
           move      w-tes-tip-mov        to   w-cod-des-zfi-cod      .
           move      04                   to   w-cod-des-zfi-lin      .
           move      18                   to   w-cod-des-zfi-pos      .
           move      04                   to   w-cod-des-zfi-dln      .
           move      24                   to   w-cod-des-zfi-dps      .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   cod-des-zfi-cll-000  thru cod-des-zfi-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-des-zfi-foi-000  thru cod-des-zfi-foi-999    .
       acc-tip-mov-110.
           perform   cod-des-zfi-cll-000  thru cod-des-zfi-cll-999    .
           if        w-cod-des-zfi-ope    =    "F+"
                     go to acc-tip-mov-115.
           if        w-cod-des-zfi-ope    =    "AC"
                     go to acc-tip-mov-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-tip-mov-115.
           perform   cod-des-zfi-foi-000  thru cod-des-zfi-foi-999    .
           go to     acc-tip-mov-110.
       acc-tip-mov-120.
           move      w-cod-des-zfi-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-key
                     go to acc-tip-mov-999.
       acc-tip-mov-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-alf                to   w-tes-tip-mov          .
       acc-tip-mov-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test che non ci siano blanks embedded       *
      *                  *---------------------------------------------*
           move      w-tes-tip-mov        to   w-all-str-alf          .
           move      05                   to   w-all-str-lun          .
           perform   all-str-ble-000      thru all-str-ble-999        .
           if        w-all-str-flg        not  = spaces
                     go to acc-tip-mov-100.
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      w-tes-tip-mov        to   w-let-arc-zfi-cod      .
           perform   let-arc-zfi-000      thru let-arc-zfi-999        .
           move      w-let-arc-zfi-des    to   w-tes-tip-mov-des      .
           move      w-let-arc-zfi-dst    to   w-tes-tip-mov-dst      .
           move      w-let-arc-zfi-vld    to   w-tes-tip-mov-vld      .
           move      w-let-arc-zfi-dpz    to   w-tes-tip-mov-dpz      .
           move      w-let-arc-zfi-tdo    to   w-tes-tip-mov-tdo      .
           move      w-let-arc-zfi-ord    to   w-tes-tip-mov-ord      .
           move      w-let-arc-zfi-prd    to   w-tes-tip-mov-prd      .
           move      w-let-arc-zfi-ngi    to   w-tes-tip-mov-ngi      .
           move      w-let-arc-zfi-sgl    to   w-tes-tip-mov-sgl      .
           move      w-let-arc-zfi-cau    to   w-tes-tip-mov-cau      .
           move      w-let-arc-zfi-siv    to   w-tes-tip-mov-siv      .
           move      w-let-arc-zfi-sve    to   w-tes-tip-mov-sve      .
           move      w-let-arc-zfi-dtr    to   w-tes-tip-mov-dtr      .
           move      w-let-arc-zfi-caf    to   w-tes-tip-mov-caf      .
           move      w-let-arc-zfi-sdi    to   w-tes-tip-mov-sdi      .
           move      w-let-arc-zfi-mod    to   w-tes-tip-mov-mod      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-mov-000      thru vis-des-mov-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-zfi-flg    not  = spaces
                     go to acc-tip-mov-100.
      *                  *---------------------------------------------*
      *                  * Se a spaces : oltre                         *
      *                  *---------------------------------------------*
           if        w-tes-tip-mov        =    spaces
                     go to acc-tip-mov-600.
      *                  *---------------------------------------------*
      *                  * Test su codice dipendenza                   *
      *                  *---------------------------------------------*
           if        w-tes-tip-mov-vld    not  = 02
                     go to acc-tip-mov-420.
           if        w-tes-cod-dpz        =    w-tes-tip-mov-dpz
                     go to acc-tip-mov-420.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Tipo movimento incompatibile con il codice dipende
      -              "nza            "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-tip-mov-100.
       acc-tip-mov-420.
      *                  *---------------------------------------------*
      *                  * Controllo codice causale                    *
      *                  *---------------------------------------------*
           move      w-tes-tip-mov-tdo    to   w-ctl-cau-doc-tdo      .
           move      w-tes-tip-mov-cau    to   w-ctl-cau-doc-cod      .
           perform   ctl-cau-doc-000      thru ctl-cau-doc-999        .
           if        w-ctl-cau-doc-flg    =    spaces
                     go to acc-tip-mov-440.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Causale contabile associata al tipo movimento erra
      -              "ta !           "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-tip-mov-100.
       acc-tip-mov-440.
      *                  *---------------------------------------------*
      *                  * Controllo tipo origine del documento        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se fattura manuale o differita : con-   *
      *                      * trollo comunque superato                *
      *                      *-----------------------------------------*
           if        w-tes-tip-mov-ord    =   01 or
                     w-tes-tip-mov-ord    =   11 or
                     w-tes-tip-mov-ord    =   31 or
                     w-tes-tip-mov-ord    =   41 or
                     w-tes-tip-mov-ord    =   51
                     go to acc-tip-mov-600.
      *                      *-----------------------------------------*
      *                      * Se in rettifica dei dati provvigionali  *
      *                      * di fattura il controllo e' superato an- *
      *                      * che in caso di fattura accompagnatoria  *
      *                      *-----------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP" and
                     w-tes-tip-mov-ord    =    02
                     go to acc-tip-mov-600.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Tipo movimento solo visualizzabile da questo progr
      -              "amma !         "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
       acc-tip-mov-600.
      *              *-------------------------------------------------*
