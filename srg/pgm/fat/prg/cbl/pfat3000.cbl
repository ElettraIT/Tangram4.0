      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       ctl-plf-lic-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     ctl-plf-lic-999.
       ctl-plf-lic-999.
           exit.

      *    *===========================================================*
      *    * Controllo righe del documento                             *
      *    *-----------------------------------------------------------*
       ctl-rig-doc-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-ctl-rig-doc-flg      .
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Normalizzazione risposta da operatore           *
      *              *-------------------------------------------------*
           move      spaces               to   w-ctl-rig-doc-tro      .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       ctl-rig-doc-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to ctl-rig-doc-900.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to ctl-rig-doc-100.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to ctl-rig-doc-100.
       ctl-rig-doc-200.
      *              *-------------------------------------------------*
      *              * Richiamo routine di controllo impostazioni su   *
      *              * riga corpo                                      *
      *              *-------------------------------------------------*
           perform   ctl-imp-rig-000      thru ctl-imp-rig-999        .
      *              *-------------------------------------------------*
      *              * Se zero errori riscontrati : riciclo su lettura *
      *              * catena                                          *
      *              *-------------------------------------------------*
           if        w-ctl-imp-rig-ele    =    zero
                     go to ctl-rig-doc-100.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione buffer errori                *
      *              *-------------------------------------------------*
           move      zero                 to    w-ctl-imp-rig-ctr     .
       ctl-rig-doc-220.
           add       1                    to    w-ctl-imp-rig-ctr     .
      *                  *---------------------------------------------*
      *                  * Se fine scansione : riciclo su lettura ca-  *
      *                  * tena                                        *
      *                  *---------------------------------------------*
           if        w-ctl-imp-rig-ctr    >     w-ctl-imp-rig-ele
                     go to ctl-rig-doc-100.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda che si tratti o meno di un *
      *              * errore bloccante                                *
      *              *-------------------------------------------------*
           if        w-ctl-imp-rig-bte
                    (w-ctl-imp-rig-ctr)   =    "B"
                     go to ctl-rig-doc-300
           else if   w-ctl-imp-rig-bte
                    (w-ctl-imp-rig-ctr)   =    "N"
                     go to ctl-rig-doc-400.
       ctl-rig-doc-300.
      *              *-------------------------------------------------*
      *              * Se errore bloccante                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Composizione messaggio completo             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing numero riga                     *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-cat-rig-cur        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Composizione stringa                    *
      *                      *-----------------------------------------*
           move      spaces               to   w-err-box-err-msg      .
           string    "Errore a riga "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " : "      delimited by   size
                     w-ctl-imp-rig-bmg
                    (w-ctl-imp-rig-ctr)
                                delimited by   size
                                          into w-err-box-err-msg      .
      *                  *---------------------------------------------*
      *                  * Emissione messaggio di errore               *
      *                  *---------------------------------------------*
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                  *---------------------------------------------*
      *                  * Flag di uscita ad errore                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-ctl-rig-doc-flg      .
      *                  *---------------------------------------------*
      *                  * A uscita                                    *
      *                  *---------------------------------------------*
           go to     ctl-rig-doc-900.
       ctl-rig-doc-400.
      *              *-------------------------------------------------*
      *              * Se errore non bloccante                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se flag di risposta operatore a X : riciclo *
      *                  * su scansione buffer errori                  *
      *                  *---------------------------------------------*
           if        w-ctl-rig-doc-tro    =    "X"
                     go to ctl-rig-doc-220.
       ctl-rig-doc-420.
      *                  *---------------------------------------------*
      *                  * Box di avviso con conferma impostazioni     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Salvataggio immagine video              *
      *                      *-----------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Video in Off                            *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Box                                     *
      *                      *-----------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      11                   to   v-lin                  .
           move      04                   to   v-pos                  .
           move      15                   to   v-lto                  .
           move      77                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Messaggio nel box                       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Linea 01                            *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Editing numero riga             *
      *                              *---------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-cat-rig-cur        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Composizione stringa            *
      *                              *---------------------------------*
           move      spaces               to   v-alf                  .
           string    "Avviso per riga "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " : "      delimited by   size
                     w-ctl-imp-rig-bmg
                    (w-ctl-imp-rig-ctr)
                                delimited by   size
                                          into v-alf                  .
      *                              *---------------------------------*
      *                              * Visualizzazione stringa         *
      *                              *---------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      70                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      06                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                          *-------------------------------------*
      *                          * Linea 02                            *
      *                          *-------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      70                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      06                   to   v-pos                  .
           move      "Si confermano ugualmente le impostazioni (S/N) ? [
      -              " ]"                 to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Video in On                             *
      *                      *-----------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Accettazione della risposta             *
      *                      *-----------------------------------------*
           move      "S"                  to   v-alf                  .
       ctl-rig-doc-422.
           move      "AC"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      56                   to   v-pos                  .
           move      "DO  "               to   v-pfk (05)             .
           move      "EXIT"               to   v-pfk (20)             .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Set del tipo risposta da operatore      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test su function-key impostata      *
      *                          *-------------------------------------*
           if        v-key                =    "EXIT"
                     move  "N"            to   w-ctl-rig-doc-tro
                     go to ctl-rig-doc-426
           else if   v-key                =    "DO  "
                     move  "X"            to   w-ctl-rig-doc-tro
                     go to ctl-rig-doc-426
           else if   v-key                =    spaces
                     go to ctl-rig-doc-424
           else      go to ctl-rig-doc-422.
       ctl-rig-doc-424.
      *                          *-------------------------------------*
      *                          * Test su valore impostato se Return  *
      *                          *-------------------------------------*
           if        v-alf                =    "N"
                     move  "N"            to   w-ctl-rig-doc-tro
                     go to ctl-rig-doc-426
           else if   v-alf                =    "S"
                     move  "S"            to   w-ctl-rig-doc-tro
                     go to ctl-rig-doc-426
           else      go to ctl-rig-doc-422.
       ctl-rig-doc-426.
      *                      *-----------------------------------------*
      *                      * Ripristino immagine video               *
      *                      *-----------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       ctl-rig-doc-440.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo di risposta *
      *                  * da operatore                                *
      *                  *---------------------------------------------*
           if        w-ctl-rig-doc-tro    =    "N"
                     go to ctl-rig-doc-442
           else if   w-ctl-rig-doc-tro    =    "S"
                     go to ctl-rig-doc-444
           else if   w-ctl-rig-doc-tro    =    "X"
                     go to ctl-rig-doc-446.
       ctl-rig-doc-442.
      *                  *---------------------------------------------*
      *                  * Tipo di risposta : No                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Flag di uscita ad errore                *
      *                      *-----------------------------------------*
           move      "#"                  to   w-ctl-rig-doc-flg      .
      *                      *-----------------------------------------*
      *                      * A uscita                                *
      *                      *-----------------------------------------*
           go to     ctl-rig-doc-900.
       ctl-rig-doc-444.
      *                  *---------------------------------------------*
      *                  * Tipo di risposta : Si                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Riciclo su scansione buffer errori      *
      *                      *-----------------------------------------*
           go to     ctl-rig-doc-220.
       ctl-rig-doc-446.
      *                  *---------------------------------------------*
      *                  * Tipo di risposta : Si, e con omissione di   *
      *                  * altri messaggi                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Riciclo su scansione buffer errori      *
      *                      *-----------------------------------------*
           go to     ctl-rig-doc-220.
       ctl-rig-doc-900.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       ctl-rig-doc-999.
           exit.

      *    *===========================================================*
      *    * Routine di controllo modificabilita' registrazione        *
      *    *-----------------------------------------------------------*
       ctl-mdf-reg-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-ctl-mdf-reg-flg      .
      *              *-------------------------------------------------*
      *              * Se si e' in rettifica dati provvigionali : u-   *
      *              * scita                                           *
      *              *-------------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "MP"
                     go to ctl-mdf-reg-999.
      *              *-------------------------------------------------*
      *              * Se non si e' in Modifica : uscita               *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "M"
                     go to ctl-mdf-reg-999.
      *              *-------------------------------------------------*
      *              * Se flag di modificabilita' parziale della re-   *
      *              * gistrazione non attivo : uscita                 *
      *              *-------------------------------------------------*
           if        w-tes-flg-mdp        =    spaces
                     go to ctl-mdf-reg-999.
       ctl-mdf-reg-100.
      *              *-------------------------------------------------*
      *              * Controllo castelletto iva                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su numero elementi                     *
      *                  *---------------------------------------------*
           if        w-pie-iva-ele (1)    not  = w-pie-iva-ele (2)
                     go to ctl-mdf-reg-900.
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione                          *
      *                  *---------------------------------------------*
           move      zero                 to   w-ctl-mdf-reg-ctr      .
       ctl-mdf-reg-120.
           add       1                    to   w-ctl-mdf-reg-ctr      .
           if        w-ctl-mdf-reg-ctr    >    w-pie-iva-ele (1)
                     go to ctl-mdf-reg-200.
           if        w-pie-iva-cod
                    (1, w-ctl-mdf-reg-ctr)
                                          =    w-pie-iva-cod
                                              (2, w-ctl-mdf-reg-ctr) and
                     w-pie-iva-ibl
                    (1, w-ctl-mdf-reg-ctr)
                                          =    w-pie-iva-ibl
                                              (2, w-ctl-mdf-reg-ctr) and
                     w-pie-iva-imp
                    (1, w-ctl-mdf-reg-ctr)
                                          =    w-pie-iva-imp
                                              (2, w-ctl-mdf-reg-ctr)
                     go to ctl-mdf-reg-120
           else      go to ctl-mdf-reg-900.
       ctl-mdf-reg-200.
      *              *-------------------------------------------------*
      *              * Controllo castelletto contropartite             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su numero elementi                     *
      *                  *---------------------------------------------*
           if        w-pie-ctp-ele (1)    not  = w-pie-ctp-ele (2)
                     go to ctl-mdf-reg-900.
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione                          *
      *                  *---------------------------------------------*
           move      zero                 to   w-ctl-mdf-reg-ctr      .
       ctl-mdf-reg-220.
           add       1                    to   w-ctl-mdf-reg-ctr      .
           if        w-ctl-mdf-reg-ctr    >    w-pie-ctp-ele (1)
                     go to ctl-mdf-reg-300.
           if        w-pie-ctp-cod
                    (1, w-ctl-mdf-reg-ctr)
                                          =    w-pie-ctp-cod
                                              (2, w-ctl-mdf-reg-ctr) and
                     w-pie-ctp-imp
                    (1, w-ctl-mdf-reg-ctr)
                                          =    w-pie-ctp-imp
                                              (2, w-ctl-mdf-reg-ctr)
                     go to ctl-mdf-reg-220
           else      go to ctl-mdf-reg-900.
       ctl-mdf-reg-300.
      *              *-------------------------------------------------*
      *              * Controllo castelletto scadenze                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su numero elementi                     *
      *                  *---------------------------------------------*
           if        w-pie-scd-ele (1)    not  = w-pie-scd-ele (2)
                     go to ctl-mdf-reg-900.
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione                          *
      *                  *---------------------------------------------*
           move      zero                 to   w-ctl-mdf-reg-ctr      .
       ctl-mdf-reg-320.
           add       1                    to   w-ctl-mdf-reg-ctr      .
           if        w-ctl-mdf-reg-ctr    >    w-pie-scd-ele (1)
                     go to ctl-mdf-reg-400.
           if        w-pie-scd-tip
                    (1, w-ctl-mdf-reg-ctr)
                                          =    w-pie-scd-tip
                                              (2, w-ctl-mdf-reg-ctr) and
                     w-pie-scd-dat
                    (1, w-ctl-mdf-reg-ctr)
                                          =    w-pie-scd-dat
                                              (2, w-ctl-mdf-reg-ctr) and
                     w-pie-scd-imp
                    (1, w-ctl-mdf-reg-ctr)
                                          =    w-pie-scd-imp
                                              (2, w-ctl-mdf-reg-ctr)
                     go to ctl-mdf-reg-320
           else      go to ctl-mdf-reg-900.
       ctl-mdf-reg-400.
      *              *-------------------------------------------------*
      *              * Uscita per controllo superato                   *
      *              *-------------------------------------------------*
           go to     ctl-mdf-reg-999.
       ctl-mdf-reg-900.
      *              *-------------------------------------------------*
      *              * Azioni per controllo con superato               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Messaggio di errore                         *
      *                  *---------------------------------------------*
           perform   box-mdf-reg-000      thru box-mdf-reg-999        .
      *                  *---------------------------------------------*
      *                  * Flag di uscita ad errore                    *
      *                  *---------------------------------------------*
           move      "#"                  to   w-ctl-mdf-reg-flg      .
       ctl-mdf-reg-999.
           exit.

