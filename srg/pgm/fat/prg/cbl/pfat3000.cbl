                     w-prs-tfu-psr-wcc    not  = 21 and
                     w-prs-tfu-psr-wcc    not  = 22 and
                     w-prs-tfu-psr-wcc    not  = 31 and
                     w-prs-tfu-psr-wcc    not  = 32 and
                     w-prs-tfu-psr-wcc    not  = 41 and
                     w-prs-tfu-psr-wcc    not  = 71 and
                     w-prs-tfu-psr-wcc    not  = 72
