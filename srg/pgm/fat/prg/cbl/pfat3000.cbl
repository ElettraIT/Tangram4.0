      *                  * A trattamento riga successiva               *
      *                  *---------------------------------------------*
           go to     ret-dat-pvg-475.
       ret-dat-pvg-600.
      *              *-------------------------------------------------*
      *              * Trattamento scadenze 'gep'                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se gestione portafoglio attiva         *
      *                  *---------------------------------------------*
           if        w-prs-gep-snx        not  = "S"
                     go to ret-dat-pvg-900.
      *                  *---------------------------------------------*
      *                  * Test se variato il codice agente            *
      *                  *---------------------------------------------*
           if        w-tes-cod-age (1)    =    w-tes-cod-age (2)
                     go to ret-dat-pvg-900.
      *                  *---------------------------------------------*
      *                  * Test se scadenze esistenti                  *
      *                  *---------------------------------------------*
           if        w-tes-nps-sdb (1)    =    zero
                     go to ret-dat-pvg-900.
      *                  *---------------------------------------------*
      *                  * Ciclo per scansione                         *
      *                  *---------------------------------------------*
           move      w-tes-nps-sdb (1)    to   w-rou-let-reg-wns      .
           subtract  1                    from w-rou-let-reg-wns      .
           move      zero                 to   w-rou-let-reg-ctr      .
       ret-dat-pvg-620.
           add       1                    to   w-rou-let-reg-ctr      .
           if        w-rou-let-reg-ctr    >    w-tes-ctr-sdb (1)
                     go to ret-dat-pvg-900.
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [sdb]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Lettura record [sdb]                        *
      *                  *---------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMSDB    "         to   f-key                  .
           add       1                    to   w-rou-let-reg-wns      .
           move      w-rou-let-reg-wns    to   rf-sdb-num-sdb         .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                      *-----------------------------------------*
      *                      * Test su esito lettura [sdb]             *
      *                      *-----------------------------------------*
           if        f-sts                =    e-not-err
                     go to ret-dat-pvg-640.
      *                  *---------------------------------------------*
      *                  * Se record non trovato : a riciclo           *
      *                  *---------------------------------------------*
           go to     ret-dat-pvg-680.
       ret-dat-pvg-640.
      *                  *---------------------------------------------*
      *                  * Se record trovato : update                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice agente                           *
      *                      *-----------------------------------------*
           move      w-tes-cod-age (1)    to   rf-sdb-cod-age         .
      *                      *-----------------------------------------*
      *                      * Update record [sdb]                     *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
       ret-dat-pvg-660.
      *                      *-----------------------------------------*
      *                      * Rilascio record [sdb]                   *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
       ret-dat-pvg-680.
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     ret-dat-pvg-620.
       ret-dat-pvg-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     ret-dat-pvg-999.
       ret-dat-pvg-999.
           exit.

      *    *===========================================================*
