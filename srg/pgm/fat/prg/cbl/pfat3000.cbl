       cmp-rec-fir-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/fat/fls/ioc/obj/ioffir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fir                 .
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           move      w-tes-num-prt        to   rf-fir-num-prt         .
           move      w-rig-num-prg (1)    to   rf-fir-num-prg         .
           move      w-tes-tip-mov        to   rf-fir-cod-tmo         .
           move      w-tes-cod-dpz        to   rf-fir-cod-dpz         .
           move      w-tes-dat-doc        to   rf-fir-dat-doc         .
           move      w-tes-num-doc        to   rf-fir-num-doc         .
           move      w-tes-cod-cli (1)    to   rf-fir-cod-cli         .
           move      w-tes-dpz-cli (1)    to   rf-fir-dpz-cli         .
           if        w-rig-cli-pls (1)    not  = zero
                     move  w-rig-cli-pls (1)
                                          to   rf-fir-cli-pls
                     move  w-rig-dpc-pls (1)
                                          to   rf-fir-dpc-pls
           else      move  w-tes-cod-cli (1)
                                          to   rf-fir-cli-pls
                     move  w-tes-dpz-cli (1)
                                          to   rf-fir-dpc-pls         .
           move      w-tes-cod-lng (1)    to   rf-fir-cod-lng         .
           move      w-tes-sgl-vpf (1)    to   rf-fir-sgl-vpf         .
