      *    *===========================================================*
      *    * Select archivio [fit] in base al numero documento         *
      *    *-----------------------------------------------------------*
       slc-num-fit-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-slc-num-fit-sel      .
      *              *-------------------------------------------------*
      *              * Normalizzazioni iniziali                        *
      *              *-------------------------------------------------*
           move      spaces               to   w-slc-num-fit-toc      .
           move      zero                 to   w-slc-num-fit-dat      .
           move      zero                 to   w-slc-num-fit-num      .
           move      zero                 to   w-slc-num-fit-crb      .
      *              *-------------------------------------------------*
      *              * Preparazione secolo, anno                       *
      *              *-------------------------------------------------*
           move      w-slc-num-fit-dds    to   s-dat                  .
           move      s-saa                to   w-slc-num-fit-saa      .
       slc-num-fit-080.
      *              *-------------------------------------------------*
      *              * Completamento numero documento                  *
      *              *-------------------------------------------------*
           move      w-slc-num-fit-saa    to   w-slc-num-fit-nsa      .
           move      w-slc-num-fit-giv    to   w-slc-num-fit-ngi      .
       slc-num-fit-100.
      *              *-------------------------------------------------*
      *              * Start su file [fit]                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start                                       *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "CNTDEN    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      w-slc-num-fit-saa    to   rf-fit-scl-ann         .
           move      w-slc-num-fit-giv    to   rf-fit-num-giv         .
           move      w-slc-num-fit-sgl    to   rf-fit-sgl-num         .
           move      w-slc-num-fit-nds    to   rf-fit-num-doc         .
           move      zero                 to   rf-fit-num-prt         .
           move      "pgm/fat/fls/ioc/obj/ioffit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fit                 .
      *                  *---------------------------------------------*
      *                  * Se errore di start : a controllo contatore  *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to slc-num-fit-800.
       slc-num-fit-200.
      *              *-------------------------------------------------*
      *              * Read-next su [fit]                              *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/fat/fls/ioc/obj/ioffit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fit                 .
      *                  *---------------------------------------------*
      *                  * Se at end : a controllo contatore           *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to slc-num-fit-500.
       slc-num-fit-300.
      *              *-------------------------------------------------*
      *              * Se oltre il massimo : a controllo contatore     *
      *              *-------------------------------------------------*
           if        rf-fit-scl-ann       not  = w-slc-num-fit-saa or
                     rf-fit-num-giv       not  = w-slc-num-fit-giv or
                     rf-fit-sgl-num       not  = w-slc-num-fit-sgl or
                     rf-fit-num-doc       not  = w-slc-num-fit-nds
                     go to slc-num-fit-500.
       slc-num-fit-400.
      *              *-------------------------------------------------*
      *              * Incremento numero records nel buffer            *
      *              *-------------------------------------------------*
           add       1                    to   w-slc-num-fit-crb      .
      *              *-------------------------------------------------*
      *              * Test se buffer oltre il numero previsto         *
      *              *-------------------------------------------------*
           if        w-slc-num-fit-crb    >    30
                     go to slc-num-fit-520.
       slc-num-fit-420.
      *              *-------------------------------------------------*
      *              * Bufferizzazione                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Protocollo                                  *
      *                  *---------------------------------------------*
           move      rf-fit-num-prt       to   w-slc-num-fit-bpt
                                              (w-slc-num-fit-crb)     .
      *                  *---------------------------------------------*
      *                  * Riciclo a lettura                           *
      *                  *---------------------------------------------*
           go to     slc-num-fit-200.
       slc-num-fit-500.
      *                  *---------------------------------------------*
      *                  * Controllo numero records letti con lo stes- *
      *                  * so valore                                   *
      *                  *---------------------------------------------*
           if        w-slc-num-fit-crb    =    zero
                     go to slc-num-fit-800.
      *                  *---------------------------------------------*
      *                  * Se trovato un solo elemento uscita con      *
      *                  * quello                                      *
      *                  *---------------------------------------------*
           if        w-slc-num-fit-crb    >    1
                     go to slc-num-fit-520.
      *                      *-----------------------------------------*
      *                      * Lettura record [fit]                    *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-slc-num-fit-bpt (1)
                                          to   rf-fit-num-prt         .
           move      "pgm/fat/fls/ioc/obj/ioffit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fit                 .
           if        f-sts                not  = e-not-err
                     move  zero           to   rf-fit-dat-doc
                     move  zero           to   rf-fit-num-doc
                     move  zero           to   rf-fit-cod-cli
                     move  spaces         to   rf-fit-dpz-cli         .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione dati letti              *
      *                      *-----------------------------------------*
           move      rf-fit-dat-doc       to   w-slc-num-fit-dat      .
           move      rf-fit-num-doc       to   w-slc-num-fit-num      .
           move      rf-fit-cod-tmo       to   w-slc-num-fit-toc      .
      *                      *-----------------------------------------*
      *                      * Ad operazioni prima dell'uscita         *
      *                      *-----------------------------------------*
           go to     slc-num-fit-800.
       slc-num-fit-520.
      *                  *---------------------------------------------*
      *                  * Box di espansione                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Determinazione numero pagine nel buffer *
      *                      *-----------------------------------------*
           move      w-slc-num-fit-crb    to   w-slc-num-fit-cpb      .
           subtract  1                    from w-slc-num-fit-cpb      .
           divide    6                    into w-slc-num-fit-cpb      .
           add       1                    to   w-slc-num-fit-cpb      .
      *                      *-----------------------------------------*
      *                      * Inizializzazione numero record nel buf- *
      *                      * fer attualmente trattato                *
      *                      *-----------------------------------------*
           move      1                    to   w-slc-num-fit-c01      .
      *                      *-----------------------------------------*
      *                      * Salvataggio immagine video              *
      *                      *-----------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Video in Off                            *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione box vuoto               *
      *                      *-----------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      07                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      18                   to   v-lto                  .
           move      80                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Fincatura                               *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      76                   to   v-car                  .
           move      08                   to   v-lin                  .
           move      03                   to   v-pos                  .
           move      "                      Selezionare la fattura desid
      -              "erata                     "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Sottolineatura fincatura                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      76                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      03                   to   v-pos                  .
           move      all   "-"            to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Sottolineatura di chiusura              *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      76                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      03                   to   v-pos                  .
           move      all   "-"            to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione pagina video contenente *
      *                      * il record attualmente trattato          *
      *                      *-----------------------------------------*
           perform   slc-num-fit-950      thru slc-num-fit-989        .
      *                      *-----------------------------------------*
      *                      * Video in On                             *
      *                      *-----------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       slc-num-fit-550.
      *                      *-----------------------------------------*
      *                      * Determinazione numero linea a video     *
      *                      *-----------------------------------------*
           move      w-slc-num-fit-c01    to   w-slc-num-fit-nli      .
       slc-num-fit-555.
           if        w-slc-num-fit-nli    >    6
                     subtract  6          from w-slc-num-fit-nli
                     go to slc-num-fit-555.
      *                          *-------------------------------------*
      *                          * Incremento numero linea a video     *
      *                          * per posizionamento verticale        *
      *                          *-------------------------------------*
           add       09                   to   w-slc-num-fit-nli      .
       slc-num-fit-560.
      *                      *-----------------------------------------*
      *                      * Espansione record attualmente trattato  *
      *                      *-----------------------------------------*
       slc-num-fit-575.
      *                      *-----------------------------------------*
      *                      * Accettazione del mark-point             *
      *                      *-----------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      spaces               to   v-ufk                  .
           if        w-slc-num-fit-c01    >    1
                     move  "UP  "         to   v-pfk (01)             .
           if        w-slc-num-fit-c01    <    w-slc-num-fit-crb
                     move  "DOWN"         to   v-pfk (02)             .
           move      "DO  "               to   v-pfk (05)             .
           if        w-slc-num-fit-cpa    >    1
                     move  "PRSC"         to   v-pfk (07)             .
           if        w-slc-num-fit-cpa    <    w-slc-num-fit-cpb
                     move  "NXSC"         to   v-pfk (08)             .
           move      "EXIT"               to   v-pfk (20)             .
           move      w-slc-num-fit-nli    to   v-lin                  .
           move      09                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       slc-num-fit-580.
           if        v-key                =    spaces or
                     v-key                =    "DO  "
                     go to slc-num-fit-582
           else if   v-key                =    "UP  "
                     go to slc-num-fit-584
           else if   v-key                =    "DOWN"
                     go to slc-num-fit-586
           else if   v-key                =    "EXIT"
                     go to slc-num-fit-598
           else if   v-key                =    "NXSC"
                     go to slc-num-fit-592
           else if   v-key                =    "PRSC"
                     go to slc-num-fit-594
           else      go to slc-num-fit-575.
       slc-num-fit-582.
      *              *-------------------------------------------------*
      *              * Se spaces, Do o select                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Restore video                               *
      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Memorizzazione valore selezionato           *
      *                  *---------------------------------------------*
           move      w-slc-num-fit-bpt
                    (w-slc-num-fit-c01)   to   w-slc-num-fit-prt      .
      *                  *---------------------------------------------*
      *                  * Lettura record [fit]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-slc-num-fit-prt    to   rf-fit-num-prt         .
           move      "pgm/fat/fls/ioc/obj/ioffit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fit                 .
           if        f-sts                not  = e-not-err
                     move  zero           to   rf-fit-dat-doc
                     move  zero           to   rf-fit-num-doc
                     move  zero           to   rf-fit-cod-cli
                     move  spaces         to   rf-fit-dpz-cli         .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione dati letti                  *
      *                  *---------------------------------------------*
           move      rf-fit-dat-doc       to   w-slc-num-fit-dat      .
           move      rf-fit-num-doc       to   w-slc-num-fit-num      .
           move      rf-fit-cod-tmo       to   w-slc-num-fit-toc      .
      *                  *---------------------------------------------*
      *                  * Ad operazioni prima dell'uscita             *
      *                  *---------------------------------------------*
           go to     slc-num-fit-800.
       slc-num-fit-584.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           subtract  1                    from w-slc-num-fit-c01      .
           if        w-slc-num-fit-nli    =    10
                     go to slc-num-fit-590
           else      go to slc-num-fit-550.
       slc-num-fit-586.
      *              *-------------------------------------------------*
      *              * Se Down                                         *
      *              *-------------------------------------------------*
           if        w-slc-num-fit-c01    <    w-slc-num-fit-crb
                     add   1              to   w-slc-num-fit-c01
                     go to slc-num-fit-588
           else      go to slc-num-fit-575.
       slc-num-fit-588.
           if        w-slc-num-fit-nli    =    15
                     go to slc-num-fit-590
           else      go to slc-num-fit-550.
       slc-num-fit-590.
           perform   slc-num-fit-950      thru slc-num-fit-989        .
           go to     slc-num-fit-550.
       slc-num-fit-592.
      *              *-------------------------------------------------*
      *              * Se Next screen                                  *
      *              *-------------------------------------------------*
           add       1                    to   w-slc-num-fit-cpa      .
           go to     slc-num-fit-596.
       slc-num-fit-594.
      *              *-------------------------------------------------*
      *              * Se Previous screen                              *
      *              *-------------------------------------------------*
           subtract  1                    from w-slc-num-fit-cpa      .
       slc-num-fit-596.
           move      w-slc-num-fit-cpa    to   w-slc-num-fit-c01      .
           multiply  6                    by   w-slc-num-fit-c01      .
           subtract  5                    from w-slc-num-fit-c01      .
           go to     slc-num-fit-590.
       slc-num-fit-598.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       slc-num-fit-800.
      *              *-------------------------------------------------*
      *              * Salvataggio valori chiave                       *
      *              *-------------------------------------------------*
           move      w-tes-val-key        to   w-sav-val-key          .
      *              *-------------------------------------------------*
      *              * Bufferizzazione valori estratti                 *
      *              *-------------------------------------------------*
           move      w-slc-num-fit-toc    to   w-tes-tip-mov          .
           move      w-slc-num-fit-dat    to   w-tes-dat-doc          .
