           move      w-att-fti-prt-ddo    to   s-dat                  .
           move      s-saa                to   w-att-fti-prt-saa      .
           move      w-att-fti-prt-saa    to   rn-fti-prt-scl-ann     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [ftiprt]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftiprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-prt             .
      *              *-------------------------------------------------*
      *              * Se record non trovato : unlock e uscita         *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rip-fti-prt-900.
      *              *-------------------------------------------------*
      *              * Se record trovato                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Confronto con il numero protocollo passato; *
      *                  * se diverso unlock e uscita                  *
      *                  *---------------------------------------------*
           if        rn-fti-prt-num-prt   not  = w-att-fti-prt-num
                     go to  rip-fti-prt-900.
      *                  *---------------------------------------------*
      *                  * Se uguale si esegue il controaggiornamento  *
      *                  *---------------------------------------------*
           subtract  1                    from w-att-fti-prt-prg      .
           if        w-att-fti-prt-prg    =    zero
                     move  zero           to   w-att-fti-prt-num      .
           move      w-att-fti-prt-num    to   rn-fti-prt-num-prt     .
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftiprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-prt             .
       rip-fti-prt-900.
      *              *-------------------------------------------------*
      *              * Unlock                                          *
      *              *-------------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftiprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-prt             .
       rip-fti-prt-999.
           exit.

      *    *===========================================================*
      *    * Routine di attribuzione numero documento                  *
      *    *-----------------------------------------------------------*
       att-num-doc-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flags di uscita                 *
      *              *-------------------------------------------------*
           move      spaces               to   w-att-num-doc-flg      .
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
      *              *-------------------------------------------------*
      *              * Lettura numerazione                             *
      *              *-------------------------------------------------*
           move      w-att-num-doc-saa    to   rn-fti-ndo-scl-ann     .
           move      w-att-num-doc-ngi    to   rn-fti-ndo-num-giv     .
           move      w-att-num-doc-sgl    to   rn-fti-ndo-sgl-num     .
           move      "GT"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
           if        f-sts                =    e-not-err
                     go to att-num-doc-100.
      *              *-------------------------------------------------*
      *              * Se numerazione non esistente la si crea norma-  *
      *              * lizzata a zero                                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione                             *
      *                  *---------------------------------------------*
           move      zero                 to   rn-fti-ndo-num-doc     .
           move      zero                 to   rn-fti-ndo-dat-doc     .
      *                  *---------------------------------------------*
      *                  * Put del record                              *
      *                  *---------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
           if        f-sts                not  = e-not-err
                     go to att-num-doc-000.
      *                  *---------------------------------------------*
      *                  * Release del record                          *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
           go to     att-num-doc-000.
       att-num-doc-100.
      *              *-------------------------------------------------*
      *              * Se numerazione esistente                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valori originali            *
      *                  *---------------------------------------------*
           move      rn-fti-ndo-num-doc   to   w-att-num-doc-nsv      .
           move      rn-fti-ndo-dat-doc   to   w-att-num-doc-dsv      .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del numero documento   *
      *                  * impostato                                   *
      *                  *---------------------------------------------*
           if        w-att-num-doc-prg    =    zero
                     go to att-num-doc-200
           else      go to att-num-doc-300.
       att-num-doc-200.
      *                  *---------------------------------------------*
      *                  * Se numero documento passato a zero          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Valore record in comodo ridefinito      *
      *                      *-----------------------------------------*
           move      rn-fti-ndo-num-doc   to   w-att-num-doc-wnu      .
      *                      *-----------------------------------------*
      *                      * Forzatura secolo/anno in comodo ridefi- *
      *                      * nito                                    *
      *                      *-----------------------------------------*
           move      w-att-num-doc-saa    to   w-att-num-doc-wsa      .
      *                      *-----------------------------------------*
      *                      * Forzatura numero giornale iva in comodo *
      *                      * ridefinito                              *
      *                      *-----------------------------------------*
           move      w-att-num-doc-ngi    to   w-att-num-doc-wgi      .
      *                      *-----------------------------------------*
      *                      * Incremento numero progressivo del como- *
      *                      * do ridefinito                           *
      *                      *-----------------------------------------*
           add       1                    to   w-att-num-doc-wpr      .
           if        w-att-num-doc-wpr    =    zero
                     move  1              to   w-att-num-doc-wpr      .
      *                      *-----------------------------------------*
      *                      * Movimento da comodo ridefinito a record *
      *                      *-----------------------------------------*
           move      w-att-num-doc-wnu    to   rn-fti-ndo-num-doc     .
      *                      *-----------------------------------------*
      *                      * Data documento                          *
      *                      *-----------------------------------------*
           move      w-att-num-doc-dat    to   rn-fti-ndo-dat-doc     .
      *                      *-----------------------------------------*
      *                      * Update record                           *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to att-num-doc-000.
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
      *                      *-----------------------------------------*
      *                      * Salvataggio nuovo valore                *
      *                      *-----------------------------------------*
           move      rn-fti-ndo-num-doc   to   w-att-num-doc-new      .
      *                      *-----------------------------------------*
      *                      * Valore in uscita                        *
      *                      *-----------------------------------------*
           move      rn-fti-ndo-num-doc   to   w-att-num-doc-num      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     att-num-doc-999.
       att-num-doc-300.
      *                  *---------------------------------------------*
      *                  * Se numero documento passato non a zero      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se numero documento passato minore o u- *
      *                      * guale a quello letto : errore           *
      *                      *-----------------------------------------*
           if        w-att-num-doc-num    >    w-att-num-doc-nsv
                     go to att-num-doc-320.
      *                          *-------------------------------------*
      *                          * Unlock                              *
      *                          *-------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
      *                          *-------------------------------------*
      *                          * Azzeramento nuovo numero documento  *
      *                          *-------------------------------------*
           move      zero                 to   w-att-num-doc-new      .
      *                          *-------------------------------------*
      *                          * Uscita                              *
      *                          *-------------------------------------*
           go to     att-num-doc-999.
       att-num-doc-320.
      *                      *-----------------------------------------*
      *                      * Se numero documento passato maggiore di *
      *                      * quello letto                            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se e' maggiore di un'unita' : come  *
      *                          * se fosse stato passato a zero       *
      *                          *-------------------------------------*
           move      w-att-num-doc-nsv    to   w-att-num-doc-wnu      .
           add       1                    to   w-att-num-doc-wpr      .
           if        w-att-num-doc-wpr    =    zero
                     move  1              to   w-att-num-doc-wpr      .
           if        w-att-num-doc-prg    =    w-att-num-doc-wpr
                     go to att-num-doc-200.
       att-num-doc-400.
      *                          *-------------------------------------*
      *                          * Se invece e' maggiore di piu' di    *
      *                          * un'unita'                           *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Salvataggio del video attuale   *
      *                              *---------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Video in Off                    *
      *                              *---------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Box per messaggio all'operatore *
      *                              *---------------------------------*
           move      "BX"                 to   v-ope                  .
           move      09                   to   v-lin                  .
           move      18                   to   v-lto                  .
           move      09                   to   v-pos                  .
           move      72                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Messaggi entro il box           *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Titolo centrale             *
      *                                  *-----------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      11                   to   v-pos                  .
           move      "                      A T T E N Z I O N E         
      -              "          "         to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                  *-----------------------------*
      *                                  * Numeri saltati              *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Preparazione differenza *
      *                                      *-------------------------*
           move      w-att-num-doc-prg    to   w-att-num-doc-wdf      .
           subtract  w-att-num-doc-wpr    from w-att-num-doc-wdf      .
           add       1                    to   w-att-num-doc-wdf      .
      *                                      *-------------------------*
      *                                      * Preparazione numero     *
      *                                      *-------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-att-num-doc-wdf    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                                      *-------------------------*
      *                                      * Stringa per 1 numero    *
      *                                      *-------------------------*
           if        v-num                >    1
                     go to att-num-doc-410.
           move      spaces               to   v-alf                  .
           string    "La numerazione e' stata aumentata di "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " numero."
                                delimited by   size
                                          into v-alf                  .
           go to     att-num-doc-420.
       att-num-doc-410.
      *                                      *-------------------------*
      *                                      * Stringa per piu' numeri *
      *                                      *-------------------------*
           move      spaces               to   v-alf                  .
           string    "La numerazione e' stata aumentata di "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " numeri."
                                delimited by   size
                                          into v-alf                  .
       att-num-doc-420.
      *                                      *-------------------------*
      *                                      * Visualizzazione stringa *
      *                                      *-------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      11                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                      *-------------------------*
      *                                      * Prompt per richiesta    *
      *                                      *-------------------------*
      *                                          *---------------------*
      *                                          * Preparazione pros-  *
      *                                          * simo numero         *
      *                                          *---------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-att-num-doc-prg    to   v-num                  .
           add       1                    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                                          *---------------------*
      *                                          * Visualizzazione     *
      *                                          *---------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      11                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           string    "Si vuole che prosegua dal numero "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " ?"
                                delimited by   size
                                          into v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Video in On                     *
      *                              *---------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       att-num-doc-430.
      *                              *---------------------------------*
      *                              * Scelta dell'operatore           *
      *                              *---------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-rat-ndo-lun    to   v-car                  .
           move      w-exp-rat-ndo-num    to   v-ldt                  .
           move      "UNS#"               to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      15                   to   v-lin                  .
           move      54                   to   v-pos                  .
           move      w-exp-rat-ndo-tbl    to   v-txt                  .
           move      "EXIT"               to   v-pfk (20)             .
           move      zero                 to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-num                to   w-exp-rat-ndo-sce      .
      *                              *---------------------------------*
      *                              * Controllo risposta              *
      *                              *---------------------------------*
           if        w-exp-rat-ndo-sce    =    01 or
                     w-exp-rat-ndo-sce    =    02 or
                     w-exp-rat-ndo-sce    =    03
                     go to att-num-doc-440.
           if        v-key                =    "EXIT"
                     go to att-num-doc-440.
           go to     att-num-doc-430.
       att-num-doc-440.
      *                              *---------------------------------*
      *                              * Ripristino immagine video       *
      *                              *---------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Esame risposta                  *
      *                              *---------------------------------*
           if        v-key                =    "EXIT"
                     move  "#"            to   w-att-num-doc-flg
                     go to att-num-doc-600.
           if        w-exp-rat-ndo-sce    =    01
                     move  "#"            to   w-att-num-doc-flg
                     go to att-num-doc-600
           else if   w-exp-rat-ndo-sce    =    03
                     go to att-num-doc-500
           else if   w-exp-rat-ndo-sce    =    02
                     go to att-num-doc-600.
       att-num-doc-500.
      *                              *---------------------------------*
      *                              * Se risposta positiva            *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Aggiornamento numerazione   *
      *                                  *-----------------------------*
           move      w-att-num-doc-num    to   rn-fti-ndo-num-doc     .
           move      w-att-num-doc-dat    to   rn-fti-ndo-dat-doc     .
      *                                  *-----------------------------*
      *                                  * Update record               *
      *                                  *-----------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
      *                                  *-----------------------------*
      *                                  * Se errori ripete l'intera   *
      *                                  * operazione                  *
      *                                  *-----------------------------*
           if        f-sts                not  = e-not-err
                     go to att-num-doc-000.
      *                                  *-----------------------------*
      *                                  * Unlock della numerazione    *
      *                                  *-----------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
      *                                  *-----------------------------*
      *                                  * Salvataggio nuovo valore    *
      *                                  *-----------------------------*
           move      rn-fti-ndo-num-doc   to   w-att-num-doc-new      .
      *                                  *-----------------------------*
      *                                  * Uscita                      *
      *                                  *-----------------------------*
           go to     att-num-doc-999.
       att-num-doc-600.
      *                              *---------------------------------*
      *                              * Se risposta negativa            *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Unlock della numerazione    *
      *                                  *-----------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
      *                                  *-----------------------------*
      *                                  * Nessun nuovo valore         *
      *                                  *-----------------------------*
           move      zero                 to   w-att-num-doc-new      .
      *                                  *-----------------------------*
      *                                  * Uscita                      *
      *                                  *-----------------------------*
           go to     att-num-doc-999.
       att-num-doc-999.
           exit.

      *    *===========================================================*
      *    * Routine di ripristino numero documento                    *
      *    *-----------------------------------------------------------*
       rip-num-doc-000.
      *              *-------------------------------------------------*
      *              * Se nessun nuovo numero documento : uscita       *
      *              *-------------------------------------------------*
           if        w-att-num-doc-new    =    zero
                     go to rip-num-doc-999.
      *              *-------------------------------------------------*
      *              * Lettura numerazione                             *
      *              *-------------------------------------------------*
           move      w-att-num-doc-saa    to   rn-fti-ndo-scl-ann     .
           move      w-att-num-doc-ngi    to   rn-fti-ndo-num-giv     .
           move      w-att-num-doc-sgl    to   rn-fti-ndo-sgl-num     .
           move      "GT"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
           if        f-sts                =    e-not-err
                     go to rip-num-doc-100.
      *              *-------------------------------------------------*
      *              * Se numerazione non esistente la si crea norma-  *
      *              * lizzata a zero                                  *
      *              *-------------------------------------------------*
           move      zero                 to   rn-fti-ndo-num-doc     .
           move      zero                 to   rn-fti-ndo-dat-doc     .
           move      "PT"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
           go to     rip-num-doc-000.
       rip-num-doc-100.
      *              *-------------------------------------------------*
      *              * Se numerazione esistente                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Controllo se il valore attuale della nume-  *
      *                  * razione e' tuttora inalterato rispetto al-  *
      *                  * l'aggiornamento eseguito in fase di attri-  *
      *                  * buzione del numero                          *
      *                  *---------------------------------------------*
           if        rn-fti-ndo-num-doc   =    w-att-num-doc-new
                     go to rip-num-doc-200
           else      go to rip-num-doc-400.
       rip-num-doc-200.
      *                  *---------------------------------------------*
      *                  * Se il valore risulta inalterato             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controaggiornamento record              *
      *                      *-----------------------------------------*
           move      w-att-num-doc-nsv    to   w-att-num-doc-wnu      .
           if        w-att-num-doc-wpr    =    zero
                     move  zero           to   w-att-num-doc-wnu      .
           move      w-att-num-doc-wnu    to   rn-fti-ndo-num-doc     .
           move      w-att-num-doc-dsv    to   rn-fti-ndo-dat-doc     .
           move      "UP"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rip-num-doc-000.
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
