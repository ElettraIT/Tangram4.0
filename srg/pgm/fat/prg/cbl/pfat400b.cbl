           if        w-wrt-mov-gep-ctr    >    w-rfa-scd-ele
                     go to wrt-mov-gep-999.
      *                  *---------------------------------------------*
      *                  * Se importo scadenza a zero : riciclo        *
      *                  *---------------------------------------------*
           if        w-ivb-scd-imp
                    (w-wrt-mov-gep-ctr)   =    zero
                     go to wrt-mov-gep-100.
      *                  *---------------------------------------------*
      *                  * Se personalizzazione di portafoglio asso-   *
      *                  * ciata al tipo pagamento non esistente : a   *
      *                  * riciclo                                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Preparazione indice di comodo           *
      *                      *-----------------------------------------*
           move      w-rfa-scd-tip
                    (w-wrt-mov-gep-ctr)   to   w-wrt-mov-gep-wtp      .
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-prs-gep-snx-prs
                    (w-wrt-mov-gep-wtp)   not  = "S"
                     go to wrt-mov-gep-100.
      *                  *---------------------------------------------*
      *                  * Aggiornamento progressivo numero scadenza   *
      *                  *---------------------------------------------*
           add       1                    to   w-wrt-mov-gep-wns      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [sdb]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Composizione record [sdb]                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Dati identificativi                     *
      *                      *-----------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rf-sdb-ide-dat         .
           move      s-ute                to   rf-sdb-ide-ute         .
           move      s-fas                to   rf-sdb-ide-fas         .
      *                      *-----------------------------------------*
      *                      * Data registrazione emissione            *
      *                      *-----------------------------------------*
           move      rr-dat-emi           to   rf-sdb-dtr-emi         .
      *                      *-----------------------------------------*
      *                      * Data registrazione movimento di conta-  *
      *                      * bilita'                                 *
      *                      *-----------------------------------------*
           if        w-rfa-scd-cau
                    (w-wrt-mov-gep-ctr)   =    zero
                     go to wrt-mov-gep-120.
           move      rr-dat-emi           to   rf-sdb-drc-emi         .
       wrt-mov-gep-120.
      *                      *-----------------------------------------*
      *                      * Numero protocollo movimento di contabi- *
      *                      * lita'                                   *
      *                      *-----------------------------------------*
           if        w-rfa-scd-cau
                    (w-wrt-mov-gep-ctr)   =    zero
                     go to wrt-mov-gep-140.
           add       1                    to   w-wrt-mov-gep-wnp      .
           move      w-wrt-mov-gep-wnp    to   rf-sdb-npc-emi         .
       wrt-mov-gep-140.
      *                      *-----------------------------------------*
      *                      * Numero protocollo fattura cliente       *
      *                      *-----------------------------------------*
           move      rf-fit-num-prt       to   rf-sdb-prt-fcl         .
      *                      *-----------------------------------------*
      *                      * Numero scadenza di origine              *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sdb-nsc-org         .
      *                      *-----------------------------------------*
      *                      * Codice agente                           *
      *                      *-----------------------------------------*
           move      rf-fit-cod-age       to   rf-sdb-cod-age         .
      *                      *-----------------------------------------*
      *                      * Numero scadenza                         *
      *                      *-----------------------------------------*
           move      w-wrt-mov-gep-wns    to   rf-sdb-num-sdb         .
      *                      *-----------------------------------------*
      *                      * Tipo scadenza                           *
      *                      *-----------------------------------------*
           move      w-rfa-scd-tip
                    (w-wrt-mov-gep-ctr)   to   rf-sdb-tip-sdb         .
      *                      *-----------------------------------------*
      *                      * Si/No dilazione concordata              *
      *                      *-----------------------------------------*
           move      "N"                  to   rf-sdb-snx-dlc         .
      *                      *-----------------------------------------*
      *                      * Tipo acquisizione scadenza              *
      *                      *-----------------------------------------*
           move      01                   to   rf-sdb-tac-sdb         .
      *                      *-----------------------------------------*
      *                      * Tipo valuta per la scadenza             *
      *                      *-----------------------------------------*
           move      01                   to   rf-sdb-tvl-sdb         .
      *                      *-----------------------------------------*
      *                      * Data scadenza                           *
      *                      *-----------------------------------------*
           move      w-rfa-scd-dat
                    (w-wrt-mov-gep-ctr)   to   rf-sdb-dts-sdb         .
      *                      *-----------------------------------------*
      *                      * Tipo debitore                           *
      *                      *-----------------------------------------*
           move      01                   to   rf-sdb-tip-dbt         .
      *                      *-----------------------------------------*
      *                      * Codice debitore                         *
      *                      *-----------------------------------------*
           move      rf-fit-cli-plf       to   rf-sdb-cod-dbt         .
      *                      *-----------------------------------------*
      *                      * Codice dipendenza del debitore          *
      *                      *-----------------------------------------*
           move      rf-fit-dpc-plf       to   rf-sdb-dpz-dbt         .
      *                      *-----------------------------------------*
      *                      * Inoltro scadenza al debitore            *
      *                      *-----------------------------------------*
           move      rf-fit-inl-pgt       to   rf-sdb-inl-sdb         .
      *                      *-----------------------------------------*
      *                      * Sigla valuta                            *
      *                      *-----------------------------------------*
           move      c-sgl                to   rf-sdb-sgl-vlt         .
      *                      *-----------------------------------------*
      *                      * Decimali valuta                         *
      *                      *-----------------------------------------*
           move      c-dec                to   rf-sdb-dec-vlt         .
      *                      *-----------------------------------------*
      *                      * Tipo di cambio                          *
      *                      *-----------------------------------------*
           move      c-tdc                to   rf-sdb-tdc-vlt         .
      *                      *-----------------------------------------*
      *                      * Coefficiente di cambio                  *
      *                      *-----------------------------------------*
           move      c-cdc                to   rf-sdb-cdc-sdb         .
      *                      *-----------------------------------------*
      *                      * Importo scadenza in valuta              *
      *                      *-----------------------------------------*
           move      w-ivl-scd-imp
                    (w-wrt-mov-gep-ctr)   to   rf-sdb-iiv-sdb         .
      *                      *-----------------------------------------*
      *                      * Importo scadenza                        *
      *                      *-----------------------------------------*
           move      w-ivb-scd-imp
                    (w-wrt-mov-gep-ctr)   to   rf-sdb-imp-sdb         .
      *                      *-----------------------------------------*
      *                      * Data documento di riferimento           *
      *                      *-----------------------------------------*
           move      rr-dat-emi           to   rf-sdb-dat-ddr         .
      *                      *-----------------------------------------*
      *                      * Numero documento di riferimento         *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      06                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<"                  to   p-edm                  .
           move      w-att-fti-ndo-npr    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                        using  p                      .
           move      p-edt                to   rf-sdb-num-ddr         .
      *                      *-----------------------------------------*
      *                      * Tipo documento di riferimento           *
      *                      *-----------------------------------------*
           move      01                   to   rf-sdb-tip-ddr         .
      *                      *-----------------------------------------*
      *                      * Importo documento di riferimento        *
      *                      *-----------------------------------------*
           move      w-ivb-tot-doc        to   rf-sdb-imp-ddr         .
      *                      *-----------------------------------------*
      *                      * Numero rata documento di riferimento    *
      *                      *-----------------------------------------*
           move      w-wrt-mov-gep-ctr    to   rf-sdb-nra-ddr         .
      *                      *-----------------------------------------*
      *                      * Codice istituto di credito per l'appog- *
      *                      * gio                                     *
      *                      *-----------------------------------------*
           move      rf-fit-cod-abi       to   rf-sdb-abi-app         .
      *                      *-----------------------------------------*
      *                      * Codice agenzia istituto di credito per  *
      *                      * l'appoggio                              *
      *                      *-----------------------------------------*
           move      rf-fit-cod-cab       to   rf-sdb-cab-app         .
      *                      *-----------------------------------------*
      *                      * Codice conto corrente per l'appoggio    *
      *                      *-----------------------------------------*
           move      rf-fit-ccc-app       to   rf-sdb-ccc-app         .
      *                      *-----------------------------------------*
      *                      * Codice nostra banca per il pagamento    *
      *                      * tramite bonifico o codice nostro conto  *
      *                      * corrente postale per il pagamento per   *
      *                      * conto corrente postale                  *
      *                      *-----------------------------------------*
           if        rf-fit-nos-ban       not  = spaces
                     move  rf-fit-nos-ban to   rf-sdb-cod-cbp
           else if   rf-fit-nos-ccp       not  = spaces
                     move  rf-fit-nos-ccp to   rf-sdb-cod-cbp
           else      move  spaces         to   rf-sdb-cod-cbp         .
      *                      *-----------------------------------------*
      *                      * Determinazione data chiusura scadenza   *
      *                      *-----------------------------------------*
           perform   det-dat-chs-000      thru det-dat-chs-999        .
      *                      *-----------------------------------------*
      *                      * Eventuale contrassegno                  *
      *                      * ___ da implementare ___                 *
      *                      *-----------------------------------------*
      *                  *---------------------------------------------*
      *                  * Scrittura record [sdb]                      *
      *                  *---------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Riciclo su prossima scadenza                *
      *                  *---------------------------------------------*
           go to     wrt-mov-gep-100.
       wrt-mov-gep-999.
           exit.

      *    *===========================================================*
      *    * Aggiornamento records bolle                               *
      *    *-----------------------------------------------------------*
       agg-rec-bol-000.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione su tabella numeri protocollo *
      *              * bolle nella fattura                             *
      *              *-------------------------------------------------*
           move      zero                 to   w-agg-rec-bol-ctr      .
       agg-rec-bol-100.
           add       1                    to   w-agg-rec-bol-ctr      .
           if        w-agg-rec-bol-ctr    >    w-rfa-pbf-num
                     go to agg-rec-bol-999.
      *                  *---------------------------------------------*
      *                  * Lettura record [bit]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-rfa-pbf-prt
                    (w-agg-rec-bol-ctr)   to   rf-bit-num-prt         .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *                  *---------------------------------------------*
      *                  * Se errore : riciclo                         *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-rec-bol-100.
      *                  *---------------------------------------------*
      *                  * Aggiornamento record con dati fattura       *
      *                  *---------------------------------------------*
           move      rr-dat-emi           to   rf-bit-fat-dat         .
           move      w-att-fti-ndo-num    to   rf-bit-fat-num         .
           move      w-rfa-pbf-num        to   rf-bit-fat-npb         .
      *                  *---------------------------------------------*
      *                  * Rewrite record [bit]                        *
      *                  *---------------------------------------------*
           move      "FP"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *                  *---------------------------------------------*
      *                  * Se errore : riciclo                         *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-rec-bol-100.
      *                  *---------------------------------------------*
      *                  * Start su file [bir]                         *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-bit-num-prt       to   rf-bir-num-prt         .
           move      zero                 to   rf-bir-num-prg         .
           move      "pgm/bol/fls/ioc/obj/iofbir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bir                 .
      *                      *-----------------------------------------*
      *                      * Test su esito operazione                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-rec-bol-300.
       agg-rec-bol-200.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale record [bir]            *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofbir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bir                 .
      *                  *---------------------------------------------*
      *                  * Test se 'at end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-rec-bol-300.
      *                  *---------------------------------------------*
      *                  * Test sul massimo                            *
      *                  *---------------------------------------------*
           if        rf-bir-num-prt       not  = rf-bit-num-prt
                     go to agg-rec-bol-300.
      *                  *---------------------------------------------*
      *                  * Aggiornamento record con dati fattura       *
      *                  *---------------------------------------------*
           move      rr-dat-emi           to   rf-bir-fat-dat         .
           move      w-att-fti-ndo-num    to   rf-bir-fat-num         .
           move      w-rfa-pbf-num        to   rf-bir-fat-npb         .
      *                  *---------------------------------------------*
      *                  * Rewrite record [bir]                        *
      *                  *---------------------------------------------*
           move      "FP"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofbir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bir                 .
      *                  *---------------------------------------------*
      *                  * Riciclo su prossimo [bir]                   *
      *                  *---------------------------------------------*
           go to     agg-rec-bol-200.
       agg-rec-bol-300.
      *              *-------------------------------------------------*
      *              * Riciclo su scansione tabella numeri protocollo  *
      *              * bolle nella fattura                             *
      *              *-------------------------------------------------*
           go to     agg-rec-bol-100.
       agg-rec-bol-999.
           exit.

      *    *===========================================================*
      *    * Scrittura record [fir]                                    *
