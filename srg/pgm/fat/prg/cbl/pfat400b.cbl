      *                  * Record non trovato                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione dati                    *
      *                      *-----------------------------------------*
           move      zero                 to   rn-num-sdb-num-sdb     .
      *                      *-----------------------------------------*
      *                      * Scrittura record normalizzato           *
      *                      *-----------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-sdb             .
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-sdb             .
      *                      *-----------------------------------------*
      *                      * Ripetizione dell'intera operazione      *
      *                      *-----------------------------------------*
           go to     det-num-sdb-100.
       det-num-sdb-200.
      *                  *---------------------------------------------*
      *                  * Record trovato                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Movimento da record a work              *
      *                      *-----------------------------------------*
           move      rn-num-sdb-num-sdb   to   w-det-num-sdb-wns      .
           move      w-det-num-sdb-wnp    to   w-det-num-sdb-wap      .
       det-num-sdb-210.
      *                      *-----------------------------------------*
      *                      * Ultimo numero scadenza utilizzato       *
      *                      *-----------------------------------------*
           move      w-det-num-sdb-wns    to   w-det-num-sdb-nps      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento numero progressivo        *
      *                      *-----------------------------------------*
           add       w-det-num-sdb-nsn    to   w-det-num-sdb-wap      .
           if        w-det-num-sdb-wap    >    99999999
                     move  zero           to   w-det-num-sdb-wap
                     go to det-num-sdb-210.
      *                      *-----------------------------------------*
      *                      * Movimento da work a record              *
      *                      *-----------------------------------------*
           move      w-det-num-sdb-wap    to   w-det-num-sdb-wnp      .
           move      w-det-num-sdb-saa    to   w-det-num-sdb-wsa      .
           move      w-det-num-sdb-wns    to   rn-num-sdb-num-sdb     .
      *                      *-----------------------------------------*
      *                      * Update record                           *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-sdb             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-num-sdb-100.
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/gep/num/ioc/obj/innumsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-num-sdb             .
      *              *-------------------------------------------------*
      *              * Primo numero scadenza da utilizzare             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Numero prima scadenza in work di comodo     *
      *                  *---------------------------------------------*
           move      w-det-num-sdb-nps    to   w-det-num-sdb-wns      .
      *                  *---------------------------------------------*
      *                  * Forzatura di secolo/anno                    *
      *                  *---------------------------------------------*
           move      w-det-num-sdb-saa    to   w-det-num-sdb-wsa      .
      *                  *---------------------------------------------*
      *                  * Da work di comodo a valore in uscita        *
      *                  *---------------------------------------------*
           move      w-det-num-sdb-wns    to   w-det-num-sdb-nps      .
           add       1                    to   w-det-num-sdb-nps      .
       det-num-sdb-999.
           exit.

      *    *===========================================================*
      *    * Scrittura record [fit]                                    *
      *    *-----------------------------------------------------------*
       wrt-rec-fit-000.
      *              *-------------------------------------------------*
      *              * Aggiornamento valori record                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Numero protocollo                           *
      *                  *---------------------------------------------*
           move      w-att-fti-prt-num    to   rf-fit-num-prt         .
      *                  *---------------------------------------------*
      *                  * Numero documento                            *
      *                  *---------------------------------------------*
           move      w-att-fti-ndo-num    to   rf-fit-num-doc         .
      *                  *---------------------------------------------*
      *                  * Numero primo protocollo di CGE              *
      *                  *---------------------------------------------*
           move      w-det-prt-cge-npp    to   rf-fit-prt-mgd         .
      *                  *---------------------------------------------*
      *                  * Numero registrazioni di CGE necessarie      *
      *                  *---------------------------------------------*
           move      w-det-prt-cge-npn    to   rf-fit-nrg-mgd         .
      *                  *---------------------------------------------*
      *                  * Numero primo scadenza di GEP                *
      *                  *---------------------------------------------*
           move      w-det-num-sdb-nps    to   rf-fit-nps-sdb         .
      *                  *---------------------------------------------*
      *                  * Numero scadenze di GEP necessarie           *
      *                  *---------------------------------------------*
           move      w-det-num-sdb-nsn    to   rf-fit-ctr-sdb         .
      *              *-------------------------------------------------*
      *              * Put record                                      *
      *              *-------------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/fat/fls/ioc/obj/ioffit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-fit                 .
       wrt-rec-fit-999.
           exit.

      *    *===========================================================*
      *    * Determinazione importi in valuta base                     *
      *    *-----------------------------------------------------------*
       det-imp-vlb-000.
      *              *-------------------------------------------------*
      *              * Trattamento castelletto iva                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Azzeramento totalizzatori                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-ivb-tot-ibl          .
           move      zero                 to   w-ivb-tot-imp          .
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione su castelletto originale *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-imp-vlb-ctr      .
       det-imp-vlb-020.
           add       1                    to   w-det-imp-vlb-ctr      .
           if        w-det-imp-vlb-ctr    >    6
                     go to det-imp-vlb-060.
           if        rf-fit-iva-cod
                    (w-det-imp-vlb-ctr)   =    zero
                     go to det-imp-vlb-020.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione imponibile originale        *
      *                  *---------------------------------------------*
           move      rf-fit-iva-ibl
                    (w-det-imp-vlb-ctr)   to   w-ivb-iva-ibl
                                              (w-det-imp-vlb-ctr)     .
      *                  *---------------------------------------------*
      *                  * Conversione imponibile in valuta base       *
      *                  *---------------------------------------------*
           move      rf-fit-sgl-vpf       to   w-cvs-vlt-sgl          .
           move      rf-fit-dec-vpf       to   w-cvs-vlt-dec          .
           move      rf-fit-tdc-vpf       to   w-cvs-vlt-tdc          .
           move      rf-fit-cdc-vpf       to   w-cvs-vlt-cdc          .
           move      w-ivb-iva-ibl
                    (w-det-imp-vlb-ctr)   to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
           move      w-cvs-vlt-avb        to   w-ivb-iva-ibl
                                              (w-det-imp-vlb-ctr)     .
      *                  *---------------------------------------------*
      *                  * Calcolo imposta                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da effettuare                   *
      *                      *-----------------------------------------*
           move      rf-fit-iva-cod
                    (w-det-imp-vlb-ctr)   to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    <    1 or
                     w-edt-iva-cod-003    >    8
                     go to det-imp-vlb-030
           else      move  zero           to   w-ivb-iva-imp
                                              (w-det-imp-vlb-ctr)  
                     go to det-imp-vlb-040.
       det-imp-vlb-030.
      *                      *-----------------------------------------*
      *                      * Deviazione a seconda che si tratti di   *
      *                      * un aliquota di sola iva (omaggio) o no  *
      *                      *-----------------------------------------*
           move      rf-fit-iva-cod
                    (w-det-imp-vlb-ctr)   to   w-edt-iva-cod          .
      *
           if        w-edt-iva-cod-003    =    9
                     go to det-imp-vlb-032
           else      go to det-imp-vlb-034.
       det-imp-vlb-032.
      *                      *-----------------------------------------*
      *                      * Se aliquota di sola iva (omaggio)       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Conversione imposta in valuta base  *
      *                          * dell'imposta                        *
      *                          *-------------------------------------*
           move      rf-fit-sgl-vpf       to   w-cvs-vlt-sgl          .
           move      rf-fit-dec-vpf       to   w-cvs-vlt-dec          .
           move      rf-fit-tdc-vpf       to   w-cvs-vlt-tdc          .
           move      rf-fit-cdc-vpf       to   w-cvs-vlt-cdc          .
           move      rf-fit-iva-imp
                    (w-det-imp-vlb-ctr)   to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
           move      w-cvs-vlt-avb        to   w-ivb-iva-imp
                                              (w-det-imp-vlb-ctr)     .
      *                          *-------------------------------------*
      *                          * Ad aggiornamento totali             *
      *                          *-------------------------------------*
           go to     det-imp-vlb-040.
       det-imp-vlb-034.
      *                      *-----------------------------------------*
      *                      * Se aliquota normale                     *
      *                      *-----------------------------------------*
           move      rf-fit-iva-cod
                    (w-det-imp-vlb-ctr)   to   w-det-imp-vlb-wci      .
           go to     det-imp-vlb-036.
       det-imp-vlb-036.
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           move      w-ivb-iva-ibl
                    (w-det-imp-vlb-ctr)   to   d-imp-iva-ibl-iva      .
           move      w-det-imp-vlb-wci    to   d-imp-iva-cod-iva      .
           perform   det-imp-iva-000      thru det-imp-iva-999        .
           move      d-imp-iva-ims-iva    to   w-ivb-iva-imp
                                              (w-det-imp-vlb-ctr)     .
       det-imp-vlb-040.
      *                  *---------------------------------------------*
      *                  * Aggiornamento totale imponibile             *
      *                  *---------------------------------------------*
           add       w-ivb-iva-ibl
                    (w-det-imp-vlb-ctr)   to   w-ivb-tot-ibl          .
      *                  *---------------------------------------------*
      *                  * Aggiornamento totale imposta                *
      *                  *---------------------------------------------*
           add       w-ivb-iva-imp
                    (w-det-imp-vlb-ctr)   to   w-ivb-tot-imp          .
      *                  *---------------------------------------------*
      *                  * Riciclo su scansione castelletto originale  *
      *                  *---------------------------------------------*
           go to     det-imp-vlb-020.
       det-imp-vlb-060.
      *                  *---------------------------------------------*
      *                  * Determinazione totale documento             *
      *                  *---------------------------------------------*
           add       w-ivb-tot-ibl
                     w-ivb-tot-imp      giving w-ivb-tot-doc          .
       det-imp-vlb-100.
      *              *-------------------------------------------------*
      *              * Trattamento castelletto contropartite           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Azzeramento totalizzatori                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-ivb-tot-ctp          .
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione su castelletto originale *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-imp-vlb-ctr      .
       det-imp-vlb-120.
           add       1                    to   w-det-imp-vlb-ctr      .
           if        w-det-imp-vlb-ctr    >    10
                     go to det-imp-vlb-140.
           if        rf-fit-ctp-cod
                    (w-det-imp-vlb-ctr)   =    zero
                     go to det-imp-vlb-120.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione importo originale           *
      *                  *---------------------------------------------*
           move      rf-fit-ctp-imp
                    (w-det-imp-vlb-ctr)   to   w-ivb-ctp-imp
                                              (w-det-imp-vlb-ctr)     .
      *                  *---------------------------------------------*
      *                  * Conversione importo in valuta base          *
      *                  *---------------------------------------------*
           move      rf-fit-sgl-vpf       to   w-cvs-vlt-sgl          .
           move      rf-fit-dec-vpf       to   w-cvs-vlt-dec          .
           move      rf-fit-tdc-vpf       to   w-cvs-vlt-tdc          .
           move      rf-fit-cdc-vpf       to   w-cvs-vlt-cdc          .
           move      w-ivb-ctp-imp
                    (w-det-imp-vlb-ctr)   to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
           move      w-cvs-vlt-avb        to   w-ivb-ctp-imp
                                              (w-det-imp-vlb-ctr)     .
      *                  *---------------------------------------------*
      *                  * Aggiornamento totale contropartite          *
      *                  *---------------------------------------------*
           add       w-ivb-ctp-imp
                    (w-det-imp-vlb-ctr)   to   w-ivb-tot-ctp          .
      *                  *---------------------------------------------*
      *                  * Riciclo su scansione castelletto originale  *
      *                  *---------------------------------------------*
           go to     det-imp-vlb-120.
       det-imp-vlb-140.
      *                  *---------------------------------------------*
      *                  * Aggiustamento dell'eventuale differenza tra *
      *                  * il castelletto iva e il castelletto contro- *
      *                  * partite                                     *
      *                  *---------------------------------------------*
           subtract  w-ivb-tot-ctp        from w-ivb-tot-ibl
                                        giving w-det-imp-vlb-s11      .
           add       w-det-imp-vlb-s11    to   w-ivb-ctp-imp (1)      .
           add       w-det-imp-vlb-s11    to   w-ivb-tot-ctp          .
       det-imp-vlb-200.
      *              *-------------------------------------------------*
      *              * Trattamento castelletto scadenze                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Azzeramento totalizzatori                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-ivb-tot-scb          .
           move      zero                 to   w-ivb-tot-scv          .
      *                  *---------------------------------------------*
      *                  * Test se almeno un elemento presente         *
      *                  *---------------------------------------------*
           if        w-rfa-scd-ele        =    zero
                     go to det-imp-vlb-300.
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione su castelletto originale *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-imp-vlb-ctr      .
       det-imp-vlb-220.
           add       1                    to   w-det-imp-vlb-ctr      .
           if        w-det-imp-vlb-ctr    >    w-rfa-scd-ele
                     go to det-imp-vlb-240.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione importo scadenza originale  *
      *                  *---------------------------------------------*
           move      w-rfa-scd-imp
                    (w-det-imp-vlb-ctr)   to   w-ivb-scd-imp
                                              (w-det-imp-vlb-ctr)     .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione importo scadenza originale  *
      *                  * in valuta                                   *
      *                  *---------------------------------------------*
           move      w-rfa-scd-imp
                    (w-det-imp-vlb-ctr)   to   w-ivl-scd-imp
                                              (w-det-imp-vlb-ctr)     .
      *                  *---------------------------------------------*
      *                  * Aggiornamento totale scadenze in valuta do- *
      *                  * cumento                                     *
      *                  *---------------------------------------------*
           add       w-rfa-scd-imp
                    (w-det-imp-vlb-ctr)   to   w-ivb-tot-scv          .
      *                  *---------------------------------------------*
      *                  * Conversione importo scadenza in valuta base *
      *                  *---------------------------------------------*
           move      rf-fit-sgl-vpf       to   w-cvs-vlt-sgl          .
           move      rf-fit-dec-vpf       to   w-cvs-vlt-dec          .
           move      rf-fit-tdc-vpf       to   w-cvs-vlt-tdc          .
           move      rf-fit-cdc-vpf       to   w-cvs-vlt-cdc          .
           move      w-ivb-scd-imp
                    (w-det-imp-vlb-ctr)   to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
           move      w-cvs-vlt-avb        to   w-ivb-scd-imp
                                              (w-det-imp-vlb-ctr)     .
      *                  *---------------------------------------------*
      *                  * Aggiornamento totale scadenze in valuta ba- *
      *                  * se                                          *
      *                  *---------------------------------------------*
           add       w-ivb-scd-imp
                    (w-det-imp-vlb-ctr)   to   w-ivb-tot-scb          .
      *                  *---------------------------------------------*
      *                  * Riciclo su scansione castelletto originale  *
      *                  *---------------------------------------------*
           go to     det-imp-vlb-220.
       det-imp-vlb-240.
      *                  *---------------------------------------------*
      *                  * Aggiustamento dell'eventuale differenza tra *
      *                  * il totale scadenze in valuta base e in va-  *
      *                  * luta documento                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Conversione totale scadenze in valuta   *
      *                      * documento nella valuta base             *
      *                      *-----------------------------------------*
           move      rf-fit-sgl-vpf       to   w-cvs-vlt-sgl          .
           move      rf-fit-dec-vpf       to   w-cvs-vlt-dec          .
           move      rf-fit-tdc-vpf       to   w-cvs-vlt-tdc          .
           move      rf-fit-cdc-vpf       to   w-cvs-vlt-cdc          .
           move      w-ivb-tot-scv        to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
           move      w-cvs-vlt-avb        to   w-ivb-tot-scv          .
      *                      *-----------------------------------------*
      *                      * Addebito della differenza sulla prima   *
      *                      * scadenza                                *
      *                      *-----------------------------------------*
           subtract  w-ivb-tot-scb        from w-ivb-tot-scv
                                        giving w-det-imp-vlb-s11      .
           add       w-det-imp-vlb-s11    to   w-ivb-scd-imp (1)      .
           add       w-det-imp-vlb-s11    to   w-ivb-tot-scb          .
       det-imp-vlb-300.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-imp-vlb-999.
       det-imp-vlb-999.
           exit.

      *    *===========================================================*
      *    * Determinazione status scadenza                            *
      *    *-----------------------------------------------------------*
       det-dat-chs-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione data scadenza chiusa a : Aper- *
      *              * ta                                              *
      *              *-------------------------------------------------*
           move      9999999              to   rf-sdb-dat-chs         .
       det-dat-chs-020.
      *              *-------------------------------------------------*
      *              * Controllo su : Insoluto                         *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-isp       =    zero
                     go to det-dat-chs-040.
      *                  *---------------------------------------------*
      *                  * Se la scadenza e' stata riscossa : oltre    *
      *                  *---------------------------------------------*
           if        rf-sdb-num-ris       not  = zero
                     go to det-dat-chs-040.
      *                  *---------------------------------------------*
      *                  * Se a fronte dell'insoluto non e' stata e-   *
      *                  * messa una nuova scadenza, essa e' da inten- *
      *                  * dersi ancora aperta                         *
      *                  *---------------------------------------------*
           if        rf-sdb-ens-isp       =    02   and
                     rf-sdb-nns-isp       =    zero
                     go to det-dat-chs-999.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-isp       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-040.
      *              *-------------------------------------------------*
      *              * Controllo su : Presunto buon esito              *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-pbe       =     zero
                     go to det-dat-chs-060.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-pbe       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-060.
      *              *-------------------------------------------------*
      *              * Controllo su : Presunto buon esito              *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-nbe       =     zero
                     go to det-dat-chs-080.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-nbe       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-080.
      *              *-------------------------------------------------*
      *              * Controllo su : Accredito scadenza al dopo in-   *
      *              *                casso                            *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-acs       =     zero
                     go to det-dat-chs-100.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-acs       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-100.
      *              *-------------------------------------------------*
      *              * Controllo su : Richiamo della scadenza presen-  *
      *              *                tata                             *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-rsp       =     zero
                     go to det-dat-chs-120.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-rsp       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-120.
      *              *-------------------------------------------------*
      *              * Controllo su : Inclusione in distinta           *
      *              *-------------------------------------------------*
           if        rf-sdb-num-ddp       =     zero
                     go to det-dat-chs-140.
      *                  *---------------------------------------------*
      *                  * Nessuna azione                              *
      *                  *---------------------------------------------*
           go to     det-dat-chs-140.
       det-dat-chs-140.
      *              *-------------------------------------------------*
      *              * Controllo su : Riscossione                      *
      *              *-------------------------------------------------*
           if        rf-sdb-dtr-ris       =     zero
                     go to det-dat-chs-160.
      *                  *---------------------------------------------*
      *                  * Memorizzazione data chiusura scadenza       *
      *                  *---------------------------------------------*
           move      rf-sdb-dtr-ris       to   rf-sdb-dat-chs         .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-dat-chs-999.
       det-dat-chs-160.
      *              *-------------------------------------------------*
      *              * Controllo su : Storno                           *
      *              *-------------------------------------------------*
