           if        rr-rag-max           =    spaces
                     go to cnt-tdo-ric-200.
           if        rr-rag-max           not  < rr-rag-min
                     go to cnt-tdo-ric-200.
           move      "ME"                 to   v-ope                  .
           move      "La ragione sociale massima non puo' essere inferio
      -              "re a quella minima !"
                                          to   v-not                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "#"                  to   w-cnt-tdo-ric-flg      .
           go to     cnt-tdo-ric-999.
       cnt-tdo-ric-200.
