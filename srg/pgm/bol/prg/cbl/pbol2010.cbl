                     rr-tip-ord           =    "C" or
                     rr-tip-ord           =    "M" or
                     rr-tip-ord           =    "P" or
                     rr-tip-ord           =    "F"
                     go to cnt-tdo-ric-100.
           move      "ME"                 to   v-ope                  .
           move      "Tipo ordinamento errato !"
                                          to   v-not                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "#"                  to   w-cnt-tdo-ric-flg      .
           go to     cnt-tdo-ric-999.
       cnt-tdo-ric-100.
      *                  *---------------------------------------------*
