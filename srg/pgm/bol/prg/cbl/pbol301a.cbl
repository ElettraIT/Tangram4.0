      *                  * Se at end : uscita                          *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to int-srt-inp-rig-900.
       int-srt-inp-rig-300.
      *              *-------------------------------------------------*
      *              * Se oltre il massimo : a controllo contatore     *
      *              *-------------------------------------------------*
           if        rf-bir-num-prt       not  = rf-bit-num-prt
                     go to int-srt-inp-rig-900.
       int-srt-inp-rig-400.
      *              *-------------------------------------------------*
      *              * Selezioni sul record                            *
      *              *-------------------------------------------------*
       int-srt-inp-rig-600.
      *              *-------------------------------------------------*
      *              * Incremento numero records nel buffer            *
      *              *-------------------------------------------------*
           add       1                    to   w-det-tot-doc-rig      .
       int-srt-inp-rig-800.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     int-srt-inp-rig-200.
       int-srt-inp-rig-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     int-srt-inp-rig-999.
       int-srt-inp-rig-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Subroutine per preparazione chiavi di sort                *
      *    *-----------------------------------------------------------*
       int-srt-inp-key-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione preliminare                     *
      *              *-------------------------------------------------*
           move      spaces               to   srt-tip-doc            .
           move      zero                 to   srt-num-key            .
           move      zero                 to   srt-dat-key            .
           move      zero                 to   srt-ndt-key            .
           move      spaces               to   srt-dpz-arc            .
           move      zero                 to   srt-tot-key            .
           move      spaces               to   srt-ann-key            .
           move      zero                 to   srt-rig-key            .
       int-srt-inp-key-050.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo di ordinamento  *
      *              *-------------------------------------------------*
           go to     int-srt-inp-key-100
                     int-srt-inp-key-200
                     int-srt-inp-key-300
                     int-srt-inp-key-400
                     int-srt-inp-key-500
                     int-srt-inp-key-600
                     int-srt-inp-key-700
                     depending            on   w-cnt-exe-rou-sro      .
       int-srt-inp-key-100.
      *              *-------------------------------------------------*
      *              * 1. per tipo documento                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Completamento chiave                        *
      *                  *---------------------------------------------*
           move      rf-bit-cod-tmb       to   srt-num-key            .
           move      rf-bit-dpz-arc       to   srt-dpz-arc            .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     int-srt-inp-key-900.
       int-srt-inp-key-200.
      *              *-------------------------------------------------*
      *              * 2. per numero documento                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Completamento chiave                        *
      *                  *---------------------------------------------*
           move      rf-bit-num-doc
                    (06 : 06)             to   srt-num-key            .
           move      rf-bit-dpz-arc       to   srt-dpz-arc            .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     int-srt-inp-key-900.
       int-srt-inp-key-300.
      *              *-------------------------------------------------*
      *              * 3. per data documento                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Completamento chiave                        *
      *                  *---------------------------------------------*
           move      rf-bit-dat-doc       to   srt-dat-key            .
           move      rf-bit-num-doc
                    (06 : 06)             to   srt-ndt-key            .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     int-srt-inp-key-900.
       int-srt-inp-key-400.
      *              *-------------------------------------------------*
      *              * 4. per dipendenza archivio                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Completamento chiave                        *
      *                  *---------------------------------------------*
           move      rf-bit-dpz-arc       to   srt-dpz-arc            .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     int-srt-inp-key-900.
       int-srt-inp-key-500.
      *              *-------------------------------------------------*
      *              * 5. per residuo documento                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Completamento chiave                        *
      *                  *---------------------------------------------*
           move      w-det-tot-doc-tot    to   srt-tot-key            .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     int-srt-inp-key-900.
       int-srt-inp-key-600.
      *              *-------------------------------------------------*
      *              * 6. per annotazioni                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Completamento chiave                        *
      *                  *---------------------------------------------*
           move      w-det-ann-doc-des    to   srt-ann-key            .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     int-srt-inp-key-900.
       int-srt-inp-key-700.
      *              *-------------------------------------------------*
      *              * 7. per numero righe                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Completamento chiave                        *
      *                  *---------------------------------------------*
           move      w-det-tot-doc-rig    to   srt-rig-key            .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     int-srt-inp-key-900.
       int-srt-inp-key-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     int-srt-inp-key-999.
       int-srt-inp-key-999.
