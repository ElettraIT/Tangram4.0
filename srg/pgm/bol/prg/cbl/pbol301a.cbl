      *    *===========================================================*
      *    * Routine di sort preliminare                               *
      *    *-----------------------------------------------------------*
       exe-rou-srt-000.
      *              *-------------------------------------------------*
      *              * Esecuzione sort in ordine ascendente oppure     *
      *              *  discendente                                    *
      *              *-------------------------------------------------*
           if        w-cnt-exe-rou-srt    =    "<"
                     go to exe-rou-srt-140
           else      go to exe-rou-srt-120.
       exe-rou-srt-120.
      *              *-------------------------------------------------*
      *              * Se ordine ascendente                            *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   int-srt-inp-000
                                          thru int-srt-inp-999
                     output procedure     is   qry-rou-pri-000
                                          thru qry-rou-pri-999        .
      *
           go to     exe-rou-srt-900.
       exe-rou-srt-140.
      *              *-------------------------------------------------*
      *              * Se ordine discendente                           *
      *              *-------------------------------------------------*
           sort      srt                  on   descending srt-key
                     input  procedure     is   int-srt-inp-000
                                          thru int-srt-inp-999
                     output procedure     is   qry-rou-pri-000
                                          thru qry-rou-pri-999        .
      *
           go to     exe-rou-srt-900.
       exe-rou-srt-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-rou-srt-999.
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       int-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni                                 *
      *              *-------------------------------------------------*
       int-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Start su [bit] per cliente                      *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DPZARCDAT "         to   f-key                  .
           move      rr-dpz-inu           to   rf-bit-cod-dpz         .
           move      "C"                  to   rf-bit-tip-arc         .
           move      rr-cod-cli           to   rf-bit-cod-arc         .
           move      rr-dem-min           to   rf-bit-dat-doc         .
           move      zero                 to   rf-bit-num-doc         .
           move      zero                 to   rf-bit-num-prt         .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to int-srt-inp-900.
       int-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [bit]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At End'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to int-srt-inp-900.
       int-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su dipendenza e archivio               *
      *                  *---------------------------------------------*
           if        rf-bit-cod-dpz       not  = rr-dpz-inu or
                     rf-bit-tip-arc       not  = "C"        or
                     rf-bit-cod-arc       not  = rr-cod-cli
                     go to int-srt-inp-900.
       int-srt-inp-310.
      *                  *---------------------------------------------*
      *                  * Test su data emissione min e max            *
      *                  *---------------------------------------------*
           if        rr-dem-max           =    zero
                     go to int-srt-inp-320
           else      go to int-srt-inp-340.
       int-srt-inp-320.
      *                  *---------------------------------------------*
      *                  * Se data emissione max a zero                *
      *                  *---------------------------------------------*
           if        rr-dem-min           =    zero
                     go to int-srt-inp-400.
           if        rf-bit-dat-doc       >    rr-dem-min
                     go to int-srt-inp-900.
           go to     int-srt-inp-400.
       int-srt-inp-340.
      *                  *---------------------------------------------*
      *                  * Se data emissione massima non zero          *
      *                  *---------------------------------------------*
           if        rf-bit-dat-doc       >    rr-dem-max
                     go to int-srt-inp-900.
           go to     int-srt-inp-400.
       int-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Selezione su codice dipendenza del cliente  *
      *                  *---------------------------------------------*
           if        rr-dpz-cli           =    "*   "
                     go to int-srt-inp-420.
           if        rf-bit-dpz-arc       not  = rr-dpz-cli
                     go to int-srt-inp-200.
       int-srt-inp-420.
      *              *-------------------------------------------------*
      *              * Selezione su tipo movimento da ricercare        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se tipo movimento da ricercare a spaces :   *
      *                  * nessuna selezione                           *
      *                  *---------------------------------------------*
           if        rr-cod-tmb           =    spaces
                     go to int-srt-inp-500.
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        rf-bit-cod-tmb       not  = rr-cod-tmb
                     go to int-srt-inp-200.
       int-srt-inp-500.
      *              *-------------------------------------------------*
      *              * Determinazione totale documento                 *
      *              *-------------------------------------------------*
           perform   det-tot-doc-000      thru det-tot-doc-999        .
      *              *-------------------------------------------------*
      *              * Determinazione annotazioni                      *
      *              *-------------------------------------------------*
           perform   int-srt-inp-ann-000  thru int-srt-inp-ann-999    .
      *              *-------------------------------------------------*
      *              * Determinazione numero righe documento           *
      *              *-------------------------------------------------*
           perform   int-srt-inp-rig-000  thru int-srt-inp-rig-999    .
       int-srt-inp-600.
      *              *-------------------------------------------------*
      *              * Preparazione record di Sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione iniziale                    *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Chiave di sort                              *
      *                  *---------------------------------------------*
           perform   int-srt-inp-key-000  thru int-srt-inp-key-999    .
       int-srt-inp-650.
      *                  *---------------------------------------------*
      *                  * Dati di sort                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Numero protocollo                       *
      *                      *-----------------------------------------*
           move      rf-bit-num-prt       to   srt-num-prt            .
      *                      *-----------------------------------------*
      *                      * Imponibile documento                    *
      *                      *-----------------------------------------*
           move      w-det-tot-doc-tot    to   srt-tot-doc            .
      *                      *-----------------------------------------*
      *                      * Annotazioni                             *
      *                      *-----------------------------------------*
           move      w-det-ann-doc-des    to   srt-ann-doc            .
      *                      *-----------------------------------------*
      *                      * Righe documento                         *
      *                      *-----------------------------------------*
           move      w-det-tot-doc-rig    to   srt-rig-doc            .
       int-srt-inp-700.
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       int-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     int-srt-inp-200.
       int-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     int-srt-inp-999.
       int-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Subroutine per la determinazione delle annotazioni        *
      *    *-----------------------------------------------------------*
       int-srt-inp-ann-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione preliminare                     *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-ann-doc-des      .
       int-srt-inp-ann-050.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda del tipo di interesse per  *
      *              * la fatturazione                                 *
      *              *-------------------------------------------------*
           go to     int-srt-inp-ann-100
                     int-srt-inp-ann-200
                     int-srt-inp-ann-300
                     depending            on    rf-bit-int-ftr        .
           go to     int-srt-inp-ann-900.
       int-srt-inp-ann-100.
      *              *-------------------------------------------------*
      *              * Se documento non interessa la fatturazione      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Literal                                     *
      *                  *---------------------------------------------*
           move      "Non fatturabile"    to   w-det-ann-doc-des      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     int-srt-inp-ann-900.
       int-srt-inp-ann-200.
      *              *-------------------------------------------------*
      *              * Se documento sottoponibile a fatturazione       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda che sia stato fattura- *
      *                  * to o no                                     *
      *                  *---------------------------------------------*
           if        rf-bit-fat-dat       =    zero and
                     rf-bit-fat-num       =    zero
                     go to int-srt-inp-ann-220.
      *                  *---------------------------------------------*
      *                  * Se e' stato fatturato                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura del tipo di movimento per la    *
      *                      * fatturazione                            *
      *                      *-----------------------------------------*
           move      rf-bit-tmo-ftr       to   w-let-arc-zfi-cod      .
           perform   let-arc-zfi-000      thru let-arc-zfi-999        .
      *                      *-----------------------------------------*
      *                      * Editing numero fattura                  *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      rf-bit-fat-num       to   w-wrk-num-doc          .
           move      w-wrk-ndo-prg        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-det-ann-doc-ned      .
      *                      *-----------------------------------------*
      *                      * Editing data fattura                    *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      rf-bit-fat-dat       to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-edt                to   w-det-ann-doc-ded      .
      *                      *-----------------------------------------*
      *                      * Composizione stringa                    *
      *                      *-----------------------------------------*
           move      27                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
           if        w-let-arc-zfi-tdo    =    01
                     move  "Ft. nr."      to   w-all-str-cat (1)
           else if   w-let-arc-zfi-tdo    =    02
                     move  "Nd. nr."      to   w-all-str-cat (1)
           else if   w-let-arc-zfi-tdo    =    03
                     move  "Nc. nr."      to   w-all-str-cat (1)
           else      move  "Ft. nr."      to   w-all-str-cat (1)      .
           move      w-det-ann-doc-ned    to   w-all-str-cat (2)      .
           move      "del"                to   w-all-str-cat (3)      .
           move      w-det-ann-doc-ded    to   w-all-str-cat (4)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
           move      w-all-str-alf        to   w-det-ann-doc-des      .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     int-srt-inp-ann-900.
       int-srt-inp-ann-220.
      *                  *---------------------------------------------*
      *                  * Se non e' ancora stato sottoposto a fattura *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Literal                                 *
      *                      *-----------------------------------------*
           move      "Da fatturare"       to   w-det-ann-doc-des      .
      *                      *-----------------------------------------*
      *                      * Eventuale segnale di momentanea esclu-  *
      *                      * sione del documento dalla fatturazione  *
      *                      * differita automatica                    *
      *                      *-----------------------------------------*
           if        rf-bit-flg-nbx (1)   =    spaces
                     go to int-srt-inp-ann-900.
      *                      *-----------------------------------------*
      *                      * Concatenamento                          *
      *                      *-----------------------------------------*
           move      27                   to   w-all-str-lun          .
           move      02                   to   w-all-str-num          .
           move      w-det-ann-doc-des    to   w-all-str-cat (1)      .
           move      "(in sospeso)"       to   w-all-str-cat (2)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
           move      w-all-str-alf        to   w-det-ann-doc-des      .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     int-srt-inp-ann-900.
       int-srt-inp-ann-300.
      *              *-------------------------------------------------*
      *              * Se documento che e' anche fattura               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     int-srt-inp-ann-900.
       int-srt-inp-ann-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     int-srt-inp-ann-999.
       int-srt-inp-ann-999.
           exit.

