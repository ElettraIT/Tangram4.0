      *                      * Preparazione valori per la chiamata     *
      *                      *-----------------------------------------*
           move      v-cnt                to   w-mpn                  .
           move      w-mpn-dat-doc        to   w-esp-idv-bit-dat      .
           move      w-mpn-num-doc        to   w-esp-idv-bit-num      .
           move      w-mpn-cod-tmb        to   w-esp-idv-bit-tmo      .
           move      w-mpn-num-prt        to   w-esp-idv-bit-prt      .
