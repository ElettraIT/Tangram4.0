      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Operazioni preliminari                          *
      *              *-------------------------------------------------*
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Start su file [dcc]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "CODCLI    "         to   f-key                  .
           move      zero                 to   rf-dcc-cod-cli         .
           move      spaces               to   rf-dcc-dpz-cli         .
           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : ad uscita                 *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Next su [dcc]                                   *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofdcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcc                 .
      *                  *---------------------------------------------*
      *                  * Se 'at end' : ad uscita                     *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-900.
       stp-srt-inp-300.
      *              *-------------------------------------------------*
      *              * Test max su [dcc]                               *
      *              *-------------------------------------------------*
       stp-srt-inp-400.
      *              *-------------------------------------------------*
      *              * Record [cli] corrispondente                     *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCLI"             to   f-key                  .
           move      rf-dcc-cod-cli       to   rf-cli-cod-cli         .
           move      "pgm/cge/fls/ioc/obj/iofcli"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-cli                 .
      *                  *---------------------------------------------*
      *                  * Se record [cli] non trovato : riciclo       *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Selezioni su record su [dcc]                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se cliente con codici vettore          *
      *                  *---------------------------------------------*
           if        rf-dcc-cod-vet       =    zero   and
                     rf-dcc-cod-vt2       =    zero   and
                     rf-dcc-cod-vt3       =    zero
                     go to stp-srt-inp-200.
       stp-srt-inp-420.
      *              *-------------------------------------------------*
      *              * Preparazione campi per ciclo di 3 vettori       *
      *              *-------------------------------------------------*
           move      zero                 to  w-stp-srt-inp-vet       .
           move      zero                 to  w-stp-srt-inp-ctr       .
       stp-srt-inp-450.
      *              *-------------------------------------------------*
      *              * Ciclo per eventuali tre vettori                 *
      *              *-------------------------------------------------*
           add       1                    to  w-stp-srt-inp-ctr       .
           if        w-stp-srt-inp-ctr    >   3
                     go to stp-srt-inp-200.
       stp-srt-inp-460.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del contatore        *
      *                  *---------------------------------------------*
           if        w-stp-srt-inp-ctr    =   1
                     go to stp-srt-inp-462
           else if   w-stp-srt-inp-ctr    =   2
                     go to stp-srt-inp-464
           else      go to stp-srt-inp-466.
       stp-srt-inp-462.
      *                  *---------------------------------------------*
      *                  * Codice vettore 1                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se a zero                          *
      *                      *-----------------------------------------*
           if        rf-dcc-cod-vet       =   zero
                     go to stp-srt-inp-450.
      *                      *-----------------------------------------*
      *                      * Codice vettore in campo di comodo       *
      *                      *-----------------------------------------*
           move      rf-dcc-cod-vet       to  w-stp-srt-inp-vet       .
      *                      *-----------------------------------------*
      *                      * A lettura vettore per selezioni         *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-500.
       stp-srt-inp-464.
      *                  *---------------------------------------------*
      *                  * Codice vettore 2                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se a zero                          *
      *                      *-----------------------------------------*
           if        rf-dcc-cod-vt2       =   zero
                     go to stp-srt-inp-450.
      *                      *-----------------------------------------*
      *                      * Test se gia' comparso                   *
      *                      *-----------------------------------------*
           if        rf-dcc-cod-vt2       =   rf-dcc-cod-vet
                     go to stp-srt-inp-450.
      *                      *-----------------------------------------*
      *                      * Codice vettore in campo di comodo       *
      *                      *-----------------------------------------*
           move      rf-dcc-cod-vt2       to  w-stp-srt-inp-vet       .
      *                      *-----------------------------------------*
      *                      * A lettura vettore per selezioni         *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-500.
       stp-srt-inp-466.
      *                  *---------------------------------------------*
      *                  * Codice vettore 3                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se a zero                          *
      *                      *-----------------------------------------*
           if        rf-dcc-cod-vt3       =   zero
                     go to stp-srt-inp-450.
      *                      *-----------------------------------------*
      *                      * Test se gia' comparso                   *
      *                      *-----------------------------------------*
           if        rf-dcc-cod-vt3       =   rf-dcc-cod-vet
                     go to stp-srt-inp-450.
           if        rf-dcc-cod-vt3       =   rf-dcc-cod-vt2
                     go to stp-srt-inp-450.
      *                      *-----------------------------------------*
      *                      * Codice vettore in campo di comodo       *
      *                      *-----------------------------------------*
           move      rf-dcc-cod-vt3       to  w-stp-srt-inp-vet       .
      *                      *-----------------------------------------*
      *                      * A lettura vettore per selezioni         *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-500.
       stp-srt-inp-500.
      *              *-------------------------------------------------*
      *              * Letture addizionali                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura record [vet]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODVET    "         to   f-key                  .
           move      w-stp-srt-inp-vet    to   rf-vet-cod-vet         .
           move      "pgm/bol/fls/ioc/obj/iofvet"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-vet                 .
      *                      *-----------------------------------------*
      *                      * Se record [vet] non trovato : riciclo   *
      *                      * a vettore successivo                    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-450.
      *                  *---------------------------------------------*
      *                  * Selezioni su anagrafica vettore             *
      *                  *---------------------------------------------*
           if        rf-vet-cod-vet       <    rr-cod-min or
                     rf-vet-cod-vet       >    rr-cod-max or
                     rf-vet-rag-key       <    rr-rag-min or
                     rf-vet-rag-key       >    rr-rag-max or
                     rf-vet-cod-mne       <    rr-mne-min or
                     rf-vet-cod-mne       >    rr-mne-max
                     go to stp-srt-inp-450.
       stp-srt-inp-600.
      *              *-------------------------------------------------*
      *              * Composizione record di Sort                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione preliminare                 *
      *                  *---------------------------------------------*
           move      spaces               to   srt-rec                .
      *                  *---------------------------------------------*
      *                  * Composizione chiave di Sort                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Chiave di ordinamento alfanumerica per  *
      *                      * i vettori                               *
      *                      *-----------------------------------------*
           if        rr-tip-orv           =    1
                     move  spaces         to   srt-key-alv
           else if   rr-tip-orv           =    2
                     move  rf-vet-rag-key to   srt-key-alv
           else      move  rf-vet-cod-mne to   srt-key-alv            .
      *                      *-----------------------------------------*
      *                      * Chiave di ordinamento numerica per i    *
      *                      * vettori                                 *
      *                      *-----------------------------------------*
           move      w-stp-srt-inp-vet    to   srt-key-nuv            .
      *                      *-----------------------------------------*
      *                      * Chiave di ordinamento alfanumerica per  *
      *                      * clienti                                 *
      *                      *-----------------------------------------*
           if        rr-tip-orc           =    1
                     move  spaces         to   srt-key-alc
           else if   rr-tip-orc           =    2
                     move  rf-dcc-rag-key to   srt-key-alc
           else      move  rf-cli-cod-mne to   srt-key-alc            .
      *                      *-----------------------------------------*
      *                      * Chiave di ordinamento numerica per i    *
      *                      * clienti                                 *
      *                      *-----------------------------------------*
           move      rf-dcc-cod-cli       to   srt-key-nuc            .
      *                  *---------------------------------------------*
      *                  * Composizione dati di Sort                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Record [dcc]                            *
      *                      *-----------------------------------------*
           move      rf-dcc               to   srt-dat-rec-dcc        .
      *                      *-----------------------------------------*
      *                      * Record [vet]                            *
      *                      *-----------------------------------------*
           move      rf-vet               to   srt-dat-rec-vet        .
       stp-srt-inp-800.
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-820.
      *              *-------------------------------------------------*
      *              * Riciclo a vettore [dcc] successivo              *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-450.
       stp-srt-inp-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-srt-inp-999.
       stp-srt-inp-999.
           exit.

