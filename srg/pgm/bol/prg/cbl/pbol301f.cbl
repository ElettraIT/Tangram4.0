      *              *-------------------------------------------------*
      *              * Normalizzazione flag di End-of-file             *
      *              *-------------------------------------------------*
           move      spaces               to   w-rip-str-bir-eof      .
       qry-str-ini-100.
      *              *-------------------------------------------------*
      *              * Start su [bir] per prodotto                     *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "MAGDAT    "         to   f-key                  .
           move      rr-dpz-inu           to   rf-bir-cod-dpz         .
           move      01                   to   rf-bir-tip-mag         .
           move      rr-cod-pro           to   rf-bir-num-pro         .
           move      rr-drg-min           to   rf-bir-dat-doc         .
           move      zero                 to   rf-bir-num-doc         .
           move      zero                 to   rf-bir-num-prt         .
           move      zero                 to   rf-bir-num-prg         .
           move      "pgm/bol/fls/ioc/obj/iofbir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bir                 .
      *              *-------------------------------------------------*
