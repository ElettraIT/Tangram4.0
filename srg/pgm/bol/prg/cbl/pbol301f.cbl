      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-qry-flg-sub      .
       qry-tst-max-050.
      *              *-------------------------------------------------*
      *              * Se fine dipendenza in uso : superamento         *
      *              *-------------------------------------------------*
           if        rf-bir-cod-dpz       not  = rr-dpz-inu
                     go to qry-tst-max-900.
       qry-tst-max-100.
      *              *-------------------------------------------------*
      *              * Se fine prodotto : superamento                  *
      *              *-------------------------------------------------*
           if        rf-bir-tip-mag       not  = 01
                     go to qry-tst-max-900.
           if        rf-bir-num-pro       not  = rr-cod-pro
                     go to qry-tst-max-900.
       qry-tst-max-200.
      *              *-------------------------------------------------*
      *              * Se oltre data registrazione massima : supera-   *
      *              * mento                                           *
      *              *-------------------------------------------------*
           if        rr-drg-max           =    zero
                     go to qry-tst-max-220
           else      go to qry-tst-max-240.
       qry-tst-max-220.
      *                  *---------------------------------------------*
      *                  * Se data registrazione massima a zero        *
      *                  *---------------------------------------------*
           if        rr-drg-min           =    zero
                     go to qry-tst-max-300.
           if        rf-bir-dat-doc       >    rr-drg-min
                     go to qry-tst-max-900.
           go to     qry-tst-max-300.
       qry-tst-max-240.
      *                  *---------------------------------------------*
      *                  * Se data registrazione massima non zero      *
      *                  *---------------------------------------------*
           if        rf-bir-dat-doc       >    rr-drg-max
                     go to qry-tst-max-900.
           go to     qry-tst-max-300.
       qry-tst-max-300.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     qry-tst-max-999.
       qry-tst-max-900.
