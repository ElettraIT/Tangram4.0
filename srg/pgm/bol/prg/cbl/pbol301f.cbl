      *    *-----------------------------------------------------------*
       qry-sel-rec-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-qry-flg-sub      .
       qry-sel-rec-100.
      *              *-------------------------------------------------*
      *              * Selezione su tipo movimento da ricercare        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se tipo movimento da ricercare a spaces :   *
      *                  * nessuna selezione                           *
      *                  *---------------------------------------------*
           if        rr-cod-tmb           =    spaces
                     go to qry-sel-rec-300.
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        rf-bir-cod-tmb       =    rr-cod-tmb
                     go to qry-sel-rec-300
           else      go to qry-sel-rec-900.
       qry-sel-rec-300.
      *              *-------------------------------------------------*
      *              * Test su tipo archivio                           *
      *              *-------------------------------------------------*
           if        rr-tip-arc           =    01
                     go to qry-sel-rec-400
           else if   rr-tip-arc           =    02  and
                     rf-bir-tip-arc       =    "F"
                     go to qry-sel-rec-350
           else if   rr-tip-arc           =    03  and
                     rf-bir-tip-arc       =    "C"
                     go to qry-sel-rec-350
           else if   rr-tip-arc           =    04  and
                     rf-bir-tip-arc       =    "D"
                     go to qry-sel-rec-350
           else if   rr-tip-arc           =    05  and
                     rf-bir-tip-arc       =    "A"
                     go to qry-sel-rec-350
           else if   rr-tip-arc           =    06  and
                     rf-bir-tip-arc       =    " "
                     go to qry-sel-rec-350
           else      go to qry-sel-rec-900.
       qry-sel-rec-350.
      *                  *---------------------------------------------*
      *                  * Test su codice archivio                     *
      *                  *---------------------------------------------*
           if        rr-cod-arc           not  = zero   and
                     rf-bir-cod-arc       not  = rr-cod-arc
                     go to qry-sel-rec-900.
       qry-sel-rec-400.
      *              *-------------------------------------------------*
      *              * Test su numero e data lotto (ex variante)       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su personalizzazione                   *
      *                  *---------------------------------------------*
           if        w-prs-sgl-vrn-snx    not  = "S" and
                     w-prs-sgl-vrn-snx    not  = "L"
                     go to qry-sel-rec-800.
      *                  *---------------------------------------------*
      *                  * Test su numero lotto                        *
      *                  *---------------------------------------------*
           if        rr-sgl-vrn-lot       =    spaces
                     go to qry-sel-rec-420.
