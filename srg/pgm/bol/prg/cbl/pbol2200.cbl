      *              *-------------------------------------------------*
      *              * Erase linee impegnate dalla chiave              *
      *              *-------------------------------------------------*
           move      "EL"                 to   v-ope                  .
           move      04                   to   v-lin                  .
           move      07                   to   v-lto                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Codice vettore                                  *
      *              *-------------------------------------------------*
           perform   pmt-cod-vet-000      thru pmt-cod-vet-999        .
      *              *-------------------------------------------------*
      *              * Codice giro                                     *
      *              *-------------------------------------------------*
           perform   pmt-cod-grc-000      thru pmt-cod-grc-999        .
      *              *-------------------------------------------------*
      *              * Numero giro                                     *
      *              *-------------------------------------------------*
           perform   pmt-num-grc-000      thru pmt-num-grc-999        .
      *              *-------------------------------------------------*
      *              * Linea di trattini di separazione a linea 07     *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      all "-"              to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-key-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per Codice vettore                *
      *    *-----------------------------------------------------------*
       pmt-cod-vet-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Codice vettore             :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cod-vet-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per Codice giro                   *
      *    *-----------------------------------------------------------*
       pmt-cod-grc-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Codice giro                :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
