      *                  *---------------------------------------------*
           move      "PV"                 to   s-ope                  .
           move      "cod-grc"            to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "N"                  to   s-tip                  .
           move      03                   to   s-car                  .
           move      zero                 to   s-dec                  .
           move      spaces               to   s-sgn                  .
           move      w-tes-cod-grc        to   s-num                  .
