                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zgc                 .
       scr-rec-zgc-600.
      *              *-------------------------------------------------*
      *              * Riciclo a lettura record di sort                *
      *              *-------------------------------------------------*
           go to     scr-rec-zgc-200.
       scr-rec-zgc-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     scr-rec-zgc-999.
       scr-rec-zgc-999.
           exit.

      *    *===========================================================*
      *    * Delete movimento da file                                  *
      *    *-----------------------------------------------------------*
       del-mov-fil-000.
      *              *-------------------------------------------------*
      *              * Cancellazione righe                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Start su righe corpo                        *
