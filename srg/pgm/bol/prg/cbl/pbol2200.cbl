       pmt-num-grc-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Numero giorno              :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
