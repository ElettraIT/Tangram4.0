           move      spaces               to   w-cnt-rou-let-reg      .
      *              *-------------------------------------------------*
      *              * Normalizzazione contatore record letti          *
      *              *-------------------------------------------------*
           move      zero                 to   w-rou-let-reg-ctr      .
      *              *-------------------------------------------------*
      *              * Start su file [zgc]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "GIRCLI    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      "V"                  to   rf-zgc-tip-arc         .
           move      w-tes-cod-arc        to   rf-zgc-cod-arc         .
           move      w-tes-cod-grc        to   rf-zgc-cod-grc         .
           move      w-tes-num-grc        to   rf-zgc-num-grc         .
           move      zero                 to   rf-zgc-num-prg         .
           move      zero                 to   rf-zgc-cod-cli         .
           move      spaces               to   rf-zgc-dpz-cli         .
           move      "pgm/bol/fls/ioc/obj/iofzgc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zgc                 .
           if        f-sts                =    e-not-err
                     go to  rou-let-reg-200.
      *                      *-----------------------------------------*
      *                      * Se errore di start : ad inserimento     *
      *                      *-----------------------------------------*
           go to     rou-let-reg-920.
       rou-let-reg-200.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale file [zgc]              *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofzgc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zgc                 .
      *                      *-----------------------------------------*
      *                      * Se at end : a test su contatore         *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  rou-let-reg-900.
      *                  *---------------------------------------------*
      *                  * Se oltre il massimo : a test su contatore   *
      *                  *---------------------------------------------*
           if        rf-zgc-tip-arc       not  = "V"           or
                     rf-zgc-cod-arc       not  = w-tes-cod-arc or
                     rf-zgc-cod-grc       not  = w-tes-cod-grc or
                     rf-zgc-num-grc       not  = w-tes-num-grc
                     go to  rou-let-reg-900.
      *                  *---------------------------------------------*
      *                  * Incremento contatore record letti           *
      *                  *---------------------------------------------*
           add       1                    to   w-rou-let-reg-ctr      .
      *                  *---------------------------------------------*
      *                  * Test se primo passaggio                     *
      *                  *---------------------------------------------*
           if        w-rou-let-reg-ctr    not  = 1
                     go to rou-let-reg-400.
       rou-let-reg-300.
      *                  *---------------------------------------------*
      *                  * Inizializzazione catena [rig]               *
      *                  *---------------------------------------------*
           move      "BE"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       rou-let-reg-400.
      *                  *---------------------------------------------*
      *                  * Bufferizzazione riga                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Valori attuali                          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Valori contenuti direttamente in    *
      *                          * record [zgc]                        *
      *                          *-------------------------------------*
           move      rf-zgc-ide-dat       to   w-rig-ide-dat (1)      .
           move      rf-zgc-ide-ute       to   w-rig-ide-ute (1)      .
           move      rf-zgc-ide-fas       to   w-rig-ide-fas (1)      .
           move      rf-zgc-num-prg       to   w-rig-num-prg (1)      .
           move      rf-zgc-cod-cli       to   w-rig-cod-cli (1)      .
           move      rf-zgc-dpz-cli       to   w-rig-dpz-cli (1)      .
           move      rf-zgc-alx-exp       to   w-rig-alx-exp (1)      .
      *                          *-------------------------------------*
      *                          * Valori contenuti indirettamente in  *
      *                          * record [zgc]                        *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Valori dipendenti dal codice    *
      *                              * cliente                         *
      *                              *---------------------------------*
           move      w-rig-cod-cli (1)    to   w-let-arc-dcc-cli      .
           move      spaces               to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
           move      w-let-arc-dcc-rag    to   w-rig-cod-cli-rag (1)  .
      *
           move      w-rig-cod-cli (1)    to   w-let-arc-dcc-cli      .
           move      w-rig-dpz-cli (1)    to   w-let-arc-dcc-dpz      .
           perform   let-arc-dcc-000      thru let-arc-dcc-999        .
           move      w-let-arc-dcc-rag    to   w-rig-dpz-cli-rag (1)  .
       rou-let-reg-600.
      *                      *-----------------------------------------*
      *                      * Valori precedenti                       *
      *                      *-----------------------------------------*
           move      w-rig-val-aep (1)    to   w-rig-val-aep (2)      .
      *                      *-----------------------------------------*
      *                      * Put su catena movimenti [rig]           *
      *                      *-----------------------------------------*
           move      "PT"                 to   w-cat-rig-ope          .
           move      rf-zgc-num-prg       to   w-cat-rig-prg          .
           move      w-rig                to   w-cat-rig-buf          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo a lettura [zgc] successivo          *
      *                  *---------------------------------------------*
           go to     rou-let-reg-200.
       rou-let-reg-900.
      *              *-------------------------------------------------*
