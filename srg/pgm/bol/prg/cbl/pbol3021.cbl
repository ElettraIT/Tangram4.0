      *              * Flag di sort eseguito a : Si'                   *
      *              *-------------------------------------------------*
           move      "#"                  to   w-cnt-exe-rou-srt      .
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   stp-srt-inp-000
                                          thru stp-srt-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-rou-srt-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del tipo di stampa       *
      *              *-------------------------------------------------*
           if        rr-tip-stp           =    01
                     go to stp-srt-inp-010
           else if   rr-tip-stp           =    02
                     go to stp-srt-inp-020
           else      go to stp-srt-inp-030.
       stp-srt-inp-010.
      *              *-------------------------------------------------*
      *              * Start su archivio [bit] per data registrazione  *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "IDEDOC    "         to   f-key                  .
           move      rr-dat-ini           to   rf-bit-dat-doc         .
           move      zero                 to   rf-bit-cod-dpz         .
           move      zero                 to   rf-bit-num-doc         .
           move      spaces               to   rf-bit-cod-tmb         .
           move      zero                 to   rf-bit-num-prt         .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
      *                  *---------------------------------------------*
      *                  * A read-next                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-100.
       stp-srt-inp-020.
      *              *-------------------------------------------------*
      *              * Start su archivio [bit] per data ultima modifi- *
      *              * ca                                              *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DATSYS    "         to   f-key                  .
           move      rr-dat-ini           to   rf-bit-ide-dat         .
           move      zero                 to   rf-bit-dat-doc         .
           move      zero                 to   rf-bit-num-prt         .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
      *                  *---------------------------------------------*
      *                  * A read-next                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-100.
       stp-srt-inp-030.
      *              *-------------------------------------------------*
      *              * Start su archivio [bit] per documenti da fat-   *
      *              * turare                                          *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "FATARC     "        to   f-key                  .
           move      "S"                  to   rf-bit-fat-snx         .
           move      zero                 to   rf-bit-fat-dat         .
           move      zero                 to   rf-bit-fat-num         .
           move      zero                 to   rf-bit-fat-npb         .
           move      "C"                  to   rf-bit-tip-arc         .
           move      zero                 to   rf-bit-arc-plf         .
           move      zero                 to   rf-bit-num-prt         .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
      *                  *---------------------------------------------*
      *                  * A read-next                                 *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-100.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Indicatore di programma in esecuzione           *
      *              *-------------------------------------------------*
           move      "IE"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Read-next su archivio [bit]                     *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofbit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bit                 .
      *                  *---------------------------------------------*
      *                  * Se at end : uscita                          *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-200.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del tipo di stampa   *
      *                  *---------------------------------------------*
           if        rr-tip-stp           =    01
                     go to stp-srt-inp-210
           else if   rr-tip-stp           =    02
                     go to stp-srt-inp-220
           else      go to stp-srt-inp-230.
       stp-srt-inp-210.
      *                  *---------------------------------------------*
      *                  * Test su data documento                      *
      *                  *---------------------------------------------*
           if        rf-bit-dat-doc       >    rr-dat-fin
                     go to stp-srt-inp-999.
      *                      *-----------------------------------------*
      *                      * A selezioni                             *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-300.
       stp-srt-inp-220.
      *                  *---------------------------------------------*
      *                  * Test su data ultima modifica                *
      *                  *---------------------------------------------*
           if        rf-bit-ide-dat       >    rr-dat-fin
                     go to stp-srt-inp-999.
      *                      *-----------------------------------------*
      *                      * A selezioni                             *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-300.
       stp-srt-inp-230.
      *                  *---------------------------------------------*
      *                  * Test su elementi per la fattura             *
      *                  *---------------------------------------------*
           if        rf-bit-fat-snx       not  = "S"  or
                     rf-bit-fat-dat       not  = zero or
                     rf-bit-fat-num       not  = zero or
                     rf-bit-fat-npb       not  = zero or
                     rf-bit-tip-arc       not  = "C"
                     go to stp-srt-inp-999.
      *                      *-----------------------------------------*
      *                      * A selezioni                             *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-300.
       stp-srt-inp-300.
      *                  *---------------------------------------------*
      *                  * Selezioni sul record [bit]                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test su codice vettore                  *
      *                      *-----------------------------------------*
           if        rr-cod-vet           =    zero
                     go to stp-srt-inp-301.
           if        rf-bit-cod-vet       not  = rr-cod-vet
                     go to stp-srt-inp-100.
       stp-srt-inp-301.
      *                      *-----------------------------------------*
      *                      * Test su date documenti                  *
      *                      *-----------------------------------------*
           if        rr-tip-stp           not  = 03
                     go to stp-srt-inp-310.
      *                          *-------------------------------------*
      *                          * Selezione su data min               *
      *                          *-------------------------------------*
           if        rr-dat-ini           =    zero
                     go to stp-srt-inp-302.
           if        rf-bit-dat-doc       <    rr-dat-ini
                     go to stp-srt-inp-100.
       stp-srt-inp-302.
      *                          *-------------------------------------*
      *                          * Selezione su data max               *
      *                          *-------------------------------------*
           if        rr-dat-fin           =    zero
                     go to stp-srt-inp-304
           else      go to stp-srt-inp-306.
       stp-srt-inp-304.
      *                          *-------------------------------------*
      *                          * Se data max a zero                  *
      *                          *-------------------------------------*
           if        rr-dat-ini           =    zero
                     go to stp-srt-inp-310.
           if        rf-bit-dat-doc       >    rr-dat-ini
                     go to stp-srt-inp-100.
           go to     stp-srt-inp-310.
       stp-srt-inp-306.
      *                          *-------------------------------------*
      *                          * Se data max non zero                *
      *                          *-------------------------------------*
           if        rf-bit-dat-doc       >    rr-dat-fin
                     go to stp-srt-inp-100.
           go to     stp-srt-inp-310.
       stp-srt-inp-310.
      *                      *-----------------------------------------*
      *                      * Test su codice dipendenza : se diverso, *
      *                      * a riciclo                               *
      *                      *-----------------------------------------*
           if        rf-bit-cod-dpz       not  = rr-dpz-inu
                     go to stp-srt-inp-100.
       stp-srt-inp-320.
      *                      *-----------------------------------------*
      *                      * Test su codice cliente                  *
      *                      *-----------------------------------------*
           if        rr-cod-cli           =    zero
                     go to stp-srt-inp-325.
           if        rf-bit-cod-arc       not  = rr-cod-cli
                     go to stp-srt-inp-100.
       stp-srt-inp-325.
      *                      *-----------------------------------------*
      *                      * Test su codice utente                   *
      *                      *-----------------------------------------*
           if        rr-cod-ute           =    spaces
                     go to stp-srt-inp-330.
           if        rf-bit-ide-ute       not  = rr-cod-ute
                     go to stp-srt-inp-100.
       stp-srt-inp-330.
      *                      *-----------------------------------------*
      *                      * Test su codice fase                     *
      *                      *-----------------------------------------*
           if        rr-cod-fas           =    spaces
                     go to stp-srt-inp-340.
           if        rf-bit-ide-fas       not  = rr-cod-fas
                     go to stp-srt-inp-100.
       stp-srt-inp-340.
      *                      *-----------------------------------------*
      *                      * Test su codice tipo movimento           *
      *                      *-----------------------------------------*
           if        rr-cod-tmb           =    spaces
                     go to stp-srt-inp-350.
           if        rf-bit-cod-tmb       not  = rr-cod-tmb
                     go to stp-srt-inp-100.
       stp-srt-inp-350.
      *                      *-----------------------------------------*
      *                      * Test su codice forma di pagamento       *
      *                      *-----------------------------------------*
           if        rr-cod-fop           =    zero
                     go to stp-srt-inp-360.
           if        rf-bit-cod-fop       not  = rr-cod-fop
                     go to stp-srt-inp-100.
       stp-srt-inp-360.
      *                      *-----------------------------------------*
      *                      * Test su solo documenti in sospeso       *
      *                      *-----------------------------------------*
           if        rr-snx-ebf           not  = "S"
                     go to stp-srt-inp-400.
           if        rf-bit-flg-nbx (1)   =    spaces
                     go to stp-srt-inp-100.
       stp-srt-inp-400.
      *                  *---------------------------------------------*
      *                  * Selezioni sul record [bir]                  *
      *                  *---------------------------------------------*
           if        rr-sgl-vrn-lot       =    spaces and
                     rr-sgl-vrn-dat       =    zero   and
                     rr-fso-dcp           =    zero
                     go to stp-srt-inp-500.
      *                      *-----------------------------------------*
      *                      * Subroutine di selezione                 *
      *                      *-----------------------------------------*
           perform   stp-srt-inp-bir-000  thru stp-srt-inp-bir-999    .
      *                      *-----------------------------------------*
      *                      * Test su esito determinazione            *
      *                      *-----------------------------------------*
           if        w-wrk-flg-sll        not  = spaces
                     go to stp-srt-inp-500
           else      go to stp-srt-inp-100.
       stp-srt-inp-500.
      *                  *---------------------------------------------*
      *                  * Preparazione record di Sort                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione iniziale                *
      *                      *-----------------------------------------*
           move      spaces               to   srt-rec                .
      *                      *-----------------------------------------*
      *                      * Chiave di sort                          *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Deviazione in funzione del tipo     *
      *                          * stampa                              *
      *                          *-------------------------------------*
           if        rr-tip-stp           =    01
                     go to stp-srt-inp-510
           else if   rr-tip-stp           =    02
                     go to stp-srt-inp-510
           else if   rr-tip-stp           =    03
                     go to stp-srt-inp-530
           else      go to stp-srt-inp-540.
       stp-srt-inp-510.
      *                          *-------------------------------------*
      *                          * Per data registrazione o immissione *
      *                          *-------------------------------------*
           move      spaces               to   srt-fat-snx            .
           move      zero                 to   srt-fdt-key            .
           move      zero                 to   srt-fnm-key            .
           move      zero                 to   srt-fat-npb            .
           move      spaces               to   srt-tpa-key            .
           move      zero                 to   srt-arc-plf            .
           move      zero                 to   srt-prt-key            .
      *                          *-------------------------------------*
      *                          * A chiavi comuni                     *
      *                          *-------------------------------------*
           go to     stp-srt-inp-580.
       stp-srt-inp-530.
      *                          *-------------------------------------*
      *                          * Per bolle da fatturare              *
      *                          *-------------------------------------*
           move      rf-bit-fat-snx       to   srt-fat-snx            .
           move      rf-bit-fat-dat       to   srt-fdt-key            .
           move      rf-bit-fat-num       to   srt-fnm-key            .
           move      rf-bit-fat-npb       to   srt-fat-npb            .
           move      rf-bit-tip-arc       to   srt-tpa-key            .
           move      rf-bit-arc-plf       to   srt-arc-plf            .
           move      rf-bit-num-prt       to   srt-prt-key            .
      *                          *-------------------------------------*
      *                          * A chiavi comuni                     *
      *                          *-------------------------------------*
           go to     stp-srt-inp-580.
       stp-srt-inp-540.
      *                          *-------------------------------------*
      *                          * Per cliente                         *
      *                          *-------------------------------------*
           move      spaces               to   srt-fat-snx            .
           move      zero                 to   srt-fdt-key            .
           move      zero                 to   srt-fnm-key            .
           move      zero                 to   srt-fat-npb            .
           move      rf-bit-tip-arc       to   srt-tpa-key            .
           move      rf-bit-arc-plf       to   srt-arc-plf            .
           move      zero                 to   srt-prt-key            .
      *                          *-------------------------------------*
      *                          * A chiavi comuni                     *
      *                          *-------------------------------------*
           go to     stp-srt-inp-580.
       stp-srt-inp-580.
      *                          *-------------------------------------*
      *                          * Data documento                      *
      *                          *-------------------------------------*
           move      rf-bit-dat-doc       to   srt-dat-doc            .
      *                          *-------------------------------------*
      *                          * Numero documento                    *
      *                          *-------------------------------------*
           move      rf-bit-num-doc       to   w-det-num-doc          .
           move      w-det-num-doc-prg    to   srt-num-doc            .
       stp-srt-inp-600.
      *                      *-----------------------------------------*
      *                      * Dati di sort                            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Protocollo                          *
      *                          *-------------------------------------*
           move      rf-bit-num-prt       to   srt-num-prt            .
      *                          *-------------------------------------*
      *                          * Tipo documento                      *
      *                          *-------------------------------------*
           move      rf-bit-cod-tmb       to   srt-tip-doc            .
      *                          *-------------------------------------*
      *                          * Tipo archivio                       *
      *                          *-------------------------------------*
           move      rf-bit-tip-arc       to   srt-tip-arc            .
      *                          *-------------------------------------*
      *                          * Codice archivio                     *
      *                          *-------------------------------------*
           move      rf-bit-cod-arc       to   srt-cod-arc            .
      *                          *-------------------------------------*
      *                          * Codice dipendenza archivio          *
      *                          *-------------------------------------*
           move      rf-bit-dpz-arc       to   srt-dpz-arc            .
      *                          *-------------------------------------*
      *                          * Sigla valuta documento              *
      *                          *-------------------------------------*
           move      rf-bit-sgl-vpf       to   srt-sgl-vpf            .
      *                          *-------------------------------------*
      *                          * Decimali valuta documento           *
      *                          *-------------------------------------*
           move      rf-bit-dec-vpf       to   srt-dec-vpf            .
      *                          *-------------------------------------*
      *                          * Tipo di cambio valuta documento     *
      *                          *-------------------------------------*
           move      rf-bit-tdc-vpf       to   srt-tdc-vpf            .
      *                          *-------------------------------------*
      *                          * Coefficiente di cambio valuta       *
      *                          *-------------------------------------*
           move      rf-bit-cdc-vpf       to   srt-cdc-vpf            .
      *                          *-------------------------------------*
      *                          * Determinazione totale documento     *
      *                          *-------------------------------------*
           perform   det-tot-doc-000      thru det-tot-doc-999        .
      *                          *-------------------------------------*
      *                          * Totale documento                    *
      *                          *-------------------------------------*
           move      w-det-tot-doc-tot    to   srt-tot-doc            .
      *                          *-------------------------------------*
      *                          * Data ultima modifica                *
      *                          *-------------------------------------*
           move      rf-bit-ide-dat       to   srt-ide-dat            .
      *                          *-------------------------------------*
      *                          * Utente                              *
      *                          *-------------------------------------*
           move      rf-bit-ide-ute       to   srt-ide-ute            .
      *                          *-------------------------------------*
      *                          * Fase                                *
      *                          *-------------------------------------*
           move      rf-bit-ide-fas       to   srt-ide-fas            .
      *                          *-------------------------------------*
      *                          * Si/No movimento per fatturazione    *
      *                          *-------------------------------------*
           move      rf-bit-int-ftr       to   srt-int-ftr            .
      *                          *-------------------------------------*
      *                          * Data fattura                        *
      *                          *-------------------------------------*
           move      rf-bit-fat-dat       to   srt-fat-dat            .
      *                          *-------------------------------------*
      *                          * Numero fattura                      *
      *                          *-------------------------------------*
           move      rf-bit-fat-num       to   srt-fat-num            .
      *                          *-------------------------------------*
      *                          * Tipo movimento di fatturazione      *
      *                          *-------------------------------------*
           move      rf-bit-tmo-ftr       to   srt-tmo-ftr            .
      *                          *-------------------------------------*
      *                          * Numero colli                        *
      *                          *-------------------------------------*
           move      rf-bit-num-col       to   srt-num-col            .
      *                          *-------------------------------------*
      *                          * Peso totale                         *
      *                          *-------------------------------------*
           move      rf-bit-pes-tot       to   srt-pes-tot            .
      *                          *-------------------------------------*
      *                          * Flags non bloccanti                 *
      *                          *-------------------------------------*
           move      rf-bit-flg-nbl       to   srt-flg-nbl            .
       stp-srt-inp-800.
      *                  *---------------------------------------------*
      *                  * Rilascio del record al Sort                 *
      *                  *---------------------------------------------*
           release   srt-rec                                          .
       stp-srt-inp-900.
      *                  *---------------------------------------------*
      *                  * Riciclo a record [bit] successivo           *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-100.
       stp-srt-inp-999.
           exit.

      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *                                                           *
      *    * Subroutine di scansione [bir]                             *
      *    *-----------------------------------------------------------*
       stp-srt-inp-bir-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di selezione               *
      *              *-------------------------------------------------*
           move      spaces               to   w-wrk-flg-sll          .
       stp-srt-inp-bir-100.
      *              *-------------------------------------------------*
      *              * Start su archivio [bir]                         *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      rf-bit-num-prt       to   rf-bir-num-prt         .
           move      zero                 to   rf-bir-num-prg         .
           move      "pgm/bol/fls/ioc/obj/iofbir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bir                 .
      *                  *---------------------------------------------*
      *                  * Se errore di start : fine lettura           *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  stp-srt-inp-bir-900.
       stp-srt-inp-bir-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale file [bir]                  *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bol/fls/ioc/obj/iofbir"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bir                 .
      *                  *---------------------------------------------*
      *                  * Se at end : fine lettura                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  stp-srt-inp-bir-900.
       stp-srt-inp-bir-300.
      *              *-------------------------------------------------*
      *              * Se oltre il massimo : fine lettura              *
      *              *-------------------------------------------------*
           if        rf-bir-num-prt       not  = rf-bit-num-prt
                     go to  stp-srt-inp-bir-900.
       stp-srt-inp-bir-400.
      *              *-------------------------------------------------*
      *              * Selezioni su [bir]                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su numero lotto                        *
      *                  *---------------------------------------------*
           if        rr-sgl-vrn-lot       =    spaces
                     go to stp-srt-inp-bir-420.
           if        rr-sgl-vrn-lot       not  = rf-bir-sgl-vrn
                                                (01 : 07)
                     go to stp-srt-inp-bir-200.
      *                  *---------------------------------------------*
      *                  * Flag di test superato                       *
      *                  *---------------------------------------------*
           move      "#"                  to   w-wrk-flg-sll          .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     stp-srt-inp-bir-900.
       stp-srt-inp-bir-420.
      *                  *---------------------------------------------*
      *                  * Test su data lotto                          *
      *                  *---------------------------------------------*
           if        rr-sgl-vrn-dat       =    zero
                     go to stp-srt-inp-bir-440.
           if        rr-sgl-vrn-dat       not  = rf-bir-sgl-vrn
                                                (08 : 07)
                     go to stp-srt-inp-bir-200.
      *                      *-----------------------------------------*
      *                      * Flag di test superato                   *
      *                      *-----------------------------------------*
           move      "#"                  to   w-wrk-flg-sll          .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     stp-srt-inp-bir-900.
       stp-srt-inp-bir-440.
      *                  *---------------------------------------------*
      *                  * Test su Prodotto di vendita                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da eseguire                     *
      *                      *-----------------------------------------*
           if        rr-fso-dcp           not  = zero
                     go to stp-srt-inp-bir-445.
      *                      *-----------------------------------------*
      *                      * Flag di test superato                   *
      *                      *-----------------------------------------*
           move      "#"                  to   w-wrk-flg-sll          .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
