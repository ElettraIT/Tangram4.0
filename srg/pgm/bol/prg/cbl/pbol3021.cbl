      *    *===========================================================*
      *    * Stampa valori totali                                      *
      *    *-----------------------------------------------------------*
       stp-val-tot-000.
      *              *-------------------------------------------------*
      *              * Composizione stringa                            *
      *              *-------------------------------------------------*
           move      spaces               to   w-stp-val-tot-x60      .
           move      1                    to   w-stp-val-tot-pnt      .
      *              *-------------------------------------------------*
      *              * Prompt                                          *
      *              *-------------------------------------------------*
           string    w-stp-val-tot-pmt
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
      *              *-------------------------------------------------*
      *              * Allineamento all'ultimo non-blank               *
      *              *-------------------------------------------------*
           move      zero                 to   w-stp-val-tot-ctr      .
           inspect   w-stp-val-tot-x60    
                                      tallying w-stp-val-tot-ctr
                                          for  trailing spaces        .
           subtract  w-stp-val-tot-ctr    from 60
                                        giving w-stp-val-tot-pnt      .
           add       1                    to   w-stp-val-tot-pnt      .
      *              *-------------------------------------------------*
      *              * Totale documento in valuta base se documento in *
      *              * valuta                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da stampare                         *
      *                  *---------------------------------------------*
           if        w-stp-val-tot-vlt    =    c-sgl
                     go to stp-val-tot-100.
           if        w-stp-val-tot-tot    =    zero
                     go to stp-val-tot-100.
      *                  *---------------------------------------------*
      *                  * Editing                                     *
      *                  *---------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           move      11                   to   p-car                  .
           move      c-dec                to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      "G<"                 to   p-edm                  .
           move      w-stp-val-tot-tot    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * String                                      *
      *                  *---------------------------------------------*
           string    " ("
                                delimited by   size
                     c-sgl
                                delimited by   size
                     " "
                                delimited by   size
                     p-edt
                                delimited by   spaces
                     ")"
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
       stp-val-tot-100.
      *              *-------------------------------------------------*
      *              * Due punti di separazione                        *
      *              *-------------------------------------------------*
           string    " : "
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda che il documento sia in    *
      *              * valuta o no                                     *
      *              *-------------------------------------------------*
           if        w-stp-val-tot-vlt    not  = c-sgl
                     go to stp-val-tot-200
           else      go to stp-val-tot-300.
       stp-val-tot-200.
      *              *-------------------------------------------------*
      *              * Se documento in valuta                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Sigla valuta                                *
      *                  *---------------------------------------------*
           string    w-stp-val-tot-vlt
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
      *                  *---------------------------------------------*
      *                  * Totale in valuta                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing                                 *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           if        w-stp-val-tot-tiv    >    999999999 or
                     w-stp-val-tot-tiv    <   -999999999
                     move  11             to   p-car
           else      move  09             to   p-car                  .
           move      w-stp-val-tot-dcv    to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           if        w-stp-val-tot-tiv    >    999999999 or
                     w-stp-val-tot-tiv    <   -999999999
                     move  spaces         to   p-edm
           else      move  "G"            to   p-edm                  .
           move      w-stp-val-tot-tiv    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * String                                  *
      *                      *-----------------------------------------*
           string    p-edt
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
      *                  *---------------------------------------------*
      *                  * A stampa stringa composta                   *
      *                  *---------------------------------------------*
           go to     stp-val-tot-500.
       stp-val-tot-300.
      *              *-------------------------------------------------*
      *              * Se documento in valuta base                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Totale in valuta base                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing                                 *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           if        w-stp-val-tot-tot    >    999999999 or
                     w-stp-val-tot-tot    <   -999999999
                     move  11             to   p-car
           else      move  09             to   p-car                  .
           move      c-dec                to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           if        w-stp-val-tot-tot    >    999999999 or
                     w-stp-val-tot-tot    <   -999999999
                     move  spaces         to   p-edm
           else      move  "G"            to   p-edm                  .
           move      w-stp-val-tot-tot    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * String                                  *
      *                      *-----------------------------------------*
           string    p-edt
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
      *                  *---------------------------------------------*
      *                  * A stampa stringa composta                   *
      *                  *---------------------------------------------*
           go to     stp-val-tot-500.
       stp-val-tot-500.
      *              *-------------------------------------------------*
      *              * Riposizionamento puntatore                      *
      *              *-------------------------------------------------*
           move      zero                 to   w-stp-val-tot-ctr      .
           inspect   w-stp-val-tot-x60    
                                      tallying w-stp-val-tot-ctr
                                          for  trailing spaces        .
           subtract  w-stp-val-tot-ctr    from 60
                                        giving w-stp-val-tot-pnt      .
           add       1                    to   w-stp-val-tot-pnt      .
      *              *-------------------------------------------------*
      *              * Stampa stringa composta                         *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      w-stp-val-tot-pnt    to   p-car                  .
           move      p-lnr                to   p-lin                  .
           subtract  w-stp-val-tot-pnt    from 101
                                        giving p-pos                  .
           add       2                    to   p-pos                  .
           move      w-stp-val-tot-x60    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-val-tot-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totale documento                           *
      *    *-----------------------------------------------------------*
       det-tot-doc-000.
      *              *-------------------------------------------------*
      *              * Azzeramento totalizzatore                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-doc-tot      .
       det-tot-doc-050.
      *              *-------------------------------------------------*
      *              * Se totale merce                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo stampa totale                  *
      *                  *---------------------------------------------*
           if        rr-tip-stt           not  = 04
                     go to det-tot-doc-080.
      *                  *---------------------------------------------*
      *                  * Totale merce                                *
      *                  *---------------------------------------------*
           move      rf-bit-tot-rig (01)  to   w-det-tot-doc-tot      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     det-tot-doc-999.
       det-tot-doc-080.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione castelletto iva              *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-doc-ctr      .
       det-tot-doc-100.
           add       1                    to   w-det-tot-doc-ctr      .
           if        w-det-tot-doc-ctr    >    6
                     go to det-tot-doc-999.
           if        rf-bit-iva-cod
                    (w-det-tot-doc-ctr)   =    zero
                     go to det-tot-doc-100.
      *                  *---------------------------------------------*
      *                  * Imponibile                                  *
      *                  *---------------------------------------------*
           add       rf-bit-iva-ibl
                    (w-det-tot-doc-ctr)   to   w-det-tot-doc-tot      .
      *                  *---------------------------------------------*
      *                  * Imposta                                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se imposta da accumulare           *
      *                      *-----------------------------------------*
           if        rr-tip-stt           =    02
                     go to det-tot-doc-800.
      *                      *-----------------------------------------*
      *                      * Accumulo imposta                        *
      *                      *-----------------------------------------*
           if        rf-bit-iva-cod
                    (w-det-tot-doc-ctr)   >    100 
                     go to det-tot-doc-800.
           multiply  rf-bit-iva-cod
                    (w-det-tot-doc-ctr)   by   rf-bit-iva-ibl
                                              (w-det-tot-doc-ctr)
                                        giving w-det-tot-doc-wpa      .
           divide    100                  into w-det-tot-doc-wpa
                                        giving w-det-tot-doc-s11
                                     remainder w-det-tot-doc-wpr      .
           move      w-det-tot-doc-s11    to   w-det-tot-doc-wpa      .
           if        w-det-tot-doc-wpr    >    zero
                     add      1           to   w-det-tot-doc-wpa
           else if   w-det-tot-doc-wpr    <    zero
                     subtract 1           from w-det-tot-doc-wpa      .
           add       w-det-tot-doc-wpa    to   w-det-tot-doc-tot      .
       det-tot-doc-800.
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-tot-doc-100.
       det-tot-doc-999.
           exit.

