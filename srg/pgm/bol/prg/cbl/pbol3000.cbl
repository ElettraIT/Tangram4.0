      *                  * Lettura archivio [zfi]                      *
      *                  *---------------------------------------------*
           move      w-tes-tip-mpf        to   w-let-arc-zfi-cod      .
           perform   let-arc-zfi-000      thru let-arc-zfi-999        .
           move      w-let-arc-zfi-vld    to   w-tes-tip-mpf-vld      .
           move      w-let-arc-zfi-dpz    to   w-tes-tip-mpf-dpz      .
           move      w-let-arc-zfi-tdo    to   w-tes-tip-mpf-tdo      .
           move      w-let-arc-zfi-ord    to   w-tes-tip-mpf-ord      .
           move      w-let-arc-zfi-prd    to   w-tes-tip-mpf-prd      .
           move      w-let-arc-zfi-ngi    to   w-tes-tip-mpf-ngi      .
           move      w-let-arc-zfi-sgl    to   w-tes-tip-mpf-sgl      .
           move      w-let-arc-zfi-cau    to   w-tes-tip-mpf-cau      .
           move      w-let-arc-zfi-siv    to   w-tes-tip-mpf-siv      .
           move      w-let-arc-zfi-sve    to   w-tes-tip-mpf-sve      .
      *                  *---------------------------------------------*
      *                  * Test su codice dipendenza                   *
      *                  *---------------------------------------------*
           if        w-tes-tip-mpf-vld    =    02            and
                     w-tes-cod-dpz        not  = w-tes-tip-mpf-dpz
                     go to ctl-slc-doc-832.
      *                  *---------------------------------------------*
      *                  * Test su tipo documento                      *
      *                  *---------------------------------------------*
           if        w-let-arc-zfi-tdo    not  = 01 and
                     w-let-arc-zfi-tdo    not  = 03
                     go to ctl-slc-doc-832.
      *                  *---------------------------------------------*
      *                  * Test su origine del documento               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se bolla da fatturare                   *
      *                      *-----------------------------------------*
           if        w-tes-tip-mpb-mif    =    02   and
                     w-let-arc-zfi-ord    not  = 11
                     go to ctl-slc-doc-832.
      *                      *-----------------------------------------*
      *                      * Se fattura accompagnatoria              *
      *                      *-----------------------------------------*
           if       (w-tes-tip-mpb-mif    =    03     ) and
                    (w-let-arc-zfi-ord    not  = 02 and
                     w-let-arc-zfi-ord    not  = 03   )
                     go to ctl-slc-doc-832.
      *                  *---------------------------------------------*
      *                  * Test su causale contabile                   *
      *                  *---------------------------------------------*
           move      w-tes-tip-mpf-tdo    to   w-ctl-cau-doc-tdo      .
           move      w-tes-tip-mpf-cau    to   w-ctl-cau-doc-cod      .
           perform   ctl-cau-doc-000      thru ctl-cau-doc-999        .
           if        w-ctl-cau-doc-flg    not  = spaces
                     go to ctl-slc-doc-832.
