                     v-key                =    "SLCT"
                     go to buf-doc-mvm-582
           else if   v-key                =    "UP  "
                     go to buf-doc-mvm-584
           else if   v-key                =    "DOWN"
                     go to buf-doc-mvm-586
           else if   v-key                =    "EXIT"
                     go to buf-doc-mvm-600
           else if   v-key                =    "NXSC"
                     go to buf-doc-mvm-592
           else if   v-key                =    "PRSC"
                     go to buf-doc-mvm-594
           else if   v-key                =    "TAB "
                     go to buf-doc-mvm-598
           else      go to buf-doc-mvm-575.
       buf-doc-mvm-582.
      *              *-------------------------------------------------*
      *              * Se spaces, Do o select                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Restore video                               *
      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Memorizzazione valori selezionati           *
      *                  *---------------------------------------------*
           move      w-buf-doc-mvm-tmo
                    (w-buf-doc-mvm-c01)   to   w-buf-doc-mvm-tds      .
           move      w-buf-doc-mvm-num
                    (w-buf-doc-mvm-c01)   to   w-buf-doc-mvm-nds      .
           move      w-buf-doc-mvm-dat
                    (w-buf-doc-mvm-c01)   to   w-buf-doc-mvm-dds      .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     buf-doc-mvm-999.
       buf-doc-mvm-584.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           subtract  1                    from w-buf-doc-mvm-c01      .
           if        w-buf-doc-mvm-nli    =    07
                     go to buf-doc-mvm-590
           else      go to buf-doc-mvm-550.
       buf-doc-mvm-586.
      *              *-------------------------------------------------*
      *              * Se Down                                         *
      *              *-------------------------------------------------*
           if        w-buf-doc-mvm-c01    <    w-buf-doc-mvm-crb
                     add   1              to   w-buf-doc-mvm-c01
                     go to buf-doc-mvm-588
           else      go to buf-doc-mvm-575.
       buf-doc-mvm-588.
           if        w-buf-doc-mvm-nli    =    12
                     go to buf-doc-mvm-590
           else      go to buf-doc-mvm-550.
       buf-doc-mvm-590.
           perform   buf-doc-mvm-950      thru buf-doc-mvm-959        .
           go to     buf-doc-mvm-550.
       buf-doc-mvm-592.
      *              *-------------------------------------------------*
      *              * Se Next screen                                  *
      *              *-------------------------------------------------*
           add       1                    to   w-buf-doc-mvm-cpa      .
           go to     buf-doc-mvm-596.
       buf-doc-mvm-594.
      *              *-------------------------------------------------*
      *              * Se Previous screen                              *
      *              *-------------------------------------------------*
           subtract  1                    from w-buf-doc-mvm-cpa      .
       buf-doc-mvm-596.
           move      w-buf-doc-mvm-cpa    to   w-buf-doc-mvm-c01      .
           multiply  6                    by   w-buf-doc-mvm-c01      .
           subtract  5                    from w-buf-doc-mvm-c01      .
           go to     buf-doc-mvm-590.
       buf-doc-mvm-598.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           move      w-buf-doc-mvm-cpb    to   w-buf-doc-mvm-cpa      .
           go to     buf-doc-mvm-596.
       buf-doc-mvm-600.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Flag di selezione                           *
      *                  *---------------------------------------------*
           move      "#"                  to   w-buf-doc-mvm-fds      .
      *                  *---------------------------------------------*
      *                  * Restore video                               *
      *                  *---------------------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       buf-doc-mvm-800.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     buf-doc-mvm-999.
       buf-doc-mvm-950.
      *              *=================================================*
      *              * Visualizzazione pagina video contenente il re-  *
      *              * cord attualmente trattato                       *
      *              *-------------------------------------------------*
           move      w-buf-doc-mvm-c01    to   w-buf-doc-mvm-c02      .
           add       5                    to   w-buf-doc-mvm-c02      .
           divide    6                    into w-buf-doc-mvm-c02      .
           move      w-buf-doc-mvm-c02    to   w-buf-doc-mvm-cpa      .
           subtract  1                    from w-buf-doc-mvm-c02      .
           multiply  6                    by   w-buf-doc-mvm-c02      .
           add       1                    to   w-buf-doc-mvm-c02      .
           add       5
                     w-buf-doc-mvm-c02  giving w-buf-doc-mvm-c03      .
           move      w-buf-doc-mvm-c03    to   w-buf-doc-mvm-c04      .
           if        w-buf-doc-mvm-c03    >    w-buf-doc-mvm-crb
                     move  w-buf-doc-mvm-crb
                                          to   w-buf-doc-mvm-c03      .
           move      07                   to   w-buf-doc-mvm-c05      .
       buf-doc-mvm-951.
      *                  *---------------------------------------------*
      *                  * Tipo documento                              *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      w-buf-doc-mvm-c05    to   v-lin                  .
           move      11                   to   v-pos                  .
           move      w-buf-doc-mvm-tmo
                    (w-buf-doc-mvm-c02)   to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Numero documento                            *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "B"                  to   v-edm                  .
           move      w-buf-doc-mvm-c05    to   v-lin                  .
           move      17                   to   v-pos                  .
           move      w-buf-doc-mvm-num
                    (w-buf-doc-mvm-c02)
                    (6 : 6)               to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Data documento                              *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      w-buf-doc-mvm-c05    to   v-lin                  .
           move      24                   to   v-pos                  .
           move      w-buf-doc-mvm-dat
                    (w-buf-doc-mvm-c02)   to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Ragione sociale intestatario documento      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      38                   to   v-car                  .
           move      w-buf-doc-mvm-c05    to   v-lin                  .
           move      33                   to   v-pos                  .
           move      w-buf-doc-mvm-rsa
                    (w-buf-doc-mvm-c02)   to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Incremento contatori                        *
      *                  *---------------------------------------------*
           add       1                    to   w-buf-doc-mvm-c02      .
           add       1                    to   w-buf-doc-mvm-c05      .
           if        w-buf-doc-mvm-c02    not  > w-buf-doc-mvm-c03
                     go to buf-doc-mvm-951.
       buf-doc-mvm-952.
           if        w-buf-doc-mvm-c02    >    w-buf-doc-mvm-c04
                     go to buf-doc-mvm-955.
           if        w-buf-doc-mvm-crb    not  > 6
                     go to buf-doc-mvm-955.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      w-buf-doc-mvm-c05    to   v-lin                  .
           move      11                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           add       1                    to   w-buf-doc-mvm-c02      .
           add       1                    to   w-buf-doc-mvm-c05      .
           go to     buf-doc-mvm-952.
       buf-doc-mvm-955.
      *                  *---------------------------------------------*
      *                  * Literal 'pagina'                            *
      *                  *---------------------------------------------*
           move      w-buf-doc-mvm-cpa    to   w-buf-doc-mvm-lt1      .
           move      w-buf-doc-mvm-cpb    to   w-buf-doc-mvm-lt2      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      34                   to   v-pos                  .
           move      w-buf-doc-mvm-ltp    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       buf-doc-mvm-959.
           exit.
       buf-doc-mvm-999.
           exit.

      *    *===========================================================*
      *    * Preparazione contatore copie da stampare                  *
      *    *-----------------------------------------------------------*
       pre-num-cps-000.
      *              *-------------------------------------------------*
      *              * Numero copie lette da tipo movimento            *
      *              *-------------------------------------------------*
           move      w-tes-tip-mpb-cps    to   w-stp-num-cps          .
      *              *-------------------------------------------------*
      *              * Al massimo sono consentite 3 copie              *
      *              *-------------------------------------------------*
           if        w-stp-num-cps        =    zero
                     move  01             to   w-stp-num-cps          .
           if        w-stp-num-cps        >    03
                     move  01             to   w-stp-num-cps          .
      *              *-------------------------------------------------*
      *              * Eventuale ritaratura in presenza dell'apposito  *
      *              * segnale                                         *
      *              *-------------------------------------------------*
           if        w-tes-tip-mpb-ncv    not  = "S"
                     go to pre-num-cps-900.
       pre-num-cps-200.
      *              *-------------------------------------------------*
      *              * Test su anagrafica vettore                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Solo se oltre due copie                     *
      *                  *---------------------------------------------*
           if        w-stp-num-cps        not  > 02
                     go to pre-num-cps-900.
      *                  *---------------------------------------------*
      *                  * Test su si/no stampa copia bolla vettore    *
      *                  *---------------------------------------------*
           if        w-pie-cod-vet-scp (1)
                                          =    "N"
                     move  02             to   w-stp-num-cps
                     go to pre-num-cps-900.
       pre-num-cps-400.
      *              *-------------------------------------------------*
      *              * Test sul Trasporto a cura                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Solo se oltre due copie                     *
      *                  *---------------------------------------------*
           if        w-stp-num-cps        not  > 02
                     go to pre-num-cps-900.
      *                  *---------------------------------------------*
      *                  * Test se stampa a cura del Vettore           *
      *                  *---------------------------------------------*
           if        w-pie-tra-cur (1)    =    30 or
                     w-pie-tra-cur (1)    =    00
                     go to pre-num-cps-900.
      *                  *---------------------------------------------*
      *                  * Se a cura del Destinatario                  *
      *                  *---------------------------------------------*
           if        w-pie-tra-cur (1)    =    20
                     move  02             to   w-stp-num-cps
                     go to pre-num-cps-900.
      *                  *---------------------------------------------*
      *                  * Se a cura del Mittente                      *
      *                  *                                             *
      *                  * Se c'e' il codice del vettore si considera  *
      *                  * che sia un vettore interno e si stampa la   *
      *                  * copia per il vettore                        *
      *                  *---------------------------------------------*
           if        w-pie-tra-cur (1)    not  = 10
                     go to pre-num-cps-900.
______*    if        w-pie-cod-vet (1)    not  = zero
______*              go to pre-num-cps-900.
           move      02                   to   w-stp-num-cps          .
       pre-num-cps-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     pre-num-cps-999.
       pre-num-cps-999.
           exit.

      *    *===========================================================*
      *    * Routine di bufferizzazione testate ordine per residui     *
      *    *-----------------------------------------------------------*
       buf-res-orc-000.
      *              *-------------------------------------------------*
      *              * Test su valore della personalizzazione          *
      *              *-------------------------------------------------*
           if        w-prs-snx-roc-tip    not  = 01
                     go to buf-res-orc-900.
       buf-res-orc-100.
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       buf-res-orc-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to buf-res-orc-900.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to buf-res-orc-200.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
       buf-res-orc-400.
      *              *-------------------------------------------------*
      *              * Test se riga che contiene riferimenti ad un     *
      *              * ordine cliente                                  *
      *              *-------------------------------------------------*
           if        w-rig-coc-prt(1)     =    zero
                     go to buf-res-orc-200.
       buf-res-orc-500.
      *              *-------------------------------------------------*
      *              * Verifica nel buffer se ordine gia' trattato     *
      *              *-------------------------------------------------*
           set       w-buf-res-orc-inx    to   1                      .
           search    w-buf-res-orc-buf
                     when    w-buf-res-orc-prt
                            (w-buf-res-orc-inx)
                                          =    w-rig-coc-prt(1)
                     go to   buf-res-orc-800.
       buf-res-orc-600.
      *              *-------------------------------------------------*
      *              * Bufferizzazione                                 *
      *              *-------------------------------------------------*
           add       1                    to   w-buf-res-orc-ele      .
           if        w-buf-res-orc-ele    >    w-buf-res-orc-max
                     go to buf-res-orc-900.
           move      w-rig-coc-prt(1)     to   w-buf-res-orc-prt
                                              (w-buf-res-orc-ele)     .
       buf-res-orc-800.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     buf-res-orc-200.
       buf-res-orc-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     buf-res-orc-999.
       buf-res-orc-999.
           exit.

      *    *===========================================================*
      *    * Routine di stampa residui ordine                          *
      *    *-----------------------------------------------------------*
       stp-res-orc-000.
      *              *-------------------------------------------------*
      *              * Test su valore della personalizzazione          *
      *              *-------------------------------------------------*
           if        w-prs-snx-roc-tip    not  = 01
                     go to stp-res-orc-900.
      *              *-------------------------------------------------*
      *              * Test su contatore elementi                      *
      *              *-------------------------------------------------*
           if        w-buf-res-orc-ele    not  > zero
                     go to stp-res-orc-900.
       stp-res-orc-050.
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
       stp-res-orc-100.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-buf-res-orc-ctr      .
       stp-res-orc-200.
      *              *-------------------------------------------------*
      *              * Lettura elemento successivo                     *
      *              *-------------------------------------------------*
           add       1                    to   w-buf-res-orc-ctr      .
           if        w-buf-res-orc-ctr    >    w-buf-res-orc-ele
                     go to stp-res-orc-900.
           if        w-buf-res-orc-ctr    >    w-buf-res-orc-max
                     go to stp-res-orc-900.
       stp-res-orc-400.
      *              *-------------------------------------------------*
      *              * ___ da completare ___                           *
      *              *-------------------------------------------------*

      
       stp-res-orc-800.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     stp-res-orc-200.
       stp-res-orc-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     stp-res-orc-999.
       stp-res-orc-999.
           exit.

