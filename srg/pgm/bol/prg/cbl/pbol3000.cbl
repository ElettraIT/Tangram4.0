      *              *-------------------------------------------------*
           move      w-let-arc-age-cpv    to   w-tes-cpv-aaa (1)      .
      *              *-------------------------------------------------*
      *              * Bufferizzazione % provvigioni agente            *
      *              *-------------------------------------------------*
           move      w-let-arc-age-ppv (1)
                                          to   w-tes-ppv-aaa (1, 1)   .
           move      w-let-arc-age-ppv (2)
                                          to   w-tes-ppv-aaa (1, 2)   .
           move      w-let-arc-age-ppv (3)
                                          to   w-tes-ppv-aaa (1, 3)   .
       det-vlt-age-910.
      *              *-------------------------------------------------*
      *              * Determinazione flag di significativita' provvi- *
      *              * gioni in testata                                *
      *              *-------------------------------------------------*
           if        w-tes-cod-age (1)    =    zero
                     move  02             to   w-tes-fsp-doc (1)
                     go to det-vlt-age-920.
           if        w-tes-fsp-doc (1)    =    zero or
                     w-tes-fsp-doc (1)    =    02
                     move  01             to   w-tes-fsp-doc (1)      .
       det-vlt-age-920.
      *              *-------------------------------------------------*
      *              * Determinazione tipo vendita per l'agente        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se codice agente a zero                     *
      *                  *---------------------------------------------*
           if        w-tes-cod-age (1)    =    zero
                     move  zero           to   w-tes-tip-vpa (1)
                     go to det-vlt-age-950.
      *                  *---------------------------------------------*
      *                  * Se documento non significativo per le prov- *
      *                  * vigioni                                     *
      *                  *---------------------------------------------*
           if        w-tes-fsp-doc (1)    =    02
                     move  zero           to   w-tes-tip-vpa (1)
                     go to det-vlt-age-950.
      *                  *---------------------------------------------*
      *                  * Se esiste un default legato al tipo movi-   *
      *                  * mento                                       *
      *                  *---------------------------------------------*
           if        w-tes-tip-vpa (1)    =    zero and
                     w-tes-tip-mpb-tva    not  = zero
                     move  w-tes-tip-mpb-tva
                                          to   w-tes-tip-vpa (1)
           else if   w-tes-tip-vpa (1)    =    zero
                     move  01             to   w-tes-tip-vpa (1)      .
       det-vlt-age-950.
      *              *-------------------------------------------------*
      *              * Determinazione eventuale contropartita vendite  *
      *              * dipendente dall'agente                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se contropartita derivata da tipo movimen-  *
      *                  * to : oltre                                  *
      *                  *---------------------------------------------*
           if        w-tes-tip-mpf-sve    not  = zero
                     go to det-vlt-age-960.
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del tipo documento     *
      *                  *---------------------------------------------*
           if        w-tes-tip-mpf-tdo    =    03
                     go to det-vlt-age-952
           else      go to det-vlt-age-954.
       det-vlt-age-952.
      *                  *---------------------------------------------*
      *                  * Se Nota di Accredito                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se contropartita resi su vendite asso-  *
      *                      * ciata all'agente a zero : oltre         *
      *                      *-----------------------------------------*
           if        w-let-arc-age-crv    =    zero
                     go to det-vlt-age-960.
      *                      *-----------------------------------------*
      *                      * Salvataggio contropartita vendite at-   *
      *                      * tuale                                   *
      *                      *-----------------------------------------*
           move      w-tes-ctp-ven (1)    to   w-sav-ctp-ven          .
