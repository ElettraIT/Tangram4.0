                    (w-wrt-mov-cge-ctr)   to   l-cge-300-imp-mov      .
      *                      *-----------------------------------------*
      *                      * Flag di regime fiscale particolare      *
      *                      *-----------------------------------------*
           move      w-tes-ass-iva-spl (1)
                                          to   l-cge-300-flg-rfp      .
      *                      *-----------------------------------------*
      *                      * Sigla numerazione                       *
      *                      *-----------------------------------------*
           move      w-tes-tip-mpf-sgl    to   l-cge-300-sgl-num      .
      *                      *-----------------------------------------*
      *                      * Data acquisizione                       *
      *                      *-----------------------------------------*
           move      zero                 to   l-cge-300-dat-acq      .
      *                      *-----------------------------------------*
      *                      * Richiamo modulo scrittura CGE           *
      *                      *-----------------------------------------*
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                      *-----------------------------------------*
      *                      * Riciclo su scansione tabella scadenze   *
      *                      *-----------------------------------------*
           go to     wrt-mov-cge-310.
       wrt-mov-cge-999.
           exit.

      *    *===========================================================*
      *    * Cancellazione movimenti di CGE                            *
      *    *-----------------------------------------------------------*
       del-mov-cge-000.
      *              *-------------------------------------------------*
      *              * Test se operazione da eseguire                  *
      *              *-------------------------------------------------*
           if        w-tes-int-ftr        not  = 03
                     go to del-mov-cge-999.
      *              *-------------------------------------------------*
      *              * Se numero protocollo di CGE a zero : uscita     *
      *              *-------------------------------------------------*
           if        w-tes-prt-mgd (2)    =    zero
                     go to del-mov-cge-999.
      *              *-------------------------------------------------*
      *              * Se codice causale di CGE a zero : uscita        *
      *              *-------------------------------------------------*
           if        w-tes-tip-mpf-cau    =    zero
                     go to del-mov-cge-999.
      *              *-------------------------------------------------*
      *              * Ciclo per tutti i movimenti registrati a parti- *
      *              * re dal numero protocollo iniziale               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione numero protocollo iniziale   *
      *                  * meno 1                                      *
      *                  *---------------------------------------------*
           move      w-tes-prt-mgd (2)    to   w-del-mov-cge-npi      .
           subtract  1                    from w-del-mov-cge-npi      .
      *                  *---------------------------------------------*
      *                  * Determinazione numero protocollo finale     *
      *                  *---------------------------------------------*
           move      w-del-mov-cge-npi    to   w-del-mov-cge-npf      .
           add       w-tes-nrg-mgd (2)    to   w-del-mov-cge-npf      .
       del-mov-cge-100.
      *                  *---------------------------------------------*
      *                  * Incremento numero protocollo                *
      *                  *---------------------------------------------*
           add       1                    to   w-del-mov-cge-npi      .
      *                  *---------------------------------------------*
      *                  * Test se oltrepassato il massimo             *
      *                  *---------------------------------------------*
           if        w-del-mov-cge-npi    >    w-del-mov-cge-npf
                     go to del-mov-cge-999.
      *                  *---------------------------------------------*
      *                  * Richiamo modulo per cancellazione movimento *
      *                  * di CGE                                      *
      *                  *---------------------------------------------*
           move      "DE"                 to   l-cge-300-tip-ope      .
           move      w-tes-dat-doc        to   l-cge-300-dat-reg      .
           move      w-del-mov-cge-npi    to   l-cge-300-num-prt      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                  *---------------------------------------------*
      *                  * Riciclo per prossima cancellazione          *
      *                  *---------------------------------------------*
           go to     del-mov-cge-100.
       del-mov-cge-999.
           exit.

      *    *===========================================================*
      *    * Scrittura movimenti di GEP                                *
      *    *-----------------------------------------------------------*
       wrt-mov-gep-000.
      *              *-------------------------------------------------*
      *              * Se gestione portafoglio non attiva : uscita     *
      *              *-------------------------------------------------*
           if        w-prs-gep-snx        not  = "S"
                     go to wrt-mov-gep-999.
      *              *-------------------------------------------------*
      *              * Test se operazione da eseguire                  *
      *              *-------------------------------------------------*
           if        w-tes-int-ftr        not  = 03
                     go to wrt-mov-gep-999.
      *              *-------------------------------------------------*
      *              * Se codice causale di CGE a zero : uscita        *
      *              *-------------------------------------------------*
           if        w-tes-tip-mpf-cau    =    zero
                     go to wrt-mov-gep-999.
      *              *-------------------------------------------------*
      *              * Preparazione numero scadenza iniziale           *
      *              *-------------------------------------------------*
           move      w-tes-nps-sdb (1)    to   w-wrt-mov-gep-wns      .
           subtract  1                    from w-wrt-mov-gep-wns      .
      *              *-------------------------------------------------*
      *              * Preparazione numero protocollo iniziale di CGE  *
      *              *-------------------------------------------------*
           move      w-tes-prt-mgd (1)    to   w-wrt-mov-gep-wnp      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione su tabella scadenze          *
      *              *-------------------------------------------------*
           move      zero                 to   w-wrt-mov-gep-ctr      .
       wrt-mov-gep-100.
           add       1                    to   w-wrt-mov-gep-ctr      .
           if        w-wrt-mov-gep-ctr    >    w-pie-scd-ele (1)
                     go to wrt-mov-gep-999.
      *                  *---------------------------------------------*
      *                  * Se tipo scadenza a zero : riciclo           *
      *                  *---------------------------------------------*
           if        w-pie-scd-tip
                    (1, w-wrt-mov-gep-ctr)
                                          =    zero
                     go to wrt-mov-gep-100.
      *                  *---------------------------------------------*
      *                  * Se importo scadenza a zero : riciclo        *
      *                  *---------------------------------------------*
           if        w-ivb-scd-imp
                    (w-wrt-mov-gep-ctr)   =    zero
                     go to wrt-mov-gep-100.
      *                  *---------------------------------------------*
      *                  * Se personalizzazione di portafoglio associa-*
      *                  * ta al tipo pagamento non esistente : riciclo*
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Preparazione indice di comodo           *
      *                      *-----------------------------------------*
           move      w-pie-scd-tip
                    (1, w-wrt-mov-gep-ctr)
                                          to   w-wrt-mov-gep-wtp      .
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-prs-gep-snx-prs
                    (w-wrt-mov-gep-wtp)   not  = "S"
                     go to wrt-mov-gep-100.
      *                  *---------------------------------------------*
      *                  * Aggiornamento progressivo numero scad.      *
      *                  *---------------------------------------------*
           add       1                    to   w-wrt-mov-gep-wns      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [sdb]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Composizione record [sdb]                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Dati identificativi                     *
      *                      *-----------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   rf-sdb-ide-dat         .
           move      s-ute                to   rf-sdb-ide-ute         .
           move      s-fas                to   rf-sdb-ide-fas         .
      *                      *-----------------------------------------*
      *                      * Data registrazione emissione            *
      *                      *-----------------------------------------*
           move      w-tes-dat-doc        to   rf-sdb-dtr-emi         .
      *                      *-----------------------------------------*
      *                      * Data registrazione movimento di conta-  *
      *                      * bilita'                                 *
      *                      *-----------------------------------------*
           if        w-pie-scd-cau
                    (1, w-wrt-mov-gep-ctr)
                                          =    zero
                     go to wrt-mov-gep-120.
           move      w-tes-dat-doc        to   rf-sdb-drc-emi         .
       wrt-mov-gep-120.
      *                      *-----------------------------------------*
      *                      * Numero protocollo movimento di contabi- *
      *                      * lita'                                   *
      *                      *-----------------------------------------*
           if        w-pie-scd-cau
                    (1, w-wrt-mov-gep-ctr)
                                          =    zero
                     go to wrt-mov-gep-140.
           add       1                    to   w-wrt-mov-gep-wnp      .
           move      w-wrt-mov-gep-wnp    to   rf-sdb-npc-emi         .
       wrt-mov-gep-140.
      *                      *-----------------------------------------*
      *                      * Numero protocollo fattura cliente       *
      *                      *-----------------------------------------*
           move      w-tes-fti-prt (1)    to   rf-sdb-prt-fcl         .
      *                      *-----------------------------------------*
      *                      * Numero scadenza di origine              *
      *                      *-----------------------------------------*
           move      zero                 to   rf-sdb-nsc-org         .
      *                      *-----------------------------------------*
      *                      * Codice agente                           *
      *                      *-----------------------------------------*
           move      w-tes-cod-age (1)    to   rf-sdb-cod-age         .
      *                      *-----------------------------------------*
      *                      * Numero scadenza                         *
      *                      *-----------------------------------------*
           move      w-wrt-mov-gep-wns    to   rf-sdb-num-sdb         .
      *                      *-----------------------------------------*
      *                      * Tipo scadenza                           *
      *                      *-----------------------------------------*
           move      w-pie-scd-tip
                    (1, w-wrt-mov-gep-ctr)
                                          to   rf-sdb-tip-sdb         .
      *                      *-----------------------------------------*
      *                      * Si/No dilazione concordata              *
      *                      *-----------------------------------------*
           move      "N"                  to   rf-sdb-snx-dlc         .
      *                      *-----------------------------------------*
      *                      * Tipo acquisizione scadenza              *
      *                      *-----------------------------------------*
           move      01                   to   rf-sdb-tac-sdb         .
      *                      *-----------------------------------------*
      *                      * Tipo valuta per la scadenza             *
      *                      *                                         *
      *                      * N.B. : Attualmente viene forzato a '01' *
      *                      *-----------------------------------------*
           move      01                   to   rf-sdb-tvl-sdb         .
      *                      *-----------------------------------------*
      *                      * Data scadenza                           *
      *                      *-----------------------------------------*
           move      w-pie-scd-dat
                    (1, w-wrt-mov-gep-ctr)
                                          to   rf-sdb-dts-sdb         .
      *                      *-----------------------------------------*
      *                      * Tipo debitore                           *
      *                      *-----------------------------------------*
           move      01                   to   rf-sdb-tip-dbt         .
      *                      *-----------------------------------------*
      *                      * Codice debitore                         *
      *                      *-----------------------------------------*
           move      w-tes-arc-plf (1)    to   rf-sdb-cod-dbt         .
      *                      *-----------------------------------------*
      *                      * Codice dipendenza del debitore          *
      *                      *-----------------------------------------*
           move      w-tes-dpz-plf (1)    to   rf-sdb-dpz-dbt         .
      *                      *-----------------------------------------*
      *                      * Inoltro scadenza al debitore            *
      *                      *-----------------------------------------*
           move      w-tes-inl-pgt (1)    to   rf-sdb-inl-sdb         .
      *                      *-----------------------------------------*
      *                      * Sigla valuta                            *
      *                      *-----------------------------------------*
           move      c-sgl                to   rf-sdb-sgl-vlt         .
      *                      *-----------------------------------------*
      *                      * Decimali valuta                         *
      *                      *-----------------------------------------*
           move      c-dec                to   rf-sdb-dec-vlt         .
      *                      *-----------------------------------------*
      *                      * Tipo di cambio                          *
      *                      *-----------------------------------------*
           move      c-tdc                to   rf-sdb-tdc-vlt         .
      *                      *-----------------------------------------*
      *                      * Coefficiente di cambio                  *
      *                      *-----------------------------------------*
           move      c-cdc                to   rf-sdb-cdc-sdb         .
      *                      *-----------------------------------------*
      *                      * Importo scadenza in valuta              *
      *                      *-----------------------------------------*
           move      w-pie-scd-imp
                    (1, w-wrt-mov-gep-ctr)
                                          to   rf-sdb-iiv-sdb         .
           if        w-tes-tip-mpf-tdo    =    03
                     multiply -1          by   rf-sdb-iiv-sdb         .
      *                      *-----------------------------------------*
      *                      * Importo scadenza                        *
      *                      *-----------------------------------------*
           move      w-ivb-scd-imp
                    (w-wrt-mov-gep-ctr)   to   rf-sdb-imp-sdb         .
           if        w-tes-tip-mpf-tdo    =    03
                     multiply -1          by   rf-sdb-imp-sdb         .
      *                      *-----------------------------------------*
      *                      * Data documento di riferimento           *
      *                      *-----------------------------------------*
           move      w-tes-dat-doc        to   rf-sdb-dat-ddr         .
      *                      *-----------------------------------------*
      *                      * Numero documento di riferimento         *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-tes-num-doc-prg    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      v-edt                to   rf-sdb-num-ddr         .
      *                      *-----------------------------------------*
      *                      * Tipo documento di riferimento           *
      *                      *-----------------------------------------*
           if        w-tes-tip-mpf-tdo    =    01
                     move  01             to   rf-sdb-tip-ddr
           else if   w-tes-tip-mpf-tdo    =    02
                     move  02             to   rf-sdb-tip-ddr
           else if   w-tes-tip-mpf-tdo    =    03
                     move  11             to   rf-sdb-tip-ddr
           else      move  99             to   rf-sdb-tip-ddr         .
      *                      *-----------------------------------------*
      *                      * Importo documento di riferimento        *
      *                      *-----------------------------------------*
           move      w-ivb-tot-doc        to   rf-sdb-imp-ddr         .
           if        w-tes-tip-mpf-tdo    =    03
                     multiply -1          by   rf-sdb-imp-ddr         .
      *                      *-----------------------------------------*
      *                      * Numero rata documento di riferimento    *
      *                      *-----------------------------------------*
           move      w-wrt-mov-gep-ctr    to   rf-sdb-nra-ddr         .
      *                      *-----------------------------------------*
      *                      * Codice istituto di credito per l'appog- *
      *                      * gio                                     *
      *                      *-----------------------------------------*
           if        w-tes-snx-abi (1)    not  = "S"
                     go to wrt-mov-gep-160.
           move      w-tes-cod-abi (1)    to   rf-sdb-abi-app         .
       wrt-mov-gep-160.
      *                      *-----------------------------------------*
      *                      * Codice agenzia istituto di credito per  *
      *                      * l'appoggio                              *
      *                      *-----------------------------------------*
           if        w-tes-snx-abi (1)    not  = "S"
                     go to wrt-mov-gep-180.
           move      w-tes-cod-cab (1)    to   rf-sdb-cab-app         .
       wrt-mov-gep-180.
      *                      *-----------------------------------------*
      *                      * Codice conto corrente per l'appoggio    *
      *                      *-----------------------------------------*
           if        w-tes-snx-rid (1)    not  = "S"
                     go to wrt-mov-gep-200.
           move      w-tes-ccc-app (1)    to   rf-sdb-ccc-app         .
       wrt-mov-gep-200.
      *                      *-----------------------------------------*
      *                      * Codice nostra banca per il pagamento    *
      *                      * tramite bonifico o codice nostro conto  *
      *                      * corrente postale per il pagamento per   *
      *                      * conto corrente postale                  *
      *                      *-----------------------------------------*
           if        w-tes-snx-nsb (1)    =    "S"
                     move  w-tes-nos-ban (1)
                                          to   rf-sdb-cod-cbp
           else if   w-tes-snx-ncp (1)    =    "S"
                     move  w-tes-nos-ccp (1)
                                          to   rf-sdb-cod-cbp
           else      move  spaces         to   rf-sdb-cod-cbp         .
      *                      *-----------------------------------------*
      *                      * Determinazione data chiusura scadenza   *
      *                      *-----------------------------------------*
           perform   det-dat-chs-000      thru det-dat-chs-999        .
      *                      *-----------------------------------------*
      *                      * Contrassegno                            *
      *                      *-----------------------------------------*
           move      w-tes-snx-cts (1)    to   rf-sdb-snx-cts         .
           move      w-pie-cod-vet (1)    to   rf-sdb-vet-cts         .
       wrt-mov-gep-400.
      *                  *---------------------------------------------*
      *                  * Scrittura record [sdb]                      *
      *                  *---------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Riciclo su prossima scadenza                *
      *                  *---------------------------------------------*
           go to     wrt-mov-gep-100.
       wrt-mov-gep-999.
           exit.

      *    *===========================================================*
      *    * Cancellazione movimenti di GEP                            *
      *    *-----------------------------------------------------------*
       del-mov-gep-000.
      *              *-------------------------------------------------*
      *              * Se gestione portafoglio non attiva : uscita     *
      *              *-------------------------------------------------*
           if        w-prs-gep-snx        not  = "S"
                     go to del-mov-gep-999.
      *              *-------------------------------------------------*
      *              * Test se operazione da eseguire                  *
      *              *-------------------------------------------------*
           if        w-tes-int-ftr        not  = 03
                     go to del-mov-gep-999.
      *              *-------------------------------------------------*
      *              * Se numero prima scadenza GEP a zero : uscita    *
      *              *-------------------------------------------------*
           if        w-tes-nps-sdb (2)    =    zero
                     go to del-mov-gep-999.
      *              *-------------------------------------------------*
      *              * Se codice causale di CGE a zero : uscita        *
      *              *-------------------------------------------------*
           if        w-tes-tip-mpf-cau    =    zero
                     go to del-mov-gep-999.
      *              *-------------------------------------------------*
      *              * Ciclo per tutti i movimenti registrati a parti- *
      *              * re dal numero scadenza iniziale                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione numero scadenza iniziale     *
      *                  * meno 1                                      *
      *                  *---------------------------------------------*
           move      w-tes-nps-sdb (2)    to   w-del-mov-gep-nsi      .
           subtract  1                    from w-del-mov-gep-nsi      .
      *                  *---------------------------------------------*
      *                  * Determinazione numero scadenza finale       *
      *                  *---------------------------------------------*
           move      w-del-mov-gep-nsi    to   w-del-mov-gep-nsf      .
           add       w-tes-ctr-sdb (2)    to   w-del-mov-gep-nsf      .
       del-mov-gep-100.
      *                  *---------------------------------------------*
      *                  * Incremento numero scadenza                  *
      *                  *---------------------------------------------*
           add       1                    to   w-del-mov-gep-nsi      .
      *                  *---------------------------------------------*
      *                  * Test se oltrepassato il massimo             *
      *                  *---------------------------------------------*
           if        w-del-mov-gep-nsi    >    w-del-mov-gep-nsf
                     go to del-mov-gep-999.
      *                  *---------------------------------------------*
      *                  * Composizione chiave primaria                *
      *                  *---------------------------------------------*
           move      w-del-mov-gep-nsi    to   rf-sdb-num-sdb         .
      *                  *---------------------------------------------*
      *                  * Delete record [sdb]                         *
      *                  *---------------------------------------------*
           move      "DE"                 to   f-ope                  .
           move      "pgm/gep/fls/ioc/obj/iofsdb"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sdb                 .
      *                  *---------------------------------------------*
      *                  * Riciclo per prossima cancellazione          *
      *                  *---------------------------------------------*
           go to     del-mov-gep-100.
       del-mov-gep-999.
           exit.

      *    *===========================================================*
      *    * Scrittura movimenti di MAG                                *
      *    *-----------------------------------------------------------*
       wrt-mov-mag-000.
      *              *-------------------------------------------------*
      *              * Se causale di magazzino a zero : uscita         *
      *              *-------------------------------------------------*
           if        w-tes-tip-mpb-cam    =    zero
                     go to wrt-mov-mag-999.
      *              *-------------------------------------------------*
      *              * Scrittura primo movimento di magazzino          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione testata                     *
      *                  *---------------------------------------------*
           move      "NT"                 to   l-mag-300-tip-ope      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Scrittura testata                           *
      *                  *---------------------------------------------*
           move      "WT"                 to   l-mag-300-tip-ope      .
           move      w-tes-dat-doc        to   l-mag-300-dat-reg      .
           move      w-tes-prt-mag (1)    to   l-mag-300-num-prt      .
           move      w-tes-cod-dpz        to   l-mag-300-cod-dpz      .
           move      w-tes-tip-mpb-cam    to   l-mag-300-cod-cau      .
           move      w-tes-tip-mpb-ctm    to   l-mag-300-cod-ctm      .
      *                      *-----------------------------------------*
      *                      * Data documento                          *
      *                      *-----------------------------------------*
           if        w-tes-tip-mpf-tdo    =    03
                     move  w-tes-dri-mgd (1)
                                          to   l-mag-300-dat-doc
           else      move  w-tes-dat-doc  to   l-mag-300-dat-doc      .
      *                      *-----------------------------------------*
      *                      * Numero documento                        *
      *                      *-----------------------------------------*
           if        w-tes-tip-mpf-tdo    =    03
                     move  w-tes-nri-mgd (1)
                                          to   l-mag-300-num-doc
                     go to wrt-mov-mag-020.
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-tes-num-doc-prg    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      v-edt                to   l-mag-300-num-doc      .
       wrt-mov-mag-020.
           move      w-tes-tip-mpb-dsl    to   l-mag-300-cod-dsl      .
           move      spaces               to   l-mag-300-cod-dsd      .
           move      w-tes-tip-arc (1)    to   l-mag-300-tip-arc      .
           move      w-tes-cod-arc (1)    to   l-mag-300-cod-arc      .
           move      w-tes-dpz-arc (1)    to   l-mag-300-dpz-arc      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        l-mag-300-exi-sts    not  = spaces
                     go to wrt-mov-mag-900.
      *                  *---------------------------------------------*
      *                  * Scrittura righe                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Inizializzazione contatore righe scritte*
      *                      *-----------------------------------------*
           move      zero                 to   w-wrt-mov-mag-ctr      .
      *                      *-----------------------------------------*
      *                      * Start su catena movimenti               *
      *                      *-----------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       wrt-mov-mag-100.
      *                      *-----------------------------------------*
      *                      * Lettura sequenziale catena movimenti    *
      *                      *-----------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                      *-----------------------------------------*
      *                      * Se fine lettura : uscita                *
      *                      *-----------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to wrt-mov-mag-200.
      *                      *-----------------------------------------*
      *                      * Movimento da buffer catena movimenti a  *
      *                      * work di lavoro                          *
      *                      *-----------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *                      *-----------------------------------------*
      *                      * Se tipo riga a spazi : uscita           *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to wrt-mov-mag-200.
      *                      *-----------------------------------------*
      *                      * Selezione su tipo riga                  *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "M" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "S"
                     go to wrt-mov-mag-100.
           if        w-rig-tip-rig-tfu (1)
                                          not  = spaces
                     go to wrt-mov-mag-100.
      *                      *-----------------------------------------*
      *                      * Selezione su tipo prodotto : se 'Servi- *
      *                      * zio' riciclo                            *
      *                      *-----------------------------------------*
           if        w-rig-tip-pro (1)    =    02
                     go to wrt-mov-mag-100.
      *                      *-----------------------------------------*
      *                      * Incremento contatore righe scritte      *
      *                      *-----------------------------------------*
           add       1                    to   w-wrt-mov-mag-ctr      .
      *                      *-----------------------------------------*
      *                      * Normalizzazione riga                    *
      *                      *-----------------------------------------*
           move      "NR"                 to   l-mag-300-tip-ope      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                      *-----------------------------------------*
      *                      * Scrittura riga                          *
      *                      *-----------------------------------------*
           move      "WR"                 to   l-mag-300-tip-ope      .
           move      w-rig-tip-mag (1)    to   l-mag-300-tip-mag      .
           move      w-rig-num-pro (1)    to   l-mag-300-num-mag      .
           move      w-rig-alf-pro (1)    to   l-mag-300-alf-mag      .
           move      w-rig-sgl-vrn (1)    to   l-mag-300-var-mag      .
           move      w-rig-umi-ven (1)    to   l-mag-300-udm-ana      .
           move      w-rig-umi-ven (1)    to   l-mag-300-udm-mov      .
           move      zero                 to   l-mag-300-num-pmg      .
           move      zero                 to   l-mag-300-ddo-rif      .
           move      spaces               to   l-mag-300-ndo-rif      .
           move      w-rig-qta-ven (1)    to   l-mag-300-qta-mov      .
           perform   pre-rif-cun-000      thru pre-rif-cun-999        .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                      *-----------------------------------------*
      *                      * Test su esito operazione                *
      *                      *-----------------------------------------*
           if        l-mag-300-exi-sts    not  = spaces
                     go to wrt-mov-mag-900.
      *                      *-----------------------------------------*
      *                      * Riciclo su lettura catena movimenti     *
      *                      *-----------------------------------------*
           go to     wrt-mov-mag-100.
       wrt-mov-mag-200.
      *                  *---------------------------------------------*
      *                  * Test su numero righe scritte                *
      *                  *---------------------------------------------*
           if        w-wrt-mov-mag-ctr    not  = zero
                     go to wrt-mov-mag-500.
      *                  *---------------------------------------------*
      *                  * Se nessuna riga scritta : cancellazione     *
      *                  * della registrazione di magazzino per elimi- *
      *                  * nare la testata scritta                     *
      *                  *---------------------------------------------*
           move      "DE"                 to   l-mag-300-tip-ope      .
           move      w-tes-dat-doc        to   l-mag-300-dat-reg      .
           move      w-tes-prt-mag (1)    to   l-mag-300-num-prt      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     wrt-mov-mag-999.
       wrt-mov-mag-500.
      *              *-------------------------------------------------*
      *              * Scrittura secondo movimento di magazzino        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se causale di magazzino aggiuntiva a zero : *
      *                  * uscita                                      *
      *                  *---------------------------------------------*
           if        w-tes-tip-mpb-cma    =    zero
                     go to wrt-mov-mag-999.
      *                  *---------------------------------------------*
      *                  * Se tipo archivio non 'D' : uscita           *
      *                  *---------------------------------------------*
           if        w-tes-tip-arc (1)    not  = "D"
                     go to wrt-mov-mag-999.
      *                  *---------------------------------------------*
      *                  * Normalizzazione testata                     *
      *                  *---------------------------------------------*
           move      "NT"                 to   l-mag-300-tip-ope      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Scrittura testata                           *
      *                  *---------------------------------------------*
           move      "WT"                 to   l-mag-300-tip-ope      .
           move      w-tes-dat-doc        to   l-mag-300-dat-reg      .
           move      w-tes-pr2-mag (1)    to   l-mag-300-num-prt      .
           move      w-tes-cod-arc (1)    to   l-mag-300-cod-dpz      .
           move      w-tes-tip-mpb-cma    to   l-mag-300-cod-cau      .
           move      spaces               to   l-mag-300-cod-ctm      .
           move      w-tes-dat-doc        to   l-mag-300-dat-doc      .
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-tes-num-doc-prg    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      v-edt                to   l-mag-300-num-doc      .
           move      spaces               to   l-mag-300-cod-dsl      .
           move      spaces               to   l-mag-300-cod-dsd      .
           move      "D"                  to   l-mag-300-tip-arc      .
           move      w-tes-cod-dpz        to   l-mag-300-cod-arc      .
           move      spaces               to   l-mag-300-dpz-arc      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        l-mag-300-exi-sts    not  = spaces
                     go to wrt-mov-mag-900.
      *                  *---------------------------------------------*
      *                  * Scrittura righe                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Inizializzazione contatore righe scritte*
      *                      *-----------------------------------------*
           move      zero                 to   w-wrt-mov-mag-ctr      .
      *                      *-----------------------------------------*
      *                      * Start su catena movimenti               *
      *                      *-----------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       wrt-mov-mag-600.
      *                      *-----------------------------------------*
      *                      * Lettura sequenziale catena movimenti    *
      *                      *-----------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                      *-----------------------------------------*
      *                      * Se fine lettura : uscita                *
      *                      *-----------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to wrt-mov-mag-700.
      *                      *-----------------------------------------*
      *                      * Movimento da buffer catena movimenti a  *
      *                      * work di lavoro                          *
      *                      *-----------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *                      *-----------------------------------------*
      *                      * Se tipo riga a spazi : uscita           *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to wrt-mov-mag-700.
      *                      *-----------------------------------------*
      *                      * Selezione su tipo riga                  *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "M" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "S"
                     go to wrt-mov-mag-600.
           if        w-rig-tip-rig-tfu (1)
                                          not  = spaces
                     go to wrt-mov-mag-600.
      *                      *-----------------------------------------*
      *                      * Selezione su tipo prodotto : se 'Servi- *
      *                      * zio' riciclo                            *
      *                      *-----------------------------------------*
           if        w-rig-tip-pro (1)    =    02
                     go to wrt-mov-mag-600.
      *                      *-----------------------------------------*
      *                      * Incremento contatore righe scritte      *
      *                      *-----------------------------------------*
           add       1                    to   w-wrt-mov-mag-ctr      .
      *                      *-----------------------------------------*
      *                      * Normalizzazione riga                    *
      *                      *-----------------------------------------*
           move      "NR"                 to   l-mag-300-tip-ope      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                      *-----------------------------------------*
      *                      * Scrittura riga                          *
      *                      *-----------------------------------------*
           move      "WR"                 to   l-mag-300-tip-ope      .
           move      w-rig-tip-mag (1)    to   l-mag-300-tip-mag      .
           move      w-rig-num-pro (1)    to   l-mag-300-num-mag      .
           move      w-rig-alf-pro (1)    to   l-mag-300-alf-mag      .
           move      w-rig-sgl-vrn (1)    to   l-mag-300-var-mag      .
           move      w-rig-umi-ven (1)    to   l-mag-300-udm-ana      .
           move      w-rig-umi-ven (1)    to   l-mag-300-udm-mov      .
           move      zero                 to   l-mag-300-num-pmg      .
           move      zero                 to   l-mag-300-ddo-rif      .
           move      spaces               to   l-mag-300-ndo-rif      .
           move      w-rig-qta-ven (1)    to   l-mag-300-qta-mov      .
           perform   pre-rif-cun-000      thru pre-rif-cun-999        .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                      *-----------------------------------------*
      *                      * Test su esito operazione                *
      *                      *-----------------------------------------*
           if        l-mag-300-exi-sts    not  = spaces
                     go to wrt-mov-mag-900.
      *                      *-----------------------------------------*
      *                      * Riciclo su lettura catena movimenti     *
      *                      *-----------------------------------------*
           go to     wrt-mov-mag-600.
       wrt-mov-mag-700.
      *                  *---------------------------------------------*
      *                  * Test su numero righe scritte                *
      *                  *---------------------------------------------*
           if        w-wrt-mov-mag-ctr    not  = zero
                     go to wrt-mov-mag-999.
      *                  *---------------------------------------------*
      *                  * Se nessuna riga scritta : cancellazione     *
      *                  * della registrazione di magazzino per elimi- *
      *                  * nare la testata scritta                     *
      *                  *---------------------------------------------*
           move      "DE"                 to   l-mag-300-tip-ope      .
           move      w-tes-dat-doc        to   l-mag-300-dat-reg      .
           move      w-tes-pr2-mag (1)    to   l-mag-300-num-prt      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Uscita                                      *
      *                  *---------------------------------------------*
           go to     wrt-mov-mag-999.
       wrt-mov-mag-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Emissione messaggio                         *
      *                  *---------------------------------------------*
           move      "Attenzione : aggiornamenti di magazzino non esegui
      -              "ti !           "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
       wrt-mov-mag-999.
           exit.

      *    *===========================================================*
      *    * Subroutine di preparazione, per la routine di aggiorna-   *
      *    * mento magazzino, dei dati relativi ai riferimenti all'or- *
      *    * dine cliente, e dei dati relativi al costo unitario ed al *
      *    * valore. Il tutto sottoposto al test se presente la perso- *
      *    * nalizzazione relativa                                     *
      *    *-----------------------------------------------------------*
       pre-rif-cun-000.
      *              *-------------------------------------------------*
      *              * Se manca la personalizzazione : nessuna prepa-  *
      *              * razione dati                                    *
      *              *-------------------------------------------------*
           if        w-prs-arg-mag-trp    not  = "S"
                     go to pre-rif-cun-999.
      *              *-------------------------------------------------*
      *              * Se documento che non interessa la fatturazione, *
      *              * nessuna preparazione dati                       *
      *              *-------------------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to pre-rif-cun-999.
      *              *-------------------------------------------------*
      *              * Se documento per registrazione reso da cliente, *
      *              * nessuna preparazione dati                       *
      *              *-------------------------------------------------*
           if        w-tes-tip-mpf-tdo    =    03
                     go to pre-rif-cun-999.
      *              *-------------------------------------------------*
      *              * Test che si tratti di una bolla di evasione di  *
      *              * altra bolla                                     *
      *              *                                                 *
      *              * N.B.: attualmente inibito                       *
      *              *-------------------------------------------------*
______*    if        w-tes-tip-mpb-maf    =    04
______*              go to pre-rif-cun-999.
       pre-rif-cun-100.
      *              *-------------------------------------------------*
      *              * Preparazione della data di riferimento pari al- *
      *              * la data conferma d'ordine cliente               *
      *              *-------------------------------------------------*
           move      w-rig-coc-dat (1)    to   l-mag-300-ddo-rif      .
      *              *-------------------------------------------------*
      *              * Preparazione del numero di riferimento pari al  *
      *              * numero conferma d'ordine cliente                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Numero conferma d'ordine cliente in work di *
      *                  * comodo ridefinita                           *
      *                  *---------------------------------------------*
           move      w-rig-coc-num (1)    to   w-pre-rif-cun-num      .
      *                  *---------------------------------------------*
      *                  * Editing                                     *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                  to   v-edm                  .
           move      w-pre-rif-cun-prg    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione                             *
      *                  *---------------------------------------------*
           move      v-edt                to   l-mag-300-ndo-rif      .
       pre-rif-cun-200.
      *              *-------------------------------------------------*
      *              * Preparazione del costo unitario pari al prezzo  *
      *              * unitario di vendita                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Prezzo di vendita in costo unitario         *
      *                  *---------------------------------------------*
           move      w-rig-prz-net (1)    to   l-mag-300-cun-mov      .
           if        w-rig-dec-prz (1)    =    1
                     divide 10            into l-mag-300-cun-mov
           else if   w-rig-dec-prz (1)    =    2
                     divide 100           into l-mag-300-cun-mov      .
      *                  *---------------------------------------------*
      *                  * Test se trasformazione nella valuta base da *
      *                  * eseguire                                    *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpp (1)    =    c-sgl and
                     w-rig-dec-vpp (1)    =    c-dec and
                     w-rig-tdc-vpp (1)    =    c-tdc
                     go to pre-rif-cun-300.
      *                  *---------------------------------------------*
      *                  * Conversione da valuta per il prezzo a valu- *
      *                  * ta base                                     *
      *                  *---------------------------------------------*
           move      w-rig-sgl-vpp (1)    to   w-cvs-vlt-sgl          .
           move      w-rig-dec-vpp (1)    to   w-cvs-vlt-dec          .
           move      w-rig-tdc-vpp (1)    to   w-cvs-vlt-tdc          .
           move      w-rig-cdc-vpp (1)    to   w-cvs-vlt-cdc          .
           move      l-mag-300-cun-mov    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione                             *
      *                  *---------------------------------------------*
           move      w-cvs-vlt-avb        to   l-mag-300-cun-mov      .
       pre-rif-cun-300.
      *              *-------------------------------------------------*
      *              * Eventuale aggiustamento in presenza dell'indi-  *
      *              * catore di prezzo per unita' di misura diversa   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se la vendita non prevede trasformazione :  *
      *                  * oltre                                       *
      *                  *---------------------------------------------*
           if        w-rig-flg-puq (1)    =    spaces
                     go to pre-rif-cun-600.
      *                  *---------------------------------------------*
      *                  * Se la vendita prevede trasformazione ma     *
      *                  * il magazzino e' gestito allo stesso modo :  *
      *                  * oltre                                       *
      *                  *---------------------------------------------*
           if        w-rig-flg-puq (1)    =    w-prs-arg-mag-ecu
                     go to pre-rif-cun-600.
      *                  *---------------------------------------------*
      *                  * Se la vendita prevede trasformazione        *
      *                  *---------------------------------------------*
           if        w-rig-flg-puq (1)    =    "D"
                     divide  10           into l-mag-300-cun-mov
           else if   w-rig-flg-puq (1)    =    "C"
                     divide  100          into l-mag-300-cun-mov
           else if   w-rig-flg-puq (1)    =    "K"
                     divide  1000         into l-mag-300-cun-mov
           else      go to pre-rif-cun-600.
       pre-rif-cun-600.
      *              *-------------------------------------------------*
      *              * Preparazione del valore totale pari alla quan-  *
      *              * tita' moltiplicata per il prezzo unitario di    *
      *              * vendita                                         *
      *              *-------------------------------------------------*
           multiply  l-mag-300-qta-mov    by   l-mag-300-cun-mov
                                        giving l-mag-300-val-mov      .
       pre-rif-cun-700.
      *              *-------------------------------------------------*
      *              * Eventuale aggiustamento in presenza dell'indi-  *
      *              * catore di costo per unita' di misura diversa    *
      *              * nella gestione del magazzino                    *
      *              *-------------------------------------------------*
           if        w-prs-arg-mag-ecu    =    "D"
                     divide  10           into l-mag-300-val-mov
           else if   w-prs-arg-mag-ecu    =    "C"
                     divide  100          into l-mag-300-val-mov
           else if   w-prs-arg-mag-ecu    =    "K"
                     divide  1000         into l-mag-300-val-mov
           else      go to pre-rif-cun-900.
       pre-rif-cun-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     pre-rif-cun-999.
       pre-rif-cun-999.
           exit.

      *    *===========================================================*
      *    * Cancellazione movimento di MAG                            *
      *    *-----------------------------------------------------------*
       del-mov-mag-000.
      *              *-------------------------------------------------*
      *              * Cancellazione primo movimento di magazzino      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se necessario                          *
      *                  *---------------------------------------------*
           if        w-tes-prt-mag (2)    =    zero
                     go to del-mov-mag-500.
      *                  *---------------------------------------------*
      *                  * Esecuzione operazione                       *
      *                  *---------------------------------------------*
           move      "DE"                 to   l-mag-300-tip-ope      .
           move      w-tes-dat-doc        to   l-mag-300-dat-reg      .
           move      w-tes-prt-mag (2)    to   l-mag-300-num-prt      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
       del-mov-mag-500.
      *              *-------------------------------------------------*
      *              * Cancellazione secondo movimento di magazzino    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se necessario                          *
      *                  *---------------------------------------------*
           if        w-tes-pr2-mag (2)    =    zero
                     go to del-mov-mag-999.
      *                  *---------------------------------------------*
      *                  * Esecuzione operazione                       *
      *                  *---------------------------------------------*
           move      "DE"                 to   l-mag-300-tip-ope      .
           move      w-tes-dat-doc        to   l-mag-300-dat-reg      .
           move      w-tes-pr2-mag (2)    to   l-mag-300-num-prt      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
       del-mov-mag-999.
           exit.

      *    *===========================================================*
      *    * Calcolo prezzo netto                                      *
      *    *-----------------------------------------------------------*
           copy      "swd/std/prg/cpy/wcalprz0.cps"                   .

