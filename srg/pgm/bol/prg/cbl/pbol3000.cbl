      *              *-------------------------------------------------*
           move      zero                 to   w-exe-exp-pie-tot      .
           move      zero                 to   w-exe-exp-pie-ctr      .
       exe-exp-pie-tot-200.
           add       1                    to   w-exe-exp-pie-ctr      .
      *
           if        w-exe-exp-pie-ctr    >    96
                     go to exe-exp-pie-tot-400.
      *
           if        w-pie-scd-tip        
                    (1, w-exe-exp-pie-ctr)
                                          =    zero
                     go to exe-exp-pie-tot-200.
      *                  *---------------------------------------------*
      *                  * Aggiornamento totale scadenze               *
      *                  *---------------------------------------------*
           add       w-pie-scd-imp
                    (1, w-exe-exp-pie-ctr)
                                          to   w-exe-exp-pie-tot      .
      *                  *---------------------------------------------*
      *                  * Aggiornamento contatore scadenze            *
      *                  *---------------------------------------------*
           move      w-exe-exp-pie-ctr    to   w-pie-scd-ele (1)      .
      *                  *---------------------------------------------*
      *                  * A riciclo                                   *
      *                  *---------------------------------------------*
           go to     exe-exp-pie-tot-200.
       exe-exp-pie-tot-400.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "BG"                 to   v-edm                  .
           move      14                   to   v-lin                  .
           move      64                   to   v-pos                  .
           move      w-exe-exp-pie-tot    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-exp-pie-tot-600.
      *              *-------------------------------------------------*
      *              * Eventuale differenza dal totale documento       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da visualizzare                     *
      *                  *---------------------------------------------*
           if        w-tes-snx-ims (1)    not  = "S"
                     go to exe-exp-pie-tot-900.
      *                  *---------------------------------------------*
      *                  * Calcolo differenza                          *
      *                  *---------------------------------------------*
           move      w-exe-exp-pie-tot    to   w-exe-exp-pie-dif      .
           subtract  w-pie-tot-doc (1)    from w-exe-exp-pie-dif      .
      *                  *---------------------------------------------*
      *                  * Editing differenza                          *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      13                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      w-exe-exp-pie-dif    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Composizione literal                        *
      *                  *---------------------------------------------*
           move      17                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
           move      "("                  to   w-all-str-cat (1)      .
      *
           if        w-exe-exp-pie-dif    >    zero
                     move  "+"            to   w-all-str-cat (2)
           else if   w-exe-exp-pie-dif    =    zero
                     move  "="            to   w-all-str-cat (2)
           else      move  "-"            to   w-all-str-cat (2)      .
      *
           move      v-edt                to   w-all-str-cat (3)      .
           move      ")"                  to   w-all-str-cat (4)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      17                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      44                   to   v-pos                  .
           move      w-all-str-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-exp-pie-tot-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-exp-pie-tot-999.
       exe-exp-pie-tot-999.
           exit.

