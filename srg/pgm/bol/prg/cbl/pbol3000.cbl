           move      w-att-ndo-fti-saa    to   w-att-ndo-fti-wsa      .
           move      w-att-ndo-fti-ngi    to   w-att-ndo-fti-wgi      .
           move      w-att-ndo-fti-wnu    to   rn-fti-ndo-num-doc     .
      *                                      *-------------------------*
      *                                      * Data                    *
      *                                      *-------------------------*
           move      w-att-ndo-fti-dat    to   rn-fti-ndo-dat-doc     .
      *                                  *-----------------------------*
      *                                  * Update record               *
      *                                  *-----------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
      *                                  *-----------------------------*
      *                                  * Se errori ripete l'intera   *
      *                                  * operazione                  *
      *                                  *-----------------------------*
           if        f-sts                not  = e-not-err
                     go to att-ndo-fti-000.
      *                                  *-----------------------------*
      *                                  * Unlock della numerazione    *
      *                                  *-----------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
      *                                  *-----------------------------*
      *                                  * Salvataggio nuovo valore    *
      *                                  *-----------------------------*
           move      rn-fti-ndo-num-doc   to   w-att-ndo-fti-new      .
      *                                  *-----------------------------*
      *                                  * Uscita                      *
      *                                  *-----------------------------*
           go to     att-ndo-fti-999.
       att-ndo-fti-600.
      *                              *---------------------------------*
      *                              * Se risposta negativa            *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Unlock della numerazione    *
      *                                  *-----------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
      *                                  *-----------------------------*
      *                                  * Nessun nuovo valore         *
      *                                  *-----------------------------*
           move      zero                 to   w-att-ndo-fti-new      .
      *                                  *-----------------------------*
      *                                  * Uscita                      *
      *                                  *-----------------------------*
           go to     att-ndo-fti-999.
       att-ndo-fti-999.
           exit.

      *    *===========================================================*
      *    * Routine di ripristino numero documento fatture Italia     *
      *    *-----------------------------------------------------------*
       rip-ndo-fti-000.
      *              *-------------------------------------------------*
      *              * Se nessun nuovo numero documento : uscita       *
      *              *-------------------------------------------------*
           if        w-att-ndo-fti-new    =    zero
                     go to rip-ndo-fti-999.
      *              *-------------------------------------------------*
      *              * Composizione chiave per lettura                 *
      *              *-------------------------------------------------*
           move      w-att-ndo-fti-dat    to   s-dat                  .
           move      s-saa                to   w-att-ndo-fti-saa      .
           move      w-att-ndo-fti-saa    to   rn-fti-ndo-scl-ann     .
           move      w-att-ndo-fti-ngi    to   rn-fti-ndo-num-giv     .
           move      w-att-ndo-fti-sgl    to   rn-fti-ndo-sgl-num     .
      *              *-------------------------------------------------*
      *              * Lettura numerazione                             *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
           if        f-sts                =    e-not-err
                     go to rip-ndo-fti-100.
      *              *-------------------------------------------------*
      *              * Se numerazione non esistente la si crea norma-  *
      *              * lizzata a zero                                  *
      *              *-------------------------------------------------*
           move      zero                 to   rn-fti-ndo-num-doc     .
           move      zero                 to   rn-fti-ndo-dat-doc     .
           move      "PT"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
           go to     rip-ndo-fti-000.
       rip-ndo-fti-100.
      *              *-------------------------------------------------*
      *              * Se numerazione esistente                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Controllo se il valore attuale della nume-  *
      *                  * razione e' tuttora inalterato rispetto al-  *
      *                  * l'aggiornamento eseguito in fase di attri-  *
      *                  * buzione del numero                          *
      *                  *---------------------------------------------*
           if        rn-fti-ndo-num-doc   =    w-att-ndo-fti-new
                     go to rip-ndo-fti-200
           else      go to rip-ndo-fti-400.
       rip-ndo-fti-200.
      *                  *---------------------------------------------*
      *                  * Se il valore risulta inalterato             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controaggiornamento record              *
      *                      *-----------------------------------------*
           move      w-att-ndo-fti-nsv    to   rn-fti-ndo-num-doc     .
           move      w-att-ndo-fti-dsv    to   rn-fti-ndo-dat-doc     .
           move      "UP"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rip-ndo-fti-000.
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
           go to     rip-ndo-fti-999.
       rip-ndo-fti-400.
      *                  *---------------------------------------------*
      *                  * Se il valore risulta cambiato               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se il cambiamento corrisponde alla for- *
      *                      * zatura eseguita dall'operatore stesso   *
      *                      * in caso di impostazione di un numero    *
      *                      * superiore al progressivo : si controag- *
      *                      * giorna senza alcun messaggio            *
      *                      *-----------------------------------------*
           if        rn-fti-ndo-num-doc   =    w-att-ndo-fti-num
                     go to rip-ndo-fti-200.
      *                      *-----------------------------------------*
      *                      * Se il cambiamento invece e' dovuto al   *
      *                      * fatto che un altro utente ha nel frat-  *
      *                      * tempo prelevato un numero progressivo   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Unlock                              *
      *                          *-------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
      *                          *-------------------------------------*
      *                          * Messaggio all'operatore che il nu-  *
      *                          * mero deve essere recuperato manual- *
      *                          * mente                               *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Salvataggio del video attuale   *
      *                              *---------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Video in Off                    *
      *                              *---------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Box                             *
      *                              *---------------------------------*
           move      "BX"                 to   v-ope                  .
           move      09                   to   v-lin                  .
           move      18                   to   v-lto                  .
           move      08                   to   v-pos                  .
           move      73                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Messaggi entro il box           *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Titolo centrale             *
      *                                  *-----------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "                     A T T E N Z I O N E          
      -              "            "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                  *-----------------------------*
      *                                  * Riga messaggio 1            *
      *                                  *-----------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "Un altro utente ha nel frattempo prelevato un nume
      -              "ro !        "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                  *-----------------------------*
      *                                  * Riga messaggio 2            *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Preparazione numero do- *
      *                                      * cumento editato         *
      *                                      *-------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-att-ndo-fti-new    to   w-att-ndo-fti-wnu      .
           move      w-att-ndo-fti-wpr    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                                      *-------------------------*
      *                                      * Visualizzazione         *
      *                                      *-------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           string    "Pertanto il numero  "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " dovra' essere recuperato manualmente."
                                delimited by   size
                                          into v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                  *-----------------------------*
      *                                  * Riga messaggio 3            *
      *                                  *-----------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "                                                  
      -              "         [ ]"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                      *-------------------------*
      *                                      * Video in On             *
      *                                      *-------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                      *-------------------------*
      *                                      * Accettazione carattere  *
      *                                      * di presa visione        *
      *                                      *-------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      17                   to   v-lin                  .
           move      70                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                      *-------------------------*
      *                                      * Ripristino immagine     *
      *                                      * video                   *
      *                                      *-------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       rip-ndo-fti-999.
           exit.

      *    *===========================================================*
      *    * Scrittura movimento su file                               *
      *    *-----------------------------------------------------------*
       scr-mov-fil-000.
      *              *-------------------------------------------------*
      *              * Se in modifica : cancellazione movimenti prece- *
      *              *                  denti                          *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "M"
                     go to scr-mov-fil-050.
       scr-mov-fil-010.
      *                  *---------------------------------------------*
      *                  * Test se esiste la testata relativa al primo *
      *                  * protocollo contabile utilizzato             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se documento che non interessa la fat-  *
      *                      * turazione : oltre                       *
      *                      *-----------------------------------------*
           if        w-tes-int-ftr        not  = 03
                     go to scr-mov-fil-020.
      *                      *-----------------------------------------*
      *                      * Se protocollo di CGE a zero : oltre     *
      *                      *-----------------------------------------*
           if        w-tes-prt-mgd (2)    =    zero
                     go to scr-mov-fil-020.
      *                      *-----------------------------------------*
      *                      * Se causale di CGE a zero : oltre        *
      *                      *-----------------------------------------*
           if        w-tes-tip-mpf-cau    =    zero
                     go to scr-mov-fil-020.
      *                      *-----------------------------------------*
      *                      * Lettura testata                         *
      *                      *-----------------------------------------*
           move      "RT"                 to   l-cge-300-tip-ope      .
           move      w-tes-dat-doc        to   l-cge-300-dat-reg      .
           move      w-tes-prt-mgd (2)    to   l-cge-300-num-prt      .
           perform   mdl-agg-cge-cll-000  thru mdl-agg-cge-cll-999    .
      *                          *-------------------------------------*
      *                          * Test su esito lettura               *
      *                          *-------------------------------------*
           if        l-cge-300-exi-sts    =    spaces
                     go to scr-mov-fil-020.
      *                          *-------------------------------------*
      *                          * Se testata non trovata : errore     *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Messaggio di avviso             *
      *                              *---------------------------------*
           move      "ATTENZIONE : manca la registrazione contabile rela
      -              "tiva al documen"    to   w-err-box-err-msg      .
           move      "to. E' impossibile pertanto l'aggiornamento della 
      -              "registrazione !"    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                              *---------------------------------*
      *                              * Uscita con errore               *
      *                              *---------------------------------*
           go to     scr-mov-fil-999.
       scr-mov-fil-020.
      *                  *---------------------------------------------*
      *                  * Cancellazione movimento di FAT precedente   *
      *                  *---------------------------------------------*
           perform   del-mov-fat-000      thru del-mov-fat-999        .
       scr-mov-fil-030.
      *                  *---------------------------------------------*
      *                  * Cancellazione movimento di CGE precedente   *
      *                  *---------------------------------------------*
           perform   del-mov-cge-000      thru del-mov-cge-999        .
       scr-mov-fil-040.
      *                  *---------------------------------------------*
      *                  * Cancellazione movimento di GEP precedente   *
      *                  *---------------------------------------------*
           perform   del-mov-gep-000      thru del-mov-gep-999        .
       scr-mov-fil-045.
      *                  *---------------------------------------------*
      *                  * Cancellazione movimento di MAG precedente   *
      *                  *---------------------------------------------*
           perform   del-mov-mag-000      thru del-mov-mag-999        .
       scr-mov-fil-050.
      *              *-------------------------------------------------*
      *              * Se inserimento non si esaminano le righe dele-  *
      *              * tate                                            *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "I"
                     go to scr-mov-fil-200.
       scr-mov-fil-100.
      *              *-------------------------------------------------*
      *              * Lettura riga "last removed"                     *
      *              *-------------------------------------------------*
           move      "LR"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Se fine : a trattamento righe "in vita"         *
      *              *-------------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-200.
      *              *-------------------------------------------------*
      *              * Se riga precedente non esistente : riciclo      *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
           if        w-rig-num-prg (2)    =    zero
                     go to scr-mov-fil-100.
      *              *-------------------------------------------------*
      *              * Delete [bir]                                    *
      *              *-------------------------------------------------*
           perform   del-rec-bir-000      thru del-rec-bir-999        .
      *              *-------------------------------------------------*
      *              * Delete [bix]                                    *
      *              *-------------------------------------------------*
           perform   del-rec-bix-000      thru del-rec-bix-999        .
      *              *-------------------------------------------------*
      *              * Delete [bie]                                    *
      *              *-------------------------------------------------*
           perform   del-rec-bie-000      thru del-rec-bie-999        .
      *              *-------------------------------------------------*
      *              * Aggiornamento record [ocr] per Delete           *
      *              *-------------------------------------------------*
           perform   agg-ocr-del-000      thru agg-ocr-del-999        .
      *              *-------------------------------------------------*
      *              * Riciclo a prossima "last removed"               *
      *              *-------------------------------------------------*
           go to     scr-mov-fil-100.
       scr-mov-fil-200.
      *              *-------------------------------------------------*
      *              * Determinazione del flag di variazioni in testa- *
      *              * ta che si ripercuotono anche sulle righe        *
      *              *-------------------------------------------------*
           if        w-tes-tip-arc (1)    not  = w-tes-tip-arc (2) or
                     w-tes-cod-arc (1)    not  = w-tes-cod-arc (2) or
                     w-tes-dpz-arc (1)    not  = w-tes-dpz-arc (2) or
                     w-tes-fat-snx (1)    not  = w-tes-fat-snx (2) or
                     w-tes-fat-dat (1)    not  = w-tes-fat-dat (2) or
                     w-tes-fat-num (1)    not  = w-tes-fat-num (2) or
                     w-tes-fat-npb (1)    not  = w-tes-fat-npb (2) or
                     w-tes-cod-lng (1)    not  = w-tes-cod-lng (2) or
                     w-tes-sgl-vpf (1)    not  = w-tes-sgl-vpf (2) or
                     w-tes-dec-vpf (1)    not  = w-tes-dec-vpf (2) or
                     w-tes-tdc-vpf (1)    not  = w-tes-tdc-vpf (2) or
                     w-tes-cdc-vpf (1)    not  = w-tes-cdc-vpf (2)
                     move  "#"            to   w-cnt-var-tes-cor      .
      *              *-------------------------------------------------*
      *              * Start su righe corpo                            *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Se start non valida : uscita                    *
      *              *-------------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-700.
       scr-mov-fil-300.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale righe corpo                 *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *              *-------------------------------------------------*
      *              * Se at end : uscita                              *
      *              *-------------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to scr-mov-fil-700.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work     *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Trattamento file righe [bir]                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se inserimento                              *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to scr-mov-fil-500.
       scr-mov-fil-400.
      *                      *-----------------------------------------*
      *                      * Write record [bir]                      *
      *                      *-----------------------------------------*
           perform   wrt-rec-bir-000      thru wrt-rec-bir-999        .
      *                      *-----------------------------------------*
      *                      * Write record [bix]                      *
      *                      *-----------------------------------------*
           perform   wrt-rec-bix-000      thru wrt-rec-bix-999        .
      *                      *-----------------------------------------*
      *                      * Write record [bie]                      *
      *                      *-----------------------------------------*
           perform   wrt-rec-bie-000      thru wrt-rec-bie-999        .
      *                      *-----------------------------------------*
      *                      * Aggiornamento record [ocr] per Write    *
      *                      *-----------------------------------------*
           perform   agg-ocr-wrt-000      thru agg-ocr-wrt-999        .
      *                      *-----------------------------------------*
      *                      * Riciclo a lettura riga corpo successiva *
      *                      *-----------------------------------------*
           go to     scr-mov-fil-300.
       scr-mov-fil-500.
      *                  *---------------------------------------------*
      *                  * Se modifica                                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se riga nuova : come inserimento        *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig (2)    =    spaces
                     go to scr-mov-fil-400.
      *                      *-----------------------------------------*
      *                      * Controllo se riga corpo variata o se    *
      *                      * variazioni in testata che si riper-     *
      *                      * cuotono sulle righe                     *
      *                      *-----------------------------------------*
           if        w-rig-val-aep (1)    not  = w-rig-val-aep (2) or
                     w-cnt-var-tes-cor    not  = spaces
                     go to scr-mov-fil-600.
      *                      *-----------------------------------------*
      *                      * Se riga corpo non variata               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Riciclo a lettura riga corpo suc-   *
      *                          * cessiva                             *
      *                          *-------------------------------------*
           go to     scr-mov-fil-300.
       scr-mov-fil-600.
      *                      *-----------------------------------------*
      *                      * Se riga corpo variata                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Rewrite [bir]                       *
      *                          *-------------------------------------*
           perform   rew-rec-bir-000      thru rew-rec-bir-999        .
      *                          *-------------------------------------*
      *                          * Rewrite [bix]                       *
      *                          *-------------------------------------*
           perform   rew-rec-bix-000      thru rew-rec-bix-999        .
      *                          *-------------------------------------*
      *                          * Rewrite [bie]                       *
      *                          *-------------------------------------*
           perform   rew-rec-bie-000      thru rew-rec-bie-999        .
      *                          *-------------------------------------*
      *                          * Aggiornamento record [ocr] per Re-  *
      *                          * write                               *
      *                          *-------------------------------------*
           perform   agg-ocr-rew-000      thru agg-ocr-rew-999        .
      *                          *-------------------------------------*
      *                          * Riciclo a lettura riga corpo suc-   *
      *                          * cessiva                             *
      *                          *-------------------------------------*
           go to     scr-mov-fil-300.
       scr-mov-fil-700.
      *              *-------------------------------------------------*
      *              * Attribuzione primo protocollo di CGE e determi- *
      *              * nazione quanti di essi sono necessari           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da eseguire                         *
      *                  *---------------------------------------------*
           if        w-tes-int-ftr        not  = 03
                     go to scr-mov-fil-710.
           if        w-tes-tip-mpf-cau    =    zero
                     go to scr-mov-fil-710.
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           perform   det-prt-cge-000      thru det-prt-cge-999        .
       scr-mov-fil-710.
      *              *-------------------------------------------------*
      *              * Attribuzione primo protocollo di GEP e determi- *
      *              * nazione quanti di essi sono necessari           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da eseguire                         *
      *                  *---------------------------------------------*
           if        w-prs-gep-snx        =    "N"
                     go to scr-mov-fil-720.
           if        w-tes-int-ftr        not  = 03
                     go to scr-mov-fil-720.
           if        w-tes-tip-mpf-cau    =    zero
                     go to scr-mov-fil-720.
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           perform   det-num-sdb-000      thru det-num-sdb-999        .
       scr-mov-fil-720.
      *              *-------------------------------------------------*
      *              * Trattamento file testata [bit]                  *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se inserimento                              *
      *                  *---------------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to scr-mov-fil-800.
