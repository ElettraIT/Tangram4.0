      *    *===========================================================*
      *    * Determinazione valori testata relativi alle spese incasso *
      *    *-----------------------------------------------------------*
       det-vlt-zin-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione tabella spese incasso           *
      *              *-------------------------------------------------*
           perform   nor-tbl-spi-000      thru nor-tbl-spi-999        .
      *              *-------------------------------------------------*
      *              * Azzeramento contatori                           *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-vlt-zin-c01      .
           move      zero                 to   w-det-vlt-zin-c02      .
           move      zero                 to   w-det-vlt-zin-c03      .
      *              *-------------------------------------------------*
      *              * Se codice spesa incasso non esistente : uscita  *
      *              *-------------------------------------------------*
           if        w-tes-add-spi (1)    =    spaces
                     go to det-vlt-zin-900.
      *              *-------------------------------------------------*
      *              * Ciclo per tre codici pagamento possibili        *
      *              *-------------------------------------------------*
       det-vlt-zin-100.
           add       1                    to   w-det-vlt-zin-c01      .
           if        w-det-vlt-zin-c01    >    3
                     go to det-vlt-zin-900.
           if        w-tes-cod-pag
                    (1, w-det-vlt-zin-c01)
                                          =    zero
                     go to det-vlt-zin-100.
      *              *-------------------------------------------------*
      *              * Ciclo su elementi tabella gia' presenti         *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-vlt-zin-c02      .
       det-vlt-zin-200.
           add       1                    to   w-det-vlt-zin-c02      .
           if        w-det-vlt-zin-c02    >    w-det-vlt-zin-c03
                     go to det-vlt-zin-300.
           if        w-tes-tpg-spi
                    (1, w-det-vlt-zin-c02)
                                          =    w-tes-tip-pag
                                              (1, w-det-vlt-zin-c01)
                     go to det-vlt-zin-100.
       det-vlt-zin-300.
      *                  *---------------------------------------------*
      *                  * Lettura record [zin]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODSPI    "         to   f-key                  .
           move      w-tes-add-spi (1)    to   rf-zin-cod-spi         .
           move      w-tes-tip-pag
                    (1, w-det-vlt-zin-c01)
                                          to   rf-zin-tip-pag         .
           move      "pgm/dcc/fls/ioc/obj/iofzin"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zin                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-vlt-zin-100.
      *                  *---------------------------------------------*
      *                  * Incremento contatore elementi in tabella    *
      *                  *---------------------------------------------*
           add       1                    to   w-det-vlt-zin-c03      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valori                      *
      *                  *---------------------------------------------*
           move      rf-zin-tip-pag       to   w-tes-tpg-spi
                                              (1, w-det-vlt-zin-c03)  .
           move      rf-zin-tfu-spi       to   w-tes-tfu-spi
                                              (1, w-det-vlt-zin-c03)  .
           move      rf-zin-amm-spi       to   w-tes-amm-spi
                                              (1, w-det-vlt-zin-c03)  .
           move      rf-zin-per-spi       to   w-tes-per-spi
                                              (1, w-det-vlt-zin-c03)  .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-vlt-zin-100.
       det-vlt-zin-900.
      *              *-------------------------------------------------*
      *              * Bufferizzazione numero elementi in tabella spe- *
      *              * se incasso                                      *
      *              *-------------------------------------------------*
           move      w-det-vlt-zin-c03    to   w-tes-eit-spi (1)      .
       det-vlt-zin-999.
           exit.

      *    *===========================================================*
      *    * Determinazione valori testata relativi alle spese bollo   *
      *    *-----------------------------------------------------------*
       det-vlt-zbo-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione tabella spese bollo             *
      *              *-------------------------------------------------*
           perform   nor-tbl-spb-000      thru nor-tbl-spb-999        .
      *              *-------------------------------------------------*
      *              * Azzeramento contatori                           *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-vlt-zbo-c01      .
           move      zero                 to   w-det-vlt-zbo-c02      .
           move      zero                 to   w-det-vlt-zbo-c03      .
      *              *-------------------------------------------------*
      *              * Se codice spesa bollo non esistente : uscita    *
      *              *-------------------------------------------------*
           if        w-tes-add-spb (1)    =    spaces
                     go to det-vlt-zbo-900.
      *              *-------------------------------------------------*
      *              * Ciclo per tre codici pagamento possibili        *
      *              *-------------------------------------------------*
       det-vlt-zbo-100.
           add       1                    to   w-det-vlt-zbo-c01      .
           if        w-det-vlt-zbo-c01    >    3
                     go to det-vlt-zbo-900.
           if        w-tes-cod-pag
                    (1, w-det-vlt-zbo-c01)
                                          =    zero
                     go to det-vlt-zbo-100.
      *              *-------------------------------------------------*
      *              * Ciclo su elementi tabella gia' presenti         *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-vlt-zbo-c02      .
       det-vlt-zbo-200.
           add       1                    to   w-det-vlt-zbo-c02      .
           if        w-det-vlt-zbo-c02    >    w-det-vlt-zbo-c03
                     go to det-vlt-zbo-300.
           if        w-tes-tpg-spb
                    (1, w-det-vlt-zbo-c02)
                                          =    w-tes-tip-pag
                                              (1, w-det-vlt-zbo-c01)
                     go to det-vlt-zbo-100.
       det-vlt-zbo-300.
      *                  *---------------------------------------------*
      *                  * Lettura record [zbo]                        *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODSPB    "         to   f-key                  .
           move      w-tes-add-spb (1)    to   rf-zbo-cod-spb         .
           move      w-tes-tip-pag
                    (1, w-det-vlt-zbo-c01)
                                          to   rf-zbo-tip-pag         .
           move      "pgm/dcc/fls/ioc/obj/iofzbo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zbo                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to det-vlt-zbo-100.
      *                  *---------------------------------------------*
      *                  * Incremento contatore elementi in tabella    *
      *                  *---------------------------------------------*
           add       1                    to   w-det-vlt-zbo-c03      .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valori                      *
      *                  *---------------------------------------------*
           move      rf-zbo-tip-pag       to   w-tes-tpg-spb
                                              (1, w-det-vlt-zbo-c03)  .
           move      rf-zbo-tau-spb       to   w-tes-tau-spb
                                              (1, w-det-vlt-zbo-c03)  .
           move      rf-zbo-per-spb       to   w-tes-per-spb
                                              (1, w-det-vlt-zbo-c03)  .
           move      zero                 to   w-det-vlt-zbo-c04      .
       det-vlt-zbo-320.
           add       1                    to   w-det-vlt-zbo-c04      .
           if        w-det-vlt-zbo-c04    >    10
                     go to det-vlt-zbo-340.
           move      rf-zbo-tbe-scg
                    (w-det-vlt-zbo-c04)   to   w-tes-tbe-scg
                                              (1,
                                               w-det-vlt-zbo-c03,
                                               w-det-vlt-zbo-c04)     .
           move      rf-zbo-tbe-asc
                    (w-det-vlt-zbo-c04)   to   w-tes-tbe-asc
                                              (1,
                                               w-det-vlt-zbo-c03,
                                               w-det-vlt-zbo-c04)     .
           move      rf-zbo-tbe-psc
                    (w-det-vlt-zbo-c04)   to   w-tes-tbe-psc
                                              (1,
                                               w-det-vlt-zbo-c03,
                                               w-det-vlt-zbo-c04)     .
           go to     det-vlt-zbo-320.
       det-vlt-zbo-340.
           move      rf-zbo-tet-spb       to   w-tes-tet-spb
                                              (1, w-det-vlt-zbo-c03)  .
           move      rf-zbo-min-spb       to   w-tes-min-spb
                                              (1, w-det-vlt-zbo-c03)  .
           move      rf-zbo-max-spb       to   w-tes-max-spb
                                              (1, w-det-vlt-zbo-c03)  .
           move      rf-zbo-tar-spb       to   w-tes-tar-spb
                                              (1, w-det-vlt-zbo-c03)  .
           move      rf-zbo-var-spb       to   w-tes-var-spb
                                              (1, w-det-vlt-zbo-c03)  .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-vlt-zbo-100.
       det-vlt-zbo-900.
      *              *-------------------------------------------------*
      *              * Bufferizzazione numero elementi in tabella spe- *
      *              * se incasso                                      *
      *              *-------------------------------------------------*
           move      w-det-vlt-zbo-c03    to   w-tes-eit-spb (1)      .
       det-vlt-zbo-999.
           exit.

      *    *===========================================================*
      *    * Determinazione flag di estensione alla descrizione        *
      *    *-----------------------------------------------------------*
       det-des-ext-000.
      *              *-------------------------------------------------*
      *              * Determinazione numero righe occupate            *
      *              *-------------------------------------------------*
           move      11                   to   w-det-des-ext-ctr      .
       det-des-ext-100.
           subtract  1                    from w-det-des-ext-ctr      .
           if        w-det-des-ext-ctr    =    zero
                     go to det-des-ext-200.
           if        w-rig-der-rig
                    (1, w-det-des-ext-ctr)
                                          =    spaces
                     go to det-des-ext-100.
       det-des-ext-200.
      *              *-------------------------------------------------*
      *              * Se numero righe non superiore a 1               *
      *              *-------------------------------------------------*
           if        w-det-des-ext-ctr    not  > 1
                     move  0              to   w-rig-des-ext (1)
                     go to det-des-ext-900.
       det-des-ext-300.
      *              *-------------------------------------------------*
      *              * Se numero righe maggiore di 1                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su tipo riga                           *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "A"     or
                     w-rig-tip-rig-tpr (1)
                                          =    "C"     or
                    (w-rig-tip-rig-tpr (1)
                                          =    "P" and
                     w-rig-tip-rig-tfu (1)
                                          =    "N"   )
                     go to det-des-ext-400
           else      go to det-des-ext-500.
       det-des-ext-400.
      *                  *---------------------------------------------*
      *                  * Se riga tipo 'A', 'C' o 'PN'                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Forzatura                               *
      *                      *-----------------------------------------*
           move      1                    to   w-rig-des-ext (1)      .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     det-des-ext-900.
       det-des-ext-500.
      *                  *---------------------------------------------*
      *                  * Se riga tipo 'P', 'M' o 'S'                 *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se descrizione impostata uguale a  *
      *                      * descrizione originale                   *
      *                      *-----------------------------------------*
           if        w-rig-des-rig (1)    =    w-rig-des-por (1)
                     move  2              to   w-rig-des-ext (1)
           else      move  1              to   w-rig-des-ext (1)      .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     det-des-ext-900.
       det-des-ext-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-des-ext-999.
       det-des-ext-999.
           exit.

      *    *===========================================================*
      *    * Determinazione quantita' secondaria per la vendita        *
      *    *-----------------------------------------------------------*
           copy      "pgm/fat/prg/cpy/wdetqts0.wks"                   .

      *    *===========================================================*
      *    * Determinazione percentuali di provvigione in riga con e-  *
      *    * ventuale aggiustamento flag di significativita' provvi-   *
      *    * gioni in riga                                             *
      *    *-----------------------------------------------------------*
       det-ppv-rig-000.
      *              *-------------------------------------------------*
      *              * Test se da effettuare                           *
      *              *-------------------------------------------------*
           if        w-rig-fsp-rig (1)    not  = 01
                     go to det-ppv-rig-999.
       det-ppv-rig-100.
      *              *-------------------------------------------------*
      *              * Preparazione link-area                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valori diretti da w-tes o w-rig             *
      *                  *---------------------------------------------*
           move      "PP"                 to   d-pvg-age-tip-ope      .
           move      w-tes-cod-age (1)    to   d-pvg-age-cod-age      .
           move      w-tes-tip-vpa (1)    to   d-pvg-age-tip-vpa      .
           move      w-tes-cpv-aaa (1)    to   d-pvg-age-cpv-aaa      .
           move      w-tes-ppv-aaa (1, 1) to   d-pvg-age-ppv-aaa (1)  .
           move      w-tes-ppv-aaa (1, 2) to   d-pvg-age-ppv-aaa (2)  .
           move      w-tes-ppv-aaa (1, 3) to   d-pvg-age-ppv-aaa (3)  .
           move      w-rig-tip-mag (1)    to   d-pvg-age-tip-mag      .
           move      w-rig-num-pro (1)    to   d-pvg-age-num-mag      .
           move      w-tes-cod-lst (1)    to   d-pvg-age-cod-lst      .
           move      w-rig-cpv-aap (1)    to   d-pvg-age-cpv-aap      .
           move      w-rig-ppv-aap (1, 1) to   d-pvg-age-ppv-aap (1)  .
           move      w-rig-ppv-aap (1, 2) to   d-pvg-age-ppv-aap (2)  .
           move      w-rig-ppv-aap (1, 3) to   d-pvg-age-ppv-aap (3)  .
           if        w-tes-tip-frn (1)    =    11
                     move  w-tes-cod-arc (1)
                                          to   d-pvg-age-cod-cli
           else      move  w-tes-arc-plf (1)
                                          to   d-pvg-age-cod-cli      .
           move      w-tes-cpv-aac (1)    to   d-pvg-age-cpv-aac      .
           move      w-tes-ppv-aac (1, 1) to   d-pvg-age-ppv-aac (1)  .
           move      w-tes-ppv-aac (1, 2) to   d-pvg-age-ppv-aac (2)  .
           move      w-tes-ppv-aac (1, 3) to   d-pvg-age-ppv-aac (3)  .
           move      w-rig-sgl-vpp (1)    to   d-pvg-age-sgl-vpp      .
           move      w-rig-per-scr (1, 1) to   d-pvg-age-per-scr (1)  .
           move      w-rig-per-scr (1, 2) to   d-pvg-age-per-scr (2)  .
           move      w-rig-per-scr (1, 3) to   d-pvg-age-per-scr (3)  .
           move      w-rig-per-scr (1, 4) to   d-pvg-age-per-scr (4)  .
           move      w-rig-per-scr (1, 5) to   d-pvg-age-per-scr (5)  .
           move      w-tes-dat-doc        to   d-pvg-age-dat-rif      .
       det-ppv-rig-200.
      *                  *---------------------------------------------*
      *                  * Valori calcolati                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Prezzo lordo standard espresso nella    *
      *                      * valuta per il prezzo                    *
      *                      *-----------------------------------------*
           move      w-rig-prz-lrs (1)    to   d-pvg-age-prz-lrs      .
      *                      *-----------------------------------------*
      *                      * Eventuale conversione da valuta per     *
      *                      * prezzi standard a valuta per il prezzo  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se necessario                  *
      *                          *-------------------------------------*
           if        w-rig-sgl-vps (1)    =    w-rig-sgl-vpp (1)
                     go to det-ppv-rig-220.
      *                          *-------------------------------------*
      *                          * Conversione valore da valuta per i  *
      *                          * prezzi standard a valuta base       *
      *                          *-------------------------------------*
           move      w-rig-sgl-vps (1)    to   w-cvs-vlt-sgl          .
           move      w-rig-dec-vps (1)    to   w-cvs-vlt-dec          .
           move      w-rig-tdc-vps (1)    to   w-cvs-vlt-tdc          .
           move      w-rig-cdc-vps (1)    to   w-cvs-vlt-cdc          .
           move      d-pvg-age-prz-lrs    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
      *                          *-------------------------------------*
      *                          * Conversione valore da valuta base a *
      *                          * valuta per il prezzo                *
      *                          *-------------------------------------*
           move      w-rig-sgl-vpp (1)    to   w-cvs-vlt-sgl          .
           move      w-rig-dec-vpp (1)    to   w-cvs-vlt-dec          .
           move      w-rig-tdc-vpp (1)    to   w-cvs-vlt-tdc          .
           move      w-rig-cdc-vpp (1)    to   w-cvs-vlt-cdc          .
           perform   cvs-vlb-alt-000      thru cvs-vlb-alt-999        .
           move      w-cvs-vlt-aav        to   d-pvg-age-prz-lrs      .
       det-ppv-rig-220.
      *                      *-----------------------------------------*
      *                      * Prezzo netto standard espresso nella    *
      *                      * valuta per il prezzo                    *
      *                      *-----------------------------------------*
           move      w-rig-prz-nts (1)    to   d-pvg-age-prz-nts      .
      *                      *-----------------------------------------*
      *                      * Eventuale conversione da valuta per     *
      *                      * prezzi standard a valuta per il prezzo  *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test se necessario                  *
      *                          *-------------------------------------*
           if        w-rig-sgl-vps (1)    =    w-rig-sgl-vpp (1)
                     go to det-ppv-rig-240.
      *                          *-------------------------------------*
      *                          * Conversione valore da valuta per i  *
      *                          * prezzi standard a valuta base       *
      *                          *-------------------------------------*
           move      w-rig-sgl-vps (1)    to   w-cvs-vlt-sgl          .
           move      w-rig-dec-vps (1)    to   w-cvs-vlt-dec          .
           move      w-rig-tdc-vps (1)    to   w-cvs-vlt-tdc          .
           move      w-rig-cdc-vps (1)    to   w-cvs-vlt-cdc          .
           move      d-pvg-age-prz-nts    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
      *                          *-------------------------------------*
      *                          * Conversione valore da valuta base a *
      *                          * valuta per il prezzo                *
      *                          *-------------------------------------*
           move      w-rig-sgl-vpp (1)    to   w-cvs-vlt-sgl          .
           move      w-rig-dec-vpp (1)    to   w-cvs-vlt-dec          .
           move      w-rig-tdc-vpp (1)    to   w-cvs-vlt-tdc          .
           move      w-rig-cdc-vpp (1)    to   w-cvs-vlt-cdc          .
           perform   cvs-vlb-alt-000      thru cvs-vlb-alt-999        .
           move      w-cvs-vlt-aav        to   d-pvg-age-prz-nts      .
       det-ppv-rig-240.
      *                      *-----------------------------------------*
      *                      * Prezzo netto effettivo, gia' espresso   *
      *                      * nella valuta per il prezzo              *
      *                      *-----------------------------------------*
           move      w-rig-prz-net (1)    to   d-pvg-age-prz-net      .
       det-ppv-rig-300.
      *              *-------------------------------------------------*
      *              * Richiamo del sottoprogramma                     *
      *              *-------------------------------------------------*
           perform   det-pvg-age-cll-000  thru det-pvg-age-cll-999    .
       det-ppv-rig-400.
      *              *-------------------------------------------------*
      *              * Memorizzazione percentuali determinate          *
      *              *-------------------------------------------------*
           move      d-pvg-age-per-pvg (1)
                                          to   w-rig-ppv-rig (1, 1)   .
           move      d-pvg-age-per-pvg (2)
                                          to   w-rig-ppv-rig (1, 2)   .
           move      d-pvg-age-per-pvg (3)
                                          to   w-rig-ppv-rig (1, 3)   .
       det-ppv-rig-500.
      *              *-------------------------------------------------*
      *              * Eventuale aggiustamento flag di significativi-  *
      *              * ta' provvigioni in riga                         *
      *              *-------------------------------------------------*
           if        d-pvg-age-flg-pvs    not  = spaces
                     move  03             to   w-rig-fsp-rig (1)      .
       det-ppv-rig-999.
           exit.

      *    *===========================================================*
      *    * Determinazione importo in riga                            *
      *    *-----------------------------------------------------------*
       det-imp-rig-000.
      *              *-------------------------------------------------*
      *              * Preparazione parametri per la determinazione    *
      *              *-------------------------------------------------*
           move      "IR"                 to   d-imp-ven-tip-ope      .
           move      w-rig-qta-ven (1)    to   d-imp-ven-qta-ven      .
           move      w-rig-snx-2qt (1)    to   d-imp-ven-snx-2qt      .
           move      w-rig-qta-a02 (1)    to   d-imp-ven-qta-a02      .
           move      w-rig-snx-3qt (1)    to   d-imp-ven-snx-3qt      .
           move      w-rig-qta-a03 (1)    to   d-imp-ven-qta-a03      .
           move      w-rig-prz-net (1)    to   d-imp-ven-prz-uni      .
           move      w-rig-prz-ven (1)    to   d-imp-ven-prz-unl      .
           move      w-rig-per-scr (1, 1) to   d-imp-ven-per-scr (1)  .
           move      w-rig-per-scr (1, 2) to   d-imp-ven-per-scr (2)  .
           move      w-rig-per-scr (1, 3) to   d-imp-ven-per-scr (3)  .
           move      w-rig-per-scr (1, 4) to   d-imp-ven-per-scr (4)  .
           move      w-rig-per-scr (1, 5) to   d-imp-ven-per-scr (5)  .
           move      w-rig-dec-prz (1)    to   d-imp-ven-dec-prz      .
      *              *-------------------------------------------------*
      *              * Determinazione                                  *
      *              *-------------------------------------------------*
           perform   det-imp-ven-cll-000  thru det-imp-ven-cll-999    .
      *              *-------------------------------------------------*
      *              * In campo di uscita                              *
      *              *-------------------------------------------------*
           move      d-imp-ven-imp-rig    to   w-rig-imp-rig (1)      .
       det-imp-rig-600.
      *              *-------------------------------------------------*
      *              * Eventuale conversione nella valuta di fattura-  *
      *              * zione                                           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se necessario                          *
      *                  *---------------------------------------------*
           if        w-rig-sgl-vpp (1)    =    w-tes-sgl-vpf (1)
                     go to det-imp-rig-999.
      *                  *---------------------------------------------*
      *                  * Conversione importo da valuta per il prezzo *
      *                  * a valuta base                               *
      *                  *---------------------------------------------*
           move      w-rig-sgl-vpp (1)    to   w-cvs-vlt-sgl          .
           move      w-rig-dec-vpp (1)    to   w-cvs-vlt-dec          .
           move      w-rig-tdc-vpp (1)    to   w-cvs-vlt-tdc          .
           move      w-rig-cdc-vpp (1)    to   w-cvs-vlt-cdc          .
           move      w-rig-imp-rig (1)    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
      *                  *---------------------------------------------*
      *                  * Conversione importo da valuta base a valuta *
      *                  * per fatturazione                            *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-cvs-vlt-sgl          .
           move      w-tes-dec-vpf (1)    to   w-cvs-vlt-dec          .
           move      w-tes-tdc-vpf (1)    to   w-cvs-vlt-tdc          .
           move      w-tes-cdc-vpf (1)    to   w-cvs-vlt-cdc          .
           perform   cvs-vlb-alt-000      thru cvs-vlb-alt-999        .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione del risultato               *
      *                  *---------------------------------------------*
           move      w-cvs-vlt-aav        to   w-rig-imp-rig (1)      .
       det-imp-rig-999.
           exit.

      *    *===========================================================*
      *    * Determinazione totali da righe prima del trattamento piede*
      *    *-----------------------------------------------------------*
       det-tot-rig-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-tot-rig-flg      .
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-cat-rig            to   w-sav-cat-rig          .
      *              *-------------------------------------------------*
      *              * Normalizzazione totalizzatori prodotti da       *
      *              * escludere nel trattamento sconti a scaglioni    *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-scc-tmr      .
           move      zero                 to   w-det-tot-scc-tdt      .
      *              *-------------------------------------------------*
      *              * Normalizzazione totalizzatori per tipo prodotto *
      *              *-------------------------------------------------*
           perform   nor-tot-rig-000      thru nor-tot-rig-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazione castelletto iva                 *
      *              *-------------------------------------------------*
           perform   nor-iva-cst-000      thru nor-iva-cst-999        .
      *              *-------------------------------------------------*
      *              * Normalizzazione castelletto contropartite       *
      *              *-------------------------------------------------*
           perform   nor-iva-ctp-000      thru nor-iva-ctp-999        .
      *              *-------------------------------------------------*
      *              * Start su catena movimenti                       *
      *              *-------------------------------------------------*
           move      "ST"                 to   w-cat-rig-ope          .
           move      1                    to   w-cat-rig-num          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
       det-tot-rig-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale catena movimenti            *
      *              *-------------------------------------------------*
           move      "RN"                 to   w-cat-rig-ope          .
           perform   cll-sub-cat-000      thru cll-sub-cat-999        .
      *                  *---------------------------------------------*
      *                  * Se fine lettura : uscita                    *
      *                  *---------------------------------------------*
           if        w-cat-rig-exs        not  = spaces
                     go to det-tot-rig-900.
      *              *-------------------------------------------------*
      *              * Se buffer catena movimenti a spaces : riciclo   *
      *              *-------------------------------------------------*
           if        w-cat-rig-buf        =    spaces
                     go to det-tot-rig-100.
      *              *-------------------------------------------------*
      *              * Movimento da buffer catena movimenti a work di  *
      *              * lavoro                                          *
      *              *-------------------------------------------------*
           move      w-cat-rig-buf        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Se tipo riga a spazi : riciclo                  *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig (1)    =    spaces
                     go to det-tot-rig-100.
      *              *-------------------------------------------------*
      *              * Selezione su tipo riga                          *
      *              *-------------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          =    "C"
                     go to det-tot-rig-100.
      *              *-------------------------------------------------*
      *              * Aggiornamento totalizzatori per tipo prodotto   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se riga di omaggio : no totalizzazione      *
      *                  *---------------------------------------------*
           move      w-rig-coi-rig (1)    to   w-edt-iva-cod          .
           if        w-edt-iva-cod-003    =    9
                     go to det-tot-rig-180.
      *                  *---------------------------------------------*
      *                  * Se tipo riga P o PN                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "P"
                     go to det-tot-rig-120.
      *                      *-----------------------------------------*
      *                      * Accumulo totali                         *
      *                      *-----------------------------------------*
           if        w-rig-tip-pro (1)    =    01
                     add  w-rig-imp-rig (1)
                                          to   w-pie-tot-rig (1, 01)
           else if   w-rig-tip-pro (1)    =    02
                     add  w-rig-imp-rig (1)
                                          to   w-pie-tot-rig (1, 02)
           else if   w-rig-tip-pro (1)    =    03
                     add  w-rig-imp-rig (1)
                                          to   w-pie-tot-rig (1, 03)
           else if   w-rig-tip-pro (1)    =    09
                     add  w-rig-imp-rig (1)
                                          to   w-pie-tot-rig (1, 09)  .
      *                      *-----------------------------------------*
      *                      * Accumulo totali prodotti da escludere   *
      *                      * nella determinazione dello sconto in    *
      *                      * chiusura a scaglioni, se gestito        *
      *                      *                                         *
      *                      * N.B.: attualmente previsto per un solo  *
      *                      *       codice prodotto                   *
      *                      *-----------------------------------------*
           if        w-prs-snx-scc        not  = "S"
                     go to det-tot-rig-180.
      *
           add       w-rig-imp-rig (1)    to   w-det-tot-scc-tmr      .
      *
           if        w-ref-pro-scc-num (1)
                                          =    zero
                     go to det-tot-rig-180.
      *
           if        w-rig-num-pro (1)    not  = w-ref-pro-scc-num (1)
                     go to det-tot-rig-180.
      *
           add       w-rig-imp-rig (1)    to   w-det-tot-scc-tdt      .
      *
           go to     det-tot-rig-180.
       det-tot-rig-120.
      *                  *---------------------------------------------*
      *                  * Se tipo riga M o S                          *
      *                  *---------------------------------------------*
           if        w-rig-tip-rig-tpr (1)
                                          not  = "M" and
                     w-rig-tip-rig-tpr (1)
                                          not  = "S"
                     go to det-tot-rig-140.
           add       w-rig-imp-rig (1)    to   w-pie-tot-rig (1, 01)  .
           go to     det-tot-rig-180.
       det-tot-rig-140.
      *                  *---------------------------------------------*
      *                  * Se tipo riga A                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Totalizzatore generico di comodo        *
      *                      *-----------------------------------------*
           add       w-rig-imp-rig (1)    to   w-pie-tot-rta (1)      .
      *                      *-----------------------------------------*
      *                      * Test se altro totale da aggiornare      *
      *                      *-----------------------------------------*
           if        w-rig-tip-rig-tot (1)
                                          =    zero or
                     w-rig-tip-rig-tot (1)
                                          >    9
                     go to det-tot-rig-180.
      *                      *-----------------------------------------*
      *                      * Aggiornamento del totale come indicato  *
      *                      * nel codice di addebito                  *
      *                      *-----------------------------------------*
           move      w-rig-tip-rig-tot (1)
                                          to   w-ivb-tot-rad          .
           if        w-ivb-tot-rad        =    zero
                     go to det-tot-rig-180.
           add       w-rig-imp-rig (1)    to   w-pie-tot-rig
                                              (1, w-ivb-tot-rad)      .
       det-tot-rig-180.
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto iva                   *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-rig-ctr      .
       det-tot-rig-200.
           add       1                    to   w-det-tot-rig-ctr      .
           if        w-det-tot-rig-ctr    >    12
                     move  12             to   w-det-tot-rig-ctr
                     go to det-tot-rig-240.
           if        w-pie-iva-cod        
                    (1, w-det-tot-rig-ctr)
                                          =    zero
                     go to det-tot-rig-220.
           if        w-rig-coi-rig (1)    =    w-pie-iva-cod
                                              (1, w-det-tot-rig-ctr)
                     go to det-tot-rig-240.
           go to     det-tot-rig-200.
       det-tot-rig-220.
           add       1                    to   w-pie-iva-ele (1)      .
           move      w-rig-coi-rig (1)    to   w-pie-iva-cod
                                              (1, w-det-tot-rig-ctr)  .
       det-tot-rig-240.
           add       w-rig-imp-rig (1)    to   w-pie-iva-ibl
                                              (1, w-det-tot-rig-ctr)  .
      *              *-------------------------------------------------*
      *              * Aggiornamento castelletto contropartite         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se riga di omaggio : no aggiornamento       *
      *                  *---------------------------------------------*
           move      w-rig-coi-rig (1)    to   w-edt-iva-cod          .
           if        w-edt-iva-cod-003    =    9
                     go to det-tot-rig-400.
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione                          *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-tot-rig-ctr      .
       det-tot-rig-300.
           add       1                    to   w-det-tot-rig-ctr      .
           if        w-det-tot-rig-ctr    >    20
                     move  20             to   w-det-tot-rig-ctr
                     go to det-tot-rig-340.
           if        w-pie-ctp-cod        
                    (1, w-det-tot-rig-ctr)
                                          =    zero
                     go to det-tot-rig-320.
           if        w-rig-ctv-rig (1)    =    w-pie-ctp-cod
                                              (1, w-det-tot-rig-ctr)
                     go to det-tot-rig-340.
           go to     det-tot-rig-300.
       det-tot-rig-320.
           add       1                    to   w-pie-ctp-ele (1)      .
           move      w-rig-ctv-rig (1)    to   w-pie-ctp-cod
                                              (1, w-det-tot-rig-ctr)  .
       det-tot-rig-340.
           add       w-rig-imp-rig (1)    to   w-pie-ctp-imp
                                              (1, w-det-tot-rig-ctr)  .
       det-tot-rig-400.
      *              *-------------------------------------------------*
      *              * Riciclo su scansione righe                      *
      *              *-------------------------------------------------*
           go to     det-tot-rig-100.
       det-tot-rig-900.
      *              *-------------------------------------------------*
      *              * Determinazione totale lordo                     *
      *              *-------------------------------------------------*
           move      zero                 to   w-pie-tot-lor (1)      .
           add       w-pie-tot-rig (1, 01)
                                          to   w-pie-tot-lor (1)      .
           add       w-pie-tot-rig (1, 02)
                                          to   w-pie-tot-lor (1)      .
           add       w-pie-tot-rig (1, 03)
                                          to   w-pie-tot-lor (1)      .
           add       w-pie-tot-rig (1, 09)
                                          to   w-pie-tot-lor (1)      .
      *              *-------------------------------------------------*
      *              * Salvataggio castelletto iva                     *
      *              *-------------------------------------------------*
           move      w-pie-iva-cst (1)    to   w-sav-iva-cst          .
      *              *-------------------------------------------------*
      *              * Salvataggio castelletto contropartite           *
      *              *-------------------------------------------------*
           move      w-pie-ctp-cst (1)    to   w-sav-ctp-cst          .
       det-tot-rig-950.
      *              *-------------------------------------------------*
      *              * Ripristino area w-rig                           *
      *              *-------------------------------------------------*
           move      w-sav-wrk-rig        to   w-rig                  .
      *              *-------------------------------------------------*
      *              * Ripristino area catena                          *
      *              *-------------------------------------------------*
           move      w-sav-cat-rig        to   w-cat-rig              .
       det-tot-rig-999.
           exit.

      *    *===========================================================*
      *    * Determinazione % di sconto in chiusura in base ad         *
      *    * eventuali scaglioni di ammontare                          *
      *    *-----------------------------------------------------------*
       det-scg-scc-000.
      *              *-------------------------------------------------*
      *              * Test preliminari                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su personalizzazione                   *
      *                  *---------------------------------------------*
           if        w-prs-snx-scc        not  = "S"
                     go to det-scg-scc-900.
      *                  *---------------------------------------------*
      *                  * Determinazione totale merce di comodo       *
      *                  *---------------------------------------------*
           move      w-det-tot-scc-tmr    to   w-det-tot-scc-tot      .
           subtract  w-det-tot-scc-tdt    from w-det-tot-scc-tot      .
      *                  *---------------------------------------------*
      *                  * Test su totale merce di comodo              *
      *                  *---------------------------------------------*
           if        w-det-tot-scc-tot    =    zero
                     go to det-scg-scc-900.
       det-scg-scc-100.
      *              *-------------------------------------------------*
      *              * Normalizzazione [zsd]                           *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcc/fls/ioc/obj/iofzsd"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zsd                 .
       det-scg-scc-200.
      *              *-------------------------------------------------*
      *              * Lettura                                         *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "DOCTMO    "         to   f-key                  .
           move      01                   to   rf-zsd-tip-doc         .
