      *                              * Salvataggio del video attuale   *
      *                              *---------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Video in Off                    *
      *                              *---------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Box                             *
      *                              *---------------------------------*
           move      "BX"                 to   v-ope                  .
           move      09                   to   v-lin                  .
           move      18                   to   v-lto                  .
           move      08                   to   v-pos                  .
           move      73                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Messaggi entro il box           *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Titolo centrale             *
      *                                  *-----------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "                     A T T E N Z I O N E          
      -              "            "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                  *-----------------------------*
      *                                  * Riga messaggio 1            *
      *                                  *-----------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "Un altro utente ha nel frattempo prelevato un nume
      -              "ro !        "       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                  *-----------------------------*
      *                                  * Riga messaggio 2            *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Preparazione numero do- *
      *                                      * cumento editato         *
      *                                      *-------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-att-bci-ndo-new    to   w-att-bci-ndo-wnu      .
           move      w-att-bci-ndo-wpr    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                                      *-------------------------*
      *                                      * Visualizzazione         *
      *                                      *-------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           string    "Pertanto il numero  "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " dovra' essere recuperato manualmente."
                                delimited by   size
                                          into v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                  *-----------------------------*
      *                                  * Riga messaggio 3            *
      *                                  *-----------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      62                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      "                                                  
      -              "         [ ]"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                      *-------------------------*
      *                                      * Video in On             *
      *                                      *-------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                      *-------------------------*
      *                                      * Accettazione carattere  *
      *                                      * di presa visione        *
      *                                      *-------------------------*
           move      "AC"                 to   v-ope                  .
           move      "K"                  to   v-tip                  .
           move      17                   to   v-lin                  .
           move      70                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                      *-------------------------*
      *                                      * Ripristino immagine     *
      *                                      * video                   *
      *                                      *-------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       rip-bci-ndo-999.
           exit.

      *    *===========================================================*
      *    * Routine di attribuzione numero documento fatture Italia   *
      *    *-----------------------------------------------------------*
       att-ndo-fti-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-att-ndo-fti-flg      .
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
      *              *-------------------------------------------------*
      *              * Composizione chiave per lettura                 *
      *              *-------------------------------------------------*
           move      w-att-ndo-fti-dat    to   s-dat                  .
           move      s-saa                to   w-att-ndo-fti-saa      .
           move      w-att-ndo-fti-saa    to   rn-fti-ndo-scl-ann     .
           move      w-att-ndo-fti-ngi    to   rn-fti-ndo-num-giv     .
           move      w-att-ndo-fti-sgl    to   rn-fti-ndo-sgl-num     .
      *              *-------------------------------------------------*
      *              * Lettura numerazione                             *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
           if        f-sts                =    e-not-err
                     go to att-ndo-fti-100.
      *              *-------------------------------------------------*
      *              * Se numerazione non esistente la si crea norma-  *
      *              * lizzata a zero                                  *
      *              *-------------------------------------------------*
           move      zero                 to   rn-fti-ndo-num-doc     .
           move      zero                 to   rn-fti-ndo-dat-doc     .
           move      "PT"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
           move      "RL"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
           go to     att-ndo-fti-000.
       att-ndo-fti-100.
      *              *-------------------------------------------------*
      *              * Se numerazione esistente                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valori originali            *
      *                  *---------------------------------------------*
           move      rn-fti-ndo-num-doc   to   w-att-ndo-fti-wnu      .
           move      w-att-ndo-fti-saa    to   w-att-ndo-fti-wsa      .
           move      w-att-ndo-fti-ngi    to   w-att-ndo-fti-wgi      .
           move      w-att-ndo-fti-wnu    to   w-att-ndo-fti-nsv      .
           move      rn-fti-ndo-dat-doc   to   w-att-ndo-fti-dsv      .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del numero documento   *
      *                  * impostato                                   *
      *                  *---------------------------------------------*
           move      w-att-ndo-fti-num    to   w-att-ndo-fti-wnu      .
           if        w-att-ndo-fti-wpr    =    zero
                     go to att-ndo-fti-200
           else      go to att-ndo-fti-300.
       att-ndo-fti-200.
      *                  *---------------------------------------------*
      *                  * Se numero documento passato a zero          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Valore record in comodo ridefinito      *
      *                      *-----------------------------------------*
           move      rn-fti-ndo-num-doc   to   w-att-ndo-fti-wnu      .
      *                      *-----------------------------------------*
      *                      * Incremento numero progressivo del comodo*
      *                      * ridefinito                              *
      *                      *-----------------------------------------*
           add       1                    to   w-att-ndo-fti-wpr      .
           if        w-att-ndo-fti-wpr    =    zero
                     move  1              to   w-att-ndo-fti-wpr      .
      *                      *-----------------------------------------*
      *                      * Forzatura secolo/anno                   *
      *                      *-----------------------------------------*
           move      w-att-ndo-fti-saa    to   w-att-ndo-fti-wsa      .
      *                      *-----------------------------------------*
      *                      * Forzatura giornale iva                  *
      *                      *-----------------------------------------*
           move      w-att-ndo-fti-ngi    to   w-att-ndo-fti-wgi      .
      *                      *-----------------------------------------*
      *                      * Movimento da comodo ridefinito a record *
      *                      *-----------------------------------------*
           move      w-att-ndo-fti-wnu    to   rn-fti-ndo-num-doc     .
      *                      *-----------------------------------------*
      *                      * Data documento                          *
      *                      *-----------------------------------------*
           move      w-att-ndo-fti-dat    to   rn-fti-ndo-dat-doc     .
      *                      *-----------------------------------------*
      *                      * Update record                           *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to att-ndo-fti-000.
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
      *                      *-----------------------------------------*
      *                      * Salvataggio nuovo valore                *
      *                      *-----------------------------------------*
           move      rn-fti-ndo-num-doc   to   w-att-ndo-fti-new      .
      *                      *-----------------------------------------*
      *                      * Valore in uscita                        *
      *                      *-----------------------------------------*
           move      rn-fti-ndo-num-doc   to   w-att-ndo-fti-num      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     att-ndo-fti-999.
       att-ndo-fti-300.
      *                  *---------------------------------------------*
      *                  * Se numero documento passato non a zero      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se numero documento passato minore o u- *
      *                      * guale a quello letto : uscita           *
      *                      *-----------------------------------------*
           if        w-att-ndo-fti-num    >    w-att-ndo-fti-nsv
                     go to att-ndo-fti-320.
      *                          *-------------------------------------*
      *                          * Unlock                              *
      *                          *-------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/fat/num/ioc/obj/inftindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-fti-ndo             .
      *                          *-------------------------------------*
      *                          * Azzeramento nuovo numero documento  *
      *                          *-------------------------------------*
           move      zero                 to   w-att-ndo-fti-new      .
           go to     att-ndo-fti-999.
       att-ndo-fti-320.
      *                      *-----------------------------------------*
      *                      * Se numero documento passato maggiore di *
      *                      * quello letto                            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se e' maggiore di un'unita' : come  *
      *                          * se fosse stato passato a zero       *
      *                          *-------------------------------------*
           move      w-att-ndo-fti-nsv    to   w-att-ndo-fti-wnu      .
           add       1                    to   w-att-ndo-fti-wpr      .
           if        w-att-ndo-fti-wpr    =    zero
                     move  1              to   w-att-ndo-fti-wpr      .
           if        w-att-ndo-fti-num    =    w-att-ndo-fti-wnu
                     go to att-ndo-fti-200.
       att-ndo-fti-400.
      *                          *-------------------------------------*
      *                          * Se invece e' maggiore di piu' di    *
      *                          * un'unita'                           *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Test su si/no numerazione modi- *
      *                              * ficabile letto da tipo movimen- *
      *                              * to                              *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Test                        *
      *                                  *-----------------------------*
           if        w-att-ndo-fti-nmm    not  = "N"
                     go to att-ndo-fti-405.
      *                                  *-----------------------------*
      *                                  * Flag di uscita              *
      *                                  *-----------------------------*
           move      "#"                  to   w-att-ndo-fti-flg      .
      *                                  *-----------------------------*
      *                                  * Ad uscita                   *
      *                                  *-----------------------------*
           go to     att-ndo-fti-600.
       att-ndo-fti-405.
      *                              *---------------------------------*
      *                              * Salvataggio del video attuale   *
      *                              *---------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Video in Off                    *
      *                              *---------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Box per messaggio all'operatore *
      *                              *---------------------------------*
           move      "BX"                 to   v-ope                  .
           move      09                   to   v-lin                  .
           move      18                   to   v-lto                  .
           move      09                   to   v-pos                  .
           move      72                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Messaggi entro il box           *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Titolo centrale             *
      *                                  *-----------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      11                   to   v-pos                  .
           move      "                      A T T E N Z I O N E         
      -              "          "         to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                  *-----------------------------*
      *                                  * Numeri saltati              *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Preparazione differenza *
      *                                      *-------------------------*
           move      w-att-ndo-fti-r13    to   w-att-ndo-fti-wdf      .
           subtract  w-att-ndo-fti-wpr    from w-att-ndo-fti-wdf      .
           add       1                    to   w-att-ndo-fti-wdf      .
      *                                      *-------------------------*
      *                                      * Preparazione numero     *
      *                                      *-------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-att-ndo-fti-wdf    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                                      *-------------------------*
      *                                      * Stringa per 1 numero    *
      *                                      *-------------------------*
           if        v-num                >    1
                     go to att-ndo-fti-410.
           move      spaces               to   v-alf                  .
           string    "La numerazione e' stata aumentata di "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " numero."
                                delimited by   size
                                          into v-alf                  .
           go to     att-ndo-fti-420.
       att-ndo-fti-410.
      *                                      *-------------------------*
      *                                      * Stringa per piu' numeri *
      *                                      *-------------------------*
           move      spaces               to   v-alf                  .
           string    "La numerazione e' stata aumentata di "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " numeri."
                                delimited by   size
                                          into v-alf                  .
       att-ndo-fti-420.
      *                                      *-------------------------*
      *                                      * Visualizzazione stringa *
      *                                      *-------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      11                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                      *-------------------------*
      *                                      * Prompt per richiesta    *
      *                                      *-------------------------*
      *                                          *---------------------*
      *                                          * Preparazione pros-  *
      *                                          * simo numero         *
      *                                          *---------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-att-ndo-fti-num    to   w-att-ndo-fti-wnu      .
           move      w-att-ndo-fti-wpr    to   v-num                  .
           add       1                    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                                          *---------------------*
      *                                          * Visualizzazione     *
      *                                          *---------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      11                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           string    "Si vuole che prosegua dal numero "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " ?"
                                delimited by   size
                                          into v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Video in On                     *
      *                              *---------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
