      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-ctl-cau-doc-flg      .
      *              *-------------------------------------------------*
      *              * Test su codice causale                          *
      *              *-------------------------------------------------*
           if        w-ctl-cau-doc-cod    =    zero
                     go to ctl-cau-doc-999.
      *              *-------------------------------------------------*
      *              * Lettura archivio [zcc]                          *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCAU    "         to   f-key                  .
           move      w-ctl-cau-doc-cod    to   rf-zcc-cod-cau         .
           move      "pgm/cge/fls/ioc/obj/iofzcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zcc                 .
      *              *-------------------------------------------------*
      *              * Test su esito lettura                           *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     move  "#"            to   w-ctl-cau-doc-flg
                     go to ctl-cau-doc-999.
      *              *-------------------------------------------------*
      *              * Se causale di bilancio : uscita con flag ad er- *
      *              * rore                                            *
      *              *-------------------------------------------------*
           if        rf-zcc-snx-bil       not  = "N"
                     move  "#"            to   w-ctl-cau-doc-flg
                     go to ctl-cau-doc-999.
      *              *-------------------------------------------------*
      *              * Test su tipo movimento iva                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test per fatture o note addebito            *
      *                  *---------------------------------------------*
           if        w-ctl-cau-doc-tdo    =    03
                     go to ctl-cau-doc-100.
           if        rf-zcc-tip-moi       not  = "1" and
                     rf-zcc-tip-moi       not  = "A"
                     move  "#"            to   w-ctl-cau-doc-flg      .
           go to     ctl-cau-doc-999.
       ctl-cau-doc-100.
      *                  *---------------------------------------------*
      *                  * Test per nota di accredito                  *
      *                  *---------------------------------------------*
           if        rf-zcc-tip-moi       not  = "2" and
                     rf-zcc-tip-moi       not  = "B"
                     move  "#"            to   w-ctl-cau-doc-flg      .
           go to     ctl-cau-doc-999.
       ctl-cau-doc-999.
