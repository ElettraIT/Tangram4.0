      *    *-----------------------------------------------------------*
       att-bci-ndo-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-att-bci-ndo-flg      .
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/bol/num/ioc/obj/inbcindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bci-ndo             .
      *              *-------------------------------------------------*
      *              * Composizione chiave per lettura                 *
      *              *-------------------------------------------------*
           move      w-att-bci-ndo-dat    to   s-dat                  .
           move      s-saa                to   w-att-bci-ndo-saa      .
           move      w-att-bci-ndo-saa    to   rn-bci-ndo-scl-ann     .
           move      w-att-bci-ndo-dpz    to   rn-bci-ndo-cod-dpz     .
           move      w-att-bci-ndo-sgl    to   rn-bci-ndo-sgl-num     .
      *              *-------------------------------------------------*
      *              * Lettura numerazione                             *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/bol/num/ioc/obj/inbcindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bci-ndo             .
           if        f-sts                =    e-not-err
                     go to att-bci-ndo-100.
      *              *-------------------------------------------------*
      *              * Se numerazione non esistente la si crea norma-  *
      *              * lizzata a zero                                  *
      *              *-------------------------------------------------*
           move      zero                 to   rn-bci-ndo-num-doc     .
           move      zero                 to   rn-bci-ndo-dat-doc     .
           move      "PT"                 to   f-ope                  .
           move      "pgm/bol/num/ioc/obj/inbcindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bci-ndo             .
           move      "RL"                 to   f-ope                  .
           move      "pgm/bol/num/ioc/obj/inbcindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bci-ndo             .
           go to     att-bci-ndo-000.
       att-bci-ndo-100.
      *              *-------------------------------------------------*
      *              * Se numerazione esistente                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Bufferizzazione valori originali            *
      *                  *---------------------------------------------*
           move      rn-bci-ndo-num-doc   to   w-att-bci-ndo-nsv      .
           move      rn-bci-ndo-dat-doc   to   w-att-bci-ndo-dsv      .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda del numero documento   *
      *                  * impostato                                   *
      *                  *---------------------------------------------*
           if        w-att-bci-ndo-prg    =    zero
                     go to att-bci-ndo-200
           else      go to att-bci-ndo-300.
       att-bci-ndo-200.
      *                  *---------------------------------------------*
      *                  * Se numero documento passato a zero          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Valore record in comodo ridefinito      *
      *                      *-----------------------------------------*
           move      rn-bci-ndo-num-doc   to   w-att-bci-ndo-wnu      .
      *                      *-----------------------------------------*
      *                      * Incremento numero progressivo del comodo*
      *                      * ridefinito                              *
      *                      *-----------------------------------------*
           add       1                    to   w-att-bci-ndo-wpr      .
           if        w-att-bci-ndo-wpr    =    zero
                     move  1              to   w-att-bci-ndo-wpr      .
      *                      *-----------------------------------------*
      *                      * Forzatura secolo/anno                   *
      *                      *-----------------------------------------*
           move      w-att-bci-ndo-saa    to   w-att-bci-ndo-wsa      .
      *                      *-----------------------------------------*
      *                      * Forzatura dipendenza                    *
      *                      *-----------------------------------------*
           move      w-att-bci-ndo-dpz    to   w-att-bci-ndo-wdz      .
      *                      *-----------------------------------------*
      *                      * Movimento da comodo ridefinito a record *
      *                      *-----------------------------------------*
           move      w-att-bci-ndo-wnu    to   rn-bci-ndo-num-doc     .
      *                      *-----------------------------------------*
      *                      * Data documento                          *
      *                      *-----------------------------------------*
           move      w-att-bci-ndo-dat    to   rn-bci-ndo-dat-doc     .
      *                      *-----------------------------------------*
      *                      * Update record                           *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/bol/num/ioc/obj/inbcindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bci-ndo             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to att-bci-ndo-000.
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/bol/num/ioc/obj/inbcindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bci-ndo             .
      *                      *-----------------------------------------*
      *                      * Salvataggio nuovo valore                *
      *                      *-----------------------------------------*
           move      rn-bci-ndo-num-doc   to   w-att-bci-ndo-new      .
      *                      *-----------------------------------------*
      *                      * Valore in uscita                        *
      *                      *-----------------------------------------*
           move      rn-bci-ndo-num-doc   to   w-att-bci-ndo-num      .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     att-bci-ndo-999.
       att-bci-ndo-300.
      *                  *---------------------------------------------*
      *                  * Se numero documento passato non a zero      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se numero documento passato minore o u- *
      *                      * guale a quello letto : uscita           *
      *                      *-----------------------------------------*
           if        w-att-bci-ndo-num    >    w-att-bci-ndo-nsv
                     go to att-bci-ndo-320.
      *                          *-------------------------------------*
      *                          * Unlock                              *
      *                          *-------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/bol/num/ioc/obj/inbcindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bci-ndo             .
      *                          *-------------------------------------*
      *                          * Azzeramento nuovo numero documento  *
      *                          *-------------------------------------*
           move      zero                 to   w-att-bci-ndo-new      .
           go to     att-bci-ndo-999.
       att-bci-ndo-320.
      *                      *-----------------------------------------*
      *                      * Se numero documento passato maggiore di *
      *                      * quello letto                            *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se e' maggiore di un'unita' : come  *
      *                          * se fosse stato passato a zero       *
      *                          *-------------------------------------*
           move      w-att-bci-ndo-nsv    to   w-att-bci-ndo-wnu      .
           add       1                    to   w-att-bci-ndo-wpr      .
           if        w-att-bci-ndo-wpr    =    zero
                     move  1              to   w-att-bci-ndo-wpr      .
           if        w-att-bci-ndo-prg    =    w-att-bci-ndo-wpr
                     go to att-bci-ndo-200.
       att-bci-ndo-400.
      *                          *-------------------------------------*
      *                          * Test se numerazione controllata     *
      *                          *-------------------------------------*
           if        w-tes-tip-mpb-nmc    =    "N"
                     go to att-bci-ndo-500.
      *                          *-------------------------------------*
      *                          * Se invece e' maggiore di piu' di    *
      *                          * un'unita'                           *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Test su si/no numerazione modi- *
      *                              * ficabile letto da tipo movimen- *
      *                              * to                              *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Test                        *
      *                                  *-----------------------------*
           if        w-att-bci-ndo-nmm    not  = "N"
                     go to att-bci-ndo-405.
      *                                  *-----------------------------*
      *                                  * Flag di uscita              *
      *                                  *-----------------------------*
           move      "#"                  to   w-att-bci-ndo-flg      .
      *                                  *-----------------------------*
      *                                  * Ad uscita                   *
      *                                  *-----------------------------*
           go to     att-bci-ndo-600.
       att-bci-ndo-405.
      *                              *---------------------------------*
      *                              * Salvataggio del video attuale   *
      *                              *---------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Video in Off                    *
      *                              *---------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Box per messaggio all'operatore *
      *                              *---------------------------------*
           move      "BX"                 to   v-ope                  .
           move      09                   to   v-lin                  .
           move      18                   to   v-lto                  .
           move      09                   to   v-pos                  .
           move      72                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Messaggi entro il box           *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Titolo centrale             *
      *                                  *-----------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      11                   to   v-pos                  .
           move      "                      A T T E N Z I O N E         
      -              "          "         to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                  *-----------------------------*
      *                                  * Numeri saltati              *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Preparazione differenza *
      *                                      *-------------------------*
           move      w-att-bci-ndo-prg    to   w-att-bci-ndo-wdf      .
           subtract  w-att-bci-ndo-wpr    from w-att-bci-ndo-wdf      .
           add       1                    to   w-att-bci-ndo-wdf      .
      *                                      *-------------------------*
      *                                      * Preparazione numero     *
      *                                      *-------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-att-bci-ndo-wdf    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                                      *-------------------------*
      *                                      * Stringa per 1 numero    *
      *                                      *-------------------------*
           if        v-num                >    1
                     go to att-bci-ndo-410.
           move      spaces               to   v-alf                  .
           string    "La numerazione e' stata aumentata di "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " numero."
                                delimited by   size
                                          into v-alf                  .
           go to     att-bci-ndo-420.
       att-bci-ndo-410.
      *                                      *-------------------------*
      *                                      * Stringa per piu' numeri *
      *                                      *-------------------------*
           move      spaces               to   v-alf                  .
           string    "La numerazione e' stata aumentata di "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " numeri."
                                delimited by   size
                                          into v-alf                  .
       att-bci-ndo-420.
      *                                      *-------------------------*
      *                                      * Visualizzazione stringa *
      *                                      *-------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      11                   to   v-pos                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                                      *-------------------------*
      *                                      * Prompt per richiesta    *
      *                                      *-------------------------*
      *                                          *---------------------*
      *                                          * Preparazione pros-  *
      *                                          * simo numero         *
      *                                          *---------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<"                  to   v-edm                  .
           move      w-att-bci-ndo-prg    to   v-num                  .
           add       1                    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                                          *---------------------*
      *                                          * Visualizzazione     *
      *                                          *---------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      60                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      11                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           string    "Si vuole che prosegua dal numero "
                                delimited by   size
                     v-edt      delimited by   spaces
                     " ?"
                                delimited by   size
                                          into v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Video in On                     *
      *                              *---------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       att-bci-ndo-430.
      *                              *---------------------------------*
      *                              * Scelta dell'operatore           *
      *                              *---------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-rat-ndo-lun    to   v-car                  .
           move      w-exp-rat-ndo-num    to   v-ldt                  .
           move      "UNS#"               to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      15                   to   v-lin                  .
           move      54                   to   v-pos                  .
           move      w-exp-rat-ndo-tbl    to   v-txt                  .
           move      "EXIT"               to   v-pfk (20)             .
           move      zero                 to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-num                to   w-exp-rat-ndo-sce      .
      *                              *---------------------------------*
      *                              * Controllo risposta              *
      *                              *---------------------------------*
           if        w-exp-rat-ndo-sce    =    01 or
                     w-exp-rat-ndo-sce    =    02 or
                     w-exp-rat-ndo-sce    =    03
                     go to att-bci-ndo-440.
           if        v-key                =    "EXIT"
                     go to att-bci-ndo-440.
           go to     att-bci-ndo-430.
       att-bci-ndo-440.
      *                              *---------------------------------*
      *                              * Ripristino immagine video       *
      *                              *---------------------------------*
           move      "RS"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                              *---------------------------------*
      *                              * Esame risposta                  *
      *                              *---------------------------------*
           if        v-key                =    "EXIT"
                     move  "#"            to   w-att-bci-ndo-flg
                     go to att-bci-ndo-600.
           if        w-exp-rat-ndo-sce    =    01
                     move  "#"            to   w-att-bci-ndo-flg
                     go to att-bci-ndo-600
           else if   w-exp-rat-ndo-sce    =    03
                     go to att-bci-ndo-500
           else if   w-exp-rat-ndo-sce    =    02
                     go to att-bci-ndo-600.
       att-bci-ndo-500.
      *                              *---------------------------------*
      *                              * Se risposta positiva            *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Aggiornamento numerazione   *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Numero                  *
      *                                      *-------------------------*
           move      w-att-bci-ndo-num    to   w-att-bci-ndo-wnu      .
           move      w-att-bci-ndo-saa    to   w-att-bci-ndo-wsa      .
           move      w-att-bci-ndo-dpz    to   w-att-bci-ndo-wdz      .
           move      w-att-bci-ndo-wnu    to   rn-bci-ndo-num-doc     .
      *                                      *-------------------------*
      *                                      * Data                    *
      *                                      *-------------------------*
           move      w-att-bci-ndo-dat    to   rn-bci-ndo-dat-doc     .
      *                                  *-----------------------------*
      *                                  * Update record               *
      *                                  *-----------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/bol/num/ioc/obj/inbcindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bci-ndo             .
      *                                  *-----------------------------*
      *                                  * Se errori ripete l'intera   *
      *                                  * operazione                  *
      *                                  *-----------------------------*
           if        f-sts                not  = e-not-err
                     go to att-bci-ndo-000.
      *                                  *-----------------------------*
      *                                  * Unlock della numerazione    *
      *                                  *-----------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/bol/num/ioc/obj/inbcindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bci-ndo             .
      *                                  *-----------------------------*
      *                                  * Salvataggio nuovo valore    *
      *                                  *-----------------------------*
           move      rn-bci-ndo-num-doc   to   w-att-bci-ndo-new      .
      *                                  *-----------------------------*
      *                                  * Uscita                      *
      *                                  *-----------------------------*
           go to     att-bci-ndo-999.
       att-bci-ndo-600.
      *                              *---------------------------------*
      *                              * Se risposta negativa            *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Unlock della numerazione    *
      *                                  *-----------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/bol/num/ioc/obj/inbcindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bci-ndo             .
      *                                  *-----------------------------*
      *                                  * Nessun nuovo valore         *
      *                                  *-----------------------------*
           move      zero                 to   w-att-bci-ndo-new      .
      *                                  *-----------------------------*
      *                                  * Uscita                      *
      *                                  *-----------------------------*
           go to     att-bci-ndo-999.
       att-bci-ndo-999.
           exit.

      *    *===========================================================*
      *    * Routine di ripristino numero documento fatture Italia     *
      *    *-----------------------------------------------------------*
       rip-bci-ndo-000.
      *              *-------------------------------------------------*
      *              * Se nessun nuovo numero documento : uscita       *
      *              *-------------------------------------------------*
           if        w-att-bci-ndo-new    =    zero
                     go to rip-bci-ndo-999.
      *              *-------------------------------------------------*
      *              * Composizione chiave per lettura                 *
      *              *-------------------------------------------------*
           move      w-att-bci-ndo-dat    to   s-dat                  .
           move      s-saa                to   w-att-bci-ndo-saa      .
           move      w-att-bci-ndo-saa    to   rn-bci-ndo-scl-ann     .
           move      w-att-bci-ndo-dpz    to   rn-bci-ndo-cod-dpz     .
           move      w-att-bci-ndo-sgl    to   rn-bci-ndo-sgl-num     .
      *              *-------------------------------------------------*
      *              * Lettura numerazione                             *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/bol/num/ioc/obj/inbcindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bci-ndo             .
           if        f-sts                =    e-not-err
                     go to rip-bci-ndo-100.
      *              *-------------------------------------------------*
      *              * Se numerazione non esistente la si crea norma-  *
      *              * lizzata a zero                                  *
      *              *-------------------------------------------------*
           move      zero                 to   rn-bci-ndo-num-doc     .
           move      zero                 to   rn-bci-ndo-dat-doc     .
           move      "PT"                 to   f-ope                  .
           move      "pgm/bol/num/ioc/obj/inbcindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bci-ndo             .
           go to     rip-bci-ndo-000.
       rip-bci-ndo-100.
      *              *-------------------------------------------------*
      *              * Se numerazione esistente                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Controllo se il valore attuale della nume-  *
      *                  * razione e' tuttora inalterato rispetto al-  *
      *                  * l'aggiornamento eseguito in fase di attri-  *
      *                  * buzione del numero                          *
      *                  *---------------------------------------------*
           if        rn-bci-ndo-num-doc   =    w-att-bci-ndo-new
                     go to rip-bci-ndo-200
           else      go to rip-bci-ndo-400.
       rip-bci-ndo-200.
      *                  *---------------------------------------------*
      *                  * Se il valore risulta inalterato             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Controaggiornamento record              *
      *                      *-----------------------------------------*
           move      w-att-bci-ndo-nsv    to   rn-bci-ndo-num-doc     .
           move      w-att-bci-ndo-dsv    to   rn-bci-ndo-dat-doc     .
           move      "UP"                 to   f-ope                  .
           move      "pgm/bol/num/ioc/obj/inbcindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bci-ndo             .
      *                      *-----------------------------------------*
      *                      * Unlock                                  *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/bol/num/ioc/obj/inbcindo"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bci-ndo             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rip-bci-ndo-000.
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     rip-bci-ndo-999.
       rip-bci-ndo-400.
      *                  *---------------------------------------------*
      *                  * Se il valore risulta cambiato               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se il cambiamento corrisponde alla for- *
      *                      * zatura eseguita dall'operatore stesso   *
      *                      * in caso di impostazione di un numero    *
      *                      * superiore al progressivo : si controag- *
      *                      * giorna senza alcun messaggio            *
      *                      *-----------------------------------------*
           if        rn-bci-ndo-num-doc   =    w-att-bci-ndo-num
