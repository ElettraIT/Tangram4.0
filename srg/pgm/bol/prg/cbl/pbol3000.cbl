      *    *===========================================================*
      *    * Espansione dati piede per visualizzare il castelletto Iva *
      *    * e trattamento scadenze                                    *
      *    *                                                           *
      *    * Trattamento tasti funzione                                *
      *    *-----------------------------------------------------------*
       exe-exp-pie-ttf-000.
      *              *-------------------------------------------------*
      *              * Up   : sempre accettato                         *
      *              *-------------------------------------------------*
           move      "UP  "               to   v-pfk (01)             .
      *              *-------------------------------------------------*
      *              * Down : sempre accettato                         *
      *              *-------------------------------------------------*
           move      "DOWN"               to   v-pfk (02)             .
      *              *-------------------------------------------------*
      *              * Find : sempre accettato                         *
      *              *-------------------------------------------------*
           move      "FIND"               to   v-pfk (03)             .
      *              *-------------------------------------------------*
      *              * Insr : solo se spazio in tabella                *
      *              *-------------------------------------------------*
           if        w-pie-scd-tip
                    (1, w-acc-sng-scd-nel)
                                          not  = zero and
                     w-pie-scd-tip
                    (1, w-acc-sng-scd-max)
                                          =    zero
                     move  "INSR"         to   v-pfk (04)             .
      *              *-------------------------------------------------*
      *              * Do   : sempre accettato                         *
      *              *-------------------------------------------------*
           move      "DO  "               to   v-pfk (05)             .
      *              *-------------------------------------------------*
      *              * Remove : test                                   *
      *              *-------------------------------------------------*
           if        w-pie-scd-tip
                    (1, w-acc-sng-scd-nel)
                                          not  = zero
                     go to exe-exp-pie-ttf-200.
           move      w-acc-sng-scd-nel    to   w-acc-sng-scd-c0a      .
           add       1                    to   w-acc-sng-scd-c0a      .
           if        w-acc-sng-scd-c0a    >    w-acc-sng-scd-max
                     go to exe-exp-pie-ttf-300.
           if        w-pie-scd-tip
                    (1, w-acc-sng-scd-c0a)
                                          =    zero
                     go to exe-exp-pie-ttf-300.
       exe-exp-pie-ttf-200.
           move      "REMV"               to   v-pfk (06)             .
       exe-exp-pie-ttf-300.
      *              *-------------------------------------------------*
      *              * Previous-screen : sempre accettato              *
      *              *-------------------------------------------------*
           move      "PRSC"               to   v-pfk (07)             .
      *              *-------------------------------------------------*
      *              * Next-screen : sempre accettato                  *
      *              *-------------------------------------------------*
           move      "NXSC"               to   v-pfk (08)             .
      *              *-------------------------------------------------*
      *              * Back : test                                     *
      *              *-------------------------------------------------*
           if        w-acc-sng-scd-nel    >    1
                     move  "BACK"         to   v-pfk (09)             .
       exe-exp-pie-ttf-400.
      *              *-------------------------------------------------*
      *              * Tab  : test                                     *
      *              *-------------------------------------------------*
           if        w-acc-sng-scd-nel    =    w-acc-sng-scd-max
                     go to exe-exp-pie-ttf-500.
           move      w-acc-sng-scd-nel    to   w-acc-sng-scd-c0a      .
           add       1                    to   w-acc-sng-scd-c0a      .
           if        w-pie-scd-tip
                    (1, w-acc-sng-scd-nel)
                                          =    spaces and
                     w-pie-scd-tip
                    (1, w-acc-sng-scd-c0a)
                                          =    spaces
                     go to exe-exp-pie-ttf-500.
           move      "TAB "               to   v-pfk (10)             .
      *              *-------------------------------------------------*
      *              * Select : sempre accettato                       *
      *              *-------------------------------------------------*
           move      "SLCT"               to   v-pfk (11)             .
      *              *-------------------------------------------------*
      *              * Exit : sempre accettato                         *
      *              *-------------------------------------------------*
           move      "EXIT"               to   v-pfk (20)             .
       exe-exp-pie-ttf-500.
      *              *-------------------------------------------------*
      *              * Inibizione eventuale tasti funzione in caso di  *
      *              * scadenze non modificabili                       *
      *              *-------------------------------------------------*
           if        w-tes-snx-ims (1)    =    "S"
                     go to exe-exp-pie-ttf-900.
       exe-exp-pie-ttf-800.
      *              *-------------------------------------------------*
      *              * Inibizione                                      *
      *              *-------------------------------------------------*
           move      spaces               to   v-pfk (03)             .
           move      spaces               to   v-pfk (04)             .
           move      spaces               to   v-pfk (06)             .
       exe-exp-pie-ttf-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-exp-pie-ttf-999.
       exe-exp-pie-ttf-999.
           exit.

