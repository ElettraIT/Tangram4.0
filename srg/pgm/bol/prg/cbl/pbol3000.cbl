      *    *===========================================================*
      *    * Routine di attribuzione numero protocollo bolle Italia    *
      *    *-----------------------------------------------------------*
       att-bci-prt-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record                          *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/bol/num/ioc/obj/inbciprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bci-prt             .
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [bciprt]                                  *
      *              *-------------------------------------------------*
           move      w-att-bci-prt-dat    to   s-dat                  .
           move      s-saa                to   w-att-bci-prt-saa      .
           move      w-att-bci-prt-saa    to   rn-bci-prt-scl-ann     .
           move      w-att-bci-prt-dpz    to   rn-bci-prt-cod-dpz     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [bciprt]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/bol/num/ioc/obj/inbciprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bci-prt             .
      *              *-------------------------------------------------*
      *              * Test su esito operazione                        *
      *              *-------------------------------------------------*
           if        f-sts                =    e-not-err
                     go to att-bci-prt-100.
      *                  *---------------------------------------------*
      *                  * Record non trovato                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Composizione record normalizzato        *
      *                      *-----------------------------------------*
           move      zero                 to   rn-bci-prt-num-prt     .
      *                      *-----------------------------------------*
      *                      * Scrittura record normalizzato           *
      *                      *-----------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/bol/num/ioc/obj/inbciprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bci-prt             .
      *                      *-----------------------------------------*
      *                      * Ripetizione dell'intera operazione      *
      *                      *-----------------------------------------*
           go to     att-bci-prt-000.
       att-bci-prt-100.
      *                  *---------------------------------------------*
      *                  * Record trovato                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Numero protocollo in work di comodo     *
      *                      *-----------------------------------------*
           move      rn-bci-prt-num-prt   to   w-att-bci-prt-wnu      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento numero protocollo         *
      *                      *-----------------------------------------*
           add       1                    to   w-att-bci-prt-wpr      .
           if        w-att-bci-prt-wpr    =    zero
                     move  1              to   w-att-bci-prt-wpr      .
      *                      *-----------------------------------------*
      *                      * Forzatura secolo/anno                   *
      *                      *-----------------------------------------*
           move      w-att-bci-prt-saa    to   w-att-bci-prt-wsa      .
      *                      *-----------------------------------------*
      *                      * Forzatura dipendenza                    *
      *                      *-----------------------------------------*
           move      w-att-bci-prt-dpz    to   w-att-bci-prt-wdz      .
      *                      *-----------------------------------------*
      *                      * Bufferizzazione numero protocollo       *
      *                      *-----------------------------------------*
           move      w-att-bci-prt-wnu    to   rn-bci-prt-num-prt     .
      *                      *-----------------------------------------*
      *                      * Update record                           *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/bol/num/ioc/obj/inbciprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bci-prt             .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione    *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to att-bci-prt-000.
      *                      *-----------------------------------------*
      *                      * Unlock record                           *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/bol/num/ioc/obj/inbciprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bci-prt             .
      *                      *-----------------------------------------*
      *                      * Valore in uscita                        *
      *                      *-----------------------------------------*
           move      rn-bci-prt-num-prt   to   w-att-bci-prt-num      .
       att-bci-prt-999.
           exit.

      *    *===========================================================*
      *    * Routine di ripristino numero protocollo bolle Italia      *
      *    *-----------------------------------------------------------*
       rip-bci-prt-000.
      *              *-------------------------------------------------*
      *              * Preparazione chiave per lettura tabella numera- *
      *              * zioni [bciprt]                                  *
      *              *-------------------------------------------------*
           move      w-att-bci-prt-dat    to   s-dat                  .
           move      s-saa                to   w-att-bci-prt-saa      .
           move      w-att-bci-prt-saa    to   rn-bci-prt-scl-ann     .
           move      w-att-bci-prt-dpz    to   rn-bci-prt-cod-dpz     .
      *              *-------------------------------------------------*
      *              * Lettura tabella numerazioni [bciprt]            *
      *              *-------------------------------------------------*
           move      "GT"                 to   f-ope                  .
           move      "pgm/bol/num/ioc/obj/inbciprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bci-prt             .
      *              *-------------------------------------------------*
      *              * Se record non trovato : unlock e uscita         *
      *              *-------------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to rip-bci-prt-900.
      *              *-------------------------------------------------*
      *              * Se record trovato                               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Confronto con il numero protocollo passato; *
      *                  * se diverso unlock e uscita                  *
      *                  *---------------------------------------------*
           if        rn-bci-prt-num-prt   not  = w-att-bci-prt-num
                     go to  rip-bci-prt-900.
      *                  *---------------------------------------------*
      *                  * Se uguale si esegue il controaggiornamento  *
      *                  *---------------------------------------------*
           move      w-att-bci-prt-num    to   w-att-bci-prt-wnu      .
           subtract  1                    from w-att-bci-prt-wpr      .
           if        w-att-bci-prt-wpr    =    zero
                     move  zero           to   w-att-bci-prt-wnu      .
           move      w-att-bci-prt-wnu    to   rn-bci-prt-num-prt     .
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/bol/num/ioc/obj/inbciprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bci-prt             .
       rip-bci-prt-900.
      *              *-------------------------------------------------*
      *              * Unlock                                          *
      *              *-------------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/bol/num/ioc/obj/inbciprt"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-bci-prt             .
       rip-bci-prt-999.
           exit.

