      *    *===========================================================*
      *    * Determinazione totale documento                           *
      *    *-----------------------------------------------------------*
       det-tot-doc-000.
      *              *-------------------------------------------------*
      *              * Azzeramento totalizzatore                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-doc-tot      .
      *              *-------------------------------------------------*
      *              * Ciclo di scansione castelletto iva              *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-tot-doc-ctr      .
       det-tot-doc-100.
           add       1                    to   w-det-tot-doc-ctr      .
           if        w-det-tot-doc-ctr    >    6
                     go to det-tot-doc-999.
           if        rf-bit-iva-cod
                    (w-det-tot-doc-ctr)   =    zero
                     go to det-tot-doc-100.
      *                  *---------------------------------------------*
      *                  * Imponibile                                  *
      *                  *---------------------------------------------*
           add       rf-bit-iva-ibl
                    (w-det-tot-doc-ctr)   to   w-det-tot-doc-tot      .
      *                  *---------------------------------------------*
      *                  * Imposta                                     *
      *                  *---------------------------------------------*
           if        rf-bit-iva-cod
                    (w-det-tot-doc-ctr)   >    900
                     move  rf-bit-iva-imp
                          (w-det-tot-doc-ctr)
                                          to   w-det-tot-doc-wpa
                     go to det-tot-doc-600.
           if        rf-bit-iva-cod
                    (w-det-tot-doc-ctr)   >    100 
                     go to det-tot-doc-800.
           multiply  rf-bit-iva-cod
                    (w-det-tot-doc-ctr)   by   rf-bit-iva-ibl
                                              (w-det-tot-doc-ctr)
                                        giving w-det-tot-doc-wpa      .
           divide    100                  into w-det-tot-doc-wpa
                                        giving w-det-tot-doc-s11
                                     remainder w-det-tot-doc-wpr      .
           move      w-det-tot-doc-s11    to   w-det-tot-doc-wpa      .
           if        w-det-tot-doc-wpr    >    zero
                     add      1           to   w-det-tot-doc-wpa
           else if   w-det-tot-doc-wpr    <    zero
                     subtract 1           from w-det-tot-doc-wpa      .
       det-tot-doc-600.
           add       w-det-tot-doc-wpa    to   w-det-tot-doc-tot      .
       det-tot-doc-800.
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     det-tot-doc-100.
       det-tot-doc-999.
           exit.

