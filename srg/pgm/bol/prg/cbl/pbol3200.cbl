       pmt-est-doc-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Estremi documento  :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
