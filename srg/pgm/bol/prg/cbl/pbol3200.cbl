      *              *-------------------------------------------------*
           if        w-tes-dat-min        =    zero or
                     w-tes-dat-max        =    zero
                     go to cnt-tdo-key-200.
           if        w-tes-dat-max        not  < w-tes-dat-min
                     go to cnt-tdo-key-200.
           move      "Data documenti massima inferiore alla data emissio
      -              "ne minima      "    to   w-err-box-err-msg      .
           go to     cnt-tdo-key-900.
       cnt-tdo-key-200.
       cnt-tdo-key-500.
      *              *-------------------------------------------------*
      *              * Normalizzazioni                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Data documento massima                      *
      *                  *---------------------------------------------*
           if        w-tes-dat-max        not  = zero
                     go to cnt-tdo-key-510.
           if        w-tes-dat-min        =    zero
                     move  9999999        to   w-tes-dat-max
           else      move  w-tes-dat-min  to   w-tes-dat-max          .
       cnt-tdo-key-510.
