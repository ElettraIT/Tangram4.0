           move      36                   to   v-car                  .
           move      06                   to   v-lin                  .
           move      45                   to   v-pos                  .
           move      "|Q.etichette|Q. in bolla |  Lotto   "
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Sottolineatura fincatura rimanente              *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      36                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      45                   to   v-pos                  .
           move      "|-----------|------------|----------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-cor-reg-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione riga corpo di accettazione in w-rig       *
      *    *-----------------------------------------------------------*
       vis-rig-cor-000.
      *              *-------------------------------------------------*
      *              * Pre-visualizzazione                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione numero linea assoluta a vi-  *
      *                  * deo                                         *
      *                  *---------------------------------------------*
           move      w-cnt-cor-nrg-dac    to   w-cnt-wrk-ctr-001      .
           subtract  1                    from w-cnt-wrk-ctr-001      .
           divide    w-lin-num-lin-vis    into w-cnt-wrk-ctr-001
                                        giving w-cnt-wrk-ctr-003
                                     remainder w-cnt-wrk-ctr-002      .
           multiply  w-lin-num-lin-prc    by   w-cnt-wrk-ctr-002      .
           add       w-lin-pri-lin-vid    to   w-cnt-wrk-ctr-002      .
       vis-rig-cor-100.
      *              *-------------------------------------------------*
      *              * Quantita' etichette                             *
      *              *-------------------------------------------------*
           perform   vis-qta-eti-000      thru vis-qta-eti-999        .
      *              *-------------------------------------------------*
      *              * Quantita' di vendita                            *
      *              *-------------------------------------------------*
           perform   vis-qta-ven-000      thru vis-qta-ven-999        .
      *              *-------------------------------------------------*
      *              * Quantita' lotto di vendita                      *
      *              *-------------------------------------------------*
           perform   vis-qta-ldv-000      thru vis-qta-ldv-999        .
       vis-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riga corpo di accettazione    *
      *    *-----------------------------------------------------------*
       pmt-rig-cor-000.
       pmt-rig-cor-999.
           exit.

      *    *===========================================================*
      *    * Accettazione del primo campo riga corpo espansa : Quanti- *
      *    * ta' etichette                                             *
      *    *-----------------------------------------------------------*
       acc-qta-eti-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione numero linea assoluta a vi-  *
      *                  * deo                                         *
      *                  *---------------------------------------------*
           move      w-cnt-cor-nrg-dac    to   w-cnt-wrk-ctr-001      .
           subtract  1                    from w-cnt-wrk-ctr-001      .
           divide    w-lin-num-lin-vis    into w-cnt-wrk-ctr-001
                                        giving w-cnt-wrk-ctr-003
                                     remainder w-cnt-wrk-ctr-002      .
           multiply  w-lin-num-lin-prc    by   w-cnt-wrk-ctr-002      .
           add       w-lin-pri-lin-vid    to   w-cnt-wrk-ctr-002      .
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-rig-qta-eti        to   w-sav-qta-eti          .
       acc-qta-eti-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ripristino valore precedente                *
      *                  *---------------------------------------------*
           move      w-sav-qta-eti        to   w-rig-qta-eti          .
      *                  *---------------------------------------------*
      *                  * Parametri generici                          *
      *                  *---------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "B"                  to   v-edm                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      48                   to   v-pos                  .
      *                  *---------------------------------------------*
      *                  * Tasti funzione                              *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Up   : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "UP"                 to   v-pfk (01)             .
      *                      *-----------------------------------------*
      *                      * Down : sempre ammesso a meno che non ci *
      *                      *        siano zero righe                 *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-cor    not  = spaces
                     move  "DOWN"         to   v-pfk (02)             .
      *                      *-----------------------------------------*
      *                      * Find : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "FIND"               to   v-pfk (03)             .
      *                      *-----------------------------------------*
      *                      * Insr : non ammesso                      *
      *                      *-----------------------------------------*
           move      spaces               to   v-pfk (04)             .
      *                      *-----------------------------------------*
      *                      * Do   : sempre ammesso, purche' sia con- *
      *                      *        cesso dallo status delle impo-   *
      *                      *        stazioni; eventualmente disat-   *
      *                      *        tivato dal richiamo della sub-   *
      *                      *        routine di accettazione          *
      *                      *-----------------------------------------*
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)
           else      move  spaces         to   v-pfk (05)             .
      *                      *-----------------------------------------*
      *                      * Remv : mai ammesso                      *
      *                      *-----------------------------------------*
           move      spaces               to   v-pfk (06)             .
      *                      *-----------------------------------------*
      *                      * Prsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "PRSC"               to   v-pfk (07)             .
      *                      *-----------------------------------------*
      *                      * Nxsc : sempre ammesso                   *
      *                      *-----------------------------------------*
           move      "NXSC"               to   v-pfk (08)             .
      *                      *-----------------------------------------*
      *                      * Back : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sulla prima riga     *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    not  = 1
                     move  "BACK"         to   v-pfk (09)
           else      move  spaces         to   v-pfk (09)             .
      *                      *-----------------------------------------*
      *                      * Tab  : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'ultima riga     *
      *                      *-----------------------------------------*
           if        w-cnt-cor-nrg-dac    not  = w-rlt-sup-max
                     move  "TAB "         to   v-pfk (10)
           else      move  spaces         to   v-pfk (10)             .
      *                      *-----------------------------------------*
      *                      * Slct : sempre ammesso, a meno che non   *
      *                      *        si sia gia' sull'unica riga      *
      *                      *-----------------------------------------*
           if        w-rlt-sup-max        not  < 2
                     move  "SLCT"         to   v-pfk (11)
           else      move  spaces         to   v-pfk (11)             .
      *                      *-----------------------------------------*
      *                      * Valore di accettazione                  *
      *                      *-----------------------------------------*
           move      w-rig-qta-eti        to   v-num                  .
       acc-qta-eti-200.
      *                      *-----------------------------------------*
      *                      * Richiamo subroutine di accettazione     *
      *                      *-----------------------------------------*
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Return                                       *
      *              *-------------------------------------------------*
           if        v-key                =    spaces
                     go to acc-qta-eti-400.
       acc-qta-eti-250.
      *              *-------------------------------------------------*
      *              * Se Slct                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        v-key                not  = "SLCT"
                     go to acc-qta-eti-280.
      *                  *---------------------------------------------*
      *                  * Se quantita' a zero : default               *
      *                  *---------------------------------------------*
           if        w-rig-qta-eti        not  = zero
                     go to acc-qta-eti-260.
      *                      *-----------------------------------------*
      *                      * Default quantita' etichette             *
      *                      *-----------------------------------------*
           move      w-rig-qta-ven        to   w-rig-qta-eti          .
      *                      *-----------------------------------------*
      *                      * Eventuale suddivisione per il lotto di  *
      *                      * vendita                                 *
      *                      *-----------------------------------------*
           if        w-rig-qta-eti        =    zero
                     go to acc-qta-eti-255.
           if        w-rig-qta-ldv        =    zero
                     go to acc-qta-eti-255.
      *
           move      w-rig-qta-eti        to   w-det-qta-eti-ven      .
           divide    w-rig-qta-ldv        into w-det-qta-eti-ven
                                        giving w-det-qta-eti-eti
                                     remainder w-det-qta-eti-wq0      .
           if        w-det-qta-eti-wq0    >    zero
                     add  1               to   w-det-qta-eti-eti      .
           move      w-det-qta-eti-eti    to   w-rig-qta-eti          .
       acc-qta-eti-255.
      *                      *-----------------------------------------*
      *                      * A visualizzazione e uscita              *
      *                      *-----------------------------------------*
           go to     acc-qta-eti-270.
       acc-qta-eti-260.
      *                  *---------------------------------------------*
      *                  * Normalizzazione quantita'                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-rig-qta-eti          .
       acc-qta-eti-270.
      *                  *---------------------------------------------*
      *                  * Visualizzazione quantita'                   *
      *                  *---------------------------------------------*
           perform   vis-qta-eti-000      thru vis-qta-eti-999        .
      *                  *---------------------------------------------*
      *                  * Oltre                                       *
      *                  *---------------------------------------------*
           go to     acc-qta-eti-400.
       acc-qta-eti-280.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-qta-eti-290.
      *                  *---------------------------------------------*
      *                  * Esecuzione ricerca per codice magazzino     *
      *                  *---------------------------------------------*
           perform   exe-rca-pcm-000      thru exe-rca-pcm-999        .
      *                  *---------------------------------------------*
      *                  * Se esito negativo : a reimpostazione        *
      *                  *---------------------------------------------*
           if        w-exe-rca-pcm-nrg    =    zero
                     go to acc-qta-eti-100.
      *                  *---------------------------------------------*
      *                  * Ci si riallaccia alla funzione di Select    *
      *                  *---------------------------------------------*
           move      w-exe-rca-pcm-nrg    to   w-cnt-slc-rap-num      .
      *                  *---------------------------------------------*
      *                  * Ex Select                                   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se numero riga impostato minore di 1 o  *
      *                      * maggiore del massimo : reimpostazione   *
      *                      *-----------------------------------------*
           if        w-cnt-slc-rap-num    =    zero       or
                     w-cnt-slc-rap-num    >    w-rlt-sup-max
                     go to acc-qta-eti-100.
      *                          *-------------------------------------*
      *                          * Se numero riga impostato pari a nu- *
      *                          * numero riga attuale : reimpostazio- *
      *                          * ne                                  *
      *                          *-------------------------------------*
           if        w-cnt-slc-rap-num    =    w-cnt-cor-nrg-dac
                     go to acc-qta-eti-100.
      *                          *-------------------------------------*
      *                          * Preparazione parametri e uscita     *
      *                          *-------------------------------------*
           move      w-cnt-slc-rap-num    to   w-cnt-slc-num-rig      .
           move      "."                  to   w-cnt-tus-acc-rig      .
           go to     acc-qta-eti-999.
       acc-qta-eti-290.
       acc-qta-eti-300.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-qta-eti-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-rig
                     go to acc-qta-eti-999.
      *              *-------------------------------------------------*
      *              * Se premuto un altro tasto funzione non deve es- *
      *              * sere avvenuta variazione del campo d'impostaz.  *
      *              *-------------------------------------------------*
           if        v-mod                not  = spaces
                     go to acc-qta-eti-100.
      *              *-------------------------------------------------*
      *              * Se Up                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "UP  "
                     move  "U"            to   w-cnt-tus-acc-rig
                     go to acc-qta-eti-999.
      *              *-------------------------------------------------*
      *              * Se Down                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DOWN"
                     move  "D"            to   w-cnt-tus-acc-rig
                     go to acc-qta-eti-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-rig
                             go to acc-qta-eti-999
                     else    go to acc-qta-eti-100.
      *              *-------------------------------------------------*
      *              * Se Insr                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "INSR"
                     move  "I"            to   w-cnt-tus-acc-rig
                     go to acc-qta-eti-999.
      *              *-------------------------------------------------*
      *              * Se Tab                                          *
      *              *-------------------------------------------------*
           if        v-key                =    "TAB "
                     move  "T"            to   w-cnt-tus-acc-rig
                     go to acc-qta-eti-999.
      *              *-------------------------------------------------*
      *              * Se Back                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "BACK"
                     move  "B"            to   w-cnt-tus-acc-rig
                     go to acc-qta-eti-999.
      *              *-------------------------------------------------*
      *              * Se Nxsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "NXSC"
                     move  "N"            to   w-cnt-tus-acc-rig
                     go to acc-qta-eti-999.
      *              *-------------------------------------------------*
      *              * Se Prsc                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "PRSC"
                     move  "P"            to   w-cnt-tus-acc-rig
                     go to acc-qta-eti-999.
       acc-qta-eti-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valore in campo di destinazione             *
      *                  *---------------------------------------------*
           move      v-num                to   w-rig-qta-eti          .
       acc-qta-eti-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Visualizzazione campo                       *
      *                  *---------------------------------------------*
           perform   vis-qta-eti-000      thru vis-qta-eti-999        .
       acc-qta-eti-800.
       acc-qta-eti-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Quantita' etichette               *
      *    *-----------------------------------------------------------*
       vis-qta-eti-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "B"                  to   v-edm                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      48                   to   v-pos                  .
           move      w-rig-qta-eti        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-qta-eti-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Quantita' di vendita              *
      *    *-----------------------------------------------------------*
       vis-qta-ven-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      w-rig-dec-qta        to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GBD"                to   v-edm                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      58                   to   v-pos                  .
           move      w-rig-qta-ven        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-qta-ven-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Quantita' lotto di vendita        *
      *    *-----------------------------------------------------------*
       vis-qta-ldv-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      w-rig-dec-qta        to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "GBD"                to   v-edm                  .
           move      w-cnt-wrk-ctr-002    to   v-lin                  .
           move      71                   to   v-pos                  .
           move      w-rig-qta-ldv        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-qta-ldv-999.
           exit.

      *    *===========================================================*
      *    * Esecuzione ricerca per codice magazzino                   *
      *    *-----------------------------------------------------------*
       exe-rca-pcm-000.
      *              *-------------------------------------------------*
      *              * Salvataggio area w-rig                          *
      *              *-------------------------------------------------*
           move      w-rig                to   w-sav-wrk-rig          .
      *              *-------------------------------------------------*
      *              * Salvataggio area catena                         *
      *              *-------------------------------------------------*
           move      w-rlt-sup            to   w-sav-rlt-sup          .
      *              *-------------------------------------------------*
      *              * Inizializzazione numero riga su cui posizionar- *
      *              * si                                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-exe-rca-pcm-nrg      .
      *              *-------------------------------------------------*
      *              * Salvataggio del video attuale                   *
      *              *-------------------------------------------------*
           move      "SV"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-rca-pcm-020.
      *              *-------------------------------------------------*
      *              * Accettazione tipo e codice magazzino da ricer-  *
      *              * care                                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Video in Off                                *
      *                  *---------------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Box                                         *
      *                  *---------------------------------------------*
           move      "BX"                 to   v-ope                  .
           move      11                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      17                   to   v-lto                  .
           move      80                   to   v-pto                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Normalizzazione work-area di accettazione   *
      *                  *---------------------------------------------*
           move      zero                 to   w-exe-rca-pcm-tpm      .
           move      zero                 to   w-exe-rca-pcm-cnm      .
           move      spaces               to   w-exe-rca-pcm-cam      .
           move      spaces               to   w-exe-rca-pcm-dem      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione prompts                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Titolo centrale                         *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      27                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      27                   to   v-pos                  .
           move      "RICERCA PER CODICE PRODOTTO"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-rca-pcm-030.
      *                      *-----------------------------------------*
      *                      * Codice di magazzino                     *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      17                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      03                   to   v-pos                  .
           move      "Codice prodotto :"  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * Carattere di presa visione              *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      16                   to   v-lin                  .
           move      77                   to   v-pos                  .
           move      "[ ]"                to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Video in On                                 *
      *                  *---------------------------------------------*
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       exe-rca-pcm-100.
      *                  *---------------------------------------------*
      *                  * Normalizzazione func-key di impostazione    *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * Tipo codice di magazzino                    *
      *                  *---------------------------------------------*
           perform   acc-tip-mag-000      thru acc-tip-mag-999        .
           if        v-key                =    "EXIT"
                     go to exe-rca-pcm-900.
           if        v-key                =    "DO  "
                     go to exe-rca-pcm-400.
       exe-rca-pcm-200.
      *                  *---------------------------------------------*
      *                  * Codice alfanumerico di magazzino            *
      *                  *---------------------------------------------*
           perform   acc-cod-mag-000      thru acc-cod-mag-999        .
           if        v-key                =    "EXIT"
                     go to exe-rca-pcm-900.
           if        v-key                =    "DO  "
                     go to exe-rca-pcm-400.
           if        v-key                =    "UP  "
                     go to exe-rca-pcm-100.
       exe-rca-pcm-300.
      *                  *---------------------------------------------*
      *                  * Carattere di presa visione                  *
      *                  *---------------------------------------------*
           perform   acc-pre-vis-000      thru acc-pre-vis-999        .
           if        v-key                =    "EXIT"
                     go to exe-rca-pcm-900.
           if        v-key                =    "DO  "
                     go to exe-rca-pcm-400.
           if        v-key                =    "UP  "
                     go to exe-rca-pcm-200.
       exe-rca-pcm-400.
      *              *-------------------------------------------------*
      *              * Controllo che esistano tutti i valori necessari *
      *              * per la rcerca                                   *
      *              *-------------------------------------------------*
           if        w-exe-rca-pcm-tpm    =    zero or
                     w-exe-rca-pcm-cnm    =    zero
                     go to exe-rca-pcm-100.
      *              *-------------------------------------------------*
      *              * Ricerca effettiva in buffer righe ordine a par- *
      *              * tire dalla riga attuale                         *
      *              *-------------------------------------------------*
           move      w-cnt-cor-nrg-dac    to   w-exe-rca-pcm-ctr      .
       exe-rca-pcm-420.
           add       1                    to   w-exe-rca-pcm-ctr      .
      *              *-------------------------------------------------*
      *              * Lettura riga da file relative di supporto       *
      *              *-------------------------------------------------*
           move      "RD"                 to   w-rlt-sup-ope          .
           move      w-exe-rca-pcm-ctr    to   w-rlt-sup-ctr          .
           move      w-rlt-sup-ctr        to   w-rlt-sup-prg          .
           perform   cll-rlt-sup-000      thru cll-rlt-sup-999        .
           move      w-rlt-sup-buf        to   w-rig                  .
      *              *-------------------------------------------------*
