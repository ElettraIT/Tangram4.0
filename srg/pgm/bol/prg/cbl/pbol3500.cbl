      *                  * Eventuale barra verticale per descrizione   *
      *                  *---------------------------------------------*
           if        w-prs-rig-scr-des    =    01 or
                     w-prs-rig-scr-des    =    05
                     move  "|"            to   w-lin-imm-brv-p01
           else if   w-prs-rig-scr-des    =    02 or
                     w-prs-rig-scr-des    =    06
                     move  "|"            to   w-lin-imm-brv-p02
           else if   w-prs-rig-scr-des    =    03
                     move  "|"            to   w-lin-imm-brv-p03
           else if   w-prs-rig-scr-des    =    04
                     move  "|"            to   w-lin-imm-brv-p04      .
      *                  *---------------------------------------------*
