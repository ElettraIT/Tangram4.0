           move      zero                 to   w-let-arc-dcp-deq      .
           move      zero                 to   w-let-arc-dcp-dlb      .
           move      zero                 to   w-let-arc-dcp-plb      .
           move      zero                 to   w-let-arc-dcp-ldv      .
       let-arc-dcp-999.
           exit.

