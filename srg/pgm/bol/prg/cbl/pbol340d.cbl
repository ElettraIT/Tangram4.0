      *    *-----------------------------------------------------------*
       reg-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Data documenti massima                          *
      *              *-------------------------------------------------*
           if        rr-dat-max           not  = zero
                     go to reg-ric-sel-100.
           if        rr-dat-min           =    zero
                     move  9999999        to   rr-dat-max
           else      move  rr-dat-min     to   rr-dat-max             .
       reg-ric-sel-100.
      *              *-------------------------------------------------*
      *              * Numero documenti massimo                        *
      *              *-------------------------------------------------*
           if        rr-ndo-max           not  = zero
                     go to reg-ric-sel-200.
           if        rr-ndo-min           =    zero
                     move  999999999      to   rr-ndo-max
           else      move  rr-ndo-min     to   rr-ndo-max             .
       reg-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Regolarizzazione numero documenti interno min   *
      *              *-------------------------------------------------*
           move      rr-ndo-min           to   w-wrk-nbl-acc          .
           move      w-wrk-ndo-saa        to   w-wrk-nbi-saa          .
           if        rr-tip-mov-ift       =    03
                     move  rr-tip-mov-giv to   w-wrk-nbi-dpz
           else      move  rr-dpz-inu     to   w-wrk-nbi-dpz          .
           move      w-wrk-ndo-npg        to   w-wrk-nbi-npg          .
           move      w-wrk-nbl-int        to   rr-nbi-min             .
      *              *-------------------------------------------------*
      *              * Regolarizzazione numero documenti interno max   *
      *              *-------------------------------------------------*
           move      rr-ndo-max           to   w-wrk-nbl-acc          .
           move      w-wrk-ndo-saa        to   w-wrk-nbi-saa          .
           if        rr-tip-mov-ift       =    03
                     move  rr-tip-mov-giv to   w-wrk-nbi-dpz
           else      move  rr-dpz-inu     to   w-wrk-nbi-dpz          .
           move      w-wrk-ndo-npg        to   w-wrk-nbi-npg          .
           move      w-wrk-nbl-int        to   rr-nbi-max             .
       reg-ric-sel-400.
      *              *-------------------------------------------------*
      *              * Tipo etichette                                  *
      *              *-------------------------------------------------*
           if        rr-tip-eti           =    zero
                     move  01             to   rr-tip-eti             .
       reg-ric-sel-999.
           exit.

