           move      zero                 to   rr-tip-mov-ift         .
           move      zero                 to   rr-dat-min             .
           move      zero                 to   rr-dat-max             .
           move      zero                 to   rr-ndo-min             .
           move      zero                 to   rr-ndo-max             .
           move      zero                 to   rr-nbi-min             .
           move      zero                 to   rr-nbi-max             .
           move      zero                 to   rr-cod-dpz             .
           move      spaces               to   rr-cod-dpz-des         .
           move      zero                 to   rr-tip-eti             .
