           move      "Manca il tipo movimento !"
                                          to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-120.
      *                  *---------------------------------------------*
      *                  * Test su data documenti minima e massima     *
      *                  *---------------------------------------------*
           if        rr-dat-min           =    zero or
                     rr-dat-max           =    zero
                     go to tdo-ric-sel-130.
           if        rr-dat-min           not  > rr-dat-max
                     go to tdo-ric-sel-130.
           move      "Data documenti iniziale maggiore di quella finale 
      -              "!"                  to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-130.
      *                  *---------------------------------------------*
      *                  * Test su numero documenti minimo e massimo   *
      *                  *---------------------------------------------*
           if        rr-ndo-min           =    zero or
                     rr-ndo-max           =    zero
                     go to tdo-ric-sel-140.
           if        rr-ndo-min           not  > rr-ndo-max
                     go to tdo-ric-sel-140.
           move      "Numero documenti iniziale maggiore di quella final
      -              "e !"                to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-140.
      *                  *---------------------------------------------*
      *                  * Test su codice diendenza                    *
      *                  *---------------------------------------------*
           if        rr-cod-dpz           not  = zero
                     go to tdo-ric-sel-150.
           move      "Manca il codice dipendenza !                      
      -              " "
                                          to   w-err-box-err-msg      .
           go to     tdo-ric-sel-900.
       tdo-ric-sel-150.
       tdo-ric-sel-160.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     tdo-ric-sel-999.
       tdo-ric-sel-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
