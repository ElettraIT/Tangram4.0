           move      "CC"                 to   w-coe-cmb-vlt-ope      .
           move      rf-bit-sgl-vpf       to   w-coe-cmb-vlt-sdv      .
           move      rf-bit-tdc-vpf       to   w-coe-cmb-vlt-tdc      .
           move      "DT"                 to   s-ope                  .
