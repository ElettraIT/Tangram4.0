      *                      *-----------------------------------------*
      *                      * Aggiornamento totale documento in valu- *
      *                      * ta base                                 *
      *                      *-----------------------------------------*
           move      w-cvs-vlt-avb        to   w-tot-doc-tot          .
           go to     qry-liv-det-060.
       qry-liv-det-060.
      *              *-------------------------------------------------*
      *              * Aggiornamento totali cliente                    *
      *              *-------------------------------------------------*
           add       w-tot-doc-tot        to   w-tot-cli-tot          .
           add       w-tot-doc-tiv        to   w-tot-cli-tiv          .
           if        rf-bit-sgl-vpf       not  = w-tot-cli-vpf
                     move  spaces         to   w-tot-cli-vpf          .
      *              *-------------------------------------------------*
      *              * Aggiornamento contatore documenti stampati      *
      *              *-------------------------------------------------*
           if        w-tot-doc-ctr        <    99999
                     add  1               to   w-tot-doc-ctr          .
      *              *-------------------------------------------------*
      *              * Stampa estremi del documento                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se flag di disabilitazione interlinea atti- *
      *                  * vo, si normalizza, e si salta a stampa det- *
      *                  * taglio senza eseguire interlinea            *
      *                  *---------------------------------------------*
           if        w-qry-flg-int        not  = spaces
                     move  spaces         to   w-qry-flg-int
                     go to qry-liv-det-120.
      *                  *---------------------------------------------*
      *                  * Test se numero linee residue sufficienti    *
      *                  *---------------------------------------------*
           if        v-res                >    1
                     go to qry-liv-det-100.
      *                      *-----------------------------------------*
      *                      * Intestazione pagina                     *
      *                      *-----------------------------------------*
           perform   stp-int-pag-000      thru stp-int-pag-999        .
      *                      *-----------------------------------------*
      *                      * Se interruzione forzata : uscita        *
      *                      *-----------------------------------------*
           if        w-cnt-qry-flg-int    not  = spaces
                     go to qry-liv-det-999.
       qry-liv-det-100.
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       qry-liv-det-120.
      *                  *---------------------------------------------*
      *                  * Eventuale segnale di momentanea esclusione  *
      *                  * del documento dalla fatturazione differita  *
      *                  * automatica                                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da stampare                     *
      *                      *-----------------------------------------*
           if        rf-bit-flg-nbx (1)   =    spaces
                     go to qry-liv-det-200.
      *                      *-----------------------------------------*
      *                      * Stampa                                  *
      *                      *-----------------------------------------*
           move      "PF"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      v-lnr                to   v-lin                  .
           move      25                   to   v-pos                  .
           move      "(in sospeso)"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       qry-liv-det-200.
      *                  *---------------------------------------------*
      *                  * Dipendenza del cliente                      *
      *                  *---------------------------------------------*
           move      "PF"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      v-lnr                to   v-lin                  .
           move      38                   to   v-pos                  .
           move      rf-bit-dpz-plf       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Tipo movimento                              *
      *                  *---------------------------------------------*
           move      "PF"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      v-lnr                to   v-lin                  .
           move      43                   to   v-pos                  .
           move      rf-bit-cod-tmb       to   v-alf                  .
           move      "+"                  to   v-edm                  .
           move      rf-bit-dat-doc       to   w-mpn-dat-doc          .
           move      rf-bit-num-doc       to   w-mpn-num-doc          .
           move      rf-bit-cod-tmb       to   w-mpn-cod-tmb          .
           move      rf-bit-num-prt       to   w-mpn-num-prt          .
           move      w-mpn                to   v-cnt                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Numero documento                            *
      *                  *---------------------------------------------*
           move      "PF"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      spaces               to   v-edm                  .
           move      v-lnr                to   v-lin                  .
           move      49                   to   v-pos                  .
           move      rf-bit-num-doc       to   w-wrk-num-doc          .
           move      w-wrk-ndo-prg        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Data documento                              *
      *                  *---------------------------------------------*
           move      "PF"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      v-lnr                to   v-lin                  .
           move      56                   to   v-pos                  .
           move      rf-bit-dat-doc       to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Sigla valuta se non valuta base             *
      *                  *---------------------------------------------*
           if        rf-bit-sgl-vpf       =    c-sgl
                     go to qry-liv-det-300.
           move      "PF"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      v-lnr                to   v-lin                  .
           move      65                   to   v-pos                  .
           move      rf-bit-sgl-vpf       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       qry-liv-det-300.
      *                  *---------------------------------------------*
      *                  * Imponibile                                  *
      *                  *---------------------------------------------*
           move      "PF"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           if        w-det-tot-doc-tot    >    999999999 or
                     w-det-tot-doc-tot    <   -999999999
                     move  11             to   v-car
           else      move  09             to   v-car                  .
           move      rf-bit-dec-vpf       to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      v-lnr                to   v-lin                  .
           move      68                   to   v-pos                  .
           if        rf-bit-dec-vpf       =    zero
                     add   1              to   v-pos                  .
           move      w-det-tot-doc-tot    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       qry-liv-det-999.
           exit.

      *    *===========================================================*
      *    * Stampa valori totali                                      *
      *    *-----------------------------------------------------------*
       stp-val-tot-000.
      *              *-------------------------------------------------*
      *              * Composizione stringa                            *
      *              *-------------------------------------------------*
           move      spaces               to   w-stp-val-tot-x60      .
           move      1                    to   w-stp-val-tot-pnt      .
      *              *-------------------------------------------------*
      *              * Prompt                                          *
      *              *-------------------------------------------------*
           string    w-stp-val-tot-pmt
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
      *              *-------------------------------------------------*
      *              * Allineamento all'ultimo non-blank               *
      *              *-------------------------------------------------*
           move      zero                 to   w-stp-val-tot-ctr      .
           inspect   w-stp-val-tot-x60    
                                      tallying w-stp-val-tot-ctr
                                          for  trailing spaces        .
           subtract  w-stp-val-tot-ctr    from 60
                                        giving w-stp-val-tot-pnt      .
           add       1                    to   w-stp-val-tot-pnt      .
      *              *-------------------------------------------------*
      *              * Totale documento in valuta base se documento in *
      *              * valuta                                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da stampare                         *
      *                  *---------------------------------------------*
           if        w-stp-val-tot-vlt    =    c-sgl
                     go to stp-val-tot-100.
           if        w-stp-val-tot-tot    =    zero
                     go to stp-val-tot-100.
      *                  *---------------------------------------------*
      *                  * Editing                                     *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "G<"                 to   v-edm                  .
           move      w-stp-val-tot-tot    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * String                                      *
      *                  *---------------------------------------------*
           string    " ("
                                delimited by   size
                     c-sgl
                                delimited by   size
                     " "
                                delimited by   size
                     v-edt
                                delimited by   spaces
                     ")"
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
       stp-val-tot-100.
      *              *-------------------------------------------------*
      *              * Due punti di separazione                        *
      *              *-------------------------------------------------*
           string    " : "
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
      *              *-------------------------------------------------*
      *              * Deviazione a seconda che il documento sia in    *
      *              * valuta o no                                     *
      *              *-------------------------------------------------*
           if        w-stp-val-tot-vlt    not  = c-sgl
                     go to stp-val-tot-200
           else      go to stp-val-tot-300.
       stp-val-tot-200.
      *              *-------------------------------------------------*
      *              * Se documento in valuta                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Sigla valuta                                *
      *                  *---------------------------------------------*
           string    w-stp-val-tot-vlt
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
      *                  *---------------------------------------------*
      *                  * Totale in valuta                            *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing                                 *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           if        w-stp-val-tot-tiv    >    999999999 or
                     w-stp-val-tot-tiv    <   -999999999
                     move  11             to   v-car
           else      move  09             to   v-car                  .
           move      w-stp-val-tot-dcv    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           if        w-stp-val-tot-tiv    >    999999999 or
                     w-stp-val-tot-tiv    <   -999999999
                     move  spaces         to   v-edm
           else      move  "G"            to   v-edm                  .
           move      w-stp-val-tot-tiv    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * String                                  *
      *                      *-----------------------------------------*
           string    v-edt
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
      *                  *---------------------------------------------*
      *                  * A stampa stringa composta                   *
      *                  *---------------------------------------------*
           go to     stp-val-tot-500.
       stp-val-tot-300.
      *              *-------------------------------------------------*
      *              * Se documento in valuta base                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Totale in valuta base                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing                                 *
      *                      *-----------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           if        w-stp-val-tot-tot    >    999999999 or
                     w-stp-val-tot-tot    <   -999999999
                     move  11             to   v-car
           else      move  09             to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           if        w-stp-val-tot-tot    >    999999999 or
                     w-stp-val-tot-tot    <   -999999999
                     move  spaces         to   v-edm
           else      move  "G"            to   v-edm                  .
           move      w-stp-val-tot-tot    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                      *-----------------------------------------*
      *                      * String                                  *
      *                      *-----------------------------------------*
           string    v-edt
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
      *                  *---------------------------------------------*
      *                  * A stampa stringa composta                   *
      *                  *---------------------------------------------*
           go to     stp-val-tot-500.
       stp-val-tot-500.
      *              *-------------------------------------------------*
      *              * Riposizionamento puntatore                      *
      *              *-------------------------------------------------*
           move      zero                 to   w-stp-val-tot-ctr      .
           inspect   w-stp-val-tot-x60    
                                      tallying w-stp-val-tot-ctr
                                          for  trailing spaces        .
           subtract  w-stp-val-tot-ctr    from 60
                                        giving w-stp-val-tot-pnt      .
           add       1                    to   w-stp-val-tot-pnt      .
      *              *-------------------------------------------------*
      *              * Stampa stringa composta                         *
      *              *-------------------------------------------------*
           move      "PF"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      w-stp-val-tot-pnt    to   v-car                  .
           move      v-lnr                to   v-lin                  .
           subtract  w-stp-val-tot-pnt    from 80
                                        giving v-pos                  .
           add       2                    to   v-pos                  .
           move      w-stp-val-tot-x60    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       stp-val-tot-999.
           exit.

      *    *===========================================================*
