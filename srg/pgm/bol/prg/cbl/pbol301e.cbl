           move      rf-bit-fat-dat       to   w-rip-str-bit-fdt      .
           move      rf-bit-fat-num       to   w-rip-str-bit-fnm      .
           move      rf-bit-fat-npb       to   w-rip-str-bit-fpb      .
           move      rf-bit-tip-arc       to   w-rip-str-bit-tar      .
           move      rf-bit-arc-plf       to   w-rip-str-bit-arc      .
           move      rf-bit-num-prt       to   w-rip-str-bit-prt      .
       qry-trt-fun-320.
      *                  *---------------------------------------------*
      *                  * Modulo di Expand su righe bolla             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Preparazione valori per la chiamata     *
      *                      *-----------------------------------------*
           move      v-cnt                to   w-mpn                  .
           move      w-mpn-dat-doc        to   w-esp-rig-bir-dat      .
           move      w-mpn-num-doc        to   w-esp-rig-bir-num      .
