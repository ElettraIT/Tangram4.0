      *    *===========================================================*
      *    * Subroutines per l'accettazione causale del trasporto      *
      *    *-----------------------------------------------------------*
       cod-des-zct-opn-000.
           move      "pgm/bol/prg/obj/acdezct0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           move      s-pat                to   w-cod-des-zct-pth      .
           move      "OP"                 to   w-cod-des-zct-ope      .
           perform   cod-des-zct-cll-000  thru cod-des-zct-cll-999    .
       cod-des-zct-opn-999.
           exit.
       cod-des-zct-cls-000.
           move      "CL"                 to   w-cod-des-zct-ope      .
           perform   cod-des-zct-cll-000  thru cod-des-zct-cll-999    .
           move      "C?"                 to   w-cod-des-zct-ope      .
           perform   cod-des-zct-cll-000  thru cod-des-zct-cll-999    .
           if        w-cod-des-zct-ope    not  = spaces
                     go to cod-des-zct-cls-999.
           cancel    w-cod-des-zct-pth                                .
       cod-des-zct-cls-999.
           exit.
       cod-des-zct-foi-000.
           if        v-key                not  = "INSR"
                     go to cod-des-zct-foi-500.
           move      "P?"                 to   s-ope                  .
           move      "pbol0200"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to cod-des-zct-foi-999.
           move      "pgm/bol/prg/obj/pbol0200"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
           move      "I+"                 to   w-cod-des-zct-ope      .
           go to     cod-des-zct-foi-999.
       cod-des-zct-foi-500.
           if        v-key                not  = "FIND"
                     go to cod-des-zct-foi-999.
           move      "P?"                 to   s-ope                  .
           move      "pbol0210"           to   s-pro                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-liv                not  = zero
                     go to cod-des-zct-foi-999.
           move      "PV"                 to   s-ope                  .
           move      "fkselect"           to   s-var                  .
           move      "+"                  to   s-dop                  .
           move      "A"                  to   s-tip                  .
           move      04                   to   s-car                  .
           move      "SLCT"               to   s-alf                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      "pgm/bol/prg/obj/pbol0210"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat                                            .
           cancel    s-pat                                            .
           move      "F+"                 to   w-cod-des-zct-ope      .
           go to     cod-des-zct-foi-999.
       cod-des-zct-foi-999.
           exit.
       cod-des-zct-cll-000.
           call      w-cod-des-zct-pth   using w-cod-des-zct
                                               v
                                               s                      .
       cod-des-zct-cll-999.
           exit.

