      *    *-----------------------------------------------------------*
       acc-pes-tot-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-pes-tot-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      03                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BGD"               to   v-edm                  .
           move      11                   to   v-lin                  .
           move      60                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
      *
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
      *
           move      w-pie-pes-tot (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-pes-tot-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-pes-tot-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-pie-pes-tot (1)      .
       acc-pes-tot-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-pes-tot-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-pes-tot-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-pes-tot-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pes-tot-100.
       acc-pes-tot-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Peso totale                 *
      *    *-----------------------------------------------------------*
       vis-pes-tot-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      03                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BGD"               to   v-edm                  .
           move      11                   to   v-lin                  .
           move      60                   to   v-pos                  .
           move      w-pie-pes-tot (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-pes-tot-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Dimensioni colli                     *
      *    *-----------------------------------------------------------*
       acc-dim-col-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-snx-dim        not  = "S"
                     go to acc-dim-col-999.
       acc-dim-col-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      16                   to   v-car                  .
           move      09                   to   v-ldt                  .
           move      "X"                  to   v-edm                  .
           move      12                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
      *
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
      *
           move      w-pie-dim-col (1)    to   v-txt                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-dim-col-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-dim-col-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-txt                to   w-pie-dim-col (1)      .
       acc-dim-col-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-dim-col-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Eventuale calcolo del volume e visualizza-  *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           perform   det-col-vol-000      thru det-col-vol-999        .
       acc-dim-col-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-dim-col-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-dim-col-100.
       acc-dim-col-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Dimensioni colli                  *
      *    *-----------------------------------------------------------*
       vis-dim-col-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-prs-snx-dim        not  = "S"
                     go to vis-dim-col-999.
       pmt-dim-col-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      16                   to   v-car                  .
           move      09                   to   v-ldt                  .
           move      12                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-pie-dim-col (1)    to   v-txt                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dim-col-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Dimensioni colli                     *
      *    *                                                           *
      *    * Calcolo del volume                                        *
      *    *                                                           *
      *    * Convenzione                                               *
      *    *                                                           *
      *    * I primi 18 caratteri devono contenere le 3 dimensioni dei *
      *    * colli separate da 'x':                                    *
      *    * 999x999x999                                               *
      *    *                                                           *
      *    * Gli ultimi 2 caratteri sono facoltativi e possono rappre- *
      *    * sentare il coefficiente moltiplicatore per il calcolo     *
      *    * 999x999x999      99                                       *
      *    *-----------------------------------------------------------*
       det-col-vol-000.
      *              *-------------------------------------------------*
      *              * Test preliminare                                *
      *              *-------------------------------------------------*
           if        w-pie-dim-col (1)    =    spaces
                     move  spaces         to   w-all-str-alf
                     go to det-col-vol-850.
       det-col-vol-050.
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-vol-col-vlm      .
           move      spaces               to   w-det-vol-col-err      .
           move      w-pie-dim-col (1)    to   w-det-vol-col-ele      .
       det-col-vol-100.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione per 9 righe da 16 caratteri  *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-vol-col-vol      .
           move      zero                 to   w-det-vol-col-wol      .
           move      zero                 to   w-det-vol-col-el1      .
           move      zero                 to   w-det-vol-col-el2      .
           move      zero                 to   w-det-vol-col-el3      .
           move      zero                 to   w-det-vol-col-coe      .
           move      spaces               to   w-det-vol-col-coa      .
      *
           move      zero                 to   w-det-vol-col-ctr      .
       det-col-vol-200.
           add       1                    to   w-det-vol-col-ctr      .
           if        w-det-vol-col-ctr    >    8
                     go to det-col-vol-800.
      *              *-------------------------------------------------*
      *              * Test su contenuto riga                          *
      *              *-------------------------------------------------*
           if        det-vol-col-dim
                    (w-det-vol-col-ctr)   =    spaces
                     go to det-col-vol-800.
      *              *-------------------------------------------------*
      *              * Eventuale coefficiente                          *
      *              *-------------------------------------------------*
           move      det-vol-col-dim
                    (w-det-vol-col-ctr)
                    (15 : 02)             to   w-det-vol-col-coa      .
      *              *-------------------------------------------------*
      *              * Conversione coefficiente                        *
      *              *-------------------------------------------------*
           move      "CV"                 to   v-ope                  .
           move      02                   to   v-car                  .
           move      w-det-vol-col-coa    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-num                to   w-det-vol-col-coe      .
      *              *-------------------------------------------------*
      *              * Sostituzione eventuali 'X' con 'x'              *
      *              *-------------------------------------------------*
           inspect   det-vol-col-dim
                    (w-det-vol-col-ctr)
                                     replacing all "X" by   "x"       .
      *              *-------------------------------------------------*
      *              * Split della riga                                *
      *              *-------------------------------------------------*
           move      det-vol-col-dim
                    (w-det-vol-col-ctr)
                    (01 : 14)             to   w-all-str-alf          .
           move      "x"                  to   w-all-str-del          .
           perform   all-str-ext-000      thru all-str-ext-999        .
      *              *-------------------------------------------------*
      *              * Test che contenga 3 elementi                    *
      *              *-------------------------------------------------*
           if        w-all-str-num        not  = 3
                     move  "#"            to   w-det-vol-col-err
                     go to det-col-vol-800.
      *              *-------------------------------------------------*
      *              * Conversione elemento 1                          *
      *              *-------------------------------------------------*
           move      "CV"                 to   v-ope                  .
           move      04                   to   v-car                  .
           move      w-all-str-cat (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-num                to   w-det-vol-col-el1      .
      *              *-------------------------------------------------*
      *              * Conversione elemento 2                          *
      *              *-------------------------------------------------*
           move      "CV"                 to   v-ope                  .
           move      04                   to   v-car                  .
           move      w-all-str-cat (2)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-num                to   w-det-vol-col-el2      .
      *              *-------------------------------------------------*
      *              * Conversione elemento 3                          *
      *              *-------------------------------------------------*
           move      "CV"                 to   v-ope                  .
           move      04                   to   v-car                  .
           move      w-all-str-cat (3)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-num                to   w-det-vol-col-el3      .
      *              *-------------------------------------------------*
      *              * Test che tutti gli elementi siano diversi da    *
      *              * zero                                            *
      *              *-------------------------------------------------*
           if        w-det-vol-col-el1    =    zero or
                     w-det-vol-col-el2    =    zero or
                     w-det-vol-col-el3    =    zero
                     move  "#"            to   w-det-vol-col-err
                     go to det-col-vol-800.
      *              *-------------------------------------------------*
      *              * Calcolo del volume                              *
      *              *-------------------------------------------------*
           multiply  w-det-vol-col-el1    by   w-det-vol-col-el2
                                        giving w-det-vol-col-wol      .
           multiply  w-det-vol-col-el3    by   w-det-vol-col-wol
                                        giving w-det-vol-col-vol      .
      *
           divide    1000000              into w-det-vol-col-vol
                                               rounded                .
      *              *-------------------------------------------------*
      *              * Eventuale moltiplicatore                        *
      *              *-------------------------------------------------*
           if        w-det-vol-col-coe    >    zero
                     multiply  w-det-vol-col-coe 
                                          by   w-det-vol-col-vol      .
      *              *-------------------------------------------------*
      *              * Cumulo del volume                               *
      *              *-------------------------------------------------*
           add       w-det-vol-col-vol    to   w-det-vol-col-vlm      .
       det-col-vol-600.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     det-col-vol-200.
       det-col-vol-800.
      *              *-------------------------------------------------*
      *              * Editing valore calcolato                        *
      *              *-------------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      02                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-det-vol-col-vlm    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *              *-------------------------------------------------*
      *              * Test se errore                                  *
      *              *-------------------------------------------------*
           if        w-det-vol-col-vlm    =    zero or
                     w-det-vol-col-err    not  = spaces
                     move  "ERR!"         to   v-edt                  .
      *              *-------------------------------------------------*
      *              * Assemblaggio                                    *
      *              *-------------------------------------------------*
           move      15                   to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      "(Vol."              to   w-all-str-cat (1)      .
           move      v-edt                to   w-all-str-cat (2)      .
           move      "mc)"                to   w-all-str-cat (3)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
       det-col-vol-850.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      15                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      12                   to   v-pos                  .
           move      w-all-str-alf        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       det-col-vol-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-col-vol-999.
       det-col-vol-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Viaggia con bolle                    *
      *    *-----------------------------------------------------------*
       acc-num-vcb-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-snx-dim        not  = "S"
                     go to acc-num-vcb-999.
       acc-num-vcb-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      08                   to   v-ldt                  .
           move      "X"                  to   v-edm                  .
           move      12                   to   v-lin                  .
           move      60                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-pie-num-vcb (1)    to   v-txt                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-num-vcb-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-num-vcb-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-txt                to   w-pie-num-vcb (1)      .
       acc-num-vcb-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se contiene carattere '+'              *
      *                  *---------------------------------------------*
           move      w-pie-num-vcb (1)    to   w-all-str-alf          .
           move      "+"                  to   w-all-str-del          .
           perform   all-str-chr-000      thru all-str-chr-999        .
           if        w-all-str-num        not = 1
                     go to acc-num-vcb-600.
      *                  *---------------------------------------------*
      *                  * Subroutine di assemblaggio di 'n' numeri    *
      *                  *---------------------------------------------*
           perform   acc-num-vcb-ann-000  thru acc-num-vcb-ann-999    .
           move      w-det-edt-vcb        to   w-pie-num-vcb (1)      .
      *                  *---------------------------------------------*
      *                  * Ad accettazione                             *
      *                  *---------------------------------------------*
           go to     acc-num-vcb-100.
       acc-num-vcb-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-num-vcb-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-num-vcb-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-num-vcb-100.
       acc-num-vcb-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Viaggia con bolle                 *
      *    *-----------------------------------------------------------*
       vis-num-vcb-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-prs-snx-dim        not  = "S"
                     go to vis-num-vcb-999.
       vis-num-vcb-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      08                   to   v-ldt                  .
           move      12                   to   v-lin                  .
           move      60                   to   v-pos                  .
           move      w-pie-num-vcb (1)    to   v-txt                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-num-vcb-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo : Viaggia con bolle                    *
      *    *                                                           *
      *    * Subroutine di assemblaggio 'n' numeri fino ad un massimo  *
      *    * di 12                                                     *
      *    *-----------------------------------------------------------*
       acc-num-vcb-ann-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore di uscita                *
      *              *-------------------------------------------------*
           move      spaces               to   w-det-edt-vcb          .
      *              *-------------------------------------------------*
      *              * Estrazione del numero e dell'indice             *
      *              *-------------------------------------------------*
           move      w-pie-num-vcb (1)    to   w-all-str-alf          .
           move      "+"                  to   w-all-str-del          .
           perform   all-str-ext-000      thru all-str-ext-999        .
           if        w-all-str-num        not = 2
                     go to acc-num-vcb-ann-900.
       acc-num-vcb-ann-100.
      *              *-------------------------------------------------*
      *              * Prima stringa: numero da incrementare           *
      *              *-------------------------------------------------*
           move      w-all-str-cat (1)    to   w-det-alf-vcb          .
      *              *-------------------------------------------------*
      *              * Test se 'N'                                     *
      *              *-------------------------------------------------*
           if        w-det-alf-vcb        not  = "N" and
                     w-det-alf-vcb        not  = "n"
                     go to acc-num-vcb-ann-150.
      *
           move      w-tes-num-doc-prg    to   w-det-pri-vcb          .
           go to     acc-num-vcb-ann-200.
       acc-num-vcb-ann-150.
      *              *-------------------------------------------------*
      *              * Conversione numero di partenza                  *
      *              *-------------------------------------------------*
           move      "CV"                 to   v-ope                  .
           move      06                   to   v-car                  .
           move      w-det-alf-vcb        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-num                to   w-det-pri-vcb          .
       acc-num-vcb-ann-200.
      *              *-------------------------------------------------*
      *              * Seconda stringa: indice di incremento           *
      *              *-------------------------------------------------*
           move      w-all-str-cat (2)    to   w-det-alf-inx          .
      *              *-------------------------------------------------*
      *              * Conversione indice di incremento                *
      *              *-------------------------------------------------*
           move      "CV"                 to   v-ope                  .
           move      02                   to   v-car                  .
           move      w-det-alf-inx        to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      v-num                to   w-det-vcb-inx          .
       acc-num-vcb-ann-300.
      *              *-------------------------------------------------*
      *              * Test su valori determinati                      *
      *              *-------------------------------------------------*
           if        w-det-pri-vcb        =    zero
                     go to acc-num-vcb-ann-900.
           if        w-det-vcb-inx        =    zero
                     go to acc-num-vcb-ann-900.
           if        w-det-vcb-inx        >    12
                     go to acc-num-vcb-ann-900.
       acc-num-vcb-ann-400.
      *              *-------------------------------------------------*
      *              * Ciclo di incremento                             *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-vcb-ctr          .
       acc-num-vcb-ann-420.
           add       1                    to   w-det-vcb-ctr          .
           if        w-det-vcb-ctr        >    w-det-vcb-inx or
                     w-det-vcb-ctr        >    12
                     go to acc-num-vcb-ann-600.
           add       w-det-vcb-ctr        to   w-det-pri-vcb
                                        giving w-det-num-vcb-num
                                              (w-det-vcb-ctr)         .
           go to     acc-num-vcb-ann-420.
       acc-num-vcb-ann-600.
      *              *-------------------------------------------------*
      *              * Ciclo di assemblaggio finale                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Ciclo                                       *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-vcb-ctr          .
       acc-num-vcb-ann-620.
           add       1                    to   w-det-vcb-ctr          .
           if        w-det-vcb-ctr        >    w-det-vcb-inx or
                     w-det-vcb-ctr        >    12
                     go to acc-num-vcb-ann-900.
      *                  *---------------------------------------------*
      *                  * Editing del numero in corso di trattamento  *
      *                  *---------------------------------------------*
           move      "ED"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      w-det-num-vcb-num
                    (w-det-vcb-ctr)       to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      v-edt                to   w-all-str-cat (3)      .
      *
           move      160                  to   w-all-str-lun          .
           move      03                   to   w-all-str-num          .
           move      w-det-edt-vcb        to   w-all-str-cat (1)      .
      *
           if        w-det-vcb-ctr        =    1
                     move  spaces         to   w-all-str-cat (2)
           else      move  ","            to   w-all-str-cat (2)      .
      *
           perform   all-str-cat-000      thru all-str-cat-999        .
           move      w-all-str-alf        to   w-det-edt-vcb          .
      *
           go to     acc-num-vcb-ann-620.
       acc-num-vcb-ann-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     acc-num-vcb-ann-999.
       acc-num-vcb-ann-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Confezioni calcolate        *
      *    *-----------------------------------------------------------*
       vis-num-ccl-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-prs-snx-cfp        not  = "S"
                     go to vis-num-ccl-999.
       pmt-num-ccl-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      13                   to   v-lin                  .
           move      67                   to   v-pos                  .
           move      w-pie-num-ccl (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-num-ccl-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Peso totale calcolato       *
      *    *-----------------------------------------------------------*
       vis-pes-tcl-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-prs-snx-cfp        not  = "S"
                     go to vis-pes-tcl-999.
       vis-pes-tcl-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      03                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BGD"               to   v-edm                  .
           move      12                   to   v-lin                  .
           move      67                   to   v-pos                  .
           move      w-pie-pes-tcl (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-pes-tcl-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo piede : Data inizio trasporto          *
      *    *-----------------------------------------------------------*
       acc-dat-itr-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-dat-itr-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      ">"                  to   v-edm                  .
           move      14                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-pie-dat-itr (1)    to   v-dat                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-dat-itr-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-dat-itr-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-dat                to   w-pie-dat-itr (1)      .
       acc-dat-itr-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-dat-itr-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Trattamento ora inizio trasporto            *
      *                  *---------------------------------------------*
           if        w-pie-dat-itr (1)    not  = zero
                     go to acc-dat-itr-800.
           if        w-pie-ora-itr (1)    =    zero
                     go to acc-dat-itr-800.
           move      zero                 to   w-pie-ora-itr (1)      .
           perform   vis-ora-itr-000      thru vis-ora-itr-999        .
       acc-dat-itr-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-dat-itr-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-dat-itr-100.
       acc-dat-itr-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Data inizio trasporto       *
      *    *-----------------------------------------------------------*
       vis-dat-itr-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      14                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-pie-dat-itr (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dat-itr-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo piede : Ora inizio trasporto           *
      *    *-----------------------------------------------------------*
       acc-ora-itr-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-sna-dxb-hit    not  = "S"
                     go to acc-ora-itr-999.
       acc-ora-itr-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "MB"                 to   v-edm                  .
           move      "XX:XX"              to   v-msk                  .
           move      15                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-pie-ora-itr (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-ora-itr-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-ora-itr-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-pie-ora-itr (1)      .
       acc-ora-itr-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Controllo che :                             *
      *                  *  - l'ora sia compresa tra      00 e 23      *
      *                  *  - i minuti siano compresi tra 00 e 59      *
      *                  *---------------------------------------------*
           if        w-pie-ora-itr (1)    >    2359
                     go to acc-ora-itr-100.
           multiply  100                  by   w-pie-ora-itr (1)      .
           if        w-pie-ora-itr (1)    >    5900
                     move  v-num          to   w-pie-ora-itr (1)
                     go to acc-ora-itr-100
           else      move  v-num          to   w-pie-ora-itr (1)      .
       acc-ora-itr-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-ora-itr-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-ora-itr-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-ora-itr-100.
       acc-ora-itr-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Ora inizio trasporto        *
      *    *-----------------------------------------------------------*
       vis-ora-itr-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-prs-sna-dxb-hit    not  = "S"
                     go to vis-ora-itr-999.
       vis-ora-itr-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      04                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "MB"                 to   v-edm                  .
           move      "XX:XX"              to   v-msk                  .
           move      15                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-pie-ora-itr (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-ora-itr-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo piede : Codice primo vettore           *
      *    *-----------------------------------------------------------*
       acc-cod-vet-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-pie-tra-cur (1)    not  = 10 and
                     w-pie-tra-cur (1)    not  = 30
                     go to acc-cod-vet-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-pie-cod-vet (1)    to   w-sav-cod-vet          .
       acc-cod-vet-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-vet-ope      .
           move      w-pie-cod-vet (1)    to   w-cod-mne-vet-cod      .
           move      17                   to   w-cod-mne-vet-lin      .
           move      30                   to   w-cod-mne-vet-pos      .
           move      17                   to   w-cod-mne-vet-rln      .
           move      41                   to   w-cod-mne-vet-rps      .
           move      zero                 to   w-cod-mne-vet-vln      .
           move      zero                 to   w-cod-mne-vet-vps      .
           move      zero                 to   w-cod-mne-vet-lln      .
           move      zero                 to   w-cod-mne-vet-lps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-vet-cll-000  thru cod-mne-vet-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-vet-foi-000  thru cod-mne-vet-foi-999    .
       acc-cod-vet-110.
           perform   cod-mne-vet-cll-000  thru cod-mne-vet-cll-999    .
           if        w-cod-mne-vet-ope    =    "F+"
                     go to acc-cod-vet-115.
           if        w-cod-mne-vet-ope    =    "AC"
                     go to acc-cod-vet-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-vet-115.
           perform   cod-mne-vet-foi-000  thru cod-mne-vet-foi-999    .
           go to     acc-cod-vet-110.
       acc-cod-vet-120.
           move      w-cod-mne-vet-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-cod-vet-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-cod-vet-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-pie-cod-vet (1)      .
       acc-cod-vet-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [vet]                      *
      *                  *---------------------------------------------*
           move      w-pie-cod-vet (1)    to   w-let-arc-vet-cod      .
           perform   let-arc-vet-000      thru let-arc-vet-999        .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione descrizione                 *
      *                  *---------------------------------------------*
           move      w-let-arc-vet-rag    to   w-pie-cod-vet-des (1)  .
           perform   vis-cod-vet-des-000  thru vis-cod-vet-des-999    .
      *                  *---------------------------------------------*
      *                  * Bufferizzazioni per il vettore              *
      *                  *---------------------------------------------*
           move      w-let-arc-vet-tip    to   w-pie-cod-vet-tip (1)  .
           move      w-let-arc-vet-scp    to   w-pie-cod-vet-scp (1)  .
      *                  *---------------------------------------------*
      *                  * Se lettura errata                           *
      *                  *---------------------------------------------*
           if        w-let-arc-vet-flg    =    spaces
                     go to acc-cod-vet-420.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "Codice vettore non esistente !                    
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-vet-100.
       acc-cod-vet-420.
      *                  *---------------------------------------------*
      *                  * Controllo compatibilita' tipo di vettore se *
      *                  * trasporto a cura del Mittente               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da effettuare                   *
      *                      *-----------------------------------------*
           if        w-pie-tra-cur (1)    not  = 10
                     go to acc-cod-vet-440.
           if        w-pie-cod-vet (1)    =    zero
                     go to acc-cod-vet-440.
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-pie-cod-vet-tip (1)
                                          =    "I" or
                     w-pie-cod-vet-tip (1)
                                          =    "V"
                     go to acc-cod-vet-440.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "Il vettore selezionato e' un corriere !           
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-vet-100.
       acc-cod-vet-440.
      *                  *---------------------------------------------*
      *                  * Controllo compatibilita' tipo di vettore se *
      *                  * trasporto a cura del Vettore                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test se da effettuare                   *
      *                      *-----------------------------------------*
           if        w-pie-tra-cur (1)    not  = 30
                     go to acc-cod-vet-600.
           if        w-pie-cod-vet (1)    =    zero
                     go to acc-cod-vet-600.
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-pie-cod-vet-tip (1)
                                          =    "C"
                     go to acc-cod-vet-600.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "Il vettore selezionato e' un trasportatore interno
      -              " !             "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-vet-100.
       acc-cod-vet-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-pie-cod-vet (1)    =    w-sav-cod-vet
                     go to acc-cod-vet-800.
       acc-cod-vet-620.
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
           if        w-pie-cod-vet (1)    not  = zero
                     go to acc-cod-vet-800.
      *                      *-----------------------------------------*
      *                      * Trattamento secondo vettore             *
      *                      *-----------------------------------------*
           if        w-pie-cod-vt2 (1)    =    zero
                     go to acc-cod-vet-630.
           move      zero                 to   w-pie-cod-vt2 (1)      .
           move      spaces               to   w-pie-cod-vt2-des (1)  .
           perform   vis-cod-vt2-000      thru vis-cod-vt2-999        .
           perform   vis-cod-vt2-des-000  thru vis-cod-vt2-des-999    .
       acc-cod-vet-630.
      *                      *-----------------------------------------*
      *                      * Trattamento terzo vettore               *
      *                      *-----------------------------------------*
           if        w-pie-cod-vt3 (1)    =    zero
                     go to acc-cod-vet-800.
           move      zero                 to   w-pie-cod-vt3 (1)      .
           move      spaces               to   w-pie-cod-vt3-des (1)  .
           perform   vis-cod-vt3-000      thru vis-cod-vt3-999        .
           perform   vis-cod-vt3-des-000  thru vis-cod-vt3-des-999    .
       acc-cod-vet-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-cod-vet-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-vet-100.
       acc-cod-vet-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Codice primo vettore        *
      *    *-----------------------------------------------------------*
       vis-cod-vet-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      17                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-pie-cod-vet (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-vet-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Descrizione primo vettore   *
      *    *-----------------------------------------------------------*
       vis-cod-vet-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      17                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-pie-cod-vet-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-vet-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo piede : Codice secondo vettore         *
      *    *-----------------------------------------------------------*
       acc-cod-vt2-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se vettore di tipo 'interno' e perso-  *
      *                  * nalizzazione gestione veicoli attiva        *
      *                  *---------------------------------------------*
           if       (w-pie-cod-vet-tip (1)
                                          =    "I" or
                     w-pie-cod-vet-tip (1)
                                          =    "V") and
                     w-prs-snx-gva        =    "S"
                     perform  acc-cod-vei-000
                                          thru acc-cod-vei-999
                     go to acc-cod-vt2-999.
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-pie-tra-cur (1)    not  = 30
                     go to acc-cod-vt2-999.
           if        w-pie-cod-vet (1)    =    zero
                     go to acc-cod-vt2-999.
       acc-cod-vt2-050.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-pie-cod-vt2 (1)    to   w-sav-cod-vet          .
       acc-cod-vt2-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-vet-ope      .
           move      w-pie-cod-vt2 (1)    to   w-cod-mne-vet-cod      .
           move      18                   to   w-cod-mne-vet-lin      .
           move      30                   to   w-cod-mne-vet-pos      .
           move      18                   to   w-cod-mne-vet-rln      .
           move      41                   to   w-cod-mne-vet-rps      .
           move      zero                 to   w-cod-mne-vet-vln      .
           move      zero                 to   w-cod-mne-vet-vps      .
           move      zero                 to   w-cod-mne-vet-lln      .
           move      zero                 to   w-cod-mne-vet-lps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-vet-cll-000  thru cod-mne-vet-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-vet-foi-000  thru cod-mne-vet-foi-999    .
       acc-cod-vt2-110.
           perform   cod-mne-vet-cll-000  thru cod-mne-vet-cll-999    .
           if        w-cod-mne-vet-ope    =    "F+"
                     go to acc-cod-vt2-115.
           if        w-cod-mne-vet-ope    =    "AC"
                     go to acc-cod-vt2-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-vt2-115.
           perform   cod-mne-vet-foi-000  thru cod-mne-vet-foi-999    .
           go to     acc-cod-vt2-110.
       acc-cod-vt2-120.
           move      w-cod-mne-vet-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-cod-vt2-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-cod-vt2-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-pie-cod-vt2 (1)      .
       acc-cod-vt2-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [vet]                      *
      *                  *---------------------------------------------*
           move      w-pie-cod-vt2 (1)    to   w-let-arc-vet-cod      .
           perform   let-arc-vet-000      thru let-arc-vet-999        .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione descrizione                 *
      *                  *---------------------------------------------*
           move      w-let-arc-vet-rag    to   w-pie-cod-vt2-des (1)  .
           perform   vis-cod-vt2-des-000  thru vis-cod-vt2-des-999    .
      *                  *---------------------------------------------*
      *                  * Se lettura errata                           *
      *                  *---------------------------------------------*
           if        w-let-arc-vet-flg    =    spaces
                     go to acc-cod-vt2-420.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "Codice vettore non esistente !                    
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-vt2-100.
       acc-cod-vt2-420.
      *                  *---------------------------------------------*
      *                  * Controllo compatibilita' tipo di vettore    *
      *                  *---------------------------------------------*
           if        w-pie-cod-vet-tip (1)
                                          =    "C"
                     go to acc-cod-vt2-600.
           if        w-pie-cod-vt2 (1)    =    zero
                     go to acc-cod-vt2-600.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "Il vettore selezionato e' un trasportatore interno
      -              " !             "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-vt2-100.
       acc-cod-vt2-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-pie-cod-vt2 (1)    =    w-sav-cod-vet
                     go to acc-cod-vt2-800.
       acc-cod-vt2-620.
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
           if        w-pie-cod-vt2 (1)    not  = zero
                     go to acc-cod-vt2-800.
      *                      *-----------------------------------------*
      *                      * Trattamento terzo vettore               *
      *                      *-----------------------------------------*
           if        w-pie-cod-vt3 (1)    =    zero
                     go to acc-cod-vt2-800.
           move      zero                 to   w-pie-cod-vt3 (1)      .
           move      spaces               to   w-pie-cod-vt3-des (1)  .
           perform   vis-cod-vt3-000      thru vis-cod-vt3-999        .
           perform   vis-cod-vt3-des-000  thru vis-cod-vt3-des-999    .
       acc-cod-vt2-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-cod-vt2-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-vt2-100.
       acc-cod-vt2-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Codice secondo vettore      *
      *    *-----------------------------------------------------------*
       vis-cod-vt2-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
