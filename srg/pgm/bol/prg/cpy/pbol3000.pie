       pmt-pie-reg-200.
      *                  *---------------------------------------------*
      *                  * Intestazione pagina totali                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Fincatura                               *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "          Voce                   Importo     %    
      -              "|            Totali"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Se in gestione consegne                 *
      *                      *-----------------------------------------*
           if        w-ipc-sub-pgm-ind    not  = "CM"
                     go to  pmt-pie-reg-205.
      *
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      04                   to   v-lin                  .
           move      64                   to   v-pos                  .
           move      " Note "             to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-pie-reg-205.
      *                      *-----------------------------------------*
      *                      * Sottolineatura fincatura                *
      *                      *-----------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      80                   to   v-car                  .
           move      05                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "------------------------- ---------------- -----  
      -              "| ----------------------------"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                      *-----------------------------------------*
      *                      * Trattini verticali                      *
      *                      *-----------------------------------------*
           move      5                    to   I                      .
       pmt-pie-reg-210.
           add       1                    to   I                      .
           if        I                    >    21
                     go to pmt-pie-reg-220.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      I                    to   v-lin                  .
           move      51                   to   v-pos                  .
           move      "|"                  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           go to     pmt-pie-reg-210.
       pmt-pie-reg-220.
      *                  *---------------------------------------------*
