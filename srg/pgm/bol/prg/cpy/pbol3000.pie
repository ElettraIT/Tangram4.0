      *    *===========================================================*
      *    * Accettazione campo : Codice veicolo                       *
      *    *-----------------------------------------------------------*
       acc-cod-vei-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-cod-vei-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-gva-ope      .
           move      w-pie-cod-vt2 (1)    to   w-cod-mne-gva-cod      .
           move      18                   to   w-cod-mne-gva-lin      .
           move      30                   to   w-cod-mne-gva-pos      .
           move      18                   to   w-cod-mne-gva-dln      .
           move      41                   to   w-cod-mne-gva-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-gva-cll-000  thru cod-mne-gva-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-gva-foi-000  thru cod-mne-gva-foi-999    .
       acc-cod-vei-110.
           perform   cod-mne-gva-cll-000  thru cod-mne-gva-cll-999    .
           if        w-cod-mne-gva-ope    =    "F+"
                     go to acc-cod-vei-115.
           if        w-cod-mne-gva-ope    =    "AC"
                     go to acc-cod-vei-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-vei-115.
           perform   cod-mne-gva-foi-000  thru cod-mne-gva-foi-999    .
           go to     acc-cod-vei-110.
       acc-cod-vei-120.
           move      w-cod-mne-gva-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-cod-vei-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-cod-vei-999.
       acc-cod-vei-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-pie-cod-vt2 (1)      .
       acc-cod-vei-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura archivio [gva]                      *
      *                  *---------------------------------------------*
           move      w-pie-cod-vt2 (1)    to   w-let-arc-gva-cod      .
           perform   let-arc-gva-000      thru let-arc-gva-999        .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione descrizione                 *
      *                  *---------------------------------------------*
           move      w-let-arc-gva-des    to   w-pie-cod-vt2-des (1)  .
           perform   vis-cod-vei-des-000  thru vis-cod-vei-des-999    .
      *                  *---------------------------------------------*
      *                  * Se lettura errata                           *
      *                  *---------------------------------------------*
           if        w-let-arc-vet-flg    =    spaces
                     go to acc-cod-vei-420.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "Codice veicolo non esistente !                    
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-vei-100.
       acc-cod-vei-420.
       acc-cod-vei-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-vei-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-cod-vei-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-vei-100.
       acc-cod-vei-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Codice veicolo                    *
      *    *-----------------------------------------------------------*
       vis-cod-vei-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      18                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "<B"                 to   v-edm                  .
           move      w-pie-cod-vt2 (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-vei-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Descrizione veicolo               *
      *    *-----------------------------------------------------------*
       vis-cod-vei-des-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      41                   to   v-pos                  .
           move      w-pie-cod-vt2-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-vei-des-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo piede : Codice annotazioni             *
      *    *-----------------------------------------------------------*
       acc-cod-ant-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-pie-cod-ant (1)    to   w-sav-cod-ant          .
       acc-cod-ant-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-zba-ope      .
           move      w-pie-cod-ant (1)    to   w-cod-mne-zba-cod      .
           move      21                   to   w-cod-mne-zba-lin      .
           move      30                   to   w-cod-mne-zba-pos      .
           move      21                   to   w-cod-mne-zba-dln      .
           move      37                   to   w-cod-mne-zba-dps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-mne-zba-cll-000  thru cod-mne-zba-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-zba-foi-000  thru cod-mne-zba-foi-999    .
       acc-cod-ant-110.
           perform   cod-mne-zba-cll-000  thru cod-mne-zba-cll-999    .
           if        w-cod-mne-zba-ope    =    "F+"
                     go to acc-cod-ant-115.
           if        w-cod-mne-zba-ope    =    "AC"
                     go to acc-cod-ant-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-ant-115.
           perform   cod-mne-zba-foi-000  thru cod-mne-zba-foi-999    .
           go to     acc-cod-ant-110.
       acc-cod-ant-120.
           move      w-cod-mne-zba-cod    to   v-num                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-cod-ant-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-cod-ant-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-pie-cod-ant (1)      .
       acc-cod-ant-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella [zba]                       *
      *                  *---------------------------------------------*
           move      w-pie-cod-ant (1)    to   w-let-arc-zba-cod      .
           perform   let-arc-zba-000      thru let-arc-zba-999        .
      *                  *---------------------------------------------*
      *                  * Se valore non ammesso                       *
      *                  *---------------------------------------------*
           if        w-let-arc-zba-flg    =    spaces
                     go to acc-cod-ant-500.
      *                      *-----------------------------------------*
      *                      * Messaggio                               *
      *                      *-----------------------------------------*
           move      "Codice annotazione non esistente !                
      -              "               "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * A reimpostazione                        *
      *                      *-----------------------------------------*
           go to     acc-cod-ant-100.
       acc-cod-ant-500.
      *                  *---------------------------------------------*
      *                  * Se valore a zero                            *
      *                  *---------------------------------------------*
           if        w-pie-cod-ant (1)    not  = zero
                     go to acc-cod-ant-550.
      *                      *-----------------------------------------*
      *                      * Se valore precedente a zero : oltre     *
      *                      *-----------------------------------------*
           if        w-sav-cod-ant        =    zero
                     go to acc-cod-ant-600.
      *                      *-----------------------------------------*
      *                      * Altrimenti : normalizzazione e rivisua- *
      *                      * lizzazione                              *
      *                      *-----------------------------------------*
           move      spaces               to   w-pie-des-ant (1)      .
           perform   vis-des-ant-000      thru vis-des-ant-999        .
           go to     acc-cod-ant-600.
       acc-cod-ant-550.
      *                  *---------------------------------------------*
      *                  * Se valore non a zero                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Bufferizzazione valore letto            *
      *                      *-----------------------------------------*
           move      w-let-arc-zba-des    to   w-pie-des-ant (1)      .
      *                      *-----------------------------------------*
      *                      * Visualizzazione descrizione annotazioni *
      *                      *-----------------------------------------*
           perform   vis-des-ant-000      thru vis-des-ant-999        .
       acc-cod-ant-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-ant-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-cod-ant-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-ant-100.
       acc-cod-ant-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Codice annotazioni          *
      *    *-----------------------------------------------------------*
       vis-cod-ant-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      21                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-pie-cod-ant (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-ant-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo piede : Descrizione annotazioni        *
      *    *-----------------------------------------------------------*
       acc-des-ant-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-pie-des-ant (1)    to   w-sav-des-ant          .
       acc-des-ant-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      03                   to   v-ldt                  .
           move      21                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-pie-des-ant (1)    to   v-txt                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-des-ant-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-des-ant-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-txt                to   w-pie-des-ant (1)      .
       acc-des-ant-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-des-ant-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale come precedente : oltre   *
      *                  *---------------------------------------------*
           if        w-pie-des-ant (1)    =    w-sav-des-ant
                     go to acc-des-ant-800.
      *                  *---------------------------------------------*
      *                  * Trattamento codice annotazioni              *
      *                  *---------------------------------------------*
           if        w-pie-cod-ant (1)    =    zero
                     go to acc-des-ant-800.
           move      zero                 to   w-pie-cod-ant (1)      .
           perform   vis-cod-ant-000      thru vis-cod-ant-999        .
       acc-des-ant-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-des-ant-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-des-ant-100.
       acc-des-ant-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Descrizione annotazioni     *
      *    *-----------------------------------------------------------*
       vis-des-ant-000.
           move      "DS"                 to   v-ope                  .
           move      "T"                  to   v-tip                  .
           move      40                   to   v-car                  .
           move      03                   to   v-ldt                  .
           move      21                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-pie-des-ant (1)    to   v-txt                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-ant-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo piede : Totale sconto incondizionato   *
      *    *-----------------------------------------------------------*
       acc-tot-scc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "CM"
                     go to acc-tot-scc-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-pie-tot-scc (1)    to   w-sav-tot-scc          .
       acc-tot-scc-100.
      *              *-------------------------------------------------*
      *              * Test su tipo di documento : fattura acc.        *
      *              *-------------------------------------------------*
           if        w-tes-tip-mpb-mif    not  = 03
                     go to acc-tot-scc-120.
      *              *-------------------------------------------------*
      *              * Note operative                                  *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           move      "Tasto Selezione per esaminare le scadenze"
                                          to   v-not                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-tot-scc-120.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      07                   to   v-lin                  .
           move      28                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "SLCT"               to   v-pfk (11)             .
      *
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
      *
           move      w-pie-tot-scc (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Cancellazione note operative                    *
      *              *-------------------------------------------------*
           move      "NT"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-tot-scc-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-tot-scc-999.
       acc-tot-scc-200.
      *              *-------------------------------------------------*
      *              * Se Select                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           if        v-key                not  = "SLCT"
                     go to acc-tot-scc-300.
      *                  *---------------------------------------------*
      *                  * Test su tipo di documento : fattura acc.    *
      *                  *---------------------------------------------*
           if        w-tes-tip-mpb-mif    not  = 03
                     go to acc-tot-scc-100.
      *                  *---------------------------------------------*
      *                  * Espansione dati piede                       *
      *                  *---------------------------------------------*
           perform   exe-exp-pie-000      thru exe-exp-pie-999        .
      *                  *---------------------------------------------*
      *                  * A reimpostazione                            *
      *                  *---------------------------------------------*
           go to     acc-tot-scc-100.
       acc-tot-scc-300.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-pie-tot-scc (1)      .
       acc-tot-scc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-tot-scc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal precedente    *
      *                  *---------------------------------------------*
           if        w-pie-tot-scc (1)    =    w-sav-tot-scc
                     go to acc-tot-scc-800.
      *                      *-----------------------------------------*
      *                      * Trattamento % sconto in chiusura        *
      *                      *-----------------------------------------*
           if        w-pie-per-scc (1)    not  = zero
                     move  zero           to   w-pie-per-scc (1)      .
      *                      *-----------------------------------------*
      *                      * Determinazione totali riepilogo docum.  *
      *                      *-----------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione intero piede          *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           perform   vis-pie-reg-000      thru vis-pie-reg-999        .
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-tot-scc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-tot-scc-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-tot-scc-100.
       acc-tot-scc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo : Totale sconto incondizionato      *
      *    *-----------------------------------------------------------*
       vis-tot-scc-000.
      *              *-------------------------------------------------*
      *              * Test se campo da visualizzare                   *
      *              *-------------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "CM"
                     go to vis-tot-scc-999.
       vis-tot-scc-100.
      *              *-------------------------------------------------*
      *              * Visualizzazione                                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      07                   to   v-lin                  .
           move      28                   to   v-pos                  .
           move      w-pie-tot-scc (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tot-scc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo piede : % sconto incondizionato        *
      *    *-----------------------------------------------------------*
       acc-per-scc-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "CM"
                     go to acc-per-scc-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-pie-per-scc (1)    to   w-sav-per-scc          .
       acc-per-scc-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      07                   to   v-lin                  .
           move      45                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-pie-per-scc (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-per-scc-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-per-scc-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-pie-per-scc (1)      .
       acc-per-scc-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-per-scc-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal precedente    *
      *                  *---------------------------------------------*
           if        w-pie-per-scc (1)    =    w-sav-per-scc
                     go to acc-per-scc-800.
      *                      *-----------------------------------------*
      *                      * Determinazione totali riepilogo docum.  *
      *                      *-----------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione intero piede          *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           perform   vis-pie-reg-000      thru vis-pie-reg-999        .
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-per-scc-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-per-scc-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-per-scc-100.
       acc-per-scc-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : % sconto incondizionato     *
      *    *-----------------------------------------------------------*
       vis-per-scc-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      07                   to   v-lin                  .
           move      45                   to   v-pos                  .
           move      w-pie-per-scc (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-per-scc-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo piede : Totale sconto pagamento        *
      *    *-----------------------------------------------------------*
       acc-tot-scp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "CM"
                     go to acc-tot-scp-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-pie-tot-scp (1)    to   w-sav-tot-scp          .
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *                                             *
      *                  * Se esiste lo sconto associato alla forma di *
      *                  * pagamento il campo non e' accettabile in    *
      *                  * quanto la % viene forzata dalla forma di    *
      *                  * pagamento stessa                            *
      *                  *---------------------------------------------*
           if        w-tes-scp-aap (1)    not  = zero and
                     w-pie-per-scp (1)    =    w-tes-scp-aap (1)
                     go to acc-tot-scp-999.
       acc-tot-scp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      08                   to   v-lin                  .
           move      28                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-pie-tot-scp (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-tot-scp-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-tot-scp-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-pie-tot-scp (1)      .
       acc-tot-scp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-tot-scp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal precedente    *
      *                  *---------------------------------------------*
           if        w-pie-tot-scp (1)    =    w-sav-tot-scp
                     go to acc-tot-scp-800.
      *                      *-----------------------------------------*
      *                      * Trattamento % sconto pagamento          *
      *                      *-----------------------------------------*
           if        w-pie-per-scp (1)    not  = zero
                     move  zero           to   w-pie-per-scp (1)      .
      *                      *-----------------------------------------*
      *                      * Determinazione totali riepilogo docum.  *
      *                      *-----------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione intero piede          *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           perform   vis-pie-reg-000      thru vis-pie-reg-999        .
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-tot-scp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-tot-scp-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-tot-scp-100.
       acc-tot-scp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Totale sconto pagamento     *
      *    *-----------------------------------------------------------*
       vis-tot-scp-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      08                   to   v-lin                  .
           move      28                   to   v-pos                  .
           move      w-pie-tot-scp (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tot-scp-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo piede : % sconto pagamento             *
      *    *-----------------------------------------------------------*
       acc-per-scp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-ipc-sub-pgm-ind    =    "CM"
                     go to acc-per-scp-999.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-pie-per-scp (1)    to   w-sav-per-scp          .
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *                                             *
      *                  * Se esiste lo sconto associato alla forma di *
      *                  * pagamento il campo non e' accettabile in    *
      *                  * quanto la % viene forzata dalla forma di    *
      *                  * pagamento stessa                            *
      *                  *---------------------------------------------*
           if        w-tes-scp-aap (1)    not  = zero and
                     w-pie-per-scp (1)    =    w-tes-scp-aap (1)
                     go to acc-per-scp-999.
       acc-per-scp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      08                   to   v-lin                  .
           move      45                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-pie-per-scp (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-per-scp-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-per-scp-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-pie-per-scp (1)      .
       acc-per-scp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-per-scp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal precedente    *
      *                  *---------------------------------------------*
           if        w-pie-per-scp (1)    =    w-sav-per-scp
                     go to acc-per-scp-800.
      *                      *-----------------------------------------*
      *                      * Determinazione totali riepilogo docum.  *
      *                      *-----------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione intero piede          *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           perform   vis-pie-reg-000      thru vis-pie-reg-999        .
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-per-scp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-per-scp-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-per-scp-100.
       acc-per-scp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : % sconto pagamento          *
      *    *-----------------------------------------------------------*
       vis-per-scp-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           move      08                   to   v-lin                  .
           move      45                   to   v-pos                  .
           move      w-pie-per-scp (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-per-scp-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga : Si/No addebito spesa in funzio- *
      *    * ne di w-acc-iep-spe-ctr                                   *
      *    *-----------------------------------------------------------*
       acc-spe-snx-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-prs-spe-fat-nst    =    zero
                     go to acc-spe-snx-999.
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-acc-iep-spe-ctr)   to   w-acc-iep-spe-inx      .
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-pie-spe-snx
                    (1, w-acc-iep-spe-inx)
                                          to   w-sav-spe-snx          .
       acc-spe-snx-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-spe-snx-lun    to   v-car                  .
           move      w-exp-spe-snx-num    to   v-ldt                  .
           move      "NS#"                to   v-msk                  .
           move      spaces               to   v-edm                  .
           add       09
                     w-acc-iep-spe-ctr  giving v-lin                  .
           move      28                   to   v-pos                  .
           move      w-exp-spe-snx-tbl    to   v-txt                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           if        w-pie-spe-snx
                    (1, w-acc-iep-spe-inx)
                                          =    0
                     move  1              to   v-num
           else if   w-pie-spe-snx
                    (1, w-acc-iep-spe-inx)
                                          =    1
                     move  2              to   v-num
           else      move  zero           to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-spe-snx-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-spe-snx-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           if        v-num                =    1
                     move  0              to   w-pie-spe-snx
                                              (1, w-acc-iep-spe-inx)
           else if   v-num                =    2
                     move  1              to   w-pie-spe-snx
                                              (1, w-acc-iep-spe-inx)
           else      move  zero           to   w-pie-spe-snx
                                              (1, w-acc-iep-spe-inx)  .
       acc-spe-snx-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-spe-snx-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal precedente    *
      *                  *---------------------------------------------*
           if        w-pie-spe-snx
                    (1, w-acc-iep-spe-inx)
                                          =    w-sav-spe-snx
                     go to acc-spe-snx-800.
      *                      *-----------------------------------------*
      *                      * Trattamento importo e percentuale spesa *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Se si addebito : oltre              *
      *                          *-------------------------------------*
           if        w-pie-spe-snx
                    (1, w-acc-iep-spe-inx)
                                          =    1
                     go to acc-spe-snx-650.
      *                          *-------------------------------------*
      *                          * Test su personalizzazione per tipo  *
      *                          * accettazione                        *
      *                          *-------------------------------------*
           if        w-prs-spe-fat-tac    =    01
                     go to acc-spe-snx-650.
      *                          *-------------------------------------*
      *                          * Normalizzazione importo e percen-   *
      *                          * tuale                               *
      *                          *-------------------------------------*
           move      zero                 to   w-pie-spe-imp
                                              (1, w-acc-iep-spe-inx)  .
           move      zero                 to   w-pie-spe-per
                                              (1, w-acc-iep-spe-inx)  .
       acc-spe-snx-650.
      *                      *-----------------------------------------*
      *                      * Determinazione totali riepilogo docum.  *
      *                      *-----------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione intero piede          *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           perform   vis-pie-reg-000      thru vis-pie-reg-999        .
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-spe-snx-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-spe-snx-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-spe-snx-100.
       acc-spe-snx-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga : Si/No addebito spese   *
      *    *-----------------------------------------------------------*
       vis-spe-snx-000.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-vis-iep-spe-ctr      .
       vis-spe-snx-100.
           add       1                    to   w-vis-iep-spe-ctr      .
           if        w-vis-iep-spe-ctr    >    w-prs-spe-fat-nst
                     go to vis-spe-snx-999.
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-vis-iep-spe-ctr)   to   w-vis-iep-spe-inx      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-spe-snx-lun    to   v-car                  .
           move      w-exp-spe-snx-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           add       09
                     w-vis-iep-spe-ctr  giving v-lin                  .
           move      28                   to   v-pos                  .
           move      w-exp-spe-snx-tbl    to   v-txt                  .
           if        w-pie-spe-snx
                    (1, w-vis-iep-spe-inx)
                                          =    0
                     move  1              to   v-num
           else if   w-pie-spe-snx
                    (1, w-vis-iep-spe-inx)
                                          =    1
                     move  2              to   v-num
           else      move  zero           to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Riciclo su scansione                        *
      *                  *---------------------------------------------*
           go to     vis-spe-snx-100.
       vis-spe-snx-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga : Importo spesa in funzione di    *
      *    * w-acc-iep-spe-ctr                                         *
      *    *-----------------------------------------------------------*
       acc-spe-imp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-acc-iep-spe-ctr)   to   w-acc-iep-spe-inx      .
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se numero spese personalizzate a zero : *
      *                      * il campo non e' da accettare            *
      *                      *-----------------------------------------*
           if        w-prs-spe-fat-nst    =    zero
                     go to acc-spe-imp-999.
      *                      *-----------------------------------------*
      *                      * Se spesa da addebitare : oltre          *
      *                      *-----------------------------------------*
           if        w-pie-spe-snx
                    (1, w-acc-iep-spe-inx)
                                          =    1
                     go to acc-spe-imp-050.
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione per tipo ac-  *
      *                      * cettazione                              *
      *                      *-----------------------------------------*
           if        w-prs-spe-fat-tac    =    00
                     go to acc-spe-imp-999.
       acc-spe-imp-050.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-pie-spe-imp
                    (1, w-acc-iep-spe-inx)
                                          to   w-sav-spe-imp          .
       acc-spe-imp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           add       09
                     w-acc-iep-spe-ctr  giving v-lin                  .
           move      31                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-pie-spe-imp
                    (1, w-acc-iep-spe-inx)
                                          to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-spe-imp-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-spe-imp-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-pie-spe-imp
                                              (1, w-acc-iep-spe-inx)  .
       acc-spe-imp-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-spe-imp-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal precedente    *
      *                  *---------------------------------------------*
           if        w-pie-spe-imp
                    (1, w-acc-iep-spe-inx)
                                          =    w-sav-spe-imp
                     go to acc-spe-imp-800.
      *                      *-----------------------------------------*
      *                      * Normalizzazione percentuale spesa       *
      *                      *-----------------------------------------*
           move      zero                 to   w-pie-spe-per
                                              (1, w-acc-iep-spe-inx)  .
      *                      *-----------------------------------------*
      *                      * Determinazione totali riepilogo docum.  *
      *                      *-----------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione intero piede          *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           perform   vis-pie-reg-000      thru vis-pie-reg-999        .
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-spe-imp-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-spe-imp-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-spe-imp-100.
       acc-spe-imp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga : Importi spese          *
      *    *-----------------------------------------------------------*
       vis-spe-imp-000.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-vis-iep-spe-ctr      .
       vis-spe-imp-100.
           add       1                    to   w-vis-iep-spe-ctr      .
           if        w-vis-iep-spe-ctr    >    w-prs-spe-fat-nst
                     go to vis-spe-imp-999.
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-vis-iep-spe-ctr)   to   w-vis-iep-spe-inx      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           add       09
                     w-vis-iep-spe-ctr  giving v-lin                  .
           move      31                   to   v-pos                  .
           move      w-pie-spe-imp
                    (1, w-vis-iep-spe-inx)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Riciclo su scansione                        *
      *                  *---------------------------------------------*
           go to     vis-spe-imp-100.
       vis-spe-imp-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo riga : % spesa in funzione di          *
      *    * w-acc-iep-spe-ctr                                         *
      *    *-----------------------------------------------------------*
       acc-spe-per-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-acc-iep-spe-ctr)   to   w-acc-iep-spe-inx      .
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se numero spese personalizzate a zero : *
      *                      * il campo non e' da accettare            *
      *                      *-----------------------------------------*
           if        w-prs-spe-fat-nst    =    zero
                     go to acc-spe-per-999.
      *                      *-----------------------------------------*
      *                      * Se tipo di imponibile per la spesa a    *
      *                      * zero : no                               *
      *                      *-----------------------------------------*
           if        w-pie-spe-ibl
                    (1, w-acc-iep-spe-inx)
                                          =    zero
                     go to acc-spe-per-999.
      *                      *-----------------------------------------*
      *                      * Se spesa da addebitare : oltre          *
      *                      *-----------------------------------------*
           if        w-pie-spe-snx
                    (1, w-acc-iep-spe-inx)
                                          =    1
                     go to acc-spe-per-050.
      *                      *-----------------------------------------*
      *                      * Test su personalizzazione per tipo ac-  *
      *                      * cettazione                              *
      *                      *-----------------------------------------*
           if        w-prs-spe-fat-tac    =    00
                     go to acc-spe-per-999.
       acc-spe-per-050.
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-pie-spe-per
                    (1, w-acc-iep-spe-inx)
                                          to   w-sav-spe-per          .
       acc-spe-per-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           add       09
                     w-acc-iep-spe-ctr  giving v-lin                  .
           move      45                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-pie-spe-per
                    (1, w-acc-iep-spe-inx)
                                          to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-spe-per-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-spe-per-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-pie-spe-per
                                              (1, w-acc-iep-spe-inx)  .
       acc-spe-per-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-spe-per-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal precedente    *
      *                  *---------------------------------------------*
           if        w-pie-spe-per
                    (1, w-acc-iep-spe-inx)
                                          =    w-sav-spe-per
                     go to acc-spe-per-800.
      *                      *-----------------------------------------*
      *                      * Determinazione totali riepilogo docum.  *
      *                      *-----------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione intero piede          *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           perform   vis-pie-reg-000      thru vis-pie-reg-999        .
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-spe-per-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-spe-per-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-spe-per-100.
       acc-spe-per-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo campo riga : % spese                *
      *    *-----------------------------------------------------------*
       vis-spe-per-000.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione                              *
      *              *-------------------------------------------------*
           move      zero                 to   w-vis-iep-spe-ctr      .
       vis-spe-per-100.
           add       1                    to   w-vis-iep-spe-ctr      .
           if        w-vis-iep-spe-ctr    >    w-prs-spe-fat-nst
                     go to vis-spe-per-999.
      *                  *---------------------------------------------*
      *                  * Determinazione indice per la spesa          *
      *                  *---------------------------------------------*
           move      w-prs-spe-fat-npt
                    (w-vis-iep-spe-ctr)   to   w-vis-iep-spe-inx      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      02                   to   v-car                  .
           move      01                   to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "BD"                 to   v-edm                  .
           add       09
                     w-vis-iep-spe-ctr  giving v-lin                  .
           move      45                   to   v-pos                  .
           move      w-pie-spe-per
                    (1, w-vis-iep-spe-inx)
                                          to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Riciclo su scansione                        *
      *                  *---------------------------------------------*
           go to     vis-spe-per-100.
       vis-spe-per-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Spese incasso calcolate     *
      *    *-----------------------------------------------------------*
       vis-tot-sic-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      19                   to   v-lin                  .
           move      31                   to   v-pos                  .
           move      w-pie-tot-sic (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tot-sic-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo piede : Spese incasso aggiuntive       *
      *    *-----------------------------------------------------------*
       acc-tot-sia-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-pie-tot-sia (1)    to   w-sav-tot-sia          .
       acc-tot-sia-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      20                   to   v-lin                  .
           move      31                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-pie-tot-sia (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-tot-sia-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-tot-sia-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-pie-tot-sia (1)      .
       acc-tot-sia-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-tot-sia-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal precedente    *
      *                  *---------------------------------------------*
           if        w-pie-tot-sia (1)    =    w-sav-tot-sia
                     go to acc-tot-sia-800.
      *                      *-----------------------------------------*
      *                      * Determinazione totali riepilogo docum.  *
      *                      *-----------------------------------------*
           perform   det-tri-doc-000      thru det-tri-doc-999        .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione intero piede          *
      *                      *-----------------------------------------*
           move      "OF"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           perform   vis-pie-reg-000      thru vis-pie-reg-999        .
           move      "ON"                 to   v-ope                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       acc-tot-sia-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-tot-sia-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-tot-sia-100.
       acc-tot-sia-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Spese incasso aggiuntive    *
      *    *-----------------------------------------------------------*
       vis-tot-sia-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      20                   to   v-lin                  .
           move      31                   to   v-pos                  .
           move      w-pie-tot-sia (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tot-sia-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Totale spese bollo          *
      *    *-----------------------------------------------------------*
       vis-tot-spb-000.
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      09                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      21                   to   v-lin                  .
           move      31                   to   v-pos                  .
           move      w-pie-tot-spb (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tot-spb-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Riepilogo totali            *
      *    *-----------------------------------------------------------*
       vis-rie-tot-000.
      *              *-------------------------------------------------*
      *              * Totale lordo                                    *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      07                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-pie-tot-lor (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Totale netto                                    *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      09                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-pie-tot-net (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Totale spese                                    *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      11                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-pie-tot-spe (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Totale imponibile                               *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      13                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-pie-tot-ibl (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Totale imposta                                  *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      15                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-pie-tot-imp (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-rie-tot-200.
      *              *-------------------------------------------------*
      *              * Totale riscosso                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da visualizzare                     *
      *                  *---------------------------------------------*
           if        w-prs-tim-scp-tip    not  = "A"
                     go to vis-rie-tot-300.
      *                  *---------------------------------------------*
      *                  * Valore                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      19                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-pie-tot-doc (1)    to   v-num                  .
           subtract  w-pie-tot-scp (1)    from v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-rie-tot-300.
      *              *-------------------------------------------------*
      *              * Totale documento                                *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      w-tes-dec-vpf (1)    to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      20                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-pie-tot-doc (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Totale documento in valuta base                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da stampare                         *
      *                  *---------------------------------------------*
           if        w-tes-sgl-vpf (1)    =    c-sgl
                     go to vis-rie-tot-999.
      *                  *---------------------------------------------*
      *                  * Determinazione                              *
      *                  *---------------------------------------------*
           move      w-tes-sgl-vpf (1)    to   w-cvs-vlt-sgl          .
           move      w-tes-dec-vpf (1)    to   w-cvs-vlt-dec          .
           move      w-tes-tdc-vpf (1)    to   w-cvs-vlt-tdc          .
           move      w-tes-cdc-vpf (1)    to   w-cvs-vlt-cdc          .
           move      w-pie-tot-doc (1)    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
      *                  *---------------------------------------------*
      *                  * Stampa                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "V"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      c-dec                to   v-dec                  .
           move      "S"                  to   v-sgn                  .
           move      "GB"                 to   v-edm                  .
           move      21                   to   v-lin                  .
           move      65                   to   v-pos                  .
           move      w-cvs-vlt-avb        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-rie-tot-999.
           exit.

