      *    *===========================================================*
      *    * Visualizzazione prompts per importi spese                 *
      *    *-----------------------------------------------------------*
       pmt-spe-imp-000.
      *              *-------------------------------------------------*
      *              * Se nessuna personalizzazione : uscita           *
      *              *-------------------------------------------------*
           if        w-prs-spe-fat-nst    =    zero
                     go to pmt-spe-imp-999.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione su tabella spese             *
      *              *-------------------------------------------------*
           move      zero                 to   w-pmt-iep-spe-ctr      .
       pmt-spe-imp-100.
           add       1                    to   w-pmt-iep-spe-ctr      .
           if        w-pmt-iep-spe-ctr    >    w-prs-spe-fat-nst
                     go to pmt-spe-imp-999.
      *                  *---------------------------------------------*
      *                  * Visualizzazione                             *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      25                   to   v-car                  .
           add       09
                     w-pmt-iep-spe-ctr  giving v-lin                  .
           move      01                   to   v-pos                  .
           move      w-prs-spe-fat-dve
                    (w-pmt-iep-spe-ctr)   to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      01                   to   v-car                  .
           add       09
                     w-pmt-iep-spe-ctr  giving v-lin                  .
           move      26                   to   v-pos                  .
           move      ":"                  to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     pmt-spe-imp-100.
       pmt-spe-imp-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per spese incasso calcolate       *
      *    *-----------------------------------------------------------*
       pmt-tot-sic-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      26                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Spese incasso calcolate  :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-tot-sic-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per spese incasso aggiuntive      *
      *    *-----------------------------------------------------------*
       pmt-tot-sia-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      26                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Spese incasso aggiuntive :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-tot-sia-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per spese bollo                   *
      *    *-----------------------------------------------------------*
       pmt-tot-spb-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      26                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Spese bollo              :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-tot-spb-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione prompts per riepilogo totali              *
      *    *-----------------------------------------------------------*
       pmt-rie-tot-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      53                   to   v-pos                  .
           move      "Lordo      :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      53                   to   v-pos                  .
           move      "Netto      :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      11                   to   v-lin                  .
           move      53                   to   v-pos                  .
           move      "Spese      :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      13                   to   v-lin                  .
           move      53                   to   v-pos                  .
           move      "Imponibile :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      15                   to   v-lin                  .
           move      53                   to   v-pos                  .
           move      "Iva        :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-rie-tot-100.
      *              *-------------------------------------------------*
      *              * Linea separazione totale                        *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      28                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      53                   to   v-pos                  .
           move      all "-"              to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-rie-tot-120.
      *              *-------------------------------------------------*
      *              * Totale riscosso                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se da visualizzare                     *
      *                  *---------------------------------------------*
           if        w-prs-tim-scp-tip    not  = "A"
                     go to pmt-rie-tot-140.
      *                  *---------------------------------------------*
      *                  * Prompt                                      *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      19                   to   v-lin                  .
           move      53                   to   v-pos                  .
           move      "Riscosso   :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-rie-tot-140.
      *              *-------------------------------------------------*
      *              * Totale documento                                *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      53                   to   v-pos                  .
           move      "TOTALE     :"       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
       pmt-rie-tot-180.
      *              *-------------------------------------------------*
      *              * Deviazione a seconda che sia un documento in    *
      *              * valuta o no                                     *
      *              *-------------------------------------------------*
           if        w-tes-sgl-vpf (1)    =    c-sgl
                     go to pmt-rie-tot-999.
       pmt-rie-tot-200.
      *              *-------------------------------------------------*
      *              * Se documento in valuta                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Valuta per fatturazione                     *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      20                   to   v-lin                  .
           move      60                   to   v-pos                  .
           move      w-tes-sgl-vpf (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
      *                  *---------------------------------------------*
      *                  * Totale in valuta base                       *
      *                  *---------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      12                   to   v-car                  .
           move      21                   to   v-lin                  .
           move      53                   to   v-pos                  .
           move      spaces               to   v-alf                  .
           string    "       "  delimited by   size
                     c-sgl      delimited by   size
                     " :"       delimited by   size
                                          into v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                        using  v                      .
           go to     pmt-rie-tot-999.
       pmt-rie-tot-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo piede : Presa visione per pagina piede *
      *    *-----------------------------------------------------------*
       acc-pre-vpp-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se campo da accettare                  *
      *                  *---------------------------------------------*
           if        w-tes-int-ftr        =    01
                     go to acc-pre-vpp-999.
       acc-pre-vpp-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "MX"                 to   v-ope                  .
           move      "U"                  to   v-tip                  .
           move      01                   to   v-car                  .
           move      spaces               to   v-msk                  .
           move      spaces               to   v-alf                  .
           move      spaces               to   v-not                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-pre-vpp-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-pre-vpp-999.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-pre-vpp-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-pre-vpp-000.
       acc-pre-vpp-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo piede : Trasporto a cura               *
      *    *-----------------------------------------------------------*
       acc-tra-cur-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Salvataggio valore precedente               *
      *                  *---------------------------------------------*
           move      w-pie-tra-cur (1)    to   w-sav-tra-cur          .
       acc-tra-cur-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tra-cur-lun    to   v-car                  .
           move      w-exp-tra-cur-num    to   v-ldt                  .
           move      "MDV#"               to   v-msk                  .
           move      spaces               to   v-edm                  .
           move      w-exp-tra-cur-tbl    to   v-txt                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           if        w-pie-tra-cur (1)    =    10
                     move  01             to   v-num
           else if   w-pie-tra-cur (1)    =    20
                     move  02             to   v-num
           else if   w-pie-tra-cur (1)    =    30
                     move  03             to   v-num
           else      move  zero           to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-tra-cur-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-tra-cur-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           if        v-num                =    01
                     move  10             to   w-pie-tra-cur (1)
           else if   v-num                =    02
                     move  20             to   w-pie-tra-cur (1)
           else if   v-num                =    03
                     move  30             to   w-pie-tra-cur (1)
           else      move  zero           to   w-pie-tra-cur (1)      .
       acc-tra-cur-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se zero : reimpostazione                    *
      *                  *---------------------------------------------*
           if        w-pie-tra-cur (1)    not  = zero
                     go to acc-tra-cur-600.
           if        v-key                =    "UP  "
                     go to acc-tra-cur-600
           else      go to acc-tra-cur-100.
       acc-tra-cur-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se valore attuale diverso dal precedente    *
      *                  *---------------------------------------------*
           if        w-pie-tra-cur (1)    =    w-sav-tra-cur
                     go to acc-tra-cur-800.
      *                  *---------------------------------------------*
      *                  * Trattamento vettore                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore attuale non Vettore           *
      *                      *-----------------------------------------*
           if        w-pie-tra-cur (1)    =    30
                     go to acc-tra-cur-700.
      *                          *-------------------------------------*
      *                          * Normalizzazione dati vettori        *
      *                          *-------------------------------------*
           if        w-pie-cod-vet (1)    =    zero and
                     w-pie-cod-vt2 (1)    =    zero and
                     w-pie-cod-vt3 (1)    =    zero
                     go to acc-tra-cur-800.
           move      zero                 to   w-pie-cod-vet (1)      .
           move      zero                 to   w-pie-cod-vt2 (1)      .
           move      zero                 to   w-pie-cod-vt3 (1)      .
           move      spaces               to   w-pie-cod-vet-des (1)  .
           move      spaces               to   w-pie-cod-vt2-des (1)  .
           move      spaces               to   w-pie-cod-vt3-des (1)  .
      *                          *-------------------------------------*
      *                          * Visualizzazione dati vettori        *
      *                          *-------------------------------------*
           perform   vis-cod-vet-000      thru vis-cod-vet-999        .
           perform   vis-cod-vet-des-000  thru vis-cod-vet-des-999    .
           perform   vis-cod-vt2-000      thru vis-cod-vt2-999        .
           perform   vis-cod-vt2-des-000  thru vis-cod-vt2-des-999    .
           perform   vis-cod-vt3-000      thru vis-cod-vt3-999        .
           perform   vis-cod-vt3-des-000  thru vis-cod-vt3-des-999    .
           go to     acc-tra-cur-800.
       acc-tra-cur-700.
      *                      *-----------------------------------------*
      *                      * Se valore attuale Vettore               *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Determinazione valori piede asso-   *
      *                          * ciati al vettore                    *
      *                          *-------------------------------------*
           perform   det-vlp-vet-000      thru det-vlp-vet-999        .
      *                          *-------------------------------------*
      *                          * Visualizzazione vettori             *
      *                          *-------------------------------------*
           perform   vis-cod-vet-000      thru vis-cod-vet-999        .
           perform   vis-cod-vet-des-000  thru vis-cod-vet-des-999    .
           perform   vis-cod-vt2-000      thru vis-cod-vt2-999        .
           perform   vis-cod-vt2-des-000  thru vis-cod-vt2-des-999    .
           perform   vis-cod-vt3-000      thru vis-cod-vt3-999        .
           perform   vis-cod-vt3-des-000  thru vis-cod-vt3-des-999    .
       acc-tra-cur-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-tra-cur-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-tra-cur-100.
       acc-tra-cur-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Trasporto a cura            *
      *    *-----------------------------------------------------------*
       vis-tra-cur-000.
           move      "DS"                 to   v-ope                  .
           move      "E"                  to   v-tip                  .
           move      w-exp-tra-cur-lun    to   v-car                  .
           move      w-exp-tra-cur-num    to   v-ldt                  .
           move      spaces               to   v-edm                  .
           move      w-exp-tra-cur-tbl    to   v-txt                  .
           move      05                   to   v-lin                  .
           move      30                   to   v-pos                  .
           if        w-pie-tra-cur (1)    =    10
                     move  01             to   v-num
           else if   w-pie-tra-cur (1)    =    20
                     move  02             to   v-num
           else if   w-pie-tra-cur (1)    =    30
                     move  03             to   v-num
           else      move  zero           to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-tra-cur-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo piede : Causale del trasporto          *
      *    *-----------------------------------------------------------*
       acc-cau-tra-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-cau-tra-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-des-zct-ope      .
           move      w-pie-cau-tra (1)    to   w-cod-des-zct-cod      .
           move      07                   to   w-cod-des-zct-lin      .
           move      30                   to   w-cod-des-zct-pos      .
           move      07                   to   w-cod-des-zct-dln      .
           move      37                   to   w-cod-des-zct-dps      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-des-zct-cll-000  thru cod-des-zct-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-des-zct-foi-000  thru cod-des-zct-foi-999    .
       acc-cau-tra-110.
           perform   cod-des-zct-cll-000  thru cod-des-zct-cll-999    .
           if        w-cod-des-zct-ope    =    "F+"
                     go to acc-cau-tra-115.
           if        w-cod-des-zct-ope    =    "AC"
                     go to acc-cau-tra-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cau-tra-115.
           perform   cod-des-zct-foi-000  thru cod-des-zct-foi-999    .
           go to     acc-cau-tra-110.
       acc-cau-tra-120.
           move      w-cod-des-zct-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-cau-tra-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-cau-tra-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-pie-cau-tra (1)      .
       acc-cau-tra-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      w-pie-cau-tra (1)    to   w-let-arc-zct-cod      .
           perform   let-arc-zct-000      thru let-arc-zct-999        .
           move      w-let-arc-zct-des    to   w-pie-cau-tra-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-ctr-000      thru vis-des-ctr-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-zct-flg    not  = spaces
                     go to acc-cau-tra-100.
       acc-cau-tra-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cau-tra-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-cau-tra-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cau-tra-100.
       acc-cau-tra-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Causale del trasporto       *
      *    *-----------------------------------------------------------*
       vis-cau-tra-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-pie-cau-tra (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cau-tra-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Descrizione causale del     *
      *    * trasporto                                                 *
      *    *-----------------------------------------------------------*
       vis-des-ctr-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      07                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-pie-cau-tra-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-ctr-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo piede : Aspetto esteriore dei beni     *
      *    *-----------------------------------------------------------*
       acc-cod-aeb-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-cod-aeb-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-des-zab-ope      .
           move      w-pie-cod-aeb (1)    to   w-cod-des-zab-cod      .
           move      09                   to   w-cod-des-zab-lin      .
           move      30                   to   w-cod-des-zab-pos      .
           move      09                   to   w-cod-des-zab-dln      .
           move      37                   to   w-cod-des-zab-dps      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           perform   cod-des-zab-cll-000  thru cod-des-zab-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-des-zab-foi-000  thru cod-des-zab-foi-999    .
       acc-cod-aeb-110.
           perform   cod-des-zab-cll-000  thru cod-des-zab-cll-999    .
           if        w-cod-des-zab-ope    =    "F+"
                     go to acc-cod-aeb-115.
           if        w-cod-des-zab-ope    =    "AC"
                     go to acc-cod-aeb-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-aeb-115.
           perform   cod-des-zab-foi-000  thru cod-des-zab-foi-999    .
           go to     acc-cod-aeb-110.
       acc-cod-aeb-120.
           move      w-cod-des-zab-cod    to   v-alf                  .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-cod-aeb-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-cod-aeb-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-pie-cod-aeb (1)      .
       acc-cod-aeb-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lettura tabella                             *
      *                  *---------------------------------------------*
           move      w-pie-cod-aeb (1)    to   w-let-arc-zab-cod      .
           perform   let-arc-zab-000      thru let-arc-zab-999        .
           move      w-let-arc-zab-des    to   w-pie-cod-aeb-des (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione descrizione                 *
      *                  *---------------------------------------------*
           perform   vis-des-aeb-000      thru vis-des-aeb-999        .
      *                  *---------------------------------------------*
      *                  * Se codice errato : reimpostazione           *
      *                  *---------------------------------------------*
           if        w-let-arc-zab-flg    not  = spaces
                     go to acc-cod-aeb-100.
       acc-cod-aeb-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-aeb-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-cod-aeb-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-cod-aeb-100.
       acc-cod-aeb-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Aspetto esteriore dei beni  *
      *    *-----------------------------------------------------------*
       vis-cod-aeb-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      03                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-pie-cod-aeb (1)    to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-cod-aeb-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Descrizione sspetto este-   *
      *    * riore dei beni                                            *
      *    *-----------------------------------------------------------*
       vis-des-aeb-000.
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      20                   to   v-car                  .
           move      09                   to   v-lin                  .
           move      37                   to   v-pos                  .
           move      w-pie-cod-aeb-des (1)
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-des-aeb-999.
           exit.

      *    *===========================================================*
      *    * Accettazione campo piede : Numero colli                   *
      *    *-----------------------------------------------------------*
       acc-num-col-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-num-col-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      11                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           if        w-cnt-sts-imp-tes    not  = spaces and
                     w-cnt-sts-imp-cor    not  = spaces and
                     w-cnt-sts-imp-pie    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      w-pie-num-col (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-pie
                     go to acc-num-col-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-pie
                     go to acc-num-col-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-num                to   w-pie-num-col (1)      .
       acc-num-col-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-num-col-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-num-col-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-pie
                             go to acc-num-col-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-num-col-100.
       acc-num-col-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione campo piede : Numero colli                *
      *    *-----------------------------------------------------------*
       vis-num-col-000.
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      05                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      11                   to   v-lin                  .
           move      30                   to   v-pos                  .
           move      w-pie-num-col (1)    to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-num-col-999.
           exit.

      *    *===========================================================*
