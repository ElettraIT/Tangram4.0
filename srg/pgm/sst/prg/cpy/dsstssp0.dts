      *    *===========================================================*
      *    * Subroutines per determinazione, relativamente ad un pro-  *
      *    * dotto, di dati statistici di acquisto e vendita           *
      *    *-----------------------------------------------------------*
       det-sst-ssp-opn-000.
      *              *=================================================*
      *              * Open modulo                                     *
      *              *-------------------------------------------------*
           move      "OP"                 to   d-sst-ssp-tip-ope      .
           perform   det-sst-ssp-cll-000  thru det-sst-ssp-cll-999    .
       det-sst-ssp-opn-999.
           exit.

       det-sst-ssp-cls-000.
      *              *=================================================*
      *              * Close modulo                                    *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Chiusura                                    *
      *                  *---------------------------------------------*
           move      "CL"                 to   d-sst-ssp-tip-ope      .
           perform   det-sst-ssp-cll-000  thru det-sst-ssp-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test se cancellabile                        *
      *                  *---------------------------------------------*
           move      "C?"                 to   d-sst-ssp-tip-ope      .
           perform   det-sst-ssp-cll-000  thru det-sst-ssp-cll-999    .
           if        d-sst-ssp-exi-sts    not  = spaces
                     go to det-sst-ssp-cls-999.
      *                  *---------------------------------------------*
      *                  * Cancellazione modulo                        *
      *                  *---------------------------------------------*
           move      "pgm/sst/prg/obj/dsstssp0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           cancel    s-pat                                            .
       det-sst-ssp-cls-999.
           exit.

       det-sst-ssp-cll-000.
      *              *=================================================*
      *              * Chiamata generica modulo                        *
      *              *-------------------------------------------------*
           move      "pgm/sst/prg/obj/dsstssp0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-sst-ssp
                                               rf-oct                 .
       det-sst-ssp-cll-999.
           exit.

