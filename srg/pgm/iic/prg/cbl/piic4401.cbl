           if        rf-mgi-tip-iva       =    "3"
                     go to stp-srt-inp-cs1-262
           else      go to stp-srt-inp-cs1-280.
       stp-srt-inp-cs1-262.
      *                                      *-------------------------*
      *                                      * Tipo iva : Corrispetti- *
      *                                      * vi                      *
      *                                      *-------------------------*
           add       rf-mgi-ibl-iva
                    (w-tai-ctr-001)       to   w-tai-ibl-cor
                                              (w-tai-ctr-002)         .
           add       rf-mgi-imp-iva
                    (w-tai-ctr-001)       to   w-tai-imp-cor
                                              (w-tai-ctr-002)         .
           go to     stp-srt-inp-cs1-280.
