                     go to stp-srt-inp-cs1-300.
      *                      *-----------------------------------------*
      *                      * Se codice iva a zero : riciclo          *
      *                      *-----------------------------------------*
           if        rf-mgi-cod-iva
                    (w-tai-ctr-001)       =    zero
                     go to stp-srt-inp-cs1-140.
      *                      *-----------------------------------------*
      *                      * Ricerca in tabella dell'aliquota letta  *
      *                      *-----------------------------------------*
           move      zero                 to   w-tai-ctr-002          .
       stp-srt-inp-cs1-150.
           add       1                    to   w-tai-ctr-002          .
           if        w-tai-ctr-002        >    w-tai-num-ele
                     go to stp-srt-inp-cs1-160.
      *                      *-----------------------------------------*
      *                      * In campi di comodo per il confronto     *
      *                      *-----------------------------------------*
           move      rf-mgi-tip-rec       to   w-tai-cmd-tr1          .
           move      w-tai-tip-rec
                    (w-tai-ctr-002)       to   w-tai-cmd-tr2          .
           move      rf-mgi-cod-num       to   w-tai-cmd-cn1          .
           move      w-tai-cod-num
                    (w-tai-ctr-002)       to   w-tai-cmd-cn2          .
           move      rf-mgi-cod-iva
                    (w-tai-ctr-001)       to   w-tai-cmd-ci1          .
