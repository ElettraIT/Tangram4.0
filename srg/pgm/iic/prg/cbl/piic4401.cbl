      *                  *---------------------------------------------*
           move      w-tai-tip-rec
                    (w-tai-ctr-001)       to   srt-tip-rec            .
           move      w-tai-cod-num
                    (w-tai-ctr-001)       to   srt-cod-num            .
           move      w-tai-cod-iva
                    (w-tai-ctr-001)       to   srt-cod-iva            .
           move      w-tai-ibl-fat
                    (w-tai-ctr-001)       to   srt-ibl-fat            .
           move      w-tai-imp-fat
                    (w-tai-ctr-001)       to   srt-imp-fat            .
           move      w-tai-ibl-cor
                    (w-tai-ctr-001)       to   srt-ibl-cor            .
           move      w-tai-imp-cor
                    (w-tai-ctr-001)       to   srt-imp-cor            .
           move      w-tai-ibl-acq
                    (w-tai-ctr-001)       to   srt-ibl-acq            .
           move      w-tai-imp-acq
                    (w-tai-ctr-001)       to   srt-imp-acq            .
      *                  *---------------------------------------------*
