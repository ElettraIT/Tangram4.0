      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Deviazione in funzione  *
      *                                      * del tipo iva            *
      *                                      *-------------------------*
           if        rf-mgi-tip-iva       =    "1" or
                     rf-mgi-tip-iva       =    "A"
                     go to stp-srt-inp-cs1-222
           else if   rf-mgi-tip-iva       =    "2" or
                     rf-mgi-tip-iva       =    "B"
                     go to stp-srt-inp-cs1-224
           else      go to stp-srt-inp-cs1-280.
       stp-srt-inp-cs1-222.
      *                                      *-------------------------*
      *                                      * Tipo iva : Dare clienti *
      *                                      *-------------------------*
           add       rf-mgi-ibl-iva
                    (w-tai-ctr-001)       to   w-tai-ibl-fat
                                              (w-tai-ctr-002)         .
           add       rf-mgi-imp-iva
                    (w-tai-ctr-001)       to   w-tai-imp-fat
                                              (w-tai-ctr-002)         .
           go to     stp-srt-inp-cs1-280.
       stp-srt-inp-cs1-224.
      *                                      *-------------------------*
      *                                      * Tipo iva : Avere clien- *
      *                                      * ti                      *
      *                                      *-------------------------*
           subtract  rf-mgi-ibl-iva
                    (w-tai-ctr-001)       from w-tai-ibl-fat
                                              (w-tai-ctr-002)         .
           subtract  rf-mgi-imp-iva
                    (w-tai-ctr-001)       from w-tai-imp-fat
                                              (w-tai-ctr-002)         .
           go to     stp-srt-inp-cs1-280.
       stp-srt-inp-cs1-240.
      *                                  *-----------------------------*
      *                                  * Tipo record : Fornitore     *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Deviazione in funzione  *
      *                                      * del tipo iva            *
      *                                      *-------------------------*
           if        rf-mgi-tip-iva       =    "5" or
                     rf-mgi-tip-iva       =    "6"
                     go to stp-srt-inp-cs1-242
           else if   rf-mgi-tip-iva       =    "4"
                     go to stp-srt-inp-cs1-244
           else if   rf-mgi-tip-iva       =    "E"
                     go to stp-srt-inp-cs1-246
           else if   rf-mgi-tip-iva       =    "D"
                     go to stp-srt-inp-cs1-248
           else      go to stp-srt-inp-cs1-280.
       stp-srt-inp-cs1-242.
      *                                      *-------------------------*
      *                                      * Tipo iva : Avere forni- *
      *                                      * tori Italia             *
      *                                      *-------------------------*
           add       rf-mgi-ibl-iva
                    (w-tai-ctr-001)       to   w-tai-ibl-acq
                                              (w-tai-ctr-002)         .
           add       rf-mgi-imp-iva
                    (w-tai-ctr-001)       to   w-tai-imp-acq
                                              (w-tai-ctr-002)         .
           go to     stp-srt-inp-cs1-280.
       stp-srt-inp-cs1-244.
      *                                      *-------------------------*
      *                                      * Tipo iva : Dare forni-  *
      *                                      * tori Italia             *
      *                                      *-------------------------*
           subtract  rf-mgi-ibl-iva
                    (w-tai-ctr-001)       from w-tai-ibl-acq
                                              (w-tai-ctr-002)         .
           subtract  rf-mgi-imp-iva
                    (w-tai-ctr-001)       from w-tai-imp-acq
                                              (w-tai-ctr-002)         .
