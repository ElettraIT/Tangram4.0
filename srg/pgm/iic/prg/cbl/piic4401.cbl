      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Stampa                                      *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           if        p-res                >    zero
                     move  w-stp-ast-fin-lst
                                          to   p-car
           else      move  w-stp-ast-fin-lus
                                          to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-stp-ast-fin-cdp    to   p-pos                  .
           move      all "*"              to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Aggiornamento contatore di posizione        *
      *                  *---------------------------------------------*
           add       w-stp-ast-fin-lst    to   w-stp-ast-fin-cdp      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     stp-ast-fin-100.
       stp-ast-fin-999.
           exit.

      *    *===========================================================*
      *    * Aggiornamento file [ivp] per il credito/debito            *
      *    *-----------------------------------------------------------*
       agg-fil-ivp-000.
      *              *-------------------------------------------------*
      *              * NESSUN AGGIORNAMENTO                            *
      *              *-------------------------------------------------*
       agg-fil-ivp-999.
           exit.

      *    *===========================================================*
      *    * Routine di aggiornamento numero ultima pagina             *
      *    *-----------------------------------------------------------*
       agg-ult-pag-000.
      *              *-------------------------------------------------*
      *              * Test preliminari                                *
      *              *-------------------------------------------------*
           if        w-ylp-iva-ult-agg    =    zero
                     go to agg-ult-pag-900.
           if        rr-snx-tdf           =    "S"
                     go to agg-ult-pag-100.
           if        rr-tip-stp           not  = "D"
                     go to agg-ult-pag-900.
       agg-ult-pag-100.
      *              *-------------------------------------------------*
      *              * Lettura year last page                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Secolo anno da data iniziale                *
      *                  *---------------------------------------------*
           move      w-ylp-iva-dat-ini    to   s-dat                  .
           move      s-saa                to   w-ylp-iva-dat-saa      .
      *                  *---------------------------------------------*
      *                  * Lettura                                     *
      *                  *---------------------------------------------*
           move      "Yg"                 to   s-ope                  .
           move      w-ref-giv-ven-cod    to   s-fas                  .
           move      w-ylp-iva-dat-saa    to   s-saa                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                =    spaces
                     go to agg-ult-pag-400.
       agg-ult-pag-200.
      *              *-------------------------------------------------*
      *              * Record non esistente                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Scrittura record normalizzato               *
      *                  *---------------------------------------------*
           move      "Yp"                 to   s-ope                  .
           move      w-ref-giv-ven-cod    to   s-fas                  .
           move      w-ylp-iva-dat-saa    to   s-saa                  .
           move      zero                 to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                  *---------------------------------------------*
      *                  * Ripetizione dell'intera operazione          *
      *                  *---------------------------------------------*
           go to     agg-ult-pag-100.
       agg-ult-pag-400.
      *              *-------------------------------------------------*
      *              * Record esistente                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Update record                               *
      *                  *---------------------------------------------*
           move      "Yu"                 to   s-ope                  .
           move      w-ref-giv-ven-cod    to   s-fas                  .
           move      w-ylp-iva-dat-saa    to   s-saa                  .
           move      w-ylp-iva-ult-agg    to   s-num                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Se errori ripete l'intera operazione di *
      *                      * aggiornamento                           *
      *                      *-----------------------------------------*
           if        s-sts                not  = spaces
                     go to agg-ult-pag-100.
       agg-ult-pag-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     agg-ult-pag-999.
       agg-ult-pag-999.
           exit.

