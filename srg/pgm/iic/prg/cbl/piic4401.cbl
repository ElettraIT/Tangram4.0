      *                              * Aggiornamento progressivi       *
      *                              *---------------------------------*
      *                                  *-----------------------------*
      *                                  * Deviazione in funzione del  *
      *                                  * tipo record                 *
      *                                  *-----------------------------*
           if        rf-mgi-tip-rec       =    "C"
                     go to stp-srt-inp-cs2-220
           else if   rf-mgi-tip-rec       =    "F"
                     go to stp-srt-inp-cs2-240
           else if   rf-mgi-tip-rec       =    "V"
                     go to stp-srt-inp-cs2-260.
       stp-srt-inp-cs2-220.
      *                                  *-----------------------------*
      *                                  * Tipo record : Cliente       *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Deviazione in funzione  *
      *                                      * del tipo iva            *
      *                                      *-------------------------*
           if        rf-mgi-tip-iva       =    "1" or
                     rf-mgi-tip-iva       =    "A"
                     go to stp-srt-inp-cs2-222
           else if   rf-mgi-tip-iva       =    "2" or
                     rf-mgi-tip-iva       =    "B"
                     go to stp-srt-inp-cs2-224
           else      go to stp-srt-inp-cs2-280.
       stp-srt-inp-cs2-222.
      *                                      *-------------------------*
      *                                      * Tipo iva : Dare clienti *
      *                                      *-------------------------*
           add       rf-mgi-ibl-iva
                    (w-tai-ctr-001)       to   w-tai-ibl-fat
                                              (w-tai-ctr-002)         .
           add       rf-mgi-imp-iva
                    (w-tai-ctr-001)       to   w-tai-imp-fat
                                              (w-tai-ctr-002)         .
           go to     stp-srt-inp-cs2-280.
       stp-srt-inp-cs2-224.
      *                                      *-------------------------*
      *                                      * Tipo iva : Avere clien- *
      *                                      * ti                      *
      *                                      *-------------------------*
           subtract  rf-mgi-ibl-iva
                    (w-tai-ctr-001)       from w-tai-ibl-fat
                                              (w-tai-ctr-002)         .
           subtract  rf-mgi-imp-iva
                    (w-tai-ctr-001)       from w-tai-imp-fat
                                              (w-tai-ctr-002)         .
           go to     stp-srt-inp-cs2-280.
       stp-srt-inp-cs2-240.
      *                                  *-----------------------------*
      *                                  * Tipo record : Fornitore     *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Deviazione in funzione  *
      *                                      * del tipo iva            *
      *                                      *-------------------------*
           if        rf-mgi-tip-iva       =    "5" or
                     rf-mgi-tip-iva       =    "6"
                     go to stp-srt-inp-cs2-242
           else if   rf-mgi-tip-iva       =    "4"
                     go to stp-srt-inp-cs2-244
           else if   rf-mgi-tip-iva       =    "E"
                     go to stp-srt-inp-cs2-246
           else if   rf-mgi-tip-iva       =    "D"
                     go to stp-srt-inp-cs2-248
           else      go to stp-srt-inp-cs2-280.
       stp-srt-inp-cs2-242.
      *                                      *-------------------------*
      *                                      * Tipo iva : Avere forni- *
      *                                      * tori Italia             *
      *                                      *-------------------------*
           add       rf-mgi-ibl-iva
                    (w-tai-ctr-001)       to   w-tai-ibl-acq
                                              (w-tai-ctr-002)         .
           add       rf-mgi-imp-iva
                    (w-tai-ctr-001)       to   w-tai-imp-acq
                                              (w-tai-ctr-002)         .
           go to     stp-srt-inp-cs2-280.
       stp-srt-inp-cs2-244.
      *                                      *-------------------------*
      *                                      * Tipo iva : Dare forni-  *
      *                                      * tori Italia             *
      *                                      *-------------------------*
           subtract  rf-mgi-ibl-iva
                    (w-tai-ctr-001)       from w-tai-ibl-acq
                                              (w-tai-ctr-002)         .
           subtract  rf-mgi-imp-iva
                    (w-tai-ctr-001)       from w-tai-imp-acq
                                              (w-tai-ctr-002)         .
           go to     stp-srt-inp-cs2-280.
       stp-srt-inp-cs2-246.
      *                                      *-------------------------*
      *                                      * Tipo iva : Avere forni- *
      *                                      * tori CEE                *
      *                                      *-------------------------*
           add       rf-mgi-ibl-iva
                    (w-tai-ctr-001)       to   w-tai-ibl-acq
                                              (w-tai-ctr-002)         .
           add       rf-mgi-imp-iva
                    (w-tai-ctr-001)       to   w-tai-imp-acq
                                              (w-tai-ctr-002)         .
           add       rf-mgi-ibl-iva
                    (w-tai-ctr-001)       to   w-tai-ibl-fat
                                              (w-tai-ctr-002)         .
           add       rf-mgi-imp-iva
                    (w-tai-ctr-001)       to   w-tai-imp-fat
                                              (w-tai-ctr-002)         .
           go to     stp-srt-inp-cs2-280.
       stp-srt-inp-cs2-248.
      *                                      *-------------------------*
      *                                      * Tipo iva : Dare forni-  *
      *                                      * tori CEE                *
      *                                      *-------------------------*
           subtract  rf-mgi-ibl-iva
                    (w-tai-ctr-001)       from w-tai-ibl-acq
                                              (w-tai-ctr-002)         .
           subtract  rf-mgi-imp-iva
                    (w-tai-ctr-001)       from w-tai-imp-acq
                                              (w-tai-ctr-002)         .
           subtract  rf-mgi-ibl-iva
                    (w-tai-ctr-001)       from w-tai-ibl-fat
                                              (w-tai-ctr-002)         .
           subtract  rf-mgi-imp-iva
                    (w-tai-ctr-001)       from w-tai-imp-fat
                                              (w-tai-ctr-002)         .
           go to     stp-srt-inp-cs2-280.
       stp-srt-inp-cs2-260.
      *                                  *-----------------------------*
      *                                  * Tipo record : Corrispettivi *
      *                                  *-----------------------------*
      *                                      *-------------------------*
      *                                      * Deviazione in funzione  *
      *                                      * del tipo iva            *
      *                                      *-------------------------*
           if        rf-mgi-tip-iva       =    "3"
                     go to stp-srt-inp-cs2-262
           else      go to stp-srt-inp-cs2-280.
       stp-srt-inp-cs2-262.
      *                                      *-------------------------*
      *                                      * Tipo iva : Corrispetti- *
      *                                      * vi                      *
