      *                  *---------------------------------------------*
           move      zero                 to   w-tai-ctr-001          .
       stp-srt-inp-cs2-140.
           add       1                    to   w-tai-ctr-001          .
           if        w-tai-ctr-001        >    6
                     go to stp-srt-inp-cs2-300.
      *                      *-----------------------------------------*
      *                      * Se codice iva a zero : riciclo          *
      *                      *-----------------------------------------*
           if        rf-mgi-cod-iva
                    (w-tai-ctr-001)       =    zero
                     go to stp-srt-inp-cs2-140.
      *                      *-----------------------------------------*
      *                      * Ricerca in tabella dell'aliquota letta  *
      *                      *-----------------------------------------*
           move      zero                 to   w-tai-ctr-002          .
       stp-srt-inp-cs2-150.
           add       1                    to   w-tai-ctr-002          .
           if        w-tai-ctr-002        >    w-tai-num-ele
                     go to stp-srt-inp-cs2-160.
      *                      *-----------------------------------------*
      *                      * In campi di comodo per il confronto     *
      *                      *-----------------------------------------*
           move      rf-mgi-tip-rec       to   w-tai-cmd-tr1          .
           move      w-tai-tip-rec
                    (w-tai-ctr-002)       to   w-tai-cmd-tr2          .
           move      rf-mgi-cod-num       to   w-tai-cmd-cn1          .
           move      w-tai-cod-num
                    (w-tai-ctr-002)       to   w-tai-cmd-cn2          .
           move      rf-mgi-cod-iva
                    (w-tai-ctr-001)       to   w-tai-cmd-ci1          .
           move      w-tai-cod-iva
                    (w-tai-ctr-002)       to   w-tai-cmd-ci2          .
      *                      *-----------------------------------------*
      *                      * Confronto                               *
      *                      *-----------------------------------------*
           if        w-tai-cmd-tr1        =    w-tai-cmd-tr2   and
                     w-tai-cmd-cn1        =    w-tai-cmd-cn2   and
                     w-tai-cmd-ci1        =    w-tai-cmd-ci2
                     go to stp-srt-inp-cs2-200.
           go to     stp-srt-inp-cs2-150.
       stp-srt-inp-cs2-160.
      *                          *-------------------------------------*
      *                          * Se elemento non trovato             *
      *                          *-------------------------------------*
      *                              *---------------------------------*
      *                              * Incremento contatore elementi   *
      *                              *---------------------------------*
           add       1                    to   w-tai-num-ele          .
      *                              *---------------------------------*
      *                              * Inizializzazione nuovo elemento *
      *                              *---------------------------------*
           move      rf-mgi-tip-rec       to   w-tai-tip-rec
                                              (w-tai-num-ele)         .
           move      rf-mgi-cod-num       to   w-tai-cod-num
                                              (w-tai-num-ele)         .
           move      rf-mgi-cod-iva
                    (w-tai-ctr-001)       to   w-tai-cod-iva
                                              (w-tai-num-ele)         .
           move      zero                 to   w-tai-ibl-fat
                                              (w-tai-num-ele)         .
           move      zero                 to   w-tai-imp-fat
                                              (w-tai-num-ele)         .
           move      zero                 to   w-tai-ibl-cor
                                              (w-tai-num-ele)         .
           move      zero                 to   w-tai-imp-cor
                                              (w-tai-num-ele)         .
           move      zero                 to   w-tai-ibl-acq
                                              (w-tai-num-ele)         .
           move      zero                 to   w-tai-imp-acq
                                              (w-tai-num-ele)         .
       stp-srt-inp-cs2-200.
      *                          *-------------------------------------*
      *                          * Se elemento trovato                 *
      *                          *-------------------------------------*
