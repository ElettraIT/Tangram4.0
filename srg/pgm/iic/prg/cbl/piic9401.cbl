           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      16                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      023                  to   p-pos                  .
           move      rf-fnt-cod-fis       to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Causale contabile                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura archivio [zcc]                  *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "CODCAU    "         to   f-key                  .
           move      rf-mgi-cod-cau       to   rf-zcc-cod-cau         .
           move      "pgm/cge/fls/ioc/obj/iofzcc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zcc                 .
           if        f-sts                not  = e-not-err
                     move  all "."        to   rf-zcc-des-cau         .
      *                      *-----------------------------------------*
      *                      * Stampa                                  *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      30                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      041                  to   p-pos                  .
           move      rf-zcc-des-cau       to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Stampa riga castelletto iva                 *
      *                  *---------------------------------------------*
           move      2                    to   w-stp-rig-csi-inx      .
           perform   stp-rig-csi-000      thru stp-rig-csi-999        .
       prn-liv-det-300.
      *              *-------------------------------------------------*
      *              * Stampa righe di dettaglio superiori alla seconda*
      *              *-------------------------------------------------*
           add       1                    to   w-stp-rig-csi-inx      .
           if        w-stp-rig-csi-inx    >    6
                     go to prn-liv-det-400.
           if        rf-mgi-cod-iva
                    (w-stp-rig-csi-inx)   =    zero
                     go to prn-liv-det-300.
      *                  *---------------------------------------------*
      *                  * Test se righe residue sufficienti           *
      *                  *---------------------------------------------*
           if        p-res                >    1
                     go to prn-liv-det-320.
      *                  *---------------------------------------------*
      *                  * Reintestazione                              *
      *                  *---------------------------------------------*
           perform   int-pag-sta-000      thru int-pag-sta-999        .
           if        w-cnt-prn-flg-int    not  = spaces
                     go to prn-liv-det-999.
       prn-liv-det-320.
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Stampa riga castelletto iva                 *
      *                  *---------------------------------------------*
           perform   stp-rig-csi-000      thru stp-rig-csi-999        .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     prn-liv-det-300.
       prn-liv-det-400.
      *              *-------------------------------------------------*
      *              * Se stampa di prova fine dettaglio               *
      *              *-------------------------------------------------*
       prn-liv-det-999.
           exit.

      *    *===========================================================*
      *    * Intestazione foglio                                       *
