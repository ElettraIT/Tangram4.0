      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Solo se prima aliquota                  *
      *                      *-----------------------------------------*
           if        w-stp-rie-fin-ctr    not  = 1
                     go to stp-rie-fin-440.
      *                      *-----------------------------------------*
      *                      * Stampa                                  *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      28                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      042                  to   p-pos                  .
           move      "Totali divisi per aliquota :"
                                          to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-rie-fin-440.
      *                  *---------------------------------------------*
      *                  * Imponibile                                  *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           if        w-rie-ibl-iva
                    (w-stp-rie-fin-ctr)   >    999999999 or
                     w-rie-ibl-iva
                    (w-stp-rie-fin-ctr)   <   -999999999
                     move  11             to   p-car
           else      move  09             to   p-car                  .
           move      c-dec                to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           if        w-rie-ibl-iva
                    (w-stp-rie-fin-ctr)   >    999999999 or
                     w-rie-ibl-iva
                    (w-stp-rie-fin-ctr)   <   -999999999
                     move  "B"            to   p-edm
           else      move  "GB"           to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      071                  to   p-pos                  .
           move      w-rie-ibl-iva
                    (w-stp-rie-fin-ctr)   to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Codice iva                                  *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      03                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "B"                  to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      084                  to   p-pos                  .
           move      w-rie-cod-iva
                    (w-stp-rie-fin-ctr)   to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Imposta                                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se aliquota normale                     *
      *                      *-----------------------------------------*
           if        w-rie-cod-iva
                    (w-stp-rie-fin-ctr)   >    300 and
                     w-rie-cod-iva
                    (w-stp-rie-fin-ctr)   <    700
                     go to stp-rie-fin-460.
      *                          *-------------------------------------*
      *                          * Stampa                              *
      *                          *-------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           move      11                   to   p-car                  .
           move      c-dec                to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      "GB"                 to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      088                  to   p-pos                  .
           move      w-rie-imp-iva
                    (w-stp-rie-fin-ctr)   to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
