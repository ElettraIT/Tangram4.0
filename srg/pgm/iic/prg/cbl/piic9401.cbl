      *                          * scansione : Data inizio mese prece- *
      *                          * dente rispetto alla data iniziale   *
      *                          *-------------------------------------*
           move      rr-dat-ini           to   s-dat                  .
           subtract  1                    from s-mes                  .
           if        s-mes                =    zero
                     move  12             to   s-mes
                     subtract 1           from s-saa                  .
           move      01                   to   s-gio                  .
      *                          *-------------------------------------*
      *                          * Start su file [sff]                 *
      *                          *-------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "FNTDTR    "         to   f-key                  .
           move      rf-mgi-cod-arc       to   rf-sff-cod-fnt         .
           move      s-dat                to   rf-sff-dtr-ftf         .
           move      zero                 to   rf-sff-num-ftf         .
           move      "pgm/scf/fls/ioc/obj/iofsff"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-sff                 .
      *                              *---------------------------------*
      *                              * Test su esito operazione        *
      *                              *---------------------------------*
           if        f-sts                not  = e-not-err
                     go to prn-liv-det-180.
       prn-liv-det-146.
