      *                          *-------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/cge/fls/ioc/obj/iofzci"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zci                 .
      *                          *-------------------------------------*
      *                          * Lettura record [zci]                *
      *                          *-------------------------------------*
           move      rf-mgi-cod-iva
                    (w-stp-rig-csi-inx)   to   w-let-arc-zci-cod      .
           perform   let-arc-zci-000      thru let-arc-zci-999        .
      *                          *-------------------------------------*
      *                          * Stampa                              *
      *                          *-------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      15                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      088                  to   p-pos                  .
           move      w-let-arc-zci-des    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       stp-rig-csi-500.
      *              *-------------------------------------------------*
      *              * Aggiornamento tabella per riepilogo finale      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Se No stampa riepilogo finale : uscita      *
      *                  *---------------------------------------------*
           if        rr-snx-rie           not  = "S"
                     go to stp-rig-csi-999.
      *                  *---------------------------------------------*
      *                  * Ciclo di scansione su elementi gia' presen- *
      *                  * ti                                          *
      *                  *---------------------------------------------*
           move      zero                 to   w-stp-rig-csi-ctr      .
       stp-rig-csi-520.
           add       1                    to   w-stp-rig-csi-ctr      .
           if        w-stp-rig-csi-ctr    >    w-rie-num-ele
                     go to stp-rig-csi-540.
           if        rf-mgi-cod-iva
                    (w-stp-rig-csi-inx)   not  = w-rie-cod-iva
                                                (w-stp-rig-csi-ctr)
                     go to stp-rig-csi-520.
      *                      *-----------------------------------------*
      *                      * Aggiornamento progressivi elemento      *
      *                      *-----------------------------------------*
           if        rf-mgi-tip-iva       =    "D"
                     subtract rf-mgi-ibl-iva
                             (w-stp-rig-csi-inx)
                                          from w-rie-ibl-iva
                                              (w-stp-rig-csi-ctr)
                     subtract rf-mgi-imp-iva
                             (w-stp-rig-csi-inx)
                                          from w-rie-imp-iva
                                              (w-stp-rig-csi-ctr)
           else      add      rf-mgi-ibl-iva
                             (w-stp-rig-csi-inx)
                                          to   w-rie-ibl-iva
                                              (w-stp-rig-csi-ctr)
                     add      rf-mgi-imp-iva
                             (w-stp-rig-csi-inx)
                                          to   w-rie-imp-iva
                                              (w-stp-rig-csi-ctr)     .
           go to     stp-rig-csi-999.
       stp-rig-csi-540.
      *                  *---------------------------------------------*
      *                  * Istituzione nuovo elemento in tabella       *
      *                  *---------------------------------------------*
           if        w-rie-num-ele        <    w-rie-max-ele
                     add   1              to   w-rie-num-ele          .
           move      rf-mgi-cod-iva
                    (w-stp-rig-csi-inx)   to   w-rie-cod-iva
                                              (w-rie-num-ele)         .
           move      rf-mgi-ibl-iva
                    (w-stp-rig-csi-inx)   to   w-rie-ibl-iva
                                              (w-rie-num-ele)         .
           move      rf-mgi-imp-iva
                    (w-stp-rig-csi-inx)   to   w-rie-imp-iva
                                              (w-rie-num-ele)         .
           if        rf-mgi-tip-iva       =    "D"
                     multiply -1          by   w-rie-ibl-iva
                                              (w-rie-num-ele)
                     multiply -1          by   w-rie-imp-iva
                                              (w-rie-num-ele)         .
       stp-rig-csi-999.
           exit.

