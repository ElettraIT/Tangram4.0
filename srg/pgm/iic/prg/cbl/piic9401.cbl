      *                          *-------------------------------------*
           if        rf-sff-sgl-vlt       =    c-sgl
                     move  rf-sff-imp-ftf to   rf-sff-iiv-ftf         .
      *                          *-------------------------------------*
      *                          * Stampa corrispettivo in valuta      *
      *                          *-------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           if        rf-sff-iiv-ftf       >    999999999 or
                     rf-sff-iiv-ftf       <   -999999999
                     move  11             to   p-car
           else      move  09             to   p-car                  .
           move      rf-sff-dec-vlt       to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           if        rf-sff-iiv-ftf       >    999999999 or
                     rf-sff-iiv-ftf       <   -999999999
                     move  "B"            to   p-edm
           else      move  "GB"           to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      120                  to   p-pos                  .
           move      rf-sff-iiv-ftf       to   p-num                  .
           if        rf-mgi-tip-iva       =    "D"
                     multiply -1          by   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     prn-liv-det-200.
       prn-liv-det-180.
      *                      *-----------------------------------------*
