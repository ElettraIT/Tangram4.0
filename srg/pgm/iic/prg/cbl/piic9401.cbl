           move      "A"                  to   p-tip                  .
           move      92                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      21                   to   p-pos                  .
           move      all   "-"            to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *              *-------------------------------------------------*
