      *    *===========================================================*
      *    * Ordinamento riepilogo finale                              *
      *    *-----------------------------------------------------------*
       ord-rie-fin-000.
      *              *-------------------------------------------------*
      *              * Test se almeno due codici da ordinare           *
      *              *-------------------------------------------------*
           if        w-rie-num-ele        <    2
                     go to ord-rie-fin-999.
      *              *-------------------------------------------------*
      *              * Ciclo di ordinamento                            *
      *              *-------------------------------------------------*
           move      zero                 to   I                      .
       ord-rie-fin-100.
           add       1                    to   I                      .
           if        I                    =    w-rie-num-ele
                     go to ord-rie-fin-999.
           move      I                    to   J
                                               K                      .
           move      w-rie-cod-iva (I)    to   w-rie-wrk-civ          .
       ord-rie-fin-200.
           add       1                    to   J                      .
           if        J                    >    w-rie-num-ele
                     go to ord-rie-fin-300.
           if        w-rie-cod-iva (J)    >    w-rie-wrk-civ
                     go to ord-rie-fin-200.
           move      J                    to   K                      .
           move      w-rie-cod-iva (J)    to   w-rie-wrk-civ          .
           go to     ord-rie-fin-200.
       ord-rie-fin-300.
           move      I                    to   L                      .          
           if        w-rie-wrk-civ        >    w-rie-cod-iva (L)
                     go to ord-rie-fin-100.
           move      w-rie-sng-ele (K)    to   w-rie-sng-ele (201)    .
           move      w-rie-sng-ele (L)    to   w-rie-sng-ele (K)      .
           move      w-rie-sng-ele (201)  to   w-rie-sng-ele (L)      .
           go to     ord-rie-fin-100.
       ord-rie-fin-999.
           exit.

      *    *===========================================================*
      *    * Stampa asterischi finali                                  *
      *    *-----------------------------------------------------------*
       stp-ast-fin-000.
      *              *-------------------------------------------------*
      *              * Test se da effettuare                           *
      *              *-------------------------------------------------*
           if        p-res                not  > 2
                     go to stp-ast-fin-999.
      *              *-------------------------------------------------*
      *              * Determinazione parametri per stampa             *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Interlinea                                  *
      *                  *---------------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Calcolo lunghezza stringhe di asterischi    *
      *                  * normale (per tutte le linee tranne l'ultima)*
      *                  *---------------------------------------------*
           divide    p-res                into p-sel-als-sel
                                        giving w-ast-lun-nor          .
      *                  *---------------------------------------------*
      *                  * Calcolo lunghezza ultima stringa di aste-   *
      *                  * rischi                                      *
      *                  *---------------------------------------------*
           multiply  w-ast-lun-nor        by   p-res
                                        giving w-ast-num-003
           subtract  w-ast-num-003        from p-sel-als-sel
                                        giving w-ast-lun-ult          .
      *                  *---------------------------------------------*
      *                  * Posizione di stampa iniziale                *
      *                  *---------------------------------------------*
           move      1                    to   w-ast-ctr-pos          .
       stp-ast-fin-100.
      *                  *---------------------------------------------*
      *                  * Ciclo di stampa fino ad esaurimento p-res   *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Stringa di asterischi                   *
      *                      *-----------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "A"                  to   p-tip                  .
           move      w-ast-lun-nor        to   p-car                  .
           if        p-res                =    1
                     add    w-ast-lun-ult to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      w-ast-ctr-pos        to   p-pos                  .
           move      all "*"              to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Test su linee residue                   *
      *                      *-----------------------------------------*
           if        p-res                =    zero
                     go to stp-ast-fin-999.
      *                          *-------------------------------------*
      *                          * Interlinea                          *
      *                          *-------------------------------------*
           move      "LF"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
      *                      * Aggiornamento contatore di posizione    *
      *                      *-----------------------------------------*
           add       w-ast-lun-nor        to   w-ast-ctr-pos          .
      *                      *-----------------------------------------*
      *                      * Riciclo a riga successiva               *
      *                      *-----------------------------------------*
           go to     stp-ast-fin-100.
       stp-ast-fin-999.
           exit.

