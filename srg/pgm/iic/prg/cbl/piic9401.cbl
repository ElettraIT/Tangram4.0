      *              *-------------------------------------------------*
           if        rf-mgi-cod-iva
                    (w-stp-rig-csi-inx)   =   zero
                     go to stp-rig-csi-999.
      *              *-------------------------------------------------*
      *              * Imponibile                                      *
      *              *-------------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           if        rf-mgi-ibl-iva
                    (w-stp-rig-csi-inx)   >    999999999 or
                     rf-mgi-ibl-iva
                    (w-stp-rig-csi-inx)   <   -999999999
                     move  11             to   p-car
           else      move  09             to   p-car                  .
           move      c-dec                to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           if        rf-mgi-ibl-iva
                    (w-stp-rig-csi-inx)   >    999999999 or
                     rf-mgi-ibl-iva
                    (w-stp-rig-csi-inx)   <   -999999999
                     move  "B"            to   p-edm
           else      move  "GB"           to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      071                  to   p-pos                  .
           move      rf-mgi-ibl-iva
                    (w-stp-rig-csi-inx)   to   p-num                  .
           if        rf-mgi-tip-iva       =    "D"
                     multiply -1          by   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Codice iva                                  *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      03                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "B"                  to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      084                  to   p-pos                  .
           move      rf-mgi-cod-iva
                    (w-stp-rig-csi-inx)   to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Imposta                                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se aliquota normale                     *
      *                      *-----------------------------------------*
           if        rf-mgi-cod-iva
                    (w-stp-rig-csi-inx)   >    300 and
                     rf-mgi-cod-iva
                    (w-stp-rig-csi-inx)   <    700
                     go to stp-rig-csi-100.
      *                          *-------------------------------------*
      *                          * Stampa                              *
      *                          *-------------------------------------*
