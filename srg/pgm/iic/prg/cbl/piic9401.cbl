           move      "A"                  to   p-tip                  .
           move      17                   to   p-car                  .
           move      p-lnr                to   p-lin                  .
           move      116                  to   p-pos                  .
           move      "_________________"  to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       prn-liv-det-200.
      *              *-------------------------------------------------*
      *              * Stampa seconda riga di dettaglio                *
      *              *-------------------------------------------------*
