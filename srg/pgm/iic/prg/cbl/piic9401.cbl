           perform   stp-rig-csi-000      thru stp-rig-csi-999        .
      *                  *---------------------------------------------*
      *                  * Totale in valuta base                       *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           if        rf-mgi-tot-doc       >    999999999 or
                     rf-mgi-tot-doc       <   -999999999
                     move  11             to   p-car
           else      move  09             to   p-car                  .
           move      c-dec                to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           if        rf-mgi-tot-doc       >    999999999 or
                     rf-mgi-tot-doc       <   -999999999
                     move  "B"            to   p-edm
           else      move  "GB"           to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      103                  to   p-pos                  .
           move      rf-mgi-tot-doc       to   p-num                  .
           if        rf-mgi-tip-iva       =    "D"
                     multiply -1          by   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
       prn-liv-det-140.
      *                  *---------------------------------------------*
      *                  * Corrispettivo in valuta                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Deviazione in funzione del tipo deter-  *
      *                      * minazione                               *
      *                      *-----------------------------------------*
           if        rr-tpd-civ           =    01
                     go to prn-liv-det-142
           else if   rr-tpd-civ           =    02
                     go to prn-liv-det-144.
       prn-liv-det-142.
      *                      *-----------------------------------------*
      *                      * Tipo determinazione : Da record [iit]   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Start su file [iit]                 *
      *                          *-------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "RIFCGE    "         to   f-key                  .
           move      rf-mgi-dat-reg       to   rf-iit-dtr-cge         .
           move      rf-mgi-num-prt       to   rf-iit-prt-cge         .
           move      zero                 to   rf-iit-dat-reg         .
           move      zero                 to   rf-iit-num-prt         .
           move      "pgm/iic/fls/ioc/obj/iofiit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-iit                 .
      *                              *---------------------------------*
      *                              * Test su esito operazione        *
      *                              *---------------------------------*
           if        f-sts                not  = e-not-err
                     go to prn-liv-det-180.
      *                          *-------------------------------------*
      *                          * Lettura record [iit]                *
      *                          *-------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/iic/fls/ioc/obj/iofiit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-iit                 .
      *                              *---------------------------------*
      *                              * Test se 'At end'                *
      *                              *---------------------------------*
           if        f-sts                not  = e-not-err
                     go to prn-liv-det-180.
      *                          *-------------------------------------*
      *                          * Test sul massimo                    *
      *                          *-------------------------------------*
           if        rf-iit-dtr-cge       not  = rf-mgi-dat-reg or
                     rf-iit-prt-cge       not  = rf-mgi-num-prt
                     go to prn-liv-det-180.
      *                          *-------------------------------------*
      *                          * Se valore a zero : come per non     *
      *                          * trovato                             *
      *                          *-------------------------------------*
           if        rf-iit-tco-eiv       =    zero
                     go to prn-liv-det-180.
      *                          *-------------------------------------*
      *                          * Stampa corrispettivo in valuta      *
      *                          *-------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           if        rf-iit-tco-eiv       >    9999999999 or
                     rf-iit-tco-eiv       <   -9999999999
                     move  13             to   p-car
           else      move  10             to   p-car                  .
           move      03                   to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           if        rf-iit-tco-eiv       >    9999999999 or
                     rf-iit-tco-eiv       <   -9999999999
                     move  "BD"           to   p-edm
           else      move  "GBD"          to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      115                  to   p-pos                  .
           move      rf-iit-tco-eiv       to   p-num                  .
           if        rf-mgi-tip-iva       =    "D"
                     multiply -1          by   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * Oltre                               *
      *                          *-------------------------------------*
           go to     prn-liv-det-200.
       prn-liv-det-144.
      *                      *-----------------------------------------*
