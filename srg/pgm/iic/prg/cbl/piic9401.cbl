           move      c-dec                to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      "GB"                 to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      088                  to   p-pos                  .
           move      rf-mgi-imp-iva
                    (w-stp-rig-csi-inx)   to   p-num                  .
           if        rf-mgi-tip-iva       =    "D"
                     multiply -1          by   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
