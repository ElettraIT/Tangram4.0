      *                  *---------------------------------------------*
      *                  * Forzatura simulata del tasto Return         *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * A controllo tasto Do                        *
      *                  *---------------------------------------------*
           go to     acc-dtr-cge-800.
       acc-dtr-cge-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-dtr-cge-410.
      *                  *---------------------------------------------*
      *                  * Se la data di registrazione e' stata varia- *
      *                  * ta rispetto al valore precedente si accetta *
      *                  * solamente il tasto funzione Return          *
      *                  *---------------------------------------------*
           if        w-tes-dtr-cge (1)    not  = w-acc-dep-cge-svd and
                     v-key                not  = spaces
                     go to acc-dtr-cge-100.
       acc-dtr-cge-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-dtr-cge-610.
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione del valore           *
      *                  *---------------------------------------------*
           if        w-tes-dtr-cge (1)    =    w-acc-dep-cge-svd
                     go to acc-dtr-cge-620
           else if   w-tes-dtr-cge (1)    =    zero
                     go to acc-dtr-cge-630
           else      go to acc-dtr-cge-650.
       acc-dtr-cge-620.
      *                  *---------------------------------------------*
      *                  * Se valore inalterato rispetto al precedente *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Nessuna azione, a controllo tasto Do    *
      *                      *-----------------------------------------*
           go to     acc-dtr-cge-800.
       acc-dtr-cge-630.
      *                  *---------------------------------------------*
      *                  * Se impostazione a zero                      *
      *                  *---------------------------------------------*
       acc-dtr-cge-632.
      *                      *-----------------------------------------*
      *                      * Se il numero di protocollo del movimen- *
      *                      * to di contabilita' generale di riferi-  *
      *                      * mento e' gia' a zero : nessuna azione   *
      *                      *-----------------------------------------*
           if        w-tes-prt-cge (1)    =    zero
                     go to acc-dtr-cge-634.
      *                      *-----------------------------------------*
      *                      * Forzatura a zero del numero di proto-   *
      *                      * collo del movimento di contabilita'     *
      *                      * generale di riferimento                 *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-prt-cge (1)      .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione del numero di proto-  *
      *                      * collo del movimento di contabilita'     *
      *                      * generale di riferimento                 *
      *                      *-----------------------------------------*
           perform   vis-prt-cge-000      thru vis-prt-cge-999        .
       acc-dtr-cge-634.
      *                      *-----------------------------------------*
      *                      * A controllo tasto Do                    *
      *                      *-----------------------------------------*
           go to     acc-dtr-cge-800.
       acc-dtr-cge-650.
      *                  *---------------------------------------------*
      *                  * Se impostazione diversa da zero             *
      *                  *---------------------------------------------*
       acc-dtr-cge-652.
      *                      *-----------------------------------------*
      *                      * Se il numero di protocollo del movimen- *
      *                      * to di contabilita' generale di riferi-  *
      *                      * mento e' gia' a zero : nessuna azione   *
      *                      *-----------------------------------------*
           if        w-tes-prt-cge (1)    =    zero
                     go to acc-dtr-cge-654.
      *                      *-----------------------------------------*
      *                      * Forzatura a zero del numero di proto-   *
      *                      * collo del movimento di contabilita'     *
      *                      * generale di riferimento                 *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-prt-cge (1)      .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione del numero di proto-  *
      *                      * collo del movimento di contabilita'     *
      *                      * generale di riferimento                 *
      *                      *-----------------------------------------*
           perform   vis-prt-cge-000      thru vis-prt-cge-999        .
       acc-dtr-cge-654.
      *                      *-----------------------------------------*
      *                      * A controllo tasto Do                    *
      *                      *-----------------------------------------*
           go to     acc-dtr-cge-800.
       acc-dtr-cge-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-dtr-cge-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-dtr-cge-100.
       acc-dtr-cge-999.
           exit.

      *    *===========================================================*
      *    * Visualizzazione : Data di registrazione del movimento di  *
      *    *                   contabilita' generale di riferimento    *
      *    *-----------------------------------------------------------*
       vis-dtr-cge-000.
           move      "DS"                 to   v-ope                  .
           move      "D"                  to   v-tip                  .
           move      09                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      w-tes-dtr-cge (1)    to   v-dat                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       vis-dtr-cge-999.
           exit.

      *    *===========================================================*
      *    * Accettazione : Numero protocollo del movimento di conta-  *
      *    *                bilita' generale di riferimento            *
      *    *-----------------------------------------------------------*
       acc-prt-cge-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-prt-cge-010.
      *                  *---------------------------------------------*
      *                  * Se data registrazione del movimento di con- *
      *                  * tabilita' generale di riferimento a zero :  *
      *                  * no accettazione ed uscita                   *
      *                  *---------------------------------------------*
           if        w-tes-dtr-cge (1)    =    zero
                     go to acc-prt-cge-999.
       acc-prt-cge-020.
      *                  *---------------------------------------------*
      *                  * Se si e' giunti all'accettazione del campo  *
      *                  * in seguito ad un ritorno indietro con tasto *
      *                  * Up : no accettazione ed uscita, in modo da  *
      *                  * regredire alla data di registrazione        *
      *                  *---------------------------------------------*
           if        v-key                =    "UP  "
                     go to acc-prt-cge-999.
       acc-prt-cge-030.
      *                  *---------------------------------------------*
      *                  * Se sulla data di registrazione era avvenuta *
      *                  * una selezione : a dipendenze da impostazio- *
      *                  * ne, con forzatira del tasto Return          *
      *                  *---------------------------------------------*
           if        w-acc-dep-cge-fsd    not  = spaces
                     move  spaces         to   v-key
                     go to acc-prt-cge-600.
       acc-prt-cge-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      07                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "DO  "               to   v-pfk (05)             .
           move      10                   to   v-lin                  .
           move      73                   to   v-pos                  .
           move      w-tes-prt-cge (1)    to   v-num                  .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-prt-cge-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-prt-cge-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-prt-cge-999.
       acc-prt-cge-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-prt-cge (1)      .
       acc-prt-cge-250.
      *              *-------------------------------------------------*
      *              * Se Find                                         *
      *              *-------------------------------------------------*
           if        v-key                not  = "FIND"
                     go to acc-prt-cge-400.
      *                  *---------------------------------------------*
      *                  * Find su archivio [mgt]                      *
      *                  *---------------------------------------------*
           move      "S"                  to   w-fnd-arc-mgt-sns      .
           move      "C"                  to   w-fnd-arc-mgt-tip      .
           perform   fnd-arc-mgt-000      thru fnd-arc-mgt-999        .
      *                  *---------------------------------------------*
      *                  * Se selezione non effettuata : a reimposta-  *
      *                  * zione                                       *
      *                  *---------------------------------------------*
           if        w-fnd-arc-mgt-sel    not  = spaces
                     go to acc-prt-cge-100.
      *                  *---------------------------------------------*
      *                  * Set del flag di selezione effettuata in ac- *
      *                  * cettazione numero di protocollo             *
      *                  *---------------------------------------------*
           move      "S"                  to   w-acc-dep-cge-fsn      .
      *                  *---------------------------------------------*
      *                  * Ripresa data registrazione di contabilita'  *
      *                  * selezionata                                 *
      *                  *---------------------------------------------*
           move      w-fnd-arc-mgt-dtr    to   w-tes-dtr-cge (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione data registrazione di con-  *
      *                  * tabilita' generale di riferimento           *
      *                  *---------------------------------------------*
           perform   vis-dtr-cge-000      thru vis-dtr-cge-999        .
      *                  *---------------------------------------------*
      *                  * Ripresa numero protocollo di contabilita'   *
      *                  * selezionato                                 *
      *                  *---------------------------------------------*
           move      w-fnd-arc-mgt-prt    to   w-tes-prt-cge (1)      .
      *                  *---------------------------------------------*
      *                  * Visualizzazione numero protocollo di con-   *
      *                  * tabilita' generale di riferimento           *
      *                  *---------------------------------------------*
           perform   vis-prt-cge-000      thru vis-prt-cge-999        .
      *                  *---------------------------------------------*
      *                  * Forzatura simulata del tasto Return         *
      *                  *---------------------------------------------*
           move      spaces               to   v-key                  .
      *                  *---------------------------------------------*
      *                  * A dipendenze dall'impostazione              *
      *                  *---------------------------------------------*
           go to     acc-prt-cge-600.
       acc-prt-cge-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-prt-cge-425.
      *                  *---------------------------------------------*
      *                  * Se valore impostato pari a zero :           *
      *                  *  - Se con tasto Up : uscita                 *
      *                  *  - Altrimenti      : reimpostazione         *
      *                  *---------------------------------------------*
           if        w-tes-prt-cge (1)    =    zero
                     if    v-key          =    "UP  "
                           go to acc-prt-cge-800
                     else  go to acc-prt-cge-100.
       acc-prt-cge-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-prt-cge-610.
      *                  *---------------------------------------------*
      *                  * Se data registrazione e numero protocollo   *
      *                  * sono pari ai valori precedenti : nessuna    *
      *                  * dipendenza dall'impostazione                *
      *                  *---------------------------------------------*
           if        w-tes-dtr-cge (1)    =    w-acc-dep-cge-svd and
                     w-tes-prt-cge (1)    =    w-acc-dep-cge-svn
                     go to acc-prt-cge-800.
       acc-prt-cge-620.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [mgt]                      *
      *                  *---------------------------------------------*
           move      w-tes-dtr-cge (1)    to   w-let-arc-mgt-dtr      .
           move      w-tes-prt-cge (1)    to   w-let-arc-mgt-prt      .
           perform   let-arc-mgt-000      thru let-arc-mgt-999        .
       acc-prt-cge-630.
      *                  *---------------------------------------------*
      *                  * Se record non esistente                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-let-arc-mgt-flg    =    spaces
                     go to acc-prt-cge-640.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Registrazione contabile non esistente in archivio 
      -              "!              "    to   w-err-box-err-msg      .
           perform   box-msg-err-000      thru box-msg-err-999        .
      *                      *-----------------------------------------*
      *                      * Forzatura del numero protocollo a zero  *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-prt-cge (1)      .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione del numero protocollo *
      *                      *-----------------------------------------*
           perform   vis-prt-cge-000      thru vis-prt-cge-999        .
      *                      *-----------------------------------------*
      *                      * Forzatura del tasto Up                  *
      *                      *-----------------------------------------*
           move      "UP  "               to   v-key                  .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     acc-prt-cge-999.
       acc-prt-cge-640.
      *                  *---------------------------------------------*
      *                  * Se tipo movimento iva della registrazione   *
      *                  * non e' congruente                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-let-arc-mgt-tmi    =    "A" or
                     w-let-arc-mgt-tmi    =    "B"
                     go to acc-prt-cge-650.
      *                      *-----------------------------------------*
      *                      * Messaggio di errore                     *
      *                      *-----------------------------------------*
           move      "Il tipo movimento Iva della registrazione contabil
      -              "e              "    to   w-err-box-err-msg      .
           move      "non si riferisce ad un movimento clienti CEE !    
      -              "               "    to   w-err-box-err-m02      .
           perform   box-msg-e02-000      thru box-msg-e02-999        .
      *                      *-----------------------------------------*
      *                      * Forzatura del numero protocollo a zero  *
      *                      *-----------------------------------------*
           move      zero                 to   w-tes-prt-cge (1)      .
      *                      *-----------------------------------------*
      *                      * Rivisualizzazione del numero protocollo *
      *                      *-----------------------------------------*
           perform   vis-prt-cge-000      thru vis-prt-cge-999        .
      *                      *-----------------------------------------*
      *                      * Forzatura del tasto Up                  *
      *                      *-----------------------------------------*
           move      "UP  "               to   v-key                  .
      *                      *-----------------------------------------*
      *                      * Uscita                                  *
      *                      *-----------------------------------------*
           go to     acc-prt-cge-999.
       acc-prt-cge-650.
      *                  *---------------------------------------------*
      *                  * Determinazione delle informazioni correlate *
      *                  * alla registrazione contabile                *
      *                  *---------------------------------------------*
       acc-prt-cge-660.
      *                      *-----------------------------------------*
      *                      * Se non si e' in Inserimento : nessuna   *
      *                      * determinazione, continuazione           *
      *                      *-----------------------------------------*
           if        w-cnt-mfu-tip-fun    not  = "I"
                     go to acc-prt-cge-720.
      *                      *-----------------------------------------*
      *                      * Se il codice cliente e' gia' stato      *
      *                      * determinato : nessuna determinazione,   *
      *                      * continuazione                           *
      *                      *-----------------------------------------*
           if        w-tes-cod-arc (1)    not  = zero
                     go to acc-prt-cge-720.
       acc-prt-cge-670.
      *                      *-----------------------------------------*
      *                      * Determinazione del cliente, e dei dati  *
      *                      * ad esso correlati, dalla registrazione  *
      *                      * contabile                               *
      *                      *-----------------------------------------*
           move      w-tes-dtr-cge (1)    to   w-det-cli-mgt-dtr      .
           move      w-tes-prt-cge (1)    to   w-det-cli-mgt-prt      .
           perform   det-cli-mgt-000      thru det-cli-mgt-999        .
       acc-prt-cge-680.
      *                      *-----------------------------------------*
      *                      * Se cliente non determinato              *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Test                                *
      *                          *-------------------------------------*
           if        w-det-cli-mgt-flg    =    spaces
                     go to acc-prt-cge-690.
      *                          *-------------------------------------*
      *                          * Continuazione                       *
      *                          *-------------------------------------*
           go to     acc-prt-cge-720.
       acc-prt-cge-690.
      *                      *-----------------------------------------*
      *                      * Forzatura valori da record cliente      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Codice cliente                      *
      *                          *-------------------------------------*
           move      w-det-cli-mgt-cli    to   w-tes-cod-arc (1)      .
      *                          *-------------------------------------*
      *                          * Codice cliente, ragione sociale     *
      *                          *-------------------------------------*
           move      w-det-cli-mgt-rag    to   w-tes-cod-arc-rag (1)  .
      *                          *-------------------------------------*
      *                          * Codice cliente, codice nazione      *
      *                          *-------------------------------------*
           move      w-det-cli-mgt-naz    to   w-tes-cod-arc-naz (1)  .
      *                          *-------------------------------------*
      *                          * Codice ISO dello Stato membro CEE   *
      *                          * cui il cliente appartiene           *
      *                          *-------------------------------------*
           move      w-det-cli-mgt-naz    to   w-tes-iso-opc (1)      .
      *                          *-------------------------------------*
      *                          * Codice Iva del cliente              *
      *                          *-------------------------------------*
           move      w-det-cli-mgt-cfi    to   w-tes-cdi-opi (1)      .
       acc-prt-cge-700.
      *                      *-----------------------------------------*
      *                      * Valori indotti da dati associati al     *
      *                      * cliente                                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Codice ISO dello Stato membro CEE   *
      *                          * cui il cliente appartiene, descri-  *
      *                          * zione                               *
      *                          *-------------------------------------*
           move      w-tes-iso-opc (1)    to   w-let-arc-gxn-cod      .
           perform   let-arc-gxn-000      thru let-arc-gxn-999        .
           if        w-let-arc-gxn-flg    =    spaces  and
                     w-let-arc-gxn-cee    =    "S"
                     move  w-let-arc-gxn-des
                                          to   w-tes-iso-opc-des (1)
           else      move  spaces         to   w-tes-iso-opc (1)
                     move  spaces         to   w-tes-iso-opc-des (1)  .
       acc-prt-cge-710.
      *                      *-----------------------------------------*
      *                      * Visualizzazione valori determinati      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Codice cliente                      *
      *                          *-------------------------------------*
           perform   vis-cod-cli-000      thru vis-cod-cli-999        .
      *                          *-------------------------------------*
      *                          * Codice cliente, ragione sociale     *
      *                          *-------------------------------------*
           perform   vis-cod-cli-rag-000  thru vis-cod-cli-rag-999    .
      *                          *-------------------------------------*
      *                          * Codice ISO dello stato membro CEE   *
      *                          * cui il cliente appartiene           *
      *                          *-------------------------------------*
           perform   vis-iso-opc-000      thru vis-iso-opc-999        .
      *                          *-------------------------------------*
      *                          * Codice ISO dello stato membro CEE   *
      *                          * cui il cliente appartiene, descri-  *
      *                          * zione                               *
      *                          *-------------------------------------*
           perform   vis-iso-opc-des-000  thru vis-iso-opc-des-999    .
      *                          *-------------------------------------*
      *                          * Codice Iva del cliente estero       *
      *                          *-------------------------------------*
           perform   vis-cdi-opi-000      thru vis-cdi-opi-999        .
       acc-prt-cge-720.
      *                  *---------------------------------------------*
      *                  * Controllo che non esistano altri movimenti  *
      *                  * Iva intracomunitaria che si riferiscano al- *
      *                  * lo stesso movimento contabile               *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Subroutine di controllo                 *
      *                      *-----------------------------------------*
           perform   ctl-iic-cge-000      thru ctl-iic-cge-999        .
      *                      *-----------------------------------------*
      *                      * Se controllo non superato : a reimpo-   *
      *                      * stazione                                *
      *                      *-----------------------------------------*
           if        w-ctl-iic-cge-flg    not  = spaces
                     go to acc-prt-cge-100.
       acc-prt-cge-730.
      *                  *---------------------------------------------*
      *                  * A controllo tasto Do                        *
      *                  *---------------------------------------------*
           go to     acc-prt-cge-800.
      *                      *-----------------------------------------*
      *                      * A controllo tasto Do                    *
      *                      *-----------------------------------------*
           go to     acc-prt-cge-800.
       acc-prt-cge-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
           if        v-key                =    "DO  "
                     perform cnt-tdo-nok-000
                                          thru cnt-tdo-nok-999
                     if      w-cnt-tdo-nok-flg
                                          =    spaces
                             move  "S"    to   w-cnt-tus-acc-tes
                             go to acc-prt-cge-999
                     else    move  spaces to   w-cnt-tdo-nok-flg
                             go to acc-prt-cge-100.
       acc-prt-cge-999.
           exit.

      *    *===========================================================*
      *    * Subroutine per il controllo che non esistano altri movi-  *
      *    * menti Iva intracomunitaria che si riferiscano allo stes-  *
      *    * so movimento contabile                                    *
      *    *-----------------------------------------------------------*
       ctl-iic-cge-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di uscita                  *
      *              *-------------------------------------------------*
           move      spaces               to   w-ctl-iic-cge-flg      .
      *              *-------------------------------------------------*
      *              * Data registrazione Iva intracomunitaria a zero  *
      *              *-------------------------------------------------*
           move      zero                 to   w-ctl-iic-cge-dat      .
      *              *-------------------------------------------------*
      *              * Tipo registrazione Iva intracomunitaria a zero  *
      *              *-------------------------------------------------*
           move      zero                 to   w-ctl-iic-cge-tip      .
      *              *-------------------------------------------------*
      *              * Numero protocollo registrazione Iva intracomu-  *
      *              * nitaria a zero                                  *
      *              *-------------------------------------------------*
           move      zero                 to   w-ctl-iic-cge-prt      .
      *              *-------------------------------------------------*
      *              * Se si e' in Visualizzazione : nessun controllo  *
      *              * ed uscita immediata                             *
      *              *-------------------------------------------------*
           if        w-cnt-mfu-tip-fun    =    "V"
                     go to ctl-iic-cge-999.
      *              *-------------------------------------------------*
      *              * Se non e' citata una registrazione contabile :  *
      *              * nessun controllo ed uscita immediata            *
      *              *-------------------------------------------------*
           if        w-tes-dtr-cge (1)    =    zero or
                     w-tes-prt-cge (1)    =    zero
                     go to ctl-iic-cge-999.
       ctl-iic-cge-100.
      *              *-------------------------------------------------*
      *              * Start su [iit] per riferimento contabile        *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "RIFCGE    "         to   f-key                  .
           move      w-tes-dtr-cge (1)    to   rf-iit-dtr-cge         .
           move      w-tes-prt-cge (1)    to   rf-iit-prt-cge         .
           move      zero                 to   rf-iit-dat-reg         .
           move      zero                 to   rf-iit-num-prt         .
           move      "pgm/iic/fls/ioc/obj/iofiit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-iit                 .
      *              *-------------------------------------------------*
      *              * Se Start errata : uscita                        *
      *              *-------------------------------------------------*
