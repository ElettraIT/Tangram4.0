      *    *===========================================================*
      *    * Accettazione : Codice ISO del paese di origine delle mer- *
      *    *                ci                                         *
      *    *-----------------------------------------------------------*
       acc-iso-org-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-iso-org-010.
      *                  *---------------------------------------------*
      *                  * Eventuale preparazione del valore di de-    *
      *                  * fault pari al codice ISO dello stato CEE    *
      *                  * di provenienza delle merci                  *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Se valore gia' presente : no prepara-   *
      *                      * zione default                           *
      *                      *-----------------------------------------*
           if        w-rig-iso-org (1)    not  = spaces
                     go to acc-iso-org-020.
      *                      *-----------------------------------------*
      *                      * Si pone il codice ISO dello Stato di o- *
      *                      * rigine delle merci pari al coduce ISO   *
      *                      * di provenienza o destinazione delle     *
      *                      * merci                                   *
      *                      *-----------------------------------------*
           move      w-tes-iso-pod (1)    to   w-rig-iso-org (1)      .
      *                      *-----------------------------------------*
      *                      * Si determina inoltre la descrizione per *
      *                      * il codice ISO dello Stato di origine    *
      *                      * delle merci                             *
      *                      *-----------------------------------------*
           move      w-rig-iso-org (1)    to   w-let-arc-gxn-cod      .
           perform   let-arc-gxn-000      thru let-arc-gxn-999        .
           if        w-let-arc-gxn-flg    =    spaces  and
                     w-let-arc-gxn-cee    =    "S"
                     move  w-let-arc-gxn-des
                                          to   w-rig-iso-org-des (1)
           else      move  spaces         to   w-rig-iso-org (1)
                     move  spaces         to   w-rig-iso-org-des (1)  .
       acc-iso-org-020.
      *                  *---------------------------------------------*
      *                  * Pre-visualizzazione                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice                                  *
      *                      *-----------------------------------------*
           perform   vis-iso-org-000      thru vis-iso-org-999        .
      *                      *-----------------------------------------*
      *                      * Descrizione                             *
      *                      *-----------------------------------------*
           perform   vis-iso-org-des-000  thru vis-iso-org-des-999    .
       acc-iso-org-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cde-iso-cee-ope      .
           move      w-rig-iso-org (1)    to   w-cde-iso-cee-iso      .
           move      21                   to   w-cde-iso-cee-lin      .
           move      30                   to   w-cde-iso-cee-pos      .
           move      21                   to   w-cde-iso-cee-dln      .
           move      41                   to   w-cde-iso-cee-dps      .
           move      spaces               to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           if        w-cnt-sts-imp-rig    not  = spaces
                     move  "DO  "         to   v-pfk (05)             .
           move      "REMV"               to   v-pfk (06)             .
           perform   cde-iso-cee-cll-000  thru cde-iso-cee-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cde-iso-cee-foi-000  thru cde-iso-cee-foi-999    .
       acc-iso-org-110.
           perform   cde-iso-cee-cll-000  thru cde-iso-cee-cll-999    .
           if        w-cde-iso-cee-ope    =    "F+"
                     go to acc-iso-org-115.
           if        w-cde-iso-cee-ope    =    "AC"
                     go to acc-iso-org-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-iso-org-115.
           perform   cde-iso-cee-foi-000  thru cde-iso-cee-foi-999    .
           go to     acc-iso-org-110.
       acc-iso-org-120.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-rig
                     go to acc-iso-org-999.
      *              *-------------------------------------------------*
      *              * Se Remv                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "REMV"
                     move  "R"            to   w-cnt-tus-acc-rig
                     go to acc-iso-org-999.
      *              *-------------------------------------------------*
      *              * Valore impostato                                *
      *              *-------------------------------------------------*
           move      v-alf                to   w-rig-iso-org (1)      .
       acc-iso-org-400.
