      *    *===========================================================*
      *    * Accettazione : Codice cliente                             *
      *    *-----------------------------------------------------------*
       acc-cod-cli-000.
      *              *-------------------------------------------------*
      *              * Pre-accettazione                                *
      *              *-------------------------------------------------*
       acc-cod-cli-010.
      *                  *---------------------------------------------*
      *                  * Salvataggio codice cliente precedente       *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-acc-cod-cli-svc      .
       acc-cod-cli-100.
      *              *-------------------------------------------------*
      *              * Accettazione valore                             *
      *              *-------------------------------------------------*
           move      "AC"                 to   w-cod-mne-cli-ope      .
           move      w-tes-cod-arc (1)    to   w-cod-mne-cli-cod      .
           move      12                   to   w-cod-mne-cli-lin      .
           move      30                   to   w-cod-mne-cli-pos      .
           move      12                   to   w-cod-mne-cli-rln      .
           move      41                   to   w-cod-mne-cli-rps      .
           move      zero                 to   w-cod-mne-cli-vln      .
           move      zero                 to   w-cod-mne-cli-vps      .
           move      zero                 to   w-cod-mne-cli-lln      .
           move      zero                 to   w-cod-mne-cli-lps      .
           move      "<B"                 to   v-edm                  .
           move      "UP  "               to   v-pfk (01)             .
           move      "DOWN"               to   v-pfk (02)             .
           move      "FIND"               to   v-pfk (03)             .
           move      "INSR"               to   v-pfk (04)             .
           move      "DO  "               to   v-pfk (05)             .
           perform   cod-mne-cli-cll-000  thru cod-mne-cli-cll-999    .
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
           perform   cod-mne-cli-foi-000  thru cod-mne-cli-foi-999    .
       acc-cod-cli-110.
           perform   cod-mne-cli-cll-000  thru cod-mne-cli-cll-999    .
           if        w-cod-mne-cli-ope    =    "F+"
                     go to acc-cod-cli-115.
           if        w-cod-mne-cli-ope    =    "AC"
                     go to acc-cod-cli-120.
           perform   exe-acc-cmp-000      thru exe-acc-cmp-999        .
       acc-cod-cli-115.
           perform   cod-mne-cli-foi-000  thru cod-mne-cli-foi-999    .
           go to     acc-cod-cli-110.
       acc-cod-cli-120.
           move      w-cod-mne-cli-cod    to   v-num                  .
       acc-cod-cli-150.
      *              *-------------------------------------------------*
      *              * Se Exit                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "EXIT"
                     move  "E"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cli-999.
      *              *-------------------------------------------------*
      *              * Se Delt                                         *
      *              *-------------------------------------------------*
           if        v-key                =    "DELT"
                     move  "X"            to   w-cnt-tus-acc-tes
                     go to acc-cod-cli-999.
       acc-cod-cli-200.
      *              *-------------------------------------------------*
      *              * Valore impostato in campo di destinazione       *
      *              *-------------------------------------------------*
           move      v-num                to   w-tes-cod-arc (1)      .
       acc-cod-cli-400.
      *              *-------------------------------------------------*
      *              * Controllo valore impostato                      *
      *              *-------------------------------------------------*
       acc-cod-cli-410.
      *                  *---------------------------------------------*
      *                  * Lettura archivio [cli]                      *
      *                  *---------------------------------------------*
           move      w-tes-cod-arc (1)    to   w-let-arc-cli-cod      .
           perform   let-arc-cli-000      thru let-arc-cli-999        .
      *                  *---------------------------------------------*
      *                  * Memorizzazione ragione sociale cliente      *
      *                  *---------------------------------------------*
           move      w-let-arc-cli-rag    to   w-tes-cod-arc-rag (1)  .
      *                  *---------------------------------------------*
      *                  * Memorizzazione codice nazione cliente       *
      *                  *---------------------------------------------*
           move      w-let-arc-cli-naz    to   w-tes-cod-arc-naz (1)  .
      *                  *---------------------------------------------*
      *                  * Visualizzazione ragione sociale cliente     *
      *                  *---------------------------------------------*
           perform   vis-cod-cli-rag-000  thru vis-cod-cli-rag-999    .
       acc-cod-cli-420.
      *                  *---------------------------------------------*
      *                  * Se codice non esistente o a zero            *
      *                  *---------------------------------------------*
       acc-cod-cli-422.
      *                      *-----------------------------------------*
      *                      * Test                                    *
      *                      *-----------------------------------------*
           if        w-let-arc-cli-flg    =    spaces and
                     w-tes-cod-arc (1)    not  = zero
                     go to acc-cod-cli-440.
       acc-cod-cli-424.
      *                      *-----------------------------------------*
      *                      * Se codice cliente precedente a zero :   *
      *                      * nessuna azione, continuazione per test  *
      *                      * se reimpostazione o uscita              *
      *                      *-----------------------------------------*
           if        w-acc-cod-cli-svc    =    zero
                     go to acc-cod-cli-432.
       acc-cod-cli-426.
      *                      *-----------------------------------------*
      *                      * Normalizzazione dati associati al cli-  *
      *                      * ente, se possibile e necessario         *
      *                      *-----------------------------------------*
       acc-cod-cli-428.
      *                          *-------------------------------------*
      *                          * Codice cliente, codice nazione      *
      *                          *-------------------------------------*
           move      spaces               to   w-tes-cod-arc-naz (1)  .
      *                          *-------------------------------------*
      *                          * Codice ISO dello Stato membro CEE   *
      *                          * cui il cliente appartiene           *
      *                          *-------------------------------------*
           move      spaces               to   w-tes-iso-opc (1)      .
      *                          *-------------------------------------*
      *                          * Codice ISO dello Stato membro CEE   *
      *                          * cui il cliente appartiene, descri-  *
      *                          * zione                               *
      *                          *-------------------------------------*
           move      spaces               to   w-tes-iso-opc-des (1)  .
      *                          *-------------------------------------*
      *                          * Codice Iva del cliente              *
      *                          *-------------------------------------*
           move      spaces               to   w-tes-cdi-opi (1)      .
       acc-cod-cli-430.
      *                      *-----------------------------------------*
      *                      * Visualizzazione dati normalizzati       *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Codice ISO dello stato membro CEE   *
      *                          * cui il cliente appartiene           *
      *                          *-------------------------------------*
           perform   vis-iso-opc-000      thru vis-iso-opc-999        .
      *                          *-------------------------------------*
      *                          * Codice ISO dello stato membro CEE   *
      *                          * cui il cliente appartiene, descri-  *
      *                          * zione                               *
      *                          *-------------------------------------*
           perform   vis-iso-opc-des-000  thru vis-iso-opc-des-999    .
      *                          *-------------------------------------*
      *                          * Codice Iva del cliente estero       *
      *                          *-------------------------------------*
           perform   vis-cdi-opi-000      thru vis-cdi-opi-999        .
       acc-cod-cli-432.
      *                      *-----------------------------------------*
      *                      * Se valore impostato pari a zero e con   *
      *                      * tasto Up : uscita, altrimenti reimpo-   *
      *                      * stazione                                *
      *                      *-----------------------------------------*
           if        w-tes-cod-arc (1)    =    zero and
                     v-key                =    "UP  "
                     go to acc-cod-cli-800
           else      go to acc-cod-cli-100.
       acc-cod-cli-440.
      *                  *---------------------------------------------*
      *                  * Fine controlli : a dipendenze               *
      *                  *---------------------------------------------*
           go to     acc-cod-cli-600.
       acc-cod-cli-600.
      *              *-------------------------------------------------*
      *              * Dipendenze dall'impostazione                    *
      *              *-------------------------------------------------*
       acc-cod-cli-610.
      *                  *---------------------------------------------*
      *                  * Se il codice cliente impostato e' pari al   *
      *                  * valore precedente : nessuna dipendenza dal- *
      *                  * l'impostazione                              *
      *                  *---------------------------------------------*
           if        w-tes-cod-arc (1)    =    w-acc-cod-cli-svc
                     go to acc-cod-cli-800.
       acc-cod-cli-620.
      *                      *-----------------------------------------*
      *                      * Forzatura valori da record cliente      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Codice ISO dello Stato membro CEE   *
      *                          * cui il cliente appartiene           *
      *                          *-------------------------------------*
           move      w-let-arc-cli-naz    to   w-tes-iso-opc (1)      .
      *                          *-------------------------------------*
      *                          * Codice Iva del cliente              *
      *                          *-------------------------------------*
           move      w-let-arc-cli-cfi    to   w-tes-cdi-opi (1)      .
       acc-cod-cli-630.
      *                      *-----------------------------------------*
      *                      * Valori indotti da dati associati al     *
      *                      * cliente                                 *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Codice ISO dello Stato membro CEE   *
      *                          * cui il cliente appartiene, descri-  *
      *                          * zione                               *
      *                          *-------------------------------------*
           move      w-tes-iso-opc (1)    to   w-let-arc-gxn-cod      .
           perform   let-arc-gxn-000      thru let-arc-gxn-999        .
           if        w-let-arc-gxn-flg    =    spaces  and
                     w-let-arc-gxn-cee    =    "S"
                     move  w-let-arc-gxn-des
                                          to   w-tes-iso-opc-des (1)
           else      move  spaces         to   w-tes-iso-opc (1)
                     move  spaces         to   w-tes-iso-opc-des (1)  .
       acc-cod-cli-640.
      *                      *-----------------------------------------*
      *                      * Visualizzazione valori determinati      *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Codice ISO dello stato membro CEE   *
      *                          * cui il cliente appartiene           *
      *                          *-------------------------------------*
           perform   vis-iso-opc-000      thru vis-iso-opc-999        .
      *                          *-------------------------------------*
      *                          * Codice ISO dello stato membro CEE   *
      *                          * cui il cliente appartiene, descri-  *
      *                          * zione                               *
      *                          *-------------------------------------*
           perform   vis-iso-opc-des-000  thru vis-iso-opc-des-999    .
      *                          *-------------------------------------*
      *                          * Codice Iva del cliente estero       *
      *                          *-------------------------------------*
           perform   vis-cdi-opi-000      thru vis-cdi-opi-999        .
       acc-cod-cli-650.
      *                      *-----------------------------------------*
      *                      * A controllo tasto Do                    *
      *                      *-----------------------------------------*
           go to     acc-cod-cli-800.
       acc-cod-cli-800.
      *              *-------------------------------------------------*
      *              * Se Do                                           *
      *              *-------------------------------------------------*
