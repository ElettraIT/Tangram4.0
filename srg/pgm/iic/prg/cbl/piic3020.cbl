      *                      *-----------------------------------------*
           if        w-prs-mul-gia-snx    =    "S"
                     move  w-prs-mul-gia-max
                                          to   w-det-dat-min-n9a
           else      move  zero           to   w-det-dat-min-n9a      .
      *                      *-----------------------------------------*
      *                      * Contatore su numerazioni                *
      *                      *-----------------------------------------*
           move      zero                 to   w-det-dat-min-c01      .
       det-dat-min-200.
      *                  *---------------------------------------------*
      *                  * Open numerazione acquisti                   *
      *                  *---------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/cge/num/ioc/obj/ingivacq"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-giv-acq             .
       det-dat-min-250.
      *                  *---------------------------------------------*
      *                  * Lettura numerazione acquisti                *
      *                  *---------------------------------------------*
           move      "RD"                 to   f-ope                  .
           move      w-det-dat-min-c01    to   rn-giv-acq-cod-num     .
           move      "pgm/cge/num/ioc/obj/ingivacq"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-giv-acq             .
      *                  *---------------------------------------------*
