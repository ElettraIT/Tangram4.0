      *                  * Next su [iit] per data                      *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/iic/fls/ioc/obj/iofiit"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-iit                 .
      *                  *---------------------------------------------*
      *                  * Se fine file : uscita per errore            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     move  "#"            to   w-cnt-prn-flg-sub
                     go to prn-let-seq-999.
       prn-let-seq-300.
      *                  *---------------------------------------------*
      *                  * Test max su [iit], se non superato : uscita *
      *                  * per errore                                  *
      *                  *---------------------------------------------*
           if        rf-iit-dat-reg       >    w-stp-ttl-dat-max
                     move  "#"            to   w-cnt-prn-flg-sub
                     go to prn-let-seq-999.
       prn-let-seq-350.
      *                  *---------------------------------------------*
      *                  * Selezione su [iit], se non superata : rici- *
      *                  * clo a lettura [iit] successivi              *
      *                  *---------------------------------------------*
           if        rf-iit-top-iic       not  = 0011
                     go to prn-let-seq-250.
       prn-let-seq-400.
      *                  *---------------------------------------------*
      *                  * Start su [iir]                              *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "DATREG    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      rf-iit-dat-reg       to   rf-iir-dat-reg         .
