           if        w-exe-ttd-txt        =    spaces
                     move  "&nbsp;"       to   w-exe-ttd-txt          .
      *                  *---------------------------------------------*
      *                  * Larghezza                                   *
      *                  *---------------------------------------------*
           if        w-exe-ttd-wdt        =    "S"
                     move  "width='20%'" 
                                          to   w-exe-ttd-wdw
           else if   w-exe-ttd-all        =    "M"
                     move  "width='40%'" 
                                          to   w-exe-ttd-wdw
           else if   w-exe-ttd-all        =    "B"
                     move  "width='80%'" 
                                          to   w-exe-ttd-wdw
           else      move  spaces         to   w-exe-ttd-wdw          .
