           if        w-exe-ttd-snh        =    spaces or
                     w-exe-ttd-snh        =    "N"
                     move  "<td"          to   w-exe-ttd-tg1
                     move  "</td>"        to   w-exe-ttd-tg2
           else      move  "<th"          to   w-exe-ttd-tg1
                     move  "</th>"        to   w-exe-ttd-tg2          .
      *                  *---------------------------------------------*
      *                  * Testo                                       *
