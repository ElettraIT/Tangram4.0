                     move  "align='left'" 
                                          to   w-exe-ttd-alw
           else if   w-exe-ttd-all        =    "R"
                     move  "align='right'"
                                          to   w-exe-ttd-alw
           else if   w-exe-ttd-all        =    "C"
                     move  "align='center'"
                                          to   w-exe-ttd-alw
           else      move  spaces         to   w-exe-ttd-alw          .
      *                  *---------------------------------------------*
      *                  * Colonne                                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Editing                                 *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      02                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<B"                 to   p-edm                  .
           move      w-exe-ttd-col        to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                      *-----------------------------------------*
