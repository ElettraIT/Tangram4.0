           move      w-exe-ttd-st1        to   w-all-str-cat (6)      .
           move      w-exe-ttd-txt        to   w-all-str-cat (7)      .
           move      w-exe-ttd-txt
                    (81 : 40)             to   w-all-str-cat (8)      .
