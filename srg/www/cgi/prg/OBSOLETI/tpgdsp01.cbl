      *    *===========================================================*
      *    * Ciclo di lettura e preparazione html                      *
      *    *-----------------------------------------------------------*
       exe-cph-000.
      *              *-------------------------------------------------*
      *              * Esecuzione sort                                 *
      *              *-------------------------------------------------*
           sort      srt                  on   ascending srt-key
                     input  procedure     is   exe-cph-inp-000
                                          thru exe-cph-inp-999
                     output procedure     is   prn-rou-pri-000
                                          thru prn-rou-pri-999        .
       exe-cph-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-cph-999.
       exe-cph-999.
           exit.

      *    *===========================================================*
      *    * Ciclo di lettura e preparazione html                      *
      *    *                                                           *
      *    * Subroutine di Input per il sort                           *
      *    *-----------------------------------------------------------*
       exe-cph-inp-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione contatore record per file di    *
      *              * appoggio kk0                                    *
      *              *-------------------------------------------------*
           move      zero                 to   w-exe-cph-inp-kk0      .
      *              *-------------------------------------------------*
      *              * Start su archivio [hct]                         *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "IDEDOC    "         to   f-key                  .
           move      rr-dat-min           to   rf-hct-dat-reg         .
           move      spaces               to   rf-hct-cod-tcl         .
           move      zero                 to   rf-hct-num-prt         .
           move      "tpg/gct/fls/ioc/obj/iofhct"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-hct                 .
      *                  *---------------------------------------------*
      *                  * Se Start errata : uscita                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exe-cph-inp-999.
       exe-cph-inp-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale archivio [hct]              *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "tpg/gct/fls/ioc/obj/iofhct"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-hct                 .
      *                  *---------------------------------------------*
      *                  * Se fine file :  uscita                      *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exe-cph-inp-999.
       exe-cph-inp-300.
      *              *-------------------------------------------------*
      *              * Test max                                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su data max                            *
      *                  *---------------------------------------------*
           if        rf-hct-dat-reg       >    rr-dat-max
                     go to exe-cph-inp-999.
       exe-cph-inp-400.
      *              *-------------------------------------------------*
      *              * Selezioni                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su data chiusura                       *
      *                  *---------------------------------------------*
           if        rf-hct-dat-chi       not  = zero
                     go to exe-cph-inp-200.
       exe-cph-inp-420.
      *                  *---------------------------------------------*
      *                  * Normalizzazione record [hst]                *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "tpg/gct/fls/ioc/obj/iofhst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-hst                 .
      *                  *---------------------------------------------*
      *                  * Lettura della scheda tecnica commessa       *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      rf-hct-num-prt       to   rf-hst-prt-cml         .
           move      "tpg/gct/fls/ioc/obj/iofhst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-hst                 .
      *                      *-----------------------------------------*
      *                      * Se record non trovato : riciclo         *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exe-cph-inp-200.
       exe-cph-inp-500.
      *              *-------------------------------------------------*
      *              * Inizio ciclo di scansione del castelletto mate- *
      *              * rie prime per individuare la quantita' ancora   *
      *              * impegnata                                       *
      *              *-------------------------------------------------*
           move      zero                 to   w-exe-cph-inp-ctr      .
       exe-cph-inp-520.
           add       1                    to   w-exe-cph-inp-ctr      .
           if        w-exe-cph-inp-ctr    >    6
                     go to exe-cph-inp-860.
      *                  *---------------------------------------------*
      *                  * Test preliminare su codice e quantita'      *
      *                  * materia prima                               *
      *                  *---------------------------------------------*
           if        rf-hst-mnm-num
                    (w-exe-cph-inp-ctr)   =    zero
                     go to exe-cph-inp-520.
           if        rf-hst-mnm-qta
                    (w-exe-cph-inp-ctr)   =    zero
                     go to exe-cph-inp-520.
      *                  *---------------------------------------------*
      *                  * Determinazione della quantita' gia' scari-  *
      *                  * cata                                        *
      *                  *---------------------------------------------*
           move      rf-hct-num-prt       to   w-det-qcl-map-cml      .
           move      rf-hst-mnm-num
                    (w-exe-cph-inp-ctr)   to   w-det-qcl-map-cod      .
           perform   det-qcl-map-000      thru det-qcl-map-999        .
      *                  *---------------------------------------------*
      *                  * Se la quantita' impegnata e' inferiore a    *
      *                  * quella scaricata, riciclo                   *
      *                  *---------------------------------------------*
           if        rf-hst-mnm-qta
                    (w-exe-cph-inp-ctr)   not  > w-det-qcl-map-qta
                     go to exe-cph-inp-520.
       exe-cph-inp-540.
      *                  *---------------------------------------------*
      *                  * Lettura record [dpm]                        *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione record                  *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dpm/fls/ioc/obj/iofdpm"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dpm                 .
      *                      *-----------------------------------------*
      *                      * Codice alfanumerico materia prima       *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMMAP    "         to   f-key                  .
           move      rf-hst-mnm-num
                    (w-exe-cph-inp-ctr)   to   rf-dpm-num-map         .
           move      "pgm/dpm/fls/ioc/obj/iofdpm"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dpm                 .
      *                      *-----------------------------------------*
      *                      * Se codice non trovato : riciclo         *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exe-cph-inp-840.
       exe-cph-inp-560.
      *                  *---------------------------------------------*
      *                  * Selezione su record [dpm] letto             *
      *                  *---------------------------------------------*
           move      "SE"                 to   f-ope                  .
           move      "pgm/dpm/prg/obj/bzosdpm0"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dpm                 .
      *                      *-----------------------------------------*
      *                      * Se selezione non superata : a riciclo   *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exe-cph-inp-840.
       exe-cph-inp-580.
      *                  *---------------------------------------------*
      *                  * Determinazione saldo di magazzino per la    *
      *                  * dipendenza richiesta solo se unica          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Data di sistema                         *
      *                      *-----------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *                      *-----------------------------------------*
      *                      * Preparazione link-area                  *
      *                      *-----------------------------------------*
           move      "SL"                 to   d-sld-mag-tip-ope      .
           move      0000                 to   d-sld-mag-tip-sld      .
           move      w-exe-dat-exe        to   d-sld-mag-dat-sld      .
           move      "U"                  to   d-sld-mag-uot-dpz      .
           move      01                   to   d-sld-mag-cod-dpz      .
           move      03                   to   d-sld-mag-tip-mag      .
           move      rf-dpm-num-map       to   d-sld-mag-num-mag      .
           move      "T"                  to   d-sld-mag-uot-var      .
           move      spaces               to   d-sld-mag-var-mag      .
           move      "T"                  to   d-sld-mag-uot-dsl      .
           move      spaces               to   d-sld-mag-cod-dsl      .
      *                      *-----------------------------------------*
      *                      * Richiamo del sottoprogramma             *
      *                      *-----------------------------------------*
           move      "pgm/mag/prg/obj/pmag300y"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using d-sld-mag              .
       exe-cph-inp-590.
      *                  *---------------------------------------------*
      *                  * Determinazione ordinato                     *
      *                  *---------------------------------------------*
           move      rf-dpm-num-map       to   w-det-orf-map-cod      .
           perform   det-orf-map-000      thru det-orf-map-999        .
       exe-cph-inp-595.
      *                  *---------------------------------------------*
      *                  * Scrittura in file d'appoggio                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Incremento contatore record per file di *
      *                      * appoggio kk0                            *
      *                      *-----------------------------------------*
           add       1                    to   w-exe-cph-inp-kk0      .
      *                      *-----------------------------------------*
      *                      * Composizione record file di appoggio    *
      *                      * [kk0]                                   *
      *                      *-----------------------------------------*
      *                          *-------------------------------------*
      *                          * Area chiave                         *
      *                          *-------------------------------------*
           move      rf-dpm-num-map       to   kk0-num-map            .
           move      rf-hct-num-prt       to   kk0-prt-cml            .
           move      w-exe-cph-inp-kk0    to   kk0-ctr-prg            .
      *                          *-------------------------------------*
      *                          * Area dati                           *
      *                          *-------------------------------------*
           move      w-exe-cph-inp-ctr    to   kk0-cod-tip            .
           move      rf-hst-mnm-qta
                    (w-exe-cph-inp-ctr)   to   kk0-qta-imp            .
           move      w-det-qcl-map-qta    to   kk0-qta-sca            .
      *                      *-----------------------------------------*
      *                      * Scrittura record [kk0]                  *
      *                      *-----------------------------------------*
           write     kk0-rec                                          .
       exe-cph-inp-600.
      *              *-------------------------------------------------*
      *              * Composizione del record di Sort                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Composizione chiave                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Protocollo commessa chiave              *
      *                      *-----------------------------------------*
           move      rf-hct-num-prt       to   srt-prt-key            .
      *                      *-----------------------------------------*
      *                      * Tipo carta nell'ambito della commessa   *
      *                      *-----------------------------------------*
           move      w-exe-cph-inp-ctr    to   srt-cod-tip            .
      *                      *-----------------------------------------*
      *                      * Codice alfanumerico materia prima       *
      *                      *-----------------------------------------*
           move      rf-dpm-alf-map       to   srt-alf-map            .
      *                      *-----------------------------------------*
      *                      * Data commessa                           *
      *                      *-----------------------------------------*
           move      rf-hct-dat-reg       to   srt-dat-cml            .
      *                      *-----------------------------------------*
      *                      * Protocollo commessa                     *
      *                      *-----------------------------------------*
           move      rf-hct-num-prt       to   srt-prt-cml            .
      *                  *---------------------------------------------*
      *                  * Composizione dati                           *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Codice materia prima                    *
      *                      *-----------------------------------------*
           move      rf-dpm-num-map       to   srt-num-map            .
      *                      *-----------------------------------------*
      *                      * Descrizione materia prima               *
      *                      *-----------------------------------------*
           move      rf-dpm-des-map       to   srt-des-map            .
      *                      *-----------------------------------------*
      *                      * Quantita' impegnata                     *
      *                      *-----------------------------------------*
           move      rf-hst-mnm-qta
                    (w-exe-cph-inp-ctr)   to   srt-qta-imp            .
      *                      *-----------------------------------------*
      *                      * Quantita' scaricata                     *
      *                      *-----------------------------------------*
           move      w-det-qcl-map-qta    to   srt-qta-sca            .
      *                      *-----------------------------------------*
      *                      * Quantita' in ordine                     *
      *                      *-----------------------------------------*
           move      w-det-orf-map-qta    to   srt-qta-ord            .
      *                      *-----------------------------------------*
      *                      * Data consegna                           *
      *                      *-----------------------------------------*
           move      w-det-orf-map-cns    to   srt-dat-cns            .
      *                      *-----------------------------------------*
      *                      * Quantita' in giacenza                   *
      *                      *-----------------------------------------*
           move      d-sld-mag-sld-mag    to   srt-qta-gia            .
      *                      *-----------------------------------------*
      *                      * Descrizione commessa                    *
      *                      *-----------------------------------------*
           move      rf-hct-des-cml       to   srt-des-cml            .
       exe-cph-inp-800.
      *              *-------------------------------------------------*
      *              * Rilascio del record al Sort                     *
      *              *-------------------------------------------------*
           release   srt-rec                                          .
       exe-cph-inp-840.
      *              *-------------------------------------------------*
      *              * Riciclo a elemento magazzino successivo         *
      *              *-------------------------------------------------*
           go to     exe-cph-inp-520.
       exe-cph-inp-860.
      *              *-------------------------------------------------*
      *              * Riciclo a record [hct] successivo               *
      *              *-------------------------------------------------*
           go to     exe-cph-inp-200.
       exe-cph-inp-999.
           exit.

      *    *===========================================================*
      *    * Ciclo di report-program                                   *
      *    *-----------------------------------------------------------*
       prn-rou-pri-000.
      *              *-------------------------------------------------*
      *              * Inizializzazione markers                        *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-mrk-uno      .
           move      spaces               to   w-cnt-prn-mrk-beg      .
      *              *-------------------------------------------------*
      *              * Inizializzazione area per rotture di livello    *
      *              *-------------------------------------------------*
           move      spaces               to   w-rot                  .
      *              *-------------------------------------------------*
      *              * Inizializzazione flag di interruzione forzata   *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
      *              *-------------------------------------------------*
      *              * Start iniziale                                  *
      *              *-------------------------------------------------*
           perform   prn-str-ini-000      thru prn-str-ini-999        .
           if        w-cnt-prn-flg-sub    not  = spaces
                     move   spaces        to   w-cnt-prn-flg-sub
                     go to  prn-rou-pri-600.
       prn-rou-pri-100.
      *              *-------------------------------------------------*
      *              * Salvataggio area rottura in area precedente     *
      *              *-------------------------------------------------*
           move      w-rot-l05            to   w-cnt-prn-sav-l05      .
           move      w-rot-l04            to   w-cnt-prn-sav-l04      .
           move      w-rot-l03            to   w-cnt-prn-sav-l03      .
           move      w-rot-l02            to   w-cnt-prn-sav-l02      .
           move      w-rot-l01            to   w-cnt-prn-sav-l01      .
       prn-rou-pri-200.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale                             *
      *              *-------------------------------------------------*
           perform   prn-let-seq-000      thru prn-let-seq-999        .
           if        w-cnt-prn-flg-sub    not  = spaces
                     move   spaces        to   w-cnt-prn-flg-sub
                     go to  prn-rou-pri-500.
      *              *-------------------------------------------------*
      *              * Test se superamento limiti massimi              *
      *              *-------------------------------------------------*
           perform   prn-tst-max-000      thru prn-tst-max-999        .
           if        w-cnt-prn-flg-sub    not  = spaces
                     move   spaces        to   w-cnt-prn-flg-sub
                     go to  prn-rou-pri-500.
      *              *-------------------------------------------------*
      *              * Selezione su record letto                       *
      *              *-------------------------------------------------*
           perform   prn-sel-rec-000      thru prn-sel-rec-999        .
           if        w-cnt-prn-flg-sub    not  = spaces
                     move   spaces        to   w-cnt-prn-flg-sub
                     go to  prn-rou-pri-200.
      *              *-------------------------------------------------*
      *              * Composizione area per tests di rottura          *
      *              *-------------------------------------------------*
           perform   prn-cmp-rot-000      thru prn-cmp-rot-999        .
      *              *-------------------------------------------------*
      *              * Test se primo passaggio                         *
      *              *-------------------------------------------------*
           if        w-cnt-prn-mrk-uno    not  = spaces
                     go to prn-rou-pri-300.
      *                  *---------------------------------------------*
      *                  * Test se programma senza stampa              *
      *                  *---------------------------------------------*
           if        w-cnt-fun-snx-stp    not  = "S"
                     go to prn-rou-pri-250.
      *                      *-----------------------------------------*
      *                      * Begin                                   *
      *                      *-----------------------------------------*
           move      "BE"                 to   p-ope                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                          *-------------------------------------*
      *                          * Se errori                           *
      *                          *-------------------------------------*
           if        p-rsc                not  = spaces
                     go to prn-rou-pri-900.
      *                      *-----------------------------------------*
      *                      * Marker di Begin eseguito                *
      *                      *-----------------------------------------*
           move      "#"                  to   w-cnt-prn-mrk-beg      .
       prn-rou-pri-250.
      *                  *---------------------------------------------*
      *                  * Inizio di tutti i livelli                   *
      *                  *---------------------------------------------*
           perform   prn-rou-pri-790      thru prn-rou-pri-791        .
           perform   prn-rou-pri-750      thru prn-rou-pri-751        .
           perform   prn-rou-pri-740      thru prn-rou-pri-741        .
           perform   prn-rou-pri-730      thru prn-rou-pri-731        .
           perform   prn-rou-pri-720      thru prn-rou-pri-721        .
           perform   prn-rou-pri-710      thru prn-rou-pri-711        .
           go to     prn-rou-pri-400.
       prn-rou-pri-300.
      *              *-------------------------------------------------*
      *              * Se rottura del 5. livello                       *
      *              *-------------------------------------------------*
           if        w-rot-l05            =    w-cnt-prn-sav-l05
                     go to prn-rou-pri-310.
           move      w-rot                to   w-cnt-prn-sav-rot      .
           move      w-cnt-prn-sav-l05    to   w-rot-l05              .
           move      w-cnt-prn-sav-l04    to   w-rot-l04              .
           move      w-cnt-prn-sav-l03    to   w-rot-l03              .
           move      w-cnt-prn-sav-l02    to   w-rot-l02              .
           move      w-cnt-prn-sav-l01    to   w-rot-l01              .
           perform   prn-rou-pri-810      thru prn-rou-pri-811        .
           perform   prn-rou-pri-820      thru prn-rou-pri-821        .
           perform   prn-rou-pri-830      thru prn-rou-pri-831        .
           perform   prn-rou-pri-840      thru prn-rou-pri-841        .
           perform   prn-rou-pri-850      thru prn-rou-pri-851        .
