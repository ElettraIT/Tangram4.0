      *    *===========================================================*
      *    * Emissione HTML                                            *
      *    *                                                           *
      *    * Elemento TD per tabella                                   *
      *    *-----------------------------------------------------------*
       emi-htm-ttd-000.
      *              *-------------------------------------------------*
      *              * Regolarizzazione contenuto                      *
      *              *-------------------------------------------------*
           if        w-exe-str-dsp        =    spaces
                     move  "&nbsp;"       to   w-exe-str-dsp          .
      *              *-------------------------------------------------*
      *              * Concatenamento                                  *
      *              *-------------------------------------------------*
           move      240                  to   w-all-str-lun          .
           move      06                   to   w-all-str-num          .
           move      "<TD"                to   w-all-str-cat (1)      .
           move      w-exe-ttd-all        to   w-all-str-cat (2)      .
           move      w-exe-ttd-wdt        to   w-all-str-cat (3)      .
           move      ">"                  to   w-all-str-cat (4)      .
           move      w-exe-str-dsp        to   w-all-str-cat (5)      .
           move      "</TD>"              to   w-all-str-cat (6)      .
           perform   all-str-csb-000      thru all-str-csb-999        .
      *              *-------------------------------------------------*
      *              * Emissione TAG 'TD'                              *
