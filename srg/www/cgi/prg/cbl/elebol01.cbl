      *                  * Test                                        *
      *                  *---------------------------------------------*
           move      w-exe-num-bol        to   w-all-str-alf          .
           move      "."                  to   w-all-str-del          .
           perform   all-str-chr-000      thru all-str-chr-999        .
      *                  *---------------------------------------------*
      *                  * Se non trovato: oltre                       *
      *                  *---------------------------------------------*
           if        w-all-str-num        =    zero
                     go to slc-num-bit-saa-300.
      *                  *---------------------------------------------*
      *                  * Scomposizione                               *
      *                  *---------------------------------------------*
           move      w-exe-num-bol        to   w-all-str-alf          .
           move      "."                  to   w-all-str-del          .
           perform   all-str-ext-000      thru all-str-ext-999        .
      *                  *---------------------------------------------*
      *                  * Trattamento secolo/anno                     *
      *                  *---------------------------------------------*
           move      "CV"                 to   p-ope                  .
           move      03                   to   p-car                  .
           move      w-all-str-cat (1)    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-num                to   w-slc-num-bit-saa      .
           add       100                  to   w-slc-num-bit-saa      .
      *                  *---------------------------------------------*
      *                  * Trattamento numero documento                *
      *                  *---------------------------------------------*
           move      "CV"                 to   p-ope                  .
           move      06                   to   p-car                  .
           move      w-all-str-cat (2)    to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-num                to   w-exe-num-cnv          .
      *                  *---------------------------------------------*
      *                  * Pulizia numero documento                    *
      *                  *---------------------------------------------*
           move      w-all-str-cat (2)    to   w-exe-num-bol          .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     slc-num-bit-saa-900.
       slc-num-bit-saa-300.
      *              *-------------------------------------------------*
      *              * Solo se primo mese dell'anno                    *
      *              *-------------------------------------------------*
           if        w-exe-mes-exe        >    1
                     go to slc-num-bit-saa-900.
       slc-num-bit-saa-400.
      *              *-------------------------------------------------*
      *              * Test su lunghezza del campo in input            *
      *              *-------------------------------------------------*
           if        w-exe-num-cnv        <    2000
                     go to slc-num-bit-saa-900.
       slc-num-bit-saa-500.
      *              *-------------------------------------------------*
      *              * Se lunghezza di 4 caratteri o superiore allora  *
      *              * anno precedente                                 *
      *              *-------------------------------------------------*
           subtract  1                    from w-slc-num-bit-saa      .
       slc-num-bit-saa-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     slc-num-bit-saa-999.
       slc-num-bit-saa-999.
           exit.

