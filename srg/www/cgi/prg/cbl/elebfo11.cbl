           move      rf-bft-tip-arc       to   l-mag-300-tip-arc      .
           move      rf-bft-cod-arc       to   l-mag-300-cod-arc      .
           move      rf-bft-dpz-arc       to   l-mag-300-dpz-arc      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *              *-------------------------------------------------*
      *              * Test su esito operazione                        *
      *              *-------------------------------------------------*
           if        l-mag-300-exi-sts    not  = spaces
                     go to wrt-mov-mag-900.
      *              *-------------------------------------------------*
      *              * Scrittura righe                                 *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Inizializzazione contatore righe scritte    *
      *                  *---------------------------------------------*
           move      zero                 to   w-wrt-mov-mag-ctr      .
      *                  *---------------------------------------------*
      *                  * Start su archivio [bfr]                     *
      *                  *---------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-slc-num-bft-prt    to   rf-bfr-num-prt         .
           move      zero                 to   rf-bfr-num-prg         .
           move      "pgm/bfo/fls/ioc/obj/iofbfr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfr                 .
      *                      *-----------------------------------------*
      *                      * Se at end : fine lettura                *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to wrt-mov-mag-999.
       wrt-mov-mag-100.
      *                  *---------------------------------------------*
      *                  * Lettura sequenziale file [bfr]              *
      *                  *---------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bfo/fls/ioc/obj/iofbfr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfr                 .
      *                      *-----------------------------------------*
      *                      * Se at end : fine scansione              *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to wrt-mov-mag-999.
      *                  *---------------------------------------------*
      *                  * Se oltre il massimo : fine scansione        *
      *                  *---------------------------------------------*
           if        rf-bfr-num-prt       not  = w-slc-num-bft-prt
                     go to wrt-mov-mag-999.
      *                  *---------------------------------------------*
      *                  * Se tipo riga a spazi : uscita               *
      *                  *---------------------------------------------*
           if        rf-bfr-tip-rig       not  = "P    "
                     go to wrt-mov-mag-100.
      *                  *---------------------------------------------*
      *                  * Incremento contatore righe scritte          *
      *                  *---------------------------------------------*
           add       1                    to   w-wrt-mov-mag-ctr      .
      *                  *---------------------------------------------*
      *                  * Determinazione valore movimento             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Spostamento in work di comodo           *
      *                      *-----------------------------------------*
           move      rf-bfr-imp-rig       to   w-wrt-mov-mag-wvm      .
      *                      *-----------------------------------------*
      *                      * Conversione in valuta base              *
      *                      *-----------------------------------------*
           move      rf-bft-sgl-vpf       to   w-cvs-vlt-sgl          .
           move      rf-bft-dec-vpf       to   w-cvs-vlt-dec          .
           move      rf-bft-tdc-vpf       to   w-cvs-vlt-tdc          .
           move      rf-bft-cdc-vpf       to   w-cvs-vlt-cdc          .
           move      w-wrt-mov-mag-wvm    to   w-cvs-vlt-aav          .
           perform   cvs-alt-vlb-000      thru cvs-alt-vlb-999        .
           move      w-cvs-vlt-avb        to   w-wrt-mov-mag-wvm      .
       wrt-mov-mag-200.
      *                  *---------------------------------------------*
      *                  * Determinazione costo unitario movimento     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normale trattamento                     *
      *                      *-----------------------------------------*
           divide    rf-bfr-qta-acq       into w-wrt-mov-mag-wvm
                                        giving w-wrt-mov-mag-wcu
                                               rounded                .
       wrt-mov-mag-250.
      *                  *---------------------------------------------*
      *                  * Applicazione della % maggiorazione prezzo   *
      *                  *                                             *
      *                  * N.B.: attualmente non implementata          *
      *                  *---------------------------------------------*
       wrt-mov-mag-260.
      *                  *---------------------------------------------*
      *                  * Preparazione data e numero riferimento      *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione valori                  *
      *                      *-----------------------------------------*
           move      zero                 to   w-wrt-mov-mag-wdr      .
           move      spaces               to   w-wrt-mov-mag-wnr      .
      *                      *-----------------------------------------*
      *                      * Data                                    *
      *                      *-----------------------------------------*
           move      rf-bfr-orf-dat       to   w-wrt-mov-mag-wdr      .
      *                      *-----------------------------------------*
      *                      * Numero                                  *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      06                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<B"                 to   p-edm                  .
           move      rf-bfr-orf-num (6 : 6)
                                          to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   w-wrt-mov-mag-wnr      .
       wrt-mov-mag-300.
      *                  *---------------------------------------------*
      *                  * Normalizzazione riga                        *
      *                  *---------------------------------------------*
           move      "NR"                 to   l-mag-300-tip-ope      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Scrittura riga                              *
      *                  *---------------------------------------------*
           move      "WR"                 to   l-mag-300-tip-ope      .
           move      rf-bfr-tip-mag       to   l-mag-300-tip-mag      .
           move      rf-bfr-num-mag       to   l-mag-300-num-mag      .
           move      rf-bfr-alf-mag       to   l-mag-300-alf-mag      .
           move      rf-bfr-sgl-vrn       to   l-mag-300-var-mag      .
           move      rf-bfr-umi-acq       to   l-mag-300-udm-ana      .
           move      rf-bfr-umi-acq       to   l-mag-300-udm-mov      .
           move      zero                 to   l-mag-300-num-pmg      .
           move      w-wrt-mov-mag-wdr    to   l-mag-300-ddo-rif      .
           move      w-wrt-mov-mag-wnr    to   l-mag-300-ndo-rif      .
           move      rf-bfr-qta-acq       to   l-mag-300-qta-mov      .
           move      w-wrt-mov-mag-wcu    to   l-mag-300-cun-mov      .
           move      w-wrt-mov-mag-wvm    to   l-mag-300-val-mov      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        l-mag-300-exi-sts    not  = spaces
                     go to wrt-mov-mag-900.
      *                  *---------------------------------------------*
      *                  * Riciclo su riga successiva                  *
      *                  *---------------------------------------------*
           go to     wrt-mov-mag-100.
       wrt-mov-mag-800.
      *              *-------------------------------------------------*
      *              * Test su numero righe scritte                    *
      *              *-------------------------------------------------*
           if        w-wrt-mov-mag-ctr    not  = zero
                     go to wrt-mov-mag-850.
      *              *-------------------------------------------------*
      *              * Se nessuna riga scritta : cancellazione della   *
      *              * registrazione di magazzino per eliminare la     *
      *              * testata scritta                                 *
      *              *-------------------------------------------------*
           move      "DE"                 to   l-mag-300-tip-ope      .
           move      rf-bft-dat-reg       to   l-mag-300-dat-reg      .
           move      rf-bft-prt-mag       to   l-mag-300-num-prt      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     wrt-mov-mag-999.
       wrt-mov-mag-850.
      *              *-------------------------------------------------*
      *              * Aggiornamento testata                           *
      *              *-------------------------------------------------*
      
       wrt-mov-mag-900.
      *              *-------------------------------------------------*
      *              * Trattamento errore                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Intestazione pagina                         *
      *                  *---------------------------------------------*
           perform   int-pag-sta-000      thru int-pag-sta-999        .
      *                  *---------------------------------------------*
      *                  * Messaggio                                   *
      *                  *---------------------------------------------*
           move      "Attenzione : aggiornamenti di magazzino non esegui
      -              "ti !           "    to   w-exe-err-msg          .
           move      "msg_red"            to   w-exe-cla-msg          .
           perform   err-msg-htm-000      thru err-msg-htm-999        .
       wrt-mov-mag-999.
           exit.

      *    *===========================================================*
      *    * Cancellazione movimento di MAG                            *
      *    *-----------------------------------------------------------*
       del-mov-mag-000.
      *              *-------------------------------------------------*
      *              * Test se necessario                              *
      *              *-------------------------------------------------*
           if        rf-bft-prt-mag       =    zero
                     go to del-mov-mag-999.
      *              *-------------------------------------------------*
      *              * Esecuzione operazione                           *
      *              *-------------------------------------------------*
           move      "DE"                 to   l-mag-300-tip-ope      .
           move      rf-bft-dat-reg       to   l-mag-300-dat-reg      .
           move      rf-bft-prt-mag       to   l-mag-300-num-prt      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
       del-mov-mag-999.
           exit.

      *    *===========================================================*
      *    * Subroutines per determinazione ubicazione di magazzino    *
      *    *-----------------------------------------------------------*
           copy      "pgm/mag/prg/cpy/dprmubi0.dts"                   .

      *    *===========================================================*
      *    * Subroutines per determinazione saldo di magazzino         *
      *    *-----------------------------------------------------------*
           copy      "pgm/mag/prg/cpy/dsldmag0.dts"                   .

      *    *===========================================================*
      *    * Subroutines per modulo di aggiornamento del magazzino     *
      *    *-----------------------------------------------------------*
           copy      "pgm/mag/prg/cpy/pmag300z.pgs"                   .

      *    *===========================================================*
      *    * Routine di conversione da altra valuta a valuta base      *
      *    *-----------------------------------------------------------*
           copy      "swd/std/prg/cpy/wcvsvlt0.cps"                   .

