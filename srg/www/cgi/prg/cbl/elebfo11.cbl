      *================================================================*
       main-000.
      *              *-------------------------------------------------*
      *              * Estrazione parametri                            *
      *              *-------------------------------------------------*
           perform   ext-prm-000          thru ext-prm-999            .
      *              *-------------------------------------------------*
      *              * Open files                                      *
      *              *-------------------------------------------------*
           perform   opn-fls-000          thru opn-fls-999            .
       main-100.
      *              *-------------------------------------------------*
      *              * Ciclo di lettura e preparazione html            *
      *              *-------------------------------------------------*
           perform   exe-cph-000          thru exe-cph-999            .
       main-800.
      *              *-------------------------------------------------*
      *              * Close files                                     *
      *              *-------------------------------------------------*
           perform   cls-fls-000          thru cls-fls-999            .
       main-999.
           exit      program.

      *================================================================*
      *       Routines                                                 *
      *================================================================*

      *    *===========================================================*
      *    * Estrazione parametri                                      *
      *    *-----------------------------------------------------------*
       ext-prm-000.
      *              *-------------------------------------------------*
      *              * Subroutine per la preparazione dei valori rela- *
      *              * tivi alla valuta base, determinati dalla segre- *
      *              * teria                                           *
      *              *-------------------------------------------------*
           move      "VB"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dec                to   c-dec                  .
           move      s-asx                to   c-sgl                  .
           move      s-sgn                to   c-tdc                  .
           move      s-num                to   c-cdc                  .
           move      s-adx (01 : 20)      to   c-des                  .
           move      s-adx (21 : 20)      to   c-din                  .
      *              *-------------------------------------------------*
      *              * Data di sistema                                 *
      *              *-------------------------------------------------*
           move      "DT"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           move      s-dat                to   w-exe-dat-exe          .
      *              *-------------------------------------------------*
      *              * CORRETTIVO PROVVISORIO                          *
      *              *-------------------------------------------------*
           if        w-exe-dat-exe        <    999999
                     add  1000000         to   w-exe-dat-exe          .
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
           move      spaces               to   w-exe-cod-rsm          .
           move      zero                 to   w-exe-cnv-rsm          .
           move      spaces               to   w-exe-num-bfo          .
           move      spaces               to   w-exe-prt-bfo          .
           move      spaces               to   w-exe-ann-ncf          .
           move      spaces               to   w-exe-num-col          .
           move      zero                 to   w-exe-cts-num          .
           move      spaces               to   w-exe-alf-pro          .
           move      zero                 to   w-exe-num-pro          .
           move      zero                 to   w-slc-num-bft-prt      .
      *              *-------------------------------------------------*
      *              * Normalizzazione parametri                       *
      *              *-------------------------------------------------*
           move      "NO"                 to   w-cgi-tip-ope          .
           move      04                   to   w-cgi-str-num          .
           perform   ope-prm-inp-000      thru ope-prm-inp-999        .
      *              *-------------------------------------------------*
      *              * Lettura della variabile di environment          *
      *              *-------------------------------------------------*
           move      "I2"                 to   o-ope                  .
           move      "POST"               to   o-com                  .
           call      "swd/mod/prg/obj/mopsys"
                                         using o                      .
      *              *-------------------------------------------------*
      *              * Estrazione parametri                            *
      *              *-------------------------------------------------*
           move      o-pst                to   w-cgi-str-var          .
           perform   cgi-str-ext-000      thru cgi-str-ext-999        .
       ext-prm-300.
      *              *-------------------------------------------------*
      *              * Assegnazione componenti                         *
      *              *-------------------------------------------------*
           move      "EX"                 to   w-cgi-tip-ope          .
           move      w-cgi-str-num        to   w-cgi-str-num          .
           perform   ope-prm-inp-000      thru ope-prm-inp-999        .
       ext-prm-500.
      *              *-------------------------------------------------*
      *              * Regolarizzazioni                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Protocollo documento                        *
      *                  *---------------------------------------------*
           perform   ext-prm-prt-000      thru ext-prm-prt-999        .
      *                  *---------------------------------------------*
      *                  * Numero documento in uppercase               *
      *                  *---------------------------------------------*
           move      w-exe-num-bfo        to   w-all-str-alf          .
           move      20                   to   w-all-str-lun          .
           perform   all-str-upp-000      thru all-str-upp-999        .
           move      w-all-str-alf        to   w-exe-num-bfo          .
      *                  *---------------------------------------------*
      *                  * Codice numerico responsabile                *
      *                  *---------------------------------------------*
           move      "CV"                 to   p-ope                  .
           move      03                   to   p-car                  .
           move      w-exe-cod-rsm        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-num                to   w-exe-cnv-rsm          .
      *                  *---------------------------------------------*
      *                  * Codice dipendenza                           *
      *                  *---------------------------------------------*
           move      01                   to   w-slc-num-bft-ndp      .
      *                  *---------------------------------------------*
      *                  * Contrassegno collo in uppercase             *
      *                  *---------------------------------------------*
           move      20                   to   w-all-str-lun          .
           move      w-exe-num-col        to   w-all-str-alf          .
           perform   all-str-upp-000      thru all-str-upp-999        .
           move      w-all-str-alf        to   w-exe-num-col          .
      *                  *---------------------------------------------*
      *                  * Eliminazione prefisso contrassegno collo    *
      *                  *---------------------------------------------*
           if        w-exe-num-col
                    (01 : 05)             =    "%2BC1"
                     move  w-exe-num-col
                          (06 : 15)       to   w-exe-num-col          .
      *                  *---------------------------------------------*
      *                  * Estrazione componente numerica contrassegno *
      *                  * collo                                       *
      *                  *---------------------------------------------*
           move      "CV"                 to   p-ope                  .
           move      20                   to   p-car                  .
           move      w-exe-num-col        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-num                to   w-exe-cts-num          .
      *                  *---------------------------------------------*
      *                  * Codice alfanumerico prodotto                *
      *                  *---------------------------------------------*
           move      w-exe-alf-pro        to   w-det-num-pro-alf      .
           perform   ext-prm-pro-000      thru ext-prm-pro-999        .
           move      w-det-num-pro-alf    to   w-exe-alf-pro          .
       ext-prm-700.
      *              *-------------------------------------------------*
      *              * Operazioni preliminari                          *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Preparazione tabella responsabili           *
      *                  *---------------------------------------------*
           perform   det-tbl-rsm-000      thru det-tbl-rsm-999        .
       ext-prm-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     ext-prm-999.
       ext-prm-999.
           exit.

      *    *===========================================================*
      *    * Estrazione parametri                                      *
      *    *                                                           *
      *    * Subroutine di assegnazione del valore in base al nome del *
      *    * campo in input                                            *
      *    *-----------------------------------------------------------*
       ext-prm-ass-000.
      *              *-------------------------------------------------*
      *              * Deviazione in funzione del nome campo           *
      *              *-------------------------------------------------*
           if        w-all-str-cat (1)    =    "rsp_doc"
                     move  w-all-str-cat (2)
                                          to   w-exe-cod-rsm
           else if   w-all-str-cat (1)    =    "num_doc"
                     move  w-all-str-cat (2)
                                          to   w-exe-num-bfo
           else if   w-all-str-cat (1)    =    "num_col"
                     move  w-all-str-cat (2)
                                          to   w-exe-num-col
           else if   w-all-str-cat (1)    =    "alf_pro"
                     move  w-all-str-cat (2)
                                          to   w-exe-alf-pro          .
       ext-prm-ass-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     ext-prm-ass-999.
       ext-prm-ass-999.
           exit.

      *    *===========================================================*
      *    * Estrazione parametri                                      *
      *    *                                                           *
      *    * Subroutine di eventuale estrazione protocollo             *
      *    *-----------------------------------------------------------*
       ext-prm-prt-000.
      *              *-------------------------------------------------*
      *              * Test su valore del campo in input               *
      *              *-------------------------------------------------*
           if        w-exe-num-bfo        =    spaces
                     go to ext-prm-prt-900.
           if        w-slc-num-bft-prt    not  = zero
                     go to ext-prm-prt-900.
       ext-prm-prt-050.
      *              *-------------------------------------------------*
      *              * Test su presenza del carattere '.'              *
      *              *-------------------------------------------------*
           move      w-exe-num-bfo        to   w-all-str-alf          .
           move      "."                  to   w-all-str-del          .
           perform   all-str-chr-000      thru all-str-chr-999        .
           if        w-all-str-num        =    1
                     perform ext-prm-prt-sep-000
                                          thru ext-prm-prt-sep-999
                     go to ext-prm-prt-900.
       ext-prm-prt-100.
      *              *-------------------------------------------------*
      *              * Test su lunghezza del campo in input            *
      *              *-------------------------------------------------*
           move      w-exe-num-bfo        to   w-all-str-alf          .
           perform   all-str-lun-000      thru all-str-lun-999        .
           if        w-all-str-lun        >    6
                     go to ext-prm-prt-900.
       ext-prm-prt-200.
      *              *-------------------------------------------------*
      *              * Se lunghezza di 6 caratteri o inferiore         *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Lunghezza stringa                           *
      *                  *---------------------------------------------*
           move      w-all-str-lun        to   w-exe-lun-prt          .
      *                  *---------------------------------------------*
      *                  * Secolo/anno da data di sistema              *
      *                  *---------------------------------------------*
           move      w-exe-dat-exe
                    (01 : 03)             to   w-exe-saa-prt          .
      *                  *---------------------------------------------*
      *                  * Codice dipendenza                           *
      *                  *---------------------------------------------*
           move      "01"                 to   w-exe-dpz-prt          .
      *                  *---------------------------------------------*
      *                  * Assemblaggio                                *
      *                  *---------------------------------------------*
           move      11                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
           move      w-exe-saa-prt        to   w-all-str-cat (1)      .
           move      w-exe-dpz-prt        to   w-all-str-cat (2)      .
      *
           if        w-exe-lun-prt        =    1
                     move  "00000"        to   w-all-str-cat (3)
           else if   w-exe-lun-prt        =    2
                     move  "0000"         to   w-all-str-cat (3)
           else if   w-exe-lun-prt        =    3
                     move  "000"          to   w-all-str-cat (3)
           else if   w-exe-lun-prt        =    4
                     move  "00"           to   w-all-str-cat (3)
           else if   w-exe-lun-prt        =    5
                     move  "0"            to   w-all-str-cat (3)
           else      move  spaces         to   w-all-str-cat (3)      .
      *
           move      w-exe-num-bfo        to   w-all-str-cat (4)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *                  *---------------------------------------------*
      *                  * Conversione in numerico                     *
      *                  *---------------------------------------------*
           move      "CV"                 to   p-ope                  .
           move      11                   to   p-car                  .
           move      w-all-str-alf        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-num                to   w-slc-num-bft-prt      .
      *                  *---------------------------------------------*
      *                  * Ad uscita                                   *
      *                  *---------------------------------------------*
           go to     ext-prm-prt-900.
       ext-prm-prt-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     ext-prm-prt-999.
       ext-prm-prt-999.
           exit.

      *    *===========================================================*
      *    * Estrazione parametri                                      *
      *    *                                                           *
      *    * Subroutine di eventuale estrazione protocollo             *
      *    *                                                           *
      *    * Sub-subroutine di estrazione protocollo e anno            *
      *    *-----------------------------------------------------------*
       ext-prm-prt-sep-000.
      *              *-------------------------------------------------*
      *              * Estrazione                                      *
      *              *-------------------------------------------------*
           move      w-exe-num-bfo        to   w-all-str-alf          .
           move      "."                  to   w-all-str-del          .
           perform   all-str-ext-000      thru all-str-ext-999        .
           move      w-all-str-cat (2)    to   w-exe-wrk-prt          .
      *              *-------------------------------------------------*
      *              * Estrazione secolo/anno                          *
      *              *-------------------------------------------------*
           move      w-all-str-cat (1)    to   w-exe-saa-prt
                                              (02 : 02)               .
           move      "1"                  to   w-exe-saa-prt
                                              (01 : 01)               .
      *              *-------------------------------------------------*
      *              * Test su lunghezza del componente numero         *
      *              *-------------------------------------------------*
           move      w-exe-wrk-prt        to   w-all-str-alf          .
           perform   all-str-lun-000      thru all-str-lun-999        .
           move      w-all-str-lun        to   w-exe-lun-prt          .
       ext-prm-prt-sep-200.
      *              *-------------------------------------------------*
      *              * Codice dipendenza                               *
      *              *-------------------------------------------------*
           move      "01"                 to   w-exe-dpz-prt          .
      *              *-------------------------------------------------*
      *              * Assemblaggio                                    *
      *              *-------------------------------------------------*
           move      11                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
           move      w-exe-saa-prt        to   w-all-str-cat (1)      .
           move      w-exe-dpz-prt        to   w-all-str-cat (2)      .
      *
           if        w-exe-lun-prt        =    1
                     move  "00000"        to   w-all-str-cat (3)
           else if   w-exe-lun-prt        =    2
                     move  "0000"         to   w-all-str-cat (3)
           else if   w-exe-lun-prt        =    3
                     move  "000"          to   w-all-str-cat (3)
           else if   w-exe-lun-prt        =    4
                     move  "00"           to   w-all-str-cat (3)
           else if   w-exe-lun-prt        =    5
                     move  "0"            to   w-all-str-cat (3)
           else      move  spaces         to   w-all-str-cat (3)      .
      *
           move      w-exe-wrk-prt        to   w-all-str-cat (4)      .
           perform   all-str-cat-000      thru all-str-cat-999        .
      *                  *---------------------------------------------*
      *                  * Conversione in numerico                     *
      *                  *---------------------------------------------*
           move      "CV"                 to   p-ope                  .
           move      11                   to   p-car                  .
           move      w-all-str-alf        to   p-alf                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-num                to   w-slc-num-bft-prt      .
       ext-prm-prt-sep-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     ext-prm-prt-sep-999.
       ext-prm-prt-sep-999.
           exit.

      *    *===========================================================*
      *    * Estrazione parametri                                      *
      *    *                                                           *
      *    * Subroutine di eventuale regolarizzazione codice prodotto  *
      *    *-----------------------------------------------------------*
       ext-prm-pro-000.
      *              *-------------------------------------------------*
      *              * Test su valore del campo in input               *
      *              *-------------------------------------------------*
           if        w-det-num-pro-alf    =    spaces
                     go to ext-prm-pro-900.
      *              *-------------------------------------------------*
      *              * Uppercase                                       *
      *              *-------------------------------------------------*
           move      w-det-num-pro-alf    to   w-all-str-alf          .
           move      24                   to   w-all-str-lun          .
           perform   all-str-upp-000      thru all-str-upp-999        .
           move      w-all-str-alf        to   w-det-num-pro-alf      .
       ext-prm-pro-200.
      *              *-------------------------------------------------*
      *              * Test se presente il carattere '%'               *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test                                        *
      *                  *---------------------------------------------*
           move      w-det-num-pro-alf    to   w-all-str-alf          .
           move      "%"                  to   w-all-str-del          .
           perform   all-str-chr-000      thru all-str-chr-999        .
      *                  *---------------------------------------------*
      *                  * Se non trovato: ad uscita                   *
      *                  *---------------------------------------------*
           if        w-all-str-num        =    zero
                     go to ext-prm-pro-900.
      *                  *---------------------------------------------*
      *                  * Scomposizione                               *
      *                  *---------------------------------------------*
           move      w-det-num-pro-alf    to   w-all-str-alf          .
           move      "%"                  to   w-all-str-del          .
           perform   all-str-ext-000      thru all-str-ext-999        .
      *                  *---------------------------------------------*
      *                  * Bufferizzazione eventuale 3' componente     *
      *                  *---------------------------------------------*
           move      w-all-str-cat (3)    to    w-det-num-pro-ele     .
      *                  *---------------------------------------------*
      *                  * Test sui componenti                         *
      *                  *---------------------------------------------*
           if        w-all-str-cat (2)
                    (01 : 02)             not  = "2F"
                     go to ext-prm-pro-900.
           move      w-all-str-cat (1)    to   w-exe-prm-vx1          .
           move      w-all-str-cat (2)
