                     go to  ord-cod-pdv-999.
           move      w-det-cod-pdv-cti    to   w-det-cod-pdv-ctj
                                               w-det-cod-pdv-ctk      .
           move      w-det-cod-pdv-alf
                    (w-det-cod-pdv-cti)   to   w-det-cod-pdv-key      .
       ord-cod-pdv-200.
           add       1                    to   w-det-cod-pdv-ctj      .
           if        w-det-cod-pdv-ctj    >    w-det-cod-pdv-ctr
                     go to  ord-cod-pdv-300.
           if        w-det-cod-pdv-alf
                    (w-det-cod-pdv-ctj)   >    w-det-cod-pdv-key
                     go to  ord-cod-pdv-200.
           move      w-det-cod-pdv-ctj    to   w-det-cod-pdv-ctk      .
           move      w-det-cod-pdv-alf
                    (w-det-cod-pdv-ctj)   to   w-det-cod-pdv-key      .
