      *                  * Apertura cella normale                      *
      *                  *---------------------------------------------*
           move      "<td id='cel_qtv' name ='cel_qtv'>"
                                          to   w-all-str-cat (1)      .
      *                  *---------------------------------------------*
      *                  * Apertura cella con quantita' superiore      *
      *                  *---------------------------------------------*
           move      "<td id='cel_qtv' name ='cel_qtv' class='sel'>"
                                          to   w-all-str-cat (2)      .
      *                  *---------------------------------------------*
      *                  * Apertura cella con quantita' inferiore      *
      *                  *---------------------------------------------*
           move      "<td id='cel_qtv' name ='cel_qtv' class='msg_red'>"
                                          to   w-all-str-cat (3)      .
      *                  *---------------------------------------------*
      *                  * Apertura cella riga chiusa                  *
      *                  *---------------------------------------------*
           move      "<td id='cel_qtv' name ='cel_qtv' class='td_ds'>"
                                          to   w-all-str-cat (4)      .
      *                  *---------------------------------------------*
      *                  * Test sulle quantita'                        *
      *                  *---------------------------------------------*
           if        w-det-vis-pro-qds    =    zero
                     move  w-all-str-cat (1)
                                          to   w-all-str-alf
           else if   w-det-vis-pro-qds    =    w-det-vis-pro-qau
                     move  w-all-str-cat (1)
                                          to   w-all-str-alf
           else if   w-det-vis-pro-qau    >    w-det-vis-pro-qds
                     move  w-all-str-cat (2)
                                          to   w-all-str-alf
           else      move  w-all-str-cat (3)
                                          to   w-all-str-alf          .
      *                  *---------------------------------------------*
      *                  * Test su stato riga                          *
      *                  *---------------------------------------------*
______*    if        rf-osr-flg-rch       not  = spaces
______*              move  w-all-str-cat (4)
______*                                   to   w-all-str-alf          .
      *                  *---------------------------------------------*
      *                  * Apertura cella                              *
      *                  *---------------------------------------------*
           display   w-all-str-alf                                    .
