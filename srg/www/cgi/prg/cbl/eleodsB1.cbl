                    (w-det-cod-pdv-ctk)   to   w-det-cod-pdv-ele
                                              (w-det-cod-pdv-max)    .
           move      w-det-cod-pdv-ele
                    (w-det-cod-pdv-ctl)   to   w-det-cod-pdv-ele
                                              (w-det-cod-pdv-ctk)      .
           move      w-det-cod-pdv-ele
                    (w-det-cod-pdv-max)   to   w-det-cod-pdv-ele
                                              (w-det-cod-pdv-ctl)      .
