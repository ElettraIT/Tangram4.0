      *    *===========================================================*
      *    * Ciclo di lettura e preparazione html                      *
      *    *                                                           *
      *    * Subroutine per livello '1'                                *
      *    *                                                           *
      *    * Sub-subroutine di scrittura movimenti di magazzino        *
      *    *-----------------------------------------------------------*
       exe-cph-agg-mag-000.
      *              *-------------------------------------------------*
      *              * Normalizzazioni preliminari                     *
      *              *-------------------------------------------------*
           move      zero                 to   w-exe-ctr-mag          .
      *              *-------------------------------------------------*
      *              * Test preliminari                                *
      *              *-------------------------------------------------*
           if        w-slc-num-bft-prt    =    zero
                     go to exe-cph-agg-mag-990.
           if        w-exe-flg-stp        not  = "#"
                     go to exe-cph-agg-mag-990.
       exe-cph-agg-mag-050.
      *              *-------------------------------------------------*
      *              * Lettura record 'zero' per verifica se presente  *
      *              * il protocollo di magazzino                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione [bfu]                       *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/bfo/fls/ioc/obj/iofbfu"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfu                 .
      *                  *---------------------------------------------*
      *                  * Lettura per protocollo                      *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "PRTPRO    "         to   f-key                  .
           move      w-slc-num-bft-prt    to   rf-bfu-num-prt         .
           move      zero                 to   rf-bfu-num-pro         .
           move      spaces               to   rf-bfu-cod-ubi         .
           move      "pgm/bfo/fls/ioc/obj/iofbfu"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfu                 .
      *                  *---------------------------------------------*
      *                  * Se protocollo di magazzino gia' assegnato   *
      *                  * uscita                                      *
      *                  *---------------------------------------------*
           if        rf-bfu-prt-mag       not  = zero
                     go to exe-cph-agg-mag-990.
       exe-cph-agg-mag-100.
      *              *-------------------------------------------------*
      *              * Start su [bfu]                                  *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "PRTPRO    "         to   f-key                  .
           move      "NL"                 to   f-cfr                  .
           move      w-slc-num-bft-prt    to   rf-bfu-num-prt         .
           move      zero                 to   rf-bfu-num-pro         .
           move      spaces               to   rf-bfu-cod-ubi         .
           move      "pgm/bfo/fls/ioc/obj/iofbfu"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfu                 .
      *                  *---------------------------------------------*
      *                  * Se errore di start : fine lettura           *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  exe-cph-agg-mag-900.
       exe-cph-agg-mag-200.
      *              *-------------------------------------------------*
      *              * Next su [bfu]                                   *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/bfo/fls/ioc/obj/iofbfu"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfu                 .
      *                  *---------------------------------------------*
      *                  * Se at end : fine lettura                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to  exe-cph-agg-mag-900.
       exe-cph-agg-mag-300.
      *              *-------------------------------------------------*
      *              * Se oltre il massimo : fine lettura              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su protocollo distinta                 *
      *                  *---------------------------------------------*
           if        rf-bfu-num-prt       not  = w-slc-num-bft-prt
                     go to  exe-cph-agg-mag-900.
       exe-cph-agg-mag-400.
      *              *-------------------------------------------------*
      *              * Selezioni su [bfu]                              *
      *              *-------------------------------------------------*
       exe-cph-agg-mag-500.
      *              *-------------------------------------------------*
      *              * Incremento contatore                            *
      *              *-------------------------------------------------*
           add       1                    to   w-exe-ctr-mag          .
       exe-cph-agg-mag-550.
      *              *-------------------------------------------------*
      *              * Test se prima riga                              *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su contatore                           *
      *                  *---------------------------------------------*
           if        w-exe-ctr-mag        >    1
                     go to exe-cph-agg-mag-600.
      *                  *---------------------------------------------*
      *                  * Protocollo di magazzino da testata docu-    *
      *                  * mento                                       *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione [bft]                   *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/bfo/fls/ioc/obj/iofbft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bft                 .
      *                      *-----------------------------------------*
      *                      * Lettura [bft]                           *
      *                      *-----------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-slc-num-bft-prt    to   rf-bft-num-prt         .
           move      "pgm/bfo/fls/ioc/obj/iofbft"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bft                 .
      *                      *-----------------------------------------*
      *                      * Se protocollo trovato                   *
      *                      *-----------------------------------------*
           if        rf-bft-pr2-mag       not  = zero
                     move  rf-bft-pr2-mag to   w-exe-prt-mag
                     move  rf-bft-dat-reg to   w-exe-drg-mag
                     go to exe-cph-agg-mag-560.
      *                      *-----------------------------------------*
      *                      * Se protocollo non trovato               *
      *                      *                                         *
      *                      * Attualmente si esce                     *
      *                      *-----------------------------------------*
           go to     exe-cph-agg-mag-990.
       exe-cph-agg-mag-555.
      *                      *-----------------------------------------*
      *                      * Test se la testata e' gia' stata inse-  *
      *                      * rita: in tal caso si esce per evitare   *
      *                      * una doppia registrazione                *
      *                      *-----------------------------------------*
           move      "TE"                 to   l-mag-300-tip-ope      .
           move      w-exe-dat-exe        to   l-mag-300-dat-reg      .
           move      w-slc-num-bft-prt    to   l-mag-300-num-prt      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
           if        l-mag-300-exi-sts    =    spaces
                     go to exe-cph-agg-mag-990.
      *                      *-----------------------------------------*
      *                      * Attribuzione nuovo protocollo           *
      *                      *-----------------------------------------*
           move      "NP"                 to   l-mag-300-tip-ope      .
           move      w-exe-dat-exe        to   l-mag-300-dat-reg      .
           move      01                   to   l-mag-300-cod-dpz      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
           move      l-mag-300-num-prt    to   w-exe-prt-mag          .
           move      w-exe-dat-exe        to   w-exe-drg-mag          .
       exe-cph-agg-mag-560.
      *                  *---------------------------------------------*
      *                  * Scrittura testata movimento di magazzino    *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Lettura tipo movimento [ybf]            *
      *                      *-----------------------------------------*
           move      rf-bft-cod-tmb       to   w-let-arc-ybf-cod      .
           move      zero                 to   w-let-arc-ybf-dpz      .
           perform   let-arc-ybf-000      thru let-arc-ybf-999        .
           move      w-let-arc-ybf-dsl    to   w-exe-dsl-mag          .
           if        w-exe-dsl-mag        =    spaces
                     move  "LRIC"         to   w-exe-dsl-mag          .
      *                      *-----------------------------------------*
      *                      * Normalizzazione testata                 *
      *                      *-----------------------------------------*
           move      "NT"                 to   l-mag-300-tip-ope      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                      *-----------------------------------------*
      *                      * Scrittura testata                       *
      *                      *-----------------------------------------*
           move      "WT"                 to   l-mag-300-tip-ope      .
           move      w-exe-drg-mag        to   l-mag-300-dat-reg      .
           move      w-exe-prt-mag        to   l-mag-300-num-prt      .
           move      01                   to   l-mag-300-cod-dpz      .
      *                      *-----------------------------------------*
      *                      * Causale cambio dislocazione uscite      *
      *                      *-----------------------------------------*
           move      00055                to   l-mag-300-cod-cau      .
           move      spaces               to   l-mag-300-cod-ctm      .
           move      w-exe-dat-exe        to   l-mag-300-dat-doc      .
      *                      *-----------------------------------------*
      *                      * Editing protocollo distinta             *
      *                      *-----------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           move      06                   to   p-car                  .
           move      zero                 to   p-dec                  .
           move      spaces               to   p-sgn                  .
           move      "<B"                 to   p-edm                  .
           move      w-slc-num-bft-prt
                    (06 : 06)             to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
           move      p-edt                to   l-mag-300-num-doc      .
      *                      *-----------------------------------------*
      *                      * Altri dati normalizzati                 *
      *                      *-----------------------------------------*
           move      spaces               to   l-mag-300-cod-dsl      .
           move      spaces               to   l-mag-300-cod-dsd      .
           move      "N"                  to   l-mag-300-tip-arc      .
           move      zero                 to   l-mag-300-cod-arc      .
           move      spaces               to   l-mag-300-dpz-arc      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
       exe-cph-agg-mag-600.
      *              *-------------------------------------------------*
      *              * Scrittura riga movimento di magazzino           *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su elementi riga                       *
      *                  *---------------------------------------------*
           if        rf-bfu-num-pro       =    zero
                     go to exe-cph-agg-mag-700.      
           if        rf-bfu-qta-ubi       =    zero
                     go to exe-cph-agg-mag-700.      
           if        rf-bfu-cod-ubi       =    spaces
                     go to exe-cph-agg-mag-700.      
      *                  *---------------------------------------------*
      *                  * Normalizzazione [dcp]                       *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *                  *---------------------------------------------*
      *                  * Lettura per codice                          *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMPRO"             to   f-key                  .
           move      rf-bfu-num-pro       to   rf-dcp-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/iofdcp"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-dcp                 .
      *                  *---------------------------------------------*
      *                  * Normalizzazione riga movimento di magazzino *
      *                  *---------------------------------------------*
           move      "NR"                 to   l-mag-300-tip-ope      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
      *                  *---------------------------------------------*
      *                  * Scrittura riga                              *
      *                  *---------------------------------------------*
           move      "WR"                 to   l-mag-300-tip-ope      .
           move      01                   to   l-mag-300-tip-mag      .
           move      rf-bfu-num-pro       to   l-mag-300-num-mag      .
           move      rf-dcp-alf-pro       to   l-mag-300-alf-mag      .
           move      spaces               to   l-mag-300-var-mag      .
           move      rf-dcp-umi-ven       to   l-mag-300-udm-ana      .
           move      rf-dcp-umi-ven       to   l-mag-300-udm-mov      .
           move      zero                 to   l-mag-300-num-pmg      .
           move      zero                 to   l-mag-300-ddo-rif      .
           move      spaces               to   l-mag-300-ndo-rif      .
           move      rf-bfu-qta-ubi       to   l-mag-300-qta-mov      .
           move      w-exe-dsl-mag        to   l-mag-300-cod-dsl      .
           move      rf-bfu-cod-ubi       to   l-mag-300-cod-dsd      .
           perform   mdl-agg-mag-cll-000  thru mdl-agg-mag-cll-999    .
       exe-cph-agg-mag-700.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     exe-cph-agg-mag-200.
