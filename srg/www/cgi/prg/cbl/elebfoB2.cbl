      *    *===========================================================*
      *    * Ciclo di lettura e preparazione html                      *
      *    *                                                           *
      *    * Subroutine per livello '2'                                *
      *    *                                                           *
      *    * Sub-subroutine per update spunte e quantita' delle singo- *
      *    * le righe                                                  *
      *    *-----------------------------------------------------------*
       exe-cph-lv2-upd-000.
      *              *-------------------------------------------------*
      *              * Ciclo di scansione della tabella di quantita'   *
      *              * in riga per ciascun prodotto                    *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-qta-pro-ctr      .
           move      w-exe-qta-ppu        to   w-det-qta-pro-qas      .
           move      zero                 to   w-det-qta-pro-qaz      .
       exe-cph-lv2-upd-200.
      *              *-------------------------------------------------*
      *              * Incremento contatore                            *
      *              *-------------------------------------------------*
           add       1                    to   w-det-qta-pro-ctr      .
      *              *-------------------------------------------------*
      *              * Test su contatore                               *
      *              *-------------------------------------------------*
           if        w-det-qta-pro-ctr    >    w-det-qta-pro-inx
                     go to exe-cph-lv2-upd-900.
           if        w-det-qta-pro-ctr    >    w-det-qta-pro-max
                     go to exe-cph-lv2-upd-900.
      *              *-------------------------------------------------*
      *              * Se la quantita' assegnata e' a zero: ad uscita  *
      *              *-------------------------------------------------*
           if        w-det-qta-pro-qas    =    zero
                     go to exe-cph-lv2-upd-900.
       exe-cph-lv2-upd-300.
      *              *-------------------------------------------------*
      *              * Ottenimento record [bfs]                        *
      *              *-------------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "NUMPRT    "         to   f-key                  .
           move      w-slc-num-bft-prt    to   rf-bfs-num-prt         .
           move      w-det-qta-pro-prg
                    (w-det-qta-pro-ctr)   to   rf-bfs-num-prg         .
           move      zero                 to   rf-bfs-num-prr         .
           move      "pgm/bfo/fls/ioc/obj/iofbfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfs                 .
      *                  *---------------------------------------------*
      *                  * Se record non trovato: a scrittura          *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exe-cph-lv2-upd-700.
       exe-cph-lv2-upd-400.
      *              *-------------------------------------------------*
      *              * Aggiornamento                                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Quantita' elemento in comodo                *
      *                  *---------------------------------------------*
           move      w-det-qta-pro-qta
                    (w-det-qta-pro-ctr)   to   w-det-qta-pro-qaz      .
      *                  *---------------------------------------------*
      *                  * Se la riga e' gia' spuntata: release        *
      *                  *---------------------------------------------*
           if        rf-bfs-flg-spn       not  = "S"
                     go to exe-cph-lv2-upd-420.
      *                  *---------------------------------------------*
      *                  * Aggiornamento quantita' assegnata           *
      *                  *---------------------------------------------*
            subtract w-det-qta-pro-qaz    from w-det-qta-pro-qas      .
      *                  *---------------------------------------------*
      *                  * Rilascio record [bfs]                       *
      *                  *---------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/bfo/fls/ioc/obj/iofbfs"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-bfs                 .
      *                  *---------------------------------------------*
      *                  * A riga successiva                           *
      *                  *---------------------------------------------*
           go to     exe-cph-lv2-upd-200.
       exe-cph-lv2-upd-420.
      *                  *---------------------------------------------*
      *                  * Data di sistema                             *
      *                  *---------------------------------------------*
           move      w-exe-dat-exe        to   rf-bfs-ide-dat         .
      *                  *---------------------------------------------*
      *                  * Deviazione in funzione della quantita'      *
      *                  * assegnata                                   *
      *                  *---------------------------------------------*
           if        w-det-qta-pro-qas    >    w-det-qta-pro-qaz
                     go to exe-cph-lv2-upd-440
           else if   w-det-qta-pro-qas    =    w-det-qta-pro-qaz
                     go to exe-cph-lv2-upd-440
           else      go to exe-cph-lv2-upd-460.
       exe-cph-lv2-upd-440.
      *              *-------------------------------------------------*
      *              * Se quantita' assegnata maggiore di quella in    *
      *              * riga o uguale                                   *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Responsabile                                *
      *                  *---------------------------------------------*
           move      w-exe-cnv-rsm        to   rf-bfs-cod-rsm         .
      *                  *---------------------------------------------*
      *                  * Spunta totale della riga                    *
      *                  *---------------------------------------------*
            move     w-det-qta-pro-qaz    to   rf-bfs-qta-ril         .
            move     "S"                  to   rf-bfs-flg-spn         .
      *                  *---------------------------------------------*
      *                  * Aggiornamento quantita' assegnata           *
      *                  *---------------------------------------------*
            subtract w-det-qta-pro-qaz    from w-det-qta-pro-qas      .
      *                  *---------------------------------------------*
      *                  * A update                                    *
      *                  *---------------------------------------------*
            go to    exe-cph-lv2-upd-500.
       exe-cph-lv2-upd-460.
      *              *-------------------------------------------------*
      *              * Se quantita' assegnata minore di quella in riga *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Responsabile                                *
      *                  *---------------------------------------------*
           move      w-exe-cnv-rsm        to   rf-bfs-cod-rsm         .
      *                  *---------------------------------------------*
      *                  * Spunta parziale della riga                  *
      *                  *---------------------------------------------*
            move     w-det-qta-pro-qas    to   rf-bfs-qta-ril         .
            move     spaces               to   rf-bfs-flg-spn         .
      *                  *---------------------------------------------*
      *                  * Aggiornamento quantita' assegnata           *
      *                  *---------------------------------------------*
            move     zero                 to   w-det-qta-pro-qas      .
      *                  *---------------------------------------------*
      *                  * A update                                    *
      *                  *---------------------------------------------*
            go to    exe-cph-lv2-upd-500.
       exe-cph-lv2-upd-500.
      *              *-------------------------------------------------*
      *              * Aggiornamento record [bfs]                      *
      *              *-------------------------------------------------*
           perform   upd-rec-bfs-000      thru upd-rec-bfs-999        .
       exe-cph-lv2-upd-600.
      *              *-------------------------------------------------*
      *              * A riciclo su elemento tabella successivo        *
      *              *-------------------------------------------------*
           go to     exe-cph-lv2-upd-200.
       exe-cph-lv2-upd-700.
      *              *-------------------------------------------------*
      *              * Se record [bfs] non trovato                     *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Scrittura record [bfs] normalizzato         *
      *                  *---------------------------------------------*
           perform   nor-rec-bfs-000      thru nor-rec-bfs-999        .
      *                  *---------------------------------------------*
      *                  * Ritorno a scrittura                         *
      *                  *---------------------------------------------*
           go to     exe-cph-lv2-upd-300.
       exe-cph-lv2-upd-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     exe-cph-lv2-upd-999.
       exe-cph-lv2-upd-999.
           exit.

