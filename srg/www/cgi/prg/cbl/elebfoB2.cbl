      *              *-------------------------------------------------*
           move      "01"                 to   w-exe-dpz-prt          .
      *              *-------------------------------------------------*
      *              * Assemblaggio                                    *
      *              *-------------------------------------------------*
           move      11                   to   w-all-str-lun          .
           move      04                   to   w-all-str-num          .
           move      w-exe-saa-prt        to   w-all-str-cat (1)      .
           move      w-exe-dpz-prt        to   w-all-str-cat (2)      .
      *
