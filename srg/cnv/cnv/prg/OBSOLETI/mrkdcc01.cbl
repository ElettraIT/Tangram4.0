           move      "CODCFL    "         to   f-key                  .
           move      rf-cli-cod-cmn       to   rf-gxc-cod-cmn         .
           move      zero                 to   rf-gxc-cod-fzn         .
           move      zero                 to   rf-gxc-cod-lct         .
           move      "pgm/geo/fls/ioc/obj/iofgxc"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-gxc                 .
           if        f-sts                not  = e-not-err
                     go to det-zon-dcc-900.
       det-zon-dcc-100.
      *              *-------------------------------------------------*
      *              * Start su file [zst]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "DESKEY    "         to   f-key                  .
           move      01                   to   rf-zst-tip-cls         .
           move      rf-gxc-des-ord       to   rf-zst-des-key         .
           move      zero                 to   rf-zst-cod-cls         .
           move      "pgm/dcc/fls/ioc/obj/iofzst"
                                          to   s-pat                  .
