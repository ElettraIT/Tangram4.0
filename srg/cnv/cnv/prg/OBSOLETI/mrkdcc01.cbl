      *              *-------------------------------------------------*
           if        rf-gxp-cod-prv       =    "AG "
                     move  02803          to   w-det-zon-dcc-cod
           else if   rf-gxp-cod-prv       =    "AL "
                     move  01003          to   w-det-zon-dcc-cod
           else if   rf-gxp-cod-prv       =    "AN "
                     move  01901          to   w-det-zon-dcc-cod
           else if   rf-gxp-cod-prv       =    "AO "
                     move  01102          to   w-det-zon-dcc-cod
           else if   rf-gxp-cod-prv       =    "AR "
                     move  01803          to   w-det-zon-dcc-cod
           else if   rf-gxp-cod-prv       =    "AP "
                     move  01903          to   w-det-zon-dcc-cod
           else if   rf-gxp-cod-prv       =    "AT "
                     move  01005          to   w-det-zon-dcc-cod
           else if   rf-gxp-cod-prv       =    "AV "
                     move  02403          to   w-det-zon-dcc-cod
           else if   rf-gxp-cod-prv       =    "BA "
                     move  02501          to   w-det-zon-dcc-cod
           else if   rf-gxp-cod-prv       =    "BL "
                     move  01503          to   w-det-zon-dcc-cod
           else if   rf-gxp-cod-prv       =    "PD "
                     move  01505          to   w-det-zon-dcc-cod
           else if   rf-gxp-cod-prv       =    "TV "
                     move  01509          to   w-det-zon-dcc-cod
           else if   rf-gxp-cod-prv       =    "VE "
                     move  01501          to   w-det-zon-dcc-cod
           else if   rf-gxp-cod-prv       =    "VR "
                     move  01511          to   w-det-zon-dcc-cod
           else if   rf-gxp-cod-prv       =    "VR "
                     move  01511          to   w-det-zon-dcc-cod


           else      move  zero           to   w-det-zon-dcc-cod      .


           if        w-det-zon-dcc-cod    >    zero
                     and  rf-gxc-snx-cpp  =    "N"
                     add  1               to   w-det-zon-dcc-cod      .
           
           if        w-det-zon-dcc-cod    >    zero
