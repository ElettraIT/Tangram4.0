       prn-fin-lr2-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Inizio 1. livello di rottura       *
      *    *-----------------------------------------------------------*
       prn-ini-lr1-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
      *              *-------------------------------------------------*
      *              * Normalizzazione variabili di comodo             *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-sld-mms-inx      .
       prn-ini-lr1-200.
           add       1                    to   w-det-sld-mms-inx      .
           if        w-det-sld-mms-inx    >    10
                     go to prn-ini-lr1-400.
      *                  *---------------------------------------------*
      *                  * Sub-ciclo                                   *
      *                  *---------------------------------------------*
           move      zero                 to   w-det-sld-mms-in2      .
       prn-ini-lr1-220.
           add       1                    to   w-det-sld-mms-in2      .
           if        w-det-sld-mms-in2    >    03
                     go to prn-ini-lr1-200.
           move      zero                 to   w-det-sld-mms-sld
                                              (w-det-sld-mms-inx,
                                               w-det-sld-mms-in2)     .
      *
           go to     prn-ini-lr1-220.
      *
           go to     prn-ini-lr1-200.
       prn-ini-lr1-400.
      *              *-------------------------------------------------*
      *              * Determinazione saldo da scheda 2005             *
      *              *-------------------------------------------------*
           perform   det-sld-mms-000      thru det-sld-mms-999        .
       prn-ini-lr1-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Fine 1. livello di rottura         *
      *    *-----------------------------------------------------------*
       prn-fin-lr1-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
       prn-fin-lr1-999.
           exit.

      *    *===========================================================*
      *    * Ciclo Report Program : Livello di dettaglio               *
      *    *-----------------------------------------------------------*
       prn-liv-det-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
      *              *-------------------------------------------------*
      *              * Aggiornamento contatore                         *
      *              *-------------------------------------------------*
           add       1                    to   w-wrk-ctr-001          .
      *              *-------------------------------------------------*
      *              * Visualizzazione contatore                       *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      23                   to   v-car                  .
           move      10                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Contatore record      :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      11                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<BG"                to   v-edm                  .
           move      10                   to   v-lin                  .
           move      47                   to   v-pos                  .
           move      w-wrk-ctr-001        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Lettura movimenti [mmr]                         *
      *              *-------------------------------------------------*
           perform   let-mov-mmr-000      thru let-mov-mmr-999        .
       prn-liv-det-200.
      *              *-------------------------------------------------*
      *              * Ricostruzione rimanenze finali                  *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-sld-mms-inx      .
           move      w-det-sld-mms-qta    to   w-det-sld-mms-rix      .
       prn-liv-det-220.
           add       1                    to   w-det-sld-mms-inx      .
           if        w-det-sld-mms-inx    >    10
                     go to prn-liv-det-400.
      *                  *---------------------------------------------*
      *                  * I elemento (2004)                           *
      *                  *---------------------------------------------*
           if        w-det-sld-mms-inx    =    01
                     move  w-det-sld-mms-rix
                                          to   w-det-sld-mms-rim
                                              (w-det-sld-mms-inx)
                     go to prn-liv-det-220.
      *                  *---------------------------------------------*
      *                  * Riporto rimanenza                           *
      *                  *---------------------------------------------*
           move      w-det-sld-mms-inx    to   w-det-sld-mms-in3      .
           subtract  1                    from w-det-sld-mms-in3      .
      *
           move      w-det-sld-mms-rix    to   w-det-sld-mms-rim
                                              (w-det-sld-mms-inx)     .
           subtract  w-det-sld-mms-sld
                    (w-det-sld-mms-in3)   from w-det-sld-mms-rim
                                              (w-det-sld-mms-inx)     .
           move      w-det-sld-mms-rim
                    (w-det-sld-mms-inx)   to   w-det-sld-mms-rix      .
      *                  *---------------------------------------------*
      *                  * Riciclo                                     *
      *                  *---------------------------------------------*
           go to     prn-liv-det-220.
       prn-liv-det-400.
      *              *-------------------------------------------------*
      *              * Ricostruzione rimanenze finali 2005             *
      *              *-------------------------------------------------*
           perform   agg-scg-lif-000      thru agg-scg-lif-999        .
       prn-liv-det-999.
           exit.

      *    *===========================================================*
      *    * Determinazione saldo 2005 [mms]                           *
      *    *-----------------------------------------------------------*
       det-sld-mms-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione valore di uscita                *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-sld-mms-qta      .
       det-sld-mms-100.
      *              *-------------------------------------------------*
      *              * Scansione 3 dipendenze                          *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-sld-mms-ctr      .
       det-sld-mms-200.
           add       1                    to   w-det-sld-mms-ctr      .
           if        w-det-sld-mms-ctr    >    3
                     go to det-sld-mms-900.
       det-sld-mms-300.
      *              *-------------------------------------------------*
      *              * Normalizzazione [mms]                           *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmms"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mms                 .
      *              *-------------------------------------------------*
      *              * Lettura                                         *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "DPMGDS    "         to   f-key                  .
           move      105                  to   rf-mms-ann-ese         .
           move      w-det-sld-mms-ctr    to   rf-mms-cod-dpz         .
           move      01                   to   rf-mms-tip-mag         .
           move      w-rot-l01-num-pro    to   rf-mms-num-mag         .
           move      spaces               to   rf-mms-var-mag         .
           move      spaces               to   rf-mms-cod-dsl         .
           move      "pgm/mag/fls/ioc/obj/iofmms"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mms                 .
           if        f-sts                not  = e-not-err
                     go to det-sld-mms-800.
       det-sld-mms-600.
      *              *-------------------------------------------------*
      *              * Aggiornamento quantita'                         *
      *              *-------------------------------------------------*
           add       rf-mms-qta-ini       to   w-det-sld-mms-qta
                                              (w-det-sld-mms-ctr)     .
       det-sld-mms-800.
      *              *-------------------------------------------------*
      *              * Riciclo                                         *
      *              *-------------------------------------------------*
           go to     det-sld-mms-200.
       det-sld-mms-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-sld-mms-999.
       det-sld-mms-999.
           exit.

      *    *===========================================================*
      *    * Lettura [mmr]                                             *
      *    *-----------------------------------------------------------*
       let-mov-mmr-000.
      *              *-------------------------------------------------*
      *              * Visualizzazione messaggio                       *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      23                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Ricostruzione saldi   :"
                                          to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
      *              *-------------------------------------------------*
      *              * Visualizzazione Codice prodotto                 *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      14                   to   v-car                  .
           move      12                   to   v-lin                  .
           move      25                   to   v-pos                  .
           move      rf-dcp-alf-pro       to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       let-mov-mmr-100.
      *              *-------------------------------------------------*
      *              * Start su file [mmr]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "MAGDAT    "         to   f-key                  .
           move      01                   to   rf-mmr-tip-mag         .
           move      rf-dcp-num-pro       to   rf-mmr-num-mag         .
           move      zero                 to   rf-mmr-dat-reg         .
           move      zero                 to   rf-mmr-num-prt         .
           move      zero                 to   rf-mmr-num-prg         .
           move      "pgm/mag/fls/ioc/obj/iofmmr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmr                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to let-mov-mmr-900.
       let-mov-mmr-200.
      *              *-------------------------------------------------*
      *              * Lettura [mmr]                                   *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmmr"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmr                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to let-mov-mmr-900.
       let-mov-mmr-300.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
           if        rf-mmr-tip-mag       not  = 01 or
                     rf-mmr-num-mag       not  = rf-dcp-num-pro
                     go to let-mov-mmr-900.
       let-mov-mmr-400.
      *              *-------------------------------------------------*
      *              * Selezione                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su data registrazione                  *
      *                  *---------------------------------------------*
           if        rf-mmr-dat-reg       >    1041231
                     go to let-mov-mmr-200.
           if        rf-mmr-dat-reg       <    0950101
                     go to let-mov-mmr-200.
      *                  *---------------------------------------------*
      *                  * Test su causale                             *
      *                  *---------------------------------------------*
           if        rf-mmr-cod-cau       =    00100 or
                     rf-mmr-cod-cau       =    00110 or
                     rf-mmr-cod-cau       =    00200 or
                     rf-mmr-cod-cau       =    00202 or
                     rf-mmr-cod-cau       =    00205 or
                     rf-mmr-cod-cau       =    00207 or
                     rf-mmr-cod-cau       =    00210 or
                     rf-mmr-cod-cau       =    00215 or
                     rf-mmr-cod-cau       =    00710 or
                     rf-mmr-cod-cau       =    00720 or
                     rf-mmr-cod-cau       =    00880 or
                     rf-mmr-cod-cau       =    00900 or
                     rf-mmr-cod-cau       =    00901
                     go to let-mov-mmr-500.
           go to     let-mov-mmr-200.
       let-mov-mmr-500.
      *              *-------------------------------------------------*
      *              * Determinazione del segno                        *
      *              *-------------------------------------------------*
           if        rf-mmr-tip-mdm       =    01
                     move  "C"            to   w-det-sld-mms-sgn
           else if   rf-mmr-tip-mdm       =    02
                     move  "S"            to   w-det-sld-mms-sgn
           else      go to let-mov-mmr-200.
       let-mov-mmr-600.
      *              *-------------------------------------------------*
      *              * Accumulo quantita' per esercizio                *
      *              *-------------------------------------------------*
           move      rf-mmr-dat-reg       to   s-dat                  .
           move      s-saa                to   w-det-sld-mms-ese      .
      *              *-------------------------------------------------*
      *              * Determinazione indice                           *
      *              *-------------------------------------------------*
           if        w-det-sld-mms-ese    =    095
                     move  10             to   w-det-sld-mms-in2
           else if   w-det-sld-mms-ese    =    096
                     move  09             to   w-det-sld-mms-in2
           else if   w-det-sld-mms-ese    =    097
                     move  08             to   w-det-sld-mms-in2
           else if   w-det-sld-mms-ese    =    098
                     move  07             to   w-det-sld-mms-in2
           else if   w-det-sld-mms-ese    =    099
                     move  06             to   w-det-sld-mms-in2
           else if   w-det-sld-mms-ese    =    100
                     move  05             to   w-det-sld-mms-in2
           else if   w-det-sld-mms-ese    =    101
                     move  04             to   w-det-sld-mms-in2
           else if   w-det-sld-mms-ese    =    102
                     move  03             to   w-det-sld-mms-in2
           else if   w-det-sld-mms-ese    =    103
                     move  02             to   w-det-sld-mms-in2
           else if   w-det-sld-mms-ese    =    104
                     move  01             to   w-det-sld-mms-in2
           else      go to let-mov-mmr-200.
      *              *-------------------------------------------------*
      *              * Deviazione in base a 'carico' o 'scarico'       *
      *              *-------------------------------------------------*
           if        w-det-sld-mms-sgn    =    "C"
                     go to let-mov-mmr-620
           else      go to let-mov-mmr-640.
       let-mov-mmr-620.
      *              *-------------------------------------------------*
      *              * Se carico                                       *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Incremento                                  *
      *                  *---------------------------------------------*
           add       rf-mmr-qta-mov       to   w-det-sld-mms-sld
                                              (w-det-sld-mms-in2)     .
      *                  *---------------------------------------------*
      *                  * A riciclo                                   *
      *                  *---------------------------------------------*
           go to     let-mov-mmr-800.
       let-mov-mmr-640.
      *              *-------------------------------------------------*
      *              * Se scarico                                      *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Decremento                                  *
      *                  *---------------------------------------------*
           subtract  rf-mmr-qta-mov       from w-det-sld-mms-sld
                                              (w-det-sld-mms-in2)     .
      *                  *---------------------------------------------*
      *                  * A riciclo                                   *
      *                  *---------------------------------------------*
           go to     let-mov-mmr-800.
       let-mov-mmr-800.
      *              *-------------------------------------------------*
      *              * Riciclo su [mmr]                                *
      *              *-------------------------------------------------*
           go to     let-mov-mmr-200.
       let-mov-mmr-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     let-mov-mmr-999.
       let-mov-mmr-999.
           exit.

      *    *===========================================================*
      *    * Aggiornamento scaglioni LIFO - esercizio 2005             *
      *    *-----------------------------------------------------------*
       agg-scg-lif-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione record [mmv]                    *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmmv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmv                 .
      *              *-------------------------------------------------*
      *              * Lettura record [mmv]                            *
      *              *-------------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "ESECOD    "         to   f-key                  .
           move      105                  to   rf-mmv-ann-ese         .
           move      01                   to   rf-mmv-tip-mag         .
           move      rf-dcp-num-pro       to   rf-mmv-num-mag         .
           move      "pgm/mag/fls/ioc/obj/iofmmv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmv                 .
      *                  *---------------------------------------------*
      *                  * Se record non trovato : ad uscita           *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-scg-lif-900.
       agg-scg-lif-600.
      *              *-------------------------------------------------*
      *              * Ciclo di aggiornamento                          *
      *              *-------------------------------------------------*
           move      zero                 to   w-det-sld-mms-inx      .
       agg-scg-lif-620.
           add       1                    to   w-det-sld-mms-inx      .
           if        w-det-sld-mms-inx    >    10
                     go to agg-scg-lif-700.
           move      w-det-sld-mms-rim
                    (w-det-sld-mms-inx)   to   rf-mmv-rim-pre
                                              (w-det-sld-mms-inx)     .
      *
           go to     agg-scg-lif-620.
       agg-scg-lif-700.
      *              *-------------------------------------------------*
      *              * Update record                                   *
      *              *-------------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmmv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmv                 .
       agg-scg-lif-800.
      *              *-------------------------------------------------*
      *              * Release record                                  *
      *              *-------------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/mag/fls/ioc/obj/iofmmv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-mmv                 .
       agg-scg-lif-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     agg-scg-lif-999.
       agg-scg-lif-999.
           exit.

