           move      w-det-vlb-sco (1)    to   rf-lst-per-sco (1)     .
           move      w-det-vlb-sco (2)    to   rf-lst-per-sco (2)     .
           move      w-det-vlb-sco (3)    to   rf-lst-per-sco (3)     .
           move      w-det-vlb-sco (4)    to   rf-lst-per-sco (4)     .
           move      w-det-vlb-sco (5)    to   rf-lst-per-sco (5)     .
      *                      *-----------------------------------------*
      *                      * Altri dati                              *
      *                      *-----------------------------------------*
           move      "S"                  to   rf-lst-snx-prz         .
           move      "N"                  to   rf-lst-snx-pvg         .
           move      "N"                  to   rf-lst-snx-sco         .
           move      zero                 to   rf-lst-dva-ini         .
           move      zero                 to   rf-lst-dva-fin         .
           move      zero                 to   rf-lst-qta-rif         .
           move      spaces               to   rf-lst-alx-exp         .
       cmp-rec-lst-999.
           exit.

      *    *===========================================================*
      *    * Scrittura record [lst]                                    *
      *    *-----------------------------------------------------------*
       wrt-rec-lst-000.
      *              *-------------------------------------------------*
      *              * Composizione record                             *
      *              *-------------------------------------------------*
           perform   cmp-rec-lst-000      thru cmp-rec-lst-999        .
      *              *-------------------------------------------------*
      *              * Put record                                      *
      *              *-------------------------------------------------*
           move      "PT"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
       wrt-rec-lst-999.
           exit.

      *    *===========================================================*
      *    * Aggiornamento record [lst]                                *
      *    *-----------------------------------------------------------*
       agg-rec-lst-000.
      *              *-------------------------------------------------*
      *              * Lettura record con lock                         *
      *              *-------------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "LSTPRO    "         to   f-key                  .
           move      01                   to   rf-lst-tip-rec         .
           move      "LDA"                to   rf-lst-cod-lst         .
           move      zero                 to   rf-lst-cod-cli         .
           move      c-sgl                to   rf-lst-sgl-vlt         .
           move      rf-dcp-num-pro       to   rf-lst-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'esito della let-  *
      *                  * tura                                        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-rec-lst-400.
       agg-rec-lst-200.
      *                  *---------------------------------------------*
      *                  * Se record esistente                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Aggiornamento                           *
      *                      *-----------------------------------------*
           move      w-det-vlb-prz        to   rf-lst-prz-lst         .
           move      w-det-vlb-sco (1)    to   rf-lst-per-sco (1)     .
           move      w-det-vlb-sco (2)    to   rf-lst-per-sco (2)     .
           move      w-det-vlb-sco (3)    to   rf-lst-per-sco (3)     .
           move      w-det-vlb-sco (4)    to   rf-lst-per-sco (4)     .
           move      w-det-vlb-sco (5)    to   rf-lst-per-sco (5)     .
       agg-rec-lst-220.
      *                      *-----------------------------------------*
      *                      * Update del record                       *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
       agg-rec-lst-230.
      *                      *-----------------------------------------*
      *                      * Unlock del record                       *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
       agg-rec-lst-240.
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     agg-rec-lst-900.
       agg-rec-lst-400.
      *                  *---------------------------------------------*
      *                  * Se record non esistente                     *
      *                  *---------------------------------------------*
           perform   wrt-rec-lst-000      thru wrt-rec-lst-999        .
       agg-rec-lst-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     agg-rec-lst-999.
       agg-rec-lst-999.
           exit.

      *    *===========================================================*
      *    * Determinazione % unica da max 5 % distinte                *
      *    *                                                           *
      *    * Input  : w-det-per-uni-001     = 1.a percentuale          *
      *    *          w-det-per-uni-002     = 2.a percentuale          *
      *    *          w-det-per-uni-003     = 3.a percentuale          *
      *    *          w-det-per-uni-004     = 4.a percentuale          *
      *    *          w-det-per-uni-005     = 5.a percentuale          *
      *    *                                                           *
      *    * Output : w-det-per-uni-per     = Unica percentuale        *
      *    *                                                           *
      *    *-----------------------------------------------------------*
       det-per-uni-000.
           move      100                  to   w-det-per-uni-w01      .
           move      zero                 to   w-det-per-uni-w02      .
      *
           multiply  w-det-per-uni-001    by   w-det-per-uni-w01
                                        giving w-det-per-uni-w03      .
           divide    100                  into w-det-per-uni-w03      .
           subtract  w-det-per-uni-w03    from w-det-per-uni-w01      .
           add       w-det-per-uni-w03    to   w-det-per-uni-w02      .
      *
           multiply  w-det-per-uni-002    by   w-det-per-uni-w01
                                        giving w-det-per-uni-w03      .
           divide    100                  into w-det-per-uni-w03      .
           subtract  w-det-per-uni-w03    from w-det-per-uni-w01      .
           add       w-det-per-uni-w03    to   w-det-per-uni-w02      .
      *
           multiply  w-det-per-uni-003    by   w-det-per-uni-w01
                                        giving w-det-per-uni-w03      .
           divide    100                  into w-det-per-uni-w03      .
           subtract  w-det-per-uni-w03    from w-det-per-uni-w01      .
           add       w-det-per-uni-w03    to   w-det-per-uni-w02      .
      *
           multiply  w-det-per-uni-004    by   w-det-per-uni-w01
                                        giving w-det-per-uni-w03      .
           divide    100                  into w-det-per-uni-w03      .
           subtract  w-det-per-uni-w03    from w-det-per-uni-w01      .
           add       w-det-per-uni-w03    to   w-det-per-uni-w02      .
      *
           multiply  w-det-per-uni-005    by   w-det-per-uni-w01
                                        giving w-det-per-uni-w03      .
           divide    100                  into w-det-per-uni-w03      .
           subtract  w-det-per-uni-w03    from w-det-per-uni-w01      .
           add       w-det-per-uni-w03    to   w-det-per-uni-w02      .
      *
           move      w-det-per-uni-w02    to   w-det-per-uni-per      .
       det-per-uni-999.
           exit.

