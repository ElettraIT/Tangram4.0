       main-000.
      *              *-------------------------------------------------*
      *              * Richiesta a segreteria di sequenzializzazione   *
      *              *-------------------------------------------------*
           move      "PO"                 to   s-ope                  .
           move      "pdx"                to   s-nam                  .
           move      "KS"                 to   s-sts                  .
           move      zero                 to   s-num                  .
           move      spaces               to   s-pat                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       main-100.
      *              *-------------------------------------------------*
      *              * [pdx]                                           *
      *              *-------------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
      *              *-------------------------------------------------*
      *              * [pdx]                                           *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
       main-200.
      *              *-------------------------------------------------*
      *              * Sostituzione del "vecchio" 'iofpdx' col nuovo   *
      *              *-------------------------------------------------*
           move      "cp /abd/asc/tmp/iofpdx /abd/ogt/pgm/dcp/fls/ioc/ob
      -              "j/iofpdx"           to   o-shs                  .
      *              *-------------------------------------------------*
      *              * Richiamo del modulo 'mopsys'                    *
      *              *-------------------------------------------------*
           move      "SH"                 to   o-ope                  .
           call      "swd/mod/prg/obj/mopsys"
                                         using o                      .
       main-300.
      *              *-------------------------------------------------*
      *              * Codice azienda da segreteria                    *
      *              *-------------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
       main-400.
      *              *-------------------------------------------------*
      *              * Rinomina del file [pdx] obsoleto                *
      *              *-------------------------------------------------*
           move      spaces               to   o-shs                  .
      *
           string    "mv /abd/azi/"  
                                delimited by   size
                     s-azi
                                delimited by   spaces
                     "/pdx /abd/azi/"
                                delimited by   size
                     s-azi
                                delimited by   spaces
                     "/SAV.pdx"
                                delimited by   size
                                          into o-shs                  .
      *              *-------------------------------------------------*
      *              * Richiamo del modulo 'mopsys'                    *
      *              *-------------------------------------------------*
           move      "SH"                 to   o-ope                  .
           call      "swd/mod/prg/obj/mopsys"
                                         using o                      .
       main-500.
      *              *-------------------------------------------------*
      *              * Richiesta a segreteria di indicizzazione        *
      *              *-------------------------------------------------*
           move      "PO"                 to   s-ope                  .
           move      "pdx"                to   s-nam                  .
           move      "SJ"                 to   s-sts                  .
           move      zero                 to   s-num                  .
           move      spaces               to   s-pat                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * [pdx]                                           *
      *              *-------------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
      *              *-------------------------------------------------*
      *              * [pdx]                                           *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofpdx"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-pdx                 .
       main-800.
      *              *-------------------------------------------------*
      *              * Codice azienda da segreteria                    *
      *              *-------------------------------------------------*
           move      "IG"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
      *              *-------------------------------------------------*
      *              * Rimozione del file sequenziale                  *
      *              *-------------------------------------------------*
           move      spaces               to   o-shs                  .
      *
           string    "rm /abd/asc/"  
                                delimited by   size
                     s-azi
                                delimited by   spaces
                     "pdx.sqz"
                                delimited by   size
                                          into o-shs                  .
      *              *-------------------------------------------------*
      *              * Richiamo del modulo 'mopsys'                    *
      *              *-------------------------------------------------*
           move      "SH"                 to   o-ope                  .
           call      "swd/mod/prg/obj/mopsys"
                                         using o                      .
       main-999.
           exit      program                                          .

