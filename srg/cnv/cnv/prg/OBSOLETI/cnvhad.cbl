      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Open file [old-had]                         *
      *                  *---------------------------------------------*
           open      i-o    had                                       .
      *                  *---------------------------------------------*
      *                  * Open file [new-had]                         *
      *                  *---------------------------------------------*
           move      "OP"                 to   f-ope                  .
           move      f-xxx-obj            to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-had                 .
       exe-cnv-had-200.
