           move      "pgm/mag/num/ioc/obj/indatinv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-dat-inv             .
           move      "NO"                 to   f-ope                  .
           move      "pgm/mag/num/ioc/obj/indatinv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-dat-inv             .
           move      "RD"                 to   f-ope                  .
           move      "pgm/mag/num/ioc/obj/indatinv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-dat-inv             .
           move      "CL"                 to   f-ope                  .
           move      "pgm/mag/num/ioc/obj/indatinv"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rn-dat-inv             .
      *              *-------------------------------------------------*
