      *    *===========================================================*
      *    * Esportazione [cli]                                        *
      *    *                                                           *
      *    * Subroutine per arrotondamento prezzi                      *
      *    *-----------------------------------------------------------*
       exe-exp-cli-arr-000.
      *              *-------------------------------------------------*
      *              * Arrotondamenti                                  *
      *              *-------------------------------------------------*
       exe-exp-cli-arr-420.
      *                  *---------------------------------------------*
      *                  * Arrotondamento eventuale del prezzo di ven- *
      *                  * dita come segue :                           *
      *                  *                                             *
      *                  *  - fino a     100 = 1                       *
      *                  *  - fino a  10.000 = 5                       *
      *                  *  - fino a  50.000 = 10                      *
      *                  *  - fino a 9999999 = 100                     *
      *                  *                                             *
      *                  * N.B. : L'arrotondamento presume 2 decimali  *
      *                  *        per il prezzo di vendita             *
      *                  *---------------------------------------------*
           if        rf-cli-prz-lst    >    5000000
                     go to exe-exp-cli-arr-422
           else if   rf-cli-prz-lst    >    1000000
                     go to exe-exp-cli-arr-424
           else if   rf-cli-prz-lst    >    10000
                     go to exe-exp-cli-arr-426
           else      go to exe-exp-cli-arr-900.
       exe-exp-cli-arr-422.
      *                  *---------------------------------------------*
      *                  * Oltre 50.000                                *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Analisi del prezzo                      *
      *                      *-----------------------------------------*
           move      rf-cli-prz-lst
                    (6 : 4)               to   w-det-val-wrk-c04      .
           if        w-det-val-wrk-c04    =    zero
                     go to exe-exp-cli-arr-900.
           subtract  w-det-val-wrk-c04    from rf-cli-prz-lst      .
           add       10000                to   rf-cli-prz-lst      .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     exe-exp-cli-arr-900.
       exe-exp-cli-arr-424.
      *                  *---------------------------------------------*
      *                  * Da 10.001 a 50.000                          *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Analisi del prezzo                      *
      *                      *-----------------------------------------*
           move      rf-cli-prz-lst
                    (7 : 3)               to   w-det-val-wrk-c03      .
           if        w-det-val-wrk-c03    =    zero
                     go to exe-exp-cli-arr-900.
           subtract  w-det-val-wrk-c03    from rf-cli-prz-lst      .
           add       1000                 to   rf-cli-prz-lst      .
      *                      *-----------------------------------------*
      *                      * Ad uscita                               *
      *                      *-----------------------------------------*
           go to     exe-exp-cli-arr-900.
       exe-exp-cli-arr-426.
      *                  *---------------------------------------------*
      *                  * Da 101 a 10.000                             *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Analisi del prezzo                      *
      *                      *-----------------------------------------*
           move      rf-cli-prz-lst
                    (7 : 3)               to   w-det-val-wrk-c03      .
           if        w-det-val-wrk-c03    =    zero
                     go to exe-exp-cli-arr-900.
           if        w-det-val-wrk-c03    <    500
