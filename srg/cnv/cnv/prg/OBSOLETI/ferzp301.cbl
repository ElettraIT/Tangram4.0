      *    *===========================================================*
      *    * Ciclo Report Program : Livello di dettaglio               *
      *    *-----------------------------------------------------------*
       prn-liv-det-000.
      *              *-------------------------------------------------*
      *              * Normalizzazione flag di interruzione forzata    *
      *              *-------------------------------------------------*
           move      spaces               to   w-cnt-prn-flg-int      .
      *              *-------------------------------------------------*
      *              * Test su apposita tabella                        *
      *              *-------------------------------------------------*
           move      rf-zp3-cod-cla       to   w-det-upd-zp3-cla      .
           move      rf-zp3-cod-gru       to   w-det-upd-zp3-gru      .
           move      rf-zp3-cod-sgr       to   w-det-upd-zp3-sgr      .
           perform   det-upd-zp3-000      thru det-upd-zp3-999        .
      *                  *---------------------------------------------*
      *                  * Test su flag di uscita                      *
      *                  *---------------------------------------------*
           if        w-det-upd-zp3-flg    =    spaces
                     go to prn-liv-det-800.
      *              *-------------------------------------------------*
      *              * Composizione del rullino messaggi               *
      *              *-------------------------------------------------*
           move      "WR"                 to   m-ope                  .
           move      spaces               to   m-msg                  .
           string    "["
                                delimited by   size
                     w-det-upd-zp3-cla
                                delimited by   size
                     "-"
                                delimited by   size
                     w-det-upd-zp3-gru
                                delimited by   size
                     "-"
                                delimited by   size
                     w-det-upd-zp3-sgr
                                delimited by   size
                     "] ("
                                delimited by   size
                     rf-zp3-des-sgr
                                delimited by   size
                     ") "
                                delimited by   size
                     rf-zp3-alx-exp
                    (04 : 01)
                                delimited by   size
                     " - "
                                delimited by   size
                     rf-zp3-alx-exp
                    (05 : 02)
                                delimited by   spaces
                                          into m-msg                  .
           call      "swd/mod/prg/obj/mmessg"
                                         using m                      .
      *              *-------------------------------------------------*
      *              * Update record [zp3]                             *
      *              *-------------------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofzp3"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zp3                 .
      *              *-------------------------------------------------*
      *              * Aggiornamento contatore                         *
      *              *-------------------------------------------------*
           add       1                    to   w-wrk-ctr-001          .
      *              *-------------------------------------------------*
      *              * Visualizzazione contatore                       *
      *              *-------------------------------------------------*
           move      "DS"                 to   v-ope                  .
           move      "A"                  to   v-tip                  .
           move      08                   to   v-car                  .
           move      18                   to   v-lin                  .
           move      01                   to   v-pos                  .
           move      "Record :"           to   v-alf                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
           move      "DS"                 to   v-ope                  .
           move      "N"                  to   v-tip                  .
           move      06                   to   v-car                  .
           move      zero                 to   v-dec                  .
           move      spaces               to   v-sgn                  .
           move      "<B"                 to   v-edm                  .
           move      18                   to   v-lin                  .
           move      10                   to   v-pos                  .
           move      w-wrk-ctr-001        to   v-num                  .
           call      "swd/mod/prg/obj/mvideo"
                                         using v                      .
       prn-liv-det-800.
      *              *-------------------------------------------------*
      *              * Rilascio del record                             *
      *              *-------------------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/iofzp3"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-zp3                 .
       prn-liv-det-900.
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     prn-liv-det-999.
       prn-liv-det-999.
           exit.

