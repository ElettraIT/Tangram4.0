      *    *===========================================================*
      *    * Input procedure per sort                                  *
      *    *-----------------------------------------------------------*
       stp-srt-inp-000.
      *              *-------------------------------------------------*
      *              * Start su file [haf]                             *
      *              *-------------------------------------------------*
           move      "SK"                 to   f-ope                  .
           move      "NL"                 to   f-cfr                  .
           move      "FNPFDA    "         to   f-key                  .
           move      rr-cod-fnt           to   rf-haf-cod-dcf         .
      *
           if        rr-cod-fnt           =    zero
                     move  spaces         to   rf-haf-fda-pif
           else      move  "N  "          to   rf-haf-fda-pif         .
      *
           move      zero                 to   rf-haf-num-pro         .
           move      "fer/gpa/fls/ioc/obj/iofhaf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-haf                 .
      *                  *---------------------------------------------*
      *                  * Test su esito operazione                    *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-100.
      *              *-------------------------------------------------*
      *              * Lettura sequenziale record [haf]                *
      *              *-------------------------------------------------*
           move      "RN"                 to   f-ope                  .
           move      "fer/gpa/fls/ioc/obj/iofhaf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-haf                 .
      *                  *---------------------------------------------*
      *                  * Test se 'At end'                            *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-999.
       stp-srt-inp-130.
      *              *-------------------------------------------------*
      *              * Test sul massimo                                *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice fornitore                    *
      *                  *---------------------------------------------*
           if        rr-cod-fnt           not  = zero   and
                     rf-haf-cod-dcf       not  = rr-cod-fnt 
                     go to stp-srt-inp-999.
      *                  *---------------------------------------------*
      *                  * Test su codice listino                      *
      *                  *---------------------------------------------*
           if        rr-cod-fnt           =    zero
                     go to stp-srt-inp-140.
           if        rf-haf-fda-pif       not  = "N  "
                     go to stp-srt-inp-999.
       stp-srt-inp-140.
      *              *-------------------------------------------------*
      *              * Selezione sul record                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test se listino negozio                     *
      *                  *---------------------------------------------*
           if        rf-haf-fda-pif       not  = "N  "
                     go to stp-srt-inp-100.
      *                  *---------------------------------------------*
      *                  * Test su ricarico                            *
      *                  *---------------------------------------------*
           if        rf-haf-prc-ctt       =    2,00
                     go to stp-srt-inp-100.
       stp-srt-inp-145.
      *              *-------------------------------------------------*
      *              * Lettura record [aaf]                            *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Normalizzazione                             *
      *                  *---------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcf/fls/ioc/obj/iofaaf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-aaf                 .
      *                  *---------------------------------------------*
      *                  * Lettura                                     *
      *                  *---------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "PRFNFM    "         to   f-key                  .
           move      01                   to   rf-aaf-tip-mag         .
           move      rf-haf-num-pro       to   rf-aaf-num-pro         .
           move      rf-haf-cod-dcf       to   rf-aaf-cod-dcf         .
           move      spaces               to   rf-aaf-fda-pif         .
           move      "pgm/dcf/fls/ioc/obj/iofaaf"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-aaf                 .
      *                      *-----------------------------------------*
      *                      * Se record non trovato : a riciclo       *
      *                      *-----------------------------------------*
           if        f-sts                not  = e-not-err
                     go to stp-srt-inp-100.
       stp-srt-inp-148.
      *                  *---------------------------------------------*
      *                  * Fornitore preferenziale                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione record [aaq]            *
