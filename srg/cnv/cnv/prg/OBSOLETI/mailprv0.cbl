      *              *-------------------------------------------------*
      *              * Normalizzazione record numerazione              *
      *              *-------------------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "fbg/gpf/fls/ioc/obj/iofhnu"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-hnu                 .
       det-dat-utr-400.
      *              *-------------------------------------------------*
      *              * Lettura numerazione senza lock                  *
      *              *-------------------------------------------------*
           move      "RK"                 to   f-ope                  .
           move      "NUMKEY    "         to   f-key                  .
           move      "expfil    "         to   rf-hnu-key-fix         .
           move      s-saa                to   rf-hnu-key-saa         .
           move      zero                 to   rf-hnu-key-prg         .
           move      spaces               to   rf-hnu-key-sgl         .
           move      "fbg/gpf/fls/ioc/obj/iofhnu"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-hnu                 .
      *              *-------------------------------------------------*
      *              * Valore letto in area per valore minimo          *
      *              *-------------------------------------------------*
           move      rf-hnu-dat-hnu       to   w-gen-dat-utr          .
       det-dat-utr-600.
      *              *-------------------------------------------------*
      *              * Close file numerazione                          *
      *              *-------------------------------------------------*
           move      "CL"                 to   f-ope                  .
           move      "fbg/gpf/fls/ioc/obj/iofhnu"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-hnu                 .
      *              *-------------------------------------------------*
      *              * Determinazione valore default per data iniziale *
      *              *-------------------------------------------------*
           if        w-gen-dat-utr        =    zero
                     go to det-dat-utr-900.
       det-dat-utr-800.
      *              *-------------------------------------------------*
      *              * Controllo data                                  *
      *              *-------------------------------------------------*
           move      "CD"                 to   s-ope                  .
           move      w-gen-dat-utr        to   s-dat                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                not  = spaces
                     move   zero          to   w-gen-dat-utr
                     go to det-dat-utr-900.
      *              *-------------------------------------------------*
      *              * Calcolo del giorno seguente                     *
      *              *-------------------------------------------------*
           add       1                    to   s-gio                  .
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                =    spaces
                     go to det-dat-utr-820.
           move      1                    to   s-gio                  .
           add       1                    to   s-mes                  .
           if        s-mes                not  > 12
                     go to det-dat-utr-820.
           move      1                    to   s-mes                  .
           if        s-ann                <    99
                     add   1              to   s-ann
                     go to det-dat-utr-820.
           move      zero                 to   s-ann                  .
           add       1                    to   s-sec                  .
       det-dat-utr-820.
      *              *-------------------------------------------------*
      *              * Data controllata                                *
      *              *-------------------------------------------------*
           move      s-dat                to   w-gen-dat-utr          .
       det-dat-utr-900.
      *              *-------------------------------------------------*
      *              * Se la data ottenuta e' maggiore di quella at-   *
      *              * tuale : data ultimo trasferimento a zero        *
      *              *-------------------------------------------------*
           if        w-gen-dat-utr        >    w-gen-dat-iep
                     move  zero           to   w-gen-dat-utr          .
      *              *-------------------------------------------------*
      *              * Uscita                                          *
      *              *-------------------------------------------------*
           go to     det-dat-utr-999.
       det-dat-utr-999.
           exit.

