      *                  *---------------------------------------------*
           if        w-stp-val-tot-vlt    =    c-sgl
                     go to stp-val-tot-100.
           if        w-stp-val-tot-tot    =    zero
                     go to stp-val-tot-100.
      *                  *---------------------------------------------*
      *                  * Editing                                     *
      *                  *---------------------------------------------*
           move      "ED"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           move      11                   to   p-car                  .
           move      c-dec                to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           move      "G<"                 to   p-edm                  .
           move      w-stp-val-tot-tot    to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * String                                      *
      *                  *---------------------------------------------*
           string    " ("
                                delimited by   size
                     c-sgl
                                delimited by   size
                     " "
                                delimited by   size
                     p-edt
                                delimited by   spaces
                     ")"
                                delimited by   size
                                          into w-stp-val-tot-x60
                                  with pointer w-stp-val-tot-pnt      .
       stp-val-tot-100.
      *              *-------------------------------------------------*
