           else      move  05             to   p-car                  .
           move      03                   to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           if        srt-qta-ord          >    99999 or
                     srt-qta-ord          <   -99999
                     move  "BD"           to   p-edm
           else      move  "GBD"          to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      060                  to   p-pos                  .
           move      srt-qta-ord          to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Quantita' gia' ricevuta                     *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           if        srt-qta-grc          >    99999 or
                     srt-qta-grc          <   -99999
                     move  06             to   p-car
           else      move  05             to   p-car                  .
           move      03                   to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           if        srt-qta-grc          >    99999 or
                     srt-qta-grc          <   -99999
                     move  "BD"           to   p-edm
           else      move  "GBD"          to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      071                  to   p-pos                  .
           move      srt-qta-grc          to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
