           move      "PF"                 to   p-ope                  .
           move      "N"                  to   p-tip                  .
           if        srt-qta-dev          >    99999 or
                     srt-qta-dev          <   -99999
                     move  06             to   p-car
           else      move  05             to   p-car                  .
           move      03                   to   p-dec                  .
           move      "S"                  to   p-sgn                  .
           if        srt-qta-dev          >    99999 or
                     srt-qta-dev          <   -99999
                     move  "BD"           to   p-edm
           else      move  "GBD"          to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      082                  to   p-pos                  .
           move      srt-qta-dev          to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
      *                  * Prezzo unitario                             *
      *                  *---------------------------------------------*
           move      "PF"                 to   p-ope                  .
           move      "V"                  to   p-tip                  .
           if        srt-prz-net          >    9999999
                     move  09             to   p-car
           else      move  07             to   p-car                  .
           move      srt-dec-vpf          to   p-dec                  .
           add       srt-dec-prz          to   p-dec                  .
           move      spaces               to   p-sgn                  .
           if        srt-prz-net          >    9999999
                     move  "B"            to   p-edm
           else      move  "BG"           to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      094                  to   p-pos                  .
           move      srt-prz-net          to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
