           else      move  "BG"           to   p-edm                  .
           move      p-lnr                to   p-lin                  .
           move      104                  to   p-pos                  .
           if        srt-dec-vpf          =    zero
                     add   1              to   p-pos                  .
           move      srt-imp-res          to   p-num                  .
           call      "swd/mod/prg/obj/mprint"
                                         using p                      .
      *                  *---------------------------------------------*
