                                         using s                      .
           call      s-pat               using f
                                               rf-oft                 .
      *                  *---------------------------------------------*
      *                  * Se fine file                                *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to exe-ass-orf-buf-900.
       exe-ass-orf-buf-300.
      *              *-------------------------------------------------*
      *              * Test Max                                        *
      *              *-------------------------------------------------*
      *                  *---------------------------------------------*
      *                  * Test su codice dipendenza                   *
      *                  *---------------------------------------------*
           if        rf-oft-cod-dpz       not  = 01
                     go to exe-ass-orf-buf-900.
