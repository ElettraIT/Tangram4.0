       agg-rec-lst-400.
      *                  *---------------------------------------------*
      *                  * Se record non esistente                     *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Normalizzazione record [lst]            *
      *                      *-----------------------------------------*
           move      "NO"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
      *                      *-----------------------------------------*
      *                      * Composizione record [lst]               *
      *                      *-----------------------------------------*
           move      01                   to   rf-lst-tip-rec         .
           move      "BL "                to   rf-lst-cod-lst         .
           move      zero                 to   rf-lst-cod-cli         .
           move      "EUR"                to   rf-lst-sgl-vlt         .
           move      2                    to   rf-lst-dec-vlt         .
           move      srt-num-pro          to   rf-lst-num-pro         .
      *                      *-----------------------------------------*
      *                      * Aggiornamento prezzo                    *
      *                      *-----------------------------------------*
