      *              * 'BL '                                           *
      *              *-------------------------------------------------*
       agg-rec-lst-100.
      *                  *---------------------------------------------*
      *                  * Lettura record da listino di destinazione,  *
      *                  * con lock                                    *
      *                  *---------------------------------------------*
           move      "GK"                 to   f-ope                  .
           move      "LSTPRO    "         to   f-key                  .
           move      01                   to   rf-lst-tip-rec         .
           move      "BL "                to   rf-lst-cod-lst         .
           move      zero                 to   rf-lst-cod-cli         .
           move      "EUR"                to   rf-lst-sgl-vlt         .
           move      srt-num-pro          to   rf-lst-num-pro         .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
      *                  *---------------------------------------------*
      *                  * Deviazione a seconda dell'esito della let-  *
      *                  * tura                                        *
      *                  *---------------------------------------------*
           if        f-sts                not  = e-not-err
                     go to agg-rec-lst-400.
       agg-rec-lst-200.
      *                  *---------------------------------------------*
      *                  * Se record esistente                         *
      *                  *---------------------------------------------*
      *                      *-----------------------------------------*
      *                      * Aggiornamento prezzo                    *
      *                      *-----------------------------------------*
           if        srt-prz-ven          =    zero
                     go to agg-rec-lst-230.
      *
           move      srt-prz-ven          to   w-det-scs-prz-n11      .
           divide    100                  into w-det-scs-prz-n11
                                       rounded                        .
           multiply  100                  by   w-det-scs-prz-n11
                                       rounded                        .
           move      w-det-scs-prz-n11    to   rf-lst-prz-lst         .
           divide    100                  into rf-lst-prz-lst         .
       agg-rec-lst-220.
      *                      *-----------------------------------------*
      *                      * Update del record                       *
      *                      *-----------------------------------------*
           move      "UP"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
           call      "swd/mod/prg/obj/mfiltp"
                                         using s                      .
           call      s-pat               using f
                                               rf-lst                 .
       agg-rec-lst-230.
      *                      *-----------------------------------------*
      *                      * Unlock del record                       *
      *                      *-----------------------------------------*
           move      "RL"                 to   f-ope                  .
           move      "pgm/dcp/fls/ioc/obj/ioflst"
                                          to   s-pat                  .
