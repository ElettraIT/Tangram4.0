      *    *===========================================================*
      *    * Regolarizzazione dei parametri di selezione               *
      *    *-----------------------------------------------------------*
       reg-ric-sel-000.
      *              *-------------------------------------------------*
      *              * Anno di esercizio                               *
      *              *-------------------------------------------------*
           move      101                  to   rr-ann-ese             .
      *              *-------------------------------------------------*
      *              * Mese iniziale                                   *
      *              *-------------------------------------------------*
           move      01                   to   rr-mes-ini             .
      *              *-------------------------------------------------*
      *              * Mese finale                                     *
      *              *-------------------------------------------------*
           move      rr-dat-max           to   s-dat                  .
           move      s-mes                to   rr-mes-fin             .
      *              *-------------------------------------------------*
      *              * Determinazione data iniziale                    *
      *              *-------------------------------------------------*
           move      01                   to   s-gio                  .
           move      rr-mes-ini           to   s-mes                  .
           move      rr-ann-ese           to   s-saa                  .
           move      s-dat                to   rr-dat-ini             .
       reg-ric-sel-200.
      *              *-------------------------------------------------*
      *              * Determinazione data finale                      *
      *              *-------------------------------------------------*
           move      31                   to   s-gio                  .
           move      rr-mes-fin           to   s-mes                  .
           move      rr-ann-ese           to   s-saa                  .
       reg-ric-sel-220.
           move      "CD"                 to   s-ope                  .
           call      "swd/mod/prg/obj/msegrt"
                                         using s                      .
           if        s-sts                not  =    spaces
                     subtract 1           from s-gio
                     go to reg-ric-sel-220.
           move      s-dat                to   rr-dat-fin             .
       reg-ric-sel-999.
           exit.

